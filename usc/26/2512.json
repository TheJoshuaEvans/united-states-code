{"tag":"section","attrib":{"id":"id45420a3c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2512"},"text":null,"children":[{"tag":"num","attrib":{"value":"2512"},"text":"§ 2512.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Valuation of gifts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45420a3d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2512/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the gift is made in property, the value thereof at the date of the gift shall be considered the amount of the gift.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45420a3e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2512/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Where property is transferred for less than an adequate and full consideration in money or money’s worth, then the amount by which the value of the property exceeded the value of the consideration shall be deemed a gift, and shall be included in computing the amount of gifts made during the calendar year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45420a3f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2512/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For individual’s right to be furnished on request a statement regarding any valuation made by the Secretary of a gift by that individual, see section 7517.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45420a40-3a70-11f1-a967-d35dac11796a"},"text":"(","children":