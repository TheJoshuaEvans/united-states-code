{"tag":"section","attrib":{"id":"id44e76794-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1301"},"text":null,"children":[{"tag":"num","attrib":{"value":"1301"},"text":"§ 1301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Averaging of farm income","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44e76795-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"At the election of an individual engaged in a farming business or fishing business, the tax imposed by section 1 for such taxable year shall be equal to the sum of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44e76796-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1301/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a tax computed under such section on taxable income reduced by elected farm income, plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44e76797-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1301/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the increase in tax imposed by section 1 which would result if taxable income for each of the 3 prior taxable years were increased by an amount equal to one-third of the elected farm income.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Any adjustment under this section for any taxable year shall be taken into account in applying this section for any subsequent taxable year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44e76798-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44e76799-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1301/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elected farm income","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44e7679a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1301/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “elected farm income” means so much of the taxable income for the taxable year—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44e7679b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1301/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is attributable to any farming business or fishing business; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44e7679c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1301/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is specified in the election under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44e7679d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1301/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of gains","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A), gain from the sale or other disposition of property (other than land) regularly used by the taxpayer in such a farming business or fishing business for a substantial period shall be treated as attributable to such a farming business or fishing business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44e7679e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1301/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individual","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “individual” shall not include any estate or trust.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44e7679f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1301/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Farming business","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “farming business” has the meaning given such term by section 263A(e)(4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44e767a0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1301/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fishing business","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “fishing business” means the conduct of commercial fishing as defined in section 3 of the Magnuson-Stevens Fishery Conservation and Management Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1802"},"text":"16 U.S.C. 1802","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44e767a1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1301/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prescribe such regulations as may be appropriate to carry out the purposes of this section, including regulations regarding—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44e767a2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1301/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the order and manner in which items of income, gain, deduction, or loss, or limitations on tax, shall be taken into account in computing the tax imposed by this chapter on the income of any taxpayer to whom this section applies for any taxable year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44e767a3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1301/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the treatment of any short taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44e767a4-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/tIX/s933/a"},"text":"Pub. L. 105–34, title IX, § 933(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/881"},"text":"111 Stat. 881","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tIII/s314/b"},"text":"Pub. L. 108–357, title III, § 314(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1468"},"text":"118 Stat. 1468","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44e767a5-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44e767a6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id44e767a7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1301, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/272/tII/s232/a"},"text":"Pub. L. 88–272, title II, § 232(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-02-26"},"text":"Feb. 26, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/106"},"text":"78 Stat. 106","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/tIII/s311/a"},"text":"Pub. L. 91–172, title III, § 311(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/586"},"text":"83 Stat. 586","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s173/b"},"text":"Pub. L. 98–369, div. A, title I, § 173(b)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag"