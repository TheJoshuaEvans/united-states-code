{"tag":"section","attrib":{"id":"id4675a8d1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6046A"},"text":null,"children":[{"tag":"num","attrib":{"value":"6046A"},"text":"§ 6046A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Returns as to interests in foreign partnerships","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4675a8d2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6046A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of return","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any United States person, except to the extent otherwise provided by regulations—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4675a8d3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6046A/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who acquires any interest in a foreign partnership,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4675a8d4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6046A/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who disposes of any portion of his interest in a foreign partnership, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4675a8d5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6046A/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose proportional interest in a foreign partnership changes substantially,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall file a return. Paragraphs (1) and (2) shall apply to any acquisition or disposition only if the United States person directly or indirectly holds at least a 10-percent interest in such partnership either before or after such acquisition or disposition, and paragraph (3) shall apply to any change only if the change is equivalent to at least a 10-percent interest in such partnership.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4675a8d6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6046A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form and contents of return","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any return required by subsection (a) shall be in such form and set forth such information as the Secretary shall by regulations prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4675a8d7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6046A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for filing return","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any return required by subsection (a) shall be filed on or before the 90th day (or on or before such later day as the Secretary may by regulations prescribe) after the day on which the United States person becomes liable to file such return.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4675a8d8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6046A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 10-percent interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsection (a), a 10-percent interest in a partnership is an interest described in section 6038(e)(3)(C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4675a8d9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6046A/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For provisions relating to penalties for violations of this section, see sections 6679 and 7203.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4675a8da-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/tIV/s405/a"},"text":"Pub. L. 97–248, title IV, § 405(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/669"},"text":"96 Stat. 669","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXI/s1143/a"},"text":"Pub. L. 105–34, title XI, § 1143(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/983"},"text":"111 Stat. 983","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4675a8db-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4675a8dc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4675a8dd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1143/a/1"},"text":"Pub. L. 105–34, § 1143(a)(1)","children":[],"tail":", inserted at end “Paragraphs (1) and (2) shall apply to any acquisition or disposition only if the United States person directly or indirectly holds at least a 10-percent interest in such partnership either before or after such acquisition or disposition, and paragraph (3) shall apply to any change only if the change is equivalent to at least a 10-percent interest in such partnership.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1143/a/2"},"text":"Pub. L. 105–34, § 1143(a)(2)","children":[],"tail":", added subsec. (d) and redesignated former subsec. (d) as (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4675a8de-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4675a8df-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXI/s1143/c"},"text":"Pub. L. 105–34, title XI, § 1143(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/984"},"text":"111 Stat. 984","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/34/tXI/s1143/c"},"text":"“The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6679"},"text":"section 6679 of this title","children":[],"tail":"] shall apply to transfers and changes after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4675a8e0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/tIV/s407/b"},"text":"Pub. L. 97–248, title IV, § 407(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/671"},"text":"96 Stat. 671","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/248/tIV/s407/b"},"text":"“The amendments made by section 405 [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6679"},"text":"section 6679 of this title","children":[],"tail":"] shall apply with respect to acquisitions or dispositions of, or substantial changes in, interests in foreign partnerships occurring after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4675a8e1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Special Rule for Certain International Satellite Partnerships","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provision that this section is not applicable to certain international satellite partnerships, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/s406"},"text":"section 406 of Pub. L. 97–248","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6231"},"text":"section 6231 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
