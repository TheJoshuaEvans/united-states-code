{"tag":"section","attrib":{"id":"id44b3114a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1059A"},"text":null,"children":[{"tag":"num","attrib":{"value":"1059A"},"text":"§ 1059A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on taxpayer’s basis or inventory cost in property imported from related persons","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44b3114b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1059A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If any property is imported into the United States in a transaction (directly or indirectly) between related persons (within the meaning of section 482), the amount of any costs—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44b3114c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1059A/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which are taken into account in computing the basis or inventory cost of such property by the purchaser, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44b3114d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1059A/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which are also taken into account in computing the customs value of such property,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall not, for purposes of computing such basis or inventory cost for purposes of this chapter, be greater than the amount of such costs taken into account in computing such customs value.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44b3114e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1059A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Customs value; import","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44b3114f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1059A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Customs value","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “customs value” means the value taken into account for purposes of determining the amount of any customs duties or any other duties which may be imposed on the importation of any property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44b31150-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1059A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Import","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in regulations, the term “import” means the entering, or withdrawal from warehouse, for consumption.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44b31151-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXII/s1248/a"},"text":"Pub. L. 99–514, title XII, § 1248(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2584"},"text":"100 Stat. 2584","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44b31152-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44b31153-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id44b31154-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXII/s1248/c"},"text":"Pub. L. 99–514, title XII, § 1248(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2584"},"text":"100 Stat. 2584","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/tXII/s1248/c"},"text":"“The amendments made by this section [enacting this section] shall apply to transactions entered into after ","children":[{"tag":"date","attrib":{"date":"1986-03-18"},"text":"March 18, 1986","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
