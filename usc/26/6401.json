1(c)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/360"},"text":"123 Stat. 360","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13404/c/4"},"text":"Pub. L. 115–97, title I, § 13404(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2138"},"text":"131 Stat. 2138","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46d5066f-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46d50670-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id46d50671-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46d50672-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":" substituted “and G” for “G, H, I, and J”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":" substituted “I, and J” for “and I”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s15316/c/3"},"text":"Pub. L. 110–246, § 15316(c)(3)","children":[],"tail":", substituted “H, and I” for “and H”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":" substituted “G, and H” for “and G”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206"},"text":"Pub. L. 105–206","children":[],"tail":" substituted “D, and G” for “and D”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" amended last sentence generally, substituting “credit so allowed by reason of section 1446” for “amount deducted and withheld under section 1446”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" inserted last sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s474/r/36"},"text":"Pub. L. 98–369, § 474(r)(36)","children":[],"tail":", amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “If the amount allowable as credits under sections 31 (relating to tax withheld on wages) and 39 (relating to certain uses of gasoline and special fuels), and 43 (relating to earned income credit), exceeds the tax imposed by subtitle A (reduced by the credits allowable under subpart A of part IV of subchapter A of chapter 1, other than the credits allowable under sections 31, 39, and 43), the amount of such excess shall be considered an overpayment. For purposes of the preceding sentence, any credit allowed under paragraph (1) of section 32 (relating to withholding of tax on nonresident aliens and on foreign corporations) to a nonresident alien individual for a taxable year with respect to which an election under section 6013(g) or (h) is in effect shall be treated as an amount allowable as a credit under section 31.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s735/c/16"},"text":"Pub. L. 98–369, § 735(c)(16)","children":[],"tail":", substituted “and special fuels” for “, special fuels, and lubricating oil”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/67"},"text":"Pub. L. 98–67","children":[],"tail":" repealed amendments made by "},{"tag":"ref","attrib":{"href":"/us/pl/97/248"},"text":"Pub. L. 97–248","children":[],"tail":". See 1982 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248"},"text":"Pub. L. 97–248","children":[],"tail":" provided that, applicable to payments of interest, dividends, and patronage dividends paid or credited after "},{"tag":"date","attrib":{"date":"1983-06-30"},"text":"June 30, 1983","children":[],"tail":", subsec. (b) is amended by inserting “, interest, dividends, and patronage dividends” after “tax withheld on wages”. Section 102(a), (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/98/67/tI"},"text":"Pub. L. 98–67, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-05"},"text":"Aug. 5, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/369"},"text":"97 Stat. 369","children":[],"tail":", repealed subtitle A (§§ 301–308) of title III of "},{"tag":"ref","attrib":{"href":"/us/pl/97/247"},"text":"Pub. L. 97–247","children":[],"tail":" as of the close of "},{"tag":"date","attrib":{"date":"1983-06-30"},"text":"June 30, 1983","children":[],"tail":", and provided that the Internal Revenue Code of 1954 [now 1986] [this title] shall be applied and administered (subject to certain exceptions) as if such subtitle A (and the amendments made by such subtitle A) had not been enacted."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/223"},"text":"Pub. L. 96–223","children":[],"tail":" struck out subsec. (d) which made a cross reference to section 46(a)(9)(C) for a rule allowing a refund for excess investment credit attributable to solar or wind energy property."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/222"},"text":"Pub. L. 96–222","children":[],"tail":" substituted “46(a)(9)(C)” for “46(a)(10)(C)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600"},"text":"Pub. L. 95–600","children":[],"tail":" inserted provisions relating to credit to a nonresident alien individual."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/618"},"text":"Pub. L. 95–618","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" substituted “wages) and” and “lubricating oil), and” for “wages),” and “lubricating oil),”, respectively; and pars. (2) and (3) made identical change: striking out “and 667(b) (relating to taxes paid by certain trusts)” after “(relating to earned income credit)”."}],"tail":"\n"},{