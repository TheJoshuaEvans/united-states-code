{"tag":"section","attrib":{"id":"id46d50668-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6401"},"text":null,"children":[{"tag":"num","attrib":{"value":"6401"},"text":"§ 6401.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts treated as overpayments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46d50669-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6401/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment and collection after limitation period.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “overpayment” includes that part of the amount of the payment of any internal revenue tax which is assessed or collected after the expiration of the period of limitation properly applicable thereto.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46d5066a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6401/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excessive credits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46d5066b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6401/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the amount allowable as credits under subpart C of part IV of subchapter A of chapter 1 (relating to refundable credits) exceeds the tax imposed by subtitle A (reduced by the credits allowable under subparts A, B, D, and G of such part IV), the amount of such excess shall be considered an overpayment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46d5066c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6401/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for credit under section 33","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1), any credit allowed under section 33 (relating to withholding of tax on nonresident aliens and on foreign corporations) for any taxable year shall be treated as a credit allowable under subpart C of part IV of subchapter A of chapter 1 only if an election under subsection (g) or (h) of section 6013 is in effect for such taxable year. The preceding sentence shall not apply to any credit so allowed by reason of section 1446.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46d5066d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6401/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule where no tax liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An amount paid as tax shall not be considered not to constitute an overpayment solely by reason of the fact that there was no tax liability in respect of which such amount was paid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46d5066e-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/791"},"text":"68A Stat. 791","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/44/tVIII/s809/d/6"},"text":"Pub. L. 89–44, title VIII, § 809(d)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-06-21"},"text":"June 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/168"},"text":"79 Stat. 168","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/tIII/s331/c"},"text":"Pub. L. 91–172, title III, § 331(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/598"},"text":"83 Stat. 598","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/258/tII/s207/d/1"},"text":"Pub. L. 91–258, title II, § 207(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-05-21"},"text":"May 21, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/248"},"text":"84 Stat. 248","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/12/tII/s204/b/1"},"text":"Pub. L. 94–12, title II, § 204(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-03-29"},"text":"Mar. 29, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/31"},"text":"89 Stat. 31","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tVII/s701/f/2"},"text":"Pub. L. 94–455, title VII, § 701(f)(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1580"},"text":"90 Stat. 1580","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/600/tVII/s701/u/15/D"},"text":"Pub. L. 95–600, title VII, § 701(u)(15)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2919"},"text":"92 Stat. 2919","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/618/tIII/s301/c/2"},"text":"Pub. L. 95–618, title III, § 301(c)(2)","children":[],"tai