{"tag":"section","attrib":{"id":"id414cb463-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s88"},"text":null,"children":[{"tag":"num","attrib":{"value":"88"},"text":"§ 88.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain amounts with respect to nuclear decommissioning costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In the case of any taxpayer who is required to include the amount of any nuclear decommissioning costs in the taxpayer’s cost of service for ratemaking purposes, there shall be includible in the gross income of such taxpayer the amount so included for any taxable year.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id414cb464-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s91/f/1"},"text":"Pub. L. 98–369, div. A, title I, § 91(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/607"},"text":"98 Stat. 607","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVIII/s1807/a/4/E/vii"},"text":"Pub. L. 99–514, title XVIII, § 1807(a)(4)(E)(vii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2813"},"text":"100 Stat. 2813","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id414cb465-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id414cb466-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendme