{"tag":"section","attrib":{"id":"id464f82c9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5812"},"text":null,"children":[{"tag":"num","attrib":{"value":"5812"},"text":"§ 5812.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id464f82ca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5812/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A firearm shall not be transferred unless (1) the transferor of the firearm has filed with the Secretary a written application, in duplicate, for the transfer and registration of the firearm to the transferee on the application form prescribed by the Secretary; (2) any tax payable on the transfer is paid as evidenced by the proper stamp affixed to the original application form; (3) the transferee is identified in the application form in such manner as the Secretary may by regulations prescribe, except that, if such person is an individual, the identification must include his fingerprints and his photograph; (4) the transferor of the firearm is identified in the application form in such manner as the Secretary may by regulations prescribe; (5) the firearm is identified in the application form in such manner as the Secretary may by regulations prescribe; and (6) the application form shows that the Secretary has approved the transfer and the registration of the firearm to the transferee. Applications shall be denied if the transfer, receipt, or possession of the firearm would place the transferee in violation of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id464f82cb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5812/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of possession","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The transferee of a firearm shall not take possession of the firearm unless the Secretary has approved the transfer and registration of the firearm to the transferee as required by subsection (a) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id464f82cc-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/618/tII/s201"},"text":"Pub. L. 90–618, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1228"},"text":"82 Stat. 1228","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id464f82cd-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id464f82ce-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id464f82cf-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5812, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/722"},"text":"68A Stat. 722","children":[],"tail":", consisted of provisions similar to those comprising this section, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/90/618"},"text":"Pub. L. 90–618","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 5813, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/723"},"text":"68A Stat. 723","children":[],"tail":", related to the affixing of the required stamps to the order form for the firearm, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/90/618"},"text":"Pub. L. 90–618","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 5814, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/723"},"text":"68A Stat. 723","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s203/c"},"text":"Pub. L. 85–859, title II, § 203(c)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1427"},"text":"72 Stat. 1427","children":[],"tail":", related to the order forms required for the transfer of a firearm, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/90/618"},"text":"Pub. L. 90–618","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id464f82d0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
