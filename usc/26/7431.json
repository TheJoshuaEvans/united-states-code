{"tag":"section","attrib":{"id":"id47535ef2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7431"},"text":null,"children":[{"tag":"num","attrib":{"value":"7431"},"text":"§ 7431.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil damages for unauthorized inspection or disclosure of returns and return information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47535ef3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7431/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47535ef4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7431/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspection or disclosure by employee of United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any officer or employee of the United States knowingly, or by reason of negligence, inspects or discloses any return or return information with respect to a taxpayer in violation of any provision of section 6103, such taxpayer may bring a civil action for damages against the United States in a district court of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47535ef5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7431/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspection or disclosure by a person who is not an employee of United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any person who is not an officer or employee of the United States knowingly, or by reason of negligence, inspects or discloses any return or return information with respect to a taxpayer in violation of any provision of section 6103 or in violation of section 6104(c), such taxpayer may bring a civil action for damages against such person in a district court of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47535ef6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7431/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No liability shall arise under this section with respect to any inspection or disclosure—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47535ef7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7431/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which results from a good faith, but erroneous, interpretation of section 6103, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47535ef8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7431/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is requested by the taxpayer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47535ef9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7431/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Damages","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any action brought under subsection (a), upon a finding of liability on the part of the defendant, the defendant shall be liable to the plaintiff in an amount equal to the sum of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47535efa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7431/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47535efb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7431/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000 for each act of unauthorized inspection or disclosure of a return or return information with respect to which such defendant is found liable, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47535efc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7431/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the sum of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47535efd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7431/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actual damages sustained by the plaintiff as a result of such unauthorized inspection or disclosure, plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47535efe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7431/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a willful inspection or disclosure or an inspection or disclosure which is the result of gross negligence, punitive damages, plus","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47535eff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7431/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs of the action, plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47535f00-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7431/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a plaintiff which is described in section 7430(c)(4)(A)(ii), reasonable attorneys fees, except that if the defendant is the United States, reasonable attorneys fees may be awarded only if the plaintiff is the prevailing party (as determined under section 7430(c)(4)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47535f01-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7431/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period for bringing action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, an action to enforce any liability created under this section may be brought, without regard to the amount in controversy, at any time within 2 years after the date of discovery by the plaintiff of the unauthorized inspection or disclosure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47535f02-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7431/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of unlawful inspection and disclosure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If any person is criminally charged by indictment or information with inspection or disclosure of a taxpayer’s return or return information in violation of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47535f03-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7431/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paragraph (1) or (2) of section 7213(a),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47535f04-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7431/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 7213A(a), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47535f05-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7431/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subparagraph (B) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1030/a/2"},"text":"section 1030(a)(2) of title 18","children":[],"tail":", United States Code,"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Secretary shall notify such taxpayer as soon as practicable of such inspection or disclosure. The Secretary shall also notify such taxpayer if the Internal Revenue Service or a Federal or State agency (upon notice to the Secretary by such Federal or State agency) proposes an administrative determination as to disciplinary or adverse action against an employee arising from the employee’s unauthorized inspection or disclosure of the taxpayer’s return or return information. The notice described in this subsection shall include the date of the unauthorized inspection or disclosure and the rights of the taxpayer under such administrative determination.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47535f06-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7431/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the terms “inspect”, “inspection”, “return”, and “return information” have the respective meanings given such terms by section 6103(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47535f07-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7431/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension to information obtained under section 3406","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47535f08-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7431/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any information obtained under section 3406 (including information with respect to any payee certification failure under subsection (d) thereof) shall be treated as return information, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47535f09-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7431/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any inspection or use of such information other than for purposes of meeting any requirement under section 3406 or (subject to the safeguards set forth in section 6103) for purposes permitted under section 6103 shall be treated as a violation of section 6103.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of subsection (b), the reference to section 6103 shall be treated as including a reference to section 3406.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47535f0a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7431/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for information obtained under section 6103(k)(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, any reference to section 6103 shall be treated as including a reference to section 6311(e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47535f0b-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/tIII/s357/a"},"text":"Pub. L. 97–248, title III, § 357(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/645"},"text":"96 Stat. 645","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/67/tI/s104/b"},"text":"Pub. L. 98–67, title I, § 104(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-05"},"text":"Aug. 5, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/379"},"text":"97 Stat. 379","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXII/s1205/c/2"},"text":"Pub. L. 105–34, title XII, § 1205(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/998"},"text":"111 Stat. 998","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/35/s3/a"},"text":"Pub. L. 105–35, § 3(a)","children":[],"tail":"–(d)(4), (6), "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1105"},"text":"111 Stat. 1105","children":[],"tail":", 1106; "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tIII/s3101/f"},"text":"Pub. L. 105–206, title III, § 3101(f)","children":[],"tail":", title VI, § 6012(b)(3), "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/729"},"text":"112 Stat. 729","children":[],"tail":", 819; "},{"tag":"ref","attrib":{"href":"/us/pl/109/280/tXII/s1224/b/7"},"text":"Pub. L. 109–280, title XII, § 1224(b)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1093"},"text":"120 Stat. 1093","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/25/tIII/s3002/a"},"text":"Pub. L. 116–25, title III, § 3002(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-07-01"},"text":"July 1, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1015"},"text":"133 Stat. 1015","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47535f0c-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47535f0d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id47535f0e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7431 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s7437"},"text":"section 7437 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id47535f0f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/25"},"text":"Pub. L. 116–25","children":[],"tail":" inserted at end of concluding provisions “The Secretary shall also notify such taxpayer if the Internal Revenue Service or a Federal or State agency (upon notice to the Secretary by such Federal or State agency) proposes an administrative determination as to disciplinary or adverse action against an employee arising from the employee’s unauthorized inspection or disclosure of the taxpayer’s return or return information. The notice described in this subsection shall include the date of the unauthorized inspection or disclosure and the rights of the taxpayer under such administrative determination.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280"},"text":"Pub. L. 109–280","children":[],"tail":", which directed insertion of “or in violation of section 6104(c)” after “6103” in subsec. (a)(2) of section 7431, without specifying the act to be amended, was executed by making the insertion in subsec. (a)(2) of this section, which is section 7431 of the Internal Revenue Code of 1986, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s3101/f"},"text":"Pub. L. 105–206, § 3101(f)","children":[],"tail":", substituted “, plus” for the period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s3101/f"},"text":"Pub. L. 105–206, § 3101(f)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (g), (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s6012/b/3"},"text":"Pub. L. 105–206, § 6012(b)(3)","children":[],"tail":", redesignated subsec. (g), relating to special rule for information obtained under section 6103(k)(8), as (h), and substituted “(9)” for “(8)” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/35/s3/d/4"},"text":"Pub. L. 105–35, § 3(d)(4)","children":[],"tail":", inserted “inspection or” before “disclosure” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/35/s3/a/1"},"text":"Pub. L. 105–35, § 3(a)(1)","children":[],"tail":", (2), substituted “Inspection or disclosure” for “Disclosure” in headings and “inspects or discloses” for “discloses” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/35/s3/c"},"text":"Pub. L. 105–35, § 3(c)","children":[],"tail":", amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) ","children":[{"tag":"inline","attrib":{},"text":"No Liability for Good Faith but Erroneous Interpretation","children":[],"tail":".—No liability shall arise under this section with respect to any disclosure which results from a good faith, but erroneous, interpretation of section 6103.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/35/s3/d/1"},"text":"Pub. L. 105–35, § 3(d)(1)","children":[],"tail":", (2), inserted “inspection or” before “disclosure” in subpars. (A) and (B)(i) and substituted “willful inspection or disclosure or an inspection or disclosure” for “willful disclosure or a disclosure” in subpar. (B)(ii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/35/s3/d/1"},"text":"Pub. L. 105–35, § 3(d)(1)","children":[],"tail":", inserted “inspection or” before “disclosure”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/35/s3/b"},"text":"Pub. L. 105–35, § 3(b)","children":[],"tail":", added subsec. (e). Former subsec. (e) redesignated (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/35/s3/b"},"text":"Pub. L. 105–35, § 3(b)","children":[],"tail":", (d)(3), redesignated subsec. (e) as (f) and amended it generally. Prior to amendment, subsec. (f) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(f) ","children":[{"tag":"inline","attrib":{},"text":"Return; Return Information","children":[],"tail":".—For purposes of this section, the terms ‘return’ and ‘return information’ have the respective meanings given such terms in section 6103(b).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/35/s3/b"},"text":"Pub. L. 105–35, § 3(b)","children":[],"tail":", (d)(6), redesignated subsec. (f) as (g) and substituted “any inspection or use” for “any use” in par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1205/c/2"},"text":"Pub. L. 105–34, § 1205(c)(2)","children":[],"tail":", added subsec. (g) relating to special rule for information obtained under section 6103(k)(8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/67"},"text":"Pub. L. 98–67","children":[],"tail":" added subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47535f10-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47535f11-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2019 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/25/tIII/s3002/b"},"text":"Pub. L. 116–25, title III, § 3002(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-07-01"},"text":"July 1, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1015"},"text":"133 Stat. 1015","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/25/tIII/s3002/b"},"text":"“The amendment made by this section [amending this section] shall apply to determinations proposed after the date which is 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2019-07-01"},"text":"July 1, 2019","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47535f12-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280"},"text":"Pub. L. 109–280","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", but not applicable to requests made before such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/280/s1224/c"},"text":"section 1224(c) of Pub. L. 109–280","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6103"},"text":"section 6103 of this ti