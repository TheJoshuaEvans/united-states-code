{"tag":"section","attrib":{"id":"id448ceb36-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s962"},"text":null,"children":[{"tag":"num","attrib":{"value":"962"},"text":"§ 962.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election by individuals to be subject to tax at corporate rates","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id448ceb37-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s962/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under regulations prescribed by the Secretary, in the case of a United States shareholder who is an individual and who elects to have the provisions of this section apply for the taxable year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id448ceb38-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s962/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the tax imposed under this chapter on amounts which are included in his gross income under section 951(a) shall (in lieu of the tax determined under sections 1 and 55) be an amount equal to the tax which would be imposed under section 11 if such amounts were received by a domestic corporation, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id448ceb39-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s962/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for purposes of applying the provisions of section 960 ","children":[{"tag":"ref","attrib":{"idref":"fn002156"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002156"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" (relating to foreign tax credit) such amounts shall be treated as if they were received by a domestic corporation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id448ceb3a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s962/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An election to have the provisions of this section apply for any taxable year shall be made by a United States shareholder at such time and in such manner as the Secretary shall prescribe by regulations. An election made for any taxable year may not be revoked except with the consent of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id448ceb3b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s962/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pro ration of each section 11 bracket amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of applying subsection (a)(1), the amount in each taxable income bracket in the tax table in section 11(b) shall not exceed an amount which bears the same ratio to such bracket amount as the amount included in the gross income of the United States shareholder under section 951(a) for the taxable year bears to such shareholder’s pro rata share of the earnings and profits for the taxable year of all controlled foreign corporations with respect to which such shareholder includes any amount in gross income under section 951(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id448ceb3c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s962/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for actual distributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The earnings and profits of a foreign corporation attributable to amounts which were included in the gross income of a United States shareholder under section 951(a) and with respect to which an election under this section applied shall, when such earnings and profits are distributed, notwithstanding the provisions of section 959(a)(1), be included in gross income to the extent that such earnings and profits so distributed exceed the amount of tax paid under this chapter on the amounts to which such election applied.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id448f352d-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/834/s12/a"},"text":"Pub. L. 87–834, § 12(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-16"},"text":"Oct. 16, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1023"},"text":"76 Stat. 1023","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/12/tIII/s303/c/3"},"text":"Pub. L. 94–12, title III, § 303(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-03-29"},"text":"Mar. 29, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/45"},"text":"89 Stat. 45","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/164/s4/d/1"},"text":"Pub. L. 94–164, § 4(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-23"},"text":"Dec. 23, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/975"},"text":"89 Stat. 975","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/600/tIII/s301/b/16"},"text":"Pub. L. 95–600, title III, § 301(b)(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2822"},"text":"92 Stat. 2822","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1007/g/11"},"text":"Pub. L. 100–647, title I, § 1007(g)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3435"},"text":"102 Stat. 3435","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s12001/b/15"},"text":"Pub. L. 115–97, title I, § 12001(b)(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2094"},"text":"131 Stat. 2094","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id448f352e-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id448f352f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id448f3530-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 960, referred to in subsec. (a)(2), was amended extensively by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":", and, as so amended, relates to deemed paid credit for subpart F inclusions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id448f3531-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":" substituted “section 11” for “sections 11 and 55”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" substituted “sections 1 and 55” and “sections 11 and 55” for “section 1” and “section 11”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600"},"text":"Pub. L. 95–600","children":[],"tail":" substituted provisions relating to the pro ration of each section 11 bracket amount for provisions relating to the surtax exemption."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/164"},"text":"Pub. L. 94–164","children":[],"tail":" substituted “same ratio to the surtax exemption” for “same ratio to $25,000” in subsec. (c) as such subsec. (c) is in effect for taxable years ending after "},{"tag":"date","attrib":{"date":"1975-12-31"},"text":"Dec. 31, 1975","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/12"},"text":"Pub. L. 94–12","children":[],"tail":" substituted “$50,000” for “$25,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id448f3532-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id448f3533-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"2017-12-31"},"text":"Dec. 31, 2017","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/s12001/c"},"text":"section 12001(c) of Pub. L. 115–97","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s11"},"text":"section 11 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id448f3534-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1019/a"},"text":"sect