{"tag":"section","attrib":{"id":"id445ab7c8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s893"},"text":null,"children":[{"tag":"num","attrib":{"value":"893"},"text":"§ 893.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation of employees of foreign governments or international organizations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id445ab7c9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s893/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule for exclusion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Wages, fees, or salary of any employee of a foreign government or of an international organization (including a consular or other officer, or a nondiplomatic representative), received as compensation for official services to such government or international organization shall not be included in gross income and shall be exempt from taxation under this subtitle if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id445ab7ca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s893/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such employee is not a citizen of the United States, or is a citizen of the Republic of the Philippines (whether or not a citizen of the United States); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id445ab7cb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s893/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an employee of a foreign government, the services are of a character similar to those performed by employees of the Government of the United States in foreign countries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id445ab7cc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s893/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an employee of a foreign government, the foreign government grants an equivalent exemption to employees of the Government of the United States performing similar services in such foreign country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id445ab7cd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s893/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certificate by Secretary of State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall certify to the Secretary of the Treasury the names of the foreign countries which grant an equivalent exemption to the employees of the Government of the United States performing services in such foreign countries, and the character of the services performed by employees of the Government of the United States in foreign countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id445ab7ce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s893/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on exclusion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id445ab7cf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s893/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any employee of a controlled commercial entity (as defined in section 892(a)(2)(B)), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id445ab7d0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s893/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any employee of a foreign government whose services are primarily in connection with a commercial activity (whether within or outside the United States) of the foreign government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id445ab7d1-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/284"},"text":"68A Stat. 284","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1012/t/4"},"text":"Pub. L. 100–647, title I, § 1012(t)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3527"},"text":"102 Stat. 3527","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id445ab7d2-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id445ab7d3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id445ab7d4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id445ab7d5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id445ab7d6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1019/a"},"text":"section 1019(a) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
