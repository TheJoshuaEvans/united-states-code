{"tag":"section","attrib":{"id":"id46aee0b1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6161"},"text":null,"children":[{"tag":"num","attrib":{"value":"6161"},"text":"§ 6161.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of time for paying tax","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46aee0b2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6161/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount determined by taxpayer on return","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46aee0b3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6161/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, except as otherwise provided in this title, may extend the time for payment of the amount of the tax shown, or required to be shown, on any return or declaration required under authority of this title (or any installment thereof), for a reasonable period not to exceed 6 months (12 months in the case of estate tax) from the date fixed for payment thereof. Such extension may exceed 6 months in the case of a taxpayer who is abroad.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46aee0b4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6161/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Estate tax","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may, for reasonable cause, extend the time for payment of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46aee0b5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6161/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any part of the amount determined by the executor as the tax imposed by chapter 11, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46aee0b6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6161/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any part of any installment under section 6166 (including any part of a deficiency prorated to any installment under such section).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"for a reasonable period not in excess of 10 years from the date prescribed by section 6151(a) for payment of the tax (or, in the case of an amount referred to in subparagraph (B), if later, not beyond the date which is 12 months after the due date for the last installment).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46aee0b7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6161/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount determined as deficiency","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46aee0b8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6161/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Income, gift, and certain other taxes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under regulations prescribed by the Secretary, the Secretary may extend the time for the payment of the amount determined as a deficiency of a tax imposed by chapter 1, 12, 41, 42, 43, or 44 for a period not to exceed 18 months from the date fixed for the payment of the deficiency, and in exceptional cases, for a further period not to exceed 12 months. An extension under this paragraph may be granted only where it is shown to the satisfaction of the Secretary that payment of a deficiency upon the date fixed for the payment thereof will result in undue hardship to the taxpayer in the case of a tax imposed by chapter 1, 41, 42, 43, or 44, or to the donor in the case of a tax imposed by chapter 12.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46aee0b9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6161/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Estate tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under regulations prescribed by the Secretary, the Secretary may, for reasonable cause, extend the time for the payment of any deficiency of a tax imposed by chapter 11 for a reasonable period not to exceed 4 years from the date otherwise fixed for the payment of the deficiency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46aee0ba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6161/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No extension for certain deficiencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No extension shall be granted under this subsection for any deficiency if the deficiency is due to negligence, to intentional disregard of rules and regulations, or to fraud with intent to evade tax.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46aee0bb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6161/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Claims in cases under title 11 of the United States Code or in receivership proceedings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Extensions of time for payment of any portion of a claim for tax under chapter 1 or chapter 12, allowed in cases under title 11 of the United States Code or in receivership proceedings, which is unpaid, may be had in the same manner and subject to the same provisions and limitations as provided in subsection (b) in respect of a deficiency in such tax.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46aee0bc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6161/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross references","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46aee0bd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6161/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For extension of the period of limitation in case of an extension under subsection (a)(2) or subsection (b)(2), see section 6503(d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46aee0be-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6161/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For authority of the Secretary to require security in case of an extension under subsection (a)(2) or subsection (b), see section 6165.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46aee0bf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6161/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Postponement of certain acts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For time for performing certain acts postponed by reason of war, see section 7508, and by reason of Presidentially declared disaster or terroristic or military action, see section 7508A.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46aee0c0-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/762"},"text":"68A Stat. 762","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/866/tII/s206/c"},"text":"Pub. L. 85–866, title II, § 206(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1684"},"text":"72 Stat. 1684","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/tI/s101/j/37"},"text":"Pub. L. 91–172, title I, § 101(j)(37)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/530"},"text":"83 Stat. 530","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/614/tI/s101/h"},"text":"Pub. L. 91–614, title I, § 101(h)","childr