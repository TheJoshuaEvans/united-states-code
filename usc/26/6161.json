trib":{"href":"/us/stat/72/1685"},"text":"72 Stat. 1685","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"“The amendments made by this section [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6166"},"text":"section 6166 of this title","children":[],"tail":" and amending this section and sections 6503 and 6601 of this title] shall apply to estates of decedents with respect to which the date for the filing of the estate tax return (including extensions thereof) prescribed by section 6075(a) of the Internal Revenue Code of 1986 [formerly I.R.C. 1954] is after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":"]; except that (1) section 6166(i) of such Code as added by this section shall apply to estates of decedents dying after "},{"tag":"date","attrib":{"date":"1954-08-16"},"text":"August 16, 1954","children":[],"tail":", but only if the date for the filing of the estate tax return (including extensions thereof) expired on or before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":"], and (2) notwithstanding section 6166(a) of such Code, if an election under such section is required to be made before the sixtieth day after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":"] such an election shall be considered timely if made on or before such sixtieth day.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
