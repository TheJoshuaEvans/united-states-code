{"tag":"section","attrib":{"id":"id451729be-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1463"},"text":null,"children":[{"tag":"num","attrib":{"value":"1463"},"text":"§ 1463.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax paid by recipient of income","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id451729bf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1463/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person, in violation of the provisions of this chapter, fails to deduct and withhold any tax under this chapter, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id451729c0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1463/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" thereafter the tax against which such tax may be credited is paid,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the tax so required to be deducted and withheld shall not be collected from such person; but this section shall in no case relieve such person from liability for interest or any penalties or additions to the tax otherwise applicable in respect of such failure to deduct and withhold.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id451729c1-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/360"},"text":"68A Stat. 360","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7743/a"},"text":"Pub. L. 101–239, title VII, § 7743(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2406"},"text":"103 Stat. 2406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1704/t/9"},"text":"Pub. L. 104–188, title I, § 1704(t)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1887"},"text":"110 Stat. 1887","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id451729c2-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id451729c3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id451729c4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":" substituted “this section” for “this subsection”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “If any tax required under this chapter to be deducted and withheld is paid by the recipient of the income, it shall not be re-collected from the withholding agent; nor in cases in which the tax is so paid shall any penalty be imposed on or collected from the recipient of the income or the withholding agent for failure to return or pay the same, unless such failure was fraudulent and for the purpose of evading payment.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id451729c5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id451729c6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7743/b"},"text":"Pub. L. 101–239, title VII, § 7743(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2406"},"text":"103 Stat. 2406","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/239/tVII/s7743/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply to failures after ","children":[{"tag":"date","attrib":{"date":"1989-12-31"},"text":"December 31, 1989","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
