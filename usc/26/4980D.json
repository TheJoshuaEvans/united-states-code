{"tag":"section","attrib":{"id":"id460cd485-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D"},"text":null,"children":[{"tag":"num","attrib":{"value":"4980D"},"text":"§ 4980D.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to meet certain group health plan requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id460cd486-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby imposed a tax on any failure of a group health plan to meet the requirements of chapter 100 (relating to group health plan requirements).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id460cd487-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of tax","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id460cd488-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of the tax imposed by subsection (a) on any failure shall be $100 for each day in the noncompliance period with respect to each individual to whom such failure relates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460cd489-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noncompliance period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “noncompliance period” means, with respect to any failure, the period—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id460cd48a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" beginning on the date such failure first occurs, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id460cd48b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ending on the date such failure is corrected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460cd48c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum tax for noncompliance period where failure discovered after notice of examination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding paragraphs (1) and (2) of subsection (c)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id460cd48d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of 1 or more failures with respect to an individual—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id460cd48e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which are not corrected before the date a notice of examination of income tax liability is sent to the employer, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id460cd48f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which occurred or continued during the period under examination,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the amount of tax imposed by subsection (a) by reason of such failures with respect to such individual shall not be less than the lesser of $2,500 or the amount of tax which would be imposed by subsection (a) without regard to such paragraphs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id460cd490-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Higher minimum tax where violations are more than de minimis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent violations for which any person is liable under subsection (e) for any year are more than de minimis, subparagraph (A) shall be applied by substituting “$15,000” for “$2,500” with respect to such person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id460cd491-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for church plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This paragraph shall not apply to any failure under a church plan (as defined in section 414(e)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id460cd492-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on amount of tax","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id460cd493-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax not to apply where failure not discovered exercising reasonable diligence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No tax shall be imposed by subsection (a) on any failure during any period for which it is established to the satisfaction of the Secretary that the person otherwise liable for such tax did not know, and exercising reasonable diligence would not have known, that such failure existed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460cd494-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax not to apply to failures corrected within certain periods","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No tax shall be imposed by subsection (a) on any failure if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id460cd495-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such failure was due to reasonable cause and not to willful neglect, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id460cd496-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id460cd497-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a plan other than a church plan (as defined in section 414(e)), such failure is corrected during the 30-day period beginning on the first date the person otherwise liable for such tax knew, or exercising reasonable diligence would have known, that such failure existed, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id460cd498-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a church plan (as so defined), such failure is corrected before the close of the correction period (determined under the rules of section 414(e)(4)(C)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460cd499-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overall limitation for unintentional failures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of failures which are due to reasonable cause and not to willful neglect—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id460cd49a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Single employer plans","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id460cd49b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of failures with respect to plans other than specified multiple employer health plans, the tax imposed by subsection (a) for failures during the taxable year of the employer shall not exceed the amount equal to the lesser of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id460cd49c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/c/3/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10 percent of the aggregate amount paid or incurred by the employer (or predecessor employer) during the preceding taxable year for group health plans, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id460cd49d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/c/3/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $500,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id460cd49e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable years in the case of certain controlled groups","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subparagraph, if not all persons who are treated as a single employer for purposes of this section have the same taxable year, the taxable years taken into account shall be determined under principles similar to the principles of section 1561.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id460cd49f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specified multiple employer health plans","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id460cd4a0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of failures with respect to a specified multiple employer health plan, the tax imposed by subsection (a) for failures during the taxable year of the trust forming part of such plan shall not exceed the amount equal to the lesser of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id460cd4a1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/c/3/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10 percent of the amount paid or incurred by such trust during such taxable year to provide medical care (as defined in section 9832(d)(3)) directly or through insurance, reimbursement, or otherwise, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id460cd4a2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/c/3/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $500,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":" For purposes of the preceding sentence, all plans of which the same trust forms a part shall be treated as one plan.","children":[],"tail":"\n"},{"tag":"clause","attrib":{"id":"id460cd4a3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for employers required to pay tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an employer is assessed a tax imposed by subsection (a) by reason of a failure with respect to a specified multiple employer health plan, the limit shall be determined under subparagraph (A) (and not under this subparagraph) and as if such plan were not a specified multiple employer health plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460cd4a4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a failure which is due to reasonable cause and not to willful neglect, the Secretary may waive part or all of the tax imposed by subsection (a) to the extent that the payment of such tax would be excessive relative to the failure involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id460cd4a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax not to apply to certain insured small employer plans","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id460cd4a6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a group health plan of a small employer which provides health insurance coverage solely through a contract with a health insurance issuer, no tax shall be imposed by this section on the employer on any failure (other than a failure attributable to section 9811) which is solely because of the health insurance coverage offered by such issuer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460cd4a7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small employer","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id460cd4a8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1), the term “small employer” means, with respect to a calendar year and a plan year, an employer who employed an average of at least 2 but not more than 50 employees on business days during the preceding calendar year and who employs at least 2 employees on the first day of the plan year. For purposes of the preceding sentence, all persons treated as a single employer under subsection (b), (c), (m), or (","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":") of section 414 shall be treated as one employer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id460cd4a9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employers not in existence in preceding year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an employer which was not in existence throughout the preceding calendar year, the determination of whether such employer is a small employer shall be based on the average number of employees that it is reasonably expected such employer will employ on business days in the current calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id460cd4aa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Predecessors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any reference in this paragraph to an employer shall include a reference to any predecessor of such employer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460cd4ab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health insurance coverage; health insurance issuer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1), the terms “health insurance coverage” and “health insurance issuer” have the respective meanings given such terms by section 9832.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id460cd4ac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability for tax","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following shall be liable for the tax imposed by subsection (a) on a failure:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id460cd4ad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise provided in this subsection, the employer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460cd4ae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a multiemployer plan, the plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460cd4af-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a failure under section 9803 (relating to guaranteed renewability) with respect to a plan described in subsection (f)(2)(B), the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id460cd4b0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id460cd4b1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Group health plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “group health plan” has the meaning given such term by section 9832(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460cd4b2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specified multiple employer health plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “specified multiple employer health plan” means a group health plan which is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id460cd4b3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any multiemployer plan, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id460cd4b4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any multiple employer welfare arrangement (as defined in section 3(40) of the Employee Retirement Income Security Act of 1974, as in effect on the date of the enactment of this section).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460cd4b5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Correction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A failure of a group health plan shall be treated as corrected if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id460cd4b6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such failure is retroactively undone to the extent possible, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id460cd4b7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person to whom the failure relates is placed in a financial position which is as good as such person would have been in had such failure not occurred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id460cd4b8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980D/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to requirements imposed on certain entities providing pharmacy benefit management services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any requirement under section 9826 that applies with respect to an entity providing pharmacy benefit management services on behalf of a group health plan, any reference in this section to such group health plan (and the reference in subsection (e)(1) to the employer) shall be treated as including a reference to such entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id460cd4b9-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191/tIV/s402/a"},"text":"Pub. L. 104–191, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2084"},"text":"110 Stat. 2084","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXV/s1531/b/2"},"text":"Pub. L. 105–34, title XV, § 1531(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1085"},"text":"111 Stat. 1085","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/135/tIV/s412/ww"},"text":"Pub. L. 109–135, title IV, § 412(ww)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-21"},"text":"Dec. 21, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2640"},"text":"119 Stat. 2640","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/75/dJ/tVII/s6701/c/3"},"text":"Pub. L. 119–75, div. J, title VII, § 6701(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2026-02-03"},"text":"Feb. 3, 2026","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/140/732"},"text":"140 Stat. 732","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id460cd4ba-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id460cd4bb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id460cd4bc-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 3(40) of the Employee Retirement Income Security Act of 1974, referred to in subsec. (f)(2)(B), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1002/40"},"text":"section 1002(40) of Title 29","children":[],"tail":", Labor."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of the enactment of this section, referred to in subsec. (f)(2)(B), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191"},"text":"Pub. L. 104–191","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id460cd4bd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2026—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/75"},"text":"Pub. L. 119–75","children":[],"tail":" added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/135"},"text":"Pub. L. 109–135","children":[],"tail":" substituted “plan requirements” for “plans requirements”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1531/b/2/A"},"text":"Pub. L. 105–34, § 1531(b)(2)(A)","children":[],"tail":", substituted “plans” for “plan portability, access, and renewability”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(B)(i)(I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1531/b/2/B"},"text":"Pub. L. 105–34, § 1531(b)(2)(B)","children":[],"tail":", substituted “9832(d)(3)” for “9805(d)(3)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1531/b/2/C"},"text":"Pub. L. 105–34, § 1531(b)(2)(C)","children":[],"tail":", inserted “(other than a failure attributable to section 9811)” after “on any failure”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1531/b/2/D"},"text":"Pub. L. 105–34, § 1531(b)(2)(D)","children":[],"tail":", substituted “section 9832” for “section 9805”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1531/b/2/E"},"text":"Pub. L. 105–34, § 1531(b)(2)(E)","children":[],"tail":", substituted “section 9832(a)” for “section 9805(a)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id460cd4be-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id460cd4bf-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXV/s1531/c"},"text":"Pub. L. 105–34, title XV, § 1531(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1085"},"text":"111 Stat. 1085","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/34/tXV/s1531/c"},"text":"“The amendments made by this section [enacting sections 9811 and 9812 of this title, amending this section and sections 9801 and 9831 of this title, and renumbering sections 9804 to 9806 of this title as sections 9831 to 9833 of this title] shall apply with respect to group health plans for plan years beginning on or after ","children":[{"tag":"date","attrib":{"date":"1998-01-01"},"text":"January 1, 1998","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id460f1eb0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191/tIV/s402/c"},"text":"Pub. L. 104–191, title IV, § 402(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2087"},"text":"110 Stat. 2087","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/191/tIV/s402/c"},"text":"“The amendments made by this section [enacting this section] shall apply to failures under chapter 100 of the Internal Revenue Code of 1986 (as added by section 401 of this Act).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
