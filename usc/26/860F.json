{"tag":"section","attrib":{"id":"id443bbe6f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F"},"text":null,"children":[{"tag":"num","attrib":{"value":"860F"},"text":"§ 860F.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other rules","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id443bbe70-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 100 percent tax on prohibited transactions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id443bbe71-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax imposed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby imposed for each taxable year of a REMIC a tax equal to 100 percent of the net income derived from prohibited transactions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id443bbe72-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited transaction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this part, the term “prohibited transaction” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id443bbe73-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of qualified mortgage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The disposition of any qualified mortgage transferred to the REMIC other than a disposition pursuant to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id443bbe74-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the substitution of a qualified replacement mortgage for a qualified mortgage (or the repurchase in lieu of substitution of a defective obligation),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id443bbe75-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a disposition incident to the foreclosure, default, or imminent default of the mortgage,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id443bbe76-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the bankruptcy or insolvency of the REMIC, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id443bbe77-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F/a/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a qualified liquidation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id443bbe78-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Income from nonpermitted assets","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The receipt of any income attributable to any asset which is neither a qualified mortgage nor a permitted investment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id443bbe79-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation for services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The receipt by the REMIC of any amount representing a fee or other compensation for services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id443bbe7a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gain from disposition of cash flow investments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Gain from the disposition of any cash flow investment other than pursuant to any qualified liquidation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id443bbe7b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of net income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1), the term “net income derived from prohibited transactions” means the excess of the gross income from prohibited transactions over the deductions allowed by this chapter which are directly connected with such transactions; except that there shall not be taken into account any item attributable to any prohibited transaction for which there was a loss.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id443bbe7c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified liquidation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this part—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id443bbe7d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified liquidation” means a transaction in which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id443bbe7e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the REMIC adopts a plan of complete liquidation,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id443bbe7f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such REMIC sells all its assets (other than cash) within the liquidation period, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id443bbe80-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F/a/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all proceeds of the liquidation (plus the cash), less assets retained to meet claims, are credited or distributed to holders of regular or residual interests on or before the last day of the liquidation period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id443bbe81-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liquidation period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “liquidation period” means the period—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id443bbe82-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" beginning on the date of the adoption of the plan of liquidation, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id443bbe83-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ending at the close of the 90th day after such date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id443bbe84-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding subparagraphs (A) and (D) of paragraph (2), the term “prohibited transaction” shall not include any disposition—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id443bbe85-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" required to prevent default on a regular interest where the threatened default resulted from a default on 1 or more qualified mortgages, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id443bbe86-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate a clean-up call (as defined in regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id443bbe87-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of transfers to the REMIC","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id443bbe88-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of transferor","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id443bbe89-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonrecognition gain or loss","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No gain or loss shall be recognized to the transferor on the transfer of any property to a REMIC in exchange for regular or residual interests in such REMIC.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id443bbe8a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjusted bases of interests","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The adjusted bases of the regular and residual interests received in a transfer described in subparagraph (A) shall be equal to the aggregate adjusted bases of the property transferred in such transfer. Such amount shall be allocated among such interests in proportion to their respective fair market values.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id443bbe8b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of nonrecognized gain","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the issue price of any regular or residual interest exceeds its adjusted basis as determined under subparagraph (B), for periods during which such interest is held by the transferor (or by any other person whose basis is determined in whole or in part by reference to the basis of such interest in the hand of the transferor)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id443bbe8c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a regular interest, such excess shall be included in gross income (as determined under rules similar to rules of section 1276(b)), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id443bbe8d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a residual interest, such excess shall be included in gross income ratably over the anticipated period during which the REMIC will be in existence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id443bbe8e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of nonrecognized loss","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the adjusted basis of any regular or residual interest received in a transfer described in subparagraph (A) exceeds its issue price, for periods during which such interest is held by the transferor (or by any other person whose basis is determined in whole or in part by reference to the basis of such interest in the hand of the transferor)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id443bbe8f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F/b/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a regular interest, such excess shall be allowable as a deduction under rules similar to the rules of section 171, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id443bbe90-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F/b/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a residual interest, such excess shall be allowable as a deduction ratably over the anticipated period during which the REMIC will be in existence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id443bbe91-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis to REMIC","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The basis of any property received by a REMIC in a transfer described in paragraph (1)(A) shall be its fair market value immediately after such transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id443bbe92-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distributions of property","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a REMIC makes a distribution of property with respect to any regular or residual interest—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id443bbe93-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notwithstanding any other provision of this subtitle, gain shall be recognized to such REMIC on the distribution in the same manner as if it had sold such property to the distributee at its fair market value, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id443bbe94-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the basis of the distributee in such property shall be its fair market value.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id443bbe95-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with wash sale rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of section 1091—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id443bbe96-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any residual interest in a REMIC shall be treated as a security, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id443bbe97-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in applying such section to any loss claimed to have been sustained on the sale or other disposition of a residual interest in a REMIC—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id443bbe98-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in regulations, any residual interest in any REMIC and any interest in a taxable mortgage pool (as defined in section 7701(i)) comparable to a residual interest in a REMIC shall be treated as substantially identical stock or securities, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id443bbe99-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsections (a) and (e) of such section shall be applied by substituting “6 months” for “30 days” each place it appears.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id443bbe9a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860F/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment under subtitle F","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subtitle F, a REMIC shall be treated as a partnership (and holders of residual interests in such REMIC shall be treated as partners). Any return required by reason of the preceding sentence shall include the amount of the daily accruals determined under section 860E(c). Such return shall be filed by the REMIC. The determination of who may sign such return shall be made without regard to the first sentence of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id443bbe9b-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVI/s671/a"},"text":"Pub. L. 99–514, title VI, § 671(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2313"},"text":"100 Stat. 2313","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1006/t/3"},"text":"Pub. L. 100–647, title I, § 1006(t)(3)","children":[],"tail":", (4), (14), (18)(A), (22)(B)–(E), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3419"},"text":"102 Stat. 3419","children":[],"tail":", 3420, 3423, 3426; "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1704/t/74"},"text":"Pub. L. 104–188, title I, § 1704(t)(74)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1891"},"text":"110 Stat. 1891","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id443bbe9c-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id443bbe9d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id443bbe9e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":" substituted “paragraph (2)” for “paragraph (1)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1006/t/3/B/i"},"text":"Pub. L. 100–647, § 1006(t)(3)(B)(i)","children":[],"tail":", struck out at end “Notwithstanding the preceding sentence, the term ‘prohibited transaction’ shall not include any disposition required to prevent default on a regular interest where the threatened default resulted from a default on 1 or more qualified mortgages.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1006/t/3/A"},"text":"Pub. L. 100–647, § 1006(t)(3)(A)","children":[],"tail":", amended cl. (i) generally. Prior to amendment, cl. (i) read as follows: “the substitution of a qualified replacement mortgage for a qualified mortgage,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A)(iii), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1006/t/22/B"},"text":"Pub. L. 100–647, § 1006(t)(22)(B)","children":[],"tail":", (C), substituted “REMIC” for “real estate mortgage pool”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1006/t/3/C"},"text":"Pub. L. 100–647, § 1006(t)(3)(C)","children":[],"tail":", struck out “described in subsection (b)” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1006/t/3/B/ii"},"text":"Pub. L. 100–647, § 1006(t)(3)(B)(ii)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1006/t/4"},"text":"Pub. L. 100–647, § 1006(t)(4)","children":[],"tail":", substituted “the transfer of any property to a REMIC in exchange for regular or residual interests in such REMIC” for “the transfer of any property to a REMIC”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(C)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1006/t/22/D"},"text":"Pub. L. 100–647, § 1006(t)(22)(D)","children":[],"tail":", substituted “REMIC” for “real estate mortgage pool”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(D)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1006/t/14"},"text":"Pub. L. 100–647, § 1006(t)(14)","children":[],"tail":", (22)(E), amended cl. (ii) identically, substituting “REMIC” for “real estate mortgage pool”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1006/t/18/A"},"text":"Pub. L. 100–647, § 1006(t)(18)(A)","children":[],"tail":", inserted at end “Such return shall be filed by the REMIC. The determination of who may sign such return shall be made without regard to the first sentence of this subsection.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id443e2e9f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id443e2ea0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1006/t/18/B"},"text":"Pub. L. 100–647, title I, § 1006(t)(18)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3426"},"text":"102 Stat. 3426","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/647/tI/s1006/t/18/B"},"text":"“Unless the REMIC otherwise elects, the amendment made by subparagraph (A) [amending this section] shall not apply to any REMIC where the start-up day (as defined in section 860G(a)(9) of the 1986 Code as in effect on the day before the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":"]) is before the date of the enactment of this Act.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by section 1006(t)(3), (4), (14), (22)(B)–(E) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1019/a"},"text":"section 1019(a) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
