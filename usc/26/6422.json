d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Pars. (7) to (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/a/292/A"},"text":"Pub. L. 115–141, § 401(a)(292)(A)","children":[],"tail":", (B), redesignated pars. (8) to (10) as (7) to (9), respectively, and struck out former par. (7) which read as follows: “For treatment of certain overpayments as having been refunded, in connection with sale of surplus war-built vessels, see section 9(b)(8) of the Merchant Ship Sales Act of 1946 (50 U.S.C. App. 1742).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (10), (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/a/292/B"},"text":"Pub. L. 115–141, § 401(a)(292)(B)","children":[],"tail":", (C), redesignated par. (11) as (10) and substituted “For credit” for “for credit”. Former par. (10) redesignated (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/a/292/B"},"text":"Pub. L. 115–141, § 401(a)(292)(B)","children":[],"tail":", which directed the redesignation of par. (12) as (11), could not be executed because there was no par. (12) following the amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/114/74"},"text":"Pub. L. 114–74","children":[],"tail":". See 2015 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Par. (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/74"},"text":"Pub. L. 114–74","children":[],"tail":" struck out par. (12) which read as follows: “For special rules in the case of a credit or refund attributable to partnership items, see section 6227 and subsections (c) and (d) of section 6230.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Pars. (5) to (13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" struck out par. (5) and redesignated pars. (6) to (13) as (5) to (12), respectively. Prior to amendment, par. (5) read as follows: “For abatement or refund of tax on transfers to avoid income tax, see section 1494(b).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" struck out par. (6) and redesignated the succeeding pars. accordingly, which was executed with respect to the succeeding pars. (consisting of pars. (7) to (12), (14), and (15)) by redesignating such pars. as (6) to (13), respectively. Prior to amendment, par. (6) provided a cross reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1481"},"text":"section 1481 of this title","children":[],"tail":" for overpayment in certain renegotiations of war contracts."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Par. (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258/s3/f/8"},"text":"Pub. L. 97–258, § 3(f)(8)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3727"},"text":"section 3727 of title 31","children":[],"tail":", United States Code” for “R.S. 3477 ("},{"tag":"ref","attrib":{"href":"/us/usc/t31/s203"},"text":"31 U.S.C. 203","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258/s3/f/9"},"text":"Pub. L. 97–258, § 3(f)(9)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3728"},"text":"section 3728 of title 31","children":[],"tail":", United States Code” for “the act of "},{"tag":"date","attrib":{"date":"1875-03-03"},"text":"March 3, 1875","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/act/1933-03-03/s13"},"text":"section 13 of the act of March 3, 1933","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t31/s227"},"text":"31 U.S.C. 227","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (15). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248"},"text":"Pub. L. 97–248","children":[],"tail":" added par. (15)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Par. (14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600"},"text":"Pub. L. 95–600","children":[],"tail":" inserted “regulated investment company or” before “real estate investment trust” and substituted “section 860” for “section 859”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1901/b/36/B"},"text":"Pub. L. 94–455, § 1901(b)(36)(B)","children":[],"tail":", redesignated par. (3) as (2). Former par. (2), which set forth a cross reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1321"},"text":"section 1321 of this title","children":[],"tail":" for overpayment arising out of adjustments incident to involuntary liquidation of inventory, was struck out."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (3) to (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1901/b/36/B"},"text":"Pub. L. 94–455, § 1901(b)(36)(B)","children":[],"tail":", redesignated pars. (4) to (9) as (3) to (8), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":", §§ 1901(b)(36)(B), 1906(a)(28)(A), redesignated par. (10) as (9) and substituted “(50 U.S.C. App. 1742)” for “("},{"tag":"ref","attrib":{"href":"/us/stat/60/48"},"text":"60 Stat. 48","children":[],"tail":"; 50 U.S.C. App. 1742)”. Former par. (9) redesignated (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1901/b/36/B"},"text":"Pub. L. 94–455, § 1901(b)(36)(B)","children":[],"tail":", redesignated par. (11) as (10). Former par. (10) redesignated (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (11). ","children":[{"tag":"ref","attrib":{