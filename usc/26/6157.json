:null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/566/s114/b"},"text":"section 114(b) of Pub. L. 94–566","children":[],"tail":" effective with respect to remuneration paid after "},{"tag":"date","attrib":{"date":"1977-12-31"},"text":"Dec. 31, 1977","children":[],"tail":", for services performed after that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/94/566/s114/c"},"text":"section 114(c) of Pub. L. 94–566","children":[],"tail":" set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s3306"},"text":"section 3306 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/566/s211/e/3"},"text":"section 211(e)(3) of Pub. L. 94–566","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1976-10-20"},"text":"Oct. 20, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/566/s211/d/3"},"text":"section 211(d)(3) of Pub. L. 94–566","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1101"},"text":"section 1101 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46aee076-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/373/s101/b/1"},"text":"section 101(b)(1) of Pub. L. 91–373","children":[],"tail":" applicable with respect to calendar years beginning after "},{"tag":"date","attrib":{"date":"1971-12-31"},"text":"Dec. 31, 1971","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/373/s101/c/1"},"text":"section 101(c)(1) of Pub. L. 91–373","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s3306"},"text":"section 3306 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/373/tI/s101/c/2"},"text":"Pub. L. 91–373, title I, § 101(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-10"},"text":"Aug. 10, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/696"},"text":"84 Stat. 696","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/91/373/tI/s101/c/2"},"text":"“The amendment made by subsection (b)(2) [amending this section] shall apply with respect to calendar years beginning after ","children":[{"tag":"date","attrib":{"date":"1969-12-31"},"text":"December 31, 1969","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id46aee077-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/53/s4/a"},"text":"Pub. L. 91–53, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-08-07"},"text":"Aug. 7, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/93"},"text":"83 Stat. 93","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/91/53/s4/a"},"text":"“The amendments made by the first two sections of this Act [enacting section 6317 and amending this section and sections 3306, 6201, 6513, and 6601 of this title] shall apply with respect to calendar years beginning after ","children":[{"tag":"date","attrib":{"date":"1969-12-31"},"text":"December 31, 1969","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id46aee078-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Extension of Time for Payment of Additional FUTA Taxes","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/244/s4"},"text":"Pub. L. 102–244, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-02-07"},"text":"Feb. 7, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4"},"text":"106 Stat. 4","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/244/s4"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law, if a qualified taxpayer is required to pay additional taxes for taxable years beginning in 1991 with respect to any employment in any State by reason of such State being declared a credit reduction State, such taxpayer may elect to defer the filing and payment of such additional taxes to a date no later than ","children":[{"tag":"date","attrib":{"date":"1992-06-30"},"text":"June 30, 1992","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interest","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding subsection (a), for purposes of section 6601(a) of the Internal Revenue Code of 1986, the last date prescribed for payment of any additional taxes for which an election is made under subsection (a) shall be ","children":[{"tag":"date","attrib":{"date":"1992-01-31"},"text":"January 31, 1992","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualified taxpayer","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘qualified taxpayer’ means a taxpayer—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a State which has been declared a credit reduction State for taxable years beginning in 1991, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who did not receive notice of such credit reduction before ","children":[{"tag":"date","attrib":{"date":"1991-12-01"},"text":"December 1, 1991","children":[],"tail":" from either the State unemployment compensation agency or the Internal Revenue Service."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Credit reduction state","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘credit reduction State’ means a State with respect to which the Internal Revenue Service has determined that a reduction in credits is applicable for taxable years beginning in 1991 pursuant to the provisions of section 3302 of the Internal Revenue Code of 1986.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Time and Manner for Making Election","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An election under this section shall be made at such time and in such manner as the Secretary of the Treasury shall prescribe.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id46aee079-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wages Paid in 1970 Calendar Quarters Ending Before ","children":[{"tag":"date","attrib":{"date":"1970-08-10"},"text":"August 10, 1970","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/373/tIII/s301/b"},"text":"Pub. L. 91–373, title III, § 301(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-10"},"text":"Aug. 10, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/713"},"text":"84 Stat. 713","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"“For purposes of section 6157 of the Internal Revenue Code of 1986 [formerly I.R.C. 1954] (relating to payment of Federal unemployment tax on quarterly or other time period basis), in computing tax as required by subsections (a)(1) and (2) of such section, the percentage contained in subsection (b) of such section applicable with respect to wages paid in any calendar quarter in 1970 ending before the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1970-08-10"},"text":"Aug. 10, 1970","children":[],"tail":"] shall be treated as being 0.4 percent.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
