te","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2428"},"text":"103 Stat. 2428","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46ac977d-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46ac977e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id46ac977f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6157, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/761"},"text":"68A Stat. 761","children":[],"tail":", § 6156; renumbered § 6157, "},{"tag":"date","attrib":{"date":"1961-06-29"},"text":"June 29, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/87/61/tII/s203/c/1"},"text":"Pub. L. 87–61, title II, § 203(c)(1)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/125"},"text":"75 Stat. 125","children":[],"tail":", made a cross reference provision for payment of taxes under provisions of the Tariff Act, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/91/53/s2/a"},"text":"Pub. L. 91–53, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-08-07"},"text":"Aug. 7, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/91"},"text":"83 Stat. 91","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46ac9780-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" substituted “subsection (c)” for “subsections (c) and (d)” in last sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" struck out subsec. (d) which related to quarterly payment of railroad unemployment repayment tax."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/76"},"text":"Pub. L. 98–76","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/s271/c/3/C"},"text":"Pub. L. 97–248, § 271(c)(3)(C)","children":[],"tail":", substituted “0.6” for “0.5” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/s271/b/2/C"},"text":"Pub. L. 97–248, § 271(b)(2)(C)","children":[],"tail":", substituted “0.8” for “0.7”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/566/s114/b"},"text":"Pub. L. 94–566, § 114(b)","children":[],"tail":", amended subsec. (a) generally, changing the general rule covering payment of Federal unemployment tax on a quarterly or other time period basis to conform to the altered definitions of employment and wages pertaining to domestic and agricultural service in "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s3306"},"text":"section 3306 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/a/11/B"},"text":"Pub. L. 94–455, § 1906(a)(11)(B)","children":[],"tail":", (b)(13)(A), substituted “subsection (c)” for “subsections (c) and (d)” and struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/566/s211/e/3/s3"},"text":"Pub. L. 94–566, § 211(e)(3) [(c)(3)]","children":[],"tail":", substituted “In the case of wages paid in any calendar quarter or other period during a calendar year to which paragraph (1) of section 3301 applies, the amount of such wages shall be multiplied by 0.7 percent in lieu of 0.5 percent” for “In the case of wages paid in any calendar quarter or other period during 1973, the amount of such wages shall be multiplied by 0.58 percent in lieu of 0.5 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/a/11/A"},"text":"Pub. L. 94–455, § 1906(a)(11)(A)","children":[],"tail":", redesignated subsec. (d) as (c). Former subsec. (c), which related to the percentage reduction for 1970 and 1971 of the tax computed in subsec. (b), was struck out."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/329"},"text":"Pub. L. 92–329","children":[],"tail":" inserted provisions setting forth the computation of tax in the case of wages paid in any calendar quarter or other period during 1973."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/373/s101/b/1"},"text":"Pub. L. 91–373, § 101(b)(1)","children":[],"tail":", reduced from 4 to 1 the number of individuals which a person had to employ on each of some 20 days during the preceding calendar year and inserted provision covering persons who, during any calendar quarter in the preceding calendar year, paid wages of $1,500 or more."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/373/s101/b/2"},"text":"Pub. L. 91–373, § 101(b)(2)","children":[],"tail":", substituted “0.5 percent” for “the number of percentage points (including fractional points) by which the rate of tax specified in section 3301 exceeds .7 percent”. be the date on which payment would have been required if such remainder had been the tax."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46aee071-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46aee072-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" applicable to remuneration paid after "},{"tag":"date","attrib":{"date":"1988-12-31"},"text":"Dec. 31, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s7106/d"},"text":"section 7106(d) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s3321"},"text":"section 3321 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46aee073-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1983 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/76"},"text":"Pub. L. 98–76","children":[],"tail":" applicable to remuneration paid after "},{"tag":"date","attrib":{"date":"1986-06-30"},"text":"June 30, 1986","children":[],"tail":", see "},{