{"tag":"section","attrib":{"id":"id43cbbdfa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s534"},"text":null,"children":[{"tag":"num","attrib":{"value":"534"},"text":"§ 534.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Burden of proof","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id43cbbdfb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s534/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any proceeding before the Tax Court involving a notice of deficiency based in whole or in part on the allegation that all or any part of the earnings and profits have been permitted to accumulate beyond the reasonable needs of the business, the burden of proof with respect to such allegation shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43cbbdfc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s534/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if notification has not been sent in accordance with subsection (b), be on the Secretary, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43cbbdfd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s534/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the taxpayer has submitted the statement described in subsection (c), be on the Secretary with respect to the grounds set forth in such statement in accordance with the provisions of such subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43cbbdfe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s534/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before mailing the notice of deficiency referred to in subsection (a), the Secretary may send by certified mail or registered mail a notification informing the taxpayer that the proposed notice of deficiency includes an amount with respect to the accumulated earnings tax imposed by section 531.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43cbbdff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s534/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement by taxpayer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within such time (but not less than 30 days) after the mailing of the notification described in subsection (b) as the Secretary may prescribe by regulations, the taxpayer may submit a statement of the grounds (together with facts sufficient to show the basis thereof) on which the taxpayer relies to establish that all or any part of the earnings and profits have not been permitted to accumulate beyond the reasonable needs of the business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43cbbe00-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s534/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jeopardy assessment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If pursuant to section 6861(a) a jeopardy assessment is made before the mailing of the notice of deficiency referred to in subsection (a), for purposes of this section such notice of deficiency shall, to the extent that it informs the taxpayer that such deficiency includes the accumulated earnings tax imposed by section 531, constitute the notification described in subsection (b), and in that event the statement described in subsection (c) may be included in the taxpayer’s petition to the Tax Court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id43cbbe01-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/180"},"text":"68A Stat. 180","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1955-08-11/ch805"},"text":"Aug. 11, 1955, ch. 805","children":[],"tail":", §§ 4, 5, "},{"tag":"ref","attrib":{"href":"/us/stat/69/690"},"text":"69 Stat. 690","children":[],"tail":", 691; "},{"tag":"ref","attrib":{"href":"/us/pl/85/866/tI/s89/b"},"text":"Pub. L. 85–866, title I, § 89(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1665"},"text":"72 Stat. 1665","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX"},"text":"Pub. L. 94–455, title XIX","children":[],"tail":", §§ 1901(a)(73), 1906(b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1776"},"text":"90 Stat. 1776","children":[],"tail":", 1834.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id43cbbe02-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id43cbbe03-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id43cbbe04-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—Subsec. (a)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":", §§ 1901(a)(73)(A), 1906(b)(13)(A), struck out “In the case of a notice of deficiency to which subsection (e)(2) applies and which is mailed on or before the 30th day after the date of enactment of this sentence, the notification referred to in the preceding sentence may be mailed at any time on or before such 30th day” after “section 531”, and “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1901/a/73/B"},"text":"Pub. L. 94–455, § 1901(a)(73)(B)","children":[],"tail":", struck out subsec. (e) relating to application of provisions of section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/866"},"text":"Pub. L. 85–866","children":[],"tail":" inserted “certified mail or” before “registered mail”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1955—Subsec. (b). Act ","children":[{"tag":"date","attrib":{"date":"1955-08-11"},"text":"Aug. 11, 1955","children":[],"tail":", § 5, inserted second sentence relating to notice of deficiency to which subsec. (e)(2) applies."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). Act ","children":[{"tag":"date","attrib":{"date":"1955-08-11"},"text":"Aug. 11, 1955","children":[],"tail":", § 4, permitted, in certain instances, application of this section to cases involving taxable years to which prior revenue laws apply."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id43cbbe05-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43cbbe06-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1901/a/73"},"text":"section 1901(a)(73) of Pub. L. 94–455","children":[],"tail":" applicable with respect to taxable years beginning after "},{"tag":"date","attrib":{"date":"1976-12-31"},"text":"Dec. 31, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1901/d"},"text":"section 1901(d) of Pub. L. 94–455","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2"},"text":"section 2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43cbbe07-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1958 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/866"},"text":"Pub. L. 85–866","children":[],"tail":" applicable only if mailing occurred after "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/85/866/s89/d"},"text":"section 89(d) of Pub. L. 85–866","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s7502"},"text":"section 7502 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
