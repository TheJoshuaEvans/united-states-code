{"tag":"section","attrib":{"id":"id44b09fb5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1054"},"text":null,"children":[{"tag":"num","attrib":{"value":"1054"},"text":"§ 1054.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain stock of Federal National Mortgage Association","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In the case of a share of stock issued pursuant to section 303(c) of the Federal National Mortgage Association Charter Act (12 U.S.C., sec. 1718), the basis of such share in the hands of the initial holder shall be an amount equal to the capital contributions evidenced by such share reduced by the amount (if any) required by section 162(d) to be treated (with respect to such share) as ordinary and necessary expenses paid or incurred in carrying on a trade or business.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id44b09fb6-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/779/s8/b"},"text":"Pub. L. 86–779, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-14"},"text":"Sept. 14, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/1003"},"text":"74 Stat. 1003","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44b09fb7-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44b09fb8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id44b09fb9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1054 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1063"},"text":"section 1063 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44b09fba-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id44b09fbb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1959-12-31"},"text":"Dec. 31, 1959","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/86/779/s8/d"},"text":"section 8(d) of Pub. L. 86–779","children":[],"tail":", set out as an Effective Date of 1960 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s162"},"text":"section 162 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
