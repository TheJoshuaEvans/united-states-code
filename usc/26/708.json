{"tag":"section","attrib":{"id":"id44003bd0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s708"},"text":null,"children":[{"tag":"num","attrib":{"value":"708"},"text":"§ 708.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation of partnership","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44003bd1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s708/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subchapter, an existing partnership shall be considered as continuing if it is not terminated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44003bd2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s708/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44003bd3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s708/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsection (a), a partnership shall be considered as terminated only if no part of any business, financial operation, or venture of the partnership continues to be carried on by any of its partners in a partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44003bd4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s708/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44003bd5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s708/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Merger or consolidation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of the merger or consolidation of two or more partnerships, the resulting partnership shall, for purposes of this section, be considered the continuation of any merging or consolidating partnership whose members own an interest of more than 50 percent in the capital and profits of the resulting partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44003bd6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s708/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Division of a partnership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a division of a partnership into two or more partnerships, the resulting partnerships (other than any resulting partnership the members of which had an interest of 50 percent or less in the capital and profits of the prior partnership) shall, for purposes of this section, be considered a continuation of the prior partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44003bd7-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/244"},"text":"68A Stat. 244","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13504/a"},"text":"Pub. L. 115–97, title I, § 13504(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2141"},"text":"131 Stat. 2141","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44003bd8-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44003bd9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44003bda-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":" struck out dash after “only if” and subpar. (A) designation before “no part” and struck out subpar. (B) which read as follows: “within a 12-month period there is a sale or exchange of 50 percent or more of the total interest in partnership capital and profits”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44003bdb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44003bdc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":" applicable to partnership taxable years beginning after "},{"tag":"date","attrib":{"date":"2017-12-31"},"text":"Dec. 31, 2017","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13504/c"},"text":"section 13504(c) of Pub. L. 115–97","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s168"},"text":"section 168 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
