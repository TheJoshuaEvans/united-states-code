:"/us/pl/106/554"},"text":"Pub. L. 106–554","children":[],"tail":", set out as an Effective Date of 2000 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1016"},"text":"section 1016 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"id44ff5ca6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/d/4/B/vii"},"text":"section 401(d)(4)(B)(vii) of Pub. L. 115–141","children":[],"tail":" not applicable to certain obligations issued, DC Zone assets acquired, or principal residences acquired before "},{"tag":"date","attrib":{"date":"2012-01-01"},"text":"Jan. 1, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/d/4/C"},"text":"section 401(d)(4)(C) of Pub. L. 115–141","children":[],"tail":", set out as a note under former "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1400"},"text":"section 1400 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by section 401(d)(5)(B)(iv), (v) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" not applicable to certain qualified community assets acquired, wages paid or incurred, qualified revitalization buildings placed in service, or property acquired before "},{"tag":"date","attrib":{"date":"2010-01-01"},"text":"Jan. 1, 2010","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/d/5/C"},"text":"section 401(d)(5)(C) of Pub. L. 115–141","children":[],"tail":", set out as a note under former "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1400E"},"text":"section 1400E of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For provisions that nothing in amendment by ","c