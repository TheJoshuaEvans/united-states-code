{"tag":"section","attrib":{"id":"id44ff5c89-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397B"},"text":null,"children":[{"tag":"num","attrib":{"value":"1397B"},"text":"§ 1397B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonrecognition of gain on rollover of empowerment zone investments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44ff5c8a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397B/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonrecognition of gain","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any sale of a qualified empowerment zone asset held by the taxpayer for more than 1 year and with respect to which such taxpayer elects the application of this section, gain from such sale shall be recognized only to the extent that the amount realized on such sale exceeds—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44ff5c8b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397B/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of any qualified empowerment zone asset (with respect to the same zone as the asset sold) purchased by the taxpayer during the 60-day period beginning on the date of such sale, reduced by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ff5c8c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397B/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any portion of such cost previously taken into account under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44ff5c8d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397B/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44ff5c8e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397B/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified empowerment zone asset","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44ff5c8f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397B/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified empowerment zone asset” means any property which would be a qualified community asset (as defined in section 1400F) ","children":[{"tag":"ref","attrib":{"idref":"fn002182"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002182"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" if in section 1400F "},{"tag":"ref","attrib":{"idref":"fn002182"},"text":"1","children":[],"tail":"—"}],"tail":null},{"tag":"clause","attrib":{"id":"id44ff5c90-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397B/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" references to empowerment zones were substituted for references to renewal communities,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44ff5c91-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397B/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" references to enterprise zone businesses (as defined in section 1397C) were substituted for references to renewal community businesses,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44ff5c92-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397B/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of the enactment of this paragraph were substituted for “","children":[{"tag":"date","attrib":{"date":"2001-12-31"},"text":"December 31, 2001","children":[],"tail":"” each place it appears, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44ff5c93-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397B/b/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the day after the date set forth in section 1391(d)(1)(A)(i) were substituted for “","children":[{"tag":"date","attrib":{"date":"2010-01-01"},"text":"January 1, 2010","children":[],"tail":"” each place it appears."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44ff5c94-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397B/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" References","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any reference in this paragraph to section 1400F shall be treated as reference to such section before its repeal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ff5c95-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397B/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain gain not eligible for rollover","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section shall not apply to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44ff5c96-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397B/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any gain which is treated as ordinary income for purposes of this subtitle, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44ff5c97-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397B/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any gain which is attributable to real property, or an intangible asset, which is not an integral part of an enterprise zone business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ff5c98-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397B/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchase","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A taxpayer shall be treated as having purchased any property if, but for paragraph (4), the unadjusted basis of such property in the hands of the taxpayer would be its cost (within the meaning of section 1012).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ff5c99-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397B/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis adjustments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If gain from any sale is not recognized by reason of subsection (a), such gain shall be applied to reduce (in the order acquired) the basis for determining gain or loss of any qualified empowerment zone asset which is purchased by the taxpayer during the 60-day period described in subsection (a). This paragraph shall not apply for purposes of section 1202.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ff5c9a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397B/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Holding period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of determining whether the nonrecognition of gain under subsection (a) applies to any qualified empowerment zone asset which is sold, the taxpayer’s holding period for such asset and the asset referred to in subsection (a)(1) shall be determined without regard to section 1223.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44ff5c9b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397B/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to sales in taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2020-12-31"},"text":"December 31, 2020","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44ff5c9c-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tI/s116/a/3"},"text":"Pub. L. 106–554, § 1(a)(7) [title I, § 116(a)(3)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–602; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dA/tII/s206/c"},"text":"Pub. L. 113–295, div. A, title II, § 206(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4027"},"text":"128 Stat. 4027","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/d/4/B/vii"},"text":"Pub. L. 115–141, div. U, title IV, § 401(d)(4)(B)(vii)","children":[],"tail":", (5)(B)(iv), (v), "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1209"},"text":"132 Stat. 1209","children":[],"tail":", 1210; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dEE/tI/s118/c"},"text":"Pub. L. 116–260, div. EE, title I, § 118(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3051"},"text":"134 Stat. 3051","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44ff5c9d-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44ff5c9e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id44ff5c9f-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this paragraph, referred to in subsec. (b)(1)(A)(iii), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554"},"text":"Pub. L. 106–554","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 1400F, referred to in subsec. (b)(1), was repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/d/5/A"},"text":"Pub. L. 115–141, div. U, title IV, § 401(d)(5)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1210"},"text":"132 Stat. 1210","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id44ff5ca0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1397B was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1397C"},"text":"section 1397C of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44ff5ca1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/d/5/B/iv"},"text":"Pub. L. 115–141, § 401(d)(5)(B)(iv)","children":[],"tail":", added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/d/4/B/vii"},"text":"Pub. L. 115–141, § 401(d)(4)(B)(vii)","children":[],"tail":", struck out subpar. (B). Text read as follows: “The District of Columbia Enterprise Zone shall not be treated as an empowerment zone for purposes of this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/d/5/B/v"},"text":"Pub. L. 115–141, § 401(d)(5)(B)(v)","children":[],"tail":", substituted “which is sold, the taxpayer’s holding period for such asset and the asset referred to in subsection (a)(1) shall be determined without regard to section 1223.” for “which is sold—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the taxpayer’s holding period for such asset and the asset referred to in subsection (a)(1) shall be determined without regard to section 1223, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) only the first year of the taxpayer’s holding period for the asset referred to in subsection (a)(1) shall be taken into account for purposes of paragraphs (2)(A)(iii), (3)(C), and (4)(A)(iii) of section 1400F(b).”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (b)(1)(A)(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" added cl. (iv)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44ff5ca2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44ff5ca3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"tex