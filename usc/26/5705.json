{"tag":"section","attrib":{"id":"id464ac850-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5705"},"text":null,"children":[{"tag":"num","attrib":{"value":"5705"},"text":"§ 5705.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit, refund, or allowance of tax","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id464ac851-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5705/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit or refund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Credit or refund of any tax imposed by this chapter or section 7652 shall be allowed or made (without interest) to the manufacturer, importer, or export warehouse proprietor, on proof satisfactory to the Secretary that the claimant manufacturer, importer, or export warehouse proprietor has paid the tax on tobacco products and cigarette papers and tubes withdrawn by him from the market; or on such articles lost (otherwise than by theft) or destroyed, by fire, casualty, or act of God, while in the possession of ownership of the claimant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id464ac852-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5705/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the tax has not yet been paid on tobacco products and cigarette papers and tubes provided to have been withdrawn from the market or lost or destroyed as aforesaid, relief from the tax on such articles may be extended upon the filing of a claim for allowance therefor in accordance with such regulations as the Secretary shall prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id464ac853-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5705/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any claim for credit or refund of tax under this section shall be filed within 6 months after the date of the withdrawal from the market, loss, or destruction of the articles to which the claim relates, and shall be in such form and contain such information as the Secretary shall by regulations prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id464ac854-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/709"},"text":"68A Stat. 709","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s202"},"text":"Pub. L. 85–859, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1419"},"text":"72 Stat. 1419","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/44/tVIII/s808/b/1"},"text":"Pub. L. 89–44, title VIII, § 808(b)(1)","children":[],"tail":", (2), (c)(1), "},{"tag":"date","attrib":{"date":"1965-06-21"},"text":"June 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/164"},"text":"79 Stat. 164","children":[],"tail":", 165; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id464ac855-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id464ac856-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id464ac857-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44/s808/c/1"},"text":"Pub. L. 89–44, § 808(c)(1)","children":[],"tail":", struck out “Refund or” and inserted in lieu thereof “Credit, refund, or” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44/s808/b/1"},"text":"Pub. L. 89–44, § 808(b)(1)","children":[],"tail":", substituted “Credit or refund” for “Refund” in heading and struck out “Refund of any tax imposed by this chapter shall be made”, replacing it with “Credit or refund of any tax imposed by this chapter or section 7652 shall be allowed or made”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44/s808/b/2"},"text":"Pub. L. 89–44, § 808(b)(2)","children":[],"tail":", inserted “credit or” before “refund”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" authorized refunds to export warehouse proprietors, provided for refunds to be made without interest, and eliminated provisions which authorized refunds where the tax has been paid in error."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" permitted relief where a tax has not yet been paid on tobacco products and cigarette papers and tubes proved to have been withdrawn from the market."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" substituted “under this section shall be filed within 6 months after the date of the withdrawal from the market, loss, or destruction of the articles to which the claim relates” for “imposed by this chapter shall be filed within 3 years of the date of payment of tax”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id464ac858-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id464ac859-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1965 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44/tVIII/s808/d/2"},"text":"Pub. L. 89–44, title VIII, § 808(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-06-21"},"text":"June 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/165"},"text":"79 Stat. 165","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/89/44/tVIII/s808/d/2"},"text":"“The amendments made by subsections (b)(1), (2), and (c) [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1965-10-01"},"text":"October 1, 1965","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id464ac85a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1958 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1958-09-03"},"text":"Sept. 3, 1958","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/s210/a/1"},"text":"section 210(a)(1) of Pub. L. 85–859","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5001"},"text":"section 5001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
