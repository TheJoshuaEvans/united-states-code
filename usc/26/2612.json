{"tag":"section","attrib":{"id":"id4546c56f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2612"},"text":null,"children":[{"tag":"num","attrib":{"value":"2612"},"text":"§ 2612.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable termination; taxable distribution; direct skip","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4546c570-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2612/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable termination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4546c571-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2612/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter, the term “taxable termination” means the termination (by death, lapse of time, release of power, or otherwise) of an interest in property held in a trust unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4546c572-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2612/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" immediately after such termination, a non-skip person has an interest in such property, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4546c573-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2612/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at no time after such termination may a distribution (including distributions on termination) be made from such trust to a skip person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4546c574-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2612/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain partial terminations treated as taxable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, upon the termination of an interest in property held in trust by reason of the death of a lineal descendant of the transferor, a specified portion of the trust’s assets are distributed to 1 or more skip persons (or 1 or more trusts for the exclusive benefit of such persons), such termination shall constitute a taxable termination with respect to such portion of the trust property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4546c575-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2612/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this chapter, the term “taxable distribution” means any distribution from a trust to a skip person (other than a taxable termination or a direct skip).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4546c576-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2612/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct skip","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4546c577-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2612/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “direct skip” means a transfer subject to a tax imposed by chapter 11 or 12 of an interest in property to a skip person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4546c578-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2612/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Look-thru rules not to apply","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Solely for purposes of determining whether any transfer to a trust is a direct skip, the rules of section 2651(f)(2) shall not apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4546c579-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXX/s2006/a"},"text":"Pub. L. 94–455, title XX, § 2006(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1883"},"text":"90 Stat. 1883","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXIV/s1431/a"},"text":"Pub. L. 99–514, title XIV, § 1431(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2719"},"text":"100 Stat. 2719","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1014/g/5/B"},"text":"Pub. L. 100–647, title I, § 1014(g)(5)(B)","children":[],"tail":", (7), (15), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3564-3566"},"text":"102 Stat. 3564–3566","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tV/s511/b"},"text":"Pub. L. 105–34, title V, § 511(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/861"},"text":"111 Stat. 861","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4546c57a-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4546c57b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4546c57c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s511/b/2"},"text":"Pub. L. 105–34, § 511(b)(2)","children":[],"tail":", substituted “section 2651(f)(2)” for “section 2651(e)(2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s511/b/1"},"text":"Pub. L. 105–34, § 511(b)(1)","children":[],"tail":", redesignated par. (3) as (2) and struck out heading and text of former par. (2). Text read as follows: “For purposes of determining whether any transfer is a direct skip, if—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) an individual is a grandchild of the transferor (or the transferor’s spouse or former spouse), and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) as of the time of the transfer, the parent of such individual who is a lineal descendant of the transferor (or the transferor’s spouse or former spouse) is dead,","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"such individual shall be treated as if such individual were a child of the transferor and all of that grandchild’s children shall be treated as if they were grandchildren of the transferor. In the case of lineal descendants below a grandchild, the preceding sentence may be reapplied. If any transfer of property to a trust would be a direct skip but for this paragraph, any generation assignment under this paragraph shall apply also for purposes of applying this chapter to transfers from the portion of the trust attributable to such property.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s511/b/1"},"text":"Pub. L. 105–34, § 511(b)(1)","children":[],"tail":", redesignated par. (3) as (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1014/g/15"},"text":"Pub. L. 100–647, § 1014(g)(15)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “If, upon the termination of an interest in property held in a trust, a specified portion of the trust assets are distributed to skip persons who are lineal descendants of the holder of such interest (or to 1 or more trusts for the exclusive benefit of such persons), such termination shall constitute a taxable termination with respect to such portion of the trust property.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1014/g/7"},"text":"Pub. L. 100–647, § 1014(g)(7)","children":[],"tail":", in closing provisions, inserted at end “If any transfer of property to a trust would be a direct skip but for this paragraph, any generation assignment under this paragraph shall apply also for purposes of applying this chapter to transfers from the portion of the trust attributable to such property.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1014/g/5/B"},"text":"Pub. L. 100–647, § 1014(g)(5)(B)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" amended section generally, substituting provisions covering definition and application of “taxable termination”, “taxable distribution”, and “direct skip” for former provisions which indicated who the “deemed transferor” would be for purposes of this chapter and that, for purposes of determining the person deemed the transferor, a parent related to the grantor of a trust by blood or adoption was to be deemed more closely related than a parent related to a grantor by marriage."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4546c57d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4546c57e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/tV/s511/c"},"text":"Pub. L. 105–34, title V, § 511(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/861"},"text":"111 Stat. 861","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/34/tV/s511/c"},"text":"“The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s2651"},"text":"section 2651 of this title","children":[],"tail":"] shall apply to terminations, distributions, and transfers occurring after "},{"tag":"date","attrib":{"date":"1997-12-31"},"text":"December 31, 1997","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4546c57f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1019/a"},"text":"section 1019(a) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4546c580-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to generation-skipping transfers (within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s2611"},"text":"section 2611 of this title","children":[],"tail":") made after "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1433"},"text":"section 1433 of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2601"},"text":"section 2601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
