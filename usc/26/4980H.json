(a)(2), (b)(1)(B), and (c)(3)(B), (C), (5)(A)(ii), (6), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/119"},"text":"124 Stat. 119","children":[],"tail":". Sections 1302(c)(4), 1402, 1411, and 1412 of the Act are classified to sections 18022(c)(4), 18071, 18081, and 18082, respectively, of Title 42, The Public Health and Welfare. Section 10108 of the Act enacted former "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s139D"},"text":"section 139D of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18101"},"text":"section 18101 of Title 42","children":[],"tail":", amended sections 36B, 162, 4980H, 6056, and 6724 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s218b"},"text":"section 218b of Title 29","children":[],"tail":", Labor, and enacted provisions set out as notes under sections 36B, 162, 4980H, and 6056 of this title and former "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s139D"},"text":"section 139D of this title","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18001"},"text":"section 18001 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id460f1f36-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/168"},"text":"Pub. L. 118–168","children":[],"tail":" added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(2)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" substituted “Department of Veterans Affairs” for “Veterans Administration” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (c)(2)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/41"},"text":"Pub. L. 114–41","children":[],"tail":" added subpar. (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/10"},"text":"Pub. L. 112–10","children":[],"tail":" struck out par. (3). Text read as follows: “No assessable payment shall be imposed under paragraph (1) for any month with respect to any employee to whom the employer provides a free choice voucher under section 10108 of the Patient Protection and Affordable Care Act for such month.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/152/s1003/d"},"text":"Pub. L. 111–152, § 1003(d)","children":[],"tail":", redesignated subsec. (c) as (b) and struck out former subsec. (b) which related to large employers with enrollment waiting periods exceeding 60 days."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10106/e"},"text":"Pub. L. 111–148, § 10106(e)","children":[],"tail":", amended subsec. (b) generally. Prior to amendment, subsec. (b) related to large employers with enrollment waiting periods exceeding 30 days."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/152/s1003/d"},"text":"Pub. L. 111–152, § 1003(d)","children":[],"tail":", redesignated subsec. (d) as (c). Former subsec. (c) redesignated (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/152/s1003/b/1"},"text":"Pub. L. 111–152, § 1003(b)(1)","children":[],"tail":", substituted “an amount equal to "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":"⁄"},{"tag":"sub","attrib":{},"text":"12","children":[],"tail":" of $3,000” for “400 percent of the applicable payment amount” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10108/i/1/A"},"text":"Pub. L. 111–148, § 10108(i)(1)(A)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/152/s1003/d"},"text":"Pub. L. 111–152, § 1003(d)","children":[],"tail":", redesignated subsec. (e) as (d). Former subsec. (d) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/152/s1003/b/2"},"text":"Pub. L. 111–152, § 1003(b)(2)","children":[],"tail":", substituted “$2,000” for “$750”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/152/s1003/a"},"text":"Pub. L. 111–152, § 1003(a)","children":[],"tail":", amended subpar. (D) generally. Prior to amendment, text read as follows: “In the case of any employer the substantial annual gross receipts of which are attributable to the construction industry—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) subparagraph (A) shall be applied by substituting ‘who employed an average of at least 5 full-time employees on business days during the preceding calendar year and whose annual payroll expenses exceed $250,000 for such preceding calendar year’ for ‘who employed an average of at least 50 full-time employees on business days during the preceding calendar year’, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) subparagraph (B) shall be applied by substituting ‘5’ for ‘50’.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10106/f/2"},"text":"Pub. L. 111–148, § 10106(f)(2)","children":[],"tail":", added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/152/s1003/c"},"text":"Pub. L. 111–152, § 1003(c)","children":[],"tail":", added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10106/f/1"},"text":"Pub. L. 111–148, § 10106(f)(1)","children":[],"tail":", inserted “, with respect to any month,” after “means”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(5)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/152/s1003/b/3"},"text":"Pub. L. 111–152, § 1003(b)(3)","children":[],"tail":", substituted “subsection (b) and paragraph (1)” for “subsection (b)(2) and (d)(1)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/152/s1003/d"},"text":"Pub. L. 111–152, § 1003(d)","children":[],"tail":", redesignated subsec. (e) as (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id460f1f37-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id460f1f38-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2024 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/168/s4/b"},"text":"Pub. L. 118–168, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2587"},"text":"138 Stat. 2587","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/168/s4/b"},"text":"“The amendment made by this section [amending this section] shall apply to assessments proposed in taxable years beginning after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id460f1f39-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/41/tIV/s4007/a/2"},"text":"Pub. L. 114–41, title IV, § 4007(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-07-31"},"text":"July 31, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/466"},"text":"129 Stat. 466","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/41/tIV/s4007/a/2"},"text":"“The amendment made by this subsection [amending this section] shall apply to months beginning after ","children":[{"tag":"date","attrib":{"date":"2013-12-31"},"text":"December 31, 2013","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id460f1f3a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2011 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/10"},"text":"Pub. L. 112–10","children":[],"tail":" effective as if included in the provisions of, and the amendments made by, the provisions of "},{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" to which it relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/112/10/s1858/d"},"text":"section 1858(d) of Pub. L. 1