{"tag":"section","attrib":{"id":"id460f1f00-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H"},"text":null,"children":[{"tag":"num","attrib":{"value":"4980H"},"text":"§ 4980H.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Shared responsibility for employers regarding health coverage","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id460f1f01-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Large employers not offering health coverage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id460f1f02-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any applicable large employer fails to offer to its full-time employees (and their dependents) the opportunity to enroll in minimum essential coverage under an eligible employer-sponsored plan (as defined in section 5000A(f)(2)) for any month, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460f1f03-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least one full-time employee of the applicable large employer has been certified to the employer under section 1411 of the Patient Protection and Affordable Care Act as having enrolled for such month in a qualified health plan with respect to which an applicable premium tax credit or cost-sharing reduction is allowed or paid with respect to the employee,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then there is hereby imposed on the employer an assessable payment equal to the product of the applicable payment amount and the number of individuals employed by the employer as full-time employees during such month.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id460f1f04-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Large employers offering coverage with employees who qualify for premium tax credits or cost-sharing reductions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id460f1f05-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id460f1f06-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an applicable large employer offers to its full-time employees (and their dependents) the opportunity to enroll in minimum essential coverage under an eligible employer-sponsored plan (as defined in section 5000A(f)(2)) for any month, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id460f1f07-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 or more full-time employees of the applicable large employer has been certified to the employer under section 1411 of the Patient Protection and Affordable Care Act as having enrolled for such month in a qualified health plan with respect to which an applicable premium tax credit or cost-sharing reduction is allowed or paid with respect to the employee,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then there is hereby imposed on the employer an assessable payment equal to the product of the number of full-time employees of the applicable large employer described in subparagraph (B) for such month and an amount equal to ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":"⁄"},{"tag":"sub","attrib":{},"text":"12","children":[],"tail":" of $3,000."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460f1f08-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overall limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The aggregate amount of tax determined under paragraph (1) with respect to all employees of an applicable large employer for any month shall not exceed the product of the applicable payment amount and the number of individuals employed by the employer as full-time employees during such month.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id460f1f09-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id460f1f0a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable payment amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “applicable payment amount” means, with respect to any month, ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":"⁄"},{"tag":"sub","attrib":{},"text":"12","children":[],"tail":" of $2,000."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460f1f0b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable large employer","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id460f1f0c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “applicable large employer” means, with respect to a calendar year, an employer who employed an average of at least 50 full-time employees on business days during the preceding calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id460f1f0d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption for certain employers","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id460f1f0e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An employer shall not be considered to employ more than 50 full-time employees if—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id460f1f0f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/c/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employer’s workforce exceeds 50 full-time employees for 120 days or fewer during the calendar year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id460f1f10-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/c/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employees in excess of 50 employed during such 120-day period were seasonal workers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id460f1f11-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of seasonal workers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “seasonal worker” means a worker who performs labor or services on a seasonal basis as defined by the Secretary of Labor, including workers covered by section 500.20(s)(1) of title 29, Code of Federal Regulations and retail workers employed exclusively during holiday seasons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id460f1f12-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules for determining employer size","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this paragraph—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id460f1f13-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of aggregation rule for employers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All persons treated as a single employer under subsection (b), (c), (m), or (","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":") of section 414 of the Internal Revenue Code of 1986 shall be treated as 1 employer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id460f1f14-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employers not in existence in preceding year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an employer which was not in existence throughout the preceding calendar year, the determination of whether such employer is an applicable large employer shall be based on the average number of employees that it is reasonably expected such employer will employ on business days in the current calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id460f1f15-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/c/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Predecessors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any reference in this subsection to an employer shall include a reference to any predecessor of such employer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id460f1f16-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of employer size to assessable penalties","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id460f1f17-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/c/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The number of individuals employed by an applicable large employer as full-time employees during any month shall be reduced by 30 solely for purposes of calculating—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id460f1f18-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/c/2/D/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the assessable payment under subsection (a), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id460f1f19-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/c/2/D/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the overall limitation under subsection (b)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id460f1f1a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/c/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aggregation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of persons treated as 1 employer under subparagraph (C)(i), only 1 reduction under subclause (I) or (II) ","children":[{"tag":"ref","attrib":{"idref":"fn002248"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002248"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably means subclause (I) or (II) of clause (i)."}],"tail":" shall be allowed with respect to such persons and such reduction shall be allocated among such persons ratably on the basis of the number of full-time employees employed by each such person."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id460f1f1b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full-time equivalents treated as full-time employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Solely for purposes of determining whether an employer is an applicable large employer under this paragraph, an employer shall, in addition to the number of full-time employees for any month otherwise determined, include for such month a number of full-time employees determined by dividing the aggregate number of hours of service of employees who are not full-time employees for the month by 120.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id460f1f1c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption for health coverage under TRICARE or the Department of Veterans Affairs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Solely for purposes of determining whether an employer is an applicable large employer under this paragraph for any month, an individual shall not be taken into account as an employee for such month if such individual has medical coverage for such month under—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id460f1f1d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/c/2/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 55 of title 10, United States Code, including coverage under the TRICARE program, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id460f1f1e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/c/2/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under a health care program under chapter 17 or 18 of title 38, United States Code, as determined by the Secretary of Veterans Affairs, in coordination with the Secretary of Health and Human Services and the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460f1f1f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable premium tax credit and cost-sharing reduction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “applicable premium tax credit and cost-sharing reduction” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id460f1f20-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any premium tax credit allowed under section 36B,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id460f1f21-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any cost-sharing reduction under section 1402 of the Patient Protection and Affordable Care Act, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id460f1f22-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any advance payment of such credit or reduction under section 1412 of such Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460f1f23-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full-time employee","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id460f1f24-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “full-time employee” means, with respect to any month, an employee who is employed on average at least 30 hours of service per week.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id460f1f25-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hours of service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Secretary of Labor, shall prescribe such regulations, rules, and guidance as may be necessary to determine the hours of service of an employee, including rules for the application of this paragraph to employees who are not compensated on an hourly basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460f1f26-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inflation adjustment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id460f1f27-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any calendar year after 2014, each of the dollar amounts in subsection (b) and paragraph (1) shall be increased by an amount equal to the product of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id460f1f28-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/c/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such dollar amount, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id460f1f29-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/c/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the premium adjustment percentage (as defined in section 1302(c)(4) of the Patient Protection and Affordable Care Act) for the calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id460f1f2a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rounding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the amount of any increase under subparagraph (A) is not a multiple of $10, such increase shall be rounded to the next lowest multiple of $10.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460f1f2b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any term used in this section which is also used in the Patient Protection and Affordable Care Act shall have the same meaning as when used in such Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460f1f2c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax nondeductible","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For denial of deduction for the tax imposed by this section, see section 275(a)(6).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id460f1f2d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration and procedure","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id460f1f2e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any assessable payment provided by this section shall be paid upon notice and demand by the Secretary, and shall be assessed and collected in the same manner as an assessable penalty under subchapter B of chapter 68.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460f1f2f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide for the payment of any assessable payment provided by this section on an annual, monthly, or other periodic basis as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460f1f30-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with credits, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe rules, regulations, or guidance for the repayment of any assessable payment (including interest) if such payment is based on the allowance or payment of an applicable premium tax credit or cost-sharing reduction with respect to an employee, such allowance or payment is subsequently disallowed, and the assessable payment would not have been required to be made but for such allowance or payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460f1f31-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980H/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for response","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall allow an applicable large employer at least 90 days from the date of the first letter which informs the employer of a proposed assessment of the employer shared responsibility payment under this section to respond to the proposed assessment before taking any further action with respect to such proposed assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id460f1f32-3a70-11f1-a967-d35dac11796a"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI/s1513/a"},"text":"Pub. L. 111–148, title I, § 1513(a)","children":[],"tail":", title X, §§ 10106(e)–(f)(2), 10108(i)(1)(A), "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/253"},"text":"124 Stat. 253","children":[],"tail":", 910, 914; "},{"tag":"ref","attrib":{"href":"/us/pl/111/152/tI/s1003"},"text":"Pub. L. 111–152, title I, § 1003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-30"},"text":"Mar. 30, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1033"},"text":"124 Stat. 1033","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/10/dB/tVIII/s1858/b/4"},"tex