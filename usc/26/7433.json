{"tag":"section","attrib":{"id":"id4755cf28-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7433"},"text":null,"children":[{"tag":"num","attrib":{"value":"7433"},"text":"§ 7433.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil damages for certain unauthorized collection actions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4755cf29-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7433/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, in connection with any collection of Federal tax with respect to a taxpayer, any officer or employee of the Internal Revenue Service recklessly or intentionally, or by reason of negligence, disregards any provision of this title, or any regulation promulgated under this title, such taxpayer may bring a civil action for damages against the United States in a district court of the United States. Except as provided in section 7432, such civil action shall be the exclusive remedy for recovering damages resulting from such actions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4755cf2a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7433/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Damages","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any action brought under subsection (a) or petition filed under subsection (e), upon a finding of liability on the part of the defendant, the defendant shall be liable to the plaintiff in an amount equal to the lesser of $1,000,000 ($100,000, in the case of negligence) or the sum of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4755cf2b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7433/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actual, direct economic damages sustained by the plaintiff as a proximate result of the reckless or intentional or negligent actions of the officer or employee, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4755cf2c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7433/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs of the action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4755cf2d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7433/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Claims pursuant to this section shall be payable out of funds appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1304"},"text":"section 1304 of title 31","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4755cf2e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7433/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4755cf2f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7433/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement that administrative remedies be exhausted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A judgment for damages shall not be awarded under subsection (b) unless the court determines that the plaintiff has exhausted the administrative remedies available to such plaintiff within the Internal Revenue Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4755cf30-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7433/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mitigation of damages","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of damages awarded under subsection (b)(1) shall be reduced by the amount of such damages which could have reasonably been mitigated by the plaintiff.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4755cf31-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7433/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period for bringing action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, an action to enforce liability created under this section may be brought without regard to the amount in controversy and may be brought only within 2 years after the date the right of action accrues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4755cf32-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7433/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions for violations of certain bankruptcy procedures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4755cf33-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7433/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, in connection with any collection of Federal tax with respect to a taxpayer, any officer or employee of the Internal Revenue Service willfully violates any provision of section 362 (relating to automatic stay) or 524 (relating to effect of discharge) of title 11, United States Code (or any successor provision), or any regulation promulgated under such provision, such taxpayer may petition the bankruptcy court to recover damages against the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4755cf34-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7433/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remedy to be exclusive","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4755cf35-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7433/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), notwithstanding section 105 of such title 11, such petition shall be the exclusive remedy for recovering damages resulting from such actions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4755cf36-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7433/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain other actions permitted","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subparagraph (A) shall not apply to an action under section 362(h) of such title 11 for a violation of a stay provided by section 362 of such title; except that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4755cf37-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7433/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administrative and litigation costs in connection with such an action may only be awarded under section 7430; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4755cf38-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7433/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administrative costs may be awarded only if incurred on or after the date that the bankruptcy petition is filed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4755cf39-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tVI/s6241/a"},"text":"Pub. L. 100–647, title VI, § 6241(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3747"},"text":"102 Stat. 3747","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/168/tVIII"},"text":"Pub. L. 104–168, title VIII","children":[],"tail":", §§ 801(a), 802(a), "},{"tag":"date","attrib":{"date":"1996-07-30"},"text":"July 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1465"},"text":"110 Stat. 1465","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tIII/s3102/a"},"text":"Pub. L. 105–206, title III, § 3102(a)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/730"},"text":"112 Stat. 730","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4755cf3a-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4755cf3b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4755cf3c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7433 was renumbered 7437 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4755cf3d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s3102/a/1/A"},"text":"Pub. L. 105–206, § 3102(a)(1)(A)","children":[],"tail":", inserted “, or by reason of negligence,” after “recklessly or intentionally”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s3102/a/1/B/i"},"text":"Pub. L. 105–206, § 3102(a)(1)(B)(i)","children":[],"tail":", (c)(2), in introductory provisions, inserted “or petition filed under subsection (e)” after “subsection (a)” and inserted “($100,000, in the case of negligence)” after “$1,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s3102/a/1/B/ii"},"text":"Pub. L. 105–206, § 3102(a)(1)(B)(ii)","children":[],"tail":", inserted “or negligent” after “reckless or intentional”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s3102/a/2"},"text":"Pub. L. 105–206, § 3102(a)(2)","children":[],"tail":", substituted “Requirement that administrative remedies be exhausted” for “Award for damages may be reduced if administrative remedies not exhausted” in heading and amended text of par. (1) generally. Prior to amendment, text read as follows: “The amount of damages awarded under subsection (b) may be reduced if the court determines that the plaintiff has not exhausted the administrative remedies available to such plaintiff within the Internal Revenue Service.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s3102/c/1"},"text":"Pub. L. 105–206, § 3102(c)(1)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/168/s801/a"},"text":"Pub. L. 104–168, § 801(a)","children":[],"tail":", substituted “$1,000,000” for “$100,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/168/s802/a"},"text":"Pub. L. 104–168, § 802(a)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"Requirement that administrative remedies be exhausted","children":[],"tail":".—A judgment for damages shall not be awarded under subsection (b) unless the court determines that the plaintiff has exhausted the administrative remedies available to such plaintiff within the Internal Revenue Service.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4755cf3e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4755cf3f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206"},"text":"Pub. L. 105–206","children":[],"tail":" applicable to actions of officers or employees of Internal Revenue Service after "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/s3102/d"},"text":"section 3102(d) of Pub. L. 105–206","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s7426"},"text":"section 7426 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4755cf40-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/168/tVIII/s801/b"},"text":"Pub. L. 104–168, title VIII, § 801(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-07-30"},"text":"July 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1465"},"text":"110 Stat. 1465","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/168/tVIII/s801/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply to actions by officers or employees of the Internal Revenue Service after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1996-07-30"},"text":"July 30, 1996","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/168/tVIII/s802/b"},"text":"Pub. L. 104–168, title VIII, § 802(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-07-30"},"text":"July 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1465"},"text":"110 Stat. 1465","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/168/tVIII/s802/b"},"text":"“The amendment made by this section [amending this section] shall apply in the case of proceedings commenced after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1996-07-30"},"text":"July 30, 1996","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
