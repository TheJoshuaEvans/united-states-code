{"tag":"section","attrib":{"id":"id45126e91-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1411"},"text":null,"children":[{"tag":"num","attrib":{"value":"1411"},"text":"§ 1411.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of tax","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45126e92-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1411/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (e)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45126e93-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1411/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to individuals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of an individual, there is hereby imposed (in addition to any other tax imposed by this subtitle) for each taxable year a tax equal to 3.8 percent of the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45126e94-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1411/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" net investment income for such taxable year, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45126e95-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1411/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the excess (if any) of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45126e96-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1411/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the modified adjusted gross income for such taxable year, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45126e97-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1411/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the threshold amount.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45126e98-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1411/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to estates and trusts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of an estate or trust, there is hereby imposed (in addition to any other tax imposed by this subtitle) for each taxable year a tax of 3.8 percent of the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45126e99-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1411/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the undistributed net investment income for such taxable year, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45126e9a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1411/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the excess (if any) of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45126e9b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1411/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adjusted gross income (as defined in section 67(e)) for such taxable year, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45126e9c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1411/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the dollar amount at which the highest tax bracket in section 1(e) begins for such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45126e9d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1411/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Threshold amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter, the term “threshold amount” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45126e9e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1411/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a taxpayer making a joint return under section 6013 or a surviving spouse (as defined in section 2(a)), $250,000,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45126e9f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1411/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a married taxpayer (as defined in section 7703) filing a separate return, ½ of the dollar amount determined under paragraph (1), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45126ea0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1411/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any other case, $200,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45126ea1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1411/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Net investment income","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45126ea2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1411/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “net investment income” means the excess (if any) of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45126ea3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1411/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the sum of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45126ea4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1411/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gross income from interest, dividends, annuities, royalties, and rents, other than such income which is derived in the ordinary course of a trade or business not described in paragraph (2),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45126ea5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1411/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other gross income derived from a trade or business described in paragraph (2), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45126ea6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1411/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" net gain (to the extent taken into account in computing taxable income) attributable to the disposition of property other than property held in a trade or business not described in paragraph (2), over","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45126ea7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1411/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deductions allowed by this subtitle which are properly allocable to such gross income or net gain.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45126ea8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1411/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trades and businesses to which tax applies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A trade or business is described in this paragraph if such trade or business is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45126ea9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1411/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a passive activity (within the meaning of section 469) with respect to the taxpayer, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45126eaa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1411/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a trade or business of trading in financial instruments or commodities (as defined in section 475(e)(2)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45126eab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1411/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Income on investment of working capital subject to tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A rule similar to the rule of section 469(e)(1)(B) shall apply for purposes of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45126eac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1411/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for certain active interests in partnerships and S corporations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a disposition of an interest in a partnership or S corporation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45126ead-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1411/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gain from such disposition shall be taken into account under clause (iii) of paragraph (1)(A) only to the extent of the net gain which would be so taken into account by the transferor if all property of the partnership or S corporation were sold for fair market value immediately before the disposition of such interest, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45126eae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1411/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a rule similar to the rule of subparagraph (A) shall apply to a loss from such disposition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45126eaf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1411/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for distributions from qualified plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “net investment income” shall not include any distribution from a plan or arrangement described in section 401(a), 403(a), 403(b), 408, 408A, or 457(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45126eb0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1411/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Net investment income shall not include any item taken into account in determining self-employment income for such taxable year on which a tax is imposed by section 1401(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45126eb1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1411/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modified adjusted gross income","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter, the term “modified adjusted gross income” means adjusted gross income increased by the excess of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45126eb2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1411/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount excluded from gross income under section 911(a)(1), over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45126eb3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1411/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of any deductions (taken into account in computing adjusted gross income) or exclusions disallowed under section 911(d)(6) with respect to the amounts described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45126eb4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1411/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplication of section","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section shall not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45126eb5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1411/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonresident alien, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45126eb6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1411/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a trust all of the unexpired interests in which are devoted to one or more of the purposes described in section 170(c)(2)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45126eb7-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/152/tI/s1402/a/1"},"text":"Pub. L. 111–152, title I, § 1402(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-30"},"text":"Mar. 30, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1061"},"text":"124 Stat. 1061","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45126eb8-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45126eb9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id45126eba-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/152/tI/s1402/a/4"},"text":"Pub. L. 111–152, title I, § 1402(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-30"},"text":"Mar. 30, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1063"},"text":"124 Stat. 1063","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/152/tI/s1402/a/4"},"text":"“The amendments made by this subsection [enacting this chapter and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6654"},"text":"section 6654 of this title","children":[],"tail":"] shall apply to taxable years beginning after "},{"tag":"date","attrib":{"date":"2012-12-31"},"text":"December 31, 2012","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
