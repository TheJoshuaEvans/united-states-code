{"tag":"section","attrib":{"id":"id44fceba7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1392"},"text":null,"children":[{"tag":"num","attrib":{"value":"1392"},"text":"§ 1392.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility criteria","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44fceba8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1392/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A nominated area shall be eligible for designation under section 1391 only if it meets the following criteria:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44fceba9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1392/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Population","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The nominated area has a maximum population of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44fcebaa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1392/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of an urban area, the lesser of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44fcebab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1392/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 200,000, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44fcebac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1392/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the greater of 50,000 or 10 percent of the population of the most populous city located within the nominated area, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44fcebad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1392/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a rural area, 30,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44fcebae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1392/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The nominated area is one of pervasive poverty, unemployment, and general distress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44fcebaf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1392/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Size","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The nominated area—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44fcebb0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1392/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not exceed 20 square miles if an urban area or 1,000 square miles if a rural area,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44fcebb1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1392/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a boundary which is continuous, or, except in the case of a rural area located in more than 1 State, consists of not more than 3 noncontiguous parcels,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44fcebb2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1392/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44fcebb3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1392/a/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an urban area, is located entirely within no more than 2 contiguous States, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44fcebb4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1392/a/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a rural area, is located entirely within no more than 3 contiguous States, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44fcebb5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1392/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include any portion of a central business district (as such term is used for purposes of the most recent Census of Retail Trade) unless the poverty rate for each population census tract in such district is not less than 35 percent (30 percent in the case of an enterprise community).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44fcebb6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1392/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Poverty rate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The poverty rate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44fcebb7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1392/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each population census tract within the nominated area is not less than 20 percent,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44fcebb8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1392/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for at least 90 percent of the population census tracts within the nominated area is not less than 25 percent, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44fcebb9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1392/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for at least 50 percent of the population census tracts within the nominated area is not less than 35 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44fcebba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1392/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules relating to determination of poverty rate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a)(4)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44fcebbb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1392/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of census tracts with small populations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44fcebbc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1392/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tracts with no population","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a population census tract with no population—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44fcebbd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1392/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such tract shall be treated as having a poverty rate which meets the requirements of subparagraphs (A) and (B) of subsection (a)(4), but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44fcebbe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1392/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such tract shall be treated as having a zero poverty rate for purposes of applying subparagraph (C) thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44fcebbf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1392/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tracts with populations of less than 2,000","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A population census tract with a population of less than 2,000 shall be treated as having a poverty rate which meets the requirements of subparagraphs (A) and (B) of subsection (a)(4) if more than 75 percent of such tract is zoned for commercial or industrial use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44fcebc0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1392/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discretion to adjust requirements for enterprise communities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining whether a nominated area is eligible for designation as an enterprise community, the appropriate Secretary may, where necessary to carry out the purposes of this subchapter, reduce by 5 percentage points one of the following thresholds for not more than 10 percent of the population census tracts (or, if fewer, 5 population census tracts) in the nominated area:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44fcebc1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1392/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The 20 percent threshold in subsection (a)(4)(A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44fcebc2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1392/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The 25 percent threshold in subsection (a)(4)(B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44fcebc3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1392/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The 35 percent threshold in subsection (a)(4)(C).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"If the appropriate Secretary elects to reduce the threshold under subparagraph (C), such Secretary may (in lieu of applying the preceding sentence) reduce by 10 percentage points the threshold under subparagraph (C) for 3 population census tracts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44fcebc4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1392/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Each noncontiguous area must satisfy poverty rate rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A nominated area may not include a noncontiguous parcel unless such parcel separately meets (subject to paragraphs (1) and (2)) the criteria set forth in subsection (a)(4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44fcebc5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1392/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Areas not within census tracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an area which is not tracted for population census tracts, the equivalent county divisions (as defined by the Bureau of the Census for purposes of defining poverty areas) shall be used for purposes of determining poverty rates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44fcebc6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1392/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors to consider","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From among the nominated areas eligible for designation under section 1391 by the appropriate Secretary, such appropriate Secretary shall make designations of empowerment zones and enterprise communities on the basis of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44fcebc7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1392/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of the strategic plan submitted pursuant to section 1391(f)(2) and the assurances made pursuant to section 1391(e)(3), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44fcebc8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1392/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" criteria specified by the appropriate Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44fcebc9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1392/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special eligibility for nominated areas located in Alaska or Hawaii","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A nominated area in Alaska or Hawaii shall be treated as meeting the requirements of paragraphs (2), (3), and (4) of subsection (a) if for each census tract or block group within such area 20 percent or more of the families have income which is 50 percent or less of the statewide median family income (as determined under section 143).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44fcebca-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13301/a"},"text":"Pub. L. 103–66, title XIII, § 13301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/545"},"text":"107 Stat. 545","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tIX/s954"},"text":"Pub. L. 105–34, title IX, § 954","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/888"},"text":"111 Stat. 888","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44fcebcb-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44fcebcc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id44fcebcd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1392, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600/tVI/s601/a"},"text":"Pub. L. 95–600, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2893"},"text":"92 Stat. 2893","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/222/tI/s106/a/5"},"text":"Pub. L. 96–222, title I, § 106(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-04-01"},"text":"Apr. 1, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/221"},"text":"94 Stat. 221","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/595/s3/a/3"},"text":"Pub. L. 96–595, § 3(a)(3)","children":[],"tail":", (4), "},{"tag":"date","attrib":{"date":"1980-12-24"},"text":"Dec. 24, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3465"},"text":"94 Stat. 3465","children":[],"tail":", related to election by general stock ownership corporations not to be subject to taxes imposed by this chapter, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXIII/s1303/a"},"text":"Pub. L. 99–514, title XIII, § 1303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2658"},"text":"100 Stat. 2658","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44fcebce-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
