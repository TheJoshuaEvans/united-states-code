{"tag":"section","attrib":{"id":"id45420a2c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2511"},"text":null,"children":[{"tag":"num","attrib":{"value":"2511"},"text":"§ 2511.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers in general","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45420a2d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2511/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the limitations contained in this chapter, the tax imposed by section 2501 shall apply whether the transfer is in trust or otherwise, whether the gift is direct or indirect, and whether the property is real or personal, tangible or intangible; but in the case of a nonresident not a citizen of the United States, shall apply to a transfer only if the property is situated within the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45420a2e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2511/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intangible property","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter, in the case of a nonresident not a citizen of the United States who is excepted from the application of section 2501(a)(2)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45420a2f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2511/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shares of stock issued by a domestic corporation, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45420a30-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2511/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" debt obligations of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45420a31-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2511/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a United States person, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45420a32-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2511/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States, a State or any political subdivision thereof, or the District of Columbia,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"which are owned and held by such nonresident shall be deemed to be property situated within the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45420a33-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/406"},"text":"68A Stat. 406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/809/tI/s109/b"},"text":"Pub. L. 89–809, title I, § 109(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-13"},"text":"Nov. 13, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1575"},"text":"80 Stat. 1575","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/16/tV/s511/e"},"text":"Pub. L. 107–16, title V, § 511(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-06-07"},"text":"June 7, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/71"},"text":"115 Stat. 71","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/147/tIV/s411/g/1"},"text":"Pub. L. 107–147, title IV, § 411(g)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-03-09"},"text":"Mar. 9, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/46"},"text":"116 Stat. 46","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/312/tIII/s302/e"},"text":"Pub. L. 111–312, title III, § 302(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-17"},"text":"Dec. 17, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3302"},"text":"124 Stat. 3302","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45420a34-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45420a35-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45420a36-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/312"},"text":"Pub. L. 111–312","children":[],"tail":" struck out subsec. (c). Text read as follows: “Notwithstanding any other provision of this section and except as provided in regulations, a transfer in trust shall be treated as a transfer of property by gift, unless the trust is treated as wholly owned by the donor or the donor’s spouse under subpart E of part I of subchapter J of chapter 1.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/147"},"text":"Pub. L. 107–147","children":[],"tail":" substituted “transfer of property by gift,” for “taxable gift under section 2503,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16"},"text":"Pub. L. 107–16","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/809"},"text":"Pub. L. 89–809","children":[],"tail":" inserted reference to nonresidents who are excepted from the application of section 2501(a)(2) and expanded section to include debt obligations of United States persons or the United States, a State or any political subdivision thereof, or the District of Columbia."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45420a37-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45420a38-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/312"},"text":"Pub. L. 111–312","children":[],"tail":" applicable to estates of decedents dying, generation-skipping transfers, and gifts made, after "},{"tag":"date","attrib":{"date":"2009-12-31"},"text":"Dec. 31, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/312/s302/f"},"text":"section 302(f) of Pub. L. 111–312","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2001"},"text":"sect