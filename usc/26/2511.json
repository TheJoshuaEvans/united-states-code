","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/809"},"text":"Pub. L. 89–809","children":[],"tail":" applicable with respect to calendar year 1967 and all calendar years thereafter, see "},{"tag":"ref","attrib":{"href":"/us/pl/89/809/s109/c"},"text":"section 109(c) of Pub. L. 89–809","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2501"},"text":"section 2501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
