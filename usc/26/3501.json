{"tag":"section","attrib":{"id":"id45a3d942-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3501"},"text":null,"children":[{"tag":"num","attrib":{"value":"3501"},"text":"§ 3501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection and payment of taxes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45a3d943-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3501/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The taxes imposed by this subtitle shall be collected by the Secretary and shall be paid into the Treasury of the United States as internal-revenue collections.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45a3d944-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3501/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxes with respect to non-cash fringe benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The taxes imposed by this subtitle with respect to non-cash fringe benefits shall be collected (or paid) by the employer at the time and in the manner prescribed by the Secretary by regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45a3d945-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/471"},"text":"68A Stat. 471","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)"