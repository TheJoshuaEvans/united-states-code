{"tag":"section","attrib":{"id":"id44d6c4f9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272"},"text":null,"children":[{"tag":"num","attrib":{"value":"1272"},"text":"§ 1272.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Current inclusion in income of original issue discount","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44d6c4fa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Original issue discount included in income on basis of constant interest rate","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44d6c4fb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this title, there shall be included in the gross income of the holder of any debt instrument having original issue discount, an amount equal to the sum of the daily portions of the original issue discount for each day during the taxable year on which such holder held such debt instrument.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d6c4fc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall not apply to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44d6c4fd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax-exempt obligations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any tax-exempt obligation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d6c4fe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States savings bonds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any United States savings bond.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d6c4ff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short-term obligations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any debt instrument which has a fixed maturity date not more than 1 year from the date of issue.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d6c500-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loans between natural persons","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44d6c501-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/a/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any loan made by a natural person to another natural person if—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id44d6c502-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/a/2/D/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such loan is not made in the course of a trade or business of the lender, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id44d6c503-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/a/2/D/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of such loan (when increased by the outstanding amount of prior loans by such natural person to such other natural person) does not exceed $10,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44d6c504-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/a/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clause (i) not to apply where tax avoidance a principal purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Clause (i) shall not apply if the loan has as 1 of its principal purposes the avoidance of any Federal tax.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44d6c505-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/a/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of husband and wife","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subparagraph, a husband and wife shall be treated as 1 person. The preceding sentence shall not apply where the spouses lived apart at all times during the taxable year in which the loan is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d6c506-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of daily portions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), the daily portion of the original issue discount on any debt instrument shall be determined by allocating to each day in any accrual period its ratable portion of the increase during such accrual period in the adjusted issue price of the debt instrument. For purposes of the preceding sentence, the increase in the adjusted issue price for any accrual period shall be an amount equal to the excess (if any) of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44d6c507-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the product of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44d6c508-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adjusted issue price of the debt instrument at the beginning of such accrual period, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44d6c509-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the yield to maturity (determined on the basis of compounding at the close of each accrual period and properly adjusted for the length of the accrual period), over","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d6c50a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sum of the amounts payable as interest on such debt instrument during such accrual period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d6c50b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjusted issue price","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the adjusted issue price of any debt instrument at the beginning of any accrual period is the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44d6c50c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the issue price of such debt instrument, plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d6c50d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adjustments under this subsection to such issue price for all periods before the first day of such accrual period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d6c50e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accrual period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in regulations prescribed by the Secretary, the term “accrual period” means a 6-month period (or shorter period from the date of original issue of the debt instrument) which ends on a day in the calendar year corresponding to the maturity date of the debt instrument or the date 6 months before such maturity date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d6c50f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of daily portions where principal subject to acceleration","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44d6c510-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any debt instrument to which this paragraph applies, the daily portion of the original issue discount shall be determined by allocating to each day in any accrual period its ratable portion of the excess (if any) of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44d6c511-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/a/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sum of (I) the present value determined under subparagraph (B) of all remaining payments under the debt instrument as of the close of such period, and (II) the payments during the accrual period of amounts included in the stated redemption price of the debt instrument, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44d6c512-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/a/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adjusted issue price of such debt instrument at the beginning of such period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d6c513-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of present value","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subparagraph (A), the present value shall be determined on the basis of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44d6c514-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/a/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the original yield to maturity (determined on the basis of compounding at the close of each accrual period and properly adjusted for the length of the accrual period),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44d6c515-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/a/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" events which have occurred before the close of the accrual period, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44d6c516-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/a/6/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a prepayment assumption determined in the manner prescribed by regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d6c517-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/a/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Debt instruments to which paragraph applies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This paragraph applies to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44d6c518-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/a/6/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any regular interest in a REMIC or qualified mortgage held by a REMIC,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44d6c519-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/a/6/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other debt instrument if payments under such debt instrument may be accelerated by reason of prepayments of other obligations securing such debt instrument (or, to the extent provided in regulations, by reason of other events), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44d6c51a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/a/6/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any pool of debt instruments the yield on which may be affected by reason of prepayments (or to the extent provided in regulations, by reason of other events).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"To the extent provided in regulations prescribed by the Secretary, in the case of a small business engaged in the trade or business of selling tangible personal property at retail, clause (iii) shall not apply to debt instruments incurred in the ordinary course of such trade or business while held by such business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d6c51b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction where subsequent holder pays acquisition premium","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44d6c51c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, in the case of any purchase after its original issue of a debt instrument to which this subsection applies, the daily portion for any day shall be reduced by an amount equal to the amount which would be the daily portion for such day (without regard to this paragraph) multiplied by the fraction determined under subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d6c51d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of fraction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subparagraph (A), the fraction determined under this subparagraph is a fraction—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44d6c51e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/a/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the numerator of which is the excess (if any) of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id44d6c51f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/a/7/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of such debt instrument incurred by the purchaser, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id44d6c520-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/a/7/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the issue price of such debt instrument, increased by the portion of original issue discount previously includible in the gross income of any holder (computed without regard to this paragraph), and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44d6c521-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/a/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the denominator of which is the sum of the daily portions for such debt instrument for all days after the date of such purchase and ending on the stated maturity date (computed without regard to this paragraph).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44d6c522-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section shall not apply to any holder—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44d6c523-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has purchased the debt instrument at a premium, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d6c524-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is a life insurance company to which section 811(b) applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44d6c525-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition and special rule","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44d6c526-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchase defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “purchase” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44d6c527-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any acquisition of a debt instrument, where","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d6c528-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the basis of the debt instrument is not determined in whole or in part by reference to the adjusted basis of such debt instrument in the hands of the person from whom acquired.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d6c529-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1272/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis adjustment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The basis of any debt instrument in the hands of the holder thereof shall be increased by the amount included in his gross income pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44d6c52a-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s41/a"},"text":"Pub. L. 98–369, div. A, title I, § 41(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/533"},"text":"98 Stat. 533","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVI/s672"},"text":"Pub. L. 99–514, title VI, § 672","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2318"},"text":"100 Stat. 2318","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tX/s1004/a"},"text":"Pub. L. 105–34, title X, § 1004(a)","children":[],"tail":", "},{"tag":"date","attrib":