{"tag":"section","attrib":{"id":"id474c5982-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7407"},"text":null,"children":[{"tag":"num","attrib":{"value":"7407"},"text":"§ 7407.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action to enjoin tax return preparers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id474c5983-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7407/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to seek injunction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A civil action in the name of the United States to enjoin any person who is a tax return preparer from further engaging in any conduct described in subsection (b) or from further acting as a tax return preparer may be commenced at the request of the Secretary. Any action under this section shall be brought in the District Court of the United States for the district in which the tax return preparer resides or has his principal place of business or in which the taxpayer with respect to whose tax return the action is brought resides. The court may exercise its jurisdiction over such action (as provided in section 7402(a)) separate and apart from any other action brought by the United States against such tax return preparer or any taxpayer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id474c5984-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7407/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjudication and decrees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any action under subsection (a), if the court finds—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id474c5985-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7407/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that a tax return preparer has—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id474c5986-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7407/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engaged in any conduct subject to penalty under section 6694 or 6695, or subject to any criminal penalty provided by this title,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id474c5987-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7407/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" misrepresented his eligibility to practice before the Internal Revenue Service, or otherwise misrepresented his experience or education as a tax return preparer,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id474c5988-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7407/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guaranteed the payment of any tax refund or the allowance of any tax credit, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id474c5989-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7407/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engaged in any other fraudulent or deceptive conduct which substantially interferes with the proper administration of the Internal Revenue laws, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id474c598a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7407/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that injunctive relief is appropriate to prevent the recurrence of such conduct,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the court may enjoin such person from further engaging in such conduct. If the court finds that a tax return preparer has continually or repeatedly engaged in any conduct described in subparagraphs (A) through (D) of this subsection and that an injunction prohibiting such conduct would not be sufficient to prevent such person’s interference with the proper administration of this title, the court may enjoin such person from acting as a tax return preparer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id474c598b-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXII/s1203/g"},"text":"Pub. L. 94–455, title XII, § 1203(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1693"},"text":"90 Stat. 1693","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7738/a"},"text":"Pub. L. 101–239, title VII, § 7738(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2404"},"text":"103 Stat. 2404","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/28/tVIII/s8246/a/2/I/i"},"text":"Pub. L. 110–28, title VIII, § 8246(a)(2)(I)(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-05-25"},"text":"May 25, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/202"},"text":"121 Stat. 202","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id474c598c-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id474c598d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id474c598e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7407 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s7410"},"text":"section 7410 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id474c598f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/28/s8246/a/2/I/i/I"},"text":"Pub. L. 110–28, § 8246(a)(2)(I)(i)(I)","children":[],"tail":", substituted “tax return preparers” for “income tax return preparers” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/28/s8246/a/2/I/i/II"},"text":"Pub. L. 110–28, § 8246(a)(2)(I)(i)(II)","children":[],"tail":"–(IV), substituted “tax return” for “income tax return” after “with respect to whose”, “tax return preparer” for “income tax preparer” after “district in which the” and after “against such”, and “a tax return preparer” for “an income tax return preparer” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/28/s8246/a/2/I/i/II"},"text":"Pub. L. 110–28, § 8246(a)(2)(I)(i)(II)","children":[],"tail":", substituted “a tax return preparer” for “an income tax return preparer” in introductory provisions and subpar. (B) of par. (1) and in two places in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7738/b"},"text":"Pub. L. 101–239, § 7738(b)","children":[],"tail":", substituted “A civil” for “Except as provided in subsection (c), a civil”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7738/a"},"text":"Pub. L. 101–239, § 7738(a)","children":[],"tail":", struck out subsec. (c) relating to bonds to stay injunctions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id474c5990-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id474c5991-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/28"},"text":"Pub. L. 110–28","children":[],"tail":" applicable to returns prepared after "},{"tag":"date","attrib":{"date":"2007-05-25"},"text":"May 25, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/28/s8246/c"},"text":"section 8246(c) of Pub. L. 110–28","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6060"},"text":"section 6060 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id474c5992-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7738/c"},"text":"Pub. L. 101–239, title VII, § 7738(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2404"},"text":"103 Stat. 2404","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/239/tVII/s7738/c"},"text":"“The amendments made by this section [amending this section] shall apply to actions commenced after ","children":[{"tag":"date","attrib":{"date":"1989-12-31"},"text":"December 31, 1989","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id474c5993-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to documents prepared after ","children":[{"tag":"date","attrib":{"date":"1976-12-31"},"text":"Dec. 31, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1203/j"},"text":"section 1203(j) of Pub. L. 94–455","children":[],"tail":", set out as an Effective Date of 1976 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s7701"},"text":"section 7701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
