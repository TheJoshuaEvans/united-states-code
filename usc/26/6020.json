{"tag":"section","attrib":{"id":"id465dda7b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6020"},"text":null,"children":[{"tag":"num","attrib":{"value":"6020"},"text":"§ 6020.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Returns prepared for or executed by Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id465dda7c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6020/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preparation of return by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any person shall fail to make a return required by this title or by regulations prescribed thereunder, but shall consent to disclose all information necessary for the preparation thereof, then, and in that case, the Secretary may prepare such return, which, being signed by such person, may be received by the Secretary as the return of such person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id465dda7d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6020/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Execution of return by Secretary","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id465dda7e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6020/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary to execute return","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any person fails to make any return required by any internal revenue law or regulation made thereunder at the time prescribed therefor, or makes, willfully or otherwise, a false or fraudulent return, the Secretary shall make such return from his own knowledge and from such information as he can obtain through testimony or otherwise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id465dda7f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6020/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status of returns","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any return so made and subscribed by the Secretary shall be prima facie good and sufficient for all legal purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id465dda80-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/740"},"text":"68A Stat. 740","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/364/tI/s103/e/3"},"text":"Pub. L. 90–364, title I, § 103(e)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-06-28"},"text":"June 28, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/264"},"text":"82 Stat. 264","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tIV/s412/b/4"},"text":"Pub. L. 98–369, div. A, title IV, § 412(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 19