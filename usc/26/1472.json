{"tag":"section","attrib":{"id":"id45199b21-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1472"},"text":null,"children":[{"tag":"num","attrib":{"value":"1472"},"text":"§ 1472.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withholdable payments to other foreign entities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45199b22-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1472/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any withholdable payment to a non-financial foreign entity, if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45199b23-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1472/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the beneficial owner of such payment is such entity or any other non-financial foreign entity, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45199b24-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1472/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirements of subsection (b) are not met with respect to such beneficial owner,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then the withholding agent with respect to such payment shall deduct and withhold from such payment a tax equal to 30 percent of the amount of such payment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45199b25-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1472/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for waiver of withholding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirements of this subsection are met with respect to the beneficial owner of a payment if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45199b26-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1472/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such beneficial owner or the payee provides the withholding agent with either—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45199b27-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1472/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification that such beneficial owner does not have any substantial United States owners, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45199b28-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1472/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address, and TIN of each substantial United States owner of such beneficial owner,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45199b29-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1472/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the withholding agent does not know, or have reason to know, that any information provided under paragraph (1) is incorrect, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45199b2a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1472/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the withholding agent reports the information provided under paragraph (1)(B) to the Secretary in such manner as the Secretary may provide.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45199b2b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1472/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45199b2c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1472/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" except as otherwise provided by the Secretary, any payment beneficially owned by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45199b2d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1472/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any corporation the stock of which is regularly traded on an established securities market,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45199b2e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1472/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any corporation which is a member of the same expanded affiliated group (as defined in section 1471(e)(2) without regard to the last sentence thereof) as a corporation described in subparagraph (A),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45199b2f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1472/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any entity which is organized under the laws of a possession of the United States and which is wholly owned by one or more bona fide residents (as defined in section 937(a)) of such possession,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45199b30-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1472/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any foreign government, any political subdivision of a foreign government, or any wholly owned agency or instrumentality of any one or more of the foregoing,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45199b31-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1472/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any international organization or any wholly owned agency or instrumentality thereof,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45199b32-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1472/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any foreign central bank of issue, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45199b33-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1472/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other class of persons identified by the Secretary for purposes of this subsection, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45199b34-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1472/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any class of payments identified by the Secretary for purposes of this subsection as posing a low risk of tax evasion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45199b35-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1472/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-financial foreign entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “non-financial foreign entity” means any foreign entity which is not a financial institution (as defined in section 1471(d)(5)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45199b36-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/147/tV/s501/a"},"text":"Pub. L. 111–147, title V, § 501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-18"},"text":"Mar. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/102"},"text":"124 Stat. 102","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
