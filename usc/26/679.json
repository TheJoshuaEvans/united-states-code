{"tag":"section","attrib":{"id":"id43f69f19-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s679"},"text":null,"children":[{"tag":"num","attrib":{"value":"679"},"text":"§ 679.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign trusts having one or more United States beneficiaries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id43f69f1a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s679/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transferor treated as owner","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43f69f1b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s679/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A United States person who directly or indirectly transfers property to a foreign trust (other than a trust described in section 6048(a)(3)(B)(ii)) shall be treated as the owner for his taxable year of the portion of such trust attributable to such property if for such year there is a United States beneficiary of any portion of such trust.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43f69f1c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s679/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall not apply—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43f69f1d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s679/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers by reason of death","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To any transfer by reason of the death of the transferor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43f69f1e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s679/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers at fair market value","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To any transfer of property to a trust in exchange for consideration of at least the fair market value of the transferred property. For purposes of the preceding sentence, consideration other than cash shall be taken into account at its fair market value.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43f69f1f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s679/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain obligations not taken into account under fair market value exception","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43f69f20-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s679/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining whether paragraph (2)(B) applies to any transfer by a person described in clause (ii) or (iii) of subparagraph (C), there shall not be taken into account—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id43f69f21-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s679/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in regulations, any obligation of a person described in subparagraph (C), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43f69f22-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s679/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent provided in regulations, any obligation which is guaranteed by a person described in subparagraph (C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43f69f23-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s679/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of principal payments on obligation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Principal payments by the trust on any obligation referred to in subparagraph (A) shall be taken into account on and after the date of the payment in determining the portion of the trust attributable to the property transferred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43f69f24-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s679/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The persons described in this subparagraph are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id43f69f25-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s679/a/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the trust,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43f69f26-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s679/a/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any grantor, owner, or beneficiary of the trust, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43f69f27-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s679/a/3/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person who is related (within the meaning of section 643(i)(2)(B)) to any grantor, owner, or beneficiary of the trust.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43f69f28-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s679/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules applicable to foreign grantor who later becomes a United States person","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43f69f29-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s679/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a nonresident alien individual has a residency starting date within 5 years after directly or indirectly transferring property to a foreign trust, this section and section 6048 shall be applied as if such individual transferred to such trust on the residency starting date an amount equal to the portion of such trust attributable to the property transferred by such individual to such trust in such transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43f69f2a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s679/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of undistributed income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, undistributed net income for periods before such individual’s residency starting date shall be taken into account in determining the portion of the trust which is attributable to property transferred by such individual to such trust but shall not otherwise be taken into account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43f69f2b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s679/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Residency starting date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this paragraph, an individual’s residency starting date is the residency starting date determined under section 7701(b)(2)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43f69f2c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s679/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outbound trust migrations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43f69f2d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s679/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual who is a citizen or resident of the United States transferred property to a trust which was not a foreign trust, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43f69f2e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s679/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such trust becomes a foreign trust while such individual is alive,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then this section and section 6048 shall be applied as if such individual transferred to such trust on the date such trust becomes a foreign trust an amount equal to the portion of such trust attributable to the property previously transferred by such individual to such trust. A rule similar to the rule of paragraph (4)(B) shall apply for purposes of this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43f69f2f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s679/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trusts acquiring United States beneficiaries","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43f69f30-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s679/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (a) applies to a trust for the transferor’s taxable year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43f69f31-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s679/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (a) would have applied to the trust for his immediately preceding taxable year but for the fact that for such preceding taxable year there was no United States beneficiary for any portion of the trust,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then, for purposes of this subtitle, the transferor shall be treated as having income for the taxable year (in addition to his other income for such year) equal to the undistributed net income (at the close of such immediately preceding taxable year) attributable to the portion of the trust referred to in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43f69f32-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s679/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trusts treated as having a United States beneficiary","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43f69f33-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s679/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, a trust shall be treated as having a United States beneficiary for the taxable year unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43f69f34-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s679/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under the terms of the trust, no part of the income or corpus of the trust may be paid or accumulated during the taxable year to or for the benefit of a United States person, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43f69f35-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s679/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the trust were terminated at any time during the taxable year, no part of the income or corpus of such trust could be paid to or for the benefit of a United States person.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of subparagraph (A), an amount shall be treated as accumulated for the benefit of a United States person even if the United States person’s interest in the trust is contingent on a future event.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43f69f36-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s679/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attribution of ownership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), an amount shall be treated as paid or accumulated to or for the benefit of a United States person if such amount is paid to or accumulated for a foreign corporation, foreign partnership, or foreign trust or estate, and—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43f69f37-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s679/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a foreign corporation, such corporation is a controlled foreign corporation (as defined in section 957(a)),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43f69f38-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s679/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a foreign partnership, a United States person is a partner of such partnership, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43f69f39-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s679/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a foreign trust or estate, such trust or estate has a United States beneficiary (within the meaning of paragraph (1)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43f69f3a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s679/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain United States beneficiaries disregarded","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A beneficiary shall not be treated as a United States person in applying this section with respect to any transfer of property to foreign trust if such beneficiary first became a United States person more than 5 years after the date of such transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43f69f3b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s679/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule in case of discretion to identify beneficiaries","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1)(A), if any person has the discretion (by authority given in the trust agreement, by power of appointment, or otherwise) of making a distribution from the trust to, or for the benefit of, any person, such trust shall be treated as having a beneficiary who is a United States person unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43f69f3c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s679/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms of the trust specifically identify the class of persons to whom such distributions may be made, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43f69f3d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s679/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" none of those persons are United States persons during the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43f69f3e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s679/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain agreements and understandings treated as terms of the trust","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1)(A), if any United States person who directly or indirectly transfers property to the trust is directly or indirectly involved in any agreement or understanding (whether written, oral, or otherwise) that may result in the income or corpus of the trust being paid or accumulated to or for the benefit of a United States person, such agreement or understanding shall be treated as a term of the trust.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43f69f3f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s679/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uncompensated use of trust property treated as a payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, a loan of cash or marketable securities (or the use of any other trust property) directly or indirectly to or by any United States person (whether or not a beneficiary under the terms of the trust) shall be treated as paid or accumulated for the benefit of a United States person. The preceding sentence shall not apply to the extent that the United States person repays the loan at a market rate of interest (or pays the fair market value of the use of such property) within a reasonable period of time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43f69f40-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s679/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presumption that foreign trust has United States beneficiary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a United States person directly or indirectly transfers property to a foreign trust (other than a trust described in section 6048(a)(3)(B)(ii)), the Secretary may treat such trust as having a United States beneficiary for purposes of applying this section to such transfer unless such person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43f69f41-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s679/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submits such information to the Secretary as the Secretary may require with respect to such transfer, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43f69f42-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s679/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates to the satisfaction of the Secretary that such trust satisfies the requirements of subparagraphs (A) and (B) of subsection (c)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43f69f43-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s679/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such regulations as may be necessary or appropriate to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id43f69f44-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tX/s1013/a"},"text":"Pub. L. 94–455, title X, § 1013(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1614"},"text":"90 Stat. 1614","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/603/s2/b"},"text":"Pub. L. 96–603, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-28"},"text":"Dec. 28, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3509"},"text":"94 Stat. 3509","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1903/a"},"text":"Pub. L. 104–188, title I, § 1903(a)","children":[],"tail":"–(f), "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"t