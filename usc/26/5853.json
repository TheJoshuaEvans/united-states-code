{"tag":"section","attrib":{"id":"id4651f467-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5853"},"text":null,"children":[{"tag":"num","attrib":{"value":"5853"},"text":"§ 5853.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer and making tax exemption available to certain governmental entities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4651f468-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5853/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A firearm may be transferred without the payment of the transfer tax imposed by section 5811 to any State, possession of the United States, any political subdivision thereof, or any official police organization of such a government entity engaged in criminal investigations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4651f469-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5853/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Making","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A firearm may be made without payment of the making tax imposed by section 5821 by, or on behalf of, any State, or possession of the United States, any political subdivision thereof, or any official police organization of such a government entity engaged in criminal investigations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4651f46a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5853/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right to exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No firearm may be transferred or made exempt from tax under this section unless the transfer or making is performed pursuant to an application in such form and manner as the Secretary may by regulations prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4651f46b-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/618/tII/s201"},"text":"Pub. L. 90–618, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1233"},"text":"82 Stat. 1233","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4651f46c-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4651f46d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4651f46e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5853, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/728"},"text":"68A Stat. 728","children":[],"tail":", related to importing firearms illegally, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/90/618"},"text":"Pub. L. 90–618","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5861/k"},"text":"section 5861(k) of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s922/a"},"text":"section 922(a) of Title 18","children":[],"tail":", Crimes and Criminal Procedure."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those comprising this section were contained in prior section 5821, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/724"},"text":"68A Stat. 724","children":[],"tail":", as amended by act "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s203/d"},"text":"Pub. L. 85–859, title II, § 203(d)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1427"},"text":"72 Stat. 1427","children":[],"tail":", prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/90/618"},"text":"Pub. L. 90–618","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4651f46f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
