{"tag":"section","attrib":{"id":"id44028597-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s734"},"text":null,"children":[{"tag":"num","attrib":{"value":"734"},"text":"§ 734.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment to basis of undistributed partnership property where section 754 election or substantial basis reduction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44028598-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s734/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The basis of partnership property shall not be adjusted as the result of a distribution of property to a partner unless the election, provided in section 754 (relating to optional adjustment to basis of partnership property), is in effect with respect to such partnership or unless there is a substantial basis reduction with respect to such distribution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44028599-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s734/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Method of adjustment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a distribution of property to a partner by a partnership with respect to which the election provided in section 754 is in effect or with respect to which there is a substantial basis reduction, the partnership shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4402859a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s734/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" increase the adjusted basis of partnership property by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4402859b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s734/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of any gain recognized to the distributee partner with respect to such distribution under section 731(a)(1), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4402859c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s734/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of distributed property to which section 732(a)(2) or (b) applies, the excess of the adjusted basis of the distributed property to the partnership immediately before the distribution (as adjusted by section 732(d)) over the basis of the distributed property to the distributee, as determined under section 732, or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4402859d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s734/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" decrease the adjusted basis of partnership property by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4402859e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s734/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of any loss recognized to the distributee partner with respect to such distribution under section 731(a)(2), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4402859f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s734/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of distributed property to which section 732(b) applies, the excess of the basis of the distributed property to the distributee, as determined under section 732, over the adjusted basis of the distributed property to the partnership immediately before such distribution (as adjusted by section 732(d)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Paragraph (1)(B) shall not apply to any distributed property which is an interest in another partnership with respect to which the election provided in section 754 is not in effect.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id440285a0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s734/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The allocation of basis among partnership properties where subsection (b) is applicable shall be made in accordance with the rules provided in section 755.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id440285a1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s734/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substantial basis reduction","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id440285a2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s734/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, there is a substantial basis reduction with respect to a distribution if the sum of the amounts described in subparagraphs (A) and (B) of subsection (b)(2) exceeds $250,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id440285a3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s734/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For regulations to carry out this subsection, see section 743(d)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id440285a4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s734/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for securitization partnerships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, a securitization partnership (as defined in section 743(f)) shall not be treated as having a substantial basis reduction with respect to any distribution of property to a partner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id440285a5-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/247"},"text":"68A Stat. 247","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s78/a"},"text":"Pub. L. 98–369, div. A, title I, § 78(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/597"},"text":"98 Stat. 597","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s833/c/1"},"text":"Pub. L. 108–357, title VIII, § 833(c)(1)","children":[],"tail":"–(5)(A), "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1591"},"text":"118 Stat. 1591","children":[],"tail":", 1592; "},{"tag":"ref","attrib":{"href":"/us/pl/109/135/tIV/s403/bb"},"text":"Pub. L. 109–135, title IV, § 403(bb)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-21"},"text":"Dec. 21, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2630"},"text":"119 Stat. 2630","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id440285a6-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id440285a7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id440285a8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/135/s403/bb/1"},"text":"Pub. L. 109–135, § 403(bb)(1)","children":[],"tail":", inserted “with respect to such distribution” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/135/s403/bb/2"},"text":"Pub. L. 109–135, § 403(bb)(2)","children":[],"tail":", reenacted heading without change and amended introductory provisions generally. Prior to amendment, introductory provisions read as follows: “In the case of a distribution of property to a partner, a partnership, with respect to which the election provided in section 754 is in effect or unless there is a substantial basis reduction, shall—”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s833/c/5/A"},"text":"Pub. L. 108–357, § 833(c)(5)(A)","children":[],"tail":", substituted “Adjustment to basis of undistributed partnership property where section 754 election or substantial basis reduction” for “Optional adjustment to basis of undistributed partnership property” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s833/c/1"},"text":"Pub. L. 108–357, § 833(c)(1)","children":[],"tail":", inserted “or unless there is a substantial basis reduction” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s833/c/2"},"text":"Pub. L. 108–357, § 833(c)(2)","children":[],"tail":", inserted “or unless there is a substantial basis reduction” after “section 754 is in effect” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s833/c/3"},"text":"Pub. L. 108–357, § 833(c)(3)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s833/c/4"},"text":"Pub. L. 108–357, § 833(c)(4)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" inserted at end “Paragraph (1)(B) shall not apply to any distributed property which is an interest in another partnership with respect to which the election provided in section 754 is not in effect.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id440285a9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id440285aa-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/135"},"text":"Pub. L. 109–135","children":[],"tail":" effective as if included in the provision of the American Jobs Creation Act of 2004, "},{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/135/s403/nn"},"text":"section 403(nn) of Pub. L. 109–135","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s26"},"text":"section 26 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id440285ab-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s833/d/3"},"text":"Pub. L. 108–357, title VIII, § 833(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1592"},"text":"118 Stat. 1592","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/357/tVIII/s833/d/3"},"text":"“The amendments made by subsection (c) [amending this section] shall apply to distributions after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id440285ac-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s78/b"},"text":"Pub. L. 98–369, div. A, title I, § 78(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/597"},"text":"98 Stat. 597","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/369/dA/tI/s78/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply to distributions after ","children":[{"tag":"date","attrib":{"date":"1984-03-01"},"text":"March 1, 1984","children":[],"tail":", in taxable years ending after such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
