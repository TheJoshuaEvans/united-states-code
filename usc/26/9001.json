{"tag":"section","attrib":{"id":"id47a6d5f5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9001"},"text":null,"children":[{"tag":"num","attrib":{"value":"9001"},"text":"§ 9001.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"This chapter may be cited as the “Presidential Election Campaign Fund Act”.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id47a6d5f6-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/178/tVIII/s801"},"text":"Pub. L. 92–178, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-10"},"text":"Dec. 10, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/563"},"text":"85 Stat. 563","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47a6d5f7-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47a6d5f8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id47a6d5f9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Adoption of Guidelines","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/26/s5"},"text":"Pub. L. 90–26, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-06-13"},"text":"June 13, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/58"},"text":"81 Stat. 58","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds which become available under the Presidential Election Campaign Fund Act of 1966 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6096"},"text":"section 6096 of this title","children":[],"tail":" and sections 971 to 973 of former Title 31, Money and Finance] shall be appropriated and disbursed only after the adoption by law of guidelines governing their distribution. Section 6096 of the Internal Revenue Code of 1986 [formerly I.R.C. 1954] shall become applicable only after the adoption by law of such guidelines."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Guidelines adopted in accordance with this section shall state expressly that they are intended to comply with this section.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id47a6d5fa-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Adoption of Guidelines: Compliance; Effective Date of Section 6096 and Amendment of Section 6096(a)","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/92/178/tVIII/s802/b/2"},"text":"Pub. L. 92–178, title VIII, § 802(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-10"},"text":"Dec. 10, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/573"},"text":"85 Stat. 573","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"“The enactment of Subtitle H of the Internal Revenue Code of 1986 [formerly I.R.C. 1954] by section 801 of this Act [this subtitle] is intended to comply with the provisions of section 5 (relating to the Presidential Election Campaign Fund Act of 1966) of the Act entitled ‘An Act to restore the investment credit and allowance of accelerated depreciation in the case of certain real property’, approved ","children":[{"tag":"date","attrib":{"date":"1967-06-13"},"text":"June 13, 1967","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/90/26"},"text":"Public Law 90–26","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/58"},"text":"81 Stat. 58","children":[],"tail":") [set out above]. The provisions of section 6096 of the Internal Revenue Code of 1986 together with the amendments of such section made by subsection (a), shall be applicable only to taxable years ending on or after "},{"tag":"date","attrib":{"date":"1972-12-31"},"text":"December 31, 1972","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
