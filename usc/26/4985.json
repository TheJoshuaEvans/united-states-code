{"tag":"section","attrib":{"id":"id46118fc5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4985"},"text":null,"children":[{"tag":"num","attrib":{"value":"4985"},"text":"§ 4985.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stock compensation of insiders in expatriated corporations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46118fc6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4985/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of tax","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of an individual who is a disqualified individual with respect to any expatriated corporation, there is hereby imposed on such person a tax equal to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46118fc7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4985/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate of tax specified in section 1(h)(1)(D), multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46118fc8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4985/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value (determined under subsection (b)) of the specified stock compensation held (directly or indirectly) by or for the benefit of such individual or a member of such individual’s family (as defined in section 267) at any time during the 12-month period beginning on the date which is 6 months before the expatriation date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46118fc9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4985/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Value","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46118fca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4985/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The value of specified stock compensation shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46118fcb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4985/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a stock option (or other similar right) or a stock appreciation right, the fair value of such option or right, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46118fcc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4985/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any other case, the fair market value of such compensation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46118fcd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4985/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Date for determining value","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The determination of value shall be made—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46118fce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4985/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of specified stock compensation held on the expatriation date, on such date,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46118fcf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4985/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of such compensation which is canceled during the 6 months before the expatriation date, on the day before such cancellation, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46118fd0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4985/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of such compensation which is granted after the expatriation date, on the date such compensation is granted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46118fd1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4985/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax to apply only if shareholder gain recognized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall apply to any disqualified individual with respect to an expatriated corporation only if gain (if any) on any stock in such corporation is recognized in whole or part by any shareholder by reason of the acquisition referred to in section 7874(a)(2)(B)(i) with respect to such corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46118fd2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4985/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception where gain recognized on compensation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46118fd3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4985/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any stock option which is exercised on the expatriation date or during the 6-month period before such date and to the stock acquired in such exercise, if income is recognized under section 83 on or before the expatriation date with respect to the stock acquired pursuant to such exercise, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46118fd4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4985/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other specified stock compensation which is exercised, sold, exchanged, distributed, cashed-out, or otherwise paid during such period in a transaction in which income, gain, or loss is recognized in full.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46118fd5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4985/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46118fd6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4985/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disqualified individual","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “disqualified individual” means, with respect to a corporation, any individual who, at any time during the 12-month period beginning on the date which is 6 months before the expatriation date—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46118fd7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4985/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is subject to the requirements of section 16(a) of the Securities Exchange Act of 1934 with respect to such corporation or any member of the expanded affiliated group which includes such corporation, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46118fd8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4985/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would be subject to such requirements if such corporation or member were an issuer of equity securities referred to in such section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46118fd9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4985/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expatriated corporation; expatriation date","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46118fda-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4985/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expatriated corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “expatriated corporation” means any corporation which is an expatriated entity (as defined in section 7874(a)(2)). Such term includes any predecessor or successor of such a corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46118fdb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4985/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expatriation date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “expatriation date” means, with respect to a corporation, the date on which the corporation first becomes an expatriated corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46118fdc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4985/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specified stock compensation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46118fdd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4985/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “specified stock compensation” means payment (or right to payment) granted by the expatriated corporation (or by any member of the expanded affiliated group which includes such corporation) to any person in connection with the performance of services by a disqualified individual for such corporation or member if the value of such payment or right is based on (or determined by reference to) the value (or change in value) of stock in such corporation (or any such member).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46118fde-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4985/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such term shall not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id46118fdf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4985/e/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any option to which part II of subchapter D of chapter 1 applies, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46118fe0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4985/e/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any payment or right to payment from a plan referred to in section 280G(b)(6).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46118fe1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4985/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expanded affiliated group","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “expanded affiliated group” means an affiliated group (as defined in section 1504(a) without regard to section 1504(b)(3)); except that section 1504(a) shall be applied by substituting “more than 50 percent” for “at least 80 percent” each place it appears.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46118fe2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4985/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46118fe3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4985/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cancellation of restriction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The cancellation of a restriction which by its terms will never lapse shall be treated as a grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46118fe4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4985/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment or reimbursement of tax by corporation treated as specified stock compensation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any payment of the tax imposed by this section directly or indirectly by the expatriated corporation or by any member of the expanded affiliated group which includes such corporation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46118fe5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4985/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be treated as specified stock compensation, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46118fe6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4985/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be allowed as a deduction under any provision of chapter 1.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46118fe7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4985/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain restrictions ignored","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whether there is specified stock compensation, and the value thereof, shall be determined without regard to any restriction other than a restriction which by its terms will never lapse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46118fe8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4985/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property transfers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any transfer of property shall be treated as a payment and any right to a transfer of property shall be treated as a right to a payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46118fe9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4985/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other administrative provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subtitle F, any tax imposed by this section shall be treated as a tax imposed by subtitle A.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46118fea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4985/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such regulations as may be necessary or appropriate to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46118feb-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s802/a"},"text":"Pub. L. 108–357, title VIII, § 802(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1566"},"text":"118 Stat. 1566","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13604/a"},"text":"Pub. L. 115–97, title I, § 13604(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2165"},"text":"131 Stat. 2165","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46118fec-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46118fed-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id46118fee-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 16(a) of the Securities Exchange Act of 1934, referred to in subsec. (e)(1)(A), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78p/a"},"text":"section 78p(a) of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id46118fef-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 4986 to 4998 were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1941/a"},"text":"Pub. L. 100–418, title I, § 1941(a)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1322"},"text":"102 Stat. 1322","children":[],"tail":", 1324, applicable to crude oil removed from the premises on or after "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 4986, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/223/tI/s101/a/1"},"text":"Pub. L. 96–223, title I, § 101(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-04-02"},"text":"Apr. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/230"},"text":"94 Stat. 230","children":[],"tail":", related to imposition of windfall profit tax on domestic crude oil."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 4987, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/223/tI/s101/a/1"},"text":"Pub. L. 96–223, title I, § 101(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-04-02"},"text":"Apr. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/230"},"text":"94 Stat. 230","children":[],"tail