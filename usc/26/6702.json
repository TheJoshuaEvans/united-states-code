{"tag":"section","attrib":{"id":"id47321ad6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6702"},"text":null,"children":[{"tag":"num","attrib":{"value":"6702"},"text":"§ 6702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Frivolous tax submissions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47321ad7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6702/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalty for frivolous tax returns","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person shall pay a penalty of $5,000 if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47321ad8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6702/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such person files what purports to be a return of a tax imposed by this title but which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47321ad9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6702/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not contain information on which the substantial correctness of the self-assessment may be judged, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47321ada-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6702/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains information that on its face indicates that the self-assessment is substantially incorrect, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47321adb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6702/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the conduct referred to in paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47321adc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6702/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is based on a position which the Secretary has identified as frivolous under subsection (c), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47321add-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6702/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reflects a desire to delay or impede the administration of Federal tax laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47321ade-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6702/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalty for specified frivolous submissions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47321adf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6702/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (3), any person who submits a specified frivolous submission shall pay a penalty of $5,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47321ae0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6702/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specified frivolous submission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47321ae1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6702/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specified frivolous submission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “specified frivolous submission” means a specified submission if any portion of such submission—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47321ae2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6702/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is based on a position which the Secretary has identified as frivolous under subsection (c), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47321ae3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6702/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reflects a desire to delay or impede the administration of Federal tax laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47321ae4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6702/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specified submission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “specified submission” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47321ae5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6702/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a request for a hearing under—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id47321ae6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6702/b/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 6320 (relating to notice and opportunity for hearing upon filing of notice of lien), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id47321ae7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6702/b/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 6330 (relating to notice and opportunity for hearing before levy), and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47321ae8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6702/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an application under—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id47321ae9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6702/b/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 6159 (relating to agreements for payment of tax liability in installments),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id47321aea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6702/b/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 7122 (relating to compromises), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id47321aeb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6702/b/2/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 7811 (relating to taxpayer assistance orders).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47321aec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6702/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Opportunity to withdraw submission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary provides a person with notice that a submission is a specified frivolous submission and such person withdraws such submission within 30 days after such notice, the penalty imposed under paragraph (1) shall not apply with respect to such submission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47321aed-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6702/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Listing of frivolous positions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe (and periodically revise) a list of positions which the Secretary has identified as being frivolous for purposes of this subsection. The Secretary shall not include in such list any position that the Secretary determines meets the requirement of section 6662(d)(2)(B)(ii)(II).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47321aee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6702/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction of penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may reduce the amount of any penalty imposed under this section if the Secretary determines that such reduction would promote compliance with and administration of the Federal tax laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47321aef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6702/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties in addition to other penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The penalties imposed by this section shall be in addition to any other penalty provided by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47321af0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6702/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnership adjustments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An administrative adjustment request under section 6227 and a partnership adjustment tracking report under section 6226(b)(4)(A) shall be treated as a return for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47321af1-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/tIII/s326/a"},"text":"Pub. L. 97–248, title III, § 326(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/617"},"text":"96 Stat. 617","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/432/dA/tIV/s407/a"},"text":"Pub. L. 109–432, div. A, title IV, § 407(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2960"},"text":"120 Stat. 2960","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tII/s206/n/4"},"text":"Pub. L. 115–141, div. U, title II, § 206(n)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1182"},"text":"132 Stat. 1182","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47321af2-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47321af3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id47321af4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432"},"text":"Pub. L. 109–432","children":[],"tail":" amended section catchline and text generally, substituting provisions relating to civil penalties for frivolous tax returns and submissions, listing of frivolous positions, reduction of penalty to promote compliance with tax laws, and application of other penalties, consisting of subsecs. (a) to (e), for provisions relating to civil penalty for frivolous tax returns and application of other penalties, consisting of subsecs. (a) and (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47321af5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47321af6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" effective as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/114/74/s1101"},"text":"section 1101 of Pub. L. 114–74","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/s207"},"text":"section 207 of Pub. L. 115–141","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6031"},"text":"section 6031 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47321af7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432"},"text":"Pub. L. 109–432","children":[],"tail":" applicable to submissions made and issues raised after the date on which the Secretary first prescribes a list under subsec. (c) of this section, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/432/s407/f"},"text":"section 407(f) of Pub. L. 109–432","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6320"},"text":"section 6320 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id47321af8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/tIII/s326/c"},"text":"Pub. L. 97–248, title III, § 326(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/617"},"text":"96 Stat. 617","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/248/tIII/s326/c"},"text":"“The amendments made by this section [enacting this section] shall apply with respect to documents filed after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
