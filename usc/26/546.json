{"tag":"section","attrib":{"id":"id43d2ea5f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s546"},"text":null,"children":[{"tag":"num","attrib":{"value":"546"},"text":"§ 546.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Income not placed on annual basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Section 443(b) (relating to computation of tax on change of annual accounting period) shall not apply in the computation of the personal holding company tax imposed by section 541.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id43d2ea60-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/191"},"text":"68A Stat. 191","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
