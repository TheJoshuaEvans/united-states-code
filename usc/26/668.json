{"tag":"section","attrib":{"id":"id43f42d6e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s668"},"text":null,"children":[{"tag":"num","attrib":{"value":"668"},"text":"§ 668.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest charge on accumulation distributions from foreign trusts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id43f42d6f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s668/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of the tax determined under section 667(a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43f42d70-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s668/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest determined using underpayment rates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The interest charge determined under this section with respect to any distribution is the amount of interest which would be determined on the partial tax computed under section 667(b) for the period described in paragraph (2) using the rates and the method under section 6621 applicable to underpayments of tax.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43f42d71-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s668/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1), the period described in this paragraph is the period which begins on the date which is the applicable number of years before the date of the distribution and which ends on the date of the distribution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43f42d72-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s668/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable number of years","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (2)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43f42d73-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s668/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The applicable number of years with respect to a distribution is the number determined by dividing—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id43f42d74-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s668/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sum of the products described in subparagraph (B) with respect to each undistributed income year, by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43f42d75-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s668/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate undistributed net income.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The quotient determined under the preceding sentence shall be rounded under procedures prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43f42d76-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s668/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Product described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subparagraph (A), the product described in this subparagraph with respect to any undistributed income year is the product of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id43f42d77-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s668/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the undistributed net income for such year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43f42d78-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s668/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sum of the number of taxable years between such year and the taxable year of the distribution (counting in each case the undistributed income year but not counting the taxable year of the distribution).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43f42d79-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s668/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Undistributed income year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the term “undistributed income year” means any prior taxable year of the trust for which there is undistributed net income, other than a taxable year during all of which the beneficiary receiving the distribution was not a citizen or resident of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43f42d7a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s668/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of undistributed net income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding section 666, for purposes of this subsection, an accumulation distribution from the trust shall be treated as reducing proportionately the undistributed net income for undistributed income years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43f42d7b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s668/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periods before 1996","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Interest for the portion of the period described in paragraph (2) which occurs before ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"January 1, 1996","children":[],"tail":", shall be determined—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43f42d7c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s668/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by using an interest rate of 6 percent, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43f42d7d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s668/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without compounding until ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"January 1, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43f42d7e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s668/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total amount of the interest charge shall not, when added to the total partial tax computed under section 667(b), exceed the amount of the accumulation distribution (other than the amount of tax deemed distributed by section 666(b) or (c)) in respect of which such partial tax was determined.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43f42d7f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s668/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest charge not deductible","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The interest charge determined under this section shall not be allowed as a deduction for purposes of any tax imposed by this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id43f42d80-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tX/s1014/b"},"text":"Pub. L. 94–455, title X, § 1014(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1617"},"text":"90 Stat. 1617","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11802/f/3"},"text":"Pub. L. 101–508, title XI, § 11802(f)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-530"},"text":"104 Stat. 1388–530","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1906/a"},"text":"Pub. L. 104–188, title I, § 1906(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1914"},"text":"110 Stat. 1914","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id43f42d81-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id43f42d82-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id43f42d83-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 668, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/225"},"text":"68A Stat. 225","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1962-10-16"},"text":"Oct. 16, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/87/834/s7/d"},"text":"Pub. L. 87–834, § 7(d)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/986"},"text":"76 Stat. 986","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/tIII/s331/a"},"text":"Pub. L. 91–172, title III, § 331(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/594"},"text":"83 Stat. 594","children":[],"tail":", related to treatment of amounts deemed distributed in preceding years, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tVII/s701/a/3"},"text":"Pub. L. 94–455, title VII, § 701(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1577"},"text":"90 Stat. 1577","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s667"},"text":"section 667 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id43f42d84-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":" reenacted heading without change and amended text generally. Prior to amendment, text read as follows: “For purposes of the tax determined under section 667(a), the interest charge is an amount equal to 6 percent of the partial tax computed under section 667(b) multiplied by a fraction—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) the numerator of which is the sum of the number of taxable years between each taxable year to which the distribution is allocated under section 666(a) and the taxable year of the distribution (counting in each case the taxable year to which the distribution is allocated but not counting the taxable year of the distribution), and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) the denominator of which is the number of taxable years to which the distribution is allocated under section 666(a).”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" substituted heading for one which read “Special rules” and amended text generally, restating provisions of former par. (1) as entire subsection and striking out former par. (2) which provided that for purposes of this section, undistributed net income existing in a trust as of "},{"tag":"date","attrib":{"date":"1977-01-01"},"text":"January 1, 1977","children":[],"tail":", would be treated as allocated under section 666(a) to the first taxable year beginning after "},{"tag":"date","attrib":{"date":"1976-12-31"},"text":"December 31, 1976","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id43f42d85-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43f42d86-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1906/d/1"},"text":"Pub. L. 104–188, title I, § 1906(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1916"},"text":"110 Stat. 1916","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/188/tI/s1906/d/1"},"text":"“The amendment made by subsection (a) [amending this section] shall apply to distributions after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id43f42d87-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tX/s1014/d"},"text":"Pub. L. 94–455, title X, § 1014(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1617"},"text":"90 Stat. 1617","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/455/tX/s1014/d"},"text":"“The amendments made by this section [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s667"},"text":"section 667 of this title","children":[],"tail":"] shall apply to taxable years beginning after "},{"tag":"date","attrib":{"date":"1976-12-31"},"text":"December 31, 1976","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"id43f42d88-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions that nothing in amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" be construed to affect treatment of certain transactions occurring, property acquired, or items of income, loss, deduction, or credit taken into account prior to "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", for purposes of determining liability for tax for periods ending after "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/s11821/b"},"text":"section 11821(b) of Pub. L. 101–508","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s45K"},"text":"section 45K of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
