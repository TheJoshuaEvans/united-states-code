","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2740"},"text":"100 Stat. 2740","children":[],"tail":", 2857; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7301/e"},"text":"Pub. L. 101–239, title VII, § 7301(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2349"},"text":"103 Stat. 2349","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/318/tV/s522/b/2/D"},"text":"Pub. L. 102–318, title V, § 522(b)(2)(D)","children":[],"tail":", (E), "},{"tag":"date","attrib":{"date":"1992-07-03"},"text":"July 3, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/314"},"text":"106 Stat. 314","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI"},"text":"Pub. L. 104–188, title I","children":[],"tail":", §§ 1455(b)(2), (d)(1), 1602(b)(6), "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1818"},"text":"110 Stat. 1818","children":[],"tail":", 1834; "},{"tag":"ref","attrib":{"href":"/us/pl/107/16/tVI/s617/d/2"},"text":"Pub. L. 107–16, title VI, § 617(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-06-07"},"text":"June 7, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/106"},"text":"115 Stat. 106","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13520/c/2"},"text":"Pub. L. 115–97, title I, § 13520(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2151"},"text":"131 Stat. 2151","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4675a8f8-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4675a8f9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4675a8fa-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13520/c/2/B"},"text":"Pub. L. 115–97, § 13520(c)(2)(B)","children":[],"tail":", added subsec. (g). Former subsec. (g) redesignated (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13520/c/2/A"},"text":"Pub. L. 115–97, § 13520(c)(2)(A)","children":[],"tail":", redesignated subsec. (g) as (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13520/c/2/C"},"text":"Pub. L. 115–97, § 13520(c)(2)(C)","children":[],"tail":", added par. (4). Text was editorially conformed to match the style of pars. (1) to (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16"},"text":"Pub. L. 107–16","children":[],"tail":" added subsec. (f) and redesignated former subsec. (f) as (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1455/b/2"},"text":"Pub. L. 104–188, § 1455(b)(2)","children":[],"tail":", inserted at end “No return or report may be required under the preceding sentence with respect to distributions to any person during any year unless such distributions aggregate $10 or more.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1) to (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1602/b/6"},"text":"Pub. L. 104–188, § 1602(b)(6)","children":[],"tail":", added pars. (1) and (2) and struck out former pars. (1) to (3) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) any employer maintaining, or the plan administrator (within the meaning of section 414(g)) of, an employee stock ownership plan—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) which acquired stock in a transaction to which section 133 applies, or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) which holds stock with respect to which section 404(k) applies to dividends paid on such stock,","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) any person making or holding a loan to which section 133 applies, or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) both such employer or plan administrator and such person,”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1455/d/1"},"text":"Pub. L. 104–188, § 1455(d)(1)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “For provisions relating to penalties for failure to file a return required by this section, see section 6652(e).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (d)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/318/s522/b/2/E"},"text":"Pub. L. 102–318, § 522(b)(2)(E)","children":[],"tail":", which directed the substitution of “section 3405(d)(3)” for “section 3405(d)(1)”, could not be executed because of the prior amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/102/318/s522/b/2/D"},"text":"Pub. L. 102–318, § 522(b)(2)(D)","children":[],"tail":". See below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/318/s522/b/2/D"},"text":"Pub. L. 102–318, § 522(b)(2)(D)","children":[],"tail":", substituted “3405(e)(1)” for “3405(d)(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" added subsec. (e) and redesignated former subsec. (e) as (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1501/d/1/D"},"text":"Pub. L. 99–514, § 1501(d)(1)(D)","children":[],"tail":", substituted “section 6652(e)” for “section 6652(f)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1848/e/2"},"text":"Pub. L. 99–514, § 1848(e)(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s491/d/57"},"text":"Pub. L. 98–369, § 491(d)(57)","children":[],"tail":", struck out “and bond purchase” after “trusts and annuity” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s491/d/47"},"text":"Pub. L. 98–369, § 491(d)(47)","children":[],"tail":", redesignated former subsecs. (d) to (f) as (c) to (e), respectively, and struck out former subsec. (c) which related to information to be supplied by employees under qualified bond purchase plans."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/448"},"text":"Pub. L. 97–448","children":[],"tail":" substituted “section 219” for “section 219(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248"},"text":"Pub. L. 97–248","children":[],"tail":" added subsec. (e) and redesignated former subsec. (e) as (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text