{"tag":"section","attrib":{"id":"id46c6af65-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6320"},"text":null,"children":[{"tag":"num","attrib":{"value":"6320"},"text":"§ 6320.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice and opportunity for hearing upon filing of notice of lien","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46c6af66-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6320/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of notice","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46c6af67-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6320/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall notify in writing the person described in section 6321 of the filing of a notice of lien under section 6323.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46c6af68-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6320/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time and method for notice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The notice required under paragraph (1) shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46c6af69-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6320/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" given in person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46c6af6a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6320/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" left at the dwelling or usual place of business of such person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46c6af6b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6320/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sent by certified or registered mail to such person’s last known address,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"not more than 5 business days after the day of the filing of the notice of lien.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46c6af6c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6320/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information included with notice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The notice required under paragraph (1) shall include in simple and nontechnical terms—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46c6af6d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6320/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of unpaid tax;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46c6af6e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6320/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the right of the person to request a hearing during the 30-day period beginning on the day after the 5-day period described in paragraph (2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46c6af6f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6320/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the administrative appeals available to the taxpayer with respect to such lien and the procedures relating to such appeals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46c6af70-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6320/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provisions of this title and procedures relating to the release of liens on property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46c6af71-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6320/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provisions of section 7345 relating to the certification of seriously delinquent tax debts and the denial, revocation, or limitation of passports of individuals with such debts pursuant to section 32101 of the FAST Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46c6af72-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6320/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right to fair hearing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46c6af73-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6320/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the person requests a hearing in writing under subsection (a)(3)(B) and states the grounds for the requested hearing, such hearing shall be held by the Internal Revenue Service Independent Office of Appeals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46c6af74-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6320/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" One hearing per period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person shall be entitled to only one hearing under this section with respect to the taxable period to which the unpaid tax specified in subsection (a)(3)(A) relates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46c6af75-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6320/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Impartial officer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The hearing under this subsection shall be conducted by an officer or employee who has had no prior involvement with respect to the unpaid tax specified in subsection (a)(3)(A) before the first hearing under this section or section 6330. A taxpayer may waive the requirement of this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46c6af76-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6320/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with section 6330","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent practicable, a hearing under this section shall be held in conjunction with a hearing under section 6330.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46c6af77-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6320/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conduct of hearing; review; suspensions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, subsections (c), (d) (other than paragraph (3)(B) thereof), (e), and (g) of section 6330 shall apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46c6af78-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/tIII/s3401/a"},"text":"Pub. L. 105–206, title III, § 3401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/746"},"text":"112 Stat. 746","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/432/dA/tIV/s407/c"},"text":"Pub. L. 109–432, div. A, title IV, § 407(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2962"},"text":"120 Stat. 2962","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dC/tXXXII/s32101/b/1"},"text":"Pub. L. 114–94, div. C, title XXXII, § 32101(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1731"},"text":"129 Stat. 1731","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/113/dQ/tIV/s424/c"},"text":"Pub. L. 114–113, div. Q, title IV, § 424(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/3125"},"text":"129 Stat. 3125","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/25/tI/s1001/b/1/B"},"text":"Pub. L. 116–25, title I, § 1001(b)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-07-01"},"text":"July 1, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/985"},"text":"133 Stat. 985","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46c6af79-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46c6af7a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id46c6af7b-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 32101 of the FAST Act, referred to in subsec. (a)(3)(E), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s32101"},"text":"section 32101 of Pub. L. 114–94","children":[],"tail":", which enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s7345"},"text":"section 7345 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2714a"},"text":"section 2714a of Title 22","children":[],"tail":", Foreign Relations and Intercourse, and amended this section and sections 6103, 6331, and 7508 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46c6af7c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/25"},"text":"Pub. L. 116–25","children":[],"tail":" substituted “Internal Revenue Service Independent Office of Appeals” for “Internal Revenue Service Office of Appeals”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(3)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113"},"text":"Pub. L. 114–113","children":[],"tail":" substituted “(3)(B)” for “(2)(B)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432/s407/c/1"},"text":"Pub. L. 109–432, § 407(c)(1)","children":[],"tail":", substituted “in writing under subsection (a)(3)(B) and states the grounds for the requested hearing” for “under subsection (a)(3)(B)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432/s407/c/2"},"text":"Pub. L. 109–432, § 407(c)(2)","children":[],"tail":", substituted “(e), and (g)” for “and (e)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46c6af7d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46c6af7e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432/dA/tIV/s407/f"},"text":"Pub. L. 109–432, div. A, title IV, § 407(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2962"},"text":"120 Stat. 2962","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/432/dA/tIV/s407/f"},"text":"“The amendments made by this section [amending this section and sections 6330, 6702, and 7122 of this title] shall apply to submissions made and issues raised after the date on which the Secretary first prescribes a list under section 6702(c) of the Internal Revenue Code of 1986, as amended by subsection (a) [list prescribed ","children":[{"tag":"date","attrib":{"date":"2007-03-16"},"text":"Mar. 16, 2007","children":[],"tail":", see I.R.S. Notice 2007–30, 2007–14, I.R.B. 883].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id46c6af7f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/tIII/s3401/d"},"text":"Pub. L. 105–206, title III, § 3401(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/750"},"text":"112 Stat. 750","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/206/tIII/s3401/d"},"text":"“The amendments made by this section [enacting this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6330"},"text":"section 6330 of this title","children":[],"tail":" and amending "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s7443A"},"text":"section 7443A of this title","children":[],"tail":"] shall apply to collection actions initiated after the date which is 180 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
