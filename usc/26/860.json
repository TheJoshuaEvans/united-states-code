{"tag":"section","attrib":{"id":"id443973b1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860"},"text":null,"children":[{"tag":"num","attrib":{"value":"860"},"text":"§ 860.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deduction for deficiency dividends","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id443973b2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a determination with respect to any qualified investment entity results in any adjustment for any taxable year, a deduction shall be allowed to such entity for the amount of deficiency dividends for purposes of determining the deduction for dividends paid (for purposes of section 852 or 857, whichever applies) for such year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id443973b3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified investment entity defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “qualified investment entity” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id443973b4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a regulated investment company, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id443973b5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a real estate investment trust.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id443973b6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules for application of section","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id443973b7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest and additions to tax determined with respect to the amount of deficiency dividend deduction allowed","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of determining interest, additions to tax, and additional amounts—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id443973b8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the tax imposed by this chapter (after taking into account the deduction allowed by subsection (a)) on the qualified investment entity for the taxable year with respect to which the determination is made shall be deemed to be increased by an amount equal to the deduction allowed by subsection (a) with respect to such taxable year,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id443973b9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the last date prescribed for payment of such increase in tax shall be deemed to have been the last date prescribed for the payment of tax (determined in the manner provided by section 6601(b)) for the taxable year with respect to which the determination is made, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id443973ba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such increase in tax shall be deemed to be paid as of the date the claim for the deficiency dividend deduction is filed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id443973bb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit or refund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the allowance of a deficiency dividend deduction results in an overpayment of tax for any taxable year, credit or refund with respect to such overpayment shall be made as if on the date of the determination 2 years remained before the expiration of the period of limitations on the filing of claim for refund for the taxable year to which the overpayment relates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id443973bc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id443973bd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment in the case of regulated investment company","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any regulated investment company, the term “adjustment” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id443973be-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any increase in the investment company taxable income of the regulated investment company (determined without regard to the deduction for dividends paid (as defined in section 561)),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id443973bf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any increase in the amount of the excess described in section 852(b)(3)(A) (relating to the excess of the net capital gain over the deduction for capital gain dividends paid), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id443973c0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any decrease in the deduction for dividends paid (as defined in section 561) determined without regard to capital gains dividends.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id443973c1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment in the case of real estate investment trust","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any real estate investment trust, the term “adjustment” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id443973c2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any increase in the sum of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id443973c3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the real estate investment trust taxable income of the real estate investment trust (determined without regard to the deduction for dividends paid (as defined in section 561) and by excluding any net capital gain), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id443973c4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the excess of the net income from foreclosure property (as defined in section 857(b)(4)(B)) over the tax on such income imposed by section 857(b)(4)(A),","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id443973c5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any increase in the amount of the excess described in section 857(b)(3)(A)(ii) ","children":[{"tag":"ref","attrib":{"idref":"fn002138"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002138"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" (relating to the excess of the net capital gain over the deduction for capital gains dividends paid), and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id443973c6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any decrease in the deduction for dividends paid (as defined in section 561) determined without regard to capital gains dividends.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id443973c7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “determination” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id443973c8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a decision by the Tax Court, or a judgment, decree, or other order by any court of competent jurisdiction, which has become final;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id443973c9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a closing agreement made under section 7121;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id443973ca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under regulations prescribed by the Secretary, an agreement signed by the Secretary and by, or on behalf of, the qualified investment entity relating to the liability of such entity for tax; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id443973cb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement by the taxpayer attached to its amendment or supplement to a return of tax for the relevant tax year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id443973cc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deficiency dividends","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id443973cd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “deficiency dividends” means a distribution of property made by the qualified investment entity on or after the date of the determination and before filing claim under subsection (g), which would have been includible in the computation of the deduction for dividends paid under section 561 for the taxable year with respect to which the liability for tax resulting from the determination exists if distributed during such taxable year. No distribution of property shall be considered as deficiency dividends for purposes of subsection (a) unless distributed within 90 days after the determination, and unless a claim for a deficiency dividend deduction with respect to such distribution is filed pursuant to subsection (g).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id443973ce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id443973cf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ordinary dividends","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of deficiency dividends (other than deficiency dividends qualifying as capital gain dividends) paid by a qualified investment entity for the taxable year with respect to which the liability for tax resulting from the determination exists shall not exceed the sum of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id443973d0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860/f/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the excess of the amount of increase referred to in subparagraph (A) of paragraph (1) or (2) of subsection (d) (whichever applies) over the amount of any increase in the deduction for dividends paid (computed without regard to capital gain dividends) for such taxable year which results from such determination, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id443973d1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860/f/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of decrease referred to in subparagraph (C) of paragraph (1) or (2) of subsection (d) (whichever applies).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id443973d2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capital gain dividends","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of deficiency dividends qualifying as capital gain dividends paid by a qualified investment entity for the taxable year with respect to which the liability for tax resulting from the determination exists shall not exceed the amount by which (i) the increase referred to in subparagraph (B) of paragraph (1) or (2) of subsection (d) (whichever applies), exceeds (ii) the amount of any dividends paid during such taxable year which are designated or reported (as the case may be) as capital gain dividends after such determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id443973d3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on dividends paid deduction","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id443973d4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" For taxable year in which paid","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Deficiency dividends paid in any taxable year shall not be included in the amount of dividends paid for such year for purposes of computing the dividends paid deduction for such year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id443973d5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" For prior taxable year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Deficiency dividends paid in any taxable year shall not be allowed for purposes of section 855(a) or 858(a) in the computation of the dividends paid deduction for the taxable year preceding the taxable year in which paid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id443973d6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Claim required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No deficiency dividend deduction shall be allowed under subsection (a) unless (under regulations prescribed by the Secretary) claim therefore is filed within 120 days after the date of the determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id443973d7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension of statute of limitations and stay of collection","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id443973d8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension of running of statute","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the qualified investment entity files a claim as provided in subsection (g), the running of the statute of limitations provided in section 6501 on the making of assessments, and the bringing of distraint or a proceeding in court for collection, in respect of the deficiency established by a determination under this section, and all interest, additions to tax, additional amounts, or assessable penalties in respect thereof, shall be suspended for a period of 2 years after the date of the determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id443973d9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stay of collection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any deficiency established by a determination under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id443973da-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the collection of the deficiency, and all interest, additions to tax, additional amounts, and assessable penalties in respect thereof, shall, except in cases of jeopardy, be stayed until the expiration of 120 days after the date of the determination, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id443973db-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if claim for a deficiency dividend deduction is filed under subsection (g), the collection of such part of the deficiency as is not reduced by the deduction for deficiency dividends provided in subsection (a) shall be stayed until the date the claim is disallowed (in whole or in part), and if disallowed in part collection shall be made only with respect to the part disallowed.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"No distraint or proceeding in court shall be begun for the collection of an amount the collection of which is stayed under subparagraph (A) or (B) during the period for which the collection of such amount is stayed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id443973dc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deduction denied in case of fraud","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No deficiency dividend deduction shall be allowed under subsection (a) if the determination contains a finding that any part of any deficiency attributable to an adjustment with respect to the taxable year is due to fraud with intent to evade tax or to willful failure to file an income tax return within the time prescribed by law or prescribed by the Secretary in pursuance of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id443973dd-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600/tIII/s362/a"},"text":"Pub. L. 95–600, title III, § 362(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2848"},"text":"92 Stat. 2848","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/222/tI/s103/a/11/B"},"text":"Pub. L. 96–222, title I, § 103(a)(11)(B)","children":[],"tail":", (C), "},{"tag":"date","attrib":{"date":"1980-04-01"},"text":"Apr. 1, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/213"},"text":"94 Stat. 213","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVI/s667/b/1"},"text":"Pub. L. 99–514, title VI, § 667(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2306"},"text":"100 Stat. 2306","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tII/s243/f/5"},"text":"Pub. L. 108–357, title II, § 243(f)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1445"},"text":"118 Stat. 1445","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/325/tIII/s301/a/2"},"text":"Pub. L. 111–325, title III, § 301(a)(2)","children":[],"tail":", title V, § 501(b), "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3542"},"text":"124 Stat. 3542","children":[],"tail":", 3554; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/149"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(149)","children":[],"tail":", (150), "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1191"},"text":"132 Stat. 1191","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id443973de-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id443973df-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id443973e0-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 857(b)(3)(A), referred to in subsec. (d)(2)(B), relating to alternative tax in case of capital gains, was repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13001/b/2/K/i"},"text":"Pub. L. 115–97, title I, § 13001(b)(2)(K)(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2096"},"text":"131 Stat. 2096","children":[],"tail":". Subsec. (b)(3)(B) of section 857, relating to treatment of capital gain dividends by shareholders, was redesignated subsec. (b)(3)(A) of that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id443973e1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 860 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s859"},"text":"section 859 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id443973e2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (f)(2)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/a/149"},"text":"Pub. L. 115–141, § 401(a)(149)","children":[],"tail":", substituted “decrease” for “decreased”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/a/150"},"text":"Pub. L. 115–141, § 401(a)(150)","children":[],"tail":", substituted “willful” for “willfull”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (f)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/325/s301/a/2"},"text":"Pub. L. 111–325, § 301(a)(2)","children":[],"tail":", inserted “or reported (as the case may be)” after “designated”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/325/s501/b"},"text":"Pub. L. 111–325, § 501(b)","children":[],"tail":", struck out subsec. (j). Text read as follows: “For assessable penalty with respect to liability for tax of a regulated investment company which is allowed a deduction under subsection (a), see section 6697.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (e)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":" added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “regulated investment company” for “qualified investment entity”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/222"},"text":"Pub. L. 96–222","children":[],"tail":" substituted in heading “Deficiency” for “Efficiency” and in par. (2)(A)(i) “(computed without regard” for “computed without regard”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id443973e3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note"