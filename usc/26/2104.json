{"tag":"section","attrib":{"id":"id453894b6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2104"},"text":null,"children":[{"tag":"num","attrib":{"value":"2104"},"text":"§ 2104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property within the United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id453894b7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stock in corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subchapter shares of stock owned and held by a nonresident not a citizen of the United States shall be deemed property within the United States only if issued by a domestic corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id453894b8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revocable transfers and transfers within 3 years of death","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subchapter, any property of which the decedent has made a transfer, by trust or otherwise, within the meaning of sections 2035 to 2038, inclusive, shall be deemed to be situated in the United States, if so situated either at the time of the transfer or at the time of the decedent’s death.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id453894b9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Debt obligations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter, debt obligations of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id453894ba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2104/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a United States person, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id453894bb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2104/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States, a State or any political subdivision thereof, or the District of Columbia,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"owned and held by a nonresident not a citizen of the United States shall be deemed property within the United States. Deposits with a domestic branch of a foreign corporation, if such branch is engaged in the commercial banking business, shall, for purposes of this subchapter, be deemed property within the United States. This subsection shall not apply to a debt obligation to which section 2105(b) applies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id453894bc-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/397"},"text":"68A Stat. 397","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/809/tI/s108/c"},"text":"Pub. L. 89–809, title I, § 108(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-13"},"text":"Nov. 13, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1572"},"text":"80 Stat. 1572","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/tIV/s435/b"},"text":"Pub. L. 91–172, title IV, § 435(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/625"},"text":"83 Stat. 625","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/17/s3/a/1"},"text":"Pub. L. 93–17, § 3(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-04-10"},"text":"Apr. 10, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/12"},"text":"87 Stat. 12","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/625/s9/b"},"text":"Pub. L. 93–625, § 9(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2116"},"text":"88 Stat. 2116","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXX/s2001/c/1/L"},"text":"Pub. L. 94–455, title XX, § 2001(c)(1)(L)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1853"},"text":"90 Stat. 1853","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1012/q/11"},"text":"Pub. L. 100–647, title I, § 1012(q)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3525"},"text":"102 Stat. 3525","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1704/t/38"},"text":"Pub. L. 104–188, title I, § 1704(t)(38)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1889"},"text":"110 Stat. 1889","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/226/tII/s217/c/3