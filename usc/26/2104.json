would be treated by reason of section 861(a)(1)(A) as income from sources without the United States”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":" substituted “section 861(a)(1)(A)” for “subparagraph (A), (C), or (D) of section 861(a)(1)” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" substituted “subparagraph (A), (C), or (D) of section 861(a)(1)” for “section 861(a)(1)(B), section 861(a)(1)(G), or section 861(a)(1)(H)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" substituted “and transfers within 3 years of death” for “and transfers in contemplation of death” after “Revocable transfers”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/625"},"text":"Pub. L. 93–625","children":[],"tail":" inserted reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s861/a/1/H"},"text":"section 861(a)(1)(H) of this title","children":[],"tail":" in last sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/17"},"text":"Pub. L. 93–17","children":[],"tail":" made subsec. (c) inapplicable to debt obligations where interest on such obligations is treated as income from sources without the United States by reason of "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s861/a/1/G"},"text":"section 861(a)(1)(G) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172"},"text":"Pub. L. 91–172","children":[],"tail":" substituted “"},{"tag"