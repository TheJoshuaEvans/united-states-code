{"tag":"section","attrib":{"id":"id40a3552f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s40B"},"text":null,"children":[{"tag":"num","attrib":{"value":"40B"},"text":"§ 40B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sustainable aviation fuel credit","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id40a35530-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s40B/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of section 38, the sustainable aviation fuel credit determined under this section for the taxable year is, with respect to any sale or use of a qualified mixture which occurs during such taxable year, an amount equal to the product of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40a35531-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s40B/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of gallons of sustainable aviation fuel in such mixture, multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40a35532-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s40B/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40a35533-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s40B/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1.25, plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40a35534-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s40B/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicable supplementary amount with respect to such sustainable aviation fuel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40a35535-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s40B/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable supplementary amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “applicable supplementary amount” means, with respect to any sustainable aviation fuel, an amount equal to $0.01 for each percentage point by which the lifecycle greenhouse gas emissions reduction percentage with respect to such fuel exceeds 50 percent. In no event shall the applicable supplementary amount determined under this subsection exceed $0.50.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40a35536-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s40B/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified mixture","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “qualified mixture” means a mixture of sustainable aviation fuel and kerosene if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40a35537-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s40B/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such mixture is produced by the taxpayer in the United States,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40a35538-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s40B/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such mixture is used by the taxpayer (or sold by the taxpayer for use) in an aircraft,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40a35539-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s40B/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sale or use is in the ordinary course of a trade or business of the taxpayer, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40a3553a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s40B/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transfer of such mixture to the fuel tank of such aircraft occurs in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40a3553b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s40B/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sustainable aviation fuel","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40a3553c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s40B/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “sustainable aviation fuel” means liquid fuel, the portion of which is not kerosene, which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40a3553d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s40B/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" meets the requirements of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40a3553e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s40B/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ASTM International Standard D7566, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40a3553f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s40B/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Fischer Tropsch provisions of ASTM International Standard D1655, Annex A1,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40a35540-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s40B/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not derived from coprocessing an applicable material (or materials derived from an applicable material) with a feedstock which is not biomass,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40a35541-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s40B/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not derived from palm fatty acid distillates or petroleum, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40a35542-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s40B/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been certified in accordance with subsection (e) as having a lifecycle greenhouse gas emissions reduction percentage of at least 50 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40a35543-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s40B/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40a35544-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s40B/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable material","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “applicable material” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40a35545-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s40B/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monoglycerides, diglycerides, and triglycerides,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40a35546-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s40B/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" free fatty acids, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40a35547-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s40B/d/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fatty acid esters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40a35548-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s40B/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biomass","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “biomass” has the same meaning given such term in section 45K(c)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40a35549-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s40B/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lifecycle greenhouse gas emissions reduction percentage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “lifecycle greenhouse gas emissions reduction percentage” means, with respect to any sustainable aviation fuel, the percentage reduction in lifecycle greenhouse gas emissions achieved by such fuel as compared with petroleum-based jet fuel, as defined in accordance with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40a3554a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s40B/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the most recent Carbon Offsetting and Reduction Scheme for International Aviation which has been adopted by the International Civil Aviation Organization with the agreement of the United States, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40a3554b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s40B/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any similar methodology which satisfies the criteria under section 211(","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(1)(H) of the Clean Air Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7545"},"text":"42 U.S.C. 7545","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(1)(H)), as in effect on the date of enactment of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40a3554c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s40B/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration of sustainable aviation fuel producers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No credit shall be allowed under this section with respect to any sustainable aviation fuel unless the producer or importer of such fuel—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40a3554d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s40B/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is registered with the Secretary under section 4101, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40a3554e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s40B/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provides—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40a3554f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s40B/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" certification (in such form and manner as the Secretary shall prescribe) from an unrelated party demonstrating compliance with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40a35550-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s40B/f/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any general requirements, supply chain traceability requirements, and information transmission requirements established under the Carbon Offsetting and Reduction Scheme for International Aviation described in paragraph (1) of subsection (e), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40a35551-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s40B/f/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any methodology established under paragraph (2) of such subsection, requirements similar to the requirements described in clause (i), and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40a35552-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s40B/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information with respect to such fuel as the Secretary may require for purposes of carrying out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40a35553-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s40B/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with credit against excise tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of the credit determined under this section with respect to any sustainable aviation fuel shall, under rules prescribed by the Secretary, be properly reduced to take into account any benefit provided with respect to such sustainable aviation fuel solely by reason of the application of section 6426 or 6427(e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40a35554-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s40B/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to any sale or use after ","children":[{"tag":"date","attrib":{"date":"2024-12-31"},"text":"December 31, 2024","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id40a35555-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169/tI/s13203/a"},"text":"Pub. L. 117–169, title I, § 13203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1932"},"text":"136 Stat. 1932","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id40a35556-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id40a35557-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id40a35558-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsec. (e)(2), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169"},"text":"Pub. L. 117–169","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id40a35559-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id40a3555a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169/tI/s13203/f"},"text":"Pub. L. 117–169, title I, § 13203(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1935"},"text":"136 Stat. 1935","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/169/tI/s13203/f"},"text":"“The amendments made by this section [enacting this section and amending sections 38, 40A, 87, 4101, 6426, and 6427 of this title] shall apply to fuel sold or used after ","children":[{"tag":"date","attrib":{"date":"2022-12-31"},"text":"December 31, 2022","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
