{"tag":"section","attrib":{"id":"id4624a2b0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5064"},"text":null,"children":[{"tag":"num","attrib":{"value":"5064"},"text":"§ 5064.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Losses resulting from disaster, vandalism, or malicious mischief","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4624a2b1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5064/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, under such regulations as he may prescribe, shall pay (without interest) an amount equal to the amount of the internal revenue taxes paid or determined and customs duties paid on distilled spirits, wines, and beer previously withdrawn, which were lost, rendered unmarketable, or condemned by a duly authorized official by reason of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4624a2b2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5064/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fire, flood, casualty, or other disaster, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4624a2b3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5064/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" breakage, destruction, or other damage (but not including theft) resulting from vandalism or malicious mischief,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"if such disaster or damage occurred in the United States and if such distilled spirits, wines, or beer were held and intended for sale at the time of such disaster or other damage. The payments provided for in this section shall be made to the person holding such distilled spirits, wines, or beer for sale at the time of such disaster or other damage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4624a2b4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5064/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Claims","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4624a2b5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5064/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period for making claim; proof","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No claim shall be allowed under this section unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4624a2b6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5064/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" filed within 6 months after the date on which such distilled spirits, wines, or beer were lost, rendered unmarketable, or condemned by a duly authorized official, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4624a2b7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5064/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the claimant furnishes proof satisfactory to the Secretary that the claimant—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4624a2b8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5064/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was not indemnified by any valid claim of insurance or otherwise in respect of the tax, or tax and duty, on the distilled spirits, wines, or beer covered by the claim; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4624a2b9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5064/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is entitled to payment under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4624a2ba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5064/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum claim","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (3)(A), no claim of less than $250 shall be allowed under this section with respect to any disaster or other damage (as the case may be).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4624a2bb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5064/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for major disasters","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the President has determined under the Robert T. Stafford Disaster Relief and Emergency Assistance Act that a “major disaster” (as defined in such Act) has occurred in any part of the United States, and if the disaster referred to in subsection (a)(1) occurs in such part of the United States by reason of such major disaster, then—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4624a2bc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5064/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paragraph (2) shall not apply, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4624a2bd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5064/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the filing period set forth in paragraph (1)(A) shall not expire before the day which is 6 months after the date on which the President makes the determination that such major disaster has occurred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4624a2be-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5064/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Claims under this section shall be filed under such regulations as the Secretary shall prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4624a2bf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5064/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Destruction of distilled spirits, wines, or beer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When the Secretary has made payment under this section in respect of the tax, or tax and duty, on the distilled spirits, wines, or beer condemned by a duly authorized official or rendered unmarketable, such distilled spirits, wines, or beer shall be destroyed under such supervision as the Secretary may prescribe, unless such distilled spirits, wines, or beer were previously destroyed under supervision satisfactory to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4624a2c0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5064/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Products of Puerto Rico","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this section shall not be applicable in respect of distilled spirits, wines, and beer of Puerto Rican manufacture brought into the United States and so lost or rendered unmarketable or condemned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4624a2c1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5064/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other laws applicable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All provisions of law, including penalties, applicable in respect of internal revenue taxes on distilled spirits, wines, and beer shall, insofar as applicable and not inconsistent with this section, be applied in respect of the payments provided for in this section to the same extent as if such payments constituted refunds of such taxes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4624a2c2-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1337"},"text":"72 Stat. 1337","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/91/606/tIII/s301/i"},"text":"Pub. L. 91–606, title III, § 301(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1759"},"text":"84 Stat. 1759","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/288/tVII/s702/i"},"text":"Pub. L. 93–288, title VII, § 702(i)","children":[],"tail":", formerly title VI, § 602(i), "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/164"},"text":"88 Stat. 164","children":[],"tail":", renumbered title VII, § 702(i), "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dC/tXXXIV/s3411/a/1"},"text":"Pub. L. 103–337, div. C, title XXXIV, § 3411(a)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3100"},"text":"108 Stat. 3100","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/423/s1/a"},"text":"Pub. L. 95–423, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-06"},"text":"Oct. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/935"},"text":"92 Stat. 935","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/tVIII/s807/a/10"},"text":"Pub. L. 96–39, title VIII, § 807(a)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/282"},"text":"93 Stat. 282","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/707/tI/s109"},"text":"Pub. L. 100–707, title I, § 109","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4709"},"text":"102 Stat. 4709","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/311/tIV/s408/a/7/D"},"text":"Pub. L. 108–311, title IV, § 408(a)(7)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-04"},"text":"Oct. 4, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1191"},"text":"118 Stat. 1191","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4624a2c3-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4624a2c4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4624a2c5-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Robert T. Stafford Disaster Relief and Emergency Assistance Act, referred to in subsec. (b)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288"},"text":"Pub. L. 93–288","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/143"},"text":"88 Stat. 143","children":[],"tail":", which is classified principally to chapter 68 (§ 5121 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"section 5121 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4624a2c6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5064, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/615"},"text":"68A Stat. 615","children":[],"tail":", related to “territorial extent of law”, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5065"},"text":"section 5065 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4624a2c7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/311"},"text":"Pub. L. 108–311","children":[],"tail":" inserted “Robert T. Stafford” before “Disaster Relief and Emergency Assistance Act” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/707"},"text":"Pub. L. 100–707","children":[],"tail":" substituted “and Emergency Assistance Act” for “Act of 1974”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39"},"text":"Pub. L. 96–39","children":[],"tail":" struck out “rectified products,” after “distilled spirits, wines,” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/423"},"text":"Pub. L. 95–423","children":[],"tail":" substituted “Losses resulting from disaster, vandalism, or malicious mischief” for “Losses caused by disaster” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/423"},"text":"Pub. L. 95–423","children":[],"tail":" substituted provisions authorizing the Secretary, under such regulations as he may prescribe, to pay the prescribed amount on distilled spirits, etc., lost, rendered unmarketable, or condemned by a duly authorized official by reason of fire, flood, casualty or other disaster, breakage, destruction, or other damage (but not including theft) resulting from vandalism or malicious mischief, for provisions authorizing such payment where the President has determined under the Disaster Relief Act of 1974 that a “major disaster” has occurred, and that distilled spirits, etc., were lost, rendered unmarketable, or condemned by a duly authorized official by reason of such disaster occurring after "},{"tag":"date","attrib":{"date":"1959-06-30"},"text":"June 30, 1959","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/423"},"text":"Pub. L. 95–423","children":[],"tail":" redesignated par. (1) as (1)(A), substituted provisions disallowing a claim unless filed within 6 months after such distilled spirits, etc., were lost, rendered unmarketable or condemned, for provisions disallowing a claim unless filed within 6 months after the President determined that such disaster occurred, and added par. (1)(B); in par. (2) substituted provisions limiting claims to no less than $250, except as provided in par. (3)(A), for provisions demanding proof that claimant was not indemnified by any valid claim of insurance and that he is entitled to payment under this section; and added pars. (3) and (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsecs. (a) to (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288"},"text":"Pub. L. 93–288","children":[],"tail":" substituted “Disaster Relief Act of 1974” for “Disaster Relief Act of 1970”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/606"},"text":"Pub. L. 91–606","children":[],"tail":" substituted “Disaster Relief Act of 1970” for “Act of "},{"tag":"date","attrib":{"date":"1950-09-30"},"text":"September 30, 1950","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1855"},"text":"42 U.S.C. 1855","children":[],"tail":")”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4624a2c8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4624a2c9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1979 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/39"},"text":"Pub. L. 96–39","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-01-01"},"text":"Jan. 1, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/s810"},"text":"section 810 of Pub. L. 96–39","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5001"},"text":"section 5001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4624a2ca-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/423/s1/c"},"text":"Pub. L. 95–423, § 1(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-06"},"text":"Oct. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/936"},"text":"92 Stat. 936","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/423/s1/c"},"text":"“The amendments made by this section [amending this section] shall apply to disasters (or other damage) occurring on or after the first day of the first calendar month which begins more than 90 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1978-10-06"},"text":"Oct. 6, 1978","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4624a2cb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1974 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288"},"text":"Pub. L. 93–288","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1974-04-01"},"text":"Apr. 1, 1974","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/288/s605"},"text":"section 605 of Pub. L. 93–288","children":[],"tail":", formerly set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"section 5121 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tai