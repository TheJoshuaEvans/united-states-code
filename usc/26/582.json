spect to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1969-07-11"},"text":"July 11, 1969","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the refund or credit of any overpayment attributable to the application of the amendment made by subsection (a) to any taxable year is otherwise prevented by the operation of any law or rule of law (other than section 7122 of the Internal Revenue Code of 1986 [formerly I.R.C. 1954], relating to compromises) on the day which is one year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":"], such credit or refund shall be nevertheless allowed or made if claim therefor is filed on or before such day.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIV/s1402/b/1"},"text":"Pub. L. 94–455, title XIV, § 1402(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1731"},"text":"90 Stat. 1731","children":[],"tail":", provided that amendment made by that section is effective with respect to taxable years beginning in 1977."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIV/s1402/b/2"},"text":"Pub. L. 94–455, title XIV, § 1402(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1732"},"text":"90 Stat. 1732","children":[],"tail":", provided that the amendment made by that section is effective with respect to taxable years beginning after "},{"tag":"