{"tag":"section","attrib":{"id":"id4723c2a6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6656"},"text":null,"children":[{"tag":"num","attrib":{"value":"6656"},"text":"§ 6656.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to make deposit of taxes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4723c2a7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6656/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Underpayment of deposits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any failure by any person to deposit (as required by this title or by regulations of the Secretary under this title) on the date prescribed therefor any amount of tax imposed by this title in such government depository as is authorized under section 6302(c) to receive such deposit, unless it is shown that such failure is due to reasonable cause and not due to willful neglect, there shall be imposed upon such person a penalty equal to the applicable percentage of the amount of the underpayment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4723c2a8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6656/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4723c2a9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6656/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable percentage","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4723c2aa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6656/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subparagraph (B), the term “applicable percentage” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4723c2ab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6656/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 percent if the failure is for not more than 5 days,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4723c2ac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6656/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 5 percent if the failure is for more than 5 days but not more than 15 days, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4723c2ad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6656/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10 percent if the failure is for more than 15 days.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4723c2ae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6656/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any case where the tax is not deposited on or before the earlier of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4723c2af-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6656/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the day 10 days after the date of the first delinquency notice to the taxpayer under section 6303, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4723c2b0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6656/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the day on which notice and demand for immediate payment is given under section 6861 or 6862 or the last sentence of section 6331(a),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the applicable percentage shall be 15 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4723c2b1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6656/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Underpayment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “underpayment” means the excess of the amount of the tax required to be deposited over the amount, if any, thereof deposited on or before the date prescribed therefor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4723c2b2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6656/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for first-time depositors of employment taxes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may waive the penalty imposed by subsection (a) on a person’s inadvertent failure to deposit any employment tax if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4723c2b3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6656/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such person meets the requirements referred to in section 7430(c)(4)(A)(ii),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4723c2b4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6656/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such failure—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4723c2b5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6656/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" occurs during the first quarter that such person was required to deposit any employment tax; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4723c2b6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6656/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such person is required to change the frequency of deposits of any employment tax, relates to the first deposit to which such change applies, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4723c2b7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6656/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the return of such tax was filed on or before the due date.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of this subsection, the term “employment taxes” means the taxes imposed by subtitle C.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4723c2b8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6656/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to abate penalty where deposit sent to Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may abate the penalty imposed by subsection (a) with respect to the first time a depositor is required to make a deposit if the amount required to be deposited is inadvertently sent to the Secretary instead of to the appropriate government depository.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4723c2b9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6656/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of periods to which deposits apply","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4723c2ba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6656/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A deposit made under this section shall be applied to the most recent period or periods within the specified tax period to which the deposit relates, unless the person making such deposit designates a different period or periods to which such deposit is to be applied.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4723c2bb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6656/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for making designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person may make a designation under paragraph (1) only during the 90-day period beginning on the date of a notice that a penalty under subsection (a) has been imposed for the specified tax period to which the deposit relates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4723c2bc-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/826"},"text":"68A Stat. 826","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/tIX/s943/b"},"text":"Pub. L. 91–172, title IX, § 943(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/728"},"text":"83 Stat. 728","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/tVII/s724/a"},"text":"Pub. L. 97–34, title VII, § 724(a)","children":[],"tail":", (b)(1), (3), "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/344"},"text":"95 Stat. 344","children":[],"tail":", 345; "},{"tag":"ref","attrib":{"href":"/us/pl/99/509/tVIII/s8001/a"},"text":"Pub. L. 99–509, title VIII, § 8001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1951"},"text":"100 Stat. 1951","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7742/a"},"text":"Pub. L. 101–239, title VII, § 7742(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2405"},"text":"103 Stat. 2405","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/168/tIII/s304/a"},"text":"Pub. L. 104–168, title III, § 304(a)","children":[],"tail":", title VII, § 701(c)(3), "},{"tag":"date","attrib":{"date":"1996-07-30"},"text":"July 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1458"},"text":"110 Stat. 1458","children":[],"tail":", 1464; "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tIII/s3304/a"},"text":"Pub. L. 105–206, title III, § 3304(a)","children":[],"tail":"–(c), "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/742"},"text":"112 Stat. 742","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4723c2bd-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4723c2be-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4723c2bf-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s3304/b/1"},"text":"Pub. L. 105–206, § 3304(b)(1)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “such failure occurs during the 1st quarter that such person was required to deposit any employment tax, and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s3304/a"},"text":"Pub. L. 105–206, § 3304(a)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s3304/c"},"text":"Pub. L. 105–206, § 3304(c)","children":[],"tail":", reenacted heading without change and amended text of par. (1) generally. Prior to amendment, text read as follows: “A person may, with respect to any deposit of tax to be reported on such person’s return for a specified tax period, designate the period or periods within such specified tax period to which the deposit is to be applied for purposes of this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/168/s304/a"},"text":"Pub. L. 104–168, § 304(a)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/168/s701/c/3"},"text":"Pub. L. 104–168, § 701(c)(3)","children":[],"tail":", substituted “section 7430(c)(4)(A)(ii)” for “section 7430(c)(4)(A)(iii)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/168/s304/a"},"text":"Pub. L. 104–168, § 304(a)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" substituted “taxes” for “taxes or overstatement of deposits” as section catchline and amended text generally, revising substance and structure."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509"},"text":"Pub. L. 99–509","children":[],"tail":" substituted “10 percent” for “5 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s724/b/1"},"text":"Pub. L. 97–34, § 724(b)(1)","children":[],"tail":", inserted “or overstatement of deposits” after “taxes” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s724/b/3"},"text":"Pub. L. 97–34, § 724(b)(3)","children":[],"tail":", substituted “Underpayment of deposits” for “Penalty” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s724/a"},"text":"Pub. L. 97–34, § 724(a)","children":[],"tail":", substituted provisions relating to conditions for imposition of penalties for overstated deposit claims and definition of “overstated deposit claim”, for provisions relating to imposition of penalties after due date for return."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172"},"text":"Pub. L. 91–172","children":[],"tail":" substituted provisions imposing a penalty of five percent for the failure to deposit on the date prescribed any amount of tax imposed by this title, for provisions imposing a penalty of one percent of the amount of underpayment each month but not to exceed six percent in the aggregate."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4723c2c0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading",