{"tag":"section","attrib":{"id":"id45b231bd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4072"},"text":null,"children":[{"tag":"num","attrib":{"value":"4072"},"text":"§ 4072.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45b231be-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4072/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable tire","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this chapter, the term “taxable tire” means any tire of the type used on highway vehicles if wholly or in part made of rubber and if marked pursuant to Federal regulations for highway use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45b231bf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4072/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rubber","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this chapter, the term “rubber” includes synthetic and substitute rubber.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45b231c0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4072/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tires of the type used on highway vehicles","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this part, the term “tires of the type used on highway vehicles” means tires of the type used on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45b231c1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4072/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" motor vehicles which are highway vehicles, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45b231c2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4072/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vehicles of the type used in connection with motor vehicles which are highway vehicles.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such term shall not include tires of a type used exclusively on vehicles described in section 4053(8).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45b231c3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4072/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biasply","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this part, the term “biasply tire” means a pneumatic tire on which the ply cords that extend to the beads are laid at alternate angles substantially less than 90 degrees to the centerline of the tread.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45b231c4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4072/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Super single tire","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this part, the term “super single tire” means a single tire greater than 13 inches in cross section width designed to replace 2 tires in a dual fitment. Such term shall not include any tire designed for steering.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45b231c5-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/482"},"text":"68A Stat. 482","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1956-06-29/ch462"},"text":"June 29, 1956, ch. 462","children":[],"tail":", title II, § 204(b), "},{"tag":"ref","attrib":{"href":"/us/stat/70/389"},"text":"70 Stat. 389","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tVII/s735/c/3"},"text":"Pub. L. 98–369, div. A, title VII, § 735(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/982"},"text":"98 Stat. 982","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII"},"text":"Pub. L. 108–357, title VIII","children":[],"tail":", §§ 851(c)(1), 869(b), "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1608"},"text":"118 Stat. 1608","children":[],"tail":", 1623; "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXIII/s1364/a"},"text":"Pub. L. 109–58, title XIII, § 1364(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1060"},"text":"119 Stat. 1060","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45b231c6-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45b231c7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"