{"tag":"section","attrib":{"id":"id47a6d644-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9005"},"text":null,"children":[{"tag":"num","attrib":{"value":"9005"},"text":"§ 9005.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification by Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47a6d645-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9005/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial certifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 10 days after the candidates of a political party for President and Vice President of the United States have met all applicable conditions for eligibility to receive payments under this chapter set forth in section 9003, the Commission shall certify to the Secretary of the Treasury for payment to such eligible candidates under section 9006 payment in full of amounts to which such candidates are entitled under section 9004.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47a6d646-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9005/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finality of certifications and determinations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Initial certifications by the Commission under subsection (a), and all determinations made by it under this chapter, shall be final and conclusive, except to the extent that they are subject to examination and audit by the Commission under section 9007 and judicial review under section 9011.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47a6d647-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/178/tVIII/s801"},"text":"Pub. L. 92–178, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-10"},"text":"Dec. 10, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/566"},"text":"85 Stat. 566","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/93/443/tIV"},"text":"Pub. L. 93–443, title IV","children":[],"tail":", §§ 404(c)(6), (7), 405(a), "},{"tag":"date","attrib":{"date":"1974-10-15"},"text":"Oct. 15, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1292"},"text":"88 Stat. 1292","children":[],"tail":", 1293; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/C"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47a6d648-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47a6d649-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id47a6d64a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" substituted “Secretary of the Treasury” for “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/443/s404/c/6"},"text":"Pub. L. 93–443, § 404(c)(6)","children":[],"tail":", substituted “Commission” for “Comptroller General” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/443/s405/a"},"text":"Pub. L. 93–443, § 405(a)","children":[],"tail":", substituted provision for certification by the Commission not later than 10 days after the candidates of a political party for President and Vice President have met all applicable conditions for eligibility to receive payments under this chapter set forth in "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s9003"},"text":"section 9003 of this title","children":[],"tail":" for prior provision for certification by the Comptroller General on the basis of the evidence, books, records, and information furnished by the eligible candidates of a political party and prior to examination and audit under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s9007"},"text":"section 9007 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/443/s404/c/7"},"text":"Pub. L. 93–443, § 404(c)(7)","children":[],"tail":", substituted “Commission” for “Comptroller General” wherever appearing and “it” for “him”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47a6d64b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47a6d64c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1974 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/443"},"text":"Pub. L. 93–443","children":[],"tail":" applicable with respect to taxable years beginning after "},{"tag":"date","attrib":{"date":"1974-12-31"},"text":"Dec. 31, 1974","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/443/s410/c/1"},"text":"section 410(c)(1) of Pub. L. 93–443","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s30101"},"text":"section 30101 of Title 52","children":[],"tail":", Voting and Elections."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
