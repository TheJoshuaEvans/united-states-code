{"tag":"section","attrib":{"id":"id41516f35-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s102"},"text":null,"children":[{"tag":"num","attrib":{"value":"102"},"text":"§ 102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gifts and inheritances","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id41516f36-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Gross income does not include the value of property acquired by gift, bequest, devise, or inheritance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id41516f37-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Income","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not exclude from gross income—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id41516f38-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s102/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the income from any property referred to in subsection (a); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41516f39-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s102/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where the gift, bequest, devise, or inheritance is of income from property, the amount of such income.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Where, under the terms of the gift, bequest, devise, or inheritance, the payment, crediting, or distribution thereof is to be made at intervals, then, to the extent that it is paid or credited or to be distributed out of income from property, it shall be treated for purposes of paragraph (2) as a gift, bequest, devise, or inheritance of income from property. Any amount included in the gross income of a beneficiary under subchapter J shall be treated for purposes of paragraph (2) as a gift, bequest, devise, or inheritance of income from property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id41516f3a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee gifts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id41516f3b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s102/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not exclude from gross income any amount transferred by or for an employer to, or for the benefit of, an employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41516f3c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s102/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross references","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For provisions excluding certain employee achievement awards from gross income, see section 74(c).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For provisions excluding certain de minimis fringes from gross income, see section 132(e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id41516f3d-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/28"},"text":"68A Stat. 28","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tI/s122/b"},"text":"Pub. L. 99–514, title I, § 122(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2110"},"text":"100 Stat. 2110","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id41516f3e-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id41516f3f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id41516f40-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id41516f41-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id41516f42-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" applicable to prizes and awards granted after "},{"tag":"date","attrib":{"date":"1986-12-31"},"text":"Dec. 31, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s151/c"},"text":"section 151(c) of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
