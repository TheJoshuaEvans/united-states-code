{"tag":"section","attrib":{"id":"id464d11a3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5721"},"text":null,"children":[{"tag":"num","attrib":{"value":"5721"},"text":"§ 5721.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inventories","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Every manufacturer or importer of tobacco products, processed tobacco, or cigarette papers and tubes, and every export warehouse proprietor, shall make a true and accurate inventory at the time of commencing business, at the time of concluding business, and at such other times, in such manner and form, and to include such items, as the Secretary shall by regulation prescribe. Such inventories shall be subject to verification by any internal revenue officer.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id464d11a4-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/713"},"text":"68A Stat. 713","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s202"},"text":"Pub. L. 85–859, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1422"},"text":"72 Stat. 1422","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tIX/s9302/h/2/A"},"text":"Pub. L. 105–33, title IX, § 9302(h)(2)(A)","children":[],"tail":", "},{"