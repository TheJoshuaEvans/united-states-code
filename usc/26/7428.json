{"tag":"section","attrib":{"id":"id47511453-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7428"},"text":null,"children":[{"tag":"num","attrib":{"value":"7428"},"text":"§ 7428.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Declaratory judgments relating to status and classification of organizations under section 501(c)(3), etc.","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47511454-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7428/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Creation of remedy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In a case of actual controversy involving—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47511455-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7428/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a determination by the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47511456-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7428/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the initial qualification or continuing qualification of an organization as an organization described in section 501(c)(3) which is exempt from tax under section 501(a) or as an organization described in section 170(c)(2),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47511457-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7428/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the initial classification or continuing classification of an organization as a private foundation (as defined in section 509(a)),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47511458-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7428/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the initial classification or continuing classification of an organization as a private operating foundation (as defined in section 4942(j)(3)),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47511459-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7428/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the initial classification or continuing classification of a cooperative as an organization described in section 521(b) which is exempt from tax under section 521(a), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4751145a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7428/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the initial qualification or continuing qualification of an organization as an organization described in section 501(c) (other than paragraph (3)) or 501(d) and exempt from tax under section 501(a), or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4751145b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7428/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a failure by the Secretary to make a determination with respect to an issue referred to in paragraph (1),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"upon the filing of an appropriate pleading, the United States Tax Court, the United States Court of Federal Claims, or the district court of the United States for the District of Columbia may make a declaration with respect to such initial qualification or continuing qualification or with respect to such initial classification or continuing classification. Any such declaration shall have the force and effect of a decision of the Tax Court or a final judgment or decree of the district court or the Court of Federal Claims, as the case may be, and shall be reviewable as such. For purposes of this section, a determination with respect to a continuing qualification or continuing classification includes any revocation of or other change in a qualification or classification.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4751145c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7428/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4751145d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7428/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petitioner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A pleading may be filed under this section only by the organization the qualification or classification of which is at issue.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4751145e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7428/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exhaustion of administrative remedies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A declaratory judgment or decree under this section shall not be issued in any proceeding unless the Tax Court, the Court of Federal Claims, or the district court of the United States for the District of Columbia determines that the organization involved has exhausted administrative remedies available to it within the Internal Revenue Service. An organization requesting the determination of an issue referred to in subsection (a)(1) shall be deemed to have exhausted its administrative remedies with respect to a failure by the Secretary to make a determination with respect to such issue at the expiration of 270 days after the date on which the request for such determination was made if the organization has taken, in a timely manner, all reasonable steps to secure such determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4751145f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7428/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for bringing action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary sends by certified or registered mail notice of his determination with respect to an issue referred to in subsection (a)(1) to the organization referred to in paragraph (1), no proceeding may be initiated under this section by such organization unless the pleading is filed before the 91st day after the date of such mailing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47511460-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7428/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplication for certain revocations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No action may be brought under this section with respect to any revocation of status described in section 6033(j)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47511461-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7428/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Validation of certain contributions made during pendency of proceedings","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47511462-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7428/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47511463-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7428/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the issue referred to in subsection (a)(1) involves the revocation of a determination that the organization is described in section 170(c)(2),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47511464-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7428/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a proceeding under this section is initiated within the time provided by subsection (b)(3), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47511465-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7428/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" either—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47511466-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7428/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a decision of the Tax Court has become final (within the meaning of section 7481), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47511467-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7428/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a judgment of the district court of the United States for the District of Columbia has been entered, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47511468-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7428/c/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a judgment of the Court of Federal Claims has been entered,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"and such decision or judgment, as the case may be, determines that the organization was not described in section 170(c)(2),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then, notwithstanding such decision or judgment, such organization shall be treated as having been described in section 170(c)(2) for purposes of section 170 for the period beginning on the date on which the notice of the revocation was published and ending on the date on which the court first determined in such proceeding that the organization was not described in section 170(c)(2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47511469-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7428/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall apply only—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4751146a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7428/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to individuals, and only to the extent that the aggregate of the contributions made by any individual to or for the use of the organization during the period specified in paragraph (1) does not exceed $1,000 (for this purpose treating a husband and wife as one contributor), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4751146b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7428/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to organizations described in section 170(c)(2) which are exempt from tax under section 501(a) (for this purpose excluding any such organization with respect to which there is pending a proceeding to revoke the determination under section 170(c)(2)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4751146c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7428/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall not apply to any individual who was responsible, in whole or in part, for the activities (or failures to act) on the part of the organization which were the basis for the revocation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4751146d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7428/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subpoena power for district court for District of Columbia","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any action brought under this section in the district court of the United States for the District of Columbia, a subpoena requiring the attendance of a witness at a trial or hearing may be served at any place in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4751146e-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIII/s1306/a"},"text":"Pub. L. 94–455, title XIII, § 1306(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1717"},"text":"90 Stat. 1717","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/600/tVII/s701/dd/2"},"text":"Pub. L. 95–600, title VII, § 701(dd)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2924"},"text":"92 Stat. 2924","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/164/tI/s152"},"text":"Pub. L. 97–164, title I, § 152","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-04-02"},"text":"Apr. 2, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/46"},"text":"96 Stat. 46","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tX/s1033/b"},"text":"Pub. L. 98–369, div. A, title X, § 1033(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1039"},"text":"98 Stat. 1039","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tIII/s317/a"},"text":"Pub. L. 108–357, title III, § 317(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1470"},"text":"118 Stat. 1470","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/280/tXII/s1223/c"},"text":"Pub. L. 109–280, title XII, § 1223(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1091"},"text":"120 Stat. 1091","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/113/dQ/tIV/s406/a"},"text":"Pub. L. 114–113, div. Q, title IV, § 406(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/3120"},"text":"129 Stat. 3120","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/325/A"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(325)(A)","children":[],"tail":", (B), "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1199"},"text":"132 Stat. 1199","children":[],"tail":", 1200.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4751146f-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47511470-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id47511471-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7428 was renumbered 7437 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id47511472-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/a/325/B"},"text":"Pub. L. 115–141, § 401(a)(325)(B)","children":[],"tail":", substituted “or the Court of Federal Claims” for “or the Claims Court” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/a/325/A"},"text":"Pub. L. 115–141, § 401(a)(325)(A)","children":[],"tail":", substituted “United States Court of Federal Claims” for “United States Claims Court” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b)(2), (c)(1)(C)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/a/325/B"},"text":"Pub. L. 115–141, § 401(a)(325)(B)","children":[],"tail":", substituted “Court of Federal Claims” for “Claims Court”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113"},"text":"Pub. L. 114–113","children":[],"tail":" added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280"},"text":"Pub. L. 109–280","children":[],"tail":", which directed addition of par. (4) at the end of section 7428(b), without specifying the act to be amended, was executed by making the addition at the end of subsec. (b) of this section, which is section 7428 of the Internal Revenue Code of 1986, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":" added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsecs. (a), (b)(2), (c)(1)(C)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164"},"text":"Pub. L. 97–164","children":[],"tail":" substituted “Claims Court” for “Court of Claims”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600"},"text":"Pub. L. 95–600","children":[],"tail":" inserted provision relating to change in qualification or classification."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47511473-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47511474-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/dQ/tIV/s406/b"},"text":"Pub. L. 114–113, div. Q, title IV, § 406(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/3120"},"text":"129 Stat. 3120","children":[],"tail":", pr