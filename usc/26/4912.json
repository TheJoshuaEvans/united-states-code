{"tag":"section","attrib":{"id":"id45e43dcc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4912"},"text":null,"children":[{"tag":"num","attrib":{"value":"4912"},"text":"§ 4912.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax on disqualifying lobbying expenditures of certain organizations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45e43dcd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4912/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax on organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an organization to which this section applies is not described in section 501(c)(3) for any taxable year by reason of making lobbying expenditures, there is hereby imposed a tax on the lobbying expenditures of such organization for such taxable year equal to 5 percent of the amount of such expenditures. The tax imposed by this subsection shall be paid by the organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45e43dce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4912/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" On management","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If tax is imposed under subsection (a) on the lobbying expenditures of any organization, there is hereby imposed on the agreement of any organization manager to the making of any such expenditures, knowing that such expenditures are likely to result in the organization not being described in section 501(c)(3), a tax equal to 5 percent of the amount of such expenditures, unless such agreement is not willful and is due to reasonable cause. The tax imposed by this subsection shall be paid by any manager who agreed to the making of the expenditures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45e43dcf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4912/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organizations to which section applies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45e43dd0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4912/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), this section shall apply to any organization which was exempt (or was determined by the Secretary to be exempt) from taxation under section 501(a) by reason of being an organization described in section 501(c)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45e43dd1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4912/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section shall not apply to any organization—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45e43dd2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4912/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to which an election under section 501(h) applies,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45e43dd3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4912/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is a disqualified organization (within the meaning of section 501(h)(5)), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45e43dd4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4912/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is a private foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45e43dd5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4912/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45e43dd6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4912/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lobbying expenditures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “lobbying expenditure” means any amount paid or incurred by the organization in carrying on propaganda, or otherwise attempting to influence legislation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45e43dd7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4912/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organization manager","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “organization manager” has the meaning given to such term by section 4955(f)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45e43dd8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4912/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint and several liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If more than 1 person is liable under subsection (b), all such persons shall be jointly and severally liable under such subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45e43dd9-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX/s10714/a"},"text":"Pub. L. 100–203, title X, § 10714(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-470"},"text":"101 Stat. 1330–470","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45e43dda-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45e43ddb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id45e43ddc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX/s10714/e"},"text":"Pub. L. 100–203, title X, § 10714(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-472"},"text":"101 Stat. 1330–472","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/203/tX/s10714/e"},"text":"“The amendments made by this section [enacting this section and amending sections 6501 and 7454 of this title] shall apply to taxable years beginning after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
