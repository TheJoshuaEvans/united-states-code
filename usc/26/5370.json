{"tag":"section","attrib":{"id":"id4637b548-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5370"},"text":null,"children":[{"tag":"num","attrib":{"value":"5370"},"text":"§ 5370.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Losses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4637b549-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5370/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No tax shall be collected in respect of any wines lost or destroyed while in bond, except that tax shall be collected—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4637b54a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5370/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Theft","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of loss by theft, unless the Secretary shall find that the theft occurred without connivance, collusion, fraud, or negligence on the part of the proprietor or other person responsible for the tax, or the owner, consignor, consignee, bailee, or carrier, or the agents or employees of any of them; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4637b54b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5370/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary destruction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of voluntary destruction, unless the wine was destroyed under Government supervision, or on such adequate notice to, and approval by, the Secretary as regulations shall provide.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4637b54c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5370/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proof of loss","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case in which the wine is lost or destroyed, whether by theft or otherwise, the Secretary may require by regulations the proprietor of the bonded wine cellar or other person liable for the tax to file a claim for relief from the tax and submit proof as to the cause of such loss. In every case where it appears that the loss was by theft, the burden shall be on the proprietor or other person liable for the tax to establish to the satisfaction of the Secretary, that such loss did not occur as the result of connivance, collusion, fraud, or negligence on the part of the proprietor, owner, consignor, consignee, bailee, or carrier, or the agents or employees of any of them.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4637b54d-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1381"},"text":"72 Stat. 1381","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4637b54e-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4637b54f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4637b550-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5370, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/666"},"text":"68A Stat. 666","children":[],"tail":", consisted of provisions similar to those comprising this section, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4637b551-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
