{"tag":"section","attrib":{"id":"id4442ea33-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s862"},"text":null,"children":[{"tag":"num","attrib":{"value":"862"},"text":"§ 862.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Income from sources without the United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4442ea34-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s862/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gross income from sources without United States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following items of gross income shall be treated as income from sources without the United States:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4442ea35-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s862/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interest other than that derived from sources within the United States as provided in section 861(a)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4442ea36-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s862/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dividends other than those derived from sources within the United States as provided in section 861(a)(2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4442ea37-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s862/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compensation for labor or personal services performed without the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4442ea38-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s862/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rentals or royalties from property located without the United States or from any interest in such property, including rentals or royalties for the use of or for the privilege of using without the United States patents, copyrights, secret processes and formulas, good will, trade-marks, trade brands, franchises, and other like properties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4442ea39-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s862/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gains, profits, and income from the sale or exchange of real property located without the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4442ea3a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s862/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gains, profits, and income derived from the purchase of inventory property (within the meaning of section 865(i)(1)) within the United States and its sale or exchange without the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4442ea3b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s862/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" underwriting income other than that derived from sources within the United States as provided in section 861(a)(7);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4442ea3c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s862/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gains, profits, and income from the disposition of a United States real property interest (as defined in section 897(c)) when the real property is located in the Virgin Islands; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4442ea3d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s862/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts received, directly or indirectly, from a foreign person for the provision of a guarantee of indebtedness of such person other than amounts which are derived from sources within the United States as provided in section 861(a)(9).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4442ea3e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s862/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable income from sources without United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the items of gross income specified in subsection (a) there shall be deducted the expenses, losses, and other deductions properly apportioned or allocated thereto, and a ratable part of any expenses, losses, or other deductions which cannot definitely be allocated to some item or class of gross income. The remainder, if any, shall be treated in full as taxable income from sources without the United States. In the case of an individual who does not itemize deductions, an amount equal to the standard deduction shall be considered a deduction which cannot definitely be allocated to some item or class of gross income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4442ea3f-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/276"},"text":"68A Stat. 276","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/178/tIII/s314/b"},"text":"Pub. L. 92–178, title III, § 314(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-10"},"text":"Dec. 10, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/528"},"text":"85 Stat. 528","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tX/s1036/b"},"text":"Pub. L. 94–455, title X, § 1036(b)","children":[],"tail":", title XIX, § 1901(b)(26)(C), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1633"},"text":"90 Stat. 1633","children":[],"tail":", 1798; "},{"tag":"ref","attrib":{"href":"/us/pl/95/30/tI/s102/b/10"},"text":"Pub. L. 95–30, title I, § 102(b)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-05-23"},"text":"May 23, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/138"},"text":"91 Stat. 138","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/tVIII/s831/a/2"},"text":"Pub. L. 97–34, title VIII, § 831(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/352"},"text":"95 Stat. 352","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tI/s104/b/12"},"text":"Pub. L. 99–514, title I, § 104(b)(12)","children":[],"tail":", title XII, § 1211(b)(1)(C), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2105"},"text":"100 Stat. 2105","children":[],"tail":", 2536; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1012/e/4"},"text":"Pub. L. 100–647, title I, § 1012(e)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3500"},"text":"102 Stat. 3500","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7811/i/2"},"text":"Pub. L. 101–239, title VII, § 7811(i)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2409"},"text":"103 Stat. 2409","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/240/tII/s2122/b"},"text":"Pub. L. 111–240, title II, § 2122(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-09-27"},"text":"Sept. 27, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2568"},"text":"124 Stat. 2568","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4442ea40-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4442ea41-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4442ea42-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/240"},"text":"Pub. L. 111–240","children":[],"tail":" added par. (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[