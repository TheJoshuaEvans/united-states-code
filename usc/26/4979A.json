{"tag":"section","attrib":{"id":"id4605a946-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4979A"},"text":null,"children":[{"tag":"num","attrib":{"value":"4979A"},"text":"§ 4979A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax on certain prohibited allocations of qualified securities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4605a947-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4979A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of tax","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4605a948-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4979A/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a prohibited allocation of qualified securities by any employee stock ownership plan or eligible worker-owned cooperative,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4605a949-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4979A/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is an allocation described in section 664(g)(5)(A),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4605a94a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4979A/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is any allocation of employer securities which violates the provisions of section 409(p), or a nonallocation year described in subsection (e)(2)(C) with respect to an employee stock ownership plan, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4605a94b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4979A/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any synthetic equity is owned by a disqualified person in any nonallocation year,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"there is hereby imposed a tax on such allocation or ownership equal to 50 percent of the amount involved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4605a94c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4979A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited allocation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “prohibited allocation” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4605a94d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4979A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any allocation of qualified securities acquired in a sale to which section 1042 applies which violates the provisions of section 409(n), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4605a94e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4979A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any benefit which accrues to any person in violation of the provisions of section 409(n).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4605a94f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4979A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability for tax","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The tax imposed by this section shall be paid—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4605a950-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4979A/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of an allocation referred to in paragraph (1) or (2) of subsection (a), by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4605a951-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4979A/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employer sponsoring such plan, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4605a952-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4979A/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligible worker-owned cooperative,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"which made the written statement described in section 664(g)(1)(E) or in section 1042(b)(3)(B) (as the case may be), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4605a953-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4979A/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an allocation or ownership referred to in paragraph (3) or (4) of subsection (a), by the S corporation the stock in which was so allocated or owned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4605a954-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4979A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special statute of limitations for tax attributable to certain allocations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The statutory period for the assessment of any tax imposed by this section on an allocation described in subsection (a)(2) of qualified employer securities shall not expire before the date which is 3 years from the later of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4605a955-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4979A/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 1st allocation of such securities in connection with a qualified gratuitous transfer (as defined in section 664(g)(1)), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4605a956-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4979A/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the Secretary is notified of the allocation described in subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4605a957-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4979A/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4605a958-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4979A/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), terms used in this section have the same respective meanings as when used in sections 409 and 4978.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4605a959-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4979A/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules relating to tax imposed by reason of paragraph (3) or (4) of subsection (a)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4605a95a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4979A/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited allocations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount involved with respect to any tax imposed by reason of subsection (a)(3) is the amount allocated to the account of any person in violation of section 409(p)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4605a95b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4979A/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Synthetic equity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount involved with respect to any tax imposed by reason of subsection (a)(4) is the value of the shares on which the synthetic equity is based.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4605a95c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4979A/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule during first nonallocation year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A), the amount involved for the first nonallocation year of any employee stock ownership plan shall be determined by taking into account the total value of all the deemed-owned shares of all disqualified persons with respect to such plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4605a95d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4979A/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statute of limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The statutory period for the assessment of any tax imposed by this section by reason of paragraph (3) or (4) of subsection (a) shall not expire before the date which is 3 years from the later of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4605a95e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4979A/e/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the allocation or ownership referred to in such paragraph giving rise to such tax, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4605a95f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4979A/e/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the Secretary is notified of such allocation or ownership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4605a960-3a70-11f1-a967-d35dac11796a"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXI/s1172/b/2"},"text":"Pub. L. 99–514, title XI, § 1172(b)(2)","children":[],"tail":", title XVIII, § 1854(a)(9)(A), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2514"},"text":"100 Stat. 2514","children":[],"tail":", 2877; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7304/a/2/D"},"text":"Pub. L. 101–239, title VII, § 7304(a)(2)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2353"},"text":"103 Stat. 2353","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1704/t/22"},"text":"Pub. L. 104–188, title I, § 1704(t)(22)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1888"},"text":"110 Stat. 1888","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXV/s1530/c/15"},"text":"Pub. L. 105–34, title XV, § 1530(c)(15)","children":[],"tail":"–(17), "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1079"},"text":"111 Stat. 1079","children":[],"tail":", 1080; "},{"tag":"ref","attrib":{"href":"/us/pl/107/16/tVI/s656/c"},"text":"Pub. L. 107–16, title VI, § 656(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-06-07"},"text":"June 7, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/134"},"text":"115 Stat. 134","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4605a961-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4605a962-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4605a963-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16/s656/c/1"},"text":"Pub. L. 107–16, § 656(c)(1)","children":[],"tail":", added pars. (3) and (4) and, in concluding provisions, substituted “there is hereby imposed a tax on such allocation or ownership equal to 50 percent of the amount involved.” for “there is hereby imposed a tax on such allocation equal to 50 percent of the amount involved.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16/s656/c/2"},"text":"Pub. L. 107–16, § 656(c)(2)","children":[],"tail":", amended heading and text of subsec. (c) generally. Prior to amendment, text read as follows: “The tax imposed by this section shall be paid by—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) the employer sponsoring such plan, or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) the eligible worker-owned cooperative,","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"which made the written statement described in section 664(g)(1)(E) or in section 1042(b)(3)(B) (as the case may be).”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16/s656/c/3"},"text":"Pub. L. 107–16, § 656(c)(3)","children":[],"tail":", amended heading and text of subsec. (e) generally. Prior to amendment, text read as follows: “Terms used in this section have the same respective meaning as when used in section 4978.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1530/c/15"},"text":"Pub. L. 105–34, § 1530(c)(15)","children":[],"tail":", amended heading and text of subsec. (a) generally. Prior to amendment, text read as follows: “If there is a prohibited allocation of qualified securities by any employee stock ownership plan or eligible worker-owned cooperative, there is hereby imposed a tax on such allocation equal to 50 percent of the amount involved.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1530/c/16"},"text":"Pub. L. 105–34, § 1530(c)(16)","children":[],"tail":", amended heading and text of subsec. (c) generally. Prior to amendment, text read as follows: “The tax imposed by this section shall be paid by—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) the employer sponsoring such plan, or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) the eligible worker-owned cooperative,","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"which made the written statement described in section 1042(b)(3)(B).”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1530/c/17"},"text":"Pub. L. 105–34, § 1530(c)(17)","children":[],"tail":", added subsec. (d) and redesignated former subsec. (d) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":" amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7304/a/2/D/ii"},"text":"Pub. L. 101–239, § 7304(a)(2)(D)(ii)","children":[],"tail":". See 1989 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (b)(1). ","children":[{"ta