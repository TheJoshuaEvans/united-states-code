blished after "},{"tag":"date","attrib":{"date":"2001-03-14"},"text":"Mar. 14, 2001","children":[],"tail":", or established on or before such date if employer securities held by the plan consist of stock in a corporation with respect to which an election under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1362/a"},"text":"section 1362(a) of this title","children":[],"tail":" is not in effect on such date, amendment applicable to plan years ending after "},{"tag":"date","attrib":{"date":"2001-03-14"},"text":"Mar. 14, 2001","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/16/s656/d"},"text":"section 656(d) of Pub. L. 107–16","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s409"},"text":"section 409 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4605a966-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" applicable to transfers made by trusts to, or for the use of, an employee stock ownership plan after "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1530/d"},"text":"section 1530(d) of Pub. L. 105–34","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s401"},"text":"section 401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4605a967-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children"