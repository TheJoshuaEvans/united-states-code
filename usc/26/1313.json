{"tag":"section","attrib":{"id":"id44e767da-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1313"},"text":null,"children":[{"tag":"num","attrib":{"value":"1313"},"text":"§ 1313.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44e767db-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1313/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this part, the term “determination” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44e767dc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1313/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a decision by the Tax Court or a judgment, decree, or other order by any court of competent jurisdiction, which has become final;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44e767dd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1313/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a closing agreement made under section 7121;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44e767de-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1313/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a final disposition by the Secretary of a claim for refund. For purposes of this part, a claim for refund shall be deemed finally disposed of by the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44e767df-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1313/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as to items with respect to which the claim was allowed, on the date of allowance of refund or credit or on the date of mailing notice of disallowance (by reason of offsetting items) of the claim for refund, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44e767e0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1313/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as to items with respect to which the claim was disallowed, in whole or in part, or as to items applied by the Secretary in reduction of the refund or credit, on expiration of the time for instituting suit with respect thereto (unless suit is instituted before the expiration of such time); or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44e767e1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1313/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under regulations prescribed by the Secretary, an agreement for purposes of this part, signed by the Secretary and by any person, relating to the liability of such person (or the person for whom he acts) in respect of a tax under this subtitle for any taxable period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44e767e2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1313/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxpayer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding section 7701(a)(14), the term “taxpayer” means any person subject to a tax under the applicable revenue law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44e767e3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1313/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Related taxpayer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this part, the term “related taxpayer” means a taxpayer who, with the taxpayer with respect to whom a determination is made, stood, in the taxable year with respect to which the erroneous inclusion, exclusion, omission, allowance, or disallowance was made, in one of the following relationships:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44e767e4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1313/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" husband and wife,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44e767e5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1313/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grantor and fiduciary,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44e767e6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1313/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grantor and beneficiary,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44e767e7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1313/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fiduciary and beneficiary, legatee, or heir,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44e767e8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1313/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" decedent and decedent’s estate,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44e767e9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1313/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" partner, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44e767ea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1313/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" member of an affiliated group of corporations (as defined in section 1504).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44e767eb-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/339"},"text":"68A Stat. 339","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44e767ec-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44e767ed-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44e767ee-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—Subsec. (a)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
