{"tag":"section","attrib":{"id":"id45afc040-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4053"},"text":null,"children":[{"tag":"num","attrib":{"value":"4053"},"text":"§ 4053.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemptions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"No tax shall be imposed by section 4051 on any of the following articles:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45afc041-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4053/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Camper coaches bodies for self-propelled mobile homes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any article designed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45afc042-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4053/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be mounted or placed on automobile trucks, automobile truck chassis, or automobile chassis, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45afc043-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4053/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be used primarily as living quarters or camping accommodations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45afc044-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4053/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Feed, seed, and fertilizer equipment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any body primarily designed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45afc045-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4053/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to process or prepare seed, feed, or fertilizer for use on farms,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45afc046-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4053/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to haul feed, seed, or fertilizer to and on farms,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45afc047-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4053/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to spread feed, seed, or fertilizer on farms,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45afc048-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4053/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to load or unload feed, seed, or fertilizer on farms, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45afc049-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4053/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any combination of the foregoing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45afc04a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4053/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" House trailers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any house trailer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45afc04b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4053/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ambulances, hearses, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any ambulance, hearse, or combination ambulance-hearse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45afc04c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4053/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Concrete mixers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any article designed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45afc04d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4053/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be placed or mounted on an automobile truck chassis or truck trailer or semitrailer chassis, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45afc04e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4053/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be used to process or prepare concrete.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45afc04f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4053/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trash containers, etc.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any box, container, receptacle, bin or other similar article—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45afc050-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4053/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is designed to be used as a trash container and is not designed for the transportation of freight other than trash, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45afc051-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4053/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is not designed to be permanently mounted on or permanently affixed to an automobile truck chassis or body.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45afc052-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4053/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rail trailers and rail vans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any chassis or body of a trailer or semitrailer which is designed for use both as a highway vehicle and a railroad car. For purposes of the preceding sentence, piggy-back trailer or semitrailer shall not be treated as designed for use as a railroad car.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45afc053-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4053/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mobile machinery","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any vehicle which consists of a chassis—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45afc054-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4053/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to which there has been permanently mounted (by welding, bolting, riveting, or other means) machinery or equipment to perform a construction, manufacturing, processing, farming, mining, drilling, timbering, or similar operation if the operation of the machinery or equipment is unrelated to transportation on or off the public highways,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45afc055-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4053/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which has been specially designed to serve only as a mobile carriage and mount (and a power source, where applicable) for the particular machinery or equipment involved, whether or not such machinery or equipment is in operation, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45afc056-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4053/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which, by reason of such special design, could not, without substantial structural modification, be used as a component of a vehicle designed to perform a function of transporting any load other than that particular machinery or equipment or similar machinery or equipment requiring such a specially designed chassis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45afc057-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4053/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Idling reduction device","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any device or system of devices which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45afc058-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4053/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is designed to provide to a vehicle those services (such as heat, air conditioning, or electricity) that would otherwise require the operation of the main drive engine while the vehicle is temporarily parked or remains stationary using one or more devices affixed to a tractor, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45afc059-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4053/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is determined by the Administrator of the Environmental Protection Agency, in consultation with the Secretary of Energy and the Secretary of Transportation, to reduce idling of such vehicle at a motor vehicle rest stop or other location where such vehicles are temporarily parked or remain stationary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45afc05a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4053/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced insulation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any insulation that has an R value of not less than R35 per inch.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45afc05b-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/424/tV/s512/b/1"},"text":"Pub. L. 97–424, title V, § 512(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-06"},"text":"Jan. 6, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2176"},"text":"96 Stat. 2176","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tVII/s735/b/1"},"text":"Pub. L. 98–369, div. A, title VII, § 735(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/981"},"text":"98 Stat. 981","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s851/a/1"},"text":"Pub. L. 108–357, title VIII, § 851(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1607"},"text":"118 Stat. 1607","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/343/dB/tII/s206/a"},"text":"Pub. L. 110–343, div. B, title II, § 206(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3839"},"text":"122 Stat. 3839","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45afc05c-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45afc05d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id45afc05e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4053, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/479"},"text":"68A Stat. 479","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/tI/s104"},"text":"Pub. L. 85–859, title I, § 104","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1276"},"text":"72 Stat. 1276","children":[],"tail":", made provision for the imposition of the retailers tax on installment sales, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1904/a/1/D"},"text":"Pub. L. 94–455, title XIX, § 1904(a)(1)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1811"},"text":"90 Stat. 1811","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For provisions of prior sections 4054 to 4058 of this title, see Prior Provisions note set out preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s4041"},"text":"section 4041 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45afc05f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Pars. (9), (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343"},"text":"Pub. L. 110–343","children":[],"tail":" added pars. (9) and (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":" added par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" amended section generally, substituting provisions listing articles on which no tax under section 4051 shall be imposed for former provisions which stated that no tax be imposed under section 4051 on any article specified in subsection (a) of section 4063 and that the exemptions provided by section 4221(a) extended to the tax imposed by section 4051."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45afc060-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45afc061-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343/dB/tII/s206/b"},"text":"Pub. L. 110–343, div. B, title II, § 206(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3839"},"text":"122 Stat. 3839","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/343/dB/tII/s206/b"},"text":"“The amendment made by this section [amending this section] shall apply to sales or installations after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45afc062-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s851/a/2"},"text":"Pub. L. 108–357, title VIII, § 851(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1607"},"text":"118 Stat. 1607","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/357/tVIII/s851/a/2"},"text":"“The amendment made by this subsection [amending this section] shall take effect on the day after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45afc063-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" effective, except as otherwise provided, as if included in the provisions of the Highway Revenue Act of 1982, title V of "},{"tag":"ref","attrib":{"href":"/us/pl/97/424"},"text":"Pub. L. 97–424","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s736"},"text":"section 736 of Pub. L. 98–369","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4051"},"text":"section 4051 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
