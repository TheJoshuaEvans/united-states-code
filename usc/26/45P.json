{"tag":"section","attrib":{"id":"id40d7d32c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45P"},"text":null,"children":[{"tag":"num","attrib":{"value":"45P"},"text":"§ 45P.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employer wage credit for employees who are active duty members of the uniformed services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id40d7d32d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45P/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of section 38, the differential wage payment credit for any taxable year is an amount equal to 20 percent of the sum of the eligible differential wage payments for each of the qualified employees of the taxpayer during such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40d7d32e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45P/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40d7d32f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45P/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible differential wage payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible differential wage payments” means, with respect to each qualified employee, so much of the differential wage payments (as defined in section 3401(h)(2)) paid to such employee for the taxable year as does not exceed $20,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d7d330-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45P/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified employee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified employee” means a person who has been an employee of the taxpayer for the 91-day period immediately preceding the period for which any differential wage payment is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d7d331-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45P/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Controlled groups","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All persons treated as a single employer under subsection (b), (c), (m), or (","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":") of section 414 shall be treated as a single employer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40d7d332-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45P/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with other credits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of credit otherwise allowable under this chapter with respect to compensation paid to any employee shall be reduced by the credit determined under this section with respect to such employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40d7d333-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45P/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disallowance for failure to comply with employment or reemployment rights of members of the reserve components of the Armed Forces of the United States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No credit shall be allowed under subsection (a) to a taxpayer for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40d7d334-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45P/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any taxable year, beginning after the date of the enactment of this section, in which the taxpayer is under a final order, judgment, or other process issued or required by a district court of the United States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4323"},"text":"section 4323 of title 38","children":[],"tail":" of the United States Code with respect to a violation of chapter 43 of such title, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d7d335-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45P/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 2 succeeding taxable years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40d7d336-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45P/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain rules to apply","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, rules similar to the rules of subsections (c), (d), and (e) of section 52 shall apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id40d7d337-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/245/tI/s111/a"},"text":"Pub. L. 110–245, title I, § 111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-17"},"text":"June 17, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1634"},"text":"122 Stat. 1634","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/312/tVII/s736/a"},"text":"Pub. L. 111–312, title VII, § 736(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-17"},"text":"Dec. 17, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3318"},"text":"124 Stat. 3318","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/240/tIII/s308/a"},"text":"Pub. L. 112–240, title III, § 308(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2329"},"text":"126 Stat. 2329","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dA/tI/s118/a"},"text":"Pub. L. 113–295, div. A, title I, § 118(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4015"},"text":"128 Stat. 4015","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/113/dQ/tI/s122/a"},"text":"Pub. L. 114–113, div. Q, title I, § 122(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/3052"},"text":"129 Stat. 3052","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id40d7d338-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id40d7d339-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id40d7d33a-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this section, referred to in subsec. (d)(1), is the date of the enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/245"},"text":"Pub. L. 110–245","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2008-06-17"},"text":"June 17, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id40d7d33b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/s122/b/1"},"text":"Pub. L. 114–113, § 122(b)(1)","children":[],"tail":", struck out “, in the case of an eligible small business employer” after “section 38”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/s122/b/2"},"text":"Pub. L. 114–113, § 122(b)(2)","children":[],"tail":", amended par. (3) generally. Prior to amendment, par. (3) defined “eligible small business employer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/s122/a"},"text":"Pub. L. 114–113, § 122(a)","children":[],"tail":", struck out subsec. (f). Text read as follows: “This section shall not apply to any payments made after "},{"tag":"date","attrib":{"date":"2014-12-31"},"text":"December 31, 2014","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2014-12-31"},"text":"December 31, 2014","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2013-12-31"},"text":"December 31, 2013","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/240"},"text":"Pub. L. 112–240","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2013-12-31"},"text":"December 31, 2013","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"December 31, 2011","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/312"},"text":"Pub. L. 111–312","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"December 31, 2011","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2009-12-31"},"text":"December 31, 2009","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id40d7d33c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id40d7d33d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl