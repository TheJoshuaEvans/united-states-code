{"tag":"section","attrib":{"id":"id46412abc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5610"},"text":null,"children":[{"tag":"num","attrib":{"value":"5610"},"text":"§ 5610.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposal of forfeited equipment and material for distilling","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All boilers, stills, or other vessels, tools and implements, used in distilling or processing, and forfeited under any of the provisions of this chapter, and all condemned material, together with any engine or other machinery connected therewith, and all empty barrels, and all grain or other material suitable for fermentation or distillation, shall be sold at public auction or otherwise disposed of as the court in which forfeiture was recovered shall in its discretion direct.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id46412abd-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1404"},"text":"72 Stat. 1404","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/tVIII/s807/a/54"},"text":"Pub. L. 96–39, title VIII, § 807(a)(54)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/289"},"text":"93 Stat. 289","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46412abe-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46412abf-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","