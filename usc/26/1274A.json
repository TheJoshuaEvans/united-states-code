{"tag":"section","attrib":{"id":"id44d936a3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1274A"},"text":null,"children":[{"tag":"num","attrib":{"value":"1274A"},"text":"§ 1274A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for certain transactions where stated principal amount does not exceed $2,800,000","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44d936a4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1274A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lower discount rate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any qualified debt instrument, the discount rate used for purposes of sections 483 and 1274 shall not exceed 9 percent, compounded semiannually.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44d936a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1274A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified debt instrument defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “qualified debt instrument” means any debt instrument given in consideration for the sale or exchange of property (other than new section 38 property within the meaning of section 48(b), as in effect on the day before the date of the enactment of the Revenue Reconciliation Act of 1990) if the stated principal amount of such instrument does not exceed $2,800,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44d936a6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1274A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election to use cash method where stated principal amount does not exceed $2,000,000","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44d936a7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1274A/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any cash method debt instrument—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44d936a8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1274A/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 1274 shall not apply, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d936a9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1274A/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interest on such debt instrument shall be taken into account by both the borrower and the lender under the cash receipts and disbursements method of accounting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d936aa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1274A/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cash method debt instrument","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), the term “cash method debt instrument” means any qualified debt instrument if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44d936ab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1274A/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the stated principal amount does not exceed $2,000,000,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d936ac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1274A/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lender does not use an accrual method of accounting and is not a dealer with respect to the property sold or exchanged,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d936ad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1274A/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 1274 would have applied to such instrument but for an election under this subsection, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d936ae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1274A/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an election under this subsection is jointly made with respect to such debt instrument by the borrower and lender.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d936af-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1274A/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Successors bound by election","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44d936b0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1274A/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), paragraph (1) shall apply to any successor to the borrower or lender with respect to a cash method debt instrument.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d936b1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1274A/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception where lender transfers debt instrument to accrual method taxpayer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the lender (or any successor) transfers any cash method debt instrument to a taxpayer who uses an accrual method of accounting, this paragraph shall not apply with respect to such instrument for periods after such transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d936b2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1274A/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fair market value rule in potentially abusive situations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any cash method debt instrument, section 483 shall be applied as if it included provisions similar to the provisions of section 1274(b)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44d936b3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1274A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other special rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44d936b4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1274A/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aggregation rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44d936b5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1274A/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all sales or exchanges which are part of the same transaction (or a series of related transactions) shall be treated as 1 sale or exchange, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d936b6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1274A/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all debt instruments arising from the same transaction (or a series of related transactions) shall be treated as 1 debt instrument.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d936b7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1274A/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment for inflation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any debt instrument arising out of a sale or exchange during any calendar year after 1989, each dollar amount contained in the preceding provisions of this section shall be increased by an amount equal to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44d936b8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1274A/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such amount, multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d936b9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1274A/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost-of-living adjustment determined under section 1(f)(3) for the calendar year in which the taxable year begins, by substituting “calendar year 1988” for “calendar year 2016” in subparagraph (A)(ii) thereof.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Any increase under the preceding sentence shall be rounded to the nearest multiple of $100 (or, if such increase is a multiple of $50, such increase shall be increased to the nearest multiple of $100).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44d936ba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1274A/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prescribe such regulations as may be necessary to carry out the purposes of this subsection, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44d936bb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1274A/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulations coordinating the provisions of this section with other provisions of this title,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d936bc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1274A/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulations necessary to prevent the avoidance of tax through the abuse of the provisions of subsection (c), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d936bd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1274A/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulations relating to the treatment of transfers of cash method debt instruments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44d936be-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/121/tI/s102/a"},"text":"Pub. L. 99–121, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-10-11"},"text":"Oct. 11, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/506"},"text":"99 Stat. 506","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11813/b/22"},"text":"Pub. L. 101–508, title XI, § 11813(b)(22)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-555"},"text":"104 Stat. 1388–555","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1704/t/62"},"text":"Pub. L. 104–188, title I, § 1704(t)(62)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1890"},"text":"110 Stat. 1890","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s11002/d/10"},"text":"Pub. L. 115–97, title I, § 11002(d)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2062"},"text":"131 Stat. 2062","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44d936bf-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id44d936c0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Inflation Adjusted Items for Certain Years","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For inflation adjustment of certain items in this section, see Revenue Rulings listed in a table below and Revenue Procedures listed in a table under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44d936c1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id44d936c2-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the Revenue Reconciliation Act of 1990, referred to in subsec. (b), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44d936c3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":" amended par. (2) generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—In the case of any debt instrument arising out of a sale or exchange during any calendar year after 1989, each dollar amount contained in the preceding provisions of this section shall be increased by the inflation adjustment for such calendar year. Any increase under the preceding sentence shall be rounded to the nearest multiple of $100 (or, if such increase is a multiple of $50, such increase shall be increased to the nearest multiple of $100)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) ","children":[{"tag":"inline","attrib":{},"text":"Inflation adjustment","children":[],"tail":".—For purposes of subparagraph (A), the inflation adjustment for any calendar year is the percentage (if any) by which—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) the CPI for the preceding calendar year exceeds","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) the CPI for calendar year 1988.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For purposes of the preceding sentence, the CPI for any calendar year is the average of the Consumer Price Index as of the close of the 12-month period ending on September 30 of such calendar year.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (c)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":" substituted “instrument” for “instument”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" inserted “, as in effect on the day before the date of the enactment of the Revenue Reconciliation Act of 1990” after “section 48(b)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44d936c4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44d936c5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"2017-12-31"},"text":"Dec. 31, 2017","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/s11002/e"},"text":"section 11002(e) of Pub. L. 115–97","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44d936c6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" applicable to property placed in service after "},{"tag":"date","attrib":{"date":"1990-12-31"},"text":"Dec. 31, 1990","children":[],"tail":", but not applicable to any transition property (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s49/e"},"text":"section 49(e) of this title","children":[],"tail":"), any property with respect to which q