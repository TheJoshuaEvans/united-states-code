{"tag":"section","attrib":{"id":"id43f69f63-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s683"},"text":null,"children":[{"tag":"num","attrib":{"value":"683"},"text":"§ 683.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of trust as an exchange fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id43f69f64-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s683/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b), if property is transferred to a trust in exchange for an interest in other trust property and if the trust would be an investment company (within the meaning of section 351) if it were a corporation, then gain shall be recognized to the transferor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43f69f65-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s683/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for pooled income funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not apply to any transfer to a pooled income fund (within the meaning of section 642(c)(5)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id43f69f66-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/235"},"text":"68A Stat. 235","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXXI/s2131/e/1"},"text":"Pub. L. 94–455, title XXI, § 2131(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1924"},"text":"90 Stat. 1924","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id43f69f67-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id43f69f68-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id43f69f69-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" substituted provisions relating to use of trust as an exchange fund for provisions setting forth rule that this part applies only to taxable years beginning after "},{"tag":"date","attrib":{"date":"1953-12-31"},"text":"Dec. 31, 1953","children":[],"tail":", and ending after the date of the enactment of this title and exceptions thereto."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id43f69f6a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43f69f6b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of section by ","children":[{"tag":