{"tag":"section","attrib":{"id":"id463c7085-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5418"},"text":null,"children":[{"tag":"num","attrib":{"value":"5418"},"text":"§ 5418.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Beer imported in bulk","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Beer imported or brought into the United States in bulk containers may, under such regulations as the Secretary may prescribe, be withdrawn from customs custody and transferred in such bulk containers to the premises of a brewery without payment of the internal revenue tax imposed on such beer. The proprietor of a brewery to which such beer is transferred shall become liable for the tax on the beer withdrawn from customs custody under this section upon release of the beer from customs custody, and the importer, or the person bringing such beer into the United States, shall thereupon be relieved of the liability for such tax.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id463c7086-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXIV/s1421/a"},"text":"Pub. L. 105–34, title XIV, § 1421(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1049"},"text":"111 Stat. 1049","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id463c7087-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id463c7088-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id463c7089-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXIV/s1421/c"},"text":"Pub. L. 105–34, title XIV, § 1421(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1049"},"text":"111 Stat. 1049","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/34/tXIV/s1421/c"},"text":"“The amendments made by this section [enacting this section] shall take effect on the 1st day of the 1st calendar quarter that begins at least 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
