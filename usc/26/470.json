{"tag":"section","attrib":{"id":"id439bfb33-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470"},"text":null,"children":[{"tag":"num","attrib":{"value":"470"},"text":"§ 470.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on deductions allocable to property used by governments or other tax-exempt entities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id439bfb34-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on losses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this section, a tax-exempt use loss for any taxable year shall not be allowed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id439bfb35-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disallowed loss carried to next year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any tax-exempt use loss with respect to any tax-exempt use property which is disallowed under subsection (a) for any taxable year shall be treated as a deduction with respect to such property in the next taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id439bfb36-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id439bfb37-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax-exempt use loss","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “tax-exempt use loss” means, with respect to any taxable year, the amount (if any) by which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id439bfb38-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the sum of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id439bfb39-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate deductions (other than interest) directly allocable to a tax-exempt use property, plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id439bfb3a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate deductions for interest properly allocable to such property, exceed","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id439bfb3b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate income from such property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id439bfb3c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax-exempt use property","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id439bfb3d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “tax-exempt use property” has the meaning given to such term by section 168(h), except that such section shall be applied—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id439bfb3e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without regard to paragraphs (1)(C) and (3) thereof, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id439bfb3f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as if section 197 intangible property (as defined in section 197), and property described in paragraph (1)(B) or (2) of section 167(f), were tangible property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id439bfb40-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for partnerships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such term shall not include any property which would (but for this subparagraph) be tax-exempt use property solely by reason of section 168(h)(6).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id439bfb41-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For treatment of partnerships as leases to which section 168(h) applies, see section 7701(e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id439bfb42-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for certain leases","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section shall not apply to any lease of property which meets the requirements of all of the following paragraphs:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id439bfb43-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id439bfb44-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A lease of property meets the requirements of this paragraph if (at all times during the lease term) not more than an allowable amount of funds are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id439bfb45-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to any arrangement referred to in subparagraph (B), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id439bfb46-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set aside or expected to be set aside,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"to or for the benefit of the lessor or any lender, or to or for the benefit of the lessee to satisfy the lessee’s obligations or options under the lease. For purposes of clause (ii), funds shall be treated as set aside or expected to be set aside only if a reasonable person would conclude, based on the facts and circumstances, that such funds are set aside or expected to be set aside.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id439bfb47-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Arrangements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The arrangements referred to in this subparagraph include a defeasance arrangement, a loan by the lessee to the lessor or any lender, a deposit arrangement, a letter of credit collateralized with cash or cash equivalents, a payment undertaking agreement, prepaid rent (within the meaning of the regulations under section 467), a sinking fund arrangement, a guaranteed investment contract, financial guaranty insurance, and any similar arrangement (whether or not such arrangement provides credit support).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id439bfb48-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowable amount","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id439bfb49-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/d/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this subparagraph, the term “allowable amount” means an amount equal to 20 percent of the lessor’s adjusted basis in the property at the time the lease is entered into.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id439bfb4a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/d/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Higher amount permitted in certain cases","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent provided in regulations, a higher percentage shall be permitted under clause (i) where necessary because of the credit-worthiness of the lessee. In no event may such regulations permit a percentage of more than 50 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id439bfb4b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/d/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Option to purchase","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If under the lease the lessee has the option to purchase the property for a fixed price or for other than the fair market value of the property (determined at the time of exercise), the allowable amount at the time such option may be exercised may not exceed 50 percent of the price at which such option may be exercised.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id439bfb4c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/d/1/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No allowable amount for certain arrangements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The allowable amount shall be zero with respect to any arrangement which involves—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id439bfb4d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/d/1/C/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a loan from the lessee to the lessor or a lender,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id439bfb4e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/d/1/C/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any deposit received, letter of credit issued, or payment undertaking agreement entered into by a lender otherwise involved in the transaction, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id439bfb4f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/d/1/C/iv/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a transaction which involves a lender, any credit support made available to the lessor in which any such lender does not have a claim that is senior to the lessor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":" For purposes of subclause (I), the term “loan” shall not include any amount treated as a loan under section 467 with respect to a section 467 rental agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id439bfb50-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lessor must make substantial equity investment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id439bfb51-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A lease of property meets the requirements of this paragraph if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id439bfb52-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the lessor—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id439bfb53-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/d/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has at the time the lease is entered into an unconditional at-risk equity investment (as determined by the Secretary) in the property of at least 20 percent of the lessor’s adjusted basis in the property as of that time, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id439bfb54-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/d/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintains such investment throughout the term of the lease, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id439bfb55-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fair market value of the property at the end of the lease term is reasonably expected to be equal to at least 20 percent of such basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id439bfb56-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Risk of loss","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A)(ii), the fair market value at the end of the lease term shall be reduced to the extent that a person other than the lessor bears a risk of loss in the value of the property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id439bfb57-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Paragraph not to apply to short-term leases","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This paragraph shall not apply to any lease with a lease term of 5 years or less.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id439bfb58-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lessee may not bear more than minimal risk of loss","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id439bfb59-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A lease of property meets the requirements of this paragraph if there is no arrangement under which the lessee bears—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id439bfb5a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any portion of the loss that would occur if the fair market value of the leased property were 25 percent less than its reasonably expected fair market value at the time the lease is terminated, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id439bfb5b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more than 50 percent of the loss that would occur if the fair market value of the leased property at the time the lease is terminated were zero.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id439bfb5c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may by regulations provide that the requirements of this paragraph are not met where the lessee bears more than a minimal risk of loss.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id439bfb5d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Paragraph not to apply to short-term leases","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This paragraph shall not apply to any lease with a lease term of 5 years or less.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id439bfb5e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property with more than 7-year class life","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a lease—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id439bfb5f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of property with a class life (as defined in section 168(i)(1)) of more than 7 years, other than fixed-wing aircraft and vessels, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id439bfb60-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under which the lessee has the option to purchase the property,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the lease meets the requirements of this paragraph only if the purchase price under the option equals the fair market value of the property (determined at the time of exercise).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id439bfb61-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id439bfb62-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of former tax-exempt use property","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id439bfb63-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any former tax-exempt use property—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id439bfb64-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any deduction allowable under subsection (b) with respect to such property for any taxable year shall be allowed only to the extent of any net income (without regard to such deduction) from such property for such taxable year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id439bfb65-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any portion of such unused deduction remaining after application of clause (i) shall be treated as a deduction allowable under subsection (b) with respect to such property in the next taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id439bfb66-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Former tax-exempt use property","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “former tax-exempt use property” means any property which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id439bfb67-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not tax-exempt use property for the taxable year, but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id439bfb68-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was tax-exempt use property for any prior taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id439bfb69-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of entire interest in property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If during the taxable year a taxpayer disposes of the taxpayer’s entire interest in tax-exempt use property (or former tax-exempt use property), rules similar to the rules of section 469(g) shall apply for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id439bfb6a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with section 469","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall be applied before the application of section 469.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id439e6c6b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with sections 1031 and 1033","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id439e6c6c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Sections 1031(a) and 1033(a) shall not apply if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id439e6c6d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/e/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the exchanged or converted property is tax-exempt use property subject to a lease which was entered into before ","children":[{"tag":"date","attrib":{"date":"2004-03-13"},"text":"March 13, 2004","children":[],"tail":", and which would not have met the requirements of subsection (d) had such requirements been in effect when the lease was entered into, or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id439e6c6e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/e/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the replacement property is tax-exempt use property subject to a lease which does not meet the requirements of subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id439e6c6f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjusted basis","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of property acquired by the lessor in a transaction to which section 1031 or 1033 applies, the adjusted basis of such property for purposes of this section shall be equal to the lesser of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id439e6c70-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/e/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fair market value of the property as of the beginning of the lease term, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id439e6c71-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/e/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount which would be the lessor’s adjusted basis if such sections did not apply to such transaction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id439e6c72-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id439e6c73-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Related parties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “lessor”, “lessee”, and “lender” each include any related party (within the meaning of section 197(f)(9)(C)(i)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id439e6c74-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lease term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “lease term” has the meaning given to such term by section 168(i)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id439e6c75-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lender","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “lender” means, with respect to any lease, a person that makes a loan to the lessor which is secured (or economically similar to being secured) by the lease or the leased property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id439e6c76-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “loan” includes any similar arrangement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id439e6c77-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prescribe such regulations as may be necessary or appropriate to carry out the purposes of this section, including regulations which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id439e6c78-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow in appropriate cases the aggregation of property subject to the same lease, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id439e6c79-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s470/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the determination of the allocation of interest expense for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id439e6c7a-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s848/a"},"text":"Pub. L. 108–357, title VIII, § 848(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1602"},"text":"118 Stat. 1602","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/172/s7/c"},"text":"Pub. L. 110–172, § 7(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-29"},"text":"Dec. 29, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2482"},"text":"121 Stat. 2482","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/120"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(120)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1190"},"text":"132 Stat. 1190","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id439e6c7b-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id439e6c7c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id439e6c7d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (d)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" substituted “subparagraph (A)(ii)” for “clause (ii)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/172/s7/c/1"},"text":"Pub. L. 110–172, § 7(c)(1)","children":[],"tail":", reenacted heading without change and amended text generally. Prior to amendment, text read as follows: “The term ‘tax-exempt use property’ has the meaning given to such term by section 168(h), except that such section shall be applied—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) without regard to paragraphs (1)(C) and (3) thereof, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) as if property described in—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) section 167(f)(1)(B),","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) section 167(f)(2), and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(iii) section 197 intangible,","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"were tangible property.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Such term shall not include property which would (but for this sentence) be tax-exempt use property solely by reason of section 168(h)(6) if any credit is allowable under section 42 or 47 with respect to such property.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/172/s7/c/2"},"text":"Pub. L. 110–172, § 7(c)(2)","children":[],"tail":", in introductory provisions, substituted “(at all times during the lease term)” for “(at any time during the lease term)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id439e6c7e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id439e6c7f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/172"},"text":"Pub. L. 110–172","children":[],"tail":" effective as if included in the provision of the American Jobs Creation Act of 2004, "},{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/110/172/s7/e"},"text":"section 7(e) of Pub. L. 110–172","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1092"},"text":"section 1092 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id439e6c80-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s849"},"text":"Pub. L. 108–357, title VIII, § 849","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1606"},"text":"118 Stat. 1606","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/135/tIV/s403/ff"},"text":"Pub. L. 109–135, title IV, § 403(ff)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-21"},"text":"Dec. 21, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2631"},"text":"119 Stat. 2631","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/135/tIV/s403/ff"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in this section, the amendments made by this part [part III (§§ 847–849) of subtitle B of title VIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":", enacting this section and amending sections 167, 168, and 197 of this title] shall apply to leases entered into after "},{"tag":"date","attrib":{"date":"2004-03-12"},"text":"March 12, 2004","children":[],"tail":", and in the case of property treated as tax-exempt use property other than by reason of a lease, to property acquired after "},{"tag":"date","attrib":{"date":"2004-03-12"},"text":"March 12, 2004","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this part shall not apply to qualified transportation property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualified transportation property","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), the term ‘qualified transportation property’ means domestic property subject to a lease with respect to which a formal application—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was submitted for approval to the Federal Transit Administration (an agency of the Department of Transportation) after ","children":[{"tag":"date","attrib":{"date":"2003-06-30"},"text":"June 30, 2003","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"2004-03-13"},"text":"March 13, 2004","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is approved by the Federal Transit Administration before ","children":[{"tag":"date","attrib":{"date":"2006-01-01"},"text":"January 1, 2006","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a description of such property and the value of such property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exchanges and conversion of tax-exempt use property","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Section 470(e)(4) of the Internal Revenue Code of 1986, as added by section 848, shall apply to property exchanged or converted after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"t