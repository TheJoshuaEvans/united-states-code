{"tag":"section","attrib":{"id":"id40d31812-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J"},"text":null,"children":[{"tag":"num","attrib":{"value":"45J"},"text":"§ 45J.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit for production from advanced nuclear power facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id40d31813-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of section 38, the advanced nuclear power facility production credit of any taxpayer for any taxable year is equal to the product of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40d31814-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1.8 cents, multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d31815-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the kilowatt hours of electricity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40d31816-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" produced by the taxpayer at an advanced nuclear power facility during the 8-year period beginning on the date the facility was originally placed in service, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40d31817-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sold by the taxpayer to an unrelated person during the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40d31818-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National limitation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40d31819-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of credit which would (but for this subsection and subsection (c)) be allowed with respect to any facility for any taxable year shall not exceed the amount which bears the same ratio to such amount of credit as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40d3181a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the national megawatt capacity limitation allocated to the facility, bears to","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40d3181b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total megawatt nameplate capacity of such facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d3181c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of national limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The aggregate amount of national megawatt capacity limitation allocated by the Secretary under paragraph (3) shall not exceed 6,000 megawatts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d3181d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall allocate the national megawatt capacity limitation in such manner as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d3181e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 6 months after the date of the enactment of or any amendment to this section, the Secretary shall prescribe such regulations as may be necessary or appropriate to carry out the purposes of this subsection. Such regulations shall provide a certification process under which the Secretary, after consultation with the Secretary of Energy, shall approve and allocate the national megawatt capacity limitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d3181f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of unutilized limitation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40d31820-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any unutilized national megawatt capacity limitation shall be allocated by the Secretary under paragraph (3) as rapidly as is practicable after ","children":[{"tag":"date","attrib":{"date":"2020-12-31"},"text":"December 31, 2020","children":[],"tail":"—"}],"tail":null},{"tag":"clause","attrib":{"id":"id40d31821-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/b/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" first to facilities placed in service on or before such date to the extent that such facilities did not receive an allocation equal to their full nameplate capacity, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40d31822-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/b/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" then to facilities placed in service after such date in the order in which such facilities are placed in service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40d31823-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unutilized national megawatt capacity limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “unutilized national megawatt capacity limitation” means the excess (if any) of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40d31824-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/b/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 6,000 megawatts, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40d31825-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/b/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amount of national megawatt capacity limitation allocated by the Secretary before ","children":[{"tag":"date","attrib":{"date":"2021-01-01"},"text":"January 1, 2021","children":[],"tail":", reduced by any amount of such limitation which was allocated to a facility which was not placed in service before such date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40d31826-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with other provisions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any unutilized national megawatt capacity limitation allocated by the Secretary pursuant to this paragraph—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40d31827-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/b/5/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such allocation shall be treated for purposes of this section in the same manner as an allocation of national megawatt capacity limitation, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40d31828-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/b/5/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (d)(1)(B) shall not apply to any facility which receives such allocation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40d31829-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40d3182a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of the credit allowable under subsection (a) (after the application of subsection (b)) for any taxable year with respect to any facility shall not exceed an amount which bears the same ratio to $125,000,000 as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40d3182b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the national megawatt capacity limitation allocated under subsection (b) to the facility, bears to","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40d3182c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d3182d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Phaseout of credit","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40d3182e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of the credit determined under subsection (a) shall be reduced by an amount which bears the same ratio to the amount of the credit (determined without regard to this paragraph) as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40d3182f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount by which the reference price (as defined in section 45(e)(2)(C)) for the calendar year in which the sale occurs exceeds 8 cents, bears to","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40d31830-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 cents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40d31831-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Phaseout adjustment based on inflation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The 8 cent amount in subparagraph (A) shall be adjusted by multiplying such amount by the inflation adjustment factor (as defined in section 45(e)(2)(B)) for the calendar year in which the sale occurs. If any amount as increased under the preceding sentence is not a multiple of 0.1 cent, such amount shall be rounded to the nearest multiple of 0.1 cent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40d31832-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced nuclear power facility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40d31833-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “advanced nuclear power facility” means any advanced nuclear facility—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40d31834-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is owned by the taxpayer and which uses nuclear energy to produce electricity, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40d31835-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is placed in service after the date of the enactment of this paragraph and before ","children":[{"tag":"date","attrib":{"date":"2021-01-01"},"text":"January 1, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d31836-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced nuclear facility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1), the term “advanced nuclear facility” means any nuclear facility the reactor design for which is approved after ","children":[{"tag":"date","attrib":{"date":"1993-12-31"},"text":"December 31, 1993","children":[],"tail":", by the Nuclear Regulatory Commission (and such design or a substantially similar design of comparable capacity was not approved on or before such date)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40d31837-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of credit by certain public entities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40d31838-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, with respect to a credit under subsection (a) for any taxable year—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40d31839-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a qualified public entity would be the taxpayer (but for this paragraph), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40d3183a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such entity elects the application of this paragraph for such taxable year with respect to all (or any portion specified in such election) of such credit,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the eligible project partner specified in such election, and not the qualified public entity, shall be treated as the taxpayer for purposes of this title with respect to such credit (or such portion thereof).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d3183b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40d3183c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified public entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified public entity” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40d3183d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federal, State, or local government entity, or any political subdivision, agency, or instrumentality thereof,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40d3183e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a mutual or cooperative electric company described in section 501(c)(12) or 1381(a)(2), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40d3183f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/e/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a not-for-profit electric utility which had or has received a loan or loan guarantee under the Rural Electrification Act of 1936.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40d31840-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible project partner","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible project partner” means any person who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40d31841-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is responsible for, or participates in, the design or construction of the advanced nuclear power facility to which the credit under subsection (a) relates,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40d31842-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participates in the provision of the nuclear steam supply system to such facility,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40d31843-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/e/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participates in the provision of nuclear fuel to such facility,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40d31844-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/e/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a financial institution providing financing for the construction or operation of such facility, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40d31845-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/e/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has an ownership interest in such facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d31846-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40d31847-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to partnerships","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a credit under subsection (a) which is determined at the partnership level—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40d31848-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/e/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for purposes of paragraph (1)(A), a qualified public entity shall be treated as the taxpayer with respect to such entity’s distributive share of such credit, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40d31849-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/e/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “eligible project partner” shall include any partner of the partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40d3184a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable year in which credit taken into account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any credit (or portion thereof) with respect to which an election is made under paragraph (1), such credit shall be taken into account in the first taxable year of the eligible project partner ending with, or after, the qualified public entity’s taxable year with respect to which the credit was determined.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40d3184b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of transfer under private use rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of section 141(b)(1), any benefit derived by an eligible project partner in connection with an election under this subsection shall not be taken into account as a private business use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40d3184c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45J/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other rules to apply","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rules similar to the rules of paragraphs (1), (3), (4), and (5) of section 45(e) shall apply for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id40d3184d-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXIII/s1306/a"},"text":"Pub. L. 109–58, title XIII, § 1306(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/997"},"text":"119 Stat. 997","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/135/tIV/s402/d"},"text":"Pub. L. 109–135, title IV, § 402(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-21"},"text":"Dec. 21, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2610"},"text":"119 Stat. 2610","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/172/s6/a"},"text":"Pub. L. 110–172, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-29"},"text":"Dec. 29, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2479"},"text":"121 Stat. 2479","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/123/dD/tI/s40501/a"},"text":"Pub. L. 115–123, div. D, title I, § 40501(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"2018-02-09"},"text":"Feb. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/153"},"text":"132 Stat. 153","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id40d3184e-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id40d3184f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id40d31850-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this section and the date of the enactment of this paragraph, referred to in subsecs. (b)(4) and (d)(1)(B), are the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Rural Electrification Act of 1936, referred to in subsec. (e)(2)(A)(iii), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-05-20/ch432"},"text":"act May 20, 1936, ch. 432","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1363"},"text":"49 Stat. 1363","children":[],"tail":", which is classified generally to chapter 31 (§ 901 et seq.) of Title 7, Agriculture. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s901"},"text":"section 901 of Title 7","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id40d31851-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123/s40501/a/1"},"text":"Pub. L. 115–123, § 40501(a)(1)","children":[],"tail":", inserted “or any amendment to” after “enactment of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123/s40501/a/2"},"text":"Pub. L. 115–123, § 40501(a)(2)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123/s40501/b/1"},"text":"Pub. L. 115–123, § 40501(b)(1)","children":[],"tail":", added subsec. (e) and redesignated former subsec. (e) as (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/172"},"text":"Pub. L. 110–172","children":[],"tail":" reenacted heading without change and amended text generally. Prior to amendment, text read as follows: “The national megawatt capacity limitation shall be 6,000 megawatts.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/135/s402/d/1"},"text":"Pub. L. 109–135, § 402(d)(1)","children":[],"tail":", amended heading and text of par. (2) generally. Prior to amendment, text read as follows: “Rules similar to the rules of section 45(b)(1) shall apply for purposes of this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/135/s402/d/2"},"text":"Pub. L. 109–135, § 402(d)(2)","children":[],"tail":", struck out “(2),” after “(1),”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id40d31852-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id40d31853-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123/dD/tI/s40501/c"},"text":"Pub. L. 115–123, div. D, title I, § 40501(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-09"},"text":"Feb. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/154"},"text":"132 Stat. 154","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/123/dD/tI/s40501/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of unutilized limitation amounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendment made by subsection (a) [amending this section] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2018-02-09"},"text":"Feb. 9, 2018","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer of credit by certain public entities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by subsection (b) [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501"},"text":"section 501 of this title","children":[],"tail":"] shall apply to taxable years beginning after the date of the enactment of this Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id40d31854-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/172"},"text":"Pub. L. 110–172","children":[],"tail":" effective as if included in the provisions of the Energy Policy Act of 2005, "},{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/110/172/s6/e"},"text":"section 6(e) of Pub. L. 110–172","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s30C"},"text":"section 30C of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id40d31855-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/135"},"text":"Pub. L. 109–135","children":[],"tail":" effective as if included in the provision of the Energy Policy Act of 2005, "},{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/135/s402/m/1"},"text":"section 402(m)(1) of Pub. L. 109–135","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s23"},"text":"section 23 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id40d31856-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to production in taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/s1306/d"},"text":"section 1306(d) of Pub. L. 109–58","children":[],"tail":", set out as an Effective Date of 2005 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s38"},"text":"section 38 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
