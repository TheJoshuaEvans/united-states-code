{"tag":"section","attrib":{"id":"id4375d60d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s441"},"text":null,"children":[{"tag":"num","attrib":{"value":"441"},"text":"§ 441.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period for computation of taxable income","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4375d60e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s441/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation of taxable income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Taxable income shall be computed on the basis of the taxpayer’s taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4375d60f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s441/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable year","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subtitle, the term “taxable year” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4375d610-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s441/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taxpayer’s annual accounting period, if it is a calendar year or a fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4375d611-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s441/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the calendar year, if subsection (g) applies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4375d612-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s441/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period for which the return is made, if a return is made for a period of less than 12 months; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4375d613-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s441/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a DISC filing a return for a period of at least 12 months, the period determined under subsection (h).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4375d614-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s441/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual accounting period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subtitle, the term “annual accounting period” means the annual period on the basis of which the taxpayer regularly computes his income in keeping his books.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4375d615-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s441/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Calendar year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subtitle, the term “calendar year” means a period of 12 months ending on December 31.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4375d616-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s441/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subtitle, the term “fiscal year” means a period of 12 months ending on the last day of any month other than December. In the case of any taxpayer who has made the election provided by subsection (f) the term means the annual period (varying from 52 to 53 weeks) so elected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4375d617-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s441/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election of year consisting of 52–53 weeks","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4375d618-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s441/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A taxpayer who, in keeping his books, regularly computes his income on the basis of an annual period which varies from 52 to 53 weeks and ends always on the same day of the week and ends always—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4375d619-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s441/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on whatever date such same day of the week last occurs in a calendar month, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4375d61a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s441/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on whatever date such same day of the week falls which is nearest to the last day of a calendar month,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"may (in accordance with the regulations prescribed under paragraph (3)) elect to compute his taxable income for purposes of this subtitle on the basis of such annual period. This paragraph shall apply to taxable years ending after the date of the enactment of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4375d61b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s441/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for 52–53-week year","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4375d61c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s441/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective dates","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any case in which the effective date or the applicability of any provision of this title is expressed in terms of taxable years beginning, including, or ending with reference to a specified date which is the first or last day of a month, a taxable year described in paragraph (1) shall (except for purposes of the computation under section 15) be treated—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4375d61d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s441/f/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as beginning with the first day of the calendar month beginning nearest to the first day of such taxable year, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4375d61e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s441/f/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as ending with the last day of the calendar month ending nearest to the last day of such taxable year,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"as the case may be.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4375d61f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s441/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Change in accounting period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a change from or to a taxable year described in paragraph (1)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4375d620-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s441/f/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such change results in a short period (within the meaning of section 443) of 359 days or more, or of less than 7 days, section 443(b) (relating to alternative tax computation) shall not apply;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4375d621-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s441/f/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such change results in a short period of less than 7 days, such short period shall, for purposes of this subtitle, be added to and deemed a part of the following taxable year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4375d622-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s441/f/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such change results in a short period to which subsection (b) of section 443 applies, the taxable income for such short period shall be placed on an annual basis for purposes of such subsection by multiplying the gross income for such short period (minus the deductions allowed by this chapter for the short period, but only the adjusted amount of the deductions for personal exemptions as described in section 443(c)) by 365, by dividing the result by the number of days in the short period, and the tax shall be the same part of the tax computed on the annual basis as the number of days in the short period is of 365 days.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4375d623-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s441/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for partnerships, S corporations, and personal service corporations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may by regulation provide terms and conditions for the application of this subsection to a partnership, S corporation, or personal service corporation (within the meaning of section 441(i)(2)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4375d624-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s441/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such regulations as he deems necessary for the application of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4375d625-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s441/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No books kept; no accounting period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in section 443 (relating to returns for periods of less than 12 months), the taxpayer’s taxable year shall be the calendar year if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4375d626-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s441/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taxpayer keeps no books;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4375d627-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s441/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taxpayer does not have an annual accounting period; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4375d628-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s441/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taxpayer has an annual accounting period, but such period does not qualify as a fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4375d629-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s441/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable year of DISC’s","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4375d62a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s441/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subtitle, the taxable year of any DISC shall be the taxable year of that shareholder (or group of shareholders with the same 12-month taxable year) who has the highest percentage of voting power.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4375d62b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s441/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule where more than one shareholder (or group) has highest percentage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If 2 or more shareholders (or groups) have the highest percentage of voting power under paragraph (1), the taxable year of the DISC shall be the same 12-month period as that of any such shareholder (or group).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4375d62c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s441/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent changes of ownership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe regulations under which paragraphs (1) and (2) shall apply to a change of ownership of a corporation after the taxable year of the corporation has been determined under paragraph (1) or (2) only if such change is a substantial change of ownership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4375d62d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s441/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voting power determined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, voting power shall be determined on the basis of total combined voting power of all classes of stock of the corporation entitled to vote.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4375d62e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s441/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable year of personal service corporations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4375d62f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s441/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subtitle, the taxable year of any personal service corporation shall be the calendar year unless the corporation establishes, to the satisfaction of the Secretary, a business purpose for having a different period for its taxable year. For purposes of this paragraph, any deferral of income to shareholders shall not be treated as a business purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4375d630-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s441/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personal service corporation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “personal service corporation” has the meaning given such term by section 269A(b)(1), except that section 269A(b)(2) shall be applied—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4375d631-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s441/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by substituting “any” for “more than 10 percent”, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4375d632-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s441/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by substituting “any” for “50 percent or more in value” in section 318(a)(2)(C).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"A corporation shall not be treated as a personal service corporation unless more than 10 percent of the stock (by value) in such corporation is held by employee-owners (within the meaning of section 269A(b)(2), as modified by the preceding sentence). If a corporation is a member of an affiliated group filing a consolidated return, all members of such group shall be taken into account in determining whether such corporation is a personal service corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4375d633-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/148"},"text":"68A Stat. 148","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/272/tII/s235/c/3"},"text":"Pub. L. 88–272, title II, § 235(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-02-26"},"text":"Feb. 26, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/127"},"text":"78 Stat. 127","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/30/tI/s102/b/5"},"text":"Pub. L. 95–30, title I, § 102(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-05-23"},"text":"May 23, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/137"},"text":"91 Stat. 137","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tIV/s474/b/2"},"text":"Pub. L. 98–369, div. A, title IV, § 474(b)(2)","children":[],"tail":", title VIII, § 803, "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/830"},"text":"98 Stat. 830","children":[],"tail":", 1000; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tI/s104/b/6"},"text":"Pub. L. 99–514, title I, § 104(b)(6)","children":[],"tail":", title VIII, § 806(c)(1), (d), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2105"},"text":"100 Stat. 2105","children":[],"tail":", 2364; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1008/e/4"},"text":"Pub. L. 100–647, title I, § 1008(e)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3440"},"text":"102 Stat. 3440","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/172/s11/g/7"},"text":"Pub. L. 110–172, § 11(g)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-29"},"text":"Dec. 29, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2490"},"text":"121 Stat. 2490","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4375d634-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4375d635-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4375d636-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/172/s11/g/7/A"},"text":"Pub. L. 110–172, § 11(g)(7)(A)","children":[],"tail":", struck out “FSC or” before “DISC filing”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/172/s11/g/7/B"},"text":"Pub. L. 110–172, § 11(g)(7)(B)","children":[],"tail":", struck out “FSC’s and” before “DISC’s” in heading and “FSC or” before “DISC” in pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (i)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" inserted at end “A corporation shall not be treated as a personal service corporation unless more than 10 percent of the stock (by value) in such corporation