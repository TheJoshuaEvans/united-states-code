{"tag":"section","attrib":{"id":"id45ad4fb6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4043"},"text":null,"children":[{"tag":"num","attrib":{"value":"4043"},"text":"§ 4043.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surtax on fuel used in aircraft part of a fractional ownership program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45ad4fb7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4043/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is hereby imposed a tax on any liquid used (during any calendar quarter by any person) in a fractional program aircraft as fuel—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45ad4fb8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4043/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the transportation of a qualified fractional owner with respect to the fractional ownership aircraft program of which such aircraft is a part, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45ad4fb9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4043/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the use of such aircraft on account of such a qualified fractional owner, including use in deadhead service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45ad4fba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4043/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rate of tax imposed by subsection (a) is 14.1 cents per gallon.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45ad4fbb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4043/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45ad4fbc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4043/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fractional program aircraft","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “fractional program aircraft” means, with respect to any fractional ownership aircraft program, any aircraft which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45ad4fbd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4043/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is listed as a fractional program aircraft in the management specifications issued to the manager of such program by the Federal Aviation Administration under subpart K of part 91 of title 14, Code of Federal Regulations, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45ad4fbe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4043/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is registered in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45ad4fbf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4043/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fractional ownership aircraft program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “fractional ownership aircraft program” means a program under which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45ad4fc0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4043/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a single fractional ownership program manager provides fractional ownership program management services on behalf of the fractional owners,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45ad4fc1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4043/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there are 1 or more fractional owners per fractional program aircraft, with at least 1 fractional program aircraft having more than 1 owner,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45ad4fc2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4043/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to at least 2 fractional program aircraft, none of the ownership interests in such aircraft are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45ad4fc3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4043/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" less than the minimum fractional ownership interest, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45ad4fc4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4043/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" held by the program manager referred to in subparagraph (A),","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45ad4fc5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4043/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there exists a dry-lease aircraft exchange arrangement among all of the fractional owners, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45ad4fc6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4043/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there are multi-year program agreements covering the fractional ownership, fractional ownership program management services, and dry-lease aircraft exchange aspects of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45ad4fc7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4043/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions related to fractional ownership interests","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45ad4fc8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4043/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified fractional owner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified fractional owner” means any fractional owner which has a minimum fractional ownership interest in at least one fractional program aircraft.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45ad4fc9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4043/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum fractional ownership interest","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “minimum fractional ownership interest” means, with respect to each type of aircraft—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45ad4fca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4043/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a fractional ownership interest equal to or greater than 1/16 of at least 1 subsonic, fixed wing, or powered lift aircraft, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45ad4fcb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4043/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a fractional ownership interest equal to or greater than 1/32 of at least 1 rotorcraft aircraft.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45ad4fcc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4043/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fractional ownership interest","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “fractional ownership interest” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45ad4fcd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4043/c/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ownership of an interest in a fractional program aircraft,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45ad4fce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4043/c/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the holding of a multi-year leasehold interest in a fractional program aircraft, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45ad4fcf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4043/c/3/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the holding of a multi-year leasehold interest which is convertible into an ownership interest in a fractional program aircraft.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45ad4fd0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4043/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fractional owner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “fractional owner” means any person owning any interest (including the entire interest) in a fractional program aircraft.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45ad4fd1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4043/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dry-lease aircraft exchange","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “dry-lease aircraft exchange” means an agreement, documented by the written program agreements, under which the fractional program aircraft are available, on an as needed basis without crew, to each fractional owner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45afbfd2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4043/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule relating to use of fractional program aircraft for flight demonstration, maintenance, or training","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsection (a), a fractional program aircraft shall not be considered to be used for the transportation of a qualified fractional owner, or on account of such qualified fractional owner, when it is used for flight demonstration, maintenance, or crew training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45afbfd3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4043/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule relating to deadhead service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A fractional program aircraft shall not be considered to be used on account of a qualified fractional owner when it is used in deadhead service and a person other than a qualified fractional owner is separately charged for such service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45afbfd4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4043/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to liquids used as a fuel in an aircraft after ","children":[{"tag":"date","attrib":{"date":"2028-09-30"},"text":"September 30, 2028","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45afbfd5-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/tXI/s1103/a/1"},"text":"Pub. L. 112–95, title XI, § 1103(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/149"},"text":"126 Stat. 149","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tVIII/s802/c/1"},"text":"Pub. L. 115–254, div. B, title VIII, § 802(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3429"},"text":"132 Stat. 3429","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/15/dB/tII/s2212/c/1"},"text":"Pub. L. 118–15, div. B, title II, § 2212(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-09-30"},"text":"Sept. 30, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/85"},"text":"137 Stat. 85","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/34/tII/s202/c/1"},"text":"Pub. L. 118–34, title II, § 202(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-26"},"text":"Dec. 26, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/1115"},"text":"137 Stat. 1115","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/41/tII/s202/c/1"},"text":"Pub. L. 118–41, title II, § 202(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-03-08"},"text":"Mar. 8, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/24"},"text":"138 Stat. 24","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/63/tXIII/s1302/c/1"},"text":"Pub. L. 118–63, title XIII, § 1302(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1433"},"text":"138 Stat. 1433","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45afbfd6-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45afbfd7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45afbfd8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63"},"text":"Pub. L. 118–63","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2028-09-30"},"text":"September 30, 2028","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2024-05-10"},"text":"May 10, 2024","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/41"},"text":"Pub. L. 118–41","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2024-05-10"},"text":"May 10, 2024","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2024-03-08"},"text":"March 8, 2024","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2023—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/34"},"text":"Pub. L. 118–34","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2024-03-08"},"text":"March 8, 2024","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2023-12-31"},"text":"December 31, 2023","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/15"},"text":"Pub. L. 118–15","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2023-12-31"},"text":"December 31, 2023","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2023-09-30"},"text":"September 30, 2023","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2023-09-30"},"text":"September 30, 2023","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2021-09-30"},"text":"September 30, 2021","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45afbfd9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id45afbfda-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/tXI/s1103/d/1"},"text":"Pub. L. 112–95, title XI, § 1103(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/151"},"text":"126 Stat. 151","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/95/tXI/s1103/d/1"},"text":"“The amendments made by subsection (a) [enacting this section and amending sections 4082 and 9502 of this title] shall apply to fuel used after ","children":[{"tag":"date","attrib":{"date":"2012-03-31"},"text":"March 31, 2012","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
