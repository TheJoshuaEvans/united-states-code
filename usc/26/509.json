{"tag":"section","attrib":{"id":"id43b17f4d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509"},"text":null,"children":[{"tag":"num","attrib":{"value":"509"},"text":"§ 509.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private foundation defined","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id43b17f4e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this title, the term “private foundation” means a domestic or foreign organization described in section 501(c)(3) other than—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43b17f4f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an organization described in section 170(b)(1)(A) (other than in clauses (vii) and (viii));","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43b17f50-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an organization which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43b17f51-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" normally receives more than one-third of its support in each taxable year from any combination of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id43b17f52-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gifts, grants, contributions, or membership fees, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43b17f53-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gross receipts from admissions, sales of merchandise, performance of services, or furnishing of facilities, in an activity which is not an unrelated trade or business (within the meaning of section 513), not including such receipts from any person, or from any bureau or similar agency of a governmental unit (as described in section 170(c)(1)), in any taxable year to the extent such receipts exceed the greater of $5,000 or 1 percent of the organization’s support in such taxable year,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"from persons other than disqualified persons (as defined in section 4946) with respect to the organization, from governmental units described in section 170(c)(1), or from organizations described in section 170(b)(1)(A) (other than in clauses (vii) and (viii)), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43b17f54-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" normally receives not more than one-third of its support in each taxable year from the sum of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id43b17f55-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gross investment income (as defined in subsection (e)) and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43b17f56-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the excess (if any) of the amount of the unrelated business taxable income (as defined in section 512) over the amount of the tax imposed by section 511;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43b17f57-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an organization which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43b17f58-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is organized, and at all times thereafter is operated, exclusively for the benefit of, to perform the functions of, or to carry out the purposes of one or more specified organizations described in paragraph (1) or (2),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43b17f59-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id43b17f5a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operated, supervised, or controlled by one or more organizations described in paragraph (1) or (2),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43b17f5b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supervised or controlled in connection with one or more such organizations, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43b17f5c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operated in connection with one or more such organizations, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43b17f5d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not controlled directly or indirectly by one or more disqualified persons (as defined in section 4946) other than foundation managers and other than one or more organizations described in paragraph (1) or (2); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43b17f5e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an organization which is organized and operated exclusively for testing for public safety.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of paragraph (3), an organization described in paragraph (2) shall be deemed to include an organization described in section 501(c)(4), (5), or (6) which would be described in paragraph (2) if it were an organization described in section 501(c)(3).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43b17f5f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation of private foundation status","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this title, if an organization is a private foundation (within the meaning of subsection (a)) on ","children":[{"tag":"date","attrib":{"date":"1969-10-09"},"text":"October 9, 1969","children":[],"tail":", or becomes a private foundation on any subsequent date, such organization shall be treated as a private foundation for all periods after "},{"tag":"date","attrib":{"date":"1969-10-09"},"text":"October 9, 1969","children":[],"tail":", or after such subsequent date, unless its status as such is terminated under section 507."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43b17f60-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status of organization after termination of private foundation status","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this part, an organization the status of which as a private foundation is terminated under section 507 shall (except as provided in section 507(b)(2)) be treated as an organization created on the day after the date of such termination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43b17f61-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of support","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this part and chapter 42, the term “support” includes (but is not limited to)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43b17f62-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gifts, grants, contributions, or membership fees,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43b17f63-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gross receipts from admissions, sales of merchandise, performance of services, or furnishing of facilities in any activity which is not an unrelated trade or business (within the meaning of section 513),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43b17f64-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" net income from unrelated business activities, whether or not such activities are carried on regularly as a trade or business,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43b17f65-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gross investment income (as defined in subsection (e)),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43b17f66-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tax revenues levied for the benefit of an organization and either paid to or expended on behalf of such organization, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43b17f67-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value of services or facilities (exclusive of services or facilities generally furnished to the public without charge) furnished by a governmental unit referred to in section 170(c)(1) to an organization without charge.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such term does not include any gain from the sale or other disposition of property which would be considered as gain from the sale or exchange of a capital asset, or the value of exemption from any Federal, State, or local tax or any similar benefit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43b17f68-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of gross investment income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsection (d), the term “gross investment income” means the gross amount of income from interest, dividends, payments with respect to securities loans (as defined in section 512(a)(5)), rents, and royalties, but not including any such income to the extent included in computing the tax imposed by section 511. Such term shall also include income from sources similar to those in the preceding sentence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43b17f69-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for supporting organizations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43b17f6a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Type III supporting organizations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a)(3)(B)(iii), an organization shall not be considered to be operated in connection with any organization described in paragraph (1) or (2) of subsection (a) unless such organization meets the following requirements:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43b17f6b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsiveness","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each taxable year beginning after the date of the enactment of this subsection, the organization provides to each supported organization such information as the Secretary may require to ensure that such organization is responsive to the needs or demands of the supported organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43b17f6c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign supported organizations","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id43b17f6d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/f/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The organization is not operated in connection with any supported organization that is not organized in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43b17f6e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/f/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transition rule for existing organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the organization is operated in connection with an organization that is not organized in the United States on the date of the enactment of this subsection, clause (i) shall not apply until the first day of the third taxable year of the organization beginning after the date of the enactment of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43b17f6f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organizations controlled by donors","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43b17f70-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a)(3)(B), an organization shall not be considered to be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id43b17f71-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/f/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operated, supervised, or controlled by any organization described in paragraph (1) or (2) of subsection (a), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43b17f72-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/f/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operated in connection with any organization described in paragraph (1) or (2) of subsection (a),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"if such organization accepts any gift or contribution from any person described in subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43b17f73-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person is described in this subparagraph if, with respect to a supported organization of an organization described in subparagraph (A), such person is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id43b17f74-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/f/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person (other than an organization described in paragraph (1), (2), or (4) of section 509(a)) who directly or indirectly controls, either alone or together with persons described in clauses (ii) and (iii), the governing body of such supported organization,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43b17f75-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/f/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the family (determined under section 4958(f)(4)) of an individual described in clause (i), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43b17f76-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/f/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a 35-percent controlled entity (as defined in section 4958(f)(3) by substituting “persons described in clause (i) or (ii) of section 509(f)(2)(B)” for “persons described in subparagraph (A) or (B) of paragraph (1)” in subparagraph (A)(i) thereof).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43b17f77-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supported organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “supported organization” means, with respect to an organization described in subsection (a)(3), an organization described in paragraph (1) or (2) of subsection (a)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43b17f78-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for whose benefit the organization described in subsection (a)(3) is organized and operated, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43b17f79-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s509/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to which the organization performs the functions of, or carries out the purposes of.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id43b17f7a-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172/tI/s101/a"},"text":"Pub. L. 91–172, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/496"},"text":"83 Stat. 496","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/81/s3/a"},"text":"Pub. L. 94–81, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-08-09"},"text":"Aug. 9, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/418"},"text":"89 Stat. 418","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/345/s2/a/1"},"text":"Pub. L. 95–345, § 2(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-08-15"},"text":"Aug. 15, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/481"},"text":"92 Stat. 481","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/280/tXII"},"text":"Pub. L. 109–280, title XII","children":[],"tail":", §§ 1221(a)(2), 1241(a), (b), "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1089"},"text":"120 Stat. 1089","children":[],"tail":", 1102.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id43b17f7b-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id43b17f7c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id43b17f7d-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this subsection, referred to in subsec. (f)(1)(A), (B)(ii), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280"},"text":"Pub. L. 109–280","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id43b17f7e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Sections 1221(a)(2) and 1241(a), (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280"},"text":"Pub. L. 109–280","children":[],"tail":", which directed the amendment of section 509 without specifying the act to be amended, were executed to this section, which is section 509 of the Internal Revenue Code of 1986, to reflect the probable intent of Congress. See 2006 Amendment notes below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id43b17f7f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/s1241/a"},"text":"Pub. L. 109–280, § 1241(a)","children":[],"tail":", amended subpar. (B) generally. Prior to amendment, subpar. (B) read as follows: “is operated, supervised, or controlled by or in connection with one or more organizations described in paragraph (1) or (2), and”. See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/s1221/a/2"},"text":"Pub. L. 109–280, § 1221(a)(2)","children":[],"tail":", inserted at end “Such term shall also include income from sources similar to those in the preceding sentence.” See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/s1241/b"},"text":"Pub. L. 109–280, § 1241(b)","children":[],"tail":", added subsec. (f). See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/345"},"text":"Pub. L. 95–345","children":[],"tail":" inserted provision relating to payments with respect to securities loans."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/81"},"text":"Pub. L. 94–81","children":[],"tail":" designated existing provisions as cl. (i) and added cl. (ii)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id43b17f80-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43b17f81-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/tXII/s1221/c"},"text":"Pub. L. 109–280, title XII, § 1221(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1089"},"text":"120 Stat. 1089","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/280/tXII/s1221/c"},"text":"“The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s4940"},"text":"section 4940 of this title","children":[],"tail":"] shall apply to taxable years beginning after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/tXII/s1241/e"},"text":"Pub. L. 109–280, title XII, § 1241(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1103"},"text":"120 Stat. 1103","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/280/tXII/s1241/e"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by subsections (a) and (b) [amending this section] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Charitable trusts which are type iii supporting organizations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (c) [enacting provisions set out as a note below] shall take effect—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of trusts operated in connection with an organization described in paragraph (1) or (2) of section 509(a) of the Internal Revenue Code of 1986 on the date of the enactment of this Act, on the date that is one year after the date of the enactment of this Act, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any other trust, on the date of the enactment of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43b17f82-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/345/s2/e"},"text":"Pub. L. 95–345, § 2(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-08-15"},"text":"Aug. 15, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/483"},"text":"92 Stat. 483","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The amendments made by this section [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1058"},"text":"section 1058 of this title","children":[],"tail":" and amending sections 509, 512, 514, 851, and 4940 of this title] apply with respect to—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts received after ","children":[{"tag":"date","attrib":{"date":"1976-12-31"},"text":"December 31, 1976","children":[],"tail":", as payments with respect to securities loans (as defined in section 512(a)(5) of the Internal Revenue Code of 1986 [formerly I.R.C. 1954]), and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfers of securities, under agreements described in section 1058 of such Code, occurring after such date.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43b3c973-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1975 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/81/s3/b"},"text":"Pub. L. 94–81, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-08-09"},"text":"Aug. 9, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/418"},"text":"89 Stat. 418","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/81/s3/b"},"text":"“The amendment made by this section [amending this section] shall apply to unrelated business taxable income derived from trades and businesses which are acquired by the organization after ","children":[{"tag":"date","attrib":{"date":"1975-06-30"},"text":"June 30, 1975","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id43b3c974-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/s101/k/1"},"text":"section 101(k)(1) of Pub. L. 91–172","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4940"},"text":"section 4940 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"id43b3c975-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Applicability of subsec. (a) of this section to testamentary trusts, see section 101(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(7) of "},{"tag":"ref","attrib":{"href":"/us/pl/91/172"},"text":"Pub. L. 91–172","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4940"},"text":"section 4940 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id43b3c976-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Charitable Trusts Which Are Type III Supporting Organizations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/tXII/s1241/c"},"text":"Pub. L. 109–280, title XII, § 1241(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1103"},"text":"120 Stat. 1103","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/280/tXII/s1241/c"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“For purposes of section 509(a)(3)(B)(iii) of the Internal Revenue Code of 1986, an organization which is a trust shall not be considered to be operated in connection with any organization described in paragraph (1) or (2) of section 509(a) of such Code solely because—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is a charitable trust under State law,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the supported organization (as defined in section 509(f)(3) of such Code) is a beneficiary of such trust, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the supported organization (as so defined) has the power to enforce the trust and compel an accounting.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id43b3c977-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Payout Requirements for Type III Supporting Organizations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/tXII/s1241/d"},"text":"Pub. L. 109–280, title XII, § 1241(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1103"},"text":"120 Stat. 1103","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/280/tXII/s1241/d"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Treasury shall promulgate new regulations under section 509 of the Internal Revenue Code of 1986 on payments required by type III supporting organizations which are not functionally integrated type III supporting organizations. Such regulations shall require such organizations to make distributions of a percentage of either income or assets to supported organizations (as defined in section 509(f)(3) of such Code) in order to ensure that a significant amount is paid to such organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Type iii supporting organization; functionally integrated type iii supporting organization","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of paragraph (1), the terms ‘type III supporting organization’ and ‘functionally integrated type III supporting organization’ have the meanings given such terms under subparagraphs (A) and (B) section 4943(f)(5) of the Internal Revenue Code of 1986 (as added by this Act), respectively.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
