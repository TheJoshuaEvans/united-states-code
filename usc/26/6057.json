{"tag":"section","attrib":{"id":"id46867213-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6057"},"text":null,"children":[{"tag":"num","attrib":{"value":"6057"},"text":"§ 6057.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual registration, etc.","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46867214-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6057/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual registration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46867215-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6057/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within such period after the end of a plan year as the Secretary may by regulations prescribe, the plan administrator (within the meaning of section 414(g)) of each plan to which the vesting standards of section 203 of part 2 of subtitle B of title I of the Employee Retirement Income Security Act of 1974 applies for such plan year shall file a registration statement with the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46867216-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6057/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The registration statement required by paragraph (1) shall set forth—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46867217-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6057/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the plan,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46867218-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6057/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name and address of the plan administrator,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46867219-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6057/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the name and taxpayer identifying number of each participant in the plan—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4686721a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6057/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who, during such plan year, separated from the service covered by the plan,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4686721b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6057/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is entitled to a deferred vested benefit under the plan as of the end of such plan year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4686721c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6057/a/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to whom retirement benefits were not paid under the plan during such plan year,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4686721d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6057/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature, amount, and form of the deferred vested benefit to which such participant is entitled, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4686721e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6057/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"At the time he files the registration statement under this subsection, the plan administrator shall furnish evidence satisfactory to the Secretary that he has complied with the requirement contained in subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4686721f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6057/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of change in status","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any plan administrator required to register under subsection (a) shall also notify the Secretary, at such time as may be prescribed by regulations, of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46867220-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6057/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any change in the name of the plan,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46867221-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6057/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any change in the name or address of the plan administrator,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46867222-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6057/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the termination of the plan, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46867223-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6057/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the merger or consolidation of the plan with any other plan or its division into two or more plans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46867224-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6057/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent provided in regulations prescribed by the Secretary, the Secretary may receive from—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46867225-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6057/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any plan to which subsection (a) applies, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46867226-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6057/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other plan (including any governmental plan or church plan (within the meaning of section 414)),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"such information (including information relating to plan years beginning before ","children":[{"tag":"date","attrib":{"date":"1974-01-01"},"text":"January 1, 1974","children":[],"tail":") as the plan administrator may wish to file with respect to the deferred vested benefit rights of any participant separated from the service covered by the plan during any plan year."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46867227-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6057/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmission of information to Commissioner of Social Security","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall transmit copies of any statements, notifications, reports, or other information obtained by him under this section to the Commissioner of Social Security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46867228-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6057/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individual statement to participant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each plan administrator required to file a registration statement under subsection (a) shall, before the expiration of the time prescribed for the filing of such registration statement, also furnish to each participant described in subsection (a)(2)(C) an individual statement setting forth the information with respect to such participant required to be contained in such registration statement. Such statement shall also include a notice to the participant of any benefits which are forfeitable if the participant dies before a certain date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46867229-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6057/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4686722a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6057/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, after consultation with the Commissioner of Social Security, may prescribe such regulations as may be necessary to carry out the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4686722b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6057/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plans to which more than one employer contributes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply to any plan to which more than one employer is required to contribute only to the extent provided in regulations prescribed under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4688bb1c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6057/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 403(b) multiple employer plans treated as one plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of annuity contracts to which this section applies and to which section 403(b) applies by reason of the plan under which such contracts are purchased meeting the requirements of paragraph (15) thereof, such plan shall be treated as a single plan for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4688bb1d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6057/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross references","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For provisions relating to penalties for failure to register or furnish statements required by this section, see section 6652(d) and section 6690.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For coordination between Department of the Treasury and the Department of Labor with regard to administration of this section, see section 3004 of the Employee Retirement Income Security Act of 1974.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4688bb1e-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tII/s1031/a"},"text":"Pub. L. 93–406, title II, § 1031(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/943"},"text":"88 Stat. 943","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dB"},"text":"Pub. L. 98–369, div. B","children":[],"tail":". title VI, § 2663(j)(5)(D), "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1171"},"text":"98 Stat. 1171","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/397/tII/s206"},"text":"Pub. L. 98–397, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-08-23"},"text":"Aug. 23, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1449"},"text":"98 Stat. 1449","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXV/s1501/d/1/F"},"text":"Pub. L. 99–514, title XV, § 1501(d)(1)(F)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2740"},"text":"100 Stat. 2740","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/296/tI/s108/h/5"},"text":"Pub. L. 103–296, title I, § 108(h)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-15"},"text":"Aug. 15, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1487"},"text":"108 Stat. 1487","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dT/tI/s106/b"},"text":"Pub. L. 117–328, div. T, title I, § 106(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5287"},"text":"136 Stat. 5287","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4688bb1f-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4688bb20-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4688bb21-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 203 of part 2 of subtitle B of title I of the Employee Retirement Income Security Act of 1974, referred to in subsec. (a)(1), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1053"},"text":"section 1053 of Title 29","children":[],"tail":", Labor. Section 3004 of such Act, referred to in subsec. (g), is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1204"},"text":"section 1204 of Title 29","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4688bb22-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsecs. (g), (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" added subsec. (g) and redesignated former subsec. (g) as (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsecs. (d), (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/296"},"text":"Pub. L. 103–296","children":[],"tail":" substituted “Commissioner of Social Security” for “Secretary of Health and Human Services” in heading and text of subsec. (d) and in text of subsec. (f)(1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “section 6652(d)” for “section 6652(e)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" substituted “Secretary of Health and Human Services” for “Secretary of Health, Education, and Welfare”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/397"},"text":"Pub. L. 98–397","children":[],"tail":" inserted provision that such statement shall also include a notice to the participant of any benefits which are forfeitable if the participant dies before a certain date."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" substituted “Secretary of Health and Human Services” for “Secretary of Health, Education, and Welfare”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4688bb23-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4688bb24-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" applicable to plan years beginning after "},{"tag":"date","attrib":{"date":"2022-