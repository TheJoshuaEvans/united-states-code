{"tag":"section","attrib":{"id":"id464ac85b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5706"},"text":null,"children":[{"tag":"num","attrib":{"value":"5706"},"text":"§ 5706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drawback of tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There shall be an allowance of drawback of tax paid on tobacco products and cigarette papers and tubes, when shipped from the United States, in accordance with such regulations and upon the filing of such bond as the Secretary shall prescribe.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id464ac85c-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/709"},"text":"68A Stat. 709","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s202"},"text":"Pub. L. 85–859, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1419"},"text":"72 Stat. 1419","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id464ac85d-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id464ac85e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Edit