{"tag":"section","attrib":{"id":"id41810ae3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139H"},"text":null,"children":[{"tag":"num","attrib":{"value":"139H"},"text":"§ 139H.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest received in action to recover property seized by the Internal Revenue Service based on structuring transaction","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Gross income shall not include any interest received from the Federal Government in connection with an action to recover property seized by the Internal Revenue Service pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s5317/c/2"},"text":"section 5317(c)(2) of title 31","children":[],"tail":", United States Code, by reason of a claimed violation of section 5324 of such title."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id41810ae4-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/25/tI/s1202/a"},"text":"Pub. L. 116–25, title I, § 1202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-07-01"},"text":"July 1, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/987"},"text":"133 Stat. 987","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id41810ae5-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id41810ae6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id41810ae7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/25/tI/s1202/c"},"text":"Pub. L. 116–25, title I, § 1202(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-07-01"},"text":"July 1, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/988"},"text":"133 Stat. 988","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/25/tI/s1202/c"},"text":"“The amendments made by this section [enacting this section] shall apply to interest received on or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2019-07-01"},"text":"July 1, 2019","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
