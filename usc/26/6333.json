{"tag":"section","attrib":{"id":"id46d04b54-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6333"},"text":null,"children":[{"tag":"num","attrib":{"value":"6333"},"text":"§ 6333.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Production of books","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If a levy has been made or is about to be made on any property, or right to property, any person having custody or control of any books or records, containing evidence or statements relating to the property or right to property subject to levy, shall, upon demand of the Secretary, exhibit such books or records to the Secretary.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id46d04b55-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/784"},"text":"68A Stat. 784","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46d04b56-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46d04b57-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46d04b58-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
