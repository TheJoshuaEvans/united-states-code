{"tag":"section","attrib":{"id":"id417c4f91-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s134"},"text":null,"children":[{"tag":"num","attrib":{"value":"134"},"text":"§ 134.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain military benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id417c4f92-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s134/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Gross income shall not include any qualified military benefit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id417c4f93-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s134/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified military benefit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id417c4f94-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s134/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified military benefit” means any allowance or in-kind benefit (other than personal use of a vehicle) which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id417c4f95-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s134/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is received by any member or former member of the uniformed services of the United States or any dependent of such member by reason of such member’s status or service as a member of such uniformed services, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id417c4f96-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s134/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was excludable from gross income on ","children":[{"tag":"date","attrib":{"date":"1986-09-09"},"text":"September 9, 1986","children":[],"tail":", under any provision of law, regulation, or administrative practice which was in effect on such date (other than a provision of this title)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id417c4f97-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s134/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No other benefit to be excludable except as provided by this title","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, no benefit shall be treated as a qualified military benefit unless such benefit—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id417c4f98-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s134/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a benefit described in paragraph (1), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id417c4f99-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s134/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is excludable from gross income under this title without regard to any provision of law which is not contained in this title and which is not contained in a revenue Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id417c4f9a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s134/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on modifications","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id417c4f9b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s134/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraphs (B) and (C) and paragraphs (4) and (5), no modification or adjustment of any qualified military benefit after ","children":[{"tag":"date","attrib":{"date":"1986-09-09"},"text":"September 9, 1986","children":[],"tail":", shall be taken into account."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id417c4f9c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s134/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for certain adjustments to cash benefits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subparagraph (A) shall not apply to any adjustment to any qualified military benefit payable in cash which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id417c4f9d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s134/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is pursuant to a provision of law or regulation (as in effect on ","children":[{"tag":"date","attrib":{"date":"1986-09-09"},"text":"September 9, 1986","children":[],"tail":"), and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id417c4f9e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s134/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is determined by reference to any fluctuation in cost, price, currency, or other similar index.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id417c4f9f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s134/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for death gratuity adjustments made by law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subparagraph (A) shall not apply to any adjustment to the amount of death gratuity payable under chapter 75 of title 10, United States Code, which is pursuant to a provision of law enacted after ","children":[{"tag":"date","attrib":{"date":"1986-09-09"},"text":"September 9, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id417c4fa0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s134/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clarification of certain benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1), such term includes any dependent care assistance program (as in effect on the date of the enactment of this paragraph) for any individual described in paragraph (1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id417c4fa1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s134/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel benefits under operation hero miles","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified military benefit” includes a travel benefit provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2613"},"text":"section 2613 of title 10","children":[],"tail":", United States Code (as in effect on the date of the enactment of this paragraph)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id417c4fa2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s134/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain State payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified military benefit” includes any bonus payment by a State or political subdivision thereof to any member or former member of the uniformed services of the United States or any dependent of such member only by reason of such member’s service in a combat zone (as defined in section 112(c)(2), determined without regard to the parenthetical).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id417c4fa3-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXI/s1168/a"},"text":"Pub. L. 99–514, title XI, § 1168(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2512"},"text":"100 Stat. 2512","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1011B/f/1"},"text":"Pub. L. 100–647, title I, § 1011B(f)(1)","children":[],"tail":", (2)(A), (3), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3489"},"text":"102 Stat. 3489","children":[],"tail":", 3490; "},{"tag":"ref","attrib":{"href":"/us/pl/108/121/tI"},"text":"Pub. L. 108–121, title I","children":[],"tail":", §§ 102(b)(1), (2), 106(a), (b)(1), "},{"tag":"date","attrib":{"date":"2003-11-11"},"text":"Nov. 11, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1337-1339"},"text":"117 Stat. 1337–1339","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tV/s585/b/1"},"text":"Pub. L. 108–375, div. A, title V, § 585(b)(1)","children":[],"tail":", (2)(A), "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1931"},"text":"118 Stat. 1931","children":[],"tail":", 1932; "},{"tag":"ref","attrib":{"href":"/us/pl/110/245/tI/s112/a"},"text":"Pub. L. 110–245, title I, § 112(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-17"},"text":"June 17, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1635"},"text":"122 Stat. 1635","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/39"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(39)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1186"},"text":"132 Stat. 1186","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id417c4fa4-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id417c4fa5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id417c4fa6-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this paragraph, referred to in subsec. (b)(4), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/121"},"text":"Pub. L. 108–121","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2003-11-11"},"text":"Nov. 11, 2003","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of the enactment of this paragraph, referred to in subsec. (b)(5), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id417c4fa7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 134 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s140"},"text":"section 140 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id417c4fa8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" substituted “a combat” for “an combat”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/245"},"text":"Pub. L. 110–245","children":[],"tail":" added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (b)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s585/b/2/A"},"text":"Pub. L. 108–375, § 585(b)(2)(A)","children":[],"tail":", substituted “paragraphs (4) and (5)” for “paragraph (4)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s585/b/1"},"text":"Pub. L. 108–375, § 585(b)(1)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (b)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/121/s106/b/1"},"text":"Pub. L. 108–121, § 106(b)(1)","children":[],"tail":", inserted “and paragraph (4)” after “subparagraphs (B) and (C)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/121/s102/b/2"},"text":"Pub. L. 108–121, § 102(b)(2)","children":[],"tail":", substituted “subparagraphs (B) and (C)” for “subparagraph (B)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/121/s102/b/1"},"text":"Pub. L. 108–121, § 102(b)(1)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/121/s106/a"},"text":"Pub. L. 108–121, § 106(a)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1011B/f/2/A"},"text":"Pub. L. 100–647, § 1011B(f)(2)(A)","children":[],"tail":", inserted “(other than personal use of a vehicle)” after “in-kind benefit” in introductory text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1011B/f/1"},"text":"Pub. L. 100–647, § 1011B(f)(1)","children":[],"tail":", substituted “, regulation, or administrative practice” for “or regulation thereunder”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1011B/f/3"},"text":"Pub. L. 100–647, § 1011B(f)(3)","children":[],"tail":", struck out “under any provision of law or regulation described in paragraph (1)” after “"},{"tag":"date","attrib":{"date":"1986-09-09"},"text":"September 9, 1986","children":[],"tail":",”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id417c4fa9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id417c4faa-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/245/tI/s112/b"},"text":"Pub. L. 110–245, title I, § 112(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-17"},"text":"June 17, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1635"},"text":"122 Stat. 1635","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/245/tI/s112/b"},"text":"“The amendment made by this section [amending this section] shall apply to payments made before, on, or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2008-06-17"},"text":"June 17, 2008","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id417c4fab-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"