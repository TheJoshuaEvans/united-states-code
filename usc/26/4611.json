000,000,000.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s11231/a/1/B"},"text":"Pub. L. 101–508, § 11231(a)(1)(B)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"January 1, 1996","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1992-01-01"},"text":"January 1, 1992","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s11231/a/2"},"text":"Pub. L. 101–508, § 11231(a)(2)","children":[],"tail":", substituted “1993” for “1989” and “1994” for “1990” in introductory provisions and “1994” for “1990” and “1995” for “1991” in subpar. (B) and concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s11231/b"},"text":"Pub. L. 101–508, § 11231(b)","children":[],"tail":", substituted “$11,970,000,000” for “$6,650,000,000” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s11231/b"},"text":"Pub. L. 101–508, § 11231(b)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"1995-12-31"},"text":"December 31, 1995","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1991-12-31"},"text":"December 31, 1991","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s11231/a/1/B"},"text":"Pub. L. 101–508, § 11231(a)(1)(B)","children":[],"tail":", (b), substituted “"},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"January 1, 1996","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1992-01-01"},"text":"January 1, 1992","children":[],"tail":"” in heading and text and “$11,970,000,000” for “$6,650,000,000” in heading and twice in text."}],"tai