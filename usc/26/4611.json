{"tag":"section","attrib":{"id":"id45dd11d7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4611"},"text":null,"children":[{"tag":"num","attrib":{"value":"4611"},"text":"§ 4611.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of tax","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45dd11d8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4611/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General Rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is hereby imposed a tax at the rate specified in subsection (c) on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45dd11d9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4611/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" crude oil received at a United States refinery, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45dd11da-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4611/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" petroleum products entered into the United States for consumption, use, or warehousing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45dd11db-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4611/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax on certain uses and exportation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45dd11dc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4611/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45dd11dd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4611/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any domestic crude oil is used in or exported from the United States, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45dd11de-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4611/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before such use or exportation, no tax was imposed on such crude oil under subsection (a),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then a tax at the rate specified in subsection (c) is hereby imposed on such crude oil.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45dd11df-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4611/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for use on premises where produced","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply to any use of crude oil for extracting oil or natural gas on the premises where such crude oil was produced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45dd11e0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4611/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rate of tax","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45dd11e1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4611/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The rate of the taxes imposed by this section is the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45dd11e2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4611/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Hazardous Substance Superfund financing rate, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45dd11e3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4611/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Oil Spill Liability Trust Fund financing rate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45dd11e4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4611/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rates","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45dd11e5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4611/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Hazardous Substance Superfund financing rate is 16.4 cents a barrel, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45dd11e6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4611/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Oil Spill Liability Trust Fund financing rate is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45dd11e7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4611/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of crude oil received or petroleum products entered before ","children":[{"tag":"date","attrib":{"date":"2017-01-01"},"text":"January 1, 2017","children":[],"tail":", 8 cents a barrel, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45dd11e8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4611/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of crude oil received or petroleum products entered after ","children":[{"tag":"date","attrib":{"date":"2016-12-31"},"text":"December 31, 2016","children":[],"tail":", 9 cents a barrel."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45dd11e9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4611/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment for inflation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45dd11ea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4611/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a year beginning after 2023, the amount in paragraph (2)(A) shall be increased by an amount equal to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45dd11eb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4611/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such amount, multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45dd11ec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4611/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost-of-living adjustment determined under section 1(f)(3) for the calendar year, determined by substituting “calendar year 2022” for “calendar year 2016” in subparagraph (A)(ii) thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45dd11ed-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4611/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rounding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any amount as adjusted under subparagraph (A) is not a multiple of $0.01, such amount shall be rounded to the next lowest multiple of $0.01.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45dd11ee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4611/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons liable for tax","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45dd11ef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4611/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crude oil received at refinery","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tax imposed by subsection (a)(1) shall be paid by the operator of the United States refinery.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45dd11f0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4611/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imported petroleum product","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tax imposed by subsection (a)(2) shall be paid by the person entering the product for consumption, use, or warehousing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45dd11f1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4611/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax on certain uses or exports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tax imposed by subsection (b) shall be paid by the person using or exporting the crude oil, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45dd11f2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4611/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"[(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169/tI/s13601/a/1"},"text":"Pub. L. 117–169, title I, § 13601(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1981"},"text":"136 Stat. 1981","children":[],"tail":"]"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45dd11f3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4611/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of Oil Spill Liability Trust Fund financing rate","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45dd11f4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4611/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), the Oil Spill Liability Trust Fund financing rate under subsection (c) shall apply on and after ","children":[{"tag":"date","attrib":{"date":"2006-04-01"},"text":"April 1, 2006","children":[],"tail":", or if later, the date which is 30 days after the last day of any calendar quarter for which the Secretary estimates that, as of the close of that quarter, the unobligated balance in the Oil Spill Liability Trust Fund is less than $2,000,000,000."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45dd11f5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4611/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Oil Spill Liability Trust Fund financing rate shall not apply after ","children":[{"tag":"date","attrib":{"date":"2025-12-31"},"text":"December 31, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attr