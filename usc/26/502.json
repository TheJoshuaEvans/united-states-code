{"tag":"section","attrib":{"id":"id43acc489-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s502"},"text":null,"children":[{"tag":"num","attrib":{"value":"502"},"text":"§ 502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Feeder organizations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id43acc48a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An organization operated for the primary purpose of carrying on a trade or business for profit shall not be exempt from taxation under section 501 on the ground that all of its profits are payable to one or more organizations exempt from taxation under section 501.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43acc48b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “trade or business” shall not include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43acc48c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s502/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deriving of rents which would be excluded under section 512(b)(3), if section 512 applied to the organization,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43acc48d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s502/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any trade or business in which substantially all the work in carrying on such trade or business is performed for the organization without compensation, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43acc48e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s502/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any trade or business which is the selling of merchandise, substantially all of which has been received by the organization as gifts or contributions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id43acc48f-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/166"},"text":"68A Stat. 166","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/tI/s121/b/7"},"text":"Pub. L. 91–172, title I, § 121(b)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/542"},"text":"83 Stat. 542","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id43acc490-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id43acc491-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id43acc492-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1969—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172"},"text":"Pub. L. 91–172","children":[],"tail":" redesignated first sentence of existing provisions as subsec. (a), and substantial portion of second sentence as subsec. (b)(1), and, in subsec. (b)(1) as so redesignated, inserted reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s512"},"text":"section 512 of this title","children":[],"tail":", and added pars. (2) and (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id43acc493-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43acc494-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1969 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172"},"text":"Pub. L. 91–172","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"1969-12-31"},"text":"Dec. 31, 1969","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/s121/g"},"text":"section 121(g) of Pub. L. 91–172","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s511"},"text":"section 511 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
