{"tag":"section","attrib":{"id":"id45d12b46-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4291"},"text":null,"children":[{"tag":"num","attrib":{"value":"4291"},"text":"§ 4291.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cases where persons receiving payment must collect tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in section 4263(a), every person receiving any payment for facilities or services on which a tax is imposed upon the payor thereof under this chapter shall collect the amount of the tax from the person making such payment.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id45d37537-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/511"},"text":"68A Stat. 511","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1956-07-25/ch725/s4/c"},"text":"July 25, 1956, ch. 725, § 4(c)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/646"},"text":"70 Stat. 646","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/tI/s131/g"},"text":"Pub. L. 85–859, title I, § 131(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1287"},"text":"72 Stat. 1287","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/44/tIII/s305/a"},"text":"Pub. L. 89–44, title III, § 305(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-06-21"},"text":"June 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/148"},"text":"79 Stat. 148","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/258/tII/s205/c/3"},"text":"Pub. L. 91–258, title II, § 