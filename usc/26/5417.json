{"tag":"section","attrib":{"id":"id463c707e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5417"},"text":null,"children":[{"tag":"num","attrib":{"value":"5417"},"text":"§ 5417.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot brewing plants","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Under such regulations as the Secretary may prescribe, and on the filing of such bonds and applications as he may require, pilot brewing plants may, at the discretion of the Secretary be established and operated off the brewery premises for research, analytical, experimental, or development purposes with regard to beer or brewery operations. Nothing in this section shall be construed as authority to waive the filing of any bond or the payment of any tax provided for in this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id463c707f-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/673/s4/a"},"text":"Pub. L. 91–673, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-12"},"text":"Jan. 12, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/2057"},"text":"84 Stat. 2057","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id463c7080-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id463c7081-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id463c7082-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id463c7083-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id463c7084-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on first day of first calendar month which begins more than 90 days after ","children":[{"tag":"date","attrib":{"date":"1971-01-12"},"text":"Jan. 12, 1971","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/673/s5"},"text":"section 5 of Pub. L. 91–673","children":[],"tail":", set out as an Effective Date of 1971 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5056"},"text":"section 5056 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
