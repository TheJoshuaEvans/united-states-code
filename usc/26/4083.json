b":{"href":"/us/pl/114/55"},"text":"Pub. L. 114–55","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2016-04-01"},"text":"April 1, 2016","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2015-10-01"},"text":"October 1, 2015","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95"},"text":"Pub. L. 112–95","children":[],"tail":" inserted at end “Such term shall not include the use of any aircraft before "},{"tag":"date","attrib":{"date":"2015-10-01"},"text":"October 1, 2015","children":[],"tail":", if tax is imposed under section 4043 with respect to the fuel consumed in such use or if no tax is imposed on such use under section 4043 by reason of subsection (c)(5) thereof.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":" substituted “subsection (h) or (i) of section 4261” for “section 4261(h)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s301/c/8"},"text":"Pub. L. 108–357, § 301(c)(8)","children":[],"tail":", reenacted heading without change and amended text of par. (2) generally. Prior to amendment, par. (2) defined the term “gasoline”, to the extent prescribed in regulations, as including gasoline blend stocks and products commonly used as additives in gasoline, and defined the term “gasoline blend stock” as meaning any petroleum product component of gasoline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s870/a"},"text":"Pub. L. 108–357, § 870(a)","children":[],"tail":", reenacted heading without change and amended text of par. (3) generally. Prior to amendment, par. (3) defined the term “diesel fuel” as meaning any liquid (other than gasoline) which is suitable for use as a fuel in a diesel-powered highway vehicle or a diesel-powered train."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s853/b"},"text":"Pub. L. 108–357, § 853(b)","children":[],"tail":", added subsec. (b) and redesignated former subsec. (b) as (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s853/b"},"text":"Pub. L. 108–357, § 853(b)","children":[],"tail":", redesignated subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(A)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s858/a"},"text":"Pub. L. 108–357, § 858(a)","children":[],"tail":", added cl. (iii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s859/b/1"},"text":"Pub. L. 108–357, § 859(b)(1)","children":[],"tail":", designated existing provisions as subpar. (A), inserted heading, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206"},"text":"Pub. L. 105–206","children":[],"tail":" made technical amendment to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1032/a"},"text":"Pub. L. 105–34, § 1032(a)","children":[],"tail":". See 1997 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (a)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1032/a"},"text":"Pub. L. 105–34, § 1032(a)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/s6010/h/1"},"text":"Pub. L. 105–206, § 6010(h)(1)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s902/b/3"},"text":"Pub. L. 105–34, § 902(b)(3)","children":[],"tail":", substituted “or a diesel-powered train” for “, a diesel-powered train, or a diesel-powered boat”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1032/e/4"},"text":"Pub. L. 105–34, § 1032(e)(4)","children":[],"tail":", substituted “taxable fuels” for “gasoline, diesel fuel,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66"},"text":"Pub. L. 103–66","children":[],"tail":" amended heading and text generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) For provisions to relieve farmers from excise tax in the case of gasoline used on the farm for farming purposes, see section 6420.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) For provisions to relieve purchasers of gasoline from excise tax in the case of gasoline used for certain nonhighway purposes, used by local transit systems, or sold for certain exempt purposes, see section 6421.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) For provisions to relieve purchasers of gasoline from excise tax in the case of gasoline not used for taxable purposes, see section 6427.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" amended section generally. Prior to amendment, section 4083 “Exemption of sales to producer”, read as follows: “Under regulations prescribed by the Secretary the tax imposed by section 4081 shall not apply in the case of sales of gasoline to a producer of gasoline.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading",