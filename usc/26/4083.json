{"tag":"section","attrib":{"id":"id45b95d60-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4083"},"text":null,"children":[{"tag":"num","attrib":{"value":"4083"},"text":"§ 4083.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions; special rule; administrative authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45b95d61-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4083/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable fuel","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subpart—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45b95d62-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4083/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “taxable fuel” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45b95d63-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4083/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gasoline,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45b95d64-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4083/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" diesel fuel, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45b95d65-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4083/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" kerosene.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45b95d66-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4083/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gasoline","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “gasoline”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45b95d67-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4083/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes any gasoline blend, other than qualified methanol or ethanol fuel (as defined in section 4041(b)(2)(B)), partially exempt methanol or ethanol fuel (as defined in section 4041(m)(2)), or a denatured alcohol, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45b95d68-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4083/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes, to the extent prescribed in regulations—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45b95d69-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4083/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any gasoline blend stock, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45b95d6a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4083/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any product commonly used as an additive in gasoline (other than alcohol).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of subparagraph (B)(i), the term “gasoline blend stock” means any petroleum product component of gasoline.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45b95d6b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4083/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Diesel fuel","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45b95d6c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4083/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “diesel fuel” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45b95d6d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4083/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any liquid (other than gasoline) which is suitable for use as a fuel in a diesel-powered highway vehicle, or a diesel-powered train,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45b95d6e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4083/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transmix, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45b95d6f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4083/a/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" diesel fuel blend stocks identified by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45b95d70-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4083/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmix","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A), the term “transmix” means a byproduct of refined products pipeline operations created by the mixing of different specification products during pipeline transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45b95d71-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4083/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercial aviation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subpart, the term “commercial aviation” means any use of an aircraft in a business of transporting persons or property for compensation or hire by air, unless properly allocable to any transportation exempt from the taxes imposed by sections 4261 and 4271 by reason of section 4281 or 4282 or by reason of subsection (h) or (i) of section 4261. Such term shall not include the use of any aircraft before ","children":[{"tag":"date","attrib":{"date":"2028-10-01"},"text":"October 1, 2028","children":[],"tail":", if tax is imposed under section 4043 with respect to the fuel consumed in such use or if no tax is imposed on such use under section 4043 by reason of subsection (c)(5) thereof."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45b95d72-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4083/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain uses defined as removal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any person uses taxable fuel (other than in the production of taxable fuels or special fuels referred to in section 4041), such use shall for the purposes of this chapter be considered a removal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45b95d73-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4083/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45b95d74-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4083/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the authority otherwise granted by this title, the Secretary may in administering compliance with this subpart, section 4041, and penalties and other administrative provisions related thereto—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45b95d75-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4083/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" enter any place at which taxable fuel is produced or is stored (or may be stored) for purposes of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45b95d76-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4083/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examining the equipment used to determine the amount or composition of such fuel and the equipment used to store such fuel,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45b95d77-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4083/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" taking and removing samples of such fuel, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45b95d78-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4083/d/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inspecting any books and records and any shipping papers pertaining to such fuel, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45b95d79-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4083/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" detain, for the purposes referred in subparagraph (A), any container which contains or may contain any taxable fuel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45b95d7a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4083/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspection sites","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may establish inspection sites for purposes of carrying out the Secretary’s authority under paragraph (1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45b95d7b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4083/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for refusal of entry","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45b95d7c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4083/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forfeiture","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The penalty provided by section 7342 shall apply to any refusal to admit entry or other refusal to permit an action by the Secretary authorized by paragraph (1), except that section 7342 shall be applied by substituting “$1,000” for “$500” for each such refusal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45b95d7d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4083/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessable penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For additional assessable penalty for the refusal to admit entry or other refusal to permit an action by the Secretary authorized by paragraph (1), see section 6717.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45b95d7e-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/483"},"text":"68A Stat. 483","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976"