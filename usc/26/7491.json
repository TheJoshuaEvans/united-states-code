{"tag":"section","attrib":{"id":"id47667171-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7491"},"text":null,"children":[{"tag":"num","attrib":{"value":"7491"},"text":"§ 7491.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Burden of proof","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47667172-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7491/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Burden shifts where taxpayer produces credible evidence","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47667173-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7491/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, in any court proceeding, a taxpayer introduces credible evidence with respect to any factual issue relevant to ascertaining the liability of the taxpayer for any tax imposed by subtitle A or B, the Secretary shall have the burden of proof with respect to such issue.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47667174-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7491/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall apply with respect to an issue only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47667175-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7491/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taxpayer has complied with the requirements under this title to substantiate any item;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47667176-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7491/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taxpayer has maintained all records required under this title and has cooperated with reasonable requests by the Secretary for witnesses, information, documents, meetings, and interviews; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47667177-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7491/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a partnership, corporation, or trust, the taxpayer is described in section 7430(c)(4)(A)(ii).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Subparagraph (C) shall not apply to any qualified revocable trust (as defined in section 645(b)(1)) with respect to liability for tax for any taxable year ending after the date of the decedent’s death and before the applicable date (as defined in section 645(b)(2)).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47667178-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7491/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply to any issue if any other provision of this title provides for a specific burden of proof with respect to such issue.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47667179-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7491/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of statistical information on unrelated taxpayers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an individual taxpayer, the Secretary shall have the burden of proof in any court proceeding with respect to any item of income which was reconstructed by the Secretary solely through the use of statistical information on unrelated taxpayers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4766717a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7491/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this title, the Secretary shall have the burden of production in any court proceeding with respect to the liability of any individual for any penalty, addition to tax, or additional amount imposed by this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4766717b-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/tIII/s3001/a"},"text":"Pub. L. 105–206, title III, § 3001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/726"},"text":"112 Stat. 726","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dJ/tIV/s4002/b"},"text":"Pub. L. 105–277, div. J, title IV, § 4002(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-906"},"text":"112 Stat. 2681–906","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4766717c-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4766717d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4766717e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7491, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/893"},"text":"68A Stat. 893","children":[],"tail":", placed the burden of proof in establishing the applicability of an exemption upon the defendant in the case of marihuana offenses, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/91/513/tIII"},"text":"Pub. L. 91–513, title III","children":[],"tail":", §§ 1101(b)(5)(A), 1103, 1105(a), "},{"tag":"date","attrib":{"date":"1970-10-27"},"text":"Oct. 27, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1292"},"text":"84 Stat. 1292","children":[],"tail":", 1294, 1295, effective on first day of seventh calendar month that begins after "},{"tag":"date","attrib":{"date":"1970-10-26"},"text":"Oct. 26, 1970","children":[],"tail":", with prosecutions commenced prior to such date not to be affected or abated by reason thereof."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 7492, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/893"},"text":"68A Stat. 893","children":[],"tail":", related to the enforceability of cotton futures contracts, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1952/n/4/A"},"text":"Pub. L. 94–455, title XIX, § 1952(n)(4)(A)","children":[],"tail":", ("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1846"},"text":"90 Stat. 1846","children":[],"tail":", effective on the 90th day after "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 7493, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/893"},"text":"68A Stat. 893","children":[],"tail":", provided that no person whose evidence is deemed material by the officer prosecuting on behalf of the United States in any case brought under any provision of subchapter D of chapter 39 of this title withhold his testimony because of complicity by him in any violation of subchapter D of chapter 39 of this title or of any regulation made pursuant to such chapter, but that such person called by such officer who testifies in the case be exempt from prosecution for any offense to which his testimony relates, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/91/452/tII"},"text":"Pub. L. 91–452, title II","children":[],"tail":", §§ 232, 260, "},{"tag":"date","attrib":{"date":"1970-10-15"},"text":"Oct. 15, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/930"},"text":"84 Stat. 930","children":[],"tail":", 931, effective on 60th day following "},{"tag":"date","attrib":{"date":"1970-10-15"},"text":"Oct. 15, 1970","children":[],"tail":", and not to affect any immunity to which any individual was entitled under by reason of any testimony given before 60th day following "},{"tag":"date","attrib":{"date":"1970-10-15"},"text":"Oct. 15, 1970","children":[],"tail":". See section 6001 et seq. of Title 18, Crimes and Criminal Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4766717f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" inserted concluding provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47667180-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47667181-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" effective as if included in the provision of the Internal Revenue Service Restructuring and Reform Act of 1998, "},{"tag":"ref","attrib":{"href":"/us/pl/105/206"},"text":"Pub. L. 105–206","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s4002/k"},"text":"section 4002(k) of Pub. L. 105–277","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id47667182-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/tIII/s3001/c"},"text":"Pub. L. 105–206, title III, § 3001(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/727"},"text":"112 Stat. 727","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/206/tIII/s3001/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section [enacting this subchapter] shall apply to court proceedings arising in connection with examinations commencing after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Taxable periods or events after date of enactment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In any case in which there is no examination, such amendments shall apply to court proceedings arising in connection with taxable periods or events beginning or occurring after such date of enactment.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
