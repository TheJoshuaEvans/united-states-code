{"tag":"section","attrib":{"id":"id45d12b09-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4272"},"text":null,"children":[{"tag":"num","attrib":{"value":"4272"},"text":"§ 4272.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of taxable transportation, etc.","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45d12b0a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4272/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this part, except as provided in subsection (b), the term “taxable transportation” means transportation by air which begins and ends in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45d12b0b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4272/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this part, the term “taxable transportation” does not include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45d12b0c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4272/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that portion of any transportation which meets the requirements of paragraphs (1), (2), (3), and (4) of section 4262(b), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45d12b0d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4272/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under regulations prescribed by the Secretary, transportation of property in the course of exportation (including shipment to a possession of the United States) by continuous movement, and in due course so exported.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45d12b0e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4272/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excess baggage of passengers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this part, the term “property” does not include excess baggage accompanying a passenger traveling on an aircraft operated on an established line.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45d12b0f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4272/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this part, the term “transportation” includes layover or waiting time and movement of the aircraft in deadhead service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45d12b10-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/258/tII/s204"},"text":"Pub. L. 91–258, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-05-21"},"text":"May 21, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/240"},"text":"84 Stat. 240","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45d12b11-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45d12b12-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id45d12b13-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 4272 and 4273 were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/475/s4/a"},"text":"Pub. L. 85–475, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-06-30"},"text":"June 30, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/260"},"text":"72 Stat. 260","children":[],"tail":". For effective date of repeal, see "},{"tag":"ref","attrib":{"href":"/us/pl/85/475/s4/c"},"text":"section 4(c) of Pub. L. 85–475","children":[],"tail":", set out as an Effective Date of 1958 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6415"},"text":"section 6415 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 4272, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/507"},"text":"68A Stat. 507","children":[],"tail":", 508, related to exemptions from tax for the transportation of property."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 4273, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/507"},"text":"68A Stat. 507","children":[],"tail":", 508, related to registration in connection with the tax for the transportation of property."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45d12b14-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
