{"tag":"section","attrib":{"id":"id421c1222-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s194A"},"text":null,"children":[{"tag":"num","attrib":{"value":"194A"},"text":"§ 194A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contributions to employer liability trusts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id421c1223-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s194A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowance of deduction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There shall be allowed as a deduction for the taxable year an amount equal to the amount—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id421c1224-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s194A/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is contributed by an employer to a trust described in section 501(c)(22) (relating to withdrawal liability payment fund) which meets the requirements of section 4223(h) of the Employee Retirement Income Security Act of 1974, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id421c1225-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s194A/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is properly allocable to such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id421c1226-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s194A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation to taxable year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a contribution described in subsection (a) which relates to any specified period of time which includes more than one taxable year, the amount properly allocable to any taxable year in such period shall be determined by prorating such amounts to such taxable years under regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id421c1227-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s194A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disallowance of deduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No deduction shall be allowed under subsection (a) with respect to any contribution described in subsection (a) which does not relate to any specified period of time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id421c1228-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/364/tII/s209/c/1"},"text":"Pub. L. 96–364, title II, § 209(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1290"},"text":"94 Stat. 1290","children":[],"tail":", § 194; renumbered § 194A, "},{"tag":"ref","attrib":{"href":"/us/pl/97/448/tIII/s305/b/1"},"text":"Pub. L. 97–448, title III, § 305(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2399"},"text":"96 Stat. 2399","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id421c1229-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id421c122a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id421c122b-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 4223(h) of the Employee Retirement Income Security Act of 1974, referred to in subsec. (a), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1403/h"},"text":"section 1403(h) of Title 29","children":[],"tail":", Labor."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id421c122c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id421c122d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1983 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/448/tIII/s311/c/2"},"text":"Pub. L. 97–448, title III, § 311(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2411"},"text":"96 Stat. 2411","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/448/tIII/s311/c/2"},"text":"“The amendments made by subsection (b) of section 305 [redesignating ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s194"},"text":"section 194 of this title","children":[],"tail":", relating to contributions to employer liability trusts, as this section] shall take effect on "},{"tag":"date","attrib":{"date":"1980-10-14"},"text":"October 14, 1980","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id421c122e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/364/tII/s210"},"text":"Pub. L. 96–364, title II, § 210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1291"},"text":"94 Stat. 1291","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/364/tII/s210"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise provided in this section, the amendments made by this title [amending sections 401, 404, 411 to 414, 4971, and 4975 of this title] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subpart C of part I of subchapter D of chapter 1 of such Code (as added by this Act) [sections 418 to 418E of this title] shall take effect, with respect to each plan, on the first day of the first plan year beginning on or after the earlier of—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the last collective-bargaining agreement providing for employer contributions under the plan, which was in effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":"], expires, without regard to extensions agreed to after such date of enactment, or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 years after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendments made by section 209 [enacting this section and amending sections 501 and 4975 of this title] shall apply to taxable years ending after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
