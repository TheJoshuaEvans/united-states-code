{"tag":"section","attrib":{"id":"id43d9ef75-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s591"},"text":null,"children":[{"tag":"num","attrib":{"value":"591"},"text":"§ 591.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deduction for dividends paid on deposits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id43d9ef76-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s591/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of mutual savings banks, cooperative banks, domestic building and loan associations, and other savings institutions chartered and supervised as savings and loan or similar associations under Federal or State law, there shall be allowed as deductions in computing taxable income amounts paid to, or credited to the accounts of, depositors or holders of accounts as dividends or interest on their deposits or withdrawable accounts, if such amounts paid or credited are withdrawable on demand subject only to customary notice of intention to withdraw.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43d9ef77-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s591/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mutual savings bank to include certain banks with capital stock","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this part, the term “mutual savings bank” includes any bank—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43d9ef78-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s591/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which has capital stock represented by shares, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43d9ef79-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s591/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is subject to, and operates under, Federal or State laws relating to mutual savings bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id43d9ef7a-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/204"},"text":"68A Stat. 204","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/834/s6/f"},"text":"Pub. L. 87–834, § 6(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-16"},"text":"Oct. 16, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/984"},"text":"76 Stat. 984","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/tII/s245/a"},"text":"Pub. L. 97–34, title II, § 245(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/255"},"text":"95 Stat. 255","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id43d9ef7b-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id43d9ef7c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id43d9ef7d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1981—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading “In general”, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/834"},"text":"Pub. L. 87–834","children":[],"tail":" included other savings institutions chartered and supervised as savings and loan or similar associations under Federal or State law, and authorized amounts paid as interest as a deduction."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id43d9ef7e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43d9ef7f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/tII/s246/d"},"text":"Pub. L. 97–34, title II, § 246(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/256"},"text":"95 Stat. 256","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/34/tII/s246/d"},"text":"“The amendments made by section 245 [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s593"},"text":"section 593 of this title","children":[],"tail":"] shall apply with respect to taxable years ending after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
