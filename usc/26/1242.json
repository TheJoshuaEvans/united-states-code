{"tag":"section","attrib":{"id":"id44c6240d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1242"},"text":null,"children":[{"tag":"num","attrib":{"value":"1242"},"text":"§ 1242.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Losses on small business investment company stock","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44c6240e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1242/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a loss is on stock in a small business investment company operating under the Small Business Investment Act of 1958, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44c6240f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1242/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such loss would (but for this section) be a loss from the sale or exchange of a capital asset,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then such loss shall be treated as an ordinary loss. For purposes of section 172 (relating to the net operating loss deduction) any amount of loss treated by reason of this section as an ordinary loss shall be treated as attributable to a trade or business of the taxpayer.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44c62410-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/866/tI/s57/a"},"text":"Pub. L. 85–866, title I, § 57(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1645"},"text":"72 Stat. 1645","children":[],"tail":"; amended "},{"tag":"ref","attrib"