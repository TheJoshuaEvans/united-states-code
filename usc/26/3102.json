ag":"content","attrib":{},"text":" the employer shall file any return or statement required under section 6051 of such Code with respect to such wages (determined without regard to such amendments), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employee shall be entitled to credit under section 209 of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s409"},"text":"42 U.S.C. 409","children":[],"tail":"] with respect to any such wages required to be included on any such return or statement.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
