{"tag":"section","attrib":{"id":"id46543db0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5891"},"text":null,"children":[{"tag":"num","attrib":{"value":"5891"},"text":"§ 5891.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Structured settlement factoring transactions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46543db1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5891/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby imposed on any person who acquires directly or indirectly structured settlement payment rights in a structured settlement factoring transaction a tax equal to 40 percent of the factoring discount as determined under subsection (c)(4) with respect to such factoring transaction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46543db2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5891/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for certain approved transactions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46543db3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5891/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tax under subsection (a) shall not apply in the case of a structured settlement factoring transaction in which the transfer of structured settlement payment rights is approved in advance in a qualified order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46543db4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5891/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified order","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “qualified order” means a final order, judgment, or decree which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46543db5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5891/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" finds that the transfer described in paragraph (1)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id46543db6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5891/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not contravene any Federal or State statute or the order of any court or responsible administrative authority, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46543db7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5891/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in the best interest of the payee, taking into account the welfare and support of the payee’s dependents, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46543db8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5891/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is issued—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id46543db9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5891/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under the authority of an applicable State statute by an applicable State court, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46543dba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5891/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the responsible administrative authority (if any) which has exclusive jurisdiction over the underlying action or proceeding which was resolved by means of the structured settlement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46543dbb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5891/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable State statute","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “applicable State statute” means a statute providing for the entry of an order, judgment, or decree described in paragraph (2)(A) which is enacted by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46543dbc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5891/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State in which the payee of the structured settlement is domiciled, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46543dbd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5891/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if there is no statute described in subparagraph (A), the State in which either the party to the structured settlement (including an assignee under a qualified assignment under section 130) or the person issuing the funding asset for the structured settlement is domiciled or has its principal place of business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46543dbe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5891/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable State court","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46543dbf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5891/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “applicable State court” means, with respect to any applicable State statute, a court of the State which enacted such statute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46543dc0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5891/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an applicable State statute described in paragraph (3)(B), such term also includes a court of the State in which the payee of the structured settlement is domiciled.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46543dc1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5891/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified order dispositive","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A qualified order shall be treated as dispositive for purposes of the exception under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46543dc2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5891/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46543dc3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5891/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Structured settlement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “structured settlement” means an arrangement—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46543dc4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5891/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" which is established by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id46543dc5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5891/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suit or agreement for the periodic payment of damages excludable from the gross income of the recipient under section 104(a)(2), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46543dc6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5891/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agreement for the periodic payment of compensation under any workers’ compensation law excludable from the gross income of the recipient under section 104(a)(1), and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46543dc7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5891/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" under which the periodic payments are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id46543dc8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5891/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the character described in subparagraphs (A) and (B) of section 130(c)(2), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46543dc9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5891/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payable by a person who is a party to the suit or agreement or to the workers’ compensation claim or by a person who has assumed the liability for such periodic payments under a qualified assignment in accordance with section 130.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46543dca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5891/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Structured settlement payment rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “structured settlement payment rights” means rights to receive payments under a structured settlement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46543dcb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5891/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Structured settlement factoring transaction","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46543dcc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5891/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “structured settlement factoring transaction” means a transfer of structured settlement payment rights (including portions of structured settlement payments) made for consideration by means of sale, assignment, pledge, or other form of encumbrance or alienation for consideration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46543dcd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5891/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such term shall not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id46543dce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5891/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the creation or perfection of a security interest in structured settlement payment rights under a blanket security agreement entered into with an insured depository institution in the absence of any action to redirect the structured settlement payments to such institution (or agent or successor thereof) or otherwise to enforce such blanket security interest as against the structured settlement payment rights, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46543dcf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5891/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a subsequent transfer of structured settlement payment rights acquired in a structured settlement factoring transaction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46543dd0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5891/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factoring discount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “factoring discount” means an amount equal to the excess of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46543dd1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5891/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate undiscounted amount of structured settlement payments being acquired in the structured settlement factoring transaction, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46543dd2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5891/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount actually paid by the acquirer to the person from whom such structured settlement payments are acquired.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46543dd3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5891/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsible administrative authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “responsible administrative authority” means the administrative authority which had jurisdiction over the underlying action or proceeding which was resolved by means of the structured settlement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46543dd4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5891/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” includes the Commonwealth of Puerto Rico and any possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46543dd5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5891/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with other provisions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46543dd6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5891/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the applicable requirements of sections 72, 104(a)(1), 104(a)(2), 130, and 461(h) were satisfied at the time the structured settlement involving structured settlement payment rights was entered into, the subsequent occurrence of a structured settlement factoring transaction shall not affect the application of the provisions of such sections to the parties to the structured settlement (including an assignee under a qualified assignment under section 130) in any taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46543dd7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5891/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No withholding of tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of section 3405 regarding withholding of tax shall not apply to the person making the payments in the event of a structured settlement factoring transaction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46543dd8-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/134/tI/s115/a"},"text":"Pub. L. 107–134, title I, § 115(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-23"},"text":"Jan. 23, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2436"},"text":"115 Stat. 2436","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46543dd9-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46543dda-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id46543ddb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/134/tI/s115/c"},"text":"Pub. L. 107–134, title I, § 115(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-23"},"text":"Jan. 23, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2438"},"text":"115 Stat. 2438","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/134/tI/s115/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section [enacting this chapter] (other than the provisions of section 5891(d) of the Internal Revenue Code of 1986, as added by this section) shall apply to structured settlement factoring transactions (as defined in section 5891(c) of such Code (as so added)) entered into on or after the 30th day following the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2002-01-23"},"text":"Jan. 23, 2002","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Clarification of existing law","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Section 5891(d) of such Code (as so added) shall apply to structured settlement factoring transactions (as defined in section 5891(c) of such Code (as so added)) entered into before, on, or after such 30th day.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transition rule","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a structured settlement factoring transaction entered into during the period beginning on the 30th day following the date of the enactment of this Act and ending on ","children":[{"tag":"date","attrib":{"date":"2002-07-01"},"text":"July 1, 2002","children":[],"tail":", no tax shall be imposed under section 5891(a) of such Code if—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the structured settlement payee is domiciled in a State (or possession of the United States) which has not enacted a statute providing that the structured settlement factoring transaction is ineffective unless the transaction has been approved by an order, judgment, or decree of a court (or where applicable, a responsible administrative authority) which finds that such transaction—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not contravene any Federal or State statute or the order of any court (or responsible administrative authority); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in the best interest of the structured settlement payee or is appropriate in light of a hardship faced by the payee; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person acquiring the structured settlement payment rights discloses to the structured settlement payee in advance of the structured settlement factoring transaction the amounts and due dates of the payments to be transferred, the aggregate amount to be transferred, the consideration to be received by the structured settlement payee for the transferred payments, the discounted present value of the transferred payments (including the present value as determined in the manner described in section 7520 of such Code), and the expenses required under the terms of the structured settlement factoring transaction to be paid by the structured settlement payee or deducted from the proceeds of such transaction.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
