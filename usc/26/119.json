,"attrib":{"date":"1953-12-31"},"text":"December 31, 1953","children":[],"tail":", and ending after "},{"tag":"date","attrib":{"date":"1954-08-16"},"text":"August 16, 1954","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id41693cda-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment; Election of Prior Law","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/615"},"text":"Pub. L. 95–615","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"1977-12-31"},"text":"Dec. 31, 1977","children":[],"tail":", with provision for election of prior law, see "},{"tag":"ref","attrib":{"href":"/us/pl/95/615/s209"},"text":"section 209 of Pub. L. 95–615","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s911"},"text":"section 911 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id41693cdb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Statute of Limitations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/605/tI/s107/b"},"text":"Pub. L. 96–605, title I, § 107(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-28"},"text":"Dec. 28, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3524"},"text":"94 Stat. 3524","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/605/tI/s107/b"},"text":"“In the case of any allowance received during calendar year 1974, 1975, 1976, or 1977, subsections (a)(2) and (e) of such section 3 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/427/s3"},"text":"section 3 of Pub. L. 95–427","children":[],"tail":", set out below] shall be applied by substituting the date one year after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1980-12-28"},"text":"Dec. 28, 1980","children":[],"tail":"] for ‘"},{"tag":"date","attrib":{"date":"1979-04-15"},"text":"April 15, 1979","children":[],"tail":"’ each place it appears.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id41693cdc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Treatment of Certain Statutory Subsistence Allowances or Subsistence Allowances Negotiated in Accordance With State Law Received by State Police Officers Before ","children":[{"tag":"date","attrib":{"date":"1978-01-01"},"text":"January 1, 1978","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/427/s3"},"text":"Pub. L. 95–427, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-07"},"text":"Oct. 7, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/996"},"text":"92 Stat. 996","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/96/605/tI/s107/a"},"text":"Pub. L. 96–605, title I, § 107(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-28"},"text":"Dec. 28, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3524"},"text":"94 Stat. 3524","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Rule","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual who was employed as a State police officer received a statutory subsistence allowance or a subsistence allowance negotiated in accordance with State law while so employed,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such individual elects, on or before ","children":[{"tag":"date","attrib":{"date":"1979-04-15"},"text":"April 15, 1979","children":[],"tail":", and in such manner and form as the Secretary of the Treasury may prescribe, to have this section apply to such allowance, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this section applies to such allowance,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then, for purposes of the Internal Revenue Code of 1986 [formerly I.R.C. 1954], such allowance shall not be included in such individual’s gross income.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allowances to Which Section Applies","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, this section applies to any statutory subsistence allowance or subsistence allowance negotiated in accordance with State law which was received—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after ","children":[{"tag":"date","attrib":{"date":"1969-12-31"},"text":"December 31, 1969","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"1974-01-01"},"text":"January 1, 1974","children":[],"tail":", to the extent such individual did not include such allowance in gross income on his income tax return for the taxable year in which such allowance was received, or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the calendar year 1974, 1975, 1976, or 1977.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State police officer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘State police officer’ means any police officer (including a highway patrolman) employed by a State (or the District of Columbia) on a full-time basis with the power to arrest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Income tax return","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘income tax return’ means the return of the taxes imposed by subtitle A of the Internal Revenue Code of 1986. If an individual filed before ","children":[{"tag":"date","attrib":{"date":"1977-11-29"},"text":"November 29, 1977","children":[],"tail":", an amended return for any taxable year, such amended return shall be treated as the return for such taxable year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Deduction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If any individual receives a subsistence allowance which is excluded from gross income under subsection (a), no deduction shall be allowed under any provision of chapter 1 of the Internal Revenue Code of 1986 for expenses in respect of which he has received such allowance, except to the extent that such expenses exceed the amount excludable from gross income under subsection (a) and the excess is otherwise allowed as a deduction under such chapter 1.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Statute of Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If refund or credit of any overpayment of tax resulting from the application of this section is prevented at any time on or before ","children":[{"tag":"date","attrib":{"date":"1979-04-15"},"text":"April 15, 1979","children":[],"tail":", by the operation of any law or rule of law (including res judicata), refund or credit of such overpayment (to the extent attributable to the application of this section) may, nevertheless, be made or allowed if claim therefor is filed on or before "},{"tag":"date","attrib":{"date":"1979-04-15"},"text":"April 15, 1979","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
