{"tag":"section","attrib":{"id":"id41693ca6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s119"},"text":null,"children":[{"tag":"num","attrib":{"value":"119"},"text":"§ 119.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meals or lodging furnished for the convenience of the employer","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id41693ca7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s119/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meals and lodging furnished to employee, his spouse, and his dependents, pursuant to employment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There shall be excluded from gross income of an employee the value of any meals or lodging furnished to him, his spouse, or any of his dependents by or on behalf of his employer for the convenience of the employer, but only if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id41693ca8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s119/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of meals, the meals are furnished on the business premises of the employer, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41693ca9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s119/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of lodging, the employee is required to accept such lodging on the business premises of his employer as a condition of his employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id41693caa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s119/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id41693cab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s119/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisions of employment contract or State statute not to be determinative","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining whether meals or lodging are furnished for the convenience of the employer, the provisions of an employment contract or of a State statute fixing terms of employment shall not be determinative of whether the meals or lodging are intended as compensation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41693cac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s119/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain factors not taken into account with respect to meals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining whether meals are furnished for the convenience of the employer, the fact that a charge is made for such meals, and the fact that the employee may accept or decline such meals, shall not be taken into account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41693cad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s119/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain fixed charges for meals","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id41693cae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s119/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id41693caf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s119/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee is required to pay on a periodic basis a fixed charge for his meals, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id41693cb0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s119/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such meals are furnished by the employer for the convenience of the employer,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"there shall be excluded from the employee’s gross income an amount equal to such fixed charge.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id41693cb1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s119/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of subparagraph (A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subparagraph (A) shall apply—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id41693cb2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s119/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the employee pays the fixed charge out of his stated compensation or out of his own funds, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id41693cb3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s119/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only if the employee is required to make the payment whether he accepts or declines the meals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41693cb4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s119/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meals furnished to employees on business premises where meals of most employees are otherwise excludable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All meals furnished on the business premises of an employer to such employer’s employees shall be treated as furnished for the convenience of the employer if, without regard to this paragraph, more than half of the employees to whom such meals are furnished on such premises are furnished such meals for the convenience of the employer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id41693cb5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s119/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employees living in certain camps","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id41693cb6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s119/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an individual who is furnished lodging in a camp located in a foreign country by or on behalf of his employer, such camp shall be considered to be part of the business premises of the employer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41693cb7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s119/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Camp","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, a camp constitutes lodging which is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id41693cb8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s119/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provided by or on behalf of the employer for the convenience of the employer because the place at which such individual renders services is in a remote area where satisfactory housing is not available on the open market,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id41693cb9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s119/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" located, as near as practicable, in the vicinity of the place at which such individual renders services, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id41693cba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s119/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" furnished in a common area (or enclave) which is not available to the public and which normally accommodates 10 or more employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id41693cbb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s119/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lodging furnished by certain educational institutions to employees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id41693cbc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s119/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an employee of an educational institution, gross income shall not include the value of qualified campus lodging furnished to such employee during the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41693cbd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s119/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception in cases of inadequate rent","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall not apply to the extent of the excess of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id41693cbe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s119/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the lesser of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id41693cbf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s119/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 5 percent of the appraised value of the qualified campus lodging, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id41693cc0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s119/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average of the rentals paid by individuals (other than employees or students of the educational institution) during such calendar year for lodging provided by the educational institution which is comparable to the qualified campus lodging provided to the employee, over","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id41693cc1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s119/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rent paid by the employee for the qualified campus lodging during such calendar year.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The appraised value under subparagraph (A)(i) shall be determined as of the close of the calendar year in which the taxable year begins, or, in the case of a rental period not greater than 1 year, at any time during the calendar year in which such period begins.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41693cc2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s119/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified campus lodging","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “qualified campus lodging” means lodging to which subsection (a) does not apply and which is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id41693cc3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s119/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" located on, or in the proximity of, a campus of the educational institution, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id41693cc4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s119/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" furnished to the employee, his spouse, and any of his dependents by or on behalf of such institution for use as a residence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41693cc5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s119/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Educational institution, etc.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id41693cc6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s119/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “educational institution” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id41693cc7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s119/d/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution described in section 170(b)(1)(A)(ii) (or an entity organized under State law and composed of public institutions so described), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id41693cc8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s119/d/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an academic health center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id41693cc9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s119/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Academic health center","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subparagraph (A), the term “academic health center” means an entity—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id41693cca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s119/d/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is described in section 170(b)(1)(A)(iii),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id41693ccb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s119/d/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which receives (during the calendar year in which the taxable year of the taxpayer begins) payments under subsection (d)(5)(B) or (h) of section 1886 of the Social Security Act (relating to graduate medical education), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id41693ccc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s119/d/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which has as one of its principal purposes or functions the providing and teaching of basic and clinical medical science and research with the entity’s own faculty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id41693ccd-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/39"},"text":"68A Stat. 39","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/427/s4/a"},"text":"Pub. L. 95–427, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-07"},"text":"Oct. 7, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/997"},"text":"92 Stat. 997","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/615/tII/s205"},"text":"Pub. L. 95–615, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-08"},"text":"Nov. 8, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3107"},"text":"92 Stat. 3107","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/222/tI/s108/a/1/G"},"text":"Pub. L. 96–222, title I, § 108(a)(1)(G)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-04-01"},"text":"Apr. 1, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/225"},"text":"94 Stat. 225","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/tI/s113"},"text":"Pub. L. 97–34, title I, § 113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/195"},"text":"95 Stat. 195","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXI/s1164/a"},"text":"Pub. L. 99–514, title XI, § 1164(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2511"},"text":"100 Stat. 2511","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1011B/d"},"text":"Pub. L. 100–647, title I, § 1011B(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3489"},"text":"102 Stat. 3489","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1123/a"},"text":"Pub. L. 104–188, title I, § 1123(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1768"},"text":"110 Stat. 1768","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tV/s5002/a"},"text":"Pub. L. 105–206, title V, § 5002(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/788"},"text":"112 Stat. 788","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id41693cce-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id41693ccf-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id41693cd0-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 1886(d)(5)(B) or (h) of the Social Security Act, referred to in subsec. (d)(4)(B)(ii), is classified to section 1395ww(d)(5)(B) or (h) of Title 42, The Public Health and Welfare.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id41693cd1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206"},"text":"Pub. L. 105–206","children":[],"tail":" added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":" amended par. (4) generally. Prior to amendment, par. (4) read as follows: “"},{"tag":"inline","attrib":{},"text":"Educational institution","children":[],"tail":".—For purposes of this paragraph, the term ‘educational institution’ means an institution described in section 170(b)(1)(A)(ii).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" struck out “(as of the close of the calendar year in which the taxable year begins)” after “appraised value” in par. (2)(A)(i) and inserted at end “The appraised value under subparagraph (A)(i) shall be determined as of the close of the calendar year in which the taxable year begins, or, in the case of a rental period not greater than 1 year, at any time during the calendar year in which such period begins.” as concluding provision."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/222"},"text":"Pub. L. 96–222","children":[],"tail":" struck out “General rule” in subsec. (a) as in effect on the day before the date of enactment of the Foreign Earned Income Act of 1978 to correct a legislative oversight in the amendment of subsec. (a) of this section by "},{"tag":"ref","attrib":{"href":"/us/pl/95/615/s205"},"text":"section 205 of Pub. L. 95–615","children":[],"tail":". The amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/95/615"},"text":"Pub. L. 95–615","children":[],"tail":", however, was executed without reference to “General rule” as the probable intent of Congress, thereby requiring no change in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/615"},"text":"Pub. L. 95–615","children":[],"tail":" designated existing provisions as subsec. (a), added subsec. (a) heading, and substituted “furnished to him, his spouse, or any of his dependents by or on behalf of his employer for the convenience of the employer” for “furnished to him by his employer for the convenience of the employer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/427"},"text":"Pub. L. 95–427","children":[],"tail":" inserted provisions relating to factors not taken into account with respect to meals and certain fixed charges for meals."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id41693cd2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id41693cd3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"r