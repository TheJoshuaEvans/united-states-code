{"tag":"section","attrib":{"id":"id479d600b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7811"},"text":null,"children":[{"tag":"num","attrib":{"value":"7811"},"text":"§ 7811.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxpayer Assistance Orders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id479d600c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7811/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to issue","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id479d600d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7811/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon application filed by a taxpayer with the Office of the Taxpayer Advocate (in such form, manner, and at such time as the Secretary shall by regulations prescribe), the National Taxpayer Advocate may issue a Taxpayer Assistance Order if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id479d600e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7811/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Taxpayer Advocate determines the taxpayer is suffering or about to suffer a significant hardship as a result of the manner in which the internal revenue laws are being administered by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id479d600f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7811/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taxpayer meets such other requirements as are set forth in regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id479d6010-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7811/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of hardship","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), a significant hardship shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id479d6011-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7811/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an immediate threat of adverse action;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id479d6012-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7811/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a delay of more than 30 days in resolving taxpayer account problems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id479d6013-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7811/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the incurring by the taxpayer of significant costs (including fees for professional representation) if relief is not granted; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id479d6014-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7811/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" irreparable injury to, or a long-term adverse impact on, the taxpayer if relief is not granted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id479d6015-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7811/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standard where administrative guidance not followed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In cases where any Internal Revenue Service employee is not following applicable published administrative guidance (including the Internal Revenue Manual), the National Taxpayer Advocate shall construe the factors taken into account in determining whether to issue a Taxpayer Assistance Order in the manner most favorable to the taxpayer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id479d6016-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7811/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of a Taxpayer Assistance Order","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The terms of a Taxpayer Assistance Order may require the Secretary within a specified time period—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id479d6017-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7811/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to release property of the taxpayer levied upon, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id479d6018-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7811/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to cease any action, take any action as permitted by law, or refrain from taking any action, with respect to the taxpayer under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id479d6019-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7811/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 64 (relating to collection),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id479d601a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7811/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subchapter B of chapter 70 (relating to bankruptcy and receiverships),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id479d601b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7811/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 78 (relating to discovery of liability and enforcement of title), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id479d601c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7811/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other provision of law which is specifically described by the National Taxpayer Advocate in such order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id479d601d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7811/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to modify or rescind","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any Taxpayer Assistance Order issued by the National Taxpayer Advocate under this section may be modified or rescinded—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id479d601e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7811/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only by the National Taxpayer Advocate, the Commissioner of Internal Revenue, or the Deputy Commissioner of Internal Revenue, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id479d601f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7811/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only if a written explanation of the reasons for the modification or rescission is provided to the National Taxpayer Advocate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id479d6020-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7811/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension of running of period of limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The running of any period of limitation with respect to any action described in subsection (b) shall be suspended for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id479d6021-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7811/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period beginning on the date of the taxpayer’s application under subsection (a) and ending on the date of the National Taxpayer Advocate’s decision with respect to such application, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id479d6022-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7811/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any period specified by the National Taxpayer Advocate in a Taxpayer Assistance Order issued pursuant to such application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id479d6023-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7811/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independent action of National Taxpayer Advocate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall prevent the National Taxpayer Advocate from taking any action in the absence of an application under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id479d6024-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7811/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Taxpayer Advocate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “National Taxpayer Advocate” includes any designee of the National Taxpayer Advocate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id479d6025-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7811/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to persons performing services under a qualified tax collection contract","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any order issued or action taken by the National Taxpayer Advocate pursuant to this section shall apply to persons performing services under a qualified tax collection contract (as defined in section 6306(b)) to the same extent and in the same manner as such order or action applies to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id479d6026-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tVI/s6230/a"},"text":"Pub. L. 100–647, title VI, § 6230(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3733"},"text":"102 Stat. 3733","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/168/tI"},"text":"Pub. L. 104–168, title I","children":[],"tail":", §§ 101(b)(1), 102(a), (b), "},{"tag":"date","attrib":{"date":"1996-07-30"},"text":"July 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1455"},"text":"110 Stat. 1455","children":[],"tail":", 1456; "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tI/s1102/c"},"text":"Pub. L. 105–206, title I, § 1102(c)","children":[],"tail":", (d)(1)(C)–(G), (2), (3), "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/703"},"text":"112 Stat. 703","children":[],"tail":", 704; "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tIII/s319/28"},"text":"Pub. L. 106–554, § 1(a)(7) [title III, § 319(28), (29)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–648; "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s881/c"},"text":"Pub. L. 108–357, title VIII, § 881(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1626"},"text":"118 Stat. 1626","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id479d6027-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id479d6028-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id479d6029-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":" added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tIII/s319/28"},"text":"Pub. L. 106–554, § 1(a)(7) [title III, § 319(28)]","children":[],"tail":", substituted “Taxpayer Assistance Order” for “taxpayer assistance order”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tIII/s319/29"},"text":"Pub. L. 106–554, § 1(a)(7) [title III, § 319(29)]","children":[],"tail":", substituted “National Taxpayer Advocate’s” for “Ombudsman’s”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s1102/c"},"text":"Pub. L. 105–206, § 1102(c)","children":[],"tail":", reenacted heading without change and amended text generally. Prior to amendment, text read as follows: “Upon application filed by a taxpayer with the Office of the Taxpayer Advocate (in such form, manner, and at such time as the Secretary shall by regulations prescribe), the Taxpayer Advocate may issue a Taxpayer Assistance Order if, in the determination of the Taxpayer Advocate, the taxpayer is suffering or about to suffer a significant hardship as a result of the manner in which the internal revenue laws are being administered by the Secretary.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s1102/d/1/C"},"text":"Pub. L. 105–206, § 1102(d)(1)(C)","children":[],"tail":", substituted “National Taxpayer Advocate” for “Taxpayer Advocate”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s1102/d/1/D"},"text":"Pub. L. 105–206, § 1102(d)(1)(D)","children":[],"tail":", substituted “National Taxpayer Advocate” for “Taxpayer Advocate” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s1102/d/2"},"text":"Pub. L. 105–206, § 1102(d)(2)","children":[],"tail":", which directed amendment of par. (1) by substituting “National Taxpayer Advocate’s” for “Taxpayer Advocate’s”, could not be executed because the words “Taxpayer Advocate’s” did not appear."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s1102/d/1/E"},"text":"Pub. L. 105–206, § 1102(d)(1)(E)","children":[],"tail":", substituted “National Taxpayer Advocate” for “Taxpayer Advocate”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s1102/d/1/F"},"text":"Pub. L. 105–206, § 1102(d)(1)(F)","children":[],"tail":", (3), substituted “National Taxpayer Advocate” for “Taxpayer Advocate” in heading and text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s1102/d/1/G"},"text":"Pub. L. 105–206, § 1102(d)(1)(G)","children":[],"tail":", (3), substituted “National Taxpayer Advocate” for “Taxpayer Advocate” in heading and in two places in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/168/s101/b/1"},"text":"Pub. L. 104–168, § 101(b)(1)","children":[],"tail":", substituted “the Office of the Taxpayer Advocate” for “the Office of the Ombudsman” and substituted “Taxpayer Advocate” for “Ombudsman” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/168/s102/a/1"},"text":"Pub. L. 104–168, § 102(a)(1)","children":[],"tail":", inserted “within a specified time period” after “the Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/168/s102/a/2"},"text":"Pub. L. 104–168, § 102(a)(2)","children":[],"tail":", inserted “take any action as permitted by law,” after “cease any action,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/168/s101/b/1/B"},"text":"Pub. L. 104–168, § 101(b)(1)(B)","children":[],"tail":", substituted “Taxpayer Advocate” for “Ombudsman”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/168/s102/b"},"text":"Pub. L. 104–168, § 102(b)","children":[],"tail":", reenacted heading without change and amended text generally. Prior to amendment, text read as follows: “Any Taxpayer Assistance Order issued by the Ombudsman under this section may be modified or rescinded only by the Ombudsman, a district director, a service center director, a compliance center director, a regional director of appeals, or any superior of any such person.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d)(2) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/168/s101/b/1/B"},"text":"Pub. L. 104–168, § 101(b)(1)(B)","children":[],"tail":", substituted “Taxpayer Advocate” for “Ombudsman” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id479d602a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id479d602b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/168/s101/b/1"},"text":"section 101(b)(1) of Pub. L. 104–168","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-07-30"},"text":"July 30, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/168/s101/c"},"text":"section 101(c) of Pub. L. 104–168","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s7802"},"text":"section 7802 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/168/tI/s102/c"},"text":"Pub. L. 104–168, title I, § 102(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-07-30"},"text":"July 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1456"},"text":"110 Stat. 1456","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/168/tI/s102/c"},"text":"“The amendments made by this section [amending this section] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1996-07-30