{"tag":"section","attrib":{"id":"id42102b75-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179B"},"text":null,"children":[{"tag":"num","attrib":{"value":"179B"},"text":"§ 179B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deduction for capital costs incurred in complying with Environmental Protection Agency sulfur regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id42102b76-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179B/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowance of deduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a small business refiner (as defined in section 45H(c)(1)) which elects the application of this section, there shall be allowed as a deduction an amount equal to 75 percent of qualified costs (as defined in section 45H(c)(2)) which are paid or incurred by the taxpayer during the taxable year and which are properly chargeable to capital account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42102b77-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179B/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduced percentage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a small business refiner with average daily domestic refinery runs for the 1-year period ending on ","children":[{"tag":"date","attrib":{"date":"2002-12-31"},"text":"December 31, 2002","children":[],"tail":", in excess of 155,000 barrels, the number of percentage points described in subsection (a) shall be reduced (not below zero) by the product of such number (before the application of this subsection) and the ratio of such excess to 50,000 barrels."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42102b78-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179B/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis reduction","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42102b79-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179B/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this title, the basis of any property shall be reduced by the portion of the cost of such property taken into account under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42102b7a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179B/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ordinary income recapture","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of section 1245, the amount of the deduction allowable under subsection (a) with respect to any property which is of a character subject to the allowance for depreciation shall be treated as a deduction allowed for depreciation under section 167.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42102b7b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179B/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with other provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Section 280B shall not apply to amounts which are treated as expenses under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42102b7c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179B/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election to allocate deduction to cooperative owner","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42102b7d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179B/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42102b7e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179B/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a small business refiner to which subsection (a) applies is an organization to which part I of subchapter T applies, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42102b7f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179B/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more persons directly holding an ownership interest in the refiner are organizations to which part I of subchapter T apply,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the refiner may elect to allocate all or a portion of the deduction allowable under subsection (a) to such persons. Such allocation shall be equal to the person’s ratable share of the total amount allocated, determined on the basis of the person’s ownership interest in the taxpayer. The taxable income of the refiner shall not be reduced under section 1382 by reason of any amount to which the preceding sentence applies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42102b80-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179B/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form and effect of election","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An election under paragraph (1) for any taxable year shall be made on a timely filed return for such year. Such election, once made, shall be irrevocable for such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42102b81-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179B/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Written notice to owners","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any portion of the deduction available under subsection (a) is allocated to owners under paragraph (1), the cooperative shall provide any owner receiving an allocation written notice of the amount of the allocation. Such notice shall be provided before the date on which the return described in paragraph (2) is due.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id42102b82-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tIII/s338/a"},"text":"Pub. L. 108–357, title III, § 338(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1480"},"text":"118 Stat. 1480","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXIII/s1324/a"},"text":"Pub. L. 109–58, title XIII, § 1324(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1015"},"text":"119 Stat. 1015","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/172/s7/a/3/A"},"text":"Pub. L. 110–172, § 7(a)(3)(A)","children":[],"tail":", (C), "},{"tag":"date","attrib":{"date":"2007-12-29"},"text":"Dec. 29, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2482"},"text":"121 Stat. 2482","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id42102b83-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id42102b84-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id42102b85-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/172"},"text":"Pub. L. 110–172","children":[],"tail":" substituted “qualified costs” for “qualified capital costs” and inserted “and which are properly chargeable to capital account” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":" added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id42102b86-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id42102b87-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/172"},"text":"Pub. L. 110–172","children":[],"tail":" effective as if included in the provision of the American Jobs Creation Act of 2004, "},{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/110/172/s7/e"},"text":"section 7(e) of Pub. L. 110–172","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1092"},"text":"section 1092 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id42102b88-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXIII/s1324/b"},"text":"Pub. L. 109–58, title XIII, § 1324(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1015"},"text":"119 Stat. 1015","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/58/tXIII/s1324/b"},"text":"“The amendment made by this section [amending this section] shall take effect as if included in the amendment made by section 338(a) of the American Jobs Creation Act of 2004 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":", enacting this section].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id42102b89-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tIII/s338/c"},"text":"Pub. L. 108–357, title III, § 338(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1481"},"text":"118 Stat. 1481","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/357/tIII/s338/c"},"text":"“The amendment made by this section [enacting this section and amending sections 263, 263A, 312, 1016, and 1245 of this title] shall apply to expenses paid or incurred after ","children":[{"tag":"date","attrib":{"date":"2002-12-31"},"text":"December 31, 2002","children":[],"tail":", in taxable years ending after such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
