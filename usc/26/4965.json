{"tag":"section","attrib":{"id":"id45f2961a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4965"},"text":null,"children":[{"tag":"num","attrib":{"value":"4965"},"text":"§ 4965.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excise tax on certain tax-exempt entities entering into prohibited tax shelter transactions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45f2961b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4965/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Being a party to and approval of prohibited transactions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45f2961c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4965/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax-exempt entity","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45f2961d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4965/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a transaction is a prohibited tax shelter transaction at the time any tax-exempt entity described in paragraph (1), (2), or (3) of subsection (c) becomes a party to the transaction, such entity shall pay a tax for the taxable year in which the entity becomes such a party and any subsequent taxable year in the amount determined under subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f2961e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4965/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Post-transaction determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any tax-exempt entity described in paragraph (1), (2), or (3) of subsection (c) is a party to a subsequently listed transaction at any time during a taxable year, such entity shall pay a tax for such taxable year in the amount determined under subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f2961f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4965/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entity manager","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any entity manager of a tax-exempt entity approves such entity as (or otherwise causes such entity to be) a party to a prohibited tax shelter transaction at any time during the taxable year and knows or has reason to know that the transaction is a prohibited tax shelter transaction, such manager shall pay a tax for such taxable year in the amount determined under subsection (b)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45f29620-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4965/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of tax","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45f29621-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4965/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a tax-exempt entity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45f29622-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4965/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subparagraph (B), the amount of the tax imposed under subsection (a)(1) with respect to any transaction for a taxable year shall be an amount equal to the product of the highest rate of tax under section 11, and the greater of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45f29623-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4965/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the entity’s net income (after taking into account any tax imposed by this subtitle (other than by this section) with respect to such transaction) for such taxable year which—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id45f4e014-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4965/b/1/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a prohibited tax shelter transaction (other than a subsequently listed transaction), is attributable to such transaction, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id45f4e015-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4965/b/1/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a subsequently listed transaction, is attributable to such transaction and which is properly allocable to the period beginning on the later of the date such transaction is identified by guidance as a listed transaction by the Secretary or the first day of the taxable year, or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45f4e016-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4965/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 75 percent of the proceeds received by the entity for the taxable year which—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id45f4e017-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4965/b/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a prohibited tax shelter transaction (other than a subsequently listed transaction), are attributable to such transaction, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id45f4e018-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4965/b/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a subsequently listed transaction, are attributable to such transaction and which are properly allocable to the period beginning on the later of the date such transaction is identified by guidance as a listed transaction by the Secretary or the first day of the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f4e019-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4965/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increase in tax for certain knowing transactions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a tax-exempt entity which knew, or had reason to know, a transaction was a prohibited tax shelter transaction at the time the entity became a party to the transaction, the amount of the tax imposed under subsection (a)(1)(A) with respect to any transaction for a taxable year shall be the greater of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45f4e01a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4965/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 100 percent of the entity’s net income (after taking into account any tax imposed by this subtitle (other than by this section) with respect to the prohibited tax shelter transaction) for such taxable year which is attributable to the prohibited tax shelter transaction, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45f4e01b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4965/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 75 percent of the proceeds received by the entity for the taxable year which are attributable to the prohibited tax shelter transaction.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"This subparagraph shall not apply to any prohibited tax shelter transaction to which a tax-exempt entity became a party on or before the date of the enactment of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f4e01c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4965/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entity manager","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of each entity manager, the amount of the tax imposed under subsection (a)(2) shall be $20,000 for each approval (or other act causing participation) described in subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45f4e01d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4965/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax-exempt entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “tax-exempt entity” means an entity which is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45f4e01e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4965/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" described in section 501(c) or 501(d),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f4e01f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4965/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" described in section 170(c) (other than the United States),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f4e020-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4965/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian tribal government (within the meaning of section 7701(a)(40)),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f4e021-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4965/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" described in paragraph (1), (2), or (3) of section 4979(e),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f4e022-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4965/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a program described in section 529,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f4e023-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4965/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an eligible deferred compensation plan described in section 457(b) which is maintained by an employer described in section 457(e)(1)(A),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f4e024-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4965/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an arrangement described in section 4973(a), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f4e025-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4965/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a program described in section 529A.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45f4e026-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4965/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entity manager","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “entity manager” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45f4e027-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4965/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of an entity described in paragraph (1), (2), or (3) of subsection (c)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45f4e028-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4965/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person with authority or responsibility similar to that exercised by an officer, director, or trustee of an organization, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f4e029-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4965/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to any act, the person having authority or responsibility with respect to such act, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f4e02a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4965/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an entity described in paragraph (4), (5), (6), or (7) of subsection (c), the person who approves or otherwise causes the entity to be a party to the prohibited tax shelter transaction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45f4e02b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4965/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited tax shelter transaction; subsequently listed transaction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45f4e02c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4965/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited tax shelter transaction","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45f4e02d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4965/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “prohibited tax shelter transaction” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45f4e02e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4965/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any listed transaction, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45f4e02f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4965/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any prohibited reportable transaction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f4e030-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4965/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Listed transaction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “listed transaction” has the meaning given such term by section 6707A(c)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f4e031-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4965/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited reportable transaction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “prohibited reportable transaction” means any confidential transaction or any transaction with contractual protection (as defined under regulations prescribed by the Secretary) which is a reportable transaction (as defined in section 6707A(c)(1)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f4e032-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4965/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequently listed transaction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “subsequently listed transaction” means any transaction to which a tax-exempt entity is a party and which is determined by the Secretary to be a listed transaction at any time after the entity has become a party to the transaction. Such term shall not include a transaction which is a prohibited reportable transaction at the time the entity became a party to the transaction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45f4e033-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4965/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulatory authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to promulgate regulations which provide guidance regarding the determination of the allocation of net income or proceeds of a tax-exempt entity attributable to a transaction to various periods, including before and after the listing of the transaction or the date which is 90 days after the date of the enactment of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45f4e034-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4965/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with other taxes and penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tax imposed by this section is in addition to any other tax, addition to tax, or penalty imposed under this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45f4e035-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/222/tV/s516/a/1"},"text":"Pub. L. 109–222, title V, § 516(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-05-17"},"text":"May 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/368"},"text":"120 Stat. 368","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/172/s11/a/30"},"text":"Pub. L. 110–172, § 11(a)(30)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-29"},"text":"Dec. 29, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2487"},"text":"121 Stat. 2487","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dB/tI/s102/e/3"},"text":"Pub. L. 113–295, div. B, title I, § 102(e)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4062"},"text":"128 Stat. 4062","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45f4e036-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45f4e037-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id45f4e038-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this section, referred to in subsecs. (b)(1)(B) and (f), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/222"},"text":"Pub. L. 109–222","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2006-05-17"},"text":"May 17, 2006","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45f4e039-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (c)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" added par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (c)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/172"},"text":"Pub. L. 110–172","children":[],"tail":" substituted “section 457(e)(1)(A)” for “section 4457(e)(1)(A)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45f4e03a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Relate