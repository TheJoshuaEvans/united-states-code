{"tag":"section","attrib":{"id":"id44e9d87c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1352"},"text":null,"children":[{"tag":"num","attrib":{"value":"1352"},"text":"§ 1352.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative tax on qualifying shipping activities","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In the case of an electing corporation, the tax imposed by section 11 shall be the amount equal to the sum of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44e9d87d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1352/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the tax imposed by section 11 determined after the application of this subchapter, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44e9d87e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1352/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a tax equal to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44e9d87f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1352/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the highest rate of tax specified in section 11, multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44e9d880-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1352/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the notional shipping income for the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44e9d881-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","childr