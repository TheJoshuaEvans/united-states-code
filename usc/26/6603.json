{"tag":"section","attrib":{"id":"id4710b030-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6603"},"text":null,"children":[{"tag":"num","attrib":{"value":"6603"},"text":"§ 6603.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposits made to suspend running of interest on potential underpayments, etc.","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4710b031-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6603/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to make deposits other than as payment of tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A taxpayer may make a cash deposit with the Secretary which may be used by the Secretary to pay any tax imposed under subtitle A or B or chapter 41, 42, 43, or 44 which has not been assessed at the time of the deposit. Such a deposit shall be made in such manner as the Secretary shall prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4710b032-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6603/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No interest imposed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent that such deposit is used by the Secretary to pay tax, for purposes of section 6601 (relating to interest on underpayments), the tax shall be treated as paid when the deposit is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4710b033-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6603/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Return of deposit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except in a case where the Secretary determines that collection of tax is in jeopardy, the Secretary shall return to the taxpayer any amount of the deposit (to the extent not used for a payment of tax) which the taxpayer requests in writing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4710b034-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6603/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of interest","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4710b035-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6603/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of section 6611 (relating to interest on overpayments), except as provided in paragraph (4), a deposit which is returned to a taxpayer shall be treated as a payment of tax for any period to the extent (and only to the extent) attributable to a disputable tax for such period. Under regulations prescribed by the Secretary, rules similar to the rules of section 6611(b)(2) shall apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4710b036-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6603/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disputable tax","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4710b037-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6603/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “disputable tax” means the amount of tax specified at the time of the deposit as the taxpayer’s reasonable estimate of the maximum amount of any tax attributable to disputable items.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4710b038-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6603/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safe harbor based on 30-day letter","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a taxpayer who has been issued a 30-day letter, the maximum amount of tax under subparagraph (A) shall not be less than the amount of the proposed deficiency specified in such letter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4710b039-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6603/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (2)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4710b03a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6603/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disputable item","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “disputable item” means any item of income, gain, loss, deduction, or credit if the taxpayer—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4710b03b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6603/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a reasonable basis for its treatment of such item, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4710b03c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6603/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonably believes that the Secretary also has a reasonable basis for disallowing the taxpayer’s treatment of such item.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4710b03d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6603/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 30-day letter","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “30-day letter” means the first letter of proposed deficiency which allows the taxpayer an opportunity for administrative review in the Internal Revenue Service Independent Office of Appeals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4710b03e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6603/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rate of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rate of interest under this subsection shall be the Federal short-term rate determined under section 6621(b), compounded daily.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4710b03f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6603/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of deposits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4710b040-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6603/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided by the taxpayer, deposits shall be treated as used for the payment of tax in the order deposited.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4710b041-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6603/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Returns of deposits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Deposits shall be treated as returned to the taxpayer on a last-in, first-out basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4710b042-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s842/a"},"text":"Pub. L. 108–357, title VIII, § 842(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1598"},"text":"118 Stat. 1598","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/25/tI/s1001/b/1/D"},"text":"Pub. L. 116–25, title I, § 1001(b)(1)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-07-01"},"text":"July 1, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/985"},"text":"133 Stat. 985","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4710b043-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4710b044-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4710b045-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (d)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/25"},"text":"Pub. L. 116–25","children":[],"tail":" substituted “Internal Revenue Service Independent Office of Appeals” for “Internal Revenue Service Office of Appeals”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4710b046-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4710b047-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s842/c"},"text":"Pub. L. 108–357, title VIII, § 842(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1599"},"text":"118 Stat. 1599","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/357/tVIII/s842/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section [enacting this section] shall apply to deposits made after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination with deposits made under revenue procedure 84–58","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of an amount held by the Secretary of the Treasury or his delegate on the date of the enactment of this Act as a deposit in the nature of a cash bond deposit pursuant to Revenue Procedure 84–58, the date that the taxpayer identifies such amount as a deposit made pursuant to section 6603 of the Internal Revenue Code (as added by this Act) shall be treated as the date such amount is deposited for purposes of such section 6603.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
