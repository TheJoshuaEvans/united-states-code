{"tag":"section","attrib":{"id":"id423d7cda-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s241"},"text":null,"children":[{"tag":"num","attrib":{"value":"241"},"text":"§ 241.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowance of special deductions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In addition to the deductions provided in part VI (sec. 161 and following), there shall be allowed as deductions in computing taxable income the items specified in this part.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id423d7cdb-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/72"},"text":"68A Stat. 72","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
