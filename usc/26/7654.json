{"tag":"section","attrib":{"id":"id4780b03b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7654"},"text":null,"children":[{"tag":"num","attrib":{"value":"7654"},"text":"§ 7654.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of United States and certain possession individual income taxes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4780b03c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7654/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The net collection of taxes imposed by chapter 1 for each taxable year with respect to an individual to whom section 931 or 932(c) applies shall be covered into the Treasury of the specified possession of which such individual is a bona fide resident.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4780b03d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7654/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition and special rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4780b03e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7654/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Net collections","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining net collections for a taxable year, an appropriate adjustment shall be made for credits allowed against the tax liability and refunds made of income taxes for the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4780b03f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7654/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specified possession","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “specified possession” means Guam, American Samoa, the Northern Mariana Islands, and the Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4780b040-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7654/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The transfers of funds between the United States and any specified possession required by this section shall be made not less frequently than annually.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4780b041-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7654/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal personnel","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the amount determined under subsection (a), the United States shall pay to each specified possession at such times and in such manner as determined by the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4780b042-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7654/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the taxes deducted and withheld by the United States under chapter 24 with respect to compensation paid to members of the Armed Forces who are stationed in such possession but who have no income tax liability to such possession with respect to such compensation by reason of the Servicemembers Civil Relief Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3901"},"text":"50 U.S.C. 3901","children":[],"tail":" et seq.), and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4780b043-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7654/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the taxes deducted and withheld under chapter 24 with respect to amounts paid for services performed as an employee of the United States (or any agency thereof) in a specified possession with respect to an individual unless section 931 or 932(c) applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4780b044-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7654/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such regulations as may be necessary to carry out the provisions of this section and sections 931 and 932, including regulations prohibiting the rebate of taxes covered over which are allocable to United States source income and prescribing the information which the individuals to whom such sections may apply shall furnish to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4780b045-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/909"},"text":"68A Stat. 909","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/606/s1/b"},"text":"Pub. L. 92–606, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-31"},"text":"Oct. 31, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1495"},"text":"86 Stat. 1495","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/248/tIII"},"text":"Pub. L. 97–248, title III","children":[],"tail":", §§ 307(a)(16), 308(a), "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/590"},"text":"96 Stat. 590","children":[],"tail":", 591; "},{"tag":"ref","attrib":{"href":"/us/pl/98/67/tI/s102/a"},"text":"Pub. L. 98–67, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-05"},"text":"Aug. 5, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/369"},"text":"97 Stat. 369","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXII/s1276/a"},"text":"Pub. L. 99–514, title XII, § 1276(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2599"},"text":"100 Stat. 2599","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1012/y"},"text":"Pub. L. 100–647, title I, § 1012(y)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3530"},"text":"102 Stat. 3530","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/189/s2/d"},"text":"Pub. L. 108–189, § 2(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2866"},"text":"117 Stat. 2866","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/330"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(330)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1200"},"text":"132 Stat. 1200","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4780b046-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4780b047-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4780b048-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Servicemembers Civil Relief Act, referred to in subsec. (d)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-17/ch888"},"text":"act Oct. 17, 1940, ch. 888","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/1178"},"text":"54 Stat. 1178","children":[],"tail":", which is classified generally to chapter 50 (§ 3901 et seq.) of Title 50, War and National Defense. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3901"},"text":"section 3901 of Title 50","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4780b049-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3901"},"text":"50 U.S.C. 3901","children":[],"tail":" et seq.” for “50 App. U.S.C. 501 et seq.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/189"},"text":"Pub. L. 108–189","children":[],"tail":" substituted “Servicemembers Civil Relief Act” for “Soldiers’ and Sailors’ Civil Relief Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" substituted “an individual to whom” for “an individual to which”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" amended section generally, substituting provisions relating to coordination of United States and certain possession individual income taxes for provisions relating to coordination of United States and Guam individual income taxes."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/67"},"text":"Pub. L. 98–67","children":[],"tail":" repealed amendments made by "},{"tag":"ref","attrib":{"href":"/us/pl/97/248"},"text":"Pub. L. 97–248","children":[],"tail":". See 1982 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248"},"text":"Pub. L. 97–248","children":[],"tail":" provided that, applicable to payments of interest, dividends, and patronage dividends paid or credited after "},{"tag":"date","attrib":{"date":"1983-06-30"},"text":"June 30, 1983","children":[],"tail":", subsec. (d) is amended by inserting “subchapter A of” before “chapter 24”. Section 102(a), (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/98/67/tI"},"text":"Pub. L. 98–67, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-05"},"text":"Aug. 5, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/369"},"text":"97 Stat. 369","children":[],"tail":", repealed sub­title A (§§ 301–308) of title III of "},{"tag":"ref","attrib":{"href":"/us/pl/97/248"},"text":"Pub. L. 97–248","children":[],"tail":" as of the close of "},{"tag":"date","attrib":{"date":"1983-06-30"},"text":"June 30, 1983","children":[],"tail":", and provided that the Internal Revenue Code of 1954 [now 1986] [this title] shall be applied and administered (subject to certain exceptions) as if such subtitle A (and the amendments made by such subtitle A) had not been enacted."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/606"},"text":"Pub. L. 92–606","children":[],"tail":" substituted provisions relating to individual income taxes in Guam and their sharing by the United States and Guam, for provisions relating to payment to Guam and American Samoa of proceeds of tax on coconut and other vegetable oils."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4780b04a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4780b04b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1019/a"},"text":"section 1019(a) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4780b04c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"1986-12-31"},"text":"Dec. 31, 1986","children":[],"tail":", with certain exceptions and qualifications, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1277"},"text":"section 1277 of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s931"},"text":"section 931 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4780b04d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},