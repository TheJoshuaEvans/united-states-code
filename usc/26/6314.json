{"tag":"section","attrib":{"id":"id46c6af40-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6314"},"text":null,"children":[{"tag":"num","attrib":{"value":"6314"},"text":"§ 6314.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Receipt for taxes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46c6af41-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6314/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, upon request, give receipts for all sums collected by him, excepting only when the same are in payment for stamps sold and delivered; but no receipt shall be issued in lieu of a stamp representing a tax.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46c6af42-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6314/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duplicate receipts for payment of estate taxes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, upon request, give to the person paying the tax under chapter 11 (relating to the estate tax) duplicate receipts, either of which shall be sufficient evidence of such payment, and shall entitle the executor to be credited and allowed the amount thereof by any court having jurisdiction to audit or settle his accounts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46c6af43-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6314/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross references","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46c6af44-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6314/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For receipt required to be furnished by employer to employee with respect to employment taxes, see section 6051.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46c6af45-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6314/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For receipt of discharge of fiduciary from personal liability, see section 2204.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46c6af46-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/778"},"text":"68A Stat. 778","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/614/tI/s101/d/2"},"text":"Pub. L. 91–614, title I, § 101(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1837"},"text":"84 Stat. 1837","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46c6af47-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46c6af48-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46c6af49-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/614"},"text":"Pub. L. 91–614","children":[],"tail":" substituted “fiduciary” for “executor”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46c6af4a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46c6af4b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/614"},"text":"Pub. L. 91–614","children":[],"tail":" applicable with respect to decedents dying after "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/614/s101/j"},"text":"section 101(j) of Pub. L. 91–614","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2032"},"text":"section 2032 of this title","chil