{"tag":"section","attrib":{"id":"id44e2aca8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1295"},"text":null,"children":[{"tag":"num","attrib":{"value":"1295"},"text":"§ 1295.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified electing fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44e2aca9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1295/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this part, any passive foreign investment company shall be treated as a qualified electing fund with respect to the taxpayer if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44e2acaa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1295/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an election by the taxpayer under subsection (b) applies to such company for the taxable year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44e2acab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1295/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such company complies with such requirements as the Secretary may prescribe for purposes of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44e2acac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1295/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determining the ordinary earnings and net capital gain of such company, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44e2acad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1295/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise carrying out the purposes of this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44e2acae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1295/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44e2acaf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1295/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A taxpayer may make an election under this subsection with respect to any passive foreign investment company for any taxable year of the taxpayer. Such an election, once made with respect to any company, shall apply to all subsequent taxable years of the taxpayer with respect to such company unless revoked by the taxpayer with the consent of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44e2acb0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1295/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" When made","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An election under this subsection may be made for any taxable year at any time on or before the due date (determined with regard to extensions) for filing the return of the tax imposed by this chapter for such taxable year. To the extent provided in regulations, such an election may be made later than as required in the preceding sentence where the taxpayer fails to make a timely election because the taxpayer reasonably believed that the company was not a passive foreign investment company.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44e2acb1-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXII/s1235/a"},"text":"Pub. L. 99–514, title XII, § 1235(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2571"},"text":"100 Stat. 2571","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1012/p/37/A"},"text":"Pub. L. 100–647, title I, § 1012(p)(37)(A)","children":[],"tail":", title VI, § 6127(a), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3522"},"text":"102 Stat. 3522","children":[],"tail":", 3715.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44e2acb2-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44e2acb3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44e2acb4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s6127/a"},"text":"Pub. L. 100–647, § 6127(a)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows: “For purposes of this part, the term ‘qualified electing fund’ means any passive foreign investment company if—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) an election under subsection (b) applies to such company for the taxable year, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) such company complies for such taxable year with such requirements as the Secretary may prescribe for purposes of—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) determining the ordinary earnings and net capital gain of such company for the taxable year,","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) ascertaining the ownership of its outstanding stock, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) otherwise carrying out the purposes of this subpart.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s6127/a"},"text":"Pub. L. 100–647, § 6127(a)","children":[],"tail":", amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—A passive foreign investment company may make an election under this subsection for any taxable year. Such an election, once made, shall apply to all subsequent taxable years of such company for which such company is a passive foreign investment company unless revoked with the consent of the Secretary."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"When made","children":[],"tail":".—An election under this subsection may be made for any taxable year at any time before the 15th day of the 3rd month of the following taxable year. To the extent provided in regulations, such an election may be made later than as required by the preceding sentence in cases where the company failed to make a timely election because it reasonably believed it was not a passive foreign investment company.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1012/p/37/A"},"text":"Pub. L. 100–647, § 1012(p)(37)(A)","children":[],"tail":", inserted sentence at end of par. (2) permitting a later election when a company reasonably believed it was not a passive foreign investment company."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44e2acb5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44e2acb6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1012/p/37/A"},"text":"section 1012(p)(37)(A) of Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1019/a"},"text":"section 1019(a) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tVI/s6127/c"},"text":"Pub. L. 100–647, title VI, § 6127(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3715"},"text":"102 Stat. 3715","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/647/tVI/s6127/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1291"},"text":"section 1291 of this title","children":[],"tail":"] shall take effect as if included in the amendments made by section 1235 of the Reform Act ["},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Time for making election","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The period during which an election under section 1295(b) of the 1986 Code may be made shall in no event expire before the date 60 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id44e2acb7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to taxable years of foreign corporations beginning after ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"Dec. 31, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1235/h"},"text":"section 1235(h) of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1291"},"text":"section 1291 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id44e2acb8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Expiration of Subsection (b) Election Period","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1012/p/37/B"},"text":"Pub. L. 100–647, title I, § 1012(p)(37)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3522"},"text":"102 Stat. 3522","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/647/tI/s1012/p/37/B"},"text":"“The period during which an election under section 1295(b) of the 1986 Code may be made shall in no event expire before the date 60 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
