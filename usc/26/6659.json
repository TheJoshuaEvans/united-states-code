{"tag":"section","attrib":{"id":"id4723c2df-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6659"},"text":null,"children":[{"tag":"num","attrib":{"value":"6659"},"text":"§ 6659.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improper claim for Trump account contribution pilot program credit","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4723c2e0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6659/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any individual who makes an election under section 6434 with respect to an individual who is not an eligible child of the taxpayer—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4723c2e1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6659/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such election was made due to negligence or disregard of the rules or regulations, there shall be imposed a penalty of $500, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4723c2e2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6659/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such election was made due to fraud, there shall be imposed a penalty of $1,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4723c2e3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6659/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4723c2e4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6659/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible child","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible child” has the meaning given such term under section 6434.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4723c2e5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6659/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Negligence; disregard","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “negligence” and “disregard” have the same meaning as when such terms are used in section 6662.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4723c2e6-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70204/d/2"},"text":"Pub. L. 119–21, title VII, § 70204(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/188"},"text":"139 Stat. 188","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4723c2e7-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4723c2e8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4723c2e9-3a70-11f1-a967-d35dac11796a"},"text":nul