ext":"January 1, 1987","children":[],"tail":", if such contract was treated as a variable contract on the taxpayer’s return.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1821/m"},"text":"section 1821(m) of Pub. L. 99–514","children":[],"tail":" effective, except as otherwise provided, as if included in the provisions of the Tax Reform Act of 1984, "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA"},"text":"Pub. L. 98–369, div. A","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1881"},"text":"section 1881 of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s48"},"text":"section 48 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4410dd76-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1983-12-31"},"text":"Dec. 31, 1983","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s215"},"text":"section 215 of Pub. L. 98–369","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4410dd77-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Delay in Effective Date for Diversification Requirements With Respect to Accounts for Certain Immediate Annuities","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1010/i"},"text":"Pub. L. 100–647, title I, § 1010(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3455"},"text":"102 Stat. 3455","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/647/tI/s1010/i"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Section 817(h) of the 1986 Code shall not apply until ","children":[{"tag":"date","attrib":{"date":"1989-01-01"},"text":"January 1, 1989","children":[],"tail":", with respect to a variable contract (as defined in section 817(d) of the 1986 Code) if—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such contract provides for the payment of an immediate annuity (as defined in section 72(u)(4) of the 1986 Code),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such contract was outstanding on ","children":[{"tag":"date","attrib":{"date":"1986-09-12"},"text":"September 12, 1986","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the segregated asset account on which such contract is based was, on ","children":[{"tag":"date","attrib":{"date":"1986-09-12"},"text":"September 12, 1986","children":[],"tail":", wholly invested in deposits insured by the Federal Deposit Insurance Corporation or the Federal Savings and Loan Insurance Corporation.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4410dd78-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Insurance-Dedicated Exchange-Traded Funds","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dT/tII/s203"},"text":"Pub. L. 117–328, div. T, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5333"},"text":"136 Stat. 5333","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dT/tII/s203"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than the date which is 7 years after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":"], the Secretary of the Treasury (or the Secretary’s delegate) shall amend the regulation issued by the Department of the Treasury relating to ‘Income Tax; Diversification Requirements for Variable Annuity, Endowment, and Life Insurance Contracts’, 54 Fed. Reg. 8728 ("},{"tag":"date","attrib":{"date":"1989-03-02"},"text":"March 2, 1989","children":[],"tail":"), and make any necessary corresponding amendments to other regulations, in order to facilitate the use of exchange-traded funds as investment options under variable contracts within the meaning of section 817(d) of the Internal Revenue Code of 1986, in accordance with subsections (b) and (c) of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designate Certain Authorized Participants and Market Makers as Eligible Investors","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Treasury (or the Secretary’s delegate) shall amend Treas. Reg. section 1.817–5(f)(3) to provide that satisfaction of the requirements in Treas. Reg. section 1.817–5(f)(2)(i) with respect to an exchange-traded fund shall not be prevented by reason of beneficial interests in such a fund being held by 1 or more authorized participants or market makers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Define Relevant Terms","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In amending Treas. Reg. section 1.817–5(f)(3) in accordance with subsection (b), the Secretary of the Treasury (or the Secretary’s delegate) shall provide definitions consistent with the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exchange-traded fund","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘exchange-traded fund’ means a regulated investment company, partnership, or trust—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is registered with the Securities and Exchange Commission as an open-end investment company or a unit investment trust;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the shares of which can be purchased or redeemed directly from the fund only by an authorized participant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the shares of which are traded throughout the day on a national stock exchange at market prices that may or may not be the same as the net asset value of the shares.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorized participant","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘authorized participant’ means a financial institution that is a member or participant of a clearing agency registered under section 17A(b) of the Securities Exchange Act of 1934 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78q–1/b"},"text":"15 U.S.C. 78q–1(b)","children":[],"tail":"] that enters into a contractual relationship with an exchange-traded fund pursuant to which the financial institution is permitted to purchase and redeem shares directly from the fund and to sell such shares to third parties, but only if the contractual arrangement or applicable law precludes the financial institution from—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchasing the shares for its own investment purposes rather than for the exclusive purpose of creating and redeeming such shares on behalf of third parties; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" selling the shares to third parties who are not market makers or otherwise described in Treas. Reg. section 1.817–5(f) (1) and (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Market maker","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘market maker’ means a financial institution that is a registered broker or dealer under section 15(b) of the Securities Exchange Act of 1934 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78"},"text":"15 U.S.C. 78","children":[],"tail":null},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(b)] that maintains liquidity for an exchange-traded fund on a national stock exchange by being always ready to buy and sell shares of such fund on the market, but only if the financial institution is contractually or legally precluded from selling or buying such shares to or from persons who are not authorized participants or otherwise described in Treas. Reg. section 1.817–5(f) (2) and (3)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall apply to segregated asset account investments made on or after the date which is 7 years after the date of the enactment of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4410dd79-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Plan Amendments Not Required Until January 1, 1989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions directing that if any amendments made by subtitle A or subtitle C of title XI [§§ 1101–1147 and 1171–1177] or title XVIII [§§ 1800–1899A] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" require an amendment to any plan, such plan amendment shall not be required to be made before the first plan year beginning on or after "},{"tag":"date","attrib":{"date":"1989-01-01"},"text":"Jan. 1, 1989","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1140"},"text":"section 1140 of Pub. L. 99–514","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s401"},"text":"section 401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
