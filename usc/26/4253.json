{"tag":"section","attrib":{"id":"id45c9ff16-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4253"},"text":null,"children":[{"tag":"num","attrib":{"value":"4253"},"text":"§ 4253.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemptions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45c9ff17-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4253/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain coin-operated service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Service paid for by inserting coins in coin-operated telephones available to the public shall not be subject to the tax imposed by section 4251 with respect to local telephone service, or with respect to toll telephone service if the charge for such toll telephone service is less than 25 cents; except that where such coin-operated telephone service is furnished for a guaranteed amount, the amounts paid under such guarantee plus any fixed monthly or other periodic charge shall be subject to the tax.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45c9ff18-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4253/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" News services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No tax shall be imposed under section 4251, except with respect to local telephone service, on any payment received from any person for services used in the collection of news for the public press, or a news ticker service furnishing a general news service similar to that of the public press, or radio broadcasting, or in the dissemination of news through the public press, or a news ticker service furnishing a general news service similar to that of the public press, or by means of radio broadcasting, if the charge for such service is billed in writing to such person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45c9ff19-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4253/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International, etc., organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No tax shall be imposed under section 4251 on any payment received for services furnished to an international organization, or to the American National Red Cross.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45c9ff1a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4253/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Servicemen in combat zone","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No tax shall be imposed under section 4251 on any payment received for any toll telephone service which originates within a combat zone, as defined in section 112, from a member of the Armed Forces of the United States performing service in such combat zone, as determined under such section, provided a certificate, setting forth such facts as the Secretary may by regulations prescribe, is furnished to the person receiving such payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45c9ff1b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4253/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Items otherwise taxed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Only one payment of tax under section 4251 shall be required with respect to the tax on any service, notwithstanding the lines or stations of one or more persons are used in furnishing such service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45c9ff1c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4253/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Common carriers and communications companies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No tax shall be imposed under section 4251 on the amount paid for any toll telephone service described in section 4252(b)(2) to the extent that the amount so paid is for use by a common carrier, telephone or telegraph company, or radio broadcasting station or network in the conduct of its business as such.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45c9ff1d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4253/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Installation charges","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No tax shall be imposed under section 4251 on so much of any amount paid for the installation of any instrument, wire, pole, switchboard, apparatus, or equipment as is properly attributable to such installation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45c9ff1e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4253/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonprofit hospitals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No tax shall be imposed under section 4251 on any amount paid by a nonprofit hospital for services furnished to such organization. For purposes of this subsection, the term “nonprofit hospital” means a hospital referred to in section 170(b)(1)(A)(iii) which is exempt from income tax under section 501(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45c9ff1f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4253/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State and local governmental exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under regulations prescribed by the Secretary, no tax shall be imposed under section 4251 upon any payment received for services or facilities furnished to the government of any State, or any political subdivision thereof, or the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45c9ff20-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4253/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption for nonprofit educational organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under regulations prescribed by the Secretary, no tax shall be imposed under section 4251 on any amount paid by a nonprofit educational organization for services or facilities furnished to such organization. For purposes of this subsection, the term “nonprofit educational organization” means an educational organization described in section 170(b)(1)(A)(ii) which is exempt from income tax under section 501(a). The term also includes a school operated as an activity of an organization described in section 501(c)(3) which is exempt from income tax under section 501(a), if such school normally maintains a regular faculty and curriculum and normally has a regularly enrolled body of pupils or students in attendance at the place where its educational activities are regularly carried on.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45cc7021-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4253/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption for qualified blood collector organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under regulations provided by the Secretary, no tax shall be imposed under section 4251 on any amount paid by a qualified blood collector organization (as defined in section 7701(a)(49)) for services or facilities furnished to such organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45cc7022-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4253/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filing of exemption certificates","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45cc7023-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4253/l/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to claim an exemption under subsection (c), (h), (i), (j), or (k), a person shall provide to the provider of communications services a statement (in such form and manner as the Secretary may provide) certifying that such person is entitled to such exemption.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45cc7024-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4253/l/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of certificate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any statement provided under paragraph (1) shall remain in effect until—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45cc7025-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4253/l/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provider of communications services has actual knowledge that the information provided in such statement is false, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45cc7026-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4253/l/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such provider is notified by the Secretary that the provider of the statement is no longer entitled to an exemption described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"If any information provided in such statement is no longer accurate, the person providing such statement shall inform the provider of communications services within 30 days of any change of information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45cc7027-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/504"},"text":"68A Stat. 504","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/tI/s133/a"},"text":"Pub. L. 85–859, title I, § 133(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1290"},"text":"72 Stat. 1290","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/344/s4/a"},"text":"Pub. L. 86–344, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-21"},"text":"Sept. 21, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/619"},"text":"73 Stat. 619","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/508/s4/b"},"text":"Pub. L. 87–508, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-06-28"},"text":"June 28, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/115"},"text":"76 Stat. 115","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/44/tIII/s302"},"text":"Pub. L. 89–44, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-06-21"},"text":"June 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/146"},"text":"79 Stat. 146","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/368/tII/s202/b"},"text":"Pub. L. 89–368, title II, § 202(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-03-15"},"text":"Mar. 15, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/66"},"text":"80 Stat. 66","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/tI/s101/j/27"},"text":"Pub. L. 91–172, title I, § 101(j)(27)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/529"},"text":"83 Stat. 529","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX"},"text":"Pub. L. 94–455, title XIX","children":[],"tail":", §§ 1904(a)(6), 1906(b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1811"},"text":"90 Stat. 1811","children":[],"tail":", 1834; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11217/c/1"},"text":"Pub. L. 101–508, title XI, § 11217(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-438"},"text":"104 Stat. 1388–438","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/280/tXII/s1207/c"},"text":"Pub. L. 109–280, title XII, § 1207(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1070"},"text":"120 Stat. 1070","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45cc7028-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45cc7029-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id45cc702a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/s1207/c"},"text":"Section 1207(c) of Pub. L. 109–280","children":[],"tail":", which directed the amendment of section 4253 without specifying the act to be amended, was executed to this section, which is section 4253 of the Internal Revenue Code of 1986, to reflect the probable intent of Congress. See 2006 Amendment notes below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This subchapter, relating to the tax on communications, was repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/364/tI/s105/b/3"},"text":"Pub. L. 90–364, title I, § 105(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-06-28"},"text":"June 28, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/266"},"text":"82 Stat. 266","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/tVII/s702/b/3"},"text":"Pub. L. 91–172, title VII, § 702(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/660"},"text":"83 Stat. 660","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/614/tII/s201/b/3"},"text":"Pub. L. 91–614, title II, § 201(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1843"},"text":"84 Stat. 1843","children":[],"tail":", effective with respect to amounts paid pursuant to bills first rendered on or after "},{"tag":"date","attrib":{"date":"1982-01-01"},"text":"Jan. 1, 1982","children":[],"tail":". In the case of communications services rendered before "},{"tag":"date","attrib":{"date":"1981-11-01"},"text":"Nov. 1, 1981","children":[],"tail":", for which a bill has not been rendered before "},{"tag":"date","attrib":{"date":"1982-01-01"},"text":"Jan. 1, 1982","children":[],"tail":", a bill shall be treated as having been first rendered on "},{"tag":"date","attrib":{"date":"1981-12-31"},"text":"Dec. 31, 1981","children":[],"tail":". Repeal of this subchapter was not executed in view of the amendments to "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4251"},"text":"section 4251 of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/96/499"},"text":"Pub. L. 96–499","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/97/248"},"text":"Pub. L. 97–248","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":", extending the date in (and finally eliminating) provisions which had reduced the tax to zero after a specified date."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45cc702b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (k). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/s1207/c/1"},"text":"Pub. L. 109–280, § 1207(c)(1)","children":[],"tail":", added subsec. (k). Former subsec. (k) redesignated ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"). See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"). "},{"tag":"ref","attrib":{"href":"/us/pl/109/280/s1207/c/1"},"text":"Pub. L. 109–280, § 1207(c)(1)","children":[],"tail":", redesignated subsec. (k) as ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"). See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(1). "},{"tag":"ref","attrib":{"href":"/us/pl/109/280/s1207/c/2"},"text":"Pub. L. 109–280, § 1207(c)(2)","children":[],"tail":", substituted “(j), or (k)” for “or (j)”. See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (k). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" added subsec. (k)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (i), (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1904/a/6"},"text":"Pub. L. 94–455, § 1904(a)(6)","children":[],"tail":", added subsecs. (i) and (j)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172"},"text":"Pub. L. 91–172","children":[],"tail":" substituted “section 170(b)(1)(A)(iii)” for “section 503(b)(5)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/368"},"text":"Pub. L. 89–368","children":[],"tail":" added subsec. (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44"},"text":"Pub. L. 89–44","children":[],"tail":" substituted “with respect to local telephone service, or with respect to toll telephone service if the charge for such toll telephone service is less than 25 cents”, for “with respect to general telephone service, or with respect to toll telephone service or telegraph service if the charge for such toll telephone service or telegraph service is less than 25 cents”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44"},"text":"Pub. L. 89–44","children":[],"tail":" substituted “local telephone service” for “general telephone service” and “such service” for “such services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44"},"text":"Pub. L. 89–44","children":[],"tail":" substituted “International, etc., organizations” for “Certain organizations” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44"},"text":"Pub. L. 89–44","children":[],"tail":" reenacted subsec. (d) without change."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44"},"text":"Pub. L. 89–44","children":[],"tail":" substituted “any service” for “toll telephone service, telegraph service, or teletypewriter exchange service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44"},"text":"Pub. L. 89–44","children":[],"tail":" substituted amounts paid for any toll telephone service for amounts paid for wire mileage service, wire and equipment service, and use of any telephone or radiotelephone line or channel which constitutes general telephone service if such line or channel connects stations between any two of which there would otherwise be a toll charge."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44"},"text":"Pub. L. 89–44","children":[],"tail":" reenacted subsec. (g) without change."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (h) to (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44"},"text":"Pub. L. 89–44","children":[],"tail":" struck out subsecs. (h) to (j), which related to terminal facilities in case of wire mileage service and to certain interior and private communications services."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/508"},"text":"Pub. L. 87–508","children":[],"tail":" adde