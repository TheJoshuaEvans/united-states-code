re than two months before such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/89/44/s701/b/2/A"},"text":"section 701(b)(2)(A) of Pub. L. 89–44","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4251"},"text":"section 4251 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45cc7033-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1962 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/508"},"text":"Pub. L. 87–508","children":[],"tail":" applicable with respect to services furnished on or after "},{"tag":"date","attrib":{"date":"1963-01-01"},"text":"Jan. 1, 1963","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/87/508/s4/c"},"text":"section 4(c) of Pub. L. 87–508","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4252"},"text":"section 4252 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45cc7034-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1959 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/86/344/s4/b"},"text":"Pub. L. 86–344, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-21"},"text":"Sept. 21, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/619"},"text":"73 Stat. 619","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to the provisions of paragraph (2), the amendment made by subsection (a) [amending this section] shall apply with respect to amounts paid on or after ","children":[{"tag":"date","attrib":{"date":"1959-01-01"},"text":"January 1, 1959","children":[],"tail":", for services rendered on or after such date."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendment made by subsection (a) [amending this section] shall not apply with respect to amounts paid pursuant to bills rendered before ","children":[{"tag":"date","attrib":{"date":"1959-01-01"},"text":"January 1, 1959","children":[],"tail":". In the case of amounts paid pursuant to bills rendered on or after such date for services for which no bill was rendered before such date, such amendment shall apply except with respect to such services as were rendered more than 2 months before such date. In the case of services rendered more than 2 months before such date, the provisions of subchapter B of chapter 33 of the Internal Revenue Code of 1986 [formerly I.R.C. 1954] in effect at the time such services were rendered shall apply to the amounts paid for such services.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45cc7035-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1958 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of amendment made by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/s133/b"},"text":"section 133(b) of Pub. L. 85–859","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4251"},"text":"section 4251 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
