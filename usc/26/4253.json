oll telephone service” for “with respect to long distance telephone service upon any payment received for any telephone or radio telephone message”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" substituted “toll telephone service, telegraph service, or teletypewriter exchange service” for “long distance telephone service or telegraph service” and “in furnishing such service” for “in the transmission of such dispatch, message or conversation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" substituted “any wire mileage service or wire and equipment service as is used in the conduct” for “the service described in sections 4252(d) and (e) as is utilized in the conduct”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (g) to (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" added subsecs. (g) to (i)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45cc702c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45cc702d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280"},"text":"Pub. L. 109–280","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2007-01-01"},"text":"Jan. 1, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"