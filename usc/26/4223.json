{"tag":"section","attrib":{"id":"id45c78e97-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4223"},"text":null,"children":[{"tag":"num","attrib":{"value":"4223"},"text":"§ 4223.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules relating to further manufacture","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45c78e98-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4223/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchasing manufacturer to be treated as the manufacturer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this chapter, a manufacturer or producer to whom an article is sold or resold free of tax under section 4221(a)(1) for use by him in further manufacture shall be treated as the manufacturer or producer of such article.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45c78e99-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4223/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation of tax","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the manufacturer or producer referred to in subsection (a) incurs liability for tax under this chapter on his sale or use of an article referred to in subsection (a) and the tax is based on the price for which the article is sold, the article shall be treated as having been sold by him—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45c78e9a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4223/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the price for which the article was sold by him (or, where the tax is on his use of the article, at the price referred to in section 4218(c)); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45c78e9b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4223/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if he so elects and establishes such price to the satisfaction of the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45c78e9c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4223/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the price for which the article was sold to him; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45c78e9d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4223/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the price for which the article was sold by the person who (without regard to subsection (a)) is the manufacturer, producer, or importer of such article.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of this subsection, the price for which the article was sold shall be determined as provided in section 4216. For purposes of paragraph (2) no adjustment or readjustment shall be made in such price by reason of any discount, rebate, allowance, return or repossession of a container or covering, or otherwise. An election under paragraph (2) shall be made in the return reporting the tax applicable to the sale or use of the article, and may not be revoked.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45c78e9e-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tI/s119/a"},"text":"Pub. L. 85–859, title I, § 119(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1285"},"text":"72 Stat. 1285","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/86/418/s2/b"},"text":"Pub. L. 86–418, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-04-08"},"text":"Apr. 8, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/38"},"text":"74 Stat. 38","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tVII/s735/c/10"},"text":"Pub. L. 98–369, div. A, title VII, § 735(c)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/983"},"text":"98 Stat. 983","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45c78e9f-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45c78ea0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id45c78ea1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4223, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/495"},"text":"68A Stat. 495","children":[],"tail":", related to exemption of articles manufactured or produced by Indians, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/s119/a"},"text":"Pub. L. 85–859, § 119(a)","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4225"},"text":"section 4225 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45c78ea2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" substituted “4218(c)” for “section 4218(e)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (b) ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1960—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/418"},"text":"Pub. L. 86–418","children":[],"tail":" substituted “section 4218(e)” for “section 4218(d)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45c78ea3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45c78ea4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" effective, except as otherwise provided, as if included in the provisions of the Highway Revenue Act of 1982, title V of "},{"tag":"ref","attrib":{"href":"/us/pl/97/424"},"text":"Pub. L. 97–424","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s736"},"text":"section 736 of Pub. L. 98–369","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4051"},"text":"section 4051 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45c78ea5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1960 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/418"},"text":"Pub. L. 86–418","children":[],"tail":" applicable only with respect to bicycle tires and tubes sold by the manufacturer, producer, or importer thereof on or after the first day of the first month which begins more than 10 days after "},{"tag":"date","attrib":{"date":"1960-04-08"},"text":"April 8, 1960","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/86/418/s4"},"text":"section 4 of Pub. L. 86–418","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4221"},"text":"section 4221 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
