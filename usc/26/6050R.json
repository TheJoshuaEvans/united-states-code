{"tag":"section","attrib":{"id":"id467f4523-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050R"},"text":null,"children":[{"tag":"num","attrib":{"value":"6050R"},"text":"§ 6050R.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Returns relating to certain purchases of fish","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id467f4524-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050R/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of reporting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Every person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467f4525-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050R/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is engaged in the trade or business of purchasing fish for resale from any person engaged in the trade or business of catching fish; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467f4526-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050R/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who makes payments in cash in the course of such trade or business to such a person of $600 or more during any calendar year for the purchase of fish,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall make a return (at such times as the Secretary may prescribe) described in subsection (b) with respect to each person to whom such a payment was made during such calendar year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467f4527-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050R/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Return","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A return is described in this subsection if such return—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467f4528-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050R/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in such form as the Secretary may prescribe, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467f4529-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050R/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" contains—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id467f452a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050R/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address, and TIN of each person to whom a payment described in subsection (a)(2) was made during the calendar year,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467f452b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050R/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amount of such payments made to such person during such calendar year and the date and amount of each such payment, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467f452c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050R/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467f452d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050R/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement to be furnished with respect to whom information is required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Every person required to make a return under subsection (a) shall furnish to each person whose name is required to be set forth in such return a written statement showing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467f452e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050R/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address, and phone number of the information contact of the person required to make such a return, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467f452f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050R/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amount of payments to the person required to be shown on the return.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The written statement required under the preceding sentence shall be furnished to the person on or before January 31 of the year following the calendar year for which the return under subsection (a) is required to be made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467f4530-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050R/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467f4531-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050R/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cash","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “cash” has the meaning given such term by section 6050I(d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467f4532-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050R/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fish","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “fish” includes other forms of aquatic life.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id467f4533-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1116/b/1"},"text":"Pub. L. 104–188, title I, § 1116(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1763"},"text":"110 Stat. 1763","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXVI/s1601/a"},"text":"Pub. L. 105–34, title XVI, § 1601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1086"},"text":"111 Stat. 1086","children":[],"tail":"; "},{"tag":"ref","attrib":{"hre