{"tag":"section","attrib":{"id":"id45d37564-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4371"},"text":null,"children":[{"tag":"num","attrib":{"value":"4371"},"text":"§ 4371.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of tax","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"There is hereby imposed, on each policy of insurance, indemnity bond, annuity contract, or policy of reinsurance issued by any foreign insurer or reinsurer, a tax at the following rates:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45d37565-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4371/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Casualty insurance and indemnity bonds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"4 cents on each dollar, or fractional part thereof, of the premium paid on the policy of casualty insurance or the indemnity bond, if issued to or for, or in the name of, an insured as defined in section 4372(d);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45d37566-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4371/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Life insurance, sickness, and accident policies, and annuity contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"1 cent on each dollar, or fractional part thereof, of the premium paid on the policy of life, sickness, or accident insurance, or annuity contract; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45d37567-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4371/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reinsurance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"1 cent on each dollar, or fractional part thereof, of the premium paid on the policy of reinsurance covering any of the contracts taxable under paragraph (1) or (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45d37568-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/521"},"text":"68A Stat. 521","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1956-03-13/ch83/s5/9"},"text":"Mar. 13, 1956, ch. 83, § 5(9)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/49"},"text":"70 Stat. 49","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/tI/s141/a"},"text":"Pub. L. 85–859, title I, § 141(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1300"},"text":"72 Stat. 1300","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/69/s3/f/3"},"text":"Pub. L. 86–69, § 3(f)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-06-25"},"text":"June 25, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/140"},"text":"73 Stat. 140","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/44/tVIII/s804/b"},"text":"Pub. L. 89–44, title VIII, § 804(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-06-21"},"text":"June 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/160"},"text":"79 Stat. 160","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/