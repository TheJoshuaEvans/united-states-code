{"tag":"section","attrib":{"id":"id417ec179-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139B"},"text":null,"children":[{"tag":"num","attrib":{"value":"139B"},"text":"§ 139B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefits provided to volunteer firefighters and emergency medical responders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id417ec17a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139B/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any member of a qualified volunteer emergency response organization, gross income shall not include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id417ec17b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139B/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any qualified State and local tax benefit, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id417ec17c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139B/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any qualified payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id417ec17d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139B/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial of double benefits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any member of a qualified volunteer emergency response organization—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id417ec17e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139B/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deduction under 164 shall be determined with regard to any qualified State and local tax benefit, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id417ec17f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139B/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expenses paid or incurred by the taxpayer in connection with the performance of services as such a member shall be taken into account under section 170 only to the extent such expenses exceed the amount of any qualified payment excluded from gross income under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id417ec180-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139B/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id417ec181-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139B/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified State and local tax benefit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified state and local tax benefit” means any reduction or rebate of a tax described in paragraph (1), (2), or (3) of section 164(a) provided by a State or political division thereof on account of services performed as a member of a qualified volunteer emergency response organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id417ec182-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139B/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified payment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id417ec183-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139B/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified payment” means any payment (whether reimbursement or otherwise) provided by a State or political division thereof on account of the performance of services as a member of a qualified volunteer emergency response organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id417ec184-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139B/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable dollar limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount determined under subparagraph (A) for any taxable year shall not exceed $50 multiplied by the number of months during such year that the taxpayer performs such services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id417ec185-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139B/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified volunteer emergency response organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified volunteer emergency response organization” means any volunteer organization—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id417ec186-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139B/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is organized and operated to provide firefighting or emergency medical services for persons in the State or political subdivision, as the case may be, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id417ec187-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139B/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is required (by written agreement) by the State or political subdivision to furnish firefighting or emergency medical services in such State or political subdivision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id417ec188-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/142/s5/a"},"text":"Pub. L. 110–142, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-20"},"text":"Dec. 20, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1805"},"text":"121 Stat. 1805","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/dO/tIII/s301/a"},"text":"Pub. L. 116–94, div. O, title III, § 301(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3175"},"text":"133 Stat. 3175","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dEE/tI/s103/a"},"text":"Pub. L. 116–260, div. EE, title I, § 103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3040"},"text":"134 Stat. 3040","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id41810a79-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id41810a7a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id41810a7b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" struck out subsec. (d). Text read as follows: “This section shall not apply with respect to taxable years beginning—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) after ","children":[{"tag":"date","attrib":{"date":"2010-12-31"},"text":"December 31, 2010","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"2020-01-01"},"text":"January 1, 2020","children":[],"tail":", or"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) after ","children":[{"tag":"date","attrib":{"date":"2020-12-31"},"text":"December 31, 2020","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s301/a"},"text":"Pub. L. 116–94, § 301(a)","children":[],"tail":", substituted “$50” for “$30”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s301/b"},"text":"Pub. L. 116–94, § 301(b)","children":[],"tail":", substituted “beginning—” for “beginning after "},{"tag":"date","attrib":{"date":"2010-12-31"},"text":"December 31, 2010","children":[],"tail":".” and added pars. (1) and (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id41810a7c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id41810a7d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dEE/tI/s103/b"},"text":"Pub. L. 116–260, div. EE, title I, § 103(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3040"},"text":"134 Stat. 3040","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/260/dEE/tI/s103/b"},"text":"“The amendment made by this section [amending this section] shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2020-12-31"},"text":"December 31, 2020","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id41810a7e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2019 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dO/tIII/s301/d"},"text":"Pub. L. 116–94, div. O, title III, § 301(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3175"},"text":"133 Stat. 3175","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/94/dO/tIII/s301/d"},"text":"“The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s3121"},"text":"section 3121 of this title","children":[],"tail":"] shall apply to taxable years beginning after "},{"tag":"date","attrib":{"date":"2019-12-31"},"text":"December 31, 2019","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id41810a7f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/142/s5/c"},"text":"Pub. L. 110–142, § 5(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-20"},"text":"Dec. 20, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1806"},"text":"121 Stat. 1806","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/142/s5/c"},"text":"“The amendments made by this section [enacting this section] shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2007-12-31"},"text":"December 31, 2007","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
