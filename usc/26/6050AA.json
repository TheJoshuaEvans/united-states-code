{"tag":"section","attrib":{"id":"id4681900e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050AA"},"text":null,"children":[{"tag":"num","attrib":{"value":"6050AA"},"text":"§ 6050AA.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Returns relating to applicable passenger vehicle loan interest received in trade or business from individuals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4681900f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050AA/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46819010-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050AA/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is engaged in a trade or business, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46819011-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050AA/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who, in the course of such trade or business, receives from any individual interest aggregating $600 or more for any calendar year on a specified passenger vehicle loan,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall make the return described in subsection (b) with respect to each individual from whom such interest was received at such time as the Secretary may provide.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46819012-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050AA/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form and manner of returns","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A return is described in this subsection if such return—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46819013-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050AA/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in such form as the Secretary may prescribe, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46819014-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050AA/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" contains—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46819015-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050AA/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name and address of the individual from whom the interest described in subsection (a)(2) was received,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46819016-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050AA/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of such interest received for the calendar year,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46819017-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050AA/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of outstanding principal on the specified passenger vehicle loan as of the beginning of such calendar year,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46819018-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050AA/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of the origination of such loan,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46819019-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050AA/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the year, make, model, and vehicle identification number of the applicable passenger vehicle which secures such loan (or such other description of such vehicle as the Secretary may prescribe), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4681901a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050AA/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4681901b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050AA/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statements to be furnished to individuals with respect to whom information is required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Every person required to make a return under subsection (a) shall furnish to each individual whose name is required to be set forth in such return a written statement showing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4681901c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050AA/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address, and phone number of the information contact of the person required to make such return, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4681901d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050AA/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information described in subparagraphs (B), (C), (D), and (E) of subsection (b)(2) with respect to such individual (and such information as is described in subsection (b)(2)(F) with respect to such individual as the Secretary may provide for purposes of this subsection).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The written statement required under the preceding sentence shall be furnished on or before January 31 of the year following the calendar year for which the return under subsection (a) was required to be made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4681901e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050AA/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4681901f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050AA/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Terms used in this section which are also used in paragraph (4) of section 163(h) shall have the same meaning as when used in such paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46819020-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050AA/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specified passenger vehicle loan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “specified passenger vehicle loan” means the indebtedness described in section 163(h)(4)(B) with respect to any applicable passenger vehicle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46819021-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050AA/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall issue such regulations or other guidance as may be necessary or appropriate to carry out the purposes of this section, including regulations or other guidance to prevent the duplicate reporting of information under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46819022-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050AA/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No return shall be required under this section for any period to which section 163(h)(4) does not apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46819023-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70203/c/1"},"text":"Pub. L. 119–21, title VII, § 70203(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/178"},"text":"139 Stat. 178","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46819024-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46819025-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id46819026-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to indebtedness incurred after ","children":[{"tag":"date","attrib":{"date":"2024-12-31"},"text":"Dec. 31, 2024","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70203/e"},"text":"section 70203(e) of Pub. L. 119–21","children":[],"tail":", set out as an Effective Date of 2025 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s56"},"text":"section 56 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
