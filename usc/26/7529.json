{"tag":"section","attrib":{"id":"id4774c86b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7529"},"text":null,"children":[{"tag":"num","attrib":{"value":"7529"},"text":"§ 7529.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of suspected identity theft","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4774c86c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7529/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary determines that there has been or may have been an unauthorized use of the identity of any individual, the Secretary shall, without jeopardizing an investigation relating to tax administration—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4774c86d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7529/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" as soon as practicable—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4774c86e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7529/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the individual of such determination,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4774c86f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7529/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide instructions on how to file a report with law enforcement regarding the unauthorized use,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4774c870-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7529/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify any steps to be taken by the individual to permit law enforcement to access personal information of the individual during the investigation,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4774c871-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7529/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide information regarding actions the individual may take in order to protect the individual from harm relating to the unauthorized use, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4774c872-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7529/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offer identity protection measures to the individual, such as the use of an identity protection personal identification number, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4774c873-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7529/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" at the time the information described in paragraph (1) is provided (or, if not available at such time, as soon as practicable thereafter), issue additional notifications to such individual (or such individual’s designee) regarding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4774c874-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7529/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether an investigation has been initiated in regards to such unauthorized use,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4774c875-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7529/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the investigation substantiated an unauthorized use of the identity of the individual, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4774c876-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7529/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" whether—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4774c877-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7529/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any action has been taken against a person relating to such unauthorized use, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4774c878-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7529/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any referral has been made for criminal prosecution of such person and, to the extent such information is available, whether such person has been criminally charged by indictment or information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4774c879-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7529/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment-related identity theft","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4774c87a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7529/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the unauthorized use of the identity of an individual includes the unauthorized use of the identity of the individual to obtain employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4774c87b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7529/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of employment-related identity theft","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, in making a determination as to whether there has been or may have been an unauthorized use of the identity of an individual to obtain employment, the Secretary shall review any information—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4774c87c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7529/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtained from a statement described in section 6051 or an information return relating to compensation for services rendered other than as an employee, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4774c87d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7529/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provided to the Internal Revenue Service by the Social Security Administration regarding any statement described in section 6051,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"which indicates that the social security account number provided on such statement or information return does not correspond with the name provided on such statement or information return or the name on the tax return reporting the income which is included on such statement or information return.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4774c87e-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/25/tII/s2007/a"},"text":"Pub. L. 116–25, title II, § 2007(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-07-01"},"text":"July 1, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1005"},"text":"133 Stat. 1005","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4774c87f-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4774c880-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4774c881-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2019 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/25/tII/s2007/d"},"text":"Pub. L. 116–25, title II, § 2007(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-07-01"},"text":"July 1, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1006"},"text":"133 Stat. 1006","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/25/tII/s2007/d"},"text":"“The amendments made by this section [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s432"},"text":"section 432 of Title 42","children":[],"tail":", The Public Health and Welfare] shall apply to determinations made after the date that is 6 months after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2019-07-01"},"text":"July 1, 2019","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4774c882-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Public-Private Partnership To Address Identity Theft Refund Fraud","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/25/tII/s2001"},"text":"Pub. L. 116–25, title II, § 2001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-07-01"},"text":"July 1, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1001"},"text":"133 Stat. 1001","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/25/tII/s2001"},"text":"“The Secretary of the Treasury (or the Secretary’s delegate) shall work collaboratively with the public and private sectors to protect taxpayers from identity theft refund fraud.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4774c883-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Information Sharing and Analysis Center","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/25/tII/s2003/a"},"text":"Pub. L. 116–25, title II, § 2003(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2019-07-01"},"text":"July 1, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1001"},"text":"133 Stat. 1001","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/25/tII/s2003/a"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Treasury (or the Secretary’s delegate) may participate in an information sharing and analysis center to centralize, standardize, and enhance data compilation and analysis to facilitate sharing actionable data and information with respect to identity theft tax refund fraud.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Development of Performance Metrics","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Treasury (or the Secretary’s delegate) shall develop metrics for measuring the success of such center in detecting and preventing identity theft tax refund fraud.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4774c884-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Single Point of Contact for Tax-Related Identity Theft Victims","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/25/tII/s2006"},"text":"Pub. L. 116–25, title II, § 2006","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-07-01"},"text":"July 1, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1004"},"text":"133 Stat. 1004","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/25/tII/s2006"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Treasury (or the Secretary’s delegate) shall establish and implement procedures to ensure that any taxpayer whose return has been delayed or otherwise adversely affected due to tax-related identity theft has a single point of contact at the Internal Revenue Service throughout the processing of the taxpayer’s case. The single point of contact shall track the taxpayer’s case to completion and coordinate with other Internal Revenue Service employees to resolve case issues as quickly as possible.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Single Point of Contact.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a), the single point of contact shall consist of a team or subset of specially trained employees who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have the ability to work across functions to resolve the issues involved in the taxpayer’s case; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be accountable for handling the case until its resolution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Team or subset","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The employees included within the team or subset described in paragraph (1) may change as required to meet the needs of the Internal Revenue Service, provided that procedures have been established to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure continuity of records and case history; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the taxpayer when appropriate.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4774c885-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Examination of Both Paper and Electronic Statements and Returns","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/25/tII/s2007/b/1"},"text":"Pub. L. 116–25, title II, § 2007(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-07-01"},"text":"July 1, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1006"},"text":"133 Stat. 1006","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/25/tII/s2007/b/1"},"text":"“The Secretary of the Treasury (or the Secretary’s delegate) shall examine the statements, information returns, and tax returns described in section 7529(b)(2) of the Internal Revenue Code of 1986 (as added by subsection (a)) for any evidence of employment-related identity theft, regardless of whether such statements or returns are submitted electronically or on paper.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4774c886-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Underreporting of Income","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/25/tII/s2007/b/3"},"text":"Pub. L. 116–25, title II, § 2007(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-07-01"},"text":"July 1, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1006"},"text":"133 Stat. 1006","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/25/tII/s2007/b/3"},"text":"“The Secretary of the Treasury (or the Secretary’s delegate) shall establish procedures to ensure that income reported in connection with the unauthorized use of a taxpayer’s identity is not taken into account in determining any penalty for underreporting of income by the victim of identity theft.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4774c887-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Guidelines for Stolen Identity Refund Fraud Cases","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/25/tII/s2008"},"text":"Pub. L. 116–25, title II, § 2008","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-07-01"},"text":"July 1, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1006"},"text":"133 Stat. 1006","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/25/tII/s2008"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2019-07-01"},"text":"July 1, 2019","children":[],"tail":"], the Secretary of the Treasury (or the Secretary’s delegate), in consultation with the National Taxpayer Advocate, shall develop and implement publicly available guidelines for management of cases involving stolen identity refund fraud in a manner that reduces the administrative burden on taxpayers who are victims of such fraud."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standards and Procedures To Be Considered","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The guidelines described in subsection (a) may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" standards for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average length of time in which a case involving stolen identity refund fraud should be resolved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maximum length of time, on average, a taxpayer who is a victim of stolen identity refund fraud and is entitled to a tax refund which has been stolen should have to wait to receive such refund; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maximum number of offices and employees within the Internal Revenue Service with whom a taxpayer who is a victim of stolen identity refund fraud should be required to interact in order to resolve a case;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standards for opening, assigning, reassigning, or closing a case involving stolen identity refund fraud; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures for implementing and accomplishing the standards described in paragraphs (1) and (2), and measures for evaluating such procedures and determining whether such standards have been successfully implemented.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
