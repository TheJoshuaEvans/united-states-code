{"tag":"section","attrib":{"id":"id45f295fc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4963"},"text":null,"children":[{"tag":"num","attrib":{"value":"4963"},"text":"§ 4963.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45f295fd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4963/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First tier tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subchapter, the term “first tier tax” means any tax imposed by subsection (a) of section 4941, 4942, 4943, 4944, 4945, 4951, 4952, 4955, 4958, 4966, 4967, 4971, or 4975.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45f295fe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4963/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Second tier tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subchapter, the term “second tier tax” means any tax imposed by subsection (b) of section 4941, 4942, 4943, 4944, 4945, 4951, 4952, 4955, 4958, 4971, or 4975.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45f295ff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4963/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable event","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subchapter, the term “taxable event” means any act (or failure to act) giving rise to liability for tax under section 4941, 4942, 4943, 4944, 4945, 4951, 4952, 4955, 4958, 4966, 4967, 4971, or 4975.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45f29600-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4963/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Correct","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45f29601-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4963/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), the term “correct” has the same meaning as when used in the section which imposes the second tier tax.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f29602-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4963/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “correct” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45f29603-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4963/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the second tier tax imposed by section 4942(b), reducing the amount of the undistributed income to zero,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f29604-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4963/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the second tier tax imposed by section 4943(b), reducing the amount of the excess business holdings to zero, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f29605-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4963/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the second tier tax imposed by section 4944, removing the investment from jeopardy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45f29606-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4963/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Correction period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45f29607-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4963/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “correction period” means, with respect to any taxable event, the period beginning on the date on which such event occurs and ending 90 days after the date of mailing under section 6212 of a notice of deficiency with respect to the second tier tax imposed on such taxable event, extended by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45f29608-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4963/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any period in which a deficiency cannot be assessed under section 6213(a) (determined without regard to the last sentence of section 4961(b)), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f29609-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4963/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other period which the Secretary determines is reasonable and necessary to bring about correction of the taxable event.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f2960a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4963/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for when taxable event occurs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), the taxable event shall be treated as occurring—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45f2960b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4963/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of section 4942, on the first day of the taxable year for which there was a failure to distribute income,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f2960c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4963/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of section 4943, on the first day on which there are excess business holdings,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f2960d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4963/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of section 4971, on the last day of the plan year in which there is an accumulated funding deficiency, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f2960e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4963/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any other case, the date on which such event occurred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45f2960f-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/596/s2/c/1"},"text":"Pub. L. 96–596, § 2(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-24"},"text":"Dec. 24, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3473"},"text":"94 Stat. 3473","children":[],"tail":", § 4962; renumbered § 4963, "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tIII/s305/a"},"text":"Pub. L. 98–369, div. A, title III, § 305(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/783"},"text":"98 Stat. 783","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX/s10712/b/3"},"text":"Pub. L. 100–203, title X, § 10712(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-467"},"text":"101 Stat. 1330–467","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/168/tXIII/s1311/c/2"},"text":"Pu