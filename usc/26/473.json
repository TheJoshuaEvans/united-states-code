{"tag":"section","attrib":{"id":"id439e6cba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s473"},"text":null,"children":[{"tag":"num","attrib":{"value":"473"},"text":"§ 473.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified liquidations of LIFO inventories","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id439e6cbb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s473/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, for any liquidation year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id439e6cbc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s473/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a qualified liquidation of goods which the taxpayer inventories under the LIFO method, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id439e6cbd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s473/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taxpayer elects to have the provisions of this section apply with respect to such liquidation,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then the gross income of the taxpayer for such taxable year shall be adjusted as provided in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id439e6cbe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s473/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment for replacements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the liquidated goods are replaced (in whole or in part) during any replacement year and such replacement is reflected in the closing inventory for such year, then the gross income for the liquidation year shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id439e6cbf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s473/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" decreased by an amount equal to the excess of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id439e6cc0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s473/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate replacement cost of the liquidated goods so replaced during such year, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id439e6cc1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s473/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate cost of such goods reflected in the opening inventory of the liquidation year, or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id439e6cc2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s473/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" increased by an amount equal to the excess of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id439e6cc3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s473/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate cost reflected in such opening inventory of the liquidated goods so replaced during such year, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id439e6cc4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s473/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such aggregate replacement cost.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id439e6cc5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s473/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified liquidation defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id439e6cc6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s473/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified liquidation” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id439e6cc7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s473/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a decrease in the closing inventory of the liquidation year from the opening inventory of such year, but only if","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id439e6cc8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s473/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taxpayer establishes to the satisfaction of the Secretary that such decrease is directly and primarily attributable to a qualified inventory interruption.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id439e6cc9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s473/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified inventory interruption defined","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id439e6cca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s473/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified inventory interruption” means a regulation, request, or interruption described in subparagraph (B) but only to the extent provided in the notice published pursuant to subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id439e6ccb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s473/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination by Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whenever the Secretary, after consultation with the appropriate Federal officers, determines—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id439e6ccc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s473/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id439e6ccd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s473/c/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Department of Energy regulation or request with respect to energy supplies, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id439e6cce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s473/c/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any embargo, international boycott, or other major foreign trade interruption,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":" has made difficult or impossible the replacement during the liquidation year of any class of goods for any class of taxpayers, and","children":[],"tail":"\n"},{"tag":"clause","attrib":{"id":"id439e6ccf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s473/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the application of this section to that class of goods and taxpayers is necessary to carry out the purposes of this section,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"he shall publish a notice of such determinations in the Federal Register, together with the period to be affected by such notice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id439e6cd0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s473/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other definitions and special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id439e6cd1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s473/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liquidation year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “liquidation year” means the taxable year in which occurs the qualified liquidation to which this section applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id439e6cd2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s473/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Replacement year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “replacement year” means any taxable year in the replacement period; except that such term shall not include any taxable year after the taxable year in which replacement of the liquidated goods is completed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id439e6cd3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s473/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Replacement period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “replacement period” means the shorter of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id439e6cd4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s473/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period of the 3 taxable years following the liquidation year, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id439e6cd5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s473/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period specified by the Secretary in a notice published in the Federal Register with respect to that qualified inventory interruption.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Any period specified by the Secretary under subparagraph (B) may be modified by the Secretary in a subsequent notice published in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id439e6cd6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s473/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" LIFO method","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “LIFO method” means the method of inventorying goods described in section 472.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id439e6cd7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s473/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id439e6cd8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s473/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An election under subsection (a) shall be made subject to such conditions, and in such manner and form and at such time, as the Secretary may prescribe by regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id439e6cd9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s473/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Irrevocable election","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An election under this section shall be irrevocable and shall be binding for the liquidation year and for all determinations for prior and subsequent taxable years insofar as such determinations are affected by the adjustments under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id439e6cda-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s473/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Replacement; inventory basis","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id439e6cdb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s473/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Replacements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the closing inventory of the taxpayer for any replacement year reflects an increase over the opening inventory of such goods for such year, the goods reflecting such increase shall be considered, in the order of their acquisition, as having been acquired in replacement of the goods most recently liquidated (whether or not in a qualified liquidation) and not previously replaced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id439e6cdc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s473/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount at which replacement goods taken into account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any qualified liquidation, any goods considered under paragraph (1) as having been acquired in replacement of the goods liquidated in such liquidation shall be taken into purchases and included in the closing inventory of the taxpayer for the replacement year at the inventory cost basis of the goods replaced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id439e6cdd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s473/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for application of adjustments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id439e6cde-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s473/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id439e6cdf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s473/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an adjustment is required under this section for any taxable year by reason of the replacement of liquidated goods during any replacement year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id439e6ce0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s473/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the assessment of a deficiency, or the allowance of a credit or refund of an overpayment of tax attributable to such adjustment, for any taxable year, is otherwise prevented by the operation of any law or rule of law (other than section 7122, relating to compromises),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then such deficiency may be assessed, or credit or refund allowed, within the period prescribed for assessing a deficiency or allowing a credit or refund for the replacement year if a notice for deficiency is mailed, or claim for refund is filed, within such period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id439e6ce1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s473/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Solely for purposes of determining interest on any overpayment or underpayment attributable to an adjustment made under this section, such overpayment or underpayment shall be treated as an overpayment or underpayment (as the case may be) for the replacement year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id439e6ce2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s473/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with section 472","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such regulations as may be necessary to coordinate the provisions of this section with the provisions of section 472.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id439e6ce3-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/223/tIV/s403/a/1"},"text":"Pub. L. 96–223, title IV, § 403(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-04-02"},"text":"Apr. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/302"},"text":"94 Stat. 302","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id439e6ce4-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id439e6ce5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id439e6ce6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/223/tIV/s403/a/3"},"text":"Pub. L. 96–223, title IV, § 403(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-04-02"},"text":"Apr. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/304"},"text":"94 Stat. 304","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"“The amendments made by paragraphs (1) and (2) [enacting this section] shall apply to qualified liquidations (within the meaning of section 473(c) of the Internal Revenue Code of 1986 [formerly I.R.C. 1954]) in taxable years ending after ","children":[{"tag":"date","attrib":{"date":"1979-10-31"},"text":"October 31, 1979","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
