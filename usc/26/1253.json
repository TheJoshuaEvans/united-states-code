{"tag":"section","attrib":{"id":"id44cf995e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1253"},"text":null,"children":[{"tag":"num","attrib":{"value":"1253"},"text":"§ 1253.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers of franchises, trademarks, and trade names","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44cf995f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1253/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A transfer of a franchise, trademark, or trade name shall not be treated as a sale or exchange of a capital asset if the transferor retains any significant power, right, or continuing interest with respect to the subject matter of the franchise, trademark, or trade name.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44cf9960-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1253/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44cf9961-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1253/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Franchise","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “franchise” includes an agreement which gives one of the parties to the agreement the right to distribute, sell, or provide goods, services, or facilities, within a specified area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44cf9962-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1253/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Significant power, right, or continuing interest","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “significant power, right, or continuing interest” includes, but is not limited to, the following rights with respect to the interest transferred:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44cf9963-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1253/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A right to disapprove any assignment of such interest, or any part thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44cf9964-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1253/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A right to terminate at will.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44cf9965-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1253/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A right to prescribe the standards of quality of products used or sold, or of services furnished, and of the equipment and facilities used to promote such products or services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44cf9966-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1253/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A right to require that the transferee sell or advertise only products or services of the transferor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44cf9967-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1253/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A right to require that the transferee purchase substantially all of his supplies and equipment from the transferor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44cf9968-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1253/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A right to payments contingent on the productivity, use, or disposition of the subject matter of the interest transferred, if such payments constitute a substantial element under the transfer agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44cf9969-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1253/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “transfer” includes the renewal of a franchise, trademark, or trade name.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44cf996a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1253/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of contingent payments by transferor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts received or accrued on account of a transfer, sale, or other disposition of a franchise, trademark, or trade name which are contingent on the productivity, use, or disposition of the franchise, trademark, or trade name transferred shall be treated as amounts received or accrued from the sale or other disposition of property which is not a capital asset.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44cf996b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1253/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of payments by transferee","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44cf996c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1253/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contingent serial payments","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44cf996d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1253/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amount described in subparagraph (B) which is paid or incurred during the taxable year on account of a transfer, sale, or other disposition of a franchise, trademark, or trade name shall be allowed as a deduction under section 162(a) (relating to trade or business expenses).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44cf996e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1253/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts to which paragraph applies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An amount is described in this subparagraph if it—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44cf996f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1253/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is contingent on the productivity, use, or disposition of the franchise, trademark, or trade name, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44cf9970-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1253/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is paid as part of a series of payments—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id44cf9971-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1253/d/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which are payable not less frequently than annually throughout the entire term of the transfer agreement, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id44cf9972-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1253/d/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which are substantially equal in amount (or payable under a fixed formula).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44cf9973-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1253/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amount paid or incurred on account of a transfer, sale, or other disposition of a franchise, trademark, or trade name to which paragraph (1) does not apply shall be treated as an amount chargeable to capital account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44cf9974-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1253/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewals, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of determining the term of a transfer agreement under this section, there shall be taken into account all renewal options (and any other period for which the parties reasonably expect the agreement to be renewed).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44cf9975-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172/tV/s516/c/1"},"text":"Pub. L. 91–172, title V, § 516(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/647"},"text":"83 Stat. 647","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7622/a"},"text":"Pub. L. 101–239, title VII, § 7622(a)","children":[],"tail":"–(c), "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2377"},"text":"103 Stat. 2377","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11701/i"},"text":"Pub. L. 101–508, title XI, § 11701(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-508"},"text":"104 Stat. 1388–508","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13261/c"},"text":"Pub. L. 103–66, title XIII, § 13261(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/539"},"text":"107 Stat. 539","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1704/t/47"},"text":"Pub. L. 104–188, title I, § 1704(t)(47)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1889"},"text":"110 Stat. 1889","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s886/b/3"},"text":"Pub. L. 108–357, title VIII, § 886(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1641"},"text":"118 Stat. 1641","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44cf9976-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44cf9977-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44cf9978-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":" struck out heading and text of subsec. (e). Text read as follows: “This section shall not apply to the transfer of a franchise to engage in professional football, basketball, baseball, or other professional sport.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":" provided that "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/s11701/i"},"text":"section 11701(i) of Pub. L. 101–508","children":[],"tail":" shall be applied as if “subsection” appeared instead of “section” in the material proposed to be stricken. See 1990 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (d)(2) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66"},"text":"Pub. L. 103–66","children":[],"tail":" added pars. (2) and (3) and struck out former pars. (2) relating to deduction of certain payments for transfer of a franchise, trademark, or trade name not treated as sale or exchange of capital asset, (3) relating to treatment of amounts paid or incurred on account of transfer, sale, or other disposition of a franchise, trademark, or trade name to which pars. (1) and (2) did not apply, (4) relating to renewals for purposes of determining term of transfer agreement under this section or period of amortization under this subtitle, and (5) relating to rules applicable to this subsection."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s11701/i"},"text":"Pub. L. 101–508, § 11701(i)","children":[],"tail":", which directed the substitution of “under this section or any period of amortization under this subtitle for any payment described in this section” for “or any period of amortization under this section”, was executed by making the substitution for “or any period of amortization under this subsection”. See 1996 Amendment note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7622/a"},"text":"Pub. L. 101–239, § 7622(a)","children":[],"tail":", substituted “serial payments” for “payments” in heading and amended text generally. Prior to amendment, text read as follows: “Amounts paid or incurred during the taxable year on account of a transfer, sale, or other disposition of a franchise, trademark, or trade name which are contingent on the productivity, use, or disposition of the franchise, trademark, or trade name transferred shall be allowed as a deduction under section 162(a) (relating to trade or business expenses).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7622/b"},"text":"Pub. L. 101–239, § 7622(b)","children":[],"tail":", designated existing provisions as subpar. (A), inserted subpar. heading, redesignated former subpars. (A) to (C) as cls. (i) to (iii), respectively, and former cls. (i) and (ii) of former subpar. (B) as subcls. (I) and (II), respectively, of cl. (ii), and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7622/c"},"text":"Pub. L. 101–239, § 7622(c)","children":[],"tail":", added pars. (3) to (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (d)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44cf9979-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44cf997a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":" applicable to property acquired after "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/s886/c/1"},"text":"section 886(c)(1) of Pub. L. 108–357","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s197"},"text":"section 197 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44cf997b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66"},"text":"Pub. L. 103–66","children":[],"tail":" applicable, except as otherwise provided, with respect to property acquired after "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/s13261/g"},"text":"section 13261(g) of Pub. L. 103–66","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s197"},"text":"section 197 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44cf997c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Revenue Reconciliation Act of 1989, "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII"},"text":"Pub. L. 101–239, title VII","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/s11701/n"},"text":"section 11701(n) of Pub. L. 101–508","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s42"},"text":"section 42 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44cf997d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" applicable to transfers after "},{"tag":"date","attrib":{"date":"1989-10-02"},"text":"Oct. 2, 1989","children":[],"tail":", but not applicable to any transfer pursuant to a written binding contract in effect on "},{"tag":"date","attrib":{"date":"1989-10-02"},"text":"Oct. 2, 1989","children":[],"tail":", and at all times thereafter before the transfer, see section 7622(c)[(e)] of "},{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s167"},"text":"section 167 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id44cf997e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to transfers after ","children":[{"tag":"date","attrib":{"date":"1969-12-31"},"text":"Dec. 31, 1969","children":[],"tail":", except that subsec. (d)(1) shall, at the election of the taxpayer (made at such time and in such manner as the Secretary or his delegate may by regulations prescribe), apply to transfers before "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", but only with respect to payments made in taxable years ending after "},{"tag":"date","attrib":{"date":"1969-12-31"},"text":"Dec. 31, 1969","children":[],"tail":", and beginning before "},{"tag":"date","attrib":{"date":"1980-01-01"},"text":"Jan. 1, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/s516/d/3"},"text":"section 516(d)(3) of Pub. L. 91–172","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
