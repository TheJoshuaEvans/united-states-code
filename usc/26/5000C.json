{"tag":"section","attrib":{"id":"id4613d994-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000C"},"text":null,"children":[{"tag":"num","attrib":{"value":"5000C"},"text":"§ 5000C.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of tax on certain foreign procurement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4613d995-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000C/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby imposed on any foreign person that receives a specified Federal procurement payment a tax equal to 2 percent of the amount of such specified Federal procurement payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4613d996-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000C/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specified Federal procurement payment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “specified Federal procurement payment” means any payment made pursuant to a contract with the Government of the United States for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46164a97-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000C/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of goods, if such goods are manufactured or produced in any country which is not a party to an international procurement agreement with the United States, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46164a98-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000C/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of services, if such services are provided in any country which is not a party to an international procurement agreement with the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46164a99-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000C/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “foreign person” means any person other than a United States person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46164a9a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000C/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative provisions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46164a9b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000C/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withholding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount deducted and withheld under chapter 3 shall be increased by the amount of tax imposed by this section on such payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46164a9c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000C/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other administrative provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subtitle F, any tax imposed by this section shall be treated as a tax imposed by subtitle A.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46164a9d-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/347/tIII/s301/a/1"},"text":"Pub. L. 111–347, title III, § 301(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-02"},"text":"Jan. 2, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3666"},"text":"124 Stat. 3666","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46164a9e-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46164a9f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id46164aa0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/347/tIII/s301/a/3"},"text":"Pub. L. 111–347, title III, § 301(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-02"},"text":"Jan. 2, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3666"},"text":"124 Stat. 3666","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/347/tIII/s301/a/3"},"text":"“The amendments made by this subsection [enacting this section] shall apply to payments received pursuant to contracts entered into on and after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2011-01-02"},"text":"Jan. 2, 2011","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id46164aa1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prohibition on Reimbursement of Fees","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/347/tIII/s301/b"},"text":"Pub. L. 111–347, title III, § 301(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-02"},"text":"Jan. 2, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3666"},"text":"124 Stat. 3666","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/347/tIII/s301/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of each executive agency shall take any and all measures necessary to ensure that no funds are disbursed to any foreign contractor in order to reimburse the tax imposed under section 5000C of the Internal Revenue Code of 1986.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator for Federal Procurement Policy shall annually review the contracting activities of each executive agency to monitor compliance with the requirements of paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Executive agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this subsection, the term ‘executive agency’ has the meaning given the term in section 4 of the Office of Federal Procurement Policy Act ([former] ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s403"},"text":"41 U.S.C. 403","children":[],"tail":") [see "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s133"},"text":"41 U.S.C. 133","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id46164aa2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Application","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/347/tIII/s301/c"},"text":"Pub. L. 111–347, title III, § 301(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-02"},"text":"Jan. 2, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3666"},"text":"124 Stat. 3666","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/347/tIII/s301/c"},"text":"“This section [enacting this section and provisions set out as notes under this section] and the amendments made by this section shall be applied in a manner consistent with United States obligations under international agreements.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
