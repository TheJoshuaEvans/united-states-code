{"tag":"section","attrib":{"id":"id4755cf49-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7434"},"text":null,"children":[{"tag":"num","attrib":{"value":"7434"},"text":"§ 7434.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil damages for fraudulent filing of information returns","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4755cf4a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7434/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any person willfully files a fraudulent information return with respect to payments purported to be made to any other person, such other person may bring a civil action for damages against the person so filing such return.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4755cf4b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7434/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Damages","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any action brought under subsection (a), upon a finding of liability on the part of the defendant, the defendant shall be liable to the plaintiff in an amount equal to the greater of $5,000 or the sum of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4755cf4c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7434/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any actual damages sustained by the plaintiff as a proximate result of the filing of the fraudulent information return (including any costs attributable to resolving deficiencies asserted as a result of such filing),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4755cf4d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7434/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs of the action, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4755cf4e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7434/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the court’s discretion, reasonable attorneys’ fees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4755cf4f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7434/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period for bringing action","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, an action to enforce the liability created under this section may be brought without regard to the amount in controversy and may be brought only within the later of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4755cf50-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7434/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 6 years after the date of the filing of the fraudulent information return, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4755cf51-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7434/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 year after the date such fraudulent information return would have been discovered by exercise of reasonable care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4755cf52-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7434/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Copy of complaint filed with IRS","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person bringing an action under subsection (a) shall provide a copy of the complaint to the Internal Revenue Service upon the filing of such complaint with the court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4755cf53-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7434/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finding of court to include correct amount of payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The decision of the court awarding damages in an action brought under subsection (a) shall include a finding of the correct amount which should have been reported in the information return.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4755cf54-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7434/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information return","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “information return” means any statement described in section 6724(d)(1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4755cf55-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/168/tVI/s601/a"},"text":"Pub. L. 104–168, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-07-30"},"text":"July 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1462"},"text":"110 Stat. 1462","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tVI/s6023/29"},"text":"Pub. L. 105–206, title VI, § 6023(29)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/826"},"text":"112 Stat. 826","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4755cf56-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4755cf57-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4755cf58-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7434 was renumbered 7437 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4755cf59-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206"},"text":"Pub. L. 105–206","children":[],"tail":" substituted “attorneys’ fees” for “attorneys fees”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4755cf5a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4755cf5b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/168/tVI/s601/c"},"text":"Pub. L. 104–168, title VI, § 601(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-07-30"},"text":"July 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1462"},"text":"110 Stat. 1462","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/168/tVI/s601/c"},"text":"“The amendments made by this section [enacting this section and renumbering former section 7434 as 7435 of this title] shall apply to fraudulent information returns filed after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1996-07-30"},"text":"July 30, 1996","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
