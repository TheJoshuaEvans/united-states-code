"/us/pl/109/59/tXI/s11121/a"},"text":"Pub. L. 109–59, title XI, § 11121(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1951"},"text":"119 Stat. 1951","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/289"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(289)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1198"},"text":"132 Stat. 1198","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46e819e3-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46e819e4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id46e819e5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6420 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6422"},"text":"section 6422 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46e819e6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (i)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" substituted “State (and” for “State and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s11121/b"},"text":"Pub. L. 109–59, § 11121(b)","children":[],"tail":", inserted concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s11121/a"},"text":"Pub. L. 109–59, § 11121(a)","children":[],"tail":", amended subpar. (B) generally. Prior to amendment, subpar. (B) read as follows: “if—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) the person so using the gasoline is an aerial or other applicator of fertilizers or other substances and is the ultimate purchaser of the gasoline, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) the person described in subparagraph (A) waives (at such time and in such form and manner as the Secretary shall prescribe) his right to be treated as the user and ultimate purchaser of the gasoline,","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"then subparagraph (A) of this paragraph shall not apply and the aerial or other applicator shall be treated as having used such gasoline on a farm for farming purposes.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/s13242/d/20"},"text":"Pub. L. 103–66, § 13242(d)(20)","children":[],"tail":", substituted “section 4083(a)” for “section 4082(b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/s13241/f/5"},"text":"Pub. L. 103–66, § 13241(f)(5)","children":[],"tail":", struck out heading and text of subsec. (h). Text read as follows: “Except with respect to taxes imposed by section 4081 at the Leaking Underground Storage Tank Trust Fund financing rate, this section shall apply only with respect to gasoline purchased before "},{"tag":"date","attrib":{"date":"1999-10-01"},"text":"October 1, 1999","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/240"},"text":"Pub. L. 102–240","children":[],"tail":" substituted “1999” for “1995”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" substituted “1995” for “1993”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" substituted “section 7602(a)” for “section 7602”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/17"},"text":"Pub. L. 100–17","children":[],"tail":" substituted “1993” for “1988”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/499"},"text":"Pub. L. 99–499","children":[],"tail":" substituted “Except with respect to taxes imposed by section 4081 at the Leaking Underground Storage Tank Trust Fund financing rate, this section” for “This section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (g)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" substituted “section 34” for “section 39”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (c)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/424/s511/f"},"text":"Pub. L. 97–424, § 511(f)","children":[],"tail":", substituted provision that, if the person so using the gasoline is an aerial or other applicator of fertilizers or other substances and is the ultimate purchaser of the gasoline, and the person described in subparagraph (A) waives (at such time and in such form and manner as the Secretary shall prescribe) his right to be treated as the user and ultimate purchaser of the gasoline, then subparagraph (A) of this paragraph shall not apply and the aerial or other applicator shall be treated as having used such gasoline on a farm for farming purposes, for provision that, if the person so using the gasoline were an aerial applicator who was the ultimate purchaser of the gasoline and the person described in subparagraph (A) waived (at such time and in such form and manner as the Secretary was to prescribe) his right to be treated as the user and ultimate purchaser of the gasoline, then subparagraph (A) of this paragraph would not apply and the aerial applicator would be treated as having used such gasoline on a farm for farming purposes."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/424/s516/b/4"},"text":"Pub. L. 97–424, § 516(b)(4)","children":[],"tail":", added subsec. (h). Former subsec. (h) redesignated (i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/473"},"text":"Pub. L. 97–473","children":[],"tail":" purported to add par. (4). See Amendment note below for subsec. (i)(4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/424/s516/b/4"},"text":"Pub. L. 97–424, § 516(b)(4)","children":[],"tail":", redesignated former subsec. (h) as (i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/473"},"text":"Pub. L. 97–473","children":[],"tail":" added par. (4). Notwithstanding the directory language that par. (4) be added to subsec. (h), it was added to subsec. (i) to reflect the probable intent of Congress and the intervening redesignation of subsec. (h) as (i) by "},{"tag":"ref","attrib":{"href":"/us/pl/97/424"},"text":"Pub. L. 97–424","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (c)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/458/s3/c"},"text":"Pub. L. 95–458, § 3(c)","children":[],"tail":", struck out provision that if the use of gasoline is by any person other than the owner, tenant, or operator of a farm, then in applying subsec. (a) of this subparagraph, the owner, tenant, or operator of the farm on which gasoline or a liquid taxable under section 4041 is used would be treated as the user or ultimate purchaser of the gasoline or liquid."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/458/s3/a"},"text":"Pub. L. 95–458, § 3(a)","children":[],"tail":", added par. (4) and redesignated former par. (4) as (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/a/26"},"text":"Pub. L. 94–455, § 1906(a)(26)","children":[],"tail":" (C)(ii), (b)(13)(A), substituted “subsection (g)” for “subsection (h)” and struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/a/26/A"},"text":"Pub. L. 94–455, § 1906(a)(26)(A)","children":[],"tail":", among other changes, struck out provisions relating to gasoline used before "},{"tag":"date","attrib":{"date":"1965-07-01"},"text":"July 1, 1965","children":[],"tail":", and struck out requirement that a person’s first taxable year beginning after "},{"tag":"date","attrib":{"date":"1965-06-30"},"text":"June 30, 1965","children":[],"tail":", include the period after "},{"tag":"date","attrib":{"date":"1965-06-30"},"text":"June 30, 1965","children":[],"tail":", and before the beginning of that first taxable year."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/6/A"},"text":"Pub. L. 94–455, § 1906(b)(6)(A)","children":[],"tail":", among other changes, struck out “and for purposes of section 6416(b)(2)(G)(ii) (but not for purposes of section 4041),” after “in applying subsection (a) to this subparagraph,” and provision that if the use of gasoline is by any person other than the owner, tenant, or operator of the farm, then, for purposes of applying section 6416(b)(2)(G)(ii), any tax paid under section 4041 in respect of a liquid used on a farm for farming purposes be treated as having been paid by the owner, tenant, or operator of the farm on which such liquid is used."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/a/26/B"},"text":"Pub. L. 94–455, § 1906(a)(26)(B)","children":[],"tail":", substituted “apply in respect” for “apply in in respect”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e)(2), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/a/26/C/i"},"text":"Pub. L. 94–455, § 1906(a)(26)(C)(i)","children":[],"tail":", (D), redesignated subsec. (h) as (g), struck out in par. (1) “with respect to gasoline used after "},{"tag":"date","attrib":{"date":"1965-06-30"},"text":"June 30, 1965","children":[],"tail":",” after “subsection (a)”, and in par. (2) “for gasoline used after "},{"tag":"date","attrib":{"date":"1965-06-30"},"text":"June 30, 1965","children":[],"tail":"” after “subtitle A”. Former subsec. (g), which provided that this section applies only with respect to gasoline purchased after "},{"tag":"date","attrib":{"date":"1955-12-31"},"text":"Dec. 31, 1955","children":[],"tail":", was struck out."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (h), (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/a/26/C/i"},"text":"Pub. L. 94–455, § 1906(a)(26)(C)(i)","children":[],"tail":", redesignated subsecs. (h) and (i) as (g) and (h), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/258/s207/b"},"text":"Pub. L. 91–258, § 207(b)","children":[],"tail":", substituted “a claim for credit or refund of overpayment of income tax” for “an income tax return” after “time prescribed by law for filing”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/258/s205/c/7/A"},"text":"Pub. L. 91–258, § 205(c)(7)(A)","children":[],"tail":", (B), substituted “special fuels” for “diesel fuel and special motor fuels” and “section 4041(f)” for “section 4041(d)”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44/s809/a/1/A"},"text":"Pub. L. 89–44, § 809(a)(1)(A)","children":[],"tail":", substituted “Except as provided in subsection (h), if” for “If”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44/s809/a/2"},"text":"Pub. L. 89–44, § 809(a)(2)","children":[],"tail":", designated existing provisions as par. (1) and made it applicable to gasoline used before "},{"tag":"date","attrib":{"date":"1965-07-01"},"text":"July 1, 1965","children":[],"tail":", and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44/s809/a/3"},"text":"Pub. L. 89–44, § 809(a)(3)","children":[],"tail":", substituted “payable” for “paid” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (h), (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44/s809/a/1/B"},"text":"Pub. L. 89–44, § 809(a)(1)(B)","children":[],"tail":", added subsec. (h) 