{"tag":"section","attrib":{"id":"id46e819be-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6420"},"text":null,"children":[{"tag":"num","attrib":{"value":"6420"},"text":"§ 6420.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gasoline used on farms","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46e819bf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6420/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gasoline","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (g), if gasoline is used on a farm for farming purposes, the Secretary shall pay (without interest) to the ultimate purchaser of such gasoline the amount determined by multiplying—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46e819c0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6420/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of gallons so used, by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46e819c1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6420/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate of tax on gasoline under section 4081 which applied on the date he purchased such gasoline.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46e819c2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6420/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for filing claims; period covered","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than one claim may be filed under this section by any person with respect to gasoline used during his taxable year, and no claim shall be allowed under this section with respect to gasoline used during any taxable year unless filed by such person not later than the time prescribed by law for filing a claim for credit or refund of overpayment of income tax for such taxable year. For purposes of this subsection, a person’s taxable year shall be his taxable year for purposes of subtitle A.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46e819c3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6420/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meaning of terms","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46e819c4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6420/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use on a farm for farming purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Gasoline shall be treated as used on a farm for farming purposes only if used (A) in carrying on a trade or business, (B) on a farm situated in the United States, and (C) for farming purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46e819c5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6420/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Farm","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “farm” includes stock, dairy, poultry, fruit, fur-bearing animal, and truck farms, plantations, ranches, nurseries, ranges, greenhouses or other similar structures used primarily for the raising of agricultural or horticultural commodities, and orchards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46e819c6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6420/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Farming purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Gasoline shall be treated as used for farming purposes only if used—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46e819c7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6420/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the owner, tenant, or operator of a farm, in connection with cultivating the soil, or in connection with raising or harvesting any agricultural or horticultural commodity, including the raising, shearing, feeding, caring for, training, and management of livestock, bees, poultry, and fur-bearing animals and wildlife, on a farm of which he is the owner, tenant, or operator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46e819c8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6420/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the owner, tenant, or operator of a farm, in handling, drying, packing, grading, or storing any agricultural or horticultural commodity in its unmanufactured state; but only if such owner, tenant or operator produced more than one-half of the commodity which he so treated during the period with respect to which claim is filed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46e819c9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6420/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" by the owner, tenant, or operator of a farm, in connection with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id46e819ca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6420/c/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the planting, cultivating, caring for, or cutting of trees, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46e819cb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6420/c/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the preparation (other than milling) of trees for market,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"incidental to farming operations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46e819cc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6420/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the owner, tenant, or operator of a farm, in connection with the operation, management, conservation, improvement, or maintenance of such farm and its tools and equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46e819cd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6420/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain farming use other than by owner, etc.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In applying paragraph (3)(A) to a use on a farm for any purpose described in paragraph (3)(A) by any person other than the owner, tenant, or operator of such farm—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46e819ce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6420/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the owner, tenant, or operator of such farm shall be treated as the user and ultimate purchaser of the gasoline, except that","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46e819cf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6420/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the person so using the gasoline is an aerial or other applicator of fertilizers or other substances and is the ultimate purchaser of the gasoline, then subparagraph (A) of this paragraph shall not apply and the aerial or other applicator shall be treated as having used such gasoline on a farm for farming purposes.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"In the case of an aerial applicator, gasoline shall be treated as used on a farm for farming purposes if the gasoline is used for the direct flight between the airfield and one or more farms.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46e819d0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6420/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gasoline","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “gasoline” has the meaning given to such term by section 4083(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46e819d1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6420/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exempt sales; other payments or refunds available","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No amount shall be payable under this section with respect to any gasoline which the Secretary determines was exempt from the tax imposed by section 4081. The amount which (but for this sentence) would be payable under this section with respect to any gasoline shall be reduced by any other amount which the Secretary determines is payable under this section, or is refundable under any provision of this title, to any person with respect to such gasoline.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46e819d2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6420/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable laws","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46e819d3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6420/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All provisions of law, including penalties, applicable in respect of the tax imposed by section 4081 shall, insofar as applicable and not inconsistent with this section, apply in respect of the payments provided for in this section to the same extent as if such payments constituted refunds of overpayments of the tax so imposed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46e819d4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6420/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examination of books and witnesses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of ascertaining the correctness of any claim made under this section, or the correctness of any payment made in respect of any such claim, the Secretary shall have the authority granted by paragraphs (1), (2), and (3) of section 7602(a) (relating to examination of books and witnesses) as if the claimant were the person liable for tax.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46e819d5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6420/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fractional parts of a dollar","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Section 7504 (granting the Secretary discretion with respect to fractional parts of a dollar) shall not apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46e819d6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6420/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may by regulations prescribe the conditions, not inconsistent with the provisions of this section, under which payments may by made under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46e819d7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6420/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Income tax credit in lieu of payment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46e819d8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6420/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons not subject to income tax","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Payment shall be made under subsection (a), only to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46e819d9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6420/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States or an agency or instrumentality thereof, a State, a political subdivision of a State, or an agency or instrumentality of one or more States or political subdivisions, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46e819da-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6420/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an organization exempt from tax under section 501(a) (other than an organization required to make a return of the tax imposed under subtitle A for its taxable year).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46e819db-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6420/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowance of credit against income tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For allowance of credit against the tax imposed by subtitle A, see section 34.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46e819dc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6420/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"[(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13241/f/5"},"text":"Pub. L. 103–66, title XIII, § 13241(f)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/512"},"text":"107 Stat. 512","children":[],"tail":"]"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46e819dd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6420/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross references","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46e819de-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6420/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For exemption from tax in case of special fuels used on a farm for farming purposes, see section 4041(f).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46e819df-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6420/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For civil penalty for excessive claim under this section, see section 6675.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46e819e0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6420/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fraud penalties, etc., see chapter 75 (section 7201 and following, relating to crimes, other offenses, and forfeitures).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46e819e1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6420/i/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For treatment of an Indian tribal government as a State (and a subdivision of an Indian tribal government as a political subdivision of a State), see section 7871.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46e819e2-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-04-02/ch160/s1"},"text":"Apr. 2, 1956, ch. 160, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/87"},"text":"70 Stat. 87","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/tI/s163/d/2"},"text":"Pub. L. 85–859, title I, § 163(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1311"},"text":"72 Stat. 1311","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/44/tVIII/s809/a"},"text":"Pub. L. 89–44, title VIII, § 809(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-06-21"},"text":"June 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/165"},"text":"79 Stat. 165","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/258/tII"},"text":"Pub. L. 91–258, title II","children":[],"tail":", §§ 205(c)(7), 207(b), "},{"tag":"date","attrib":{"date":"1970-05-21"},"text":"May 21, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/242"},"text":"84 Stat. 242","children":[],"tail":", 248; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX"},"text":"Pub. L. 94–455, title XIX","children":[],"tail":", §§ 1906(a)(26), (b)(6)(A), (13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1827"},"text":"90 Stat. 1827","children":[],"tail":", 1833, 1834; "},{"tag":"ref","attrib":{"href":"/us/pl/95/458/s3/a"},"text":"Pub. L. 95–458, § 3(a)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1978-10-14"},"text":"Oct. 14, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1257"},"text":"92 Stat. 1257","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/424/tV"},"text":"Pub. L. 97–424, title V","children":[],"tail":", §§ 511(f), 516(b)(4), "},{"tag":"date","attrib":{"date":"1983-01-06"},"text":"Jan. 6, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2172"},"text":"96 Stat. 2172","children":[],"tail":", 2183; "},{"tag":"ref","attrib":{"href":"/us/pl/97/473/tII/s202/b/12"},"text":"Pub. L. 97–473, title II, § 202(b)(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-14"},"text":"Jan. 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2610"},"text":"96 Stat. 2610","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tIV/s474/r/38"},"text":"Pub. L. 98–369, div. A, title IV, § 474(r)(38)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/846"},"text":"98 Stat. 846","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/499/tV/s521/