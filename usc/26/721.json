{"tag":"section","attrib":{"id":"id44003bf9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s721"},"text":null,"children":[{"tag":"num","attrib":{"value":"721"},"text":"§ 721.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonrecognition of gain or loss on contribution","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44003bfa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s721/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No gain or loss shall be recognized to a partnership or to any of its partners in the case of a contribution of property to the partnership in exchange for an interest in the partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44003bfb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s721/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not apply to gain realized on a transfer of property to a partnership which would be treated as an investment company (within the meaning of section 351) if the partnership were incorporated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44003bfc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s721/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations relating to certain transfers to partnerships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide by regulations that subsection (a) shall not apply to gain realized on the transfer of property to a partnership if such gain, when recognized, will be includible in the gross income of a person other than a United States person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44003bfd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s721/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers of intangibles","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For regulatory authority to treat intangibles transferred to a partnership as sold, see section 367(d)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44003bfe-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/245"},"text":"68A Stat. 245","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXXI/s2131/b"},"text":"Pub. L. 94–455, title XXI, § 2131(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1924"},"text":"90 Stat. 1924","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXI/s1131/b/3"},"text":"Pub. L. 105–34, title XI, § 1131(b)(3)","children":[],"tail":", (5)(B), "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/979"},"text":"111 Stat. 979","children":[],"tail":", 980.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44003bff-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44003c00-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id44003c01-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1131/b"},"text":"section 1131(b) of Pub. L. 105–34","children":[],"tail":" enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s684"},"text":"section 684 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44003c02-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1131/b/3"},"text":"Pub. L. 105–34, § 1131(b)(3)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1131/b/5/B"},"text":"Pub. L. 105–34, § 1131(b)(5)(B)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" designated existing provisions as subsec. (a), added subsec. (a) heading “General rule”, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44003c03-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44003c04-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXXI/s2131/f/3"},"text":"Pub. L. 94–455, title XXI, § 2131(f)(3)","children":[],"tail":"–(5), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1924"},"text":"90 Stat. 1924","children":[],"tail":", 1925, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/455/tXXI/s2131/f/3"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (4), the amendments made by subsections (b) and (c) [amending this section and sections 722 and 723 of this title] shall apply to transfers made after ","children":[{"tag":"date","attrib":{"date":"1976-02-17"},"text":"February 17, 1976","children":[],"tail":", in taxable years ending after such date."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The amendments made by subsections (b) and (c) shall not apply to transfers to a partnership made on or before the 90th day after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":"] if—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" either—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a ruling request with respect to such transfers was filed with the Internal Revenue Service before ","children":[{"tag":"date","attrib":{"date":"1976-03-27"},"text":"March 27, 1976","children":[],"tail":", or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a registration statement with respect to such transfers was filed with the Securities and Exchange Commission before ","children":[{"tag":"date","attrib":{"date":"1976-03-27"},"text":"March 27, 1976","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the securities transferred were deposited on or before the 60th day after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":"], and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" either—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate value (determined as of the close of the 60th day referred to in subparagraph (B), or, if earlier, the close of the deposit period) of the securities so transferred does not exceed $100,000,000, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the securities transferred were all on deposit on ","children":[{"tag":"date","attrib":{"date":"1976-02-29"},"text":"February 29, 1976","children":[],"tail":", pursuant to a registration statement referred to in subparagraph (A)(ii)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If no registration statement was required to be filed with the Securities and Exchange Commission with respect to the transfer of securities to any partnership, then paragraph (4) shall be applied to such transfers—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as if paragraph (4) did not contain subparagraph (A)(ii) thereof, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by substituting ‘$25,000,000’ for ‘$100,000,000’ in subparagraph (C)(i) thereof.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
