{"tag":"section","attrib":{"id":"id4244a8e3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s247"},"text":null,"children":[{"tag":"num","attrib":{"value":"247"},"text":"§ 247.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contributions to Alaska Native Settlement Trusts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4244a8e4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s247/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a Native Corporation, there shall be allowed a deduction for any contributions made by such Native Corporation to a Settlement Trust (regardless of whether an election under section 646 is in effect for such Settlement Trust) for which the Native Corporation has made an annual election under subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4244a8e5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s247/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of deduction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of the deduction under subsection (a) shall be equal to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4244a8e6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s247/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a cash contribution (regardless of the method of payment, including currency, coins, money order, or check), the amount of such contribution, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4244a8e7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s247/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a contribution not described in paragraph (1), the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4244a8e8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s247/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Native Corporation’s adjusted basis in the property contributed, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4244a8e9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s247/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fair market value of the property contributed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4244a8ea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s247/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation and carryover","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4244a8eb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s247/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), the deduction allowed under subsection (a) for any taxable year shall not exceed the taxable income (as determined without regard to such deduction) of the Native Corporation for the taxable year in which the contribution was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4244a8ec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s247/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carryover","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the aggregate amount of contributions described in subsection (a) for any taxable year exceeds the limitation under paragraph (1), such excess shall be treated as a contribution described in subsection (a) in each of the 15 succeeding years in order of time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4244a8ed-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s247/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the terms “Native Corporation” and “Settlement Trust” have the same meaning given such terms under section 646(h).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4244a8ee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s247/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manner of making election","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4244a8ef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s247/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each taxable year, a Native Corporation may elect to have this section apply for such taxable year on the income tax return or an amendment or supplement to the return of the Native Corporation, with such election to have effect solely for such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4244a8f0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s247/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any election made by a Native Corporation pursuant to this subsection may be revoked pursuant to a timely filed amendment or supplement to the income tax return of such Native Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4244a8f1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s247/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4244a8f2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s247/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Earnings and profits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding section 646(d)(2), in the case of a Native Corporation which claims a deduction under this section for any taxable year, the earnings and profits of such Native Corporation for such taxable year shall be reduced by the amount of such deduction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4244a8f3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s247/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gain or loss","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No gain or loss shall be recognized by the Native Corporation with respect to a contribution of property for which a deduction is allowed under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4244a8f4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s247/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (g), a Settlement Trust shall include in income the amount of any deduction allowed under this section in the taxable year in which the Settlement Trust actually receives such contribution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4244a8f5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s247/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The holding period under section 1223 of the Settlement Trust shall include the period the property was held by the Native Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4244a8f6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s247/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The basis that a Settlement Trust has for which a deduction is allowed under this section shall be equal to the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4244a8f7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s247/f/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adjusted basis of the Native Corporation in such property immediately before such contribution, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4244a8f8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s247/f/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fair market value of the property immediately before such contribution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4244a8f9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s247/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No deduction shall be allowed under this section with respect to any contributions made to a Settlement Trust which are in violation of subsection (a)(2) or (c)(2) of section 39 of the Alaska Native Claims Settlement Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1629e"},"text":"43 U.S.C. 1629e","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4244a8fa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s247/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election by Settlement Trust to defer income recognition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4244a8fb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s247/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a contribution which consists of property other than cash, a Settlement Trust may elect to defer recognition of any income related to such property until the sale or exchange of such property, in whole or in part, by the Settlement Trust.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4244a8fc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s247/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of property described in paragraph (1), any income or gain realized on the sale or exchange of such property shall be treated as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4244a8fd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s247/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for such amount of the income or gain as is equal to or less than the amount of income which would be included in income at the time of contribution under subsection (f)(3) but for the taxpayer’s election under this subsection, ordinary income, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4244a8fe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s247/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any amounts of the income or gain which are in excess of the amount of income which would be included in income at the time of contribution under subsection (f)(3) but for the taxpayer’s election under this subsection, having the same character as if this subsection did not apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4244a8ff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s247/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4244a900-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s247/g/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each taxable year, a Settlement Trust may elect to apply this subsection for any property described in paragraph (1) which was contributed during such year. Any property to which the election applies shall be identified and described with reasonable particularity on the income tax return or an amendment or supplement to the return of the Settlement Trust, with such election to have effect solely for such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4244a901-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s247/g/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any election made by a Settlement Trust pursuant to this subsection may be revoked pursuant to a timely filed amendment or supplement to the income tax return of such Settlement Trust.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4244a902-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s247/g/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain dispositions","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4244a903-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s247/g/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any property for which an election is in effect under this subsection and which is disposed of within the first taxable year subsequent to the taxable year in which such property was contributed to the Settlement Trust—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4244a904-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s247/g/3/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this section shall be applied as if the election under this subsection had not been made,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4244a905-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s247/g/3/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any income or gain which would have been included in the year of contribution under subsection (f)(3) but for the taxpayer’s election under this subsection shall be included in income for the taxable year of such contribution, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4244a906-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s247/g/3/C/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Settlement Trust shall pay any increase in tax resulting from such inclusion, including any applicable interest, and increased by 10 percent of the amount of such increase with interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4244a907-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s247/g/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding section 6501(a), any amount described in subclause (III) of clause (i) may be assessed, or a proceeding in court with respect to such amount may be initiated without assessment, within 4 years after the date on which the return making the election under this subsection for such property was filed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4244a908-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13821/b/1"},"text":"Pub. L. 115–97, title I, § 13821(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2179"},"text":"131 Stat. 2179","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4244a909-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4244a90a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4244a90b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 247, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/75"},"text":"68A Stat. 75","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1901/a/35"},"text":"Pub. L. 94–455, title XIX, § 1901(a)(35)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1770"},"text":"90 Stat. 1770","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/600/tIII/s301/b/4"},"text":"Pub. L. 95–600, title III, § 301(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2820"},"text":"92 Stat. 2820","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11801/c/8/C"},"text":"Pub. L. 101–508, title XI, § 11801(c)(8)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-524"},"text":"104 Stat. 1388–524","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1704/t/49"},"text":"Pub. L. 104–188, title I, § 1704(t)(49)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1890"},"text":"110 Stat. 1890","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/135/tIV/s402/a/5"},"text":"Pub. L. 109–135, title IV, § 402(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-21"},"text":"Dec. 21, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2610"},"text":"119 Stat. 2610","children":[],"tail":", allowed to public utilities as a deduction a percentage of the amount of the lesser of dividends paid during the taxable year on its preferred stock or taxable income for the taxable year under certain conditions, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dA/tII/s221/a/41/A"},"text":"Pub. L. 113–295, div. A, title II, § 221(a)(41)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4043"},"text":"128 Stat. 4043","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4244a90c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4244a90d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13821/b/3"},"text":"Pub. L. 115–97, title I, § 13821(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2181"},"text":"131 Stat. 2181","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/97/tI/s13821/b/3"},"text":"\n","children":[{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this subsection [enacting this section] shall apply to taxable years for which the period of limitation on refund or credit under section 6511 of the Internal Revenue Code of 1986 has not expired.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"One-year waiver of statute of limitations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the period of limitation on a credit or refund resulting from the amendments made by paragraph (1) expires before the end of the 1-year period beginning on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":"], refund or credit of such overpayment (to the extent attributable to such amendments) may, nevertheless, be made or allowed if claim therefor is filed before the close of such 1-year period.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
