 data, and sanctions imposed and indictments filed for failure to comply, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/s101"},"text":"section 101 of Pub. L. 101–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s5311"},"text":"section 5311 of Title 31","children":[],"tail":", Money and Finance."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id467cd47b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"No Inference To Be Drawn From Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7601/a/4"},"text":"Pub. L. 100–690, title VII, § 7601(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4504"},"text":"102 Stat. 4504","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/690/tVII/s7601/a/4"},"text":"“No inference shall be drawn from the amendment made by paragraph (1) [amending this section] on the application of the Internal Revenue Code of 1986 without regard to such amendment.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
