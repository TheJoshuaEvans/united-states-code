{"tag":"section","attrib":{"id":"id467a643c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I"},"text":null,"children":[{"tag":"num","attrib":{"value":"6050I"},"text":"§ 6050I.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Returns relating to cash received in trade or business, etc.","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id467a643d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cash receipts of more than $10,000","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467a643e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is engaged in a trade or business, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467a643f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who, in the course of such trade or business, receives more than $10,000 in cash in 1 transaction (or 2 or more related transactions),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall make the return described in subsection (b) with respect to such transaction (or related transactions) at such time as the Secretary may by regulations prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467a6440-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form and manner of returns","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A return is described in this subsection if such return—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467a6441-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in such form as the Secretary may prescribe,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467a6442-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" contains—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id467a6443-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address, and TIN of the person from whom the cash was received,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467a6444-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of cash received,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467a6445-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date and nature of the transaction, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467a6446-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467a6447-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467a6448-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cash received by financial institutions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id467a6449-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cash received in a transaction reported under title 31, United States Code, if the Secretary determines that reporting under this section would duplicate the reporting to the Treasury under title 31, United States Code, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467a644a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cash received by any financial institution (as defined in subparagraphs (A), (B), (C), (D), (E), (F), (G), (J), (K), (R), and (S) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s5312/a/2"},"text":"section 5312(a)(2) of title 31","children":[],"tail":", United States Code)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467cd44b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transactions occurring outside the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except to the extent provided in regulations prescribed by the Secretary, subsection (a) shall not apply to any transaction if the entire transaction occurs outside the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467cd44c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cash includes foreign currency and certain monetary instruments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “cash” includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467cd44d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign currency,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467cd44e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent provided in regulations prescribed by the Secretary, any monetary instrument (whether or not in bearer form) with a face amount of not more than $10,000, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467cd44f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any digital asset (as defined in section 6045(g)(3)(D)).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Paragraph (2) shall not apply to any check drawn on the account of the writer in a financial institution referred to in subsection (c)(1)(B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467cd450-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statements to be furnished to persons with respect to whom information is required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Every person required to make a return under subsection (a) shall furnish to each person whose name is required to be set forth in such return a written statement showing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467cd451-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address, and phone number of the information contact of the person required to make such return, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467cd452-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amount of cash described in subsection (a) received by the person required to make such return.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The written statement required under the preceding sentence shall be furnished to the person on or before January 31 of the year following the calendar year for which the return under subsection (a) was required to be made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467cd453-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Structuring transactions to evade reporting requirements prohibited","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467cd454-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No person shall for the purpose of evading the return requirements of this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id467cd455-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cause or attempt to cause a trade or business to fail to file a return required under this section,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467cd456-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cause or attempt to cause a trade or business to file a return required under this section that contains a material omission or misstatement of fact, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467cd457-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" structure or assist in structuring, or attempt to structure or assist in structuring, any transaction with one or more trades or businesses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467cd458-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person violating paragraph (1) of this subsection shall be subject to the same civil and criminal sanctions applicable to a person which fails to file or completes a false or incorrect return under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467cd459-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cash received by criminal court clerks","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467cd45a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every clerk of a Federal or State criminal court who receives more than $10,000 in cash as bail for any individual charged with a specified criminal offense shall make a return described in paragraph (2) (at such time as the Secretary may by regulations prescribe) with respect to the receipt of such bail.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467cd45b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Return","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A return is described in this paragraph if such return—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id467cd45c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in such form as the Secretary may prescribe, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467cd45d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" contains—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id467cd45e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/g/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the name, address, and TIN of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id467cd45f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/g/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual charged with the specified criminal offense, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id467cd460-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/g/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each person posting the bail (other than a person licensed as a bail bondsman),","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id467cd461-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/g/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of cash received,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id467cd462-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/g/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date the cash was received, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id467cd463-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/g/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467cd464-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specified criminal offense","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “specified criminal offense” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id467cd465-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/g/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Federal criminal offense involving a controlled substance,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467cd466-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/g/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" racketeering (as defined in section 1951, 1952, or 1955 of title 18, United States Code),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467cd467-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/g/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" money laundering (as defined in section 1956 or 1957 of such title), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467cd468-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/g/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any State criminal offense substantially similar to an offense described in subparagraph (A), (B), or (C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467cd469-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information to Federal prosecutors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each clerk required to include on a return under paragraph (1) the information described in paragraph (2)(B) with respect to an individual described in paragraph (2)(B)(i)(I) shall furnish (at such time as the Secretary may by regulations prescribe) a written statement showing such information to the United States Attorney for the jurisdiction in which such individual resides and the jurisdiction in which the specified criminal offense occurred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467cd46a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information to payors of bail","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each clerk required to make a return under paragraph (1) shall furnish (at such time as the Secretary may by regulations prescribe) to each person whose name is required to be set forth in such return by reason of paragraph (2)(B)(i)(II) a written statement showing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id467cd46b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/g/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name and address of the clerk’s office required to make the return, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467cd46c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050I/g/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amount of cash described in paragraph (1) received by such clerk.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id467cd46d-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s146/a"},"text":"Pub. L. 98–369, div. A, title I, § 146(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/685"},"text":"98 Stat. 685","children":[],"tail"