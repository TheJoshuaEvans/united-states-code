{"tag":"section","attrib":{"id":"id44c1425d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1234"},"text":null,"children":[{"tag":"num","attrib":{"value":"1234"},"text":"§ 1234.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Options to buy or sell","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44c1425e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1234/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of gain or loss in the case of the purchaser","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44c1425f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1234/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Gain or loss attributable to the sale or exchange of, or loss attributable to failure to exercise, an option to buy or sell property shall be considered gain or loss from the sale or exchange of property which has the same character as the property to which the option relates has in the hands of the taxpayer (or would have in the hands of the taxpayer if acquired by him).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44c14260-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1234/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for loss attributable to failure to exercise option","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1), if loss is attributable to failure to exercise an option, the option shall be deemed to have been sold or exchanged on the day it expired.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44c14261-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1234/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplication of subsection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This subsection shall not apply to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44c14262-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1234/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an option which constitutes property described in paragraph (1) of section 1221(a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44c14263-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1234/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of gain attributable to the sale or exchange of an option, any income derived in connection with such option which, without regard to this subsection, is treated as other than gain from the sale or exchange of a capital asset; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44c14264-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1234/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a loss attributable to failure to exercise an option described in section 1233(c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44c14265-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1234/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of grantor of option in the case of stock, securities, or commodities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44c14266-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1234/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of the grantor of the option, gain or loss from any closing transaction with respect to, and gain on lapse of, an option in property shall be treated as a gain or loss from the sale or exchange of a capital asset held not more than 1 year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44c14267-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1234/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44c14268-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1234/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Closing transaction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “closing transaction” means any termination of the taxpayer’s obligation under an option in property other than through the exercise or lapse of the option.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44c14269-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1234/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “property” means stocks and securities (including stocks and securities dealt with on a “when issued” basis), commodities, and commodity futures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44c1426a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1234/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplication of subsection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall not apply to any option granted in the ordinary course of the taxpayer’s trade or business of granting options.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44c1426b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1234/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of options on section 1256 contracts and cash settlement options","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44c1426c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1234/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Section 1256 contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Gain or loss shall be recognized on the exercise of an option on a section 1256 contract (within the meaning of section 1256(b)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44c1426d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1234/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of cash settlement options","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44c1426e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1234/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsections (a) and (b), a cash settlement option shall be treated as an option to buy or sell property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44c1426f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1234/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cash settlement option","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A), the term “cash settlement option” means any option which on exercise settles in (or could be settled in) cash or property other than the underlying property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44c14270-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch376"},"text":"Aug. 16, 1954, ch. 376","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/329"},"text":"68A Stat. 329","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/866/tI/s53"},"text":"Pub. L. 85–866, title I, § 53","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1644"},"text":"72 Stat. 1644","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/809/tII/s210/a"},"text":"Pub. L. 89–809, title II, § 210(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-13"},"text":"Nov. 13, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1580"},"text":"80 Stat. 1580","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIV/s1402/b/1/U"},"text":"Pub. L. 94–455, title XIV, § 1402(b)(1)(U)","children":[],"tail":", (2), title XXI, § 2136(a), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1732"},"text":"90 Stat. 1732","children":[],"tail":", 1929; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s105/a"},"text":"Pub. L. 98–369, div. A, title I, § 105(a)","children":[],"tail":", title X, § 1001(b)(18), (e), "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/629"},"text":"98 Stat. 629","children":[],"tail":", 1012; "},{"tag":"ref","attrib":{"href":"/us/pl/106/170/tV/s532/c/1/H"},"text":"Pub. L. 106–170, title V, § 532(c)(1)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-17"},"text":"Dec. 17, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1930"},"text":"113 Stat. 1930","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44c14271-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44c14272-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44c14273-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Subsec. (a)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/170"},"text":"Pub. L. 106–170","children":[],"tail":" substituted “section 1221(a)” for “section 1221”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s1001/b/18"},"text":"Pub. L. 98–369, § 1001(b)(18)","children":[],"tail":", (e), substituted “6 months” for “1 year”, applicable to property acquired after "},{"tag":"date","attrib":{"date":"1984-06-22"},"text":"June 22, 1984","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"1988-01-01"},"text":"Jan. 1, 1988","children":[],"tail":". See Effective Date of 1984 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s105/a"},"text":"Pub. L. 98–369, § 105(a)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s2136/a"},"text":"Pub. L. 94–455, § 2136(a)","children":[],"tail":", inserted in heading “in the case of the purchaser”; designated existing provisions as par. “(1) General rule” and substituted “an option” and “the option” for “a privilege or option” and “the option or privilege”; redesignated existing subsec. (b) as par. (2) and substituted “an option” and “the option” for “a privilege or option” and “the privilege or option”; and redesignated existing subsec. (d)(1) to (3) as par. (3)(A) to (C) and substituted in heading and introductory text “Nonapplication” and “subsection” for “Non-application” and “section”, in par. (3)(A) “an option” for “a privilege or option”, in par. (3)(B) “an option”, “such option” and “subsection” for “a privilege or option”, “such privilege or option” and “section” and in par. (3)(C) substituted a period for “; or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s2136/a"},"text":"Pub. L. 94–455, § 2136(a)","children":[],"tail":", added subsec. (b), incorporating provisions of a prior subsec. (c) providing for a special rule for grantors of straddles, par. (1) relating to “gain on lapse” and reading “In the case of gain on lapse of an option granted by the taxpayer as part of a straddle, the gain shall be deemed to be gain from the sale or exchange of a capital asset held for not more than 6 months on the day that the option expired.”; par. (2) relating to “exception” and reading “This subsection shall not apply to any person who holds securities for sale to customers in the ordinary course of his trade or business.”, now covered in subsec. (b)(3); and par. (3) relating to definitions of “straddle” and “security”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1402/b/2"},"text":"Pub. L. 94–455, § 1402(b)(2)","children":[],"tail":", provided that “9 months” would be changed to “1 year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1402/b/1/U"},"text":"Pub. L. 94–455, § 1402(b)(1)(U)","children":[],"tail":", provided that “6 months” would be changed to “9 months” for taxable years beginning in 1977."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s2136/a"},"text":"Pub. L. 94–455, § 2136(a)","children":[],"tail":", struck out provision respecting special rule for grantors of straddles, the paragraphs relating to: (1) gain on lapse; (2) exception, now covered in subsec. (b)(3); and (3) definitions of “straddle” and “security”, such provision now covered generally by subsec. (b) of this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s2136/a"},"text":"Pub. L. 94–455, § 2136(a)","children":[],"tail":", struck out provision respecting non-application of section, pars. (1) to (3) now covered in subsec. (a)(3)(A) to (C) of this section, and par. (4) providing for such non-application to gain attributable to the sale or exchange of a privilege or option acquired by the taxpayer before "},{"tag":"date","attrib":{"date":"1954-03-01"},"text":"Mar. 1, 1954","children":[],"tail":", if in the hands of the taxpayer such privilege or option was a capital asset."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/809"},"text":"Pub. L. 89–809","children":[],"tail":" added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/866"},"text":"Pub. L. 85–866","children":[],"tail":" amended section generally and among other changes provided in subsec. (a) that gain or loss resulting from option to buy or sell property is to be considered gain or loss arising from property which has the same character as the property underlying the option, incorporated existing provisions in subsecs. (b) and (c)(3), and inserted provisions set out in subsec. (c)(1), (2), (4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44c14274-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44c14275-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1999 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/170"},"text":"Pub. L. 106–170","children":[],"tail":" applicable to any instrument held, acquired, or entered into, any transaction entered into, and supplies held or acquired on or after "},{"tag":"date","attrib":{"date":"1999-12-17"},"text":"Dec. 17, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/170/s532/d"},"text":"section 532(d) of Pub. L. 106–170","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s170"},"text":"section 170 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44c14276-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s105/b"},"text":"Pub. L. 98–369, div. A, title I, § 105(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/629"},"text":"98 Stat. 629","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/369/dA/tI/s105/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply to options purchased or granted after ","children":[{"tag":"date","attrib":{"date":"1983-10-31"},"text":"October 31, 1983","children":[],"tail":", in taxable years ending after such date.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s1001/b/18"},"text":"section 1001(b)(18) of Pub. L. 98–369","children":[],"tail":" applicable to property acquired after "},{"tag":"date","attrib":{"date":"1984-06-22"},"text":"June 22, 1984","children":[