{"tag":"section","attrib":{"id":"id4605a92c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4979"},"text":null,"children":[{"tag":"num","attrib":{"value":"4979"},"text":"§ 4979.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax on certain excess contributions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4605a92d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4979/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any plan, there is hereby imposed a tax for the taxable year equal to 10 percent of the sum of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4605a92e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4979/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any excess contributions under such plan for the plan year ending in such taxable year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4605a92f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4979/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any excess aggregate contributions under the plan for the plan year ending in such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4605a930-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4979/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability for tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tax imposed by subsection (a) shall be paid by the employer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4605a931-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4979/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excess contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “excess contributions” has the meaning given such term by sections 401(k)(8)(B), 408(k)(6)(C), and 501(c)(18).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4605a932-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4979/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excess aggregate contribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “excess aggregate contribution” has the meaning given to such term by section 401(m)(6)(B). For purposes of determining excess aggregate contributions under an annuity contract described in section 403(b), such contract shall be treated as a plan described in subsection (e)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4605a933-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4979/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “plan” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4605a934-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4979/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan described in section 401(a) which includes a trust exempt from tax under section 501(a),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4605a935-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4979/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any annuity plan described in section 403(a),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4605a936-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4979/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any annuity contract described in section 403(b),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4605a937-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4979/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a simplified employee pension of an employer which satisfies the requirements of section 408(k), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4605a938-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4979/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan described in section 501(c)(18).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such term includes any plan which, at any time, has been determined by the Secretary to be such a plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4605a939-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4979/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No tax where excess distributed within specified period after close of year","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4605a93a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4979/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No tax shall be imposed under this section on any excess contribution or excess aggregate contribution, as the case may be, to the extent such contribution (together with any income allocable thereto through the end of the plan year for which the contribution was made) is distributed (or, if forfeitable, is forfeited) before the close of the first 2½ months (6 months in the case of an excess contribution or excess aggregate contribution to an eligible automatic contribution arrangement (as defined in section 414(w)(3))) of the following plan year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4605a93b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4979/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Year of inclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amount distributed as provided in paragraph (1) shall be treated as earned and received by the recipient in the recipient’s taxable year in which such distributions were made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4605a93c-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXI/s1117/b/1"},"text":"Pub. L. 99–514, title XI, § 1117(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2461"},"text":"100 Stat. 2461","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1011"},"text":"Pub. L. 100–647, title I, § 1011","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(8)–(11), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3470"},"text":"102 Stat. 3470","children":[],"tail":", 3471; "},{"tag":"ref","attrib":{"href":"/us/pl/109/280/tIX/s902/e/1"},"text":"Pub. L. 109–280, title IX, § 902(e)(1)","children":[],"tail":"–(3)(A), "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1038"},"text":"120 Stat. 1038","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4605a93d-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4605a93e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4605a93f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/s902/e/1/B"},"text":"Pub. L. 109–280, § 902(e)(1)(B)","children":[],"tail":", substituted “specified period after” for “2½ months of” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/s902/e/1/A"},"text":"Pub. L. 109–280, § 902(e)(1)(A)","children":[],"tail":", (3)(A), inserted “through the end of the plan year for which the contribution was made” after “thereto” and “(6 months in the case of an excess contribution or excess aggregate contribution to an eligible automatic contribution arrangement (as defined in section 414(w)(3)))” after “2½ months”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/s902/e/2"},"text":"Pub. L. 109–280, § 902(e)(2)","children":[],"tail":", reenacted heading without change and amended text of par. (2) generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—Except as provided in subparagraph (B), any amount distributed as provided in paragraph (1) shall be treated as received and earned by the recipient in his taxable year for which such contribution was made."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) ","children":[{"tag":"inline","attrib":{},"text":"De minimis distributions","children":[],"tail":".—If the total excess contributions and excess aggregate contributions distributed to a recipient under a plan for any plan year are less than $100, such distributions (and any income allocable thereto) shall be treated as earned and received by the recipient in his taxable year in which such distributions were made.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1011"},"text":"Pub. L. 100–647, § 1011","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(8), struck out “a cash or deferred arrangement which is part of” after “contributions under”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1011"},"text":"Pub. L. 100–647, § 1011","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(9), struck out “403(b),” and substituted “408(k)(6)(C)” for “408(k)(8)(B)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1011"},"text":"Pub. L. 100–647, § 1011","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(10), inserted sentence at end relating to determination of excess aggregate contributions under certain annuity contracts."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1011"},"text":"Pub. L. 100–647, § 1011","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(11), substituted “Year of inclusion” for “Included in prior year” as heading, and amended text generally. Prior to amendment, text read as follows: “Any amount distributed as provided in paragraph (1) shall be treated as received and earned by the recipient in his taxable year for which such contribution was made.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4605a940-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4605a941-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280"},"text":"Pub. L. 109–280","children":[],"tail":" applicable to plan years beginning after "},{"tag":"date","attrib":{"date":"2007-12-31"},"text":"Dec. 31, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/280/s902/g"},"text":"section 902(g) of Pub. L. 109–280","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s401"},"text":"section 401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4605a942-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1019/a"},"text":"section 1019(a) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4605a943-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to plan years beginning after ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"Dec. 31, 1986","children":[],"tail":", with special provisions for plans maintained pursuant to collective bargaining agreements ratified before "},{"tag":"date","attrib":{"date":"1986-03-01"},"text":"Mar. 1, 1986","children":[],"tail":", and for annuity contracts under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s403/b"},"text":"section 403(b) of this title","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1117/d"},"text":"section 1117(d) of Pub. L. 99–514","children":[],"ta