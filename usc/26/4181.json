{"tag":"section","attrib":{"id":"id45c062ad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4181"},"text":null,"children":[{"tag":"num","attrib":{"value":"4181"},"text":"§ 4181.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is hereby imposed upon the sale by the manufacturer, producer, or importer of the following articles a tax equivalent to the specified percent of the price for which so sold:","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"Articles taxable at 10 percent—","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"Pistols.","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"Revolvers.","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"Articles taxable at 11 percent—","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"Firearms (other than pistols and revolvers).","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"Shells, and cartridges.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id45c062ae-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/490"},"text":"68A Stat. 490","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
