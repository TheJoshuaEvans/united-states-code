{"tag":"section","attrib":{"id":"id4632fb06-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5272"},"text":null,"children":[{"tag":"num","attrib":{"value":"5272"},"text":"§ 5272.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bonds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4632fb07-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5272/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before any permit required by section 5271(a) is granted, the Secretary may require a bond, in such form and amount as he may prescribe, to insure compliance with the terms of the permit and the provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4632fb08-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5272/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No bond shall be required in the case of permits issued to the United States or any governmental agency thereof, or to the several States or any political subdivision thereof, or to the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4632fb09-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1372"},"text":"72 Stat. 1372","children":[],"tail":";