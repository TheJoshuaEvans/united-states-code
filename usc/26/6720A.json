{"tag":"section","attrib":{"id":"id4736d612-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6720A"},"text":null,"children":[{"tag":"num","attrib":{"value":"6720A"},"text":"§ 6720A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty with respect to certain adulterated fuels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4736d613-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6720A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who knowingly transfers for resale, sells for resale, or holds out for resale any liquid for use in a diesel-powered highway vehicle or a diesel-powered train which does not meet applicable EPA regulations (as defined in section 45H(c)(3)), shall pay a penalty of $10,000 for each such transfer, sale, or holding out for resale, in addition to the tax on such liquid (if any).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4736d614-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6720A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty in the case of retailers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who knowingly holds out for sale (other than for resale) any liquid described in subsection (a), shall pay a penalty of $10,000 for each such holding out for sale, in addition to the tax on such liquid (if any).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4736d615-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/tXI/s11167/a"},"text":"Pub. L. 109–59, title XI, § 11167(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1977"},"text":"119 Stat. 1977","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4736d616-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4736d617-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4736d618-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/tXI/s11167/d"},"text":"Pub. L. 109–59, title XI, § 11167(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1978"},"text":"119 Stat. 1978","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/59/tXI/s11167/d"},"text":"“The amendments made by this section [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s9503"},"text":"section 9503 of this title","children":[],"tail":"] shall apply to any transfer, sale, or holding out for sale or resale occurring after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
