{"tag":"section","attrib":{"id":"id4736d5ef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6718"},"text":null,"children":[{"tag":"num","attrib":{"value":"6718"},"text":"§ 6718.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to display tax registration on vessels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4736d5f0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6718/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to display registration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every operator of a vessel who fails to display proof of registration pursuant to section 4101(a)(3) shall pay a penalty of $500 for each such failure. With respect to any vessel, only one penalty shall be imposed by this section during any calendar month.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4736d5f1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6718/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiple violations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining the penalty under subsection (a) on any person, subsection (a) shall be applied by increasing the amount in subsection (a) by the product of such amount and the aggregate number of penalties (if any) imposed with respect to prior months by this section on such person (or a related person or any predecessor of such person or related person).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4736d5f2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6718/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reasonable cause exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No penalty shall be imposed under this section with respect to any failure if it is shown that such failure is due to reasonable cause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4736d5f3-3a70-11f1-a967-d35dac11796a"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII"},"text":"Pub. L. 108–357, title VIII","children":[],"tail":", §§ 861(b)(1), 862(b), "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1618"},"text":"118 Stat. 1618","children":[],"tail":", 1619.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4736d5f4-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4736d5f5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4736d5f6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s862/b"},"text":"Pub. L. 108–357, § 862(b)","children":[],"tail":", substituted “section 4101(a)(3)” for “section 4101(a)(2)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4736d5f7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4736d5f8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s862/b"},"text":"section 862(b) of Pub. L. 108–357","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2005-01-01"},"text":"Jan. 1, 2005","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/s862/c"},"text":"section 862(c) of Pub. L. 108–357","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4101"},"text":"section 4101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4736d5f9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s861/c/2"},"text":"Pub. L. 108–357, title VIII, § 861(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1619"},"text":"118 Stat. 1619","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/357/tVIII/s861/c/2"},"text":"“The amendments made by subsection (b) [enacting this section] shall apply to penalties imposed after ","children":[{"tag":"date","attrib":{"date":"2004-12-31"},"text":"December 31, 2004","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
