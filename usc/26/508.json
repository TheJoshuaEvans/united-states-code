{"tag":"section","attrib":{"id":"id43b17f27-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s508"},"text":null,"children":[{"tag":"num","attrib":{"value":"508"},"text":"§ 508.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules with respect to section 501(c)(3) organizations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id43b17f28-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s508/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New organizations must notify Secretary that they are applying for recognition of section 501(c)(3) status","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (c), an organization organized after ","children":[{"tag":"date","attrib":{"date":"1969-10-09"},"text":"October 9, 1969","children":[],"tail":", shall not be treated as an organization described in section 501(c)(3)—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id43b17f29-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s508/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unless it has given notice to the Secretary in such manner as the Secretary may by regulations prescribe, that it is applying for recognition of such status, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43b17f2a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s508/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any period before the giving of such notice, if such notice is given after the time prescribed by the Secretary by regulations for giving notice under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43b17f2b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s508/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presumption that organizations are private foundations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (c), any organization (including an organization in existence on ","children":[{"tag":"date","attrib":{"date":"1969-10-09"},"text":"October 9, 1969","children":[],"tail":") which is described in section 501(c)(3) and which does not notify the Secretary, at such time and in such manner as the Secretary may by regulations prescribe, that it is not a private foundation shall be presumed to be a private foundation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43b17f2c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s508/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43b17f2d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s508/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsections (a) and (b) shall not apply to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43b17f2e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s508/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" churches, their integrated auxiliaries, and conventions or associations of churches, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43b17f2f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s508/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any organization which is not a private foundation (as defined in section 509(a)) and the gross receipts of which in each taxable year are normally not more than $5,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43b17f30-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s508/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions by regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may by regulations exempt (to the extent and subject to such conditions as may be prescribed in such regulations) from the provisions of subsection (a) or (b) or both—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43b17f31-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s508/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educational organizations described in section 170(b)(1)(A)(ii), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43b17f32-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s508/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other class of organizations with respect to which the Secretary determines that full compliance with the provisions of subsections (a) and (b) is not necessary to the efficient administration of the provisions of this title relating to private foundations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43b17f33-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s508/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disallowance of certain charitable, etc., deductions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43b17f34-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s508/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gift or bequest to organizations subject to section 507(c) tax","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No gift or bequest made to an organization upon which the tax provided by section 507(c) has been imposed shall be allowed as a deduction under section 170, 545(b)(2), 642(c), 2055, 2106(a)(2), or 2522, if such gift or bequest is made—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43b17f35-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s508/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by any person after notification is made under section 507(a), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43b17f36-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s508/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by a substantial contributor (as defined in section 507(d)(2)) in his taxable year which includes the first day on which action is taken by such organization which culminates in the imposition of tax under section 507(c) and any subsequent taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43b17f37-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s508/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gift or bequest to taxable private foundation, section 4947 trust, etc.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No gift or bequest made to an organization shall be allowed as a deduction under section 170, 545(b)(2), 642(c), 2055, 2106(a)(2), or 2522, if such gift or bequest is made—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43b17f38-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s508/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a private foundation or a trust described in section 4947 in a taxable year for which it fails to meet the requirements of subsection (e) (determined without regard to subsection (e)(2)), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43b17f39-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s508/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any organization in a period for which it is not treated as an organization described in section 501(c)(3) by reason of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43b17f3a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s508/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply if the entire amount of the unpaid portion of the tax imposed by section 507(c) is abated by the Secretary under section 507(g).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43b17f3b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s508/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Governing instruments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43b17f3c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s508/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A private foundation shall not be exempt from taxation under section 501(a) unless its governing instrument includes provisions the effects of which are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43b17f3d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s508/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to require its income for each taxable year to be distributed at such time and in such manner as not to subject the foundation to tax under section 4942, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43b17f3e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s508/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prohibit the foundation from engaging in any act of self-dealing (as defined in section 4941(d)), from retaining any excess business holdings (as defined in section 4943(c)), from making any investments in such manner as to subject the foundation to tax under section 4944, and from making any taxable expenditures (as defined in section 4945(d)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43b17f3f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s508/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for existing private foundations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any organization organized before ","children":[{"tag":"date","attrib":{"date":"1970-01-01"},"text":"January 1, 1970","children":[],"tail":", paragraph (1) shall not apply—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43b17f40-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s508/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any period after ","children":[{"tag":"date","attrib":{"date":"1971-12-31"},"text":"December 31, 1971","children":[],"tail":", during the pendency of any judicial proceeding begun before "},{"tag":"date","attrib":{"date":"1972-01-01"},"text":"January 1, 1972","children":[],"tail":", by the private foundation which is necessary to reform, or to excuse such foundation from compliance with, its governing instrument or any other instrument in order to meet the requirements of paragraph (1), and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43b17f41-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s508/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any period after the termination of any judicial proceeding described in subparagraph (A) during which its governing instrument or any other instrument does not permit it to meet the requirements of paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43b17f42-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s508/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional provisions relating to sponsoring organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A sponsoring organization (as defined in section 4966(d)(1)) shall give notice to the Secretary (in such manner as the Secretary may provide) whether such organization maintains or intends to maintain donor advised funds (as defined in section 4966(d)(2)) and the manner in which such organization plans to operate such funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id43b17f43-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172/tI/s101/a"},"text":"Pub. L. 91–172, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/494"},"text":"83 Stat. 494","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX"},"text":"Pub. L. 94–455, title XIX","children":[],"tail":", §§ 1901(a)(71), (b)(8)(E), 1906(b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1776"},"text":"90 Stat. 1776","children":[],"tail":", 1794, 1834; "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tIV/s413/c/30"},"text":"Pub. L. 108–357, title IV, § 413(c)(30)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1509"},"text":"118 Stat. 1509","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/280/tXII/s1235/b/1"},"text":"Pub. L. 109–280, title XII, § 1235(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1101"},"text":"120 Stat. 1101","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id43b17f44-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id43b17f45-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id43b17f46-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280"},"text":"Pub. L. 109–280","children":[],"tail":", which directed the addition of subsec. (f) to section 508, without specifying the act to be amended, was executed by making the addition to this section, which is section 508 of the Internal Revenue Code of 1986, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (d)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":" struck out “556(b)(2),” after “545(b)(2),”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1901/a/71/A"},"text":"Pub. L. 94–455, § 1901(a)(71)(A)","children":[],"tail":", struck out last sentence providing that for purposes of paragraph (2), the time prescribed for giving notice under this subsection shall not expire before the 90th day after the day on which regulations first prescribed under this subsection become final."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” in three places after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":", §§ 1901(a)(71)(A), 1906(b)(13)(A), struck out “or his delegate” in two places after “Secretary” and “The time prescribed for giving notice under this subsection shall not expire before the 90th day after the day on which regulations first prescribed under this subsection become final” after “a private foundation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1901/b/8/E"},"text":"Pub. L. 94–455, § 1901(b)(8)(E)","children":[],"tail":", substituted “(A) educational organizations described in section 170(b)(1)(A)(ii), and” for “(A) educational organizations which normally maintain a regular faculty and curriculum and normally have a regularly enrolled body of pupils or students in attendance at the place where their educational activities are regularly carried on; and” after “(b) or both—”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1901/a/71/C"},"text":"Pub. L. 94–455, § 1901(a)(71)(C)","children":[],"tail":", substituted “(e)(2)” for “(e)(2)(B) and (C)” after “regard to subsection”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/