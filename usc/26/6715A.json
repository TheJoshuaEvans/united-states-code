{"tag":"section","attrib":{"id":"id473464ce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6715A"},"text":null,"children":[{"tag":"num","attrib":{"value":"6715A"},"text":"§ 6715A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tampering with or failing to maintain security requirements for mechanical dye injection systems","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id473464cf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6715A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of penalty","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id473464d0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6715A/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tampering","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any person tampers with a mechanical dye injection system used to indelibly dye fuel for purposes of section 4082, such person shall pay a penalty in addition to the tax (if any).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id473464d1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6715A/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to maintain security requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any operator of a mechanical dye injection system used to indelibly dye fuel for purposes of section 4082 fails to maintain the security standards for such system as established by the Secretary, then such operator shall pay a penalty in addition to the tax (if any).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4736d5d2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6715A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of penalty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of the penalty under subsection (a) shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4736d5d3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6715A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for each violation described in paragraph (1), the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4736d5d4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6715A/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $25,000, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4736d5d5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6715A/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10 for each gallon of fuel involved, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4736d5d6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6715A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for each—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4736d5d7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6715A/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" failure to maintain security standards described in paragraph (2), $1,000, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4736d5d8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6715A/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" failure to correct a violation described in paragraph (2), $1,000 per day for each day after which such violation was discovered or such person should have reasonably known of such violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4736d5d9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6715A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint and several liability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4736d5da-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6715A/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a penalty is imposed under this section on any business entity, each officer, employee, or agent of such entity or other contracting party who willfully participated in any act giving rise to such penalty shall be jointly and severally liable with such entity for such penalty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4736d5db-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6715A/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affiliated groups","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a business entity described in paragraph (1) is part of an affiliated group (as defined in section 1504(a)), the parent corporation of such entity shall be jointly and severally liable with such entity for the penalty imposed under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4736d5dc-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s854/c/1"},"text":"Pub. L. 108–357, title VIII, § 854(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1615"},"text":"118 Stat. 1615","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4736d5dd-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4736d5de-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4736d5df-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the 180th day after the date on which the Secretary of the Treasury issues the regulations described in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s854/b"},"text":"section 854(b) of Pub. L. 108–357","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/s854/d"},"text":"section 854(d) of Pub. L. 108–357","children":[],"tail":", set out as an Effective Date of 2004 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4082"},"text":"section 4082 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
