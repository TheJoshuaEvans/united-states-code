{"tag":"section","attrib":{"id":"id43af0eab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s504"},"text":null,"children":[{"tag":"num","attrib":{"value":"504"},"text":"§ 504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status after organization ceases to qualify for exemption under section 501(c)(3) because of substantial lobbying or because of political activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id43af0eac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An organization which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43af0ead-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s504/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was exempt (or was determined by the Secretary to be exempt) from taxation under section 501(a) by reason of being an organization described in section 501(c)(3), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43af0eae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s504/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is not an organization described in section 501(c)(3)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43af0eaf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s504/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by reason of carrying on propaganda, or otherwise attempting, to influence legislation, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43af0eb0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s504/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by reason of participating in, or intervening in, any political campaign on behalf of (or in opposition to) any candidate for public office,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall not at any time thereafter be treated as an organization described in section 501(c)(4).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43af0eb1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations to prevent avoidance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such regulations as may be necessary or appropriate to prevent the avoidance of subsection (a), including regulations relating to a direct or indirect transfer of all or part of the assets of an organization to an organization controlled (directly or indirectly) by the same person or persons who control the transferor organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43af0eb2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s504/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Churches, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not apply to any organization which is a disqualified organization within the meaning of section 501(h)(5) (relating to churches, etc.) for the taxable year immediately preceding the first taxable year for which such organization is described in paragraph (2) of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id43af0eb3-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIII/s1307/a/2"},"text":"Pub. L. 94–455, title XIII, § 1307(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1721"},"text":"90 Stat. 1721","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX/s10711/b/1"},"text":"Pub. L. 100–203, title X, § 10711(b)(1)","children":[],"tail":", (2)(A), "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-464"},"text":"101 Stat. 1330–464","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id43af0eb4-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id43af0eb5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id43af0eb6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 504, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/168"},"text":"68A Stat. 168","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/90/630/s6/a"},"text":"Pub. L. 90–630, § 6(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1330"},"text":"82 Stat. 1330","children":[],"tail":", related to denial of exemption, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/tI/s101/j/15"},"text":"Pub. L. 91–172, title I, § 101(j)(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/527"},"text":"83 Stat. 527","children":[],"tail":". For effective date of repeal, see "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/s101/k/2/B"},"text":"section 101(k)(2)(B) of Pub. L. 91–172","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4940"},"text":"section 4940 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id43af0eb7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/s10711/b/2/A"},"text":"Pub. L. 100–203, § 10711(b)(2)(A)","children":[],"tail":", substituted “substantial lobbying or because of political activities” for “substantial lobbying” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/s10711/b/1"},"text":"Pub. L. 100–203, § 10711(b)(1)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “is not an organization described in section 501(c)(3) by reason of carrying on propaganda, or otherwise attempting, to influence legislation,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id43af0eb8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43af0eb9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1987 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" applicable with respect to activities after "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/s10711/c"},"text":"section 10711(c) of Pub. L. 100–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s170"},"text":"section 170 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id43af0eba-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIII/s1307/a/3"},"text":"Pub. L. 94–455, title XIII, § 1307(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1722"},"text":"90 Stat. 1722","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/455/tXIII/s1307/a/3"},"text":"“It is the intent of Congress that enactment of this section [amending section 501 and enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s504"},"text":"section 504 of this title","children":[],"tail":"] is not to be regarded in any way as an approval or disapproval of the decision of the Court of Appeals for the Tenth Circuit in Christian Echoes National Ministry, Inc. versus United States, 470 F.2d 849 (1972), or of the reasoning in any of the opinions leading to that decision.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
