{"tag":"section","attrib":{"id":"id445141b9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s876"},"text":null,"children":[{"tag":"num","attrib":{"value":"876"},"text":"§ 876.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alien residents of Puerto Rico, Guam, American Samoa, or the Northern Mariana Islands","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id445141ba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s876/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subpart shall not apply to any alien individual who is a bona fide resident of Puerto Rico, Guam, American Samoa, or the Northern Mariana Islands during the entire taxable year and such alien shall be subject to the tax imposed by section 1.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id445141bb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s876/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross references","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For exclusion from gross income of income derived from sources within—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id445141bc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s876/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Guam, American Samoa, and the Northern Mariana Islands, see section 931, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id445141bd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s876/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Puerto Rico, see section 933.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id445141be-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/281"},"text":"68A Stat. 281","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXII/s1272/b"},"text":"Pub. L. 99–514, title XII, § 1272(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2593"},"text":"100 Stat. 2593","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id445141bf-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id445141c0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id445141c1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1272/b"},"text":"Pub. L. 99–514, § 1272(b)","children":[],"tail":", inserted “, Guam, American Samoa, or the Northern Mariana Islands” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1272/b"},"text":"Pub. L. 99–514, § 1272(b)","children":[],"tail":", amended subsec. (a) generally, substituting “General rule” for “No application to certain alien residents of Puerto Ri