{"tag":"section","attrib":{"id":"id40bd938b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43"},"text":null,"children":[{"tag":"num","attrib":{"value":"43"},"text":"§ 43.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhanced oil recovery credit","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id40bd938c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of section 38, the enhanced oil recovery credit for any taxable year is an amount equal to 15 percent of the taxpayer’s qualified enhanced oil recovery costs for such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40bd938d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Phase-out of credit as crude oil prices increase","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40bd938e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of the credit determined under subsection (a) for any taxable year shall be reduced by an amount which bears the same ratio to the amount of such credit (determined without regard to this paragraph) as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40bd938f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount by which the reference price for the calendar year preceding the calendar year in which the taxable year begins exceeds $28, bears to","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40bd9390-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $6.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40bd9391-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reference price","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the term “reference price” means, with respect to any calendar year, the reference price determined for such calendar year under section 45K(d)(2)(C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40bd9392-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inflation adjustment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40bd9393-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any taxable year beginning in a calendar year after 1991, there shall be substituted for the $28 amount under paragraph (1)(A) an amount equal to the product of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40bd9394-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $28, multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40bd9395-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the inflation adjustment factor for such calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40bd9396-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inflation adjustment factor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “inflation adjustment factor” means, with respect to any calendar year, a fraction the numerator of which is the GNP implicit price deflator for the preceding calendar year and the denominator of which is the GNP implicit price deflator for 1990. For purposes of the preceding sentence, the term “GNP implicit price deflator” means the first revision of the implicit price deflator for the gross national product as computed and published by the Secretary of Commerce. Not later than April 1 of any calendar year, the Secretary shall publish the inflation adjustment factor for the preceding calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40bd9397-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified enhanced oil recovery costs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40bd9398-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified enhanced oil recovery costs” means any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40bd9399-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any amount paid or incurred during the taxable year for tangible property—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40bd939a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is an integral part of a qualified enhanced oil recovery project, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40bd939b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to which depreciation (or amortization in lieu of depreciation) is allowable under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40bd939c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any intangible drilling and development costs—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40bd939d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which are paid or incurred in connection with a qualified enhanced oil recovery project, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40bd939e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to which the taxpayer may make an election under section 263(c) for the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40bd939f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any qualified tertiary injectant expenses (as defined in section 193(b)) which are paid or incurred in connection with a qualified enhanced oil recovery project and for which a deduction is allowable for the taxable year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40bd93a0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any amount which is paid or incurred during the taxable year to construct a gas treatment plant which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40bd93a1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/c/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is located in the area of the United States (within the meaning of section 638(1)) lying north of 64 degrees North latitude,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40bd93a2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/c/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepares Alaska natural gas for transportation through a pipeline with a capacity of at least 2,000,000,000,000 Btu of natural gas per day, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40bd93a3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/c/1/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" produces carbon dioxide which is injected into hydrocarbon-bearing geological formations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40bd93a4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified enhanced oil recovery project","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40bd93a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified enhanced oil recovery project” means any project—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40bd93a6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which involves the application (in accordance with sound engineering principles) of 1 or more tertiary recovery methods (as defined in section 193(b)(3)) which can reasonably be expected to result in more than an insignificant increase in the amount of crude oil which will ultimately be recovered,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40bd93a7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is located within the United States (within the meaning of section 638(1)), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40bd93a8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to which the first injection of liquids, gases, or other matter commences after ","children":[{"tag":"date","attrib":{"date":"1990-12-31"},"text":"December 31, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40bd93a9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A project shall not be treated as a qualified enhanced oil recovery project unless the operator submits to the Secretary (at such times and in such manner as the Secretary provides) a certification from a petroleum engineer that the project meets (and continues to meet) the requirements of subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40bd93aa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" At-risk limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of determining qualified enhanced oil recovery costs, rules similar to the rules of section 49(a)(1), section 49(a)(2), and section 49(b) shall apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40bd93ab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for certain gas displacement projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, immiscible non-hydrocarbon gas displacement shall be treated as a tertiary recovery method under section 193(b)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40bd93ac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alaska natural gas","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1)(D)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40bd93ad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Alaska natural gas” means natural gas entering the Alaska natural gas pipeline (as defined in section 168(i)(16) (determined without regard to subparagraph (B) thereof)) which is produced from a well—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40bd93ae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/c/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" located in the area of the State of Alaska lying north of 64 degrees North latitude, determined by excluding the area of the Alaska National Wildlife Refuge (including the continental shelf thereof within the meaning of section 638(1)), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40bd93af-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/c/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursuant to the applicable State and Federal pollution prevention, control, and permit requirements from such area (including the continental shelf thereof within the meaning of section 638(1)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40bd93b0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Natural gas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “natural gas” has the meaning given such term by section 613A(e)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40bd93b1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40bd93b2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disallowance of deduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any deduction allowable under this chapter for any costs taken into account in computing the amount of the credit determined under subsection (a) shall be reduced by the amount of such credit attributable to such costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40bd93b3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis adjustments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subtitle, if a credit is determined under this section for any expenditure with respect to any property, the increase in the basis of such property which would (but for this subsection) result from such expenditure shall be reduced by the amount of the credit so allowed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40bd93b4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election to have credit not apply","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40bd93b5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A taxpayer may elect to have this section not apply for any taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40bd93b6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for making election","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An election under paragraph (1) for any taxable year may be made (or revoked) at any time before the expiration of the 3-year period beginning on the last date prescribed by law for filing the return for such taxable year (determined without regard to extensions).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40bd93b7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s43/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manner of making election","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An election under paragraph (1) (or revocation thereof) shall be made in such manner as the Secretary may by regulations prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id40bd93b8-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11511/a"},"text":"Pub. L. 101–508, title XI, § 11511(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-483"},"text":"104 Stat. 1388–483","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tIII/s317/a"},"text":"Pub. L. 106–554, § 1(a)(7) [title III, § 317(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–645; "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVII/s707/a"},"text":"Pub. L. 108–357, title VII, § 707(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1550"},"text":"118 Stat. 1550","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXIII/s1322/a/3/B"},"text":"Pub. L. 109–58, title XIII, § 1322(a)(3)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1011"},"text":"119 Stat. 1011","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/135/tIV/s412/i"},"text":"Pub. L. 109–135, title IV, § 412(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-21"},"text":"Dec. 21, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2637"},"text":"119 Stat. 2637","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id40bd93b9-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id40bd93ba-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Inflation Adjusted Items for Certain Tax Years","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For inflation adjustment of certain items in this section, see Internal Revenue Notices listed in a table below.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id40bd93bb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id40bd93bc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 43 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s32"},"text":"section 32 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 43 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s37"},"text":"section 37 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id40bd93bd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":" substituted “section 45K(d)(2)(C)” for “section 29(d)(2)(C)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/135"},"text":"Pub. L. 109–135","children":[],"tail":" reenacted heading without change and amended text generally. Prior to amendment, text read as follows: “For purposes of paragraph (1)(D)—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—The term ‘Alaska natural gas’ means natural gas entering the Alaska natural gas pipeline (as defined in section 168(i)(16) (determined without regard to subparagraph (B) thereof)) which is produced from a well—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) located in the area of the State of Alaska lying north of 64 degrees North latitude, determined by excluding the area of the Alaska National Wildlife Refuge (including the continental shelf thereof within the meaning of section 638(1)), and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) pursuant to the applicable State and Federal pollution prevention, control, and permit requirements from such area (including the continental shelf thereof within the meaning of section 638(1)).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Natural gas","children":[],"tail":".—The term ‘natural gas’ has the meaning given such term by section 613A(e)(2).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (c)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s707/a"},"text":"Pub. L. 108–357, § 707(a)","children":[],"tail":", added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s707/b"},"text":"Pub. L. 108–357, § 707(b)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (c)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554"},"text":"Pub. L. 106–554","children":[],"tail":" inserted “(as defined in section 193(b))” after “expenses” and struck out “under section 193” after “allowable”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id40bd93be-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id40bd