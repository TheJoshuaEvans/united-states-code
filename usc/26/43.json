ed in taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1990-12-31"},"text":"December 31, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special rule for significant expansion of projects","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of section 43(c)(2)(A)(iii) of the Internal Revenue Code of 1986 (as added by subsection (a)), any significant expansion after ","children":[{"tag":"date","attrib":{"date":"1990-12-31"},"text":"December 31, 1990","children":[],"tail":", of a project begun before "},{"tag":"date","attrib":{"date":"1991-01-01"},"text":"January 1, 1991","children":[],"tail":", shall be treated as a project with respect to which the first injection commences after "},{"tag":"date","attrib":{"date":"1990-12-31"},"text":"December 31, 1990","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id40bd93c3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Inflation Adjusted Items for Certain Years","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions relating to inflation adjustment of items in this section for certain years were contained in the following:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2024—Internal Revenue Notice 2024–61.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2023—Internal Revenue Notice 2023–57.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Internal Revenue Notice 2022–19.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Internal Revenue Notice 2021–47.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Internal Re