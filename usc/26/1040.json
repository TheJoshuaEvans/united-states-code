{"tag":"section","attrib":{"id":"id44abe4ea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1040"},"text":null,"children":[{"tag":"num","attrib":{"value":"1040"},"text":"§ 1040.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of certain farm, etc., real property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44abe4eb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1040/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the executor of the estate of any decedent transfers to a qualified heir (within the meaning of section 2032A(e)(1)) any property with respect to which an election was made under section 2032A, then gain on such transfer shall be recognized to the estate only to the extent that, on the date of such transfer, the fair market value of such property exceeds the value of such property for purposes of chapter 11 (determined without regard to section 2032A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44abe4ec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1040/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Similar rule for certain trusts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent provided in regulations prescribed by the Secretary, a rule similar to the rule provided in subsection (a) shall apply where the trustee of a trust (any portion of which is included in the gross estate of the decedent) transfers property with respect to which an election was made under section 2032A.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44abe4ed-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1040/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis of property acquired in transfer described in subsection (a) or (b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The basis of property acquired in a transfer with respect to which gain realized is not recognized by reason of subsection (a) or (b) shall be the basis of such property immediately before the transfer increased by the amount of the gain recognized to the estate or trust on the transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44abe4ee-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXX/s2005/b"},"text":"Pub. L. 94–455, title XX, § 2005(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1877"},"text":"90 Stat. 1877","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/600/tVII/s702/d/3"},"text":"Pub. L. 95–600, title VII, § 702(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2929"},"text":"92 Stat. 2929","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/222/tI/s105/a/5/A"},"text":"Pub. L. 96–222, title I, § 105(a)(5)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-04-01"},"text":"Apr. 1, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/219"},"text":"94 Stat. 219","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/223/tIV/s401/c/2/A"},"text":"Pub. L. 96–223, title IV, § 401(c)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-04-02"},"text":"Apr. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/300"},"text":"94 Stat. 300","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/tIV/s421/j/2/B"},"text":"Pub. L. 97–34, title IV, § 421(j)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/312"},"text":"95 Stat. 312","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/448/tI/s104/b/3/A"},"text":"Pub. L. 97–448, title I, § 104(b)(3)(A)","children":[],"tail":", (B), "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2381"},"text":"96 Stat. 2381","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/16/tV/s542/d/1"},"text":"Pub. L. 107–16, title V, § 542(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-06-07"},"text":"June 7, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/84"},"text":"115 Stat. 84","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/312/tIII/s301/a"},"text":"Pub. L. 111–312, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-17"},"text":"Dec. 17, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3300"},"text":"124 Stat. 3300","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44abe4ef-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44abe4f0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44abe4f1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/312"},"text":"Pub. L. 111–312","children":[],"tail":" amended section to read as if amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/107/16/s542/d/1"},"text":"Pub. L. 107–16, § 542(d)(1)","children":[],"tail":", had never been enacted. See 2001 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16/s542/d/1"},"text":"Pub. L. 107–16, § 542(d)(1)","children":[],"tail":", amended section generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) ","children":[{"tag":"inline","attrib":{},"text":"General rule","children":[],"tail":".—If the executor of the estate of any decedent transfers to a qualified heir (within the meaning of section 2032A(e)(1)) any property with respect to which an election was made under section 2032A, then gain on such transfer shall be recognized to the estate only to the extent that, on the date of such transfer, the fair market value of such property exceeds the value of such property for purposes of chapter 11 (determined without regard to section 2032A)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) ","children":[{"tag":"inline","attrib":{},"text":"Similar rule for certain trusts","children":[],"tail":".—To the extent provided in regulations prescribed by the Secretary, a rule similar to the rule provided in subsection (a) shall apply where the trustee of a trust (any portion of which is included in the gross estate of the decedent) transfers property with respect to which an election was made under section 2032A."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(c) ","children":[{"tag":"inline","attrib":{},"text":"Basis of property acquired in transfer described in subsection (","children":[],"tail":"a"},{"tag":"inline","attrib":{},"text":") or (","children":[],"tail":"b).—The basis of property acquired in a transfer with respect to which gain realized is not recognized by reason of subsection (a) or (b) shall be the basis of such property immediately before the transfer increased by the amount of the gain recognized to the estate or trust on the transfer.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/448/s104/b/3/A"},"text":"Pub. L. 97–448, § 104(b)(3)(A)","children":[],"tail":", substituted “on the date of such transfer” for “on the date of such exchange”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/448/s104/b/3/B"},"text":"Pub. L. 97–448, § 104(b)(3)(B)","children":[],"tail":", substituted references to “transfer”, “a transfer”, and “the transfer” for references to “exchange”, “an exchange”, and “the exchange”, respectively, wherever appearing in heading and text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":" substituted “Transfer of certain farm, etc., real property” for “Use of farm, etc., real property to satisfy pecuniary bequest” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":" revised subsec. (a) generally, substituting “transfers to a qualified heir (within the meaning of section 2032A(e)(1)) any property” for “satisfies the right of a qualified heir (within the meaning of section 2032A(e)(1)) to receive a pecuniary bequest with property” and “such transfer” for “such exchange” before “shall be recognized”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":" substituted “shall apply where the trustee of a trust (any portion of which is included in the gross estate of the decedent) transfers property with respect to which an election was made under section 2032A” for “shall apply where—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) by reason of the death of the decedent, a qualified heir has a right to receive from a trust a specific dollar amount which is the equivalent of a pecuniary bequest, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) the trustee of the trust satisfies such right with property with respect to which an election was made under section 2032A”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/223"},"text":"Pub. L. 96–223","children":[],"tail":" substituted “Use of farm, etc., property to satisfy pecuniary bequest” for “Use of certain appreciated carryover basis property to satisfy pecuniary request” in section catchline, generally revised subsecs. (a) and (b) to reflect the repeal elsewhere in the Code of carryover basis provisions, and struck out subsec. (d) which had provided that, for purposes of this section, references to carryover basis property should be treated as including a reference to property the valuation of which is determined under section 2032A. "},{"tag":"ref","attrib":{"href":"/us/pl/96/222"},"text":"Pub. L. 96–222","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600"},"text":"Pub. L. 95–600","children":[],"tail":" substituted “chapter 11 (determined without regard to section 2032A)” for “chapter 11”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44abe4f2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44abe4f3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/312"},"text":"Pub. L. 111–312","children":[],"tail":" applicable to estates of decedents dying, and transfers made after "},{"tag":"date","attrib":{"date":"2009-12-31"},"text":"Dec. 31, 2009","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/312/s301/e"},"text":"section 301(e) of Pub. L. 111–312","children":[],"tail":", set out as an Effective and Termination Dates of 2010 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s121"},"text":"section 121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44abe4f4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2001 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16"},"text":"Pub. L. 107–16","children":[],"tail":" applicable to estates of decedents dying after "},{"tag":"date","attrib":{"date":"2009-12-31"},"text":"Dec. 31, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/16/s542/f/1"},"text":"section 542(f)(1) of Pub. L. 107–16","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s121"},"text":"section 121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44abe4f5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1983 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/448"},"text":"Pub. L. 97–448","children":[],"tail":" effective, except as otherwise provided, as if it had been included in the provision of the Economic Recovery Tax Act of 1981, "},{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/97/448/s109"},"text":"section 109 of Pub. L. 97–448","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44abe4f6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":" applicable with respect to the estates of decedents dying after "},{"tag":"date","attrib":{"date":"1976-12-31"},"text":"Dec. 31, 1976","children":[],"tail":", upon compliance with certain conditions relating to timely election requirement, reinstatement of elections, and statute of limitations, see "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/s421/k/5"},"text":"section 421(k)(5) of Pub. L. 97–34","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2032A"},"text":"section 2032A of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44abe4f7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/223"},"text":"Pub. L. 96–223","children":[],"tail":" applicable in respect of decedents dying after "},{"tag":"date","attrib":{"date":"1976-12-31"},"text":"Dec. 31, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/223/s401/e"},"text":"section 401(e) of Pub. L. 96–223","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1023"},"text":"section 1023 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/222/tI/s105/a/5/B"},"text":"Pub. L. 96–222, title I, § 105(a)(5)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-04-01"},"text":"Apr. 1, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/219"},"text":"94 Stat. 219","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"“Notwithstanding section 515 of the Revenue Act of 1978 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600/s515"},"text":"section 515 of Pub. L. 95–600","children":[],"tail":" which deferred carryover basis rules until "},{"tag":"date","attrib":{"date":"1979-12-31"},"text":"Dec. 31, 1979","children":[],"tail":"], section 1040 of the Internal Revenue Code of 1986 [formerly I.R.C. 1954] (as amended by subparagraph (A) [amending this section]) shall apply with respect to the estates of decedents dying after "},{"tag":"date","attrib":{"date":"1976-12-31"},"text":"December 31, 1976","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"to