{"tag":"section","attrib":{"id":"id4734645f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6709"},"text":null,"children":[{"tag":"num","attrib":{"value":"6709"},"text":"§ 6709.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties with respect to mortgage credit certificates","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47346460-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6709/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Negligence","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47346461-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6709/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person makes a material misstatement in any verified written statement made under penalties of perjury with respect to the issuance of a mortgage credit certificate, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47346462-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6709/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such misstatement is due to the negligence of such person,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"such person shall pay a penalty of $1,000 for each mortgage credit certificate with respect to which such a misstatement was made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47346463-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6709/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fraud","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a misstatement described in subsection (a)(1) is due to fraud on the part of the person making such misstatement, in addition to any criminal penalty, such person shall pay a penalty of $10,000 for each mortgage credit certificate with respect to which such a misstatement is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47346464-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6709/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person required by section 25(g) to file a report with the Secretary who fails to file the report with respect to any mortgage credit certificate at the time and in the manner required by the Secretary shall pay a penalty of $200 for such failure unless it is shown that such failure is due to reasonable cause and not to willful neglect. In the case of any report required under the second sentence of section 25(g), the aggregate amount of the penalty imposed by the preceding sentence shall not exceed $2,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47346465-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6709/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mortgage credit certificate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “mortgage credit certificate” has the meaning given to such term by section 25(c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47346466-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tVI/s612/d/1"},"text":"Pub. L. 98–369, div. A, title VI, § 612(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/912"},"text":"98 Stat. 912","children":[],"tail":", § 6708; renumbered § 6709, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVIII/s1862/d/2"},"text":"Pub. L. 99–514, title XVIII, § 1862(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2884"},"text":"100 Stat. 2884","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47346467-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47346468-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47346469-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" effective, except as otherwise provided, as if included in the provisions of the Tax Reform Act of 1984, "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA"},"text":"Pub. L. 98–369, div. A","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1881"},"text":"section 1881 of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s48"},"text":"section 48 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4734646a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to interest paid or accrued after ","children":[{"tag":"date","attrib":{"date":"1984-12-31"},"text":"Dec. 31, 1984","children":[],"tail":", on indebtedness incurred after "},{"tag":"date","attrib":{"date":"1984-12-31"},"text":"Dec. 31, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s612/g"},"text":"section 612(g) of Pub. L. 98–369","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s25"},"text":"section 25 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
