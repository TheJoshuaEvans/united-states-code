{"tag":"section","attrib":{"id":"id4102b398-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D"},"text":null,"children":[{"tag":"num","attrib":{"value":"48D"},"text":"§ 48D.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced manufacturing investment credit","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4102b399-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of section 46, the advanced manufacturing investment credit for any taxable year is an amount equal to 35 percent of the qualified investment for such taxable year with respect to any advanced manufacturing facility of an eligible taxpayer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4102b39a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified investment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4102b39b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsection (a), the qualified investment with respect to any advanced manufacturing facility for any taxable year is the basis of any qualified property placed in service by the taxpayer during such taxable year which is part of an advanced manufacturing facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4102b39c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified property","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4102b39d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “qualified property” means property—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4102b39e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is tangible property,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4102b39f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to which depreciation (or amortization in lieu of depreciation) is allowable,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4102b3a0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" which is—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4102b3a1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/b/2/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" constructed, reconstructed, or erected by the taxpayer, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4102b3a2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/b/2/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquired by the taxpayer if the original use of such property commences with the taxpayer, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4102b3a3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/b/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is integral to the operation of the advanced manufacturing facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4102b3a4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Buildings and structural components","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4102b3a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified property” includes any building or its structural components which otherwise satisfy the requirements under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4102b3a6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Clause (i) shall not apply with respect to a building or portion of a building used for offices, administrative services, or other functions unrelated to manufacturing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4102b3a7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced manufacturing facility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “advanced manufacturing facility” means a facility for which the primary purpose is the manufacturing of semiconductors or semiconductor manufacturing equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4102b3a8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with rehabilitation credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The qualified investment with respect to any advanced manufacturing facility for any taxable year shall not include that portion of the basis of any property which is attributable to qualified rehabilitation expenditures (as defined in section 47(c)(2)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4102b3a9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain progress expenditure rules made applicable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rules similar to the rules of subsections (c)(4) and (d) of section 46 (as in effect on the day before the date of the enactment of the Revenue Reconciliation Act of 1990) shall apply for purposes of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4102b3aa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible taxpayer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “eligible taxpayer” means any taxpayer which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4102b3ab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not a foreign entity of concern (as defined in section 9901(6) ","children":[{"tag":"ref","attrib":{"idref":"fn002039"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002039"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the William M. (Mac) Thornberry National Defense Authorization Act for Fiscal Year 2021), and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4102b3ac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not made an applicable transaction (as defined in section 50(a)) during the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4102b3ad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elective payment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4102b3ae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in paragraph (2)(A), in the case of a taxpayer making an election (at such time and in such manner as the Secretary may provide) under this subsection with respect to the credit determined under subsection (a) with respect to such taxpayer, such taxpayer shall be treated as making a payment against the tax imposed by subtitle A (for the taxable year with respect to which such credit was determined) equal to the amount of such credit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4102b3af-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4102b3b0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to partnerships and s corporations","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4102b3b1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of the credit determined under subsection (a) with respect to any property held directly by a partnership or S corporation, any election under paragraph (1) shall be made by such partnership or S corporation. If such partnership or S corporation makes an election under such paragraph (in such manner as the Secretary may provide) with respect to such credit—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4102b3b2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/d/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall make a payment to such partnership or S corporation equal to the amount of such credit,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4102b3b3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/d/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paragraph (3) shall be applied with respect to such credit before determining any partner’s distributive share, or shareholder’s pro rata share, of such credit,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4102b3b4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/d/2/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amount with respect to which the election in paragraph (1) is made shall be treated as tax exempt income for purposes of sections 705 and 1366, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4102b3b5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/d/2/A/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a partner’s distributive share of such tax exempt income shall be based on such partner’s distributive share of the otherwise applicable credit for each taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4102b3b6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with application at partner or shareholder level","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any property held directly by a partnership or S corporation, no election by any partner or shareholder shall be allowed under paragraph (1) with respect to any credit determined under subsection (a) with respect to such property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4102b3b7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elections","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any election under paragraph (1) shall be made not later than the due date (including extensions of time) for the return of tax for the taxable year for which the election is made, but in no event earlier than 270 days after the date of the enactment of this section. Any such election, once made, shall be irrevocable. Except as otherwise provided in this subparagraph, any election under paragraph (1) shall apply with respect to any credit for the taxable year for which the election is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4102b3b8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The payment described in paragraph (1) shall be treated as made on the later of the due date (determined without regard to extensions) of the return of tax for the taxable year or the date on which such return is filed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4102b3b9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of payments to partnerships and s corporations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1324"},"text":"section 1324 of title 31","children":[],"tail":", United States Code, the payments under subparagraph (A)(i)(I) shall be treated in the same manner as a refund due from a credit provision referred to in subsection (b)(2) of such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id410523ba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition of, and prior to, any amount being treated as a payment which is made by the taxpayer under paragraph (1) or any payment being made pursuant to subparagraph (A), the Secretary may require such information or registration as the Secretary deems necessary or appropriate for purposes of preventing duplication, fraud, improper payments, or excessive payments under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id410523bb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excessive payment","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id410523bc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/d/2/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any amount treated as a payment which is made by the taxpayer under paragraph (1), or any payment made pursuant to subparagraph (A), which the Secretary determines constitutes an excessive payment, the tax imposed on such taxpayer by chapter 1 for the taxable year in which such determination is made shall be increased by an amount equal to the sum of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id410523bd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/d/2/F/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of such excessive payment, plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id410523be-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/d/2/F/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to 20 percent of such excessive payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id410523bf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/d/2/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reasonable cause","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Clause (i)(II) shall not apply if the taxpayer demonstrates to the satisfaction of the Secretary that the excessive payment resulted from reasonable cause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id410523c0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/d/2/F/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excessive payment defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subparagraph, the term “excessive payment” means, with respect to property for which an election is made under this subsection for any taxable year, an amount equal to the excess of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id410523c1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/d/2/F/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount treated as a payment which is made by the taxpayer under paragraph (1), or the amount of the payment made pursuant to subparagraph (A), with respect to such property for such taxable year, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id410523c2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/d/2/F/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the credit which, without application of this subsection, would be otherwise allowable (determined without regard to section 38(c)) under subsection (a) with respect to such property for such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id410523c3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial of double benefit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a taxpayer making an election under this subsection with respect to the credit determined under subsection (a), such credit shall be reduced to zero and shall, for any other purposes under this title, be deemed to have been allowed to the taxpayer for such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id410523c4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mirror code possessions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any possession of the United States with a mirror code tax system (as defined in section 24(k)), this subsection shall not be treated as part of the income tax laws of the United States for purposes of determining the income tax law of such possession unless such possession elects to have this subsection be so treated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id410523c5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis reduction and recapture","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Rules similar to the rules of subsections (a) and (c) of section 50 shall apply with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id410523c6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amount treated as a payment which is made by the taxpayer under paragraph (1), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id410523c7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any payment made pursuant to paragraph (2)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id410523c8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall issue such regulations or other guidance as may be necessary or appropriate to carry out the purposes of this subsection, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id410523c9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/d/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulations or other guidance providing rules for determining a partner’s distributive share of the tax exempt income described in paragraph (2)(A)(i)(III), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id410523ca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/d/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guidance to ensure that the amount of the payment or deemed payment made under this subsection is commensurate with the amount of the credit that would be otherwise allowable (determined without regard to section 38(c)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id410523cb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s48D/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The credit allowed under this section shall not apply to property the construction of which begins after ","children":[{"tag":"date","attrib":{"date":"2026-12-31"},"text":"December 31, 2026","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id410523cc-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dA/s107/a"},"text":"Pub. L. 117–167, div. A, § 107(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1393"},"text":"136 Stat. 1393","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70308/a"},"text":"Pub. L. 119–21, title VII, § 70308(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/201"},"text":"139 Stat. 201","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id410523cd-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id410523ce-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id410523cf-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the Revenue Reconciliation Act of 1990, referred to in subsec. (b)(5), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 9901(6) of the William M. (Mac) Thornberry National Defense Authorization Act for Fiscal Year 2021, referred to in subsec. (c)(1), means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s9901/6"},"text":"section 9901(6) of Pub. L. 116–283","children":[],"tail":", but probably should be a reference to section 9901(8) of the Act, which defines “foreign entity of concern” and which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s4651/8"},"text":"section 4651(8) of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of the enactment of this section, referred to in subsec. (d)(2)(B), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167"},"text":"Pub. L. 117–167","children":[],"tail":", which was approved Aug. 9. 2022."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id410523d0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 48D, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIX/s9023/a"},"text":"Pub. L. 111–148, title IX, § 9023(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/877"},"text":"124 Stat. 877","children":[],"tail":", provided for a qualifying therapeutic discovery project credit, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/d/3/A"},"text":"Pub. L. 115–141, div. U, title IV, § 401(d)(3)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1209"},"text":"132 Stat. 1209","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id410523d1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" substituted “35 percent” for “25 percent”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id410523d2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id410523d3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70308/b"},"text":"Pub. L. 119–21, title VII, § 70308(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/201"},"text":"139 Stat. 201","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/21/tVII/s70308/b"},"text":"“The amendments made by this section [amending this section] shall apply to property placed in service after ","children":[{"tag":"date","attrib":{"date":"2025-12-31"},"text":"December 31, 2025","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id410523d4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to property placed in service after ","children":[{"tag":"date","attrib":{"date":"2022-12-31"},"text":"Dec. 31, 2022","children":[],"tail":", and, for any property the construction of which begins prior to "},{"tag":"date","attrib":{"date":"2023-01-01"},"text":"Jan. 1, 2023","children":[],"tail":", only to the extent of the basis thereof attributable to the construction, reconstruction, or erection after "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/s107/f"},"text":"section 107(f) of Pub. L. 117–167","children":[],"tail":", set out as an Effective Date of 2022 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s905"},"text":"section 905 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
