{"tag":"section","attrib":{"id":"id467f459b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W"},"text":null,"children":[{"tag":"num","attrib":{"value":"6050W"},"text":"§ 6050W.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Returns relating to payments made in settlement of payment card and third party network transactions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id467f459c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each payment settlement entity shall make a return for each calendar year setting forth—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467f459d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address, and TIN of each participating payee to whom one or more payments in settlement of reportable payment transactions are made,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467f459e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the gross amount of the reportable payment transactions with respect to each such participating payee and ","children":[{"tag":"ref","attrib":{"idref":"fn002284"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002284"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be preceded by a comma."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467f459f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a third party settlement organization, the portion of reportable payment transactions that have been reasonably designated by payors as cash tips and the occupation described in section 224(d)(1) of the person receiving such tips.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such return shall be made at such time and in such form and manner as the Secretary may require by regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467f45a0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment settlement entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467f45a1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “payment settlement entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id467f45a2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a payment card transaction, the merchant acquiring entity, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467f45a3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a third party network transaction, the third party settlement organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467f45a4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Merchant acquiring entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “merchant acquiring entity” means the bank or other organization which has the contractual obligation to make payment to participating payees in settlement of payment card transactions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467f45a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Third party settlement organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “third party settlement organization” means the central organization which has the contractual obligation to make payment to participating payees of third party network transactions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467f45a6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules related to intermediaries","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id467f45a7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aggregated payees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any case where reportable payment transactions of more than one participating payee are settled through an intermediary—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id467f45a8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such intermediary shall be treated as the participating payee for purposes of determining the reporting obligations of the payment settlement entity with respect to such transactions, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id467f45a9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such intermediary shall be treated as the payment settlement entity with respect to the settlement of such transactions with the participating payees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467f45aa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electronic payment facilitators","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case where an electronic payment facilitator or other third party makes payments in settlement of reportable payment transactions on behalf of the payment settlement entity, the return under subsection (a) shall be made by such electronic payment facilitator or other third party in lieu of the payment settlement entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467f45ab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reportable payment transaction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467f45ac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “reportable payment transaction” means any payment card transaction and any third party network transaction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467f45ad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment card transaction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “payment card transaction” means any transaction in which a payment card is accepted as payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467f45ae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Third party network transaction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “third party network transaction” means any transaction described in subsection (d)(3)(A)(iii) which is settled through a third party payment network.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467f45af-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467f45b0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participating payee","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id467f45b1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “participating payee” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id467f45b2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a payment card transaction, any person who accepts a payment card as payment, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id467f45b3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a third party network transaction, any person who accepts payment from a third party settlement organization in settlement of such transaction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467f45b4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of foreign persons","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided by the Secretary in regulations or other guidance, such term shall not include any person with a foreign address. Notwithstanding the preceding sentence, a person with only a foreign address shall not be treated as a participating payee with respect to any payment settlement entity solely because such person receives payments from such payment settlement entity in dollars.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467f45b5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion of governmental units","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person” includes any governmental unit (and any agency or instrumentality thereof).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467f45b6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment card","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “payment card” means any card which is issued pursuant to an agreement or arrangement which provides for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id467f45b7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more issuers of such cards,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467f45b8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a network of persons unrelated to each other, and to the issuer, who agree to accept such cards as payment, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467f45b9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standards and mechanisms for settling the transactions between the merchant acquiring entities and the persons who agree to accept such cards as payment.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The acceptance as payment of any account number or other indicia associated with a payment card shall be treated for purposes of this section in the same manner as accepting such payment card as payment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46818faa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Third party payment network","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “third party payment network” means any agreement or arrangement—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46818fab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" which involves the establishment of accounts with a central organization by a substantial number of persons who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id46818fac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are unrelated to such organization,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46818fad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide goods or services, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46818fae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/d/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have agreed to settle transactions for the provision of such goods or services pursuant to such agreement or arrangement,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46818faf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which provides for standards and mechanisms for settling such transactions, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46818fb0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which guarantees persons providing goods or services pursuant to such agreement or arrangement that such persons will be paid for providing such goods or services.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such term shall not include any agreement or arrangement which provides for the issuance of payment cards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46818fb1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for de minimis payments by third party settlement organizations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A third party settlement organization shall be required to report any information under subsection (a) with respect to third party network transactions of any participating payee only if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46818fb2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount which would otherwise be reported under subsection (a)(2) with respect to such transactions exceeds $20,000, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46818fb3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate number of such transactions exceeds 200.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46818fb4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statements to be furnished to persons with respect to whom information is required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Every person required to make a return under subsection (a) shall furnish to each person with respect to whom such a return is required a written statement showing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46818fb5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address, and phone number of the information contact of the person required to make such return, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46818fb6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the gross amount of the reportable payment transactions (including a separate accounting of any such amounts that have been reasonably designated by payors as cash tips and the occupation described in section 224(d)(1) of the person receiving such tips) with respect to the person required to be shown on the return.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The written statement required under the preceding sentence shall be furnished to the person on or before January 31 of the year following the calendar year for which the return under subsection (a) was required to be made. Such statement may be furnished electronically, and if so, the email address of the person required to make such return may be shown in lieu of the phone number.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46818fb7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050W/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may prescribe such regulations or other guidance as may be necessary or appropriate to carry out this section, including rules to prevent the reporting of the same transaction more than once.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46818fb8-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289/dC/tIII/s3091/a"},"text":"Pub. L. 110–289, div. C, title III, § 3091(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2908"},"text":"122 Stat. 2908","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/123/dD/tII/s41117/a"},"text":"Pub. L. 115–123, div. D, title II, § 41117(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-09"},"text":"Feb. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/162"},"text":"132 Stat. 162","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/2/tIX/s9674/a"},"text":"Pub. L. 117–2, title IX, § 9674(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/185"},"text":"135 Stat. 185","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII"},"text":"Pub. L. 119–21, title VII","children":[],"tail":", §§ 70201(f)(3), 70432(a)(1), "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/173"},"text":"139 Stat. 173","children":[],"tail":", 243.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46818fb9-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46818fba-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46818fbb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70201/f/3/A"},"text":"Pub. L. 119–21, § 70201(f)(3)(A)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70432/a/1"},"text":"Pub. L. 119–21, § 70432(a)(1)","children":[],"tail":", amended subsec. (e) generally. Prior to amendment, text read as follows: “A third party settlement organization shall not be required to report any information under subsection (a) with respect to third party network transactions of any participating payee if the amount which would otherwise be reported under subsection (a)(2) with respect to such transactions does not exceed $600.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70201/f/3/B"},"text":"Pub. L. 119–21, § 70201(f)(3)(B)","children":[],"tail":", inserted “(including a separate accounting of any such amounts that have been reasonably designated by payors as cash tips and the occupation described in section 224(d)(1) of the person receiving such tips)” after “reportable payment transactions”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2/s9674/b"},"text":"Pub. L. 117–2, § 9674(b)","children":[],"tail":", inserted “described in subsection (d)(3)(A)(iii)” after “any transaction”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2/s9674/a"},"text":"Pub. L. 117–2, § 9674(a)","children":[],"tail":", amended subsec. (e) generally. Prior to amendment, subsec. (e) related to an exception for de minimis payments by third party settlement organizations."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (d)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123"},"text":"Pub. L. 115–123","children":[],"tail":" inserted at end “Notwithstanding the preceding sentence, a person with only a foreign address shall not be treated as a participating payee with respect to any payment settlement entity solely because such person receives payments from such payment settlement entity in dollars.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46818fbc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46818fbd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70201/f/3"},"text":"section 70201(f)(3) of Pub. L. 119–21","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"2024-12-31"},"text":"Dec. 31, 2024","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70201/j"},"text":"section 70201(j) of Pub. L. 119–21","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s45B"},"text":"section 45B of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70432/a/2"},"text":"Pub. L. 119–21, title VII, § 70432(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/243"},"text":"139 Stat. 243","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/21/tVII/s70432/a/2"},"text":"“The amendment made by this subsection [amending this section] shall take effect as if included in section 9674 of the American Rescue Plan Act [of 2021, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2"},"text":"Pub. L. 117–2","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46818fbe-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2/tIX/s9674/c"},"text":"Pub. L. 117–2, title IX, § 9674(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/185"},"text":"135 Stat. 185","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/2/tIX/s9674/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null