{"tag":"section","attrib":{"id":"id451729c7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1464"},"text":null,"children":[{"tag":"num","attrib":{"value":"1464"},"text":"§ 1464.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refunds and credits with respect to withheld tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Where there has been an overpayment of tax under this chapter, any refund or credit made under chapter 65 shall be made to the withholding agent unless the amount of such tax was actually withheld by the withholding agent.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id451729c8-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/360"},"text":"68A Stat. 360","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
