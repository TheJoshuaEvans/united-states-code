{"tag":"section","attrib":{"id":"id417ec151-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139"},"text":null,"children":[{"tag":"num","attrib":{"value":"139"},"text":"§ 139.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disaster relief payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id417ec152-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Gross income shall not include any amount received by an individual as a qualified disaster relief payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id417ec153-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified disaster relief payment defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “qualified disaster relief payment” means any amount paid to or for the benefit of an individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id417ec154-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reimburse or pay reasonable and necessary personal, family, living, or funeral expenses incurred as a result of a qualified disaster,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id417ec155-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reimburse or pay reasonable and necessary expenses incurred for the repair or rehabilitation of a personal residence or repair or replacement of its contents to the extent that the need for such repair, rehabilitation, or replacement is attributable to a qualified disaster,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id417ec156-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by a person engaged in the furnishing or sale of transportation as a common carrier by reason of the death or personal physical injuries incurred as a result of a qualified disaster, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id417ec157-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such amount is paid by a Federal, State, or local government, or agency or instrumentality thereof, in connection with a qualified disaster in order to promote the general welfare,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"but only to the extent any expense compensated by such payment is not otherwise compensated for by insurance or otherwise.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id417ec158-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified disaster defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “qualified disaster” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id417ec159-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a disaster which results from a terroristic or military action (as defined in section 692(c)(2)),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id417ec15a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a federally declared disaster (as defined by section 165(i)(5)(A)),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id417ec15b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a disaster which results from an accident involving a common carrier, or from any other event, which is determined by the Secretary to be of a catastrophic nature, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id417ec15c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to amounts described in subsection (b)(4), a disaster which is determined by an applicable Federal, State, or local authority (as determined by the Secretary) to warrant assistance from the Federal, State, or local government or agency or instrumentality thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id417ec15d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with employment taxes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of chapter 2 and subtitle C, qualified disaster relief payments and qualified disaster mitigation payments shall not be treated as net earnings from self-employment, wages, or compensation subject to tax.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id417ec15e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No relief for certain individuals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsections (a), (f), and (g) shall not apply with respect to any individual identified by the Attorney General to have been a participant or conspirator in a terroristic action (as so defined), or a representative of such individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id417ec15f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of certain additional payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Gross income shall not include any amount received as payment under section 406 of the Air Transportation Safety and System Stabilization Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id417ec160-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified disaster mitigation payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id417ec161-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Gross income shall not include any amount received as a qualified disaster mitigation payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id417ec162-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified disaster mitigation payment defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “qualified disaster mitigation payment” means any amount which is paid pursuant to the Robert T. Stafford Disaster Relief and Emergency Assistance Act (as in effect on the date of the enactment of this subsection) or the National Flood Insurance Act (as in effect on such date) to or for the benefit of the owner of any property for hazard mitigation with respect to such property. Such term shall not include any amount received for the sale or disposition of any property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id417ec163-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No increase in basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this subtitle, no increase in the basis or adjusted basis of any property shall result from any amount excluded under this subsection with respect to such property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id417ec164-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial of double benefit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this subtitle, no deduction or credit shall be allowed (to the person for whose benefit a qualified disaster relief payment or qualified disaster mitigation payment is made) for, or by reason of, any expenditure to the extent of the amount excluded under this section with respect to such expenditure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id417ec165-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/134/tI/s111/a"},"text":"Pub. L. 107–134, title I, § 111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-23"},"text":"Jan. 23, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2432"},"text":"115 Stat. 2432","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/7/s1/a"},"text":"Pub. L. 109–7, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-04-15"},"text":"Apr. 15, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/21"},"text":"119 Stat. 21","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/343/dC/tVII/s706/a/2/D/iv"},"text":"Pub. L. 110–343, div. C, title VII, § 706(a)(2)(D)(iv)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3922"},"text":"122 Stat. 3922","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/41"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(41)","children":[],"tail":", (b)(10)(A), "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1186"},"text":"132 Stat. 1186","children":[],"tail":", 1202.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id417ec166-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id417ec167-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id417ec168-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 406 of the Air Transportation Safety and System Stabilization Act, referred to in subsec. (f), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/42/s406"},"text":"section 406 of Pub. L. 107–42","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s40101"},"text":"section 40101 of Title 49","children":[],"tail":", Transportation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Robert T. Stafford Disaster Relief and Emergency Assistance Act, referred to in subsec. (g)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288"},"text":"Pub. L. 93–288","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/143"},"text":"88 Stat. 143","children":[],"tail":", which is classified principally to chapter 68 (§ 5121 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"section 5121 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of the enactment of this subsection, referred to in subsec. (g)(2), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/7"},"text":"Pub. L. 109–7","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2005-04-15"},"text":"Apr. 15, 2005","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The National Flood Insurance Act, referred to in subsec. (g)(2), probably means the National Flood Insurance Act of 1968, title XIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/448"},"text":"Pub. L. 90–448","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-01"},"text":"Aug. 1, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/572"},"text":"82 Stat. 572","children":[],"tail":", which is classified principally to chapter 50 (§ 4001 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4001"},"text":"section 4001 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id417ec169-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 139 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s140"},"text":"section 140 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id417ec16a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/b/10/A"},"text":"Pub. L. 115–141, § 401(b)(10)(A)","children":[],"tail":", substituted “section 165(i)(5)(A)” for “section 165(h)(3)(C)(i)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/a/41"},"text":"Pub. L. 115–141, § 401(a)(41)","children":[],"tail":", substituted “a federally” for “federally”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343"},"text":"Pub. L. 110–343","children":[],"tail":" amended par. (2) generally. Prior to amendment, par. (2) read as follows: “a Presidentially declared disaster (as defined in section 1033(h)(3)),”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/7/s1/a/2/A"},"text":"Pub. L. 109–7, § 1(a)(2)(A)","children":[],"tail":", substituted “qualified disaster relief payments and qualified disaster mitigation payments” for “a qualified disaster relief payment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/7/s1/a/2/B"},"text":"Pub. L. 109–7, § 1(a)(2)(B)","children":[],"tail":", substituted “, (f), and (g)” for “and (f)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (g), (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/7/s1/a/1"},"text":"Pub. L. 109–7, § 1(a)(1)","children":[],"tail":", added subsecs. (g) and (h)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id417ec16b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id417ec16c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343"},"text":"Pub. L. 110–343","children":[],"tail":" applicable to disasters declared in taxable years beginning after "},{"tag":"date","attrib":{"date":"2007-12-31"},"text":"Dec. 31, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/343/s706/d/1"},"text":"section 706(d)(1) of Pub. L. 110–343","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s56"},"text":"section 56 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id417ec16d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/7/s1/c/1"},"text":"Pub. L. 109–7, § 1(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-04-15"},"text":"Apr. 15, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/22"},"text":"119 Stat. 22","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/7/s1/c/1"},"text":"“The amendments made by subsection (a) [amending this section] shall apply to amounts received before, on, or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2005-04-15"},"text":"Apr. 15, 2005","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id417ec16e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/134/tI/s111/c"},"text":"Pub. L. 107–134, title I, § 111(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-23"},"text":"Jan. 23, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2433"},"text":"115 Stat. 2433","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/134/tI/s111/c"},"text":"“The amendments made by this section [enacting this section and renumbering former section 139 as ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s140"},"text":"section 140 of this title","children":[],"tail":"] shall apply to taxable years ending on or after "},{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"id417ec16f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions that nothing in amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/b/10/A"},"text":"section 401(b)(10)(A) of Pub. L. 115–141","children":[],"tail":" be construed to affect treatment of certain transactions occurring, property acquired, or items of income, loss, deduction, or credit taken into account prior to "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", for purposes of determining liability for tax for periods ending after "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/e"},"text":"section 401(e) of Pub. L. 115–141","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s23"},"text":"section 23 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
