{"tag":"section","attrib":{"id":"id4632fae5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5271"},"text":null,"children":[{"tag":"num","attrib":{"value":"5271"},"text":"§ 5271.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4632fae6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5271/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No person shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4632fae7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5271/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procure or use distilled spirits free of tax under the provisions of section 5214(a)(2) or (3); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4632fae8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5271/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procure, deal in, or use specially denatured distilled spirits; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4632fae9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5271/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recover specially or completely denatured distilled spirits, until he has filed an application with and received a permit to do so from the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4632faea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5271/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of application and permit","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4632faeb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5271/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The application required by subsection (a) shall be in such form, shall be submitted at such times, and shall contain such information, as the Secretary shall by regulations prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4632faec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5271/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Permits under this section shall, under such regulations as the Secretary shall prescribe, designate and limit the acts which are permitted, and the place where and time when such acts may be performed. Such permits shall be issued in such form and under such conditions as the Secretary may by regulations prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4632faed-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5271/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disapproval of application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any application submitted under this section may be disapproved and the permit denied if the Secretary, after notice and opportunity for hearing, finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4632faee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5271/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in case of an application to withdraw and use distilled spirits free of tax, the applicant is not authorized by law or regulations issued pursuant thereto to withdraw or use such distilled spirits; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4632faef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5271/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant (including, in the case of a corporation, any officer, director, or principal stockholder, and, in the case of a partnership, a partner) is, by reason of his business experience, financial standing, or trade connections, not likely to maintain operations in compliance with this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4632faf0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5271/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant has failed to disclose any material information required, or made any false statement as to any material fact, in connection with his application; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4632faf1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5271/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the premises on which it is proposed to conduct the business are not adequate to protect the revenue.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4632faf2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5271/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Changes after issuance of permit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to any change relating to the information contained in the application for a permit issued under this section, the Secretary may by regulations require the filing of written notice of such change and, where the change affects the terms of the permit, require the filing of an amended application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4632faf3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5271/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension or revocation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, after notice and hearing, the Secretary finds that any person holding a permit issued under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4632faf4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5271/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not in good faith complied with the provisions of this chapter or regulations issued thereunder; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4632faf5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5271/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has violated the conditions of such permit; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4632faf6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5271/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has made any false statement as to any material fact in his application therefor; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4632faf7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5271/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has failed to disclose any material information required to be furnished; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4632faf8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5271/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has violated or conspired to violate any law of the United States relating to intoxicating liquor, or has been convicted of any offense under this title punishable as a felony or of any conspiracy to commit such offense; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4632faf9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5271/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is, in the case of any person who has a permit under subsection (a)(1) or (a)(2), by reason of his operations, no longer warranted in procuring or using the distilled spirits or specially denatured distilled spirits authorized by his permit; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4632fafa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5271/e/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has, in the case of any person who has a permit under subsection (a)(2), manufactured articles which do not correspond to the descriptions and limitations prescribed by law and regulations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4632fafb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5271/e/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not engaged in any of the operations authorized by the permit for a period of more than 2 years;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"such permit may, in whole or in part, be revoked or be suspended for such period as the Secretary deems proper.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4632fafc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5271/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of permits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Permits issued under this section, unless terminated by the terms of the permit, shall continue in effect until suspended or revoked as provided in this section, or until voluntarily surrendered.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4632fafd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5271/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Posting of permits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Permits issued under this section, to use distilled spirits free of tax, to deal in, or use specially denatured distilled spirits, or to recover specially or completely denatured distilled spirits, shall be kept posted available for inspection on the premises covered by the permit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4632fafe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5271/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe all necessary regulations relating to issuance, denial, suspension, or revocation, of permits under this section, and for the disposition of distilled spirits (including specially denatured distilled spirits) procured under permit pursuant to this section which remain unused when such permit is no longer in effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4632faff-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1370"},"text":"72 Stat. 1370","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4632fb00-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4632fb01-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4632fb02-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5271, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/650"},"text":"68A Stat. 650","children":[],"tail":", related to “notice of business of rectifier”, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":". See sections 5171(a), (c), 5172, and 5178(a)(1)(A), (4)(B)–(D) of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those comprising subsecs. (a) to (f) and (h) of this section were contained in prior section 5304(a)(1) to (4), (b), (c), ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/655"},"text":"68A Stat. 655","children":[],"tail":", prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4632fb03-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—Subsecs. (a) to (e), (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4632fb04-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4632fb05-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1959-07-01"},"text":"July 1, 1959","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/s210/a/1"},"text":"section 210(a)(1) of Pub. L. 85–859","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5001"},"text":"section 5001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
