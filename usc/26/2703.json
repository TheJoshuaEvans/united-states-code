{"tag":"section","attrib":{"id":"id454df197-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2703"},"text":null,"children":[{"tag":"num","attrib":{"value":"2703"},"text":"§ 2703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain rights and restrictions disregarded","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id454df198-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2703/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subtitle, the value of any property shall be determined without regard to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id454df199-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2703/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any option, agreement, or other right to acquire or use the property at a price less than the fair market value of the property (without regard to such option, agreement, or right), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454df19a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2703/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any restriction on the right to sell or use such property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id454df19b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2703/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply to any option, agreement, right, or restriction which meets each of the following requirements:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id454df19c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2703/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It is a bona fide business arrangement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454df19d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2703/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It is not a device to transfer such property to members of the decedent’s family for less than full and adequate consideration in money or money’s worth.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id454df19e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2703/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Its terms are comparable to similar arrangements entered into by persons in an arms’ length transaction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id454df19f-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11602/a"},"text":"Pub. L. 101–508, title XI, § 11602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-498"},"text":"104 Stat. 1388–498","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
