{"tag":"section","attrib":{"id":"id463ee180-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5603"},"text":null,"children":[{"tag":"num","attrib":{"value":"5603"},"text":"§ 5603.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty relating to records, returns, and reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id463ee181-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5603/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fraudulent noncompliance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person required by this chapter (other than subchapters F and G) or regulations issued pursuant thereto to keep or file any record, return, report, summary, transcript, or other document, who, with intent to defraud the United States, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id463ee182-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5603/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fail to keep any such document or to make required entries therein; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id463ee183-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5603/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make any false entry in such document; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id463ee184-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5603/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cancel, alter, or obliterate any part of such document or any entry therein, or destroy any part of such document or any entry therein; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id463ee185-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5603/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hinder or obstruct any internal revenue officer from inspecting any such document or taking any abstracts therefrom; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id463ee186-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5603/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fail or refuse to preserve or produce any such document, as required by this chapter or regulations issued pursuant thereto;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"or who shall, with intent to defraud the United States, cause or procure the same to be done, shall be fined not more than $10,000, or imprisoned not more than 5 years, or both, for each such offense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id463ee187-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5603/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to comply","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person required by this chapter (other than subchapters F and G) or regulations issued pursuant thereto to keep or file any record, return, report, summary, transcript, or other document, who, otherwise than with intent to defraud the United States, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id463ee188-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5603/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fail to keep any such document or to make required entries therein; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id463ee189-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5603/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make any false entry in such document; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id463ee18a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5603/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cancel, alter, or obliterate any part of such document or any entry therein, or destroy any part of such document, or any entry therein, except as provided by this title or regulations issued pursuant thereto; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id463ee18b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5603/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hinder or obstruct any internal revenue officer from inspecting any such document or taking any abstracts therefrom; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id463ee18c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5603/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fail to refuse to preserve or produce any such document, as required by this chapter or regulations issued pursuant thereto;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"or who shall, otherwise than with intent to defraud the United States, cause or procure the same to be done, shall be fined not more than $1,000, or imprisoned not more than 1 year, or both, for each such offense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id463ee18d-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1400"},"text":"72 Stat. 1400","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/249"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(249)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1196"},"text":"132 Stat. 1196","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id463ee18e-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id463ee18f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id463ee190-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5603, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/684"},"text":"68A Stat. 684","children":[],"tail":", related to penalty for failure or refusal of distiller or rectifier to give notice of intention to engage in such business, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":". See section 5601(a)(2), (3) of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those comprising this section were contained in prior sections 5610, 5611, 5620, 5621, 5692, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/685"},"text":"68A Stat. 685","children":[],"tail":" to 687, 703, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id463ee191-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" inserted comma after “returns” in section catchline."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
