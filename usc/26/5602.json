{"tag":"section","attrib":{"id":"id463ee17b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5602"},"text":null,"children":[{"tag":"num","attrib":{"value":"5602"},"text":"§ 5602.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for tax fraud by distiller","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever any person engaged in or carrying on the business of a distiller defrauds, attempts to defraud, or engages in such business with intent to defraud the United States of the tax on the spirits distilled by him, or of any part thereof, he shall be fined not more than $10,000, or imprisoned not more than 5 years, or both. No discontinuance or nolle prosequi of any prosecution under this section shall be allowed without the permission in writing of the Attorney General.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id463ee17c-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1400"},"text":"72 Stat. 1400","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id463ee17d-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id463ee17e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id463ee17f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5602, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/863"},"text":"68A Stat. 863","children":[],"tail":", related to penalty and forfeiture for setting up still without a permit, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":". See sections 5615(2) and 5687 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those comprising this section were contained in prior sections 5606, 5626, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/684"},"text":"68A Stat. 684","children":[],"tail":", 688, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
