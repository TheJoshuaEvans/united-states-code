{"tag":"section","attrib":{"id":"id44f83080-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1378"},"text":null,"children":[{"tag":"num","attrib":{"value":"1378"},"text":"§ 1378.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable year of S corporation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44f83081-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1378/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subtitle, the taxable year of an S corporation shall be a permitted year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44f83082-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1378/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permitted year defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “permitted year” means a taxable year which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44f83083-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1378/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a year ending December 31, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44f83084-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1378/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is any other accounting period for which the corporation establishes a business purpose to the satisfaction of the Secretary.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of paragraph (2), any deferral of income to shareholders shall not be treated as a business purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44f83085-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/354/s2"},"text":"Pub. L. 97–354, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-19"},"text":"Oct. 19, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1685"},"text":"96 Stat. 1685","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tVII/s721/m"},"text":"Pub. L. 98–369, div. A, title VII, § 721(m)","children":[],"tail":", (q), "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/969"},"text":"98 Stat. 969","children":[],"tail":", 970; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVIII/s806/b"},"text":"Pub. L. 99–514, title VIII, § 806(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2363"},"text":"100 Stat. 2363","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44f83086-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44f83087-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id44f83088-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1378, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/389/s2/a"},"text":"Pub. L. 89–389, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-04-14"},"text":"Apr. 14, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/113"},"text":"80 Stat. 113","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/tV/s511/c/4"},"text":"Pub. L. 91–172, title V, § 511(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/638"},"text":"83 Stat. 638","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1901/a/152"},"text":"Pub. L. 94–455, title XIX, § 1901(a)(152)","children":[],"tail":", (b)(33)(R), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1789"},"text":"90 Stat. 1789","children":[],"tail":", 1802, related to tax imposed on certain capital gains, prior to the general revision of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/97/354/s2"},"text":"section 2 of Pub. L. 97–354","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44f83089-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s806/b/1"},"text":"Pub. L. 99–514, § 806(b)(1)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows: “For purposes of this subtitle—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) an S corporation shall not change its taxable year to any accounting period other than a permitted year, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) no corporation may make an election under section 1362(a) for any taxable year unless such taxable year is a permitted year.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s806/b/2"},"text":"Pub. L. 99–514, § 806(b)(2)","children":[],"tail":", inserted at end “For purposes of paragraph (2), any deferral of income to shareholders shall not be treated as a business purpose.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s806/b/3"},"text":"Pub. L. 99–514, § 806(b)(3)","children":[],"tail":", struck out subsec. (c) which required existing S corporations to use permitted year after 50-percent shift in ownership."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s721/m"},"text":"Pub. L. 98–369, § 721(m)","children":[],"tail":", substituted “which includes "},{"tag":"date","attrib":{"date":"1982-12-31"},"text":"December 31, 1982","children":[],"tail":" (or which is an S corporation for a taxable year beginning during 1983 by reason of an election made on or before "},{"tag":"date","attrib":{"date":"1982-10-19"},"text":"October 19, 1982","children":[],"tail":")” for “which includes "},{"tag":"date","attrib":{"date":"1982-12-31"},"text":"December 31, 1982","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s721/q"},"text":"Pub. L. 98–369, § 721(q)","children":[],"tail":", substituted “who (or whose estate) held” for “who held”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44f8308a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44f8308b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVIII/s806/e"},"text":"Pub. L. 99–514, title VIII, § 806(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2364"},"text":"100 Stat. 2364","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1008/e/7"},"text":"Pub. L. 100–647, title I, § 1008(e)(7)","children":[],"tail":", (8), (10), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3441"},"text":"102 Stat. 3441","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/647/tI/s1008/e/7"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section [amending this section and sections 267, 441, and 706 of this title] shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Change in accounting period","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any partnership, S corporation, or personal service corporation required by the amendments made by this section to change its accounting period for the taxpayer’s first taxable year beginning after ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such change shall be treated as initiated by the partnership, S corporation, or personal service corporation,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such change shall be treated as having been made with the consent of the Secretary, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to any partner or shareholder of an S corporation which is required to include the items from more than 1 taxable year of the partnership or S corporation in any 1 taxable year, income in excess of expenses of such partnership or corporation for the short taxable year required by such amendments shall be taken into account ratably in each of the first 4 taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":", unless such partner or shareholder elects to include all such income in the the [sic] partner’s or shareholder’s taxable year with or within which the partnership’s or S corporation’s short taxable year ends."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Subparagraph (C) shall apply to a shareholder of an S corporation only if such corporation was an S corporation for a taxable year beginning in 1986.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis, etc. rules—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Basis rule","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The adjusted basis of any partner’s interest in a partnership or shareholder’s stock in an S corporation shall be determined as if all of the income to be taken into account ratably in the 4 taxable years referred to in paragraph (2)(C) were included in gross income for the 1st of such taxable years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of dispositions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If any interest in a partnership or stock in an S corporation is disposed of before the last taxable year in the spread period, all amounts which would be included in the gross income of the partner or shareholder for subsequent taxable years in the spread period under paragraph (2)(C) and attributable to the interest or stock disposed of shall be included in gross income for the taxable year in which the disposition occurs. For purposes of the preceding sentence, the term ‘spread period’ means the period consisting of the 4 taxable years referred to in paragraph (2)(C).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44f8308c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" effective as if included in Subchapter S Revision Act of 1982, "},{"tag":"ref","attrib":{"href":"/us/pl/97/354"},"text":"Pub. L. 97–354","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s721/y/1"},"text":"section 721(y)(1) of Pub. L. 98–369","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1361"},"text":"section 1361 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id44f8308d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1982-12-31"},"text":"Dec. 31, 1982","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/354/s6/a"},"text":"section 6(a) of Pub. L. 97–354","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1361"},"text":"section 1361 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id44f8308e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s806"},"text":"Section 806 of Pub. L. 99–514","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1008/e/9"},"text":"Pub. L. 100–647, title I, § 1008(e)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3441"},"text":"102 Stat. 3441","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/647/tI/s1008/e/9"},"text":"“Nothing in section 806 of the Reform Act [","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", amending this section and sections 267, 441, and 706 of this title and enacting provisions set out above] or in any legislative history relating thereto shall be construed as requiring the Secretary of the Treasury or his delegate to permit an automatic change of a taxable year.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
