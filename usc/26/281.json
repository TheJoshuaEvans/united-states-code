{"tag":"section","attrib":{"id":"id42a196e0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s281"},"text":null,"children":[{"tag":"num","attrib":{"value":"281"},"text":"§ 281.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terminal railroad corporations and their shareholders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id42a196e1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s281/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation of taxable income of terminal railroad corporations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42a196e2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s281/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In computing the taxable income of a terminal railroad corporation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42a196e3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s281/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such corporation shall not be considered to have received or accrued—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id42a196e4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s281/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the portion of any liability of any railroad corporation, with respect to related terminal services provided by such corporation, which is discharged by crediting such liability with an amount of related terminal income, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id42a196e5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s281/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the portion of any charge which would be made by such corporation for related terminal services provided by it, but which is not made as a result of taking related terminal income into account in computing such charge; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42a196e6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s281/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no deduction otherwise allowable under this chapter shall be disallowed as a result of any discharge of liability described in subparagraph (A)(i) or as a result of any computation of charges in the manner described in subparagraph (A)(ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42a196e7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s281/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any taxable year ending after the date of the enactment of this section, paragraph (1) shall not apply to the extent that it would (but for this paragraph) operate to create (or increase) a net operating loss for the terminal railroad corporation for the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42a196e8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s281/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation of taxable income of shareholders","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the limitation in subsection (a)(2), in computing the taxable income of any shareholder of a terminal railroad corporation, no amount shall be considered to have been received or accrued or paid or incurred by such shareholder as a result of any discharge of liability described in subsection (a)(1)(A)(i) or as a result of any computation of charges in the manner described in subsection (a)(1)(A)(ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42a196e9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s281/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any taxable year, subsections (a) and (b) shall apply with respect to any discharge of liability described in subsection (a)(1)(A)(i), and to any computation of charges in the manner described in subsection (a)(1)(A)(ii), only if such discharge or computation (as the case may be) was provided for in a written agreement, to which all of the shareholders of the terminal railroad corporation were parties, entered into before the beginning of such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42a196ea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s281/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42a196eb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s281/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terminal railroad corporation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “terminal railroad corporation” means a domestic railroad corporation which is not a member, other than as a common parent corporation, of an affiliated group (as defined in section 1504) and—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42a196ec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s281/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all of the shareholders of which are rail carriers subject to part A of subtitle IV of title 49;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42a196ed-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s281/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the primary business of which is the providing of railroad terminal and switching facilities and services to rail carriers subject to part A of subtitle IV of title 49 and to the shippers and passengers of such railroad corporations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42a196ee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s281/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a substantial part of the services of which for the taxable year is rendered to one or more of its shareholders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42a196ef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s281/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each shareholder of which computes its taxable income on the basis of a taxable year beginning or ending on the same day that the taxable year of the terminal railroad corporation begins or ends.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42a196f0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s281/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Related terminal income","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “related terminal income” means the income (determined in accordance with regulations prescribed by the Secretary) of a terminal railroad corporation derived—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42a196f1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s281/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from services or facilities of a character ordinarily and regularly provided by terminal railroad corporations for railroad corporations or for the employees, passengers, or shippers of railroad corporations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42a196f2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s281/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from the use by persons other than railroad corporations of portions of a facility, or a service, which is used primarily for railroad purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42a196f3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s281/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from any railroad corporation for services or facilities provided by such terminal railroad corporation in connection with railroad operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42a196f4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s281/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from the United States in payment for facilities or services in connection with mail handling.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of subparagraph (B), a substantial addition, constructed after the date of the enactment of this section, to a facility shall be treated as a separate facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42a196f5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s281/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Related terminal services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “related terminal services” includes only services, and the use of facilities, taken into account in computing related terminal income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42a196f6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s281/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such regulations as may be necessary to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id42a196f7-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/870/s1/a"},"text":"Pub. L. 87–870, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-23"},"text":"Oct. 23, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1158"},"text":"76 Stat. 1158","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX"},"text":"Pub. L. 94–455, title XIX","children":[],"tail":", §§ 1901(a)(40), 1906(b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1771"},"text":"90 Stat. 1771","children":[],"tail":", 1834; "},{"tag":"ref","attrib":{"href":"/us/pl/95/473/s2/a/2/D"},"text":"Pub. L. 95–473, § 2(a)(2)(D)","children":[],"tail":", (E), "},{"tag":"date","attrib":{"date":"1978-10-17"},"text":"Oct. 17, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1464"},"text":"92 Stat. 1464","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/tIII/s304/b"},"text":"Pub. L. 104–88, title III, § 304(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/943"},"text":"109 Stat. 943","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id42a196f8-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id42a196f9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id42a196fa-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this section, referred to in subsecs. (a)(2) and (d)(2), refers to the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/870"},"text":"Pub. L. 87–870","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1962-10-23"},"text":"Oct. 23, 1962","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id42a196fb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1995—Subsec. (d)(1)(A), (B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":" substituted “rail carriers subject to part A of subtitle IV” for “domestic railroad corporations providing transportation subject to subchapter I of chapter 105”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (d)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/473/s2/a/2/D"},"text":"Pub. L. 95–473, § 2(a)(2)(D)","children":[],"tail":", substituted “providing transportation subject to subchapter I of chapter 105 of title 49” for “subject to part I of the Interstate Commerce Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1"},"text":"49 U.S.C. 1","children":[],"tail":" and following)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/473/s2/a/2/E"},"text":"Pub. L. 95–473, § 2(a)(2)(E)","children":[],"tail":", substituted “providing transportation subject to subchapter I of chapter 105 of title 49” for “subject to part I of the Interstate Commerce Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (d)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1901/a"},"text":"Pub. L. 94–455, § 1901(a)","children":[],"tail":" (40)(A), inserted “("},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1"},"text":"49 U.S.C. 1","children":[],"tail":" and following)” after “Interstate Commerce Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":", §§ 1901(a)(40)(B), 1906(b)(13)(A), redesignated subsec. (f) as (e) and struck out “or his delegate” after “Secretary”. Former subsec. (e), which made special provision for the application of this section to taxable years ending before "},{"tag":"date","attrib":{"date":"1962-10-23"},"text":"Oct. 23, 1962","children":[],"tail":", was struck out."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id42a196fc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id42a196fd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1995 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of Title 49","children":[],"tail":", Transportation."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id42a196fe-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1901/a/40"},"text":"section 1901(a)(40) of Pub. L. 94–455","children":[],"tail":" effective for taxable years beginning after "},{"tag":"date","attrib":{"date":"1976-12-31"},"text":"Dec. 31, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1901/d"},"text":"section 1901(d) of Pub. L. 94–455","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2"},"text":"section 2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id42a196ff-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/87/870/s2/a"},"text":"Pub. L. 87–870, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-23"},"text":"Oct. 23, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1160"},"text":"76 Stat. 1160","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/87/870/s2/a"},"text":"“The amendments made by the first section of this Act [enacting this section] shall apply with respect to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1953-12-31"},"text":"December 31, 1953","children":[],"tail":", and ending after "},{"tag":"date","attrib":{"date":"1954-08-16"},"text":"August 16, 1954","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id42a19700-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Internal Revenue Code of 1939; Inclusion of Terminal Railroad Corporations and Their Shareholders Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/87/870/s2/b"},"text":"Pub. L. 87–870, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-23"},"text":"Oct. 23, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1160"},"text":"76 Stat. 1160","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"“Provisions having the same effect as section 281 of the Internal Revenue Code of 1986 [formerly I.R.C. 1954] (as added by the first section of this Act) shall be deemed to be included in the Internal Revenue Code of 1939, effective with respect to all taxable years to which such Code applies.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
