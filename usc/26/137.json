n":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id417ec116-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id417ec117-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s541"},"text":"Section 541 of title 14","children":[],"tail":", referred to in subsec. (c), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s2903"},"text":"section 2903 of title 14","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s117/b"},"text":"Pub. L. 115–282, title I, § 117(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4230"},"text":"132 Stat. 4230","children":[],"tail":", and references to "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s541"},"text":"section 541 of title 14","children":[],"tail":" deemed to refer to such redesignated section, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/b/1"},"text":"section 123(b)(1) of Pub. L. 115–282","children":[],"tail":", set out as a References to Sections of Title 14 as Redesignated by "},{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s101"},"text":"section 101 of Title 14","children":[],"tail":", Coast Guard."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id417ec118-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 137 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s140"},"text":"section 140 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id417ec119-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2"},"text":"Pub. L. 117–2","children":[],"tail":" inserted “85(c)” before “221”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsec. (b)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" struck out “222,” after “sections 221,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" substituted “section 541” for “section 514” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (b)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13305/b/1"},"text":"Pub. L. 115–97, § 13305(b)(1)","children":[],"tail":", struck out “199,” before “221”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s11002/d/1/N"},"text":"Pub. L. 115–97, § 11002(d)(1)(N)","children":[],"tail":", substituted “for ‘calendar year 2016’ in subparagraph (A)(ii)” for “for ‘calendar year 1992’ in subparagraph (B)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10909/a/2/B"},"text":"Pub. L. 111–148, § 10909(a)(2)(B)","children":[],"tail":", (c), as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/312"},"text":"Pub. L. 111–312","children":[],"tail":", temporarily substituted “$13,170” for “$10,000” in heading and text. See Effective and Termination Dates of 2010 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10909/a/2/A"},"text":"Pub. L. 111–148, § 10909(a)(2)(A)","children":[],"tail":", (c), as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/312"},"text":"Pub. L. 111–312","children":[],"tail":", temporarily substituted “$13,170” for “$10,000”. See Effective and Termination Dates of 2010 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10909/b/2/J/i"},"text":"Pub. L. 111–148, § 10909(b)(2)(J)(i)","children":[],"tail":", (c), as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/312"},"text":"Pub. L. 111–312","children":[],"tail":", temporarily substituted “section 36C(d)” for “section 23(d)”. See Effective and Termination Dates of 2010 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10909/b/2/J/ii"},"text":"Pub. L. 111–148, § 10909(b)(2)(J)(ii)","children":[],"tail":", (c), as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/312"},"text":"Pub. L. 111–312","children":[],"tail":", temporarily substituted “section 36C” for “section 23”. See Effective and Termination Dates of 2010 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10909/a/2/C"},"text":"Pub. L. 111–148, § 10909(a)(2)(C)","children":[],"tail":", (c), as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/312"},"text":"Pub. L. 111–312","children":[],"tail":", temporarily amended subsec. (f) generally. See Effective and Termination Dates of 2010 Amendment note below. Prior to amendment subsec. (f) read as follows: “"},{"tag":"inline","attrib":{},"text":"Adjustments for inflation","children":[],"tail":".—In the case of a taxable year beginning after "},{"tag":"date","attrib":{"date":"2002-12-31"},"text":"December 31, 2002","children":[],"tail":", each of the dollar amounts in subsection (a)(2) and paragraphs (1) and (2)(A) of subsection (b) shall be increased by an amount equal to—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) such dollar amount, multiplied by","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) the cost-of-living adjustment determined under section 1(f)(3) for the calendar year in which the taxable year begins, determined by substituting ‘calendar year 2001’ for ‘calendar year 1992’ in subparagraph (B) thereof.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"If any amount as increased under the preceding sentence is not a multiple of $10, such amount shall be rounded to the nearest multiple of $10.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/311"},"text":"Pub. L. 108–311","children":[],"tail":" amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/107/147/s411/c/2/B"},"text":"Pub. L. 107–147, § 411(c)(2)(B)","children":[],"tail":". See 2002 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":" inserted “199,” before “221”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/147/s411/c/2/A"},"text":"Pub. L. 107–147, § 411(c)(2)(A)","children":[],"tail":", amended heading and text of subsec. (a) generally. Prior to amendment, text read as follows: “Gross income of an employee does not include amounts paid or expenses incurred by the employer for adoption expenses in connection with the adoption of a child by an employee if such amounts are furnished pursuant to an adoption assistance program. The amount of the exclusion shall be—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) in the case of an adoption of a child other than a child with special needs, the amount of the qualified adoption expenses paid or incurred by the taxpayer, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) in the case of an adoption of a child with special needs, $10,000.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/147/s411/c/2/B"},"text":"Pub. L. 107–147, § 411(c)(2)(B)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/108/311"},"text":"Pub. L. 108–311","children":[],"tail":", substituted “subsection (a)” for “subsection (a)(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/147/s418/a/2"},"text":"Pub. L. 107–147, § 418(a)(2)","children":[],"tail":", inserted at end “If any amount as increased under the preceding sentence is not a multiple of $10, such amount shall be rounded to the nearest multiple of $10.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16/s202/a/2"},"text":"Pub. L. 107–16, § 202(a)(2)","children":[],"tail":", reenacted heading without change and amended text generally. Prior to amendment, text read as follows: “Gross income of an employee does not include amounts paid or expenses incurred by the employer for qualified adoption expenses in connection with the adoption of a child by an employee if such amounts are furnished pursuant to an adoption assistance program.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16/s202/b/1/B"},"text":"Pub. L. 107–16, § 202(b)(1)(B)","children":[],"tail":", substituted “subsection (a)(1)” for “subsection (a)” and “$10,000” for “$5,000 ($6,000, in the case of a child with special needs)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16/s202/b/2/B"},"text":"Pub. L. 107–16, § 202(b)(2)(B)","children":[],"tail":", substituted “$150,000” for “$75,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16/s431/c/1"},"text":"Pub. L. 107–16, § 431(c)(1)","children":[],"tail":", inserted “222,” after “221,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16/s202/d/2"},"text":"Pub. L. 107–16, § 202(d)(2)","children":[],"tail":", (e)(2), added subsec. (f) and struck out heading and text of former subsec. (f). Text read as follows: “This section shall not apply to amounts paid or expenses incurred after "},{"tag":"date","attrib":{"date":"2001-12-31"},"text":"December 31, 2001","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" inserted “221,” after “and sections”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" substituted “of the amounts paid or expenses incurred which may be taken into account” for “amount excludable from gross income”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id417ec11a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":