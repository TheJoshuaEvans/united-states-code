{"tag":"section","attrib":{"id":"id417c4fff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s137"},"text":null,"children":[{"tag":"num","attrib":{"value":"137"},"text":"§ 137.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adoption assistance programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id417c5000-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s137/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id417c5001-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s137/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Gross income of an employee does not include amounts paid or expenses incurred by the employer for qualified adoption expenses in connection with the adoption of a child by an employee if such amounts are furnished pursuant to an adoption assistance program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id417c5002-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s137/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" $10,000 exclusion for adoption of child with special needs regardless of expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an adoption of a child with special needs which becomes final during a taxable year, the qualified adoption expenses with respect to such adoption for such year shall be increased by an amount equal to the excess (if any) of $10,000 over the actual aggregate qualified adoption expenses with respect to such adoption during such taxable year and all prior taxable years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id417c5003-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s137/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id417c5004-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s137/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dollar limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The aggregate of the amounts paid or expenses incurred which may be taken into account under subsection (a) for all taxable years with respect to the adoption of a child by the taxpayer shall not exceed $10,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id417ec105-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s137/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Income limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount excludable from gross income under subsection (a) for any taxable year shall be reduced (but not below zero) by an amount which bears the same ratio to the amount so excludable (determined without regard to this paragraph but with regard to paragraph (1)) as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id417ec106-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s137/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount (if any) by which the taxpayer’s adjusted gross income exceeds $150,000, bears to","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id417ec107-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s137/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $40,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id417ec108-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s137/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of adjusted gross income","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (2), adjusted gross income shall be determined—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id417ec109-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s137/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without regard to this section and sections 85(c) ","children":[{"tag":"ref","attrib":{"idref":"fn002062"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002062"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a comma."}],"tail":" 221, 911, 931, and 933, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id417ec10a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s137/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after the application of sections 86, 135, 219, and 469.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id417ec10b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s137/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adoption assistance program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, an adoption assistance program is a separate written plan of an employer for the exclusive benefit of such employer’s employees—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id417ec10c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s137/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under which the employer provides such employees with adoption assistance, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id417ec10d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s137/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which meets requirements similar to the requirements of paragraphs (2), (3), (5), and (6) of section 127(b).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"An adoption reimbursement program operated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1052"},"text":"section 1052 of title 10","children":[],"tail":", United States Code (relating to armed forces) or section 541 "},{"tag":"ref","attrib":{"idref":"fn002063"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002063"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" of title 14, United States Code (relating to members of the Coast Guard) shall be treated as an adoption assistance program for purposes of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id417ec10e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s137/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified adoption expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “qualified adoption expenses” has the meaning given such term by section 23(d) (determined without regard to reimbursements under this section).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id417ec10f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s137/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain rules to apply","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rules similar to the rules of subsections (e), (f), and (g) of section 23 shall apply for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id417ec110-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s137/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustments for inflation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a taxable year beginning after ","children":[{"tag":"date","attrib":{"date":"2002-12-31"},"text":"December 31, 2002","children":[],"tail":", each of the dollar amounts in subsection (a)(2) and paragraphs (1) and (2)(A) of subsection (b) shall be increased by an amount equal to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id417ec111-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s137/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such dollar amount, multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id417ec112-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s137/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost-of-living adjustment determined under section 1(f)(3) for the calendar year in which the taxable year begins, determined by substituting “calendar year 2001” for “calendar year 2016” in subparagraph (A)(ii) thereof.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"If any amount as increased under the preceding sentence is not a multiple of $10, such amount shall be rounded to the nearest multiple of $10.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id417ec113-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1807/b"},"text":"Pub. L. 104–188, title I, § 1807(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1901"},"text":"110 Stat. 1901","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXVI/s1601/h/2/C"},"text":"Pub. L. 105–34, title XVI, § 1601(h)(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1092"},"text":"111 Stat. 1092","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dJ/tIV/s4003/a/2/C"},"text":"Pub. L. 105–277, div. J, title IV, § 4003(a)(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-908"},"text