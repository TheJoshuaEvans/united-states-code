{"tag":"section","attrib":{"id":"id44d20b25-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1257"},"text":null,"children":[{"tag":"num","attrib":{"value":"1257"},"text":"§ 1257.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of converted wetlands or highly erodible croplands","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44d20b26-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1257/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gain treated as ordinary income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any gain on the disposition of converted wetland or highly erodible cropland shall be treated as ordinary income. Such gain shall be recognized notwithstanding any other provision of this subtitle, except that this section shall not apply to the extent such gain is recognized as ordinary income under any other provision of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44d20b27-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1257/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loss treated as long-term capital loss","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any loss recognized on the disposition of converted wetland or highly erodible cropland shall be treated as a long-term capital loss.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44d20b28-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1257/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44d20b29-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1257/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Converted wetland","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “converted wetland” means any converted wetland (as defined in section 1201(a)(7) of the Food Security Act of 1985 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3801/7"},"text":"16 U.S.C. 3801(7)","children":[],"tail":")) held—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44d20b2a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1257/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the person whose activities resulted in such land being converted wetland, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d20b2b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1257/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by any other person who at any time used such land for farming purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d20b2c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1257/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Highly erodible cropland","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “highly erodible cropland” means any highly erodible cropland (as defined in section 1201(a)(10) of the Food Security Act of 1985 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3801/10"},"text":"16 U.S.C. 3801(10)","children":[],"tail":")), if at any time the taxpayer used such land for farming purposes (other than the grazing of animals)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d20b2d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1257/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of successors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any land is converted wetland or highly erodible cropland in the hands of any person, such land shall be treated as converted wetland or highly erodible cropland in the hands of any other person whose adjusted basis in such land is determined (in whole or in part) by reference to the adjusted basis of such land in the hands of such person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44d20b2e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1257/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under regulations prescribed by the Secretary, rules similar to the rules applicable under section 1245 shall apply for purposes of subsection (a). For purposes of sections 170(e) and 751(c), amounts treated as ordinary income under subsection (a) shall be treated in the same manner as amounts treated as ordinary income under section 1245.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44d20b2f-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tIV/s403/a"},"text":"Pub. L. 99–514, title IV, § 403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2222"},"text":"100 Stat. 2222","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/27/tIII/s302/e/4/B/ii"},"text":"Pub. L. 108–27, title III, § 302(e)(4)(B)(ii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-05-28"},"text":"May 28, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/764"},"text":"117 Stat. 764","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/177"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(177)","children":[],"tail":", (178), "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1192"},"text":"132 Stat. 1192","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44d20b30-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44d20b31-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44d20b32-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/a/177"},"text":"Pub. L. 115–141, § 401(a)(177)","children":[],"tail":", substituted “section 1201(a)(7)” for “section 1201(4)” and “"},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3801/7"},"text":"16 U.S.C. 3801(7)","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3801/4"},"text":"16 U.S.C. 3801(4)","children":[],"tail":"” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/a/178"},"text":"Pub. L. 115–141, § 401(a)(178)","children":[],"tail":", substituted “section 1201(a)(10)” for “section 1201(6)” and “"},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3801/10"},"text":"16 U.S.C. 3801(10)","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t16/s3801/6"},"text":"16 U.S.C. 3801(6)","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/27"},"text":"Pub. L. 108–27","children":[],"tail":" struck out “, 341(e)(12),” after “170(e)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44d20b33-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44d20b34-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/27"},"text":"Pub. L. 108–27","children":[],"tail":" applicable, except as otherwise provided, to taxable years beginning after "},{"tag":"date","attrib":{"date":"2002-12-31"},"text":"Dec. 31, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/27/s302/f"},"text":"section 302(f) of Pub. L. 108–27","children":[],"tail":", set out as an Effective and Termination Dates of 2003 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id44d20b35-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tIV/s403/c"},"text":"Pub. L. 99–514, title IV, § 403(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2222"},"text":"100 Stat. 2222","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/tIV/s403/c"},"text":"“The amendments made by this section [enacting this section] shall apply to dispositions of converted wetland or highly erodible cropland (as defined in section 1257(c) of the Internal Revenue Code of 1986 as added by this section) first used for farming after ","children":[{"tag":"date","attrib":{"date":"1986-03-01"},"text":"March 1, 1986","children":[],"tail":", in taxable years ending after that date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
