{"tag":"section","attrib":{"id":"id472d3907-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6695"},"text":null,"children":[{"tag":"num","attrib":{"value":"6695"},"text":"§ 6695.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other assessable penalties with respect to the preparation of tax returns for other persons","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id472d3908-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6695/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to furnish copy to taxpayer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who is a tax return preparer with respect to any return or claim for refund who fails to comply with section 6107(a) with respect to such return or claim shall pay a penalty of $50 for such failure, unless it is shown that such failure is due to reasonable cause and not due to willful neglect. The maximum penalty imposed under this subsection on any person with respect to documents filed during any calendar year shall not exceed $25,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id472d3909-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6695/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to sign return","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who is a tax return preparer with respect to any return or claim for refund, who is required by regulations prescribed by the Secretary to sign such return or claim, and who fails to comply with such regulations with respect to such return or claim shall pay a penalty of $50 for such failure, unless it is shown that such failure is due to reasonable cause and not due to willful neglect. The maximum penalty imposed under this subsection on any person with respect to documents filed during any calendar year shall not exceed $25,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id472d390a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6695/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to furnish identifying number","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who is a tax return preparer with respect to any return or claim for refund and who fails to comply with section 6109(a)(4) with respect to such return or claim shall pay a penalty of $50 for such failure, unless it is shown that such failure is due to reasonable cause and not due to willful neglect. The maximum penalty imposed under this subsection on any person with respect to documents filed during any calendar year shall not exceed $25,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id472d390b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6695/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to retain copy or list","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who is a tax return preparer with respect to any return or claim for refund who fails to comply with section 6107(b) with respect to such return or claim shall pay a penalty of $50 for each such failure, unless it is shown that such failure is due to reasonable cause and not due to willful neglect. The maximum penalty imposed under this subsection on any person with respect to any return period shall not exceed $25,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id472d390c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6695/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to file correct information returns","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person required to make a return under section 6060 who fails to comply with the requirements of such section shall pay a penalty of $50 for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id472d390d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6695/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each failure to file a return as required under such section, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id472d390e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6695/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each failure to set forth an item in the return as required under section,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"unless it is shown that such failure is due to reasonable cause and not due to willful neglect. The maximum penalty imposed under this subsection on any person with respect to any return period shall not exceed $25,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id472d390f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6695/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Negotiation of check","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who is a tax return preparer who endorses or otherwise negotiates (directly or through an agent) any check made in respect of the taxes imposed by this title which is issued to a taxpayer (other than the tax return preparer) shall pay a penalty of $500 with respect to each such check. The preceding sentence shall not apply with respect to the deposit by a bank (within the meaning of section 581) of the full amount of the check in the taxpayer’s account in such bank for the benefit of the taxpayer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id472d3910-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6695/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to be diligent in determining eligibility for certain tax benefits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person who is a tax return preparer with respect to any return or claim for refund who fails to comply with due diligence requirements imposed by the Secretary by regulations with respect to determining—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id472d3911-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6695/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligibility to file as a head of household (as defined in section 2(b)) on the return, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id472d3912-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6695/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligibility for, or the amount of, the credit allowable by section 24, 25A(a)(1), or 32,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall pay a penalty of $500 for each such failure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id472d3913-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6695/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment for inflation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id472d3914-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6695/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any failure relating to a return or claim for refund filed in a calendar year beginning after 2014, each of the dollar amounts under subsections (a), (b), (c), (d), (e), (f), and (g) shall be increased by an amount equal to such dollar amount multiplied by the cost-of-living adjustment determined under section 1(f)(3) for the calendar year determined by substituting “calendar year 2013” for “calendar year 2016” in subparagraph (A)(ii) thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id472d3915-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6695/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rounding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If any amount adjusted under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id472d3916-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6695/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not less than $5,000 and is not a multiple of $500, such amount shall be rounded to the next lowest multiple of $500, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id472d3917-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6695/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not described in subparagraph (A) and is not a multiple of $5, such amount shall be rounded to the next lowest multiple of $5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id472d3918-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXII/s1203/f"},"text":"Pub. L. 94–455, title XII, § 1203(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1692"},"text":"90 Stat. 1692","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/600/tVII/s701/cc/1"},"text":"Pub. L. 95–600, title VII, § 701(cc)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2923"},"text":"92 Stat. 2923","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s179/b/2"},"text":"Pub. L. 98–369, div. A, title I, § 179(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/718"},"text":"98 Stat. 718","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/44/s1/b"},"text":"Pub. L. 99–44, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-05-24"},"text":"May 24, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/77"},"text":"99 Stat. 77","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7733/a"},"text":"Pub. L. 101–239, title VII, § 7733(a)","children":[],"tail":"–(d), "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2402"},"text":"103 Stat. 2402","children":[],"tail":", 2403; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tX/s1085/a/2"},"text":"Pub. L. 105–34, title X, § 1085(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/956"},"text":"111 Stat. 956","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/28/tVIII/s8246/a/2/G/i"},"text":"Pub. L. 110–28, title VIII, § 8246(a)(2)(G)(i)","children":[],"tail":", (ii), "},{"tag":"date","attrib":{"date":"2007-05-25"},"text":"May 25, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/202"},"text":"121 Stat. 202","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/41/tV/s501/a"},"text":"Pub. L. 112–41, title V, § 501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-10-21"},"text":"Oct. 21, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/459"},"text":"125 Stat. 459","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dB/tII/s208/c"},"text":"Pub. L. 113–295, div. B, title II, § 208(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4073"},"text":"128 Stat. 4073","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/113/dQ/tII/s207/a"},"text":"Pub. L. 114–113, div. Q, title II, § 207(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/3082"},"text":"129 Stat. 3082","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI"},"text":"Pub. L. 115–97, title I","children":[],"tail":", §§ 11001(b), 11002(d)(1)(MM), "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2058"},"text":"131 Stat. 2058","children":[],"tail":", 2060; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/299/C"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(299)(C)","children":[],"tail":", (309), (310), "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1198"},"text":"132 Stat. 1198","children":[],"tail":", 1199.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id472fa919-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id472fa91a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Inflation Adjusted Items for Certain Years","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For inflation adjustment of certain items in this section, see Revenue Procedures listed in a table under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id472fa91b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id472fa91c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (h)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/a/299/C"},"text":"Pub. L. 115–141, § 401(a)(299)(C)","children":[],"tail":", inserted “an amount equal to” after “increased by” and “for the calendar year” after “section 1(f)(3)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/a/309"},"text":"Pub. L. 115–141, § 401(a)(309)","children":[],"tail":", substituted “paragraph (1)” for “subparagraph (A)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/a/310"},"text":"Pub. L. 115–141, § 401(a)(310)","children":[],"tail":", substituted “subparagraph (A)” for “clause (i)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s11001/b"},"text":"Pub. L. 115–97, § 11001(b)","children":[],"tail":", amended subsec. (g) generally. Prior to amendment, text read as follows: “Any person who is a tax return preparer with respect to any return or claim for refund who fails to comply with due diligence requirements imposed by the Secretary by regulations with respect to determining eligibility for, or the amount of, the credit allowable by section 24, 25A(a)(1), or 32 shall pay a penalty of $500 for each such failure.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s11002/d/1/MM"},"text":"Pub. L. 115–97, § 11002(d)(1)(MM)","children":[],"tail":", substituted “for ‘calendar year 2016’ in subparagraph (A)(ii)” for “for ‘calendar year 1992’ in subparagraph (B)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113"},"text":"Pub. L. 114–113","children":[],"tail":" inserted “child tax credit; American Opportunity Tax Credit; and” before “earned income credit” in heading and substituted “section 24, 25A(a)(1), or 32” for “section 32” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" added subsec. (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/41"},"text":"Pub. L. 112–41","children":[],"tail":" substituted “$500” for “$100”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/28/s8246/a/2/G/i/I"},"text":"Pub. L. 110–28, § 8246(a)(2)(G)(i)(I)","children":[],"tail":", struck out “income” before “tax” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/28/s8246/a/2/G/i/II"},"text":"Pub. L. 110–28, § 8246(a)(2)(G)(i)(II)","children":[],"tail":", substituted “a tax return preparer” for “an income tax return preparer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/28/s8246/a/2/G/i/II"},"text":"Pub. L. 110–28, § 8246(a)(2)(G)(i)(II)","children":[],"tail":", (ii), substituted “a tax return preparer” for “an income tax return preparer”, “this title” for “subtitle A”, and “the tax return preparer” for “the income tax return preparer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/28/s8246/a/2/G/i/II"},"text":"Pub. L. 110–28, § 8246(a)(2)(G)(i)(II)","children":[],"tail":", substituted “a tax return preparer” for “an income tax return preparer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsecs. (a) to (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7733/a"},"text":"Pub. L. 101–239, § 7733(a)","children":[],"tail":"–(c), substituted “$50” for “$25” and inserted at end “The maximum penalty imposed under this subsection on any person with respect to documents filed during any calendar year shall not exceed $25,000.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7733/d"},"text":"Pub. L. 101–239, § 7733(d)","children":[],"tail":", substituted “returns” for “return” in heading and amended text generally. Prior to amendment, text read as follows: “Any person required to make a return under section 6060 who fails to comply with the requirements of such section shall pay a penalty of—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) $100 for each failure to file a return as required under such section, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) $5 for each failure to set forth an item in the return as required under such section,","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"unless it is shown that such failure is due to reasonable cause and not due to willful neglect. The maximum penalty imposed under this subsection on any person with respect to any return period shall not exceed $20,000.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/44"},"text":"Pub. L. 99–44","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s179/b/2"},"text":"Pub. L. 98–369, § 179(b)(2)","children":[],"tail":", which amended subsec. (b), and provided that the Internal Revenue Code of 1954 [now 1986] [this title] shall be applied and administered as if section 179(b)(2) (and the amendments made by such section) had not been enacted. See 1984 Amendment note and Effective Date of 1985 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" amended subsec. (b) generally, substituting provisions dealing with failure to inform taxpayer of certain recordkeeping requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s274/d"},"text":"section 274(d) of this title","children":[],"tail":" or to sign returns, for provisions dealing with failure to sign returns. See 1985 Amendment note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600"},"text":"Pub. L. 95–600","children":[],"tail":" inserted provision relating to deposits by a bank."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id472fa91d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id472fa91e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s11001/b"},"text":"section 11001(b) of Pub. L. 115–97","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"2017-12-31"},"text":"Dec. 31, 2017","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/s11001/c"},"text":"section 11001(c) of Pub. L. 115–97","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s11002/d/1/MM"},"text":"section 11002(d)(1)(MM) of Pub. L. 115–97","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date"