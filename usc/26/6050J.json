{"tag":"section","attrib":{"id":"id467cd47c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050J"},"text":null,"children":[{"tag":"num","attrib":{"value":"6050J"},"text":"§ 6050J.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Returns relating to foreclosures and abandonments of security","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id467cd47d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050J/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person who, in connection with a trade or business conducted by such person, lends money secured by property and who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467cd47e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050J/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in full or partial satisfaction of any indebtedness, acquires an interest in any property which is security for such indebtedness, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467cd47f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050J/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has reason to know that the property in which such person has a security interest has been abandoned,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall make a return described in subsection (c) with respect to each of such acquisitions or abandonments, at such time as the Secretary may by regulations prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467cd480-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050J/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not apply to any loan to an individual secured by an interest in tangible personal property which is not held for investment and which is not used in a trade or business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467cd481-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050J/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form and manner of return","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The return required under subsection (a) with respect to any acquisition or abandonment of property—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467cd482-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050J/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be in such form as the Secretary may prescribe,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467cd483-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050J/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall contain—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id467cd484-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050J/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name and address of each person who is a borrower with respect to the indebtedness which is secured,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467cd485-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050J/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a general description of the nature of such property and such indebtedness,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467cd486-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050J/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a return required under subsection (a)(1)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id467cd487-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050J/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of such indebtedness at the time of such acquisition, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id467cd488-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050J/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of indebtedness satisfied in such acquisition,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467cd489-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050J/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a return required under subsection (a)(2), the amount of such indebtedness at the time of such abandonment, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467cd48a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050J/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467cd48b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050J/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications to governmental units","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467cd48c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050J/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treated as persons","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person” includes any governmental unit (and any agency or instrumentality thereof).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467cd48d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050J/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a governmental unit or any agency or instrumentality thereof—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id467cd48e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050J/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (a) shall be applied without regard to the trade or business requirement contained therein, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467cd48f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050J/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any return under this section shall be made by the officer or employee appropriately designated for the purpose of making such return.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467cd490-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050J/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statements to be furnished to persons with respect to whom information is required to be furnished","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every person required to make a return under subsection (a) shall furnish to each person whose name is required to be set forth in such return a written statement showing the name, address, and phone number of the information contact of the person required to make such return. The written statement required under the preceding sentence shall be furnished to the person on or before January 31 of the year following the calendar year for which the return under subsection (a) was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467cd491-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050J/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of other dispositions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent provided by regulations prescribed by the Secretary, any transfer of the property which secures the indebtedness to a person other than the lender shall be treated as an abandonment of such property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id467cd492-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s148/a"},"text":"Pub. L. 98–369, div. A, title I, § 148(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/687"},"text":"98 Stat. 687","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/168/tXII/s1201/a/10"},"text":"Pub. L. 104–168, title XII, § 1201(a)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-07-30"},"text":"July 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1470"},"text":"110 Stat. 1470","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id467cd493-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id467cd494-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id467cd495-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/168"},"text":"Pub. L. 104–168","children":[],"tail":" substituted “name, address, and phone number of the information contact” for “name and address”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id467cd496-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id467cd497-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/168"},"text":"Pub. L. 104–168","children":[],"tail":" applicable to statements required to be furnished after "},{"tag":"date","attrib":{"date":"1996-12-31"},"text":"Dec. 31, 1996","children":[],"tail":" (determined without regard to any extension), see "},{"tag":"ref","attrib":{"href":"/us/pl/104/168/s1201/b"},"text":"section 1201(b) of Pub. L. 104–168","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6041"},"text":"section 6041 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id467cd498-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s148/d"},"text":"Pub. L. 98–369, div. A, title I, § 148(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/689"},"text":"98 Stat. 689","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/369/dA/tI/s148/d"},"text":"“The amendments made by this section [enacting this section and amending sections 6652 and 6678 of this title] shall apply with respect to acquisitions of property and abandonments of property after ","children":[{"tag":"date","attrib":{"date":"1984-12-31"},"text":"December 31, 1984","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
