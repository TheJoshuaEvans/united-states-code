{"tag":"section","attrib":{"id":"id42ad7d72-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s307"},"text":null,"children":[{"tag":"num","attrib":{"value":"307"},"text":"§ 307.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis of stock and stock rights acquired in distributions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id42ad7d73-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s307/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a shareholder in a corporation receives its stock or rights to acquire its stock (referred to in this subsection as “new stock”) in a distribution to which section 305(a) applies, then the basis of such new stock and of the stock with respect to which it is distributed (referred to in this section as “old stock”), respectively, shall, in the shareholder’s hands, be determined by allocating between the old stock and the new stock the adjusted basis of the old stock. Such allocation shall be made under regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42ad7d74-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s307/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for certain stock rights","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42ad7d75-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s307/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42ad7d76-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s307/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a corporation distributes rights to acquire its stock to a shareholder in a distribution to which section 305(a) applies, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42ad7d77-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s307/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fair market value of such rights at the time of the distribution is less than 15 percent of the fair market value of the old stock at such time,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then subsection (a) shall not apply and the basis of such rights shall be zero, unless the taxpayer elects under paragraph (2) of this subsection to determine the basis of the old stock and of the stock rights under the method of allocation provided in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42ad7d78-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s307/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The election referred to in paragraph (1) shall be made in the return filed within the time prescribed by law (including extensions thereof) for the taxable year in which such rights were received. Such election shall be made in such manner as the Secretary may by regulations prescribe, and shall be irrevocable when made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42ad7d79-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s307/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For basis of stock and stock rights distributed before ","children":[{"tag":"date","attrib":{"date":"1954-06-22"},"text":"June 22, 1954","children":[],"tail":", see section 1052."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id42ad7d7a-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/93"},"text":"68A Stat. 93","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id42ad7d7b-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id42ad7d7c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id42ad7d7d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—Subsecs. (a), (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
