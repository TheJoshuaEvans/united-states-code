{"tag":"section","attrib":{"id":"id4613d983-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000B"},"text":null,"children":[{"tag":"num","attrib":{"value":"5000B"},"text":"§ 5000B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of tax on indoor tanning services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4613d984-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000B/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby imposed on any indoor tanning service a tax equal to 10 percent of the amount paid for such service (determined without regard to this section), whether paid by insurance or otherwise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4613d985-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000B/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indoor tanning service","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4613d986-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000B/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “indoor tanning service” means a service employing any electronic product designed to incorporate 1 or more ultraviolet lamps and intended for the irradiation of an individual by ultraviolet radiation, with wavelengths in air between 200 and 400 nanometers, to induce skin tanning.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4613d987-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000B/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of phototherapy services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such term does not include any phototherapy service performed by a licensed medical professional.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4613d988-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000B/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of tax","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4613d989-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000B/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tax imposed by this section shall be paid by the individual on whom the service is performed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4613d98a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000B/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every person receiving a payment for services on which a tax is imposed under subsection (a) shall collect the amount of the tax from the individual on whom the service is performed and remit such tax quarterly to the Secretary at such time and in such manner as provided by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4613d98b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5000B/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secondary liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Where any tax imposed by subsection (a) is not paid at the time payments for indoor tanning services are made, then to the extent that such tax is not collected, such tax shall be paid by the person who performs the service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4613d98c-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10907/b"},"text":"Pub. L. 111–148, title X, § 10907(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1020"},"text":"124 Stat. 1020","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4613d98d-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4613d98e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4613d98f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5000B, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIX/s9017/a"},"text":"Pub. L. 111–148, title IX, § 9017(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/872"},"text":"124 Stat. 872","children":[],"tail":", which related to tax on elective cosmetic medical procedures, and "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s9017/c"},"text":"section 9017(c) of Pub. L. 111–148","children":[],"tail":", which provided that the amendments made by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s9017"},"text":"section 9017 of Pub. L. 111–148","children":[],"tail":" were applicable to procedures performed on or after "},{"tag":"date","attrib":{"date":"2010-01-01"},"text":"Jan. 1, 2010","children":[],"tail":", were not set out in the Code in view of "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10907/a"},"text":"Pub. L. 111–148, title X, § 10907(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1020"},"text":"124 Stat. 1020","children":[],"tail":", which provided that the provisions of, and amendments made by, "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s9017"},"text":"section 9017 of Pub. L. 111–148","children":[],"tail":" were deemed null, void, and of no effect."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4613d990-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4613d991-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10907/d"},"text":"Pub. L. 111–148, title X, § 10907(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1021"},"text":"124 Stat. 1021","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/148/tX/s10907/d"},"text":"“The amendments made by this section [enacting this section] shall apply to services performed on or after ","children":[{"tag":"date","attrib":{"date":"2010-07-01"},"text":"July 1, 2010","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
