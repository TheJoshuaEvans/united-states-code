{"tag":"section","attrib":{"id":"id462bce47-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5181"},"text":null,"children":[{"tag":"num","attrib":{"value":"5181"},"text":"§ 5181.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distilled spirits for fuel use","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id462bce48-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5181/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id462bce49-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5181/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes for which plant may be established","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On such application and bond and in such manner as the Secretary may prescribe by regulation, a person may establish a distilled spirits plant solely for the purpose of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id462bce4a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5181/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" producing, processing, and storing, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id462bce4b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5181/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using or distributing,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"distilled spirits to be used exclusively for fuel use.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id462bce4c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5181/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In prescribing regulations under paragraph (1) and in carrying out the provisions of this section, the Secretary shall, to the greatest extent possible, take steps to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id462bce4d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5181/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expedite all applications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id462bce4e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5181/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a minimum bond; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id462bce4f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5181/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" generally encourage and promote (through regulation or otherwise) the production of alcohol for fuel purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id462bce50-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5181/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to exempt","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may by regulation provide for the waiver of any provision of this chapter (other than this section or any provision requiring the payment of tax) for any distilled spirits plant described in subsection (a) if the Secretary finds it necessary to carry out the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id462bce51-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5181/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for small plant production","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id462bce52-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5181/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id462bce53-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5181/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An application for an operating permit for an eligible distilled spirits plant shall be in such a form and manner, and contain such information, as the Secretary may by regulations prescribe; except that the Secretary shall, to the greatest extent possible, take steps to simplify the application so as to expedite the issuance of such permits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id462bce54-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5181/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Receipt of application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 15 days of receipt of an application under subparagraph (A), the Secretary shall send a written notice of receipt to the applicant, together with a statement as to whether the application meets the requirements of subparagraph (A). If such a notice is not sent and the applicant has a receipt indicating that the Secretary has received an application, paragraph (2) shall apply as if a written notice required by the preceding sentence, together with a statement that the application meets the requirements of subparagraph (A), had been sent on the 15th day after the date the Secretary received the application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id462bce55-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5181/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiple applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If more than one application is submitted with respect to any eligible distilled spirits plant in any calendar quarter, the provisions of this section shall apply only to the first application submitted with respect to such plant during such quarter. For purposes of the preceding sentence, if a corrected or amended first application is filed, such application shall not be considered as a separate application, and the 15-day period referred to in subparagraph (A) shall commence with receipt of the corrected or amended application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id462bce56-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5181/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id462bce57-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5181/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case in which the Secretary under paragraph (1)(B) has notified an applicant of receipt of an application which meets the requirements of paragraph (1)(A), the Secretary shall make a determination as to whether such operating permit is to be issued, and shall notify the applicant of such determination, within 45 days of the date on which notice was sent under paragraph (1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id462bce58-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5181/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to make determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary has not notified an applicant within the time prescribed under subparagraph (A), the application shall be treated as approved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id462bce59-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5181/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rejection of application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary determines under subparagraph (A) that a permit should not be issued—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id462bce5a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5181/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall include in the notice to the applicant of such determination under subparagraph (A) detailed reasons for such determination, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id462bce5b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5181/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such determination shall not prejudice any further application for such operating permit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id462bce5c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5181/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bond","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No bond shall be required for an eligible distilled spirits plant. For purposes of section 5212 and subsection (e)(2) of this section, the premises of an eligible distilled spirits plant shall be treated as bonded premises.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id462bce5d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5181/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible distilled spirits plant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible distilled spirits plant” means a plant which is used to produce distilled spirits exclusively for fuel use and the production from which does not exceed 10,000 proof gallons per year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id462bce5e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5181/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal free of tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Distilled spirits produced under this section may be withdrawn free of tax from the bonded premises (and any premises which are not bonded by reason of subsection (c)(3)) of a distilled spirits plant exclusively for fuel use as provided in section 5214(a)(12).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id462bce5f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5181/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited withdrawal, use, sale, or disposition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id462bce60-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5181/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Distilled spirits produced under this section shall not be withdrawn, used, sold, or disposed of for other than fuel use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id462bce61-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5181/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rendering unfit for use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For protection of the revenue and under such regulations as the Secretary may prescribe, distilled spirits produced under this section shall, before withdrawal from the bonded premises of a distilled spirits plant, be rendered unfit for beverage use by the addition of substances which will not impair the quality of the spirits for fuel use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id462bce62-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5181/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of distilled spirits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “distilled spirits” does not include distilled spirits produced from petroleum, natural gas, or coal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id462bce63-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/223/tII/s232/e/1"},"text":"Pub. L. 96–223, title II, § 232(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-04-02"},"text":"Apr. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/278"},"text":"94 Stat. 278","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id462bce64-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id462bce65-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id462bce66-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5181 was renumbered 5182 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id462bce67-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id462e1858-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/223/tII/s232/h/3"},"text":"Pub. L. 96–223, title II, § 232(h)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-04-02"},"text":"Apr. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/281"},"text":"94 Stat. 281","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/223/tII/s232/h/3"},"text":"“The amendments made by subsection (e) [enacting this section, amending sections 5004, 5005, 5214, and 5601, and repealing provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s4081"},"text":"section 4081 of this title","children":[],"tail":"] shall take effect on the first day of the first calendar month beginning more than 60 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1980-04-02"},"text":"Apr. 2, 1980","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
