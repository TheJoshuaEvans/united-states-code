 669 of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s856"},"text":"section 856 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id443973a0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1604/h"},"text":"section 1604(h) of Pub. L. 94–455","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1608/d"},"text":"section 1608(d) of Pub. L. 94–455","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s856"},"text":"section 856 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id443973a1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to taxable years of real estate investment trusts beginning after ","children":[{"tag":"date","attrib":{"date":"1960-12-31"},"text":"Dec. 31, 1960","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/86/779/s10/k"},"text":"section 10(k) of Pub. L. 86–779","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s856"},"text":"section 856 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
