{"tag":"section","attrib":{"id":"id44370393-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s858"},"text":null,"children":[{"tag":"num","attrib":{"value":"858"},"text":"§ 858.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dividends paid by real estate investment trust after close of taxable year","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44370394-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s858/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this part, if a real estate investment trust—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44370395-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s858/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" declares a dividend before the time prescribed by law for the filing of its return for a taxable year (including the period of any extension of time granted for filing such return), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44397396-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s858/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" distributes the amount of such dividend to shareholders or holders of beneficial interests in the 12-month period following the close of such taxable year and not later than the date of the first regular dividend payment made after such declaration,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the amount so declared and distributed shall, to the extent the trust elects in such return (and specifies in dollar amounts) in accordance with regulations prescribed by the Secretary, be considered as having been paid only during such taxable year, except as provided in subsections (b) and (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44397397-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s858/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Receipt by shareholder","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in section 857(b)(9), amounts to which subsection (a) applies shall be treated as received by the shareholder or holder of a beneficial interest in the taxable year in which the distribution is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44397398-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s858/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to shareholders","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of amounts to which subsection (a) applies, any notice to shareholders or holders of beneficial interests required under this part with respect to such amounts shall be made not later than 30 days after the close of the taxable year in which the distribution is made (or mailed to its shareholders or holders of beneficial interests with its annual report for the taxable year).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44397399-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/779/s10/a"},"text":"Pub. L. 86–779, § 10(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-14"},"text":"Sept. 14, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/1008"},"text":"74 Stat. 1008","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXVI"},"text":"Pub. L. 94–455, title XVI","children":[],"tail":", §§ 1604(h), title XIX, § 1906(b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1752"},"text":"90 Stat. 1752","children":[],"tail":", 1834; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVI"},"text":"Pub. L. 99–514, title VI","children":[],"tail":", §§ 665(b)(2), 668(b)(1)(B), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2304"},"text":"100 Stat. 2304","children":[],"tail":", 2307; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1018/u/27"},"text":"Pub. L. 100–647, title I, § 1018(u)(27)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3591"},"text":"102 Stat. 3591","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dA/tII/s220/m"},"text":"Pub. L. 113–295, div. A, title II, § 220(m)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4036"},"text":"128 Stat. 4036","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4439739a-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4439739b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4439739c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" substituted “857(b)(9)” for “857(b)(8)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1018/u/27"},"text":"Pub. L. 100–647, § 1018(u)(27)","children":[],"tail":", made technical correction to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", see 1986 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s668/b/1/B"},"text":"Pub. L. 99–514, § 668(b)(1)(B)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1018/u/27"},"text":"Pub. L. 100–647, § 1018(u)(27)","children":[],"tail":", substituted “Except as provided in section 857(b)(8), amounts” for “Amounts”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s665/b/2"},"text":"Pub. L. 99–514, § 665(b)(2)","children":[],"tail":", inserted “(or mailed to its shareholders or holders of beneficial interests with its annual report for the taxable year)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":", §§ 1604(h), 1906(b)(13)(A), inserted “(and specifies in dollar amounts)” after “to the extent the trust elects in such return” and substituted “paid only during such taxable year” for “paid during such taxable year”, and struck out “or his delegate” after “Secretary”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4439739d-3a70-11f1-a967-d35dac11796a"},"text":null,"chil