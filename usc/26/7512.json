{"tag":"section","attrib":{"id":"id476b5361-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7512"},"text":null,"children":[{"tag":"num","attrib":{"value":"7512"},"text":"§ 7512.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separate accounting for certain collected taxes, etc.","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id476b5362-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7512/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whenever any person who is required to collect, account for, and pay over any tax imposed by subtitle C or chapter 33—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id476b5363-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7512/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the time and in the manner prescribed by law or regulations (A) fails to collect, truthfully account for, or pay over such tax, or (B) fails to make deposits, payments, or returns of such tax, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id476b5364-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7512/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is notified, by notice delivered in hand to such person, of any such failure,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then all the requirements of subsection (b) shall be complied with. In the case of a corporation, partnership, or trust, notice delivered in hand to an officer, partner, or trustee, shall, for purposes of this section, be deemed to be notice delivered in hand to such corporation, partnership, or trust and to all officers, partners, trustees, and employees thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id476b5365-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7512/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who is required to collect, account for, and pay over any tax imposed by subtitle C or chapter 33, if notice has been delivered to such person in accordance with subsection (a), shall collect the taxes imposed by subtitle C or chapter 33 which become collectible after delivery of such notice, shall (not later than the end of the second banking day after any amount of such taxes is collected) deposit such amount in a separate account in a bank (as defined in section 581), and shall keep the amount of such taxes in such account until payment over to the United States. Any such account shall be designated as a special fund in trust for the United States, payable to the United States by such person as trustee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id476b5366-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7512/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relief from further compliance with subsection (b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever the Secretary is satisfied, with respect to any notification made under subsection (a), that all requirements of law and regulations with respect to the taxes imposed by subtitle C or chapter 33, as the case may be, will henceforth be complied with, he may cancel such notification. Such cancellation shall take effect at such time as is specified in the notice of such cancellation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id476b5367-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/321/s1"},"text":"Pub. L. 85–321, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-02-11"},"text":"Feb. 11, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/5"},"text":"72 Stat. 5","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/223/tI/s101/c/3"},"text":"Pub. L. 96–223, title I, § 101(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-04-02"},"text":"Apr. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/251"},"text":"94 Stat. 251","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1941/b/2/O"},"text":"Pub. L. 100–418, title I, § 1941(b)(2)(O)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1324"},"text":"102 Stat. 1324","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id476b5368-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id476b5369-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id476b536a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1941/b/2/O/i"},"text":"Pub. L. 100–418, § 1941(b)(2)(O)(i)","children":[],"tail":", substituted “or chapter 33” for “, by chapter 33, or by section 4986” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1941/b/2/O/i"},"text":"Pub. L. 100–418, § 1941(b)(2)(O)(i)","children":[],"tail":", (ii), substituted “or chapter 33” for “, by chapter 33, or by section 4986” and “or chapter 33” for “, chapter 33, or section 4986”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1941/b/2/O/ii"},"text":"Pub. L. 100–418, § 1941(b)(2)(O)(ii)","children":[],"tail":", substituted “or chapter 33” for “, chapter 33, or section 4986”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsecs. (a) to (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/223"},"text":"Pub. L. 96–223","children":[],"tail":" inserted references to tax imposed by section 4986."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id476d9d5b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id476d9d5c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Pub. L. 100–418","children":[],"tail":" applicable to crude oil removed from the premises on or after "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1941/c"},"text":"section 1941(c) of Pub. L. 100–418","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s164"},"text":"section 164 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id476d9d5d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/223"},"text":"Pub. L. 96–223","children":[],"tail":" applicable to periods after "},{"tag":"date","attrib":{"date":"1980-02-29"},"text":"Feb. 29, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/223/s101/i"},"text":"section 101(i) of Pub. L. 96–223","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6161"},"text":"section 6161 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id476d9d5e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Notification of Failure To Collect, Account for, and Pay Over Taxes","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/85/321/s4"},"text":"Pub. L. 85–321, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-02-11"},"text":"Feb. 11, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/6"},"text":"72 Stat. 6","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Notification may be made under section 7512(a) of the Internal Revenue Code of 1986 [formerly I.R.C. 1954] (as added by the first section of this Act)—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of taxes imposed by subtitle C of such Code, only with respect to pay periods beginning after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1958-02-11"},"text":"Feb. 11, 1958","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of taxes imposed by chapter 33 of such Code, only with respect to taxes so imposed after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1958-02-11"},"text":"Feb. 11, 1958","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
