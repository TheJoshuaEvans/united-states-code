{"tag":"section","attrib":{"id":"id43fb5a19-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s703"},"text":null,"children":[{"tag":"num","attrib":{"value":"703"},"text":"§ 703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnership computations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id43fb5a1a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s703/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Income and deductions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The taxable income of a partnership shall be computed in the same manner as in the case of an individual except that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43fb5a1b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s703/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the items described in section 702(a) shall be separately stated, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43fb5a1c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s703/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the following deductions shall not be allowed to the partnership:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43fb5a1d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s703/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deductions for personal exemptions provided in section 151,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43fb5a1e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s703/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deduction for taxes provided in section 164(a) with respect to taxes, described in section 901, paid or accrued to foreign countries and to possessions of the United States,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43fb5a1f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s703/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deduction for charitable contributions provided in section 170,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43fb5a20-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s703/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the net operating loss deduction provided in section 172,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43fb5a21-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s703/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the additional itemized deductions for individuals provided in part VII of subchapter B (sec. 211 and following), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43fb5a22-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s703/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deduction for depletion under section 611 with respect to oil and gas wells.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43fb5a23-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s703/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elections of the partnership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any election affecting the computation of taxable income derived from a partnership shall be made by the partnership, except that any election under—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43fb5a24-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s703/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (b)(5) or (c)(3) of section 108 (relating to income from discharge of indebtedness),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43fb5a25-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s703/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 617 (relating to deduction and recapture of certain mining exploration expenditures), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43fb5a26-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s703/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 901 (relating to taxes of foreign countries and possessions of the United States),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be made by each partner separately.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id43fb5a27-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/240"},"text":"68A Stat. 240","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/570/s2/b"},"text":"Pub. L. 89–570, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-12"},"text":"Sept. 12, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/764"},"text":"80 Stat. 764","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/tV/s504/c/3"},"text":"Pub. L. 91–172, title V, § 504(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/633"},"text":"83 Stat. 633","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/178/tIII/s304/c"},"text":"Pub. L. 92–178, title III, § 304(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-10"},"text":"Dec. 10, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/523"},"text":"85 Stat. 523","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/12/tV/s501/b/3"},"text":"Pub. L. 94–12, title V, § 501(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-03-29"},"text":"Mar. 29, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/53"},"text":"89 Stat. 53","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1901/b/21/F"},"text":"Pub. L. 94–455, title XIX, § 1901(b)(21)(F)","children":[],"tail":", title XXI, § 2115(c)(2), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1798"},"text":"90 Stat. 1798","children":[],"tail":", 1909; "},{"tag":"ref","attrib":{"href":"/us/pl/95/30/tI/s101/d/10"},"text":"Pub. L. 95–30, title I, § 101(d)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-05-23"},"text":"May 23, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/134"},"text":"91 Stat. 134","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/p