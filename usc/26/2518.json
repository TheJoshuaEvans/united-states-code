{"tag":"section","attrib":{"id":"id45420a8c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2518"},"text":null,"children":[{"tag":"num","attrib":{"value":"2518"},"text":"§ 2518.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclaimers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45420a8d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2518/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subtitle, if a person makes a qualified disclaimer with respect to any interest in property, this subtitle shall apply with respect to such interest as if the interest had never been transferred to such person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45420a8e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2518/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified disclaimer defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a), the term “qualified disclaimer” means an irrevocable and unqualified refusal by a person to accept an interest in property but only if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45420a8f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2518/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such refusal is in writing,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45420a90-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2518/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such writing is received by the transferor of the interest, his legal representative, or the holder of the legal title to the property to which the interest relates not later than the date which is 9 months after the later of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45420a91-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2518/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the day on which the transfer creating the interest in such person is made, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45420a92-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2518/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the day on which such person attains age 21,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45420a93-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2518/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such person has not accepted the interest or any of its benefits, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45420a94-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2518/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" as a result of such refusal, the interest passes without any direction on the part of the person making the disclaimer and passes either—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45420a95-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2518/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the spouse of the decedent, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45420a96-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2518/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a person other than the person making the disclaimer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45420a97-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2518/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45420a98-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2518/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclaimer of undivided portion of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A disclaimer with respect to an undivided portion of an interest which meets the requirements of the preceding sentence shall be treated as a qualified disclaimer of such portion of the interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45420a99-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2518/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A power with respect to property shall be treated as an interest in such property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45420a9a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2518/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain transfers treated as disclaimers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A written transfer of the transferor’s entire interest in the property—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45420a9b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2518/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which meets requirements similar to the requirements of paragraphs (2) and (3) of subsection (b), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45420a9c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2518/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is to a person or persons who would have received the property had the transferor made a qualified disclaimer (within the meaning of subsection (b)),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be treated as a qualified disclaimer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45420a9d-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXX/s2009/b/1"},"text":"Pub. L. 94–455, title XX, § 2009(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1893"},"text":"90 Stat. 1893","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/600/tVII/s702/m/1"},"text":"Pub. L. 95–600, title VII, § 702(m)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2935"},"text":"92 Stat. 2935","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/tIV/s426/a"},"text":"Pub. L. 97–34, title IV, § 426(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/318"},"text":"95 Stat. 318","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/448/tI/s104/e"},"text":"Pub. L. 97–448, title I, § 104(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2384"},"text":"96 Stat. 2384","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45420a9e-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45420a9f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45420aa0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1983—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/448"},"text":"Pub. L. 97–448","children":[],"tail":" substituted “A written transfer” for “For purposes of subsection (a), a written transfer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":" added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600"},"text":"Pub. L. 95–600","children":[],"tail":" inserted provision relating to spouse of decedent."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45420aa1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45420aa2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1983 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/448"},"text":"Pub. L. 97–448","children":[],"tail":" effective, except as otherwise provided, as if it had been included in the provision of the Economic Recovery Tax Act of 1981, "},{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/97/448/s109"},"text":"section 109 of Pub. L. 97–448","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45420aa3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/tIV/s426/b"},"text":"Pub. L. 97–34, title IV, § 426(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/318"},"text":"95 Stat. 318","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/34/tIV/s426/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply to transfers creating an interest in the person disclaiming made after ","children":[{"tag":"date","attrib":{"date":"1981-12-31"},"text":"December 31, 1981","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45420aa4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600/tVII/s702/m/2"},"text":"Pub. L. 95–600, title VII, § 702(m)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2935"},"text":"92 Stat. 2935","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/600/tVII/s702/m/2"},"text":"“The amendment made by paragraph (1) [amending this section] shall apply to transfers creating an interest in the person disclaiming made after ","children":[{"tag":"date","attrib":{"date":"1976-12-31"},"text":"December 31, 1976","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id45420aa5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXX/s2009/e/2"},"text":"Pub. L. 94–455, title XX, § 2009(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1896"},"text":"90 Stat. 1896","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/455/tXX/s2009/e/2"},"text":"“The amendments made by subsection (b) [enacting this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s2046"},"text":"section 2046 of this title","children":[],"tail":" and amending sections 2041, 2055, 2056, and 2514 of this title] shall apply with respect to transfers creating an interest in the person disclaiming made after "},{"tag":"date","attrib":{"date":"1976-12-31"},"text":"December 31, 1976","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
