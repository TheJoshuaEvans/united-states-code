{"tag":"section","attrib":{"id":"id44db7fef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1276"},"text":null,"children":[{"tag":"num","attrib":{"value":"1276"},"text":"§ 1276.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition gain representing accrued market discount treated as ordinary income","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44db7ff0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1276/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ordinary income","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44db7ff1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1276/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this section, gain on the disposition of any market discount bond shall be treated as ordinary income to the extent it does not exceed the accrued market discount on such bond. Such gain shall be recognized notwithstanding any other provision of this subtitle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44db7ff2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1276/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dispositions other than sales, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1), a person disposing of any market discount bond in any transaction other than a sale, exchange, or involuntary conversion shall be treated as realizing an amount equal to the fair market value of the bond.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44db7ff3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1276/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of partial principal payments","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44db7ff4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1276/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any partial principal payment on a market discount bond shall be included in gross income as ordinary income to the extent such payment does not exceed the accrued market discount on such bond.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44db7ff5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1276/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If subparagraph (A) applies to any partial principal payment on any market discount bond, for purposes of applying this section to any disposition of (or subsequent partial principal payment on) such bond, the amount of accrued market discount shall be reduced by the amount of such partial principal payment included in gross income under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44db7ff6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1276/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gain treated as interest for certain purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except for purposes of sections 103, 871(a), 881, 1441, 1442, and 6049 (and such other provisions as may be specified in regulations), any amount treated as ordinary income under paragraph (1) or (3) shall be treated as interest for purposes of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44db7ff7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1276/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accrued market discount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44db7ff8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1276/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ratable accrual","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this subsection or subsection (c), the accrued market discount on any bond shall be an amount which bears the same ratio to the market discount on such bond as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44db7ff9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1276/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of days which the taxpayer held the bond, bears to","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44db7ffa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1276/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of days after the date the taxpayer acquired the bond and up to (and including) the date of its maturity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44db7ffb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1276/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election of accrual on basis of constant interest rate (in lieu of ratable accrual)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44db7ffc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1276/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"At the election of the taxpayer with respect to any bond, the accrued market discount on such bond shall be the aggregate amount which would have been includible in the gross income of the taxpayer under section 1272(a) (determined without regard to paragraph (2) thereof) with respect to such bond for all periods during which the bond was held by the taxpayer if such bond had been—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44db7ffd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1276/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" originally issued on the date on which such bond was acquired by the taxpayer,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44db7ffe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1276/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for an issue price equal to the basis of the taxpayer in such bond immediately after its acquisition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44db7fff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1276/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination where bond has original issue discount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any bond having original issue discount, for purposes of applying subparagraph (A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44db8000-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1276/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the stated redemption price at maturity of such bond shall be treated as equal to its revised issue price, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44db8001-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1276/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the determination of the portion of the original issue discount which would have been includible in the gross income of the taxpayer under section 1272(a) shall be made under regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44db8002-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1276/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election irrevocable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An election under subparagraph (A), once made with respect to any bond, shall be irrevocable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44db8003-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1276/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule where partial principal payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a bond the principal of which may be paid in 2 or more payments, the amount of accrued market discount shall be determined under regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44db8004-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1276/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of nonrecognition transactions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under regulations prescribed by the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44db8005-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1276/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transferred basis property","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a market discount bond is transferred in a nonrecognition transaction and such bond is transferred basis property in the hands of the transferee, for purposes of determining the amount of the accrued market discount with respect to the transferee—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44db8006-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1276/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transferee shall be treated as having acquired the bond on the date on which it was acquired by the transferor for an amount equal to the basis of the transferor, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44db8007-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1276/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proper adjustments shall be made for gain recognized by the transferor on such transfer (and for any original issue discount or market discount included in the gross income of the transferor).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44db8008-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1276/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exchanged basis property","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If any market discount bond is disposed of by the taxpayer in a nonrecognition transaction and paragraph (1) does not apply to such transaction, any accrued market discount determined with respect to the property disposed of to the extent not theretofore treated as ordinary income under subsection (a)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44db8009-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1276/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be treated as accrued market discount with respect to the exchanged basis property received by the taxpayer in such transaction if such property is a market discount bond, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44db800a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1276/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be treated as ordinary income on the disposition of the exchanged basis property received by the taxpayer in such exchange if such property is not a market discount bond.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44db800b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1276/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Paragraph (1) to apply to certain distributions by corporations or partnerships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1), if the basis of any market discount bond in the hands of a transferee is determined under section 732(a), or 732(b), such property shall be treated as transferred basis property in the hands of such transferee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44db800c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1276/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under regulations prescribed by the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44db800d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1276/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" rules similar to the rules of subsection (b) of section 1245 shall apply for purposes of this section; except that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44db800e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1276/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paragraph (1) of such subsection shall not apply,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44db800f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1276/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an exchange qualifying under section 354(a), 355(a), or 356(a) (determined without regard to subsection (a) of this section) shall be treated as an exchange described in paragraph (3) of such subsection, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44db8010-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1276/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paragraph (3) of section 1245(b) shall be applied as if it did not contain a reference to section 351, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44db8011-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1276/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate adjustments shall be made to the basis of any property to reflect gain recognized under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44db8012-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s41/a"},"text":"Pub. L. 98–369, div. A, title I, § 41(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/543"},"text":"98 Stat. 543","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVI/s631/e/15"},"text":"Pub. L. 99–514, title VI, § 631(e)(15)","children":[],"tail":", title XVIII, §§ 1803(a)(5), (13)(A), 1899A(28), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2275"},"text":"100 Stat. 2275","children":[],"tail":", 2793, 2796, 2960; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1018/u/46"},"text":"Pub. L. 100–647, title I, § 1018(u)(46)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3592"},"text":"102 Stat. 3592","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13206/b/1/A"},"text":"Pub. L. 103–66, title XIII, § 13206(b)(1)(A)","children":[],"tail":", (2)(B)(i), "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/465"},"text":"107 Stat. 465","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/180"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(180)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1193"},"text":"132 Stat. 1193","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44db8013-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44db8014-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44db8015-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" substituted “871(a),” for “871(a),,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/s13206/b/2/B/i"},"text":"Pub. L. 103–66, § 13206(b)(2)(B)(i)","children":[],"tail":", substituted “sections 103, 871(a),” for “sections 871(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/s13206/b/1/A"},"text":"Pub. L. 103–66, § 13206(b)(1)(A)","children":[],"tail":", struck out heading and text of subsec. (e). Text read as follows: “This section shall not apply to any market discount bond issued on or before "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" designated paragraph relating to special rule where there are partial principal payments as par. (3) and inserted period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1803/a/13/A/i"},"text":"Pub. L. 99–514, § 1803(a)(13)(A)(i)","children":[],"tail":", added par. (3). Former par. (3) redesignated (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1803/a/13/A/i"},"text":"Pub. L. 99–514, § 1803(a)(13)(A)(i)","children":[],"tail":", (ii), redesignated par. (3) as (4) and substituted “