{"tag":"section","attrib":{"id":"id47287dc1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6665"},"text":null,"children":[{"tag":"num","attrib":{"value":"6665"},"text":"§ 6665.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable rules","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47287dc2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6665/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additions treated as tax","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this title—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47287dc3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6665/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the additions to the tax, additional amounts, and penalties provided by this chapter shall be paid upon notice and demand and shall be assessed, collected, and paid in the same manner as taxes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47287dc4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6665/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any reference in this title to “tax” imposed by this title shall be deemed also to refer to the additions to the tax, additional amounts, and penalties provided by this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47287dc5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6665/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedure for assessing certain additions to tax","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subchapter B of chapter 63 (relating to deficiency procedures for income, estate, gift, and certain excise taxes), subsection (a) shall not apply to any addition to tax under section 6651, 6654, or 6655; except that it shall apply—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47287dc6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6665/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an addition described in section 6651, to that portion of such addition which is attributable to a deficiency in tax described in section 6211; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47287dc7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6665/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to an addition described in section 6654 or 6655, if no return is filed for the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47287dc8-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7721/a"},"text":"Pub. L. 101–239, title VII, § 7721(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2399"},"text":"103 Stat. 2399","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47287dc9-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47287dca-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id47287dcb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to returns the due date for which (determined without regard to extensions) is after ","children":[{"tag":"date","attrib":{"date":"1989-12-31"},"text":"Dec. 31, 1989","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7721/d"},"text":"section 7721(d) of Pub. L. 101–239","children":[],"tail":", set out as an Effective Date of 1989 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s461"},"text":"section 461 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
