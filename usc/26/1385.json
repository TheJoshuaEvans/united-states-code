{"tag":"section","attrib":{"id":"id44fa79e6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1385"},"text":null,"children":[{"tag":"num","attrib":{"value":"1385"},"text":"§ 1385.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts includible in patron’s gross income","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44fa79e7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1385/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in subsection (b), each person shall include in gross income—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44fa79e8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1385/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of any patronage dividend which is paid in money, a qualified written notice of allocation, or other property (except a nonqualified written notice of allocation), and which is received by him during the taxable year from an organization described in section 1381(a),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44fa79e9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1385/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amount, described in section 1382 (c)(2)(A) (relating to certain nonpatronage distributions by tax-exempt farmers’ cooperatives), which is paid in money, a qualified written notice of allocation, or other property (except a nonqualified written notice of allocation), and which is received by him during the taxable year from an organization described in section 1381(a)(1), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44fa79ea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1385/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of any per-unit retain allocation which is paid in qualified per-unit retain certificates and which is received by him during the taxable year from an organization described in section 1381(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44fa79eb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1385/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion from gross income","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under regulations prescribed by the Secretary, the amount of any patronage dividend, and any amount received on the redemption, sale, or other disposition of a nonqualified written notice of allocation which was paid as a patronage dividend, shall not be included in gross income to the extent that such amount—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44fa79ec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1385/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is properly taken into account as an adjustment to basis of property, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44fa79ed-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1385/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is attributable to personal, living, or family items.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44fa79ee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1385/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain nonqualified written notices of allocation and certain nonqualified per-unit retain certificates","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44fa79ef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1385/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of subsection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This subsection shall apply to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44fa79f0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1385/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any nonqualified written notice of allocation which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44fa79f1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1385/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was paid as a patronage dividend, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44fa79f2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1385/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was paid by an organization described in section 1381(a)(1) on a patronage basis with respect to earnings derived from business or sources described in section 1382(c)(2)(A), and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44fa79f3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1385/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any nonqualified per-unit retain certificate which was paid as a per-unit retain allocation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44fa79f4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1385/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis; amount of gain","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any nonqualified written notice of allocation or nonqualified per-unit retain certificate to which this subsection applies, for purposes of this chapter—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44fa79f5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1385/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the basis of such written notice of allocation or per-unit retain certificate in the hands of the patron to whom such written notice of allocation or per-unit retain certificate was paid shall be zero,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44fa79f6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1385/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the basis of such written notice of allocation or per-unit retain certificate which was acquired from a decedent shall be its basis in the hands of the decedent, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44fa79f7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1385/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gain on the redemption, sale, or other disposition of such written notice of allocation or per-unit retain certificate by any person shall, to the extent that the stated dollar amount of such written notice of allocation or per-unit retain certificate exceeds its basis, be considered as ordinary income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44fa79f8-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/834/s17/a"},"text":"Pub. L. 87–834, § 17(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-16"},"text":"Oct. 16, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1048"},"text":"76 Stat. 1048","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/89/809/tII/s211/b/1"},"text":"Pub. L. 89–809, title II, § 211(b)(1)","children":[],"tail":"–(4), "},{"tag":"date","attrib":{"date":"1966-11-13"},"text":"Nov. 13, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1582"},"text":"80 Stat. 1582","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX"},"text":"Pub. L. 94–455, title XIX","children":[],"tail":", §§ 1901(b)(3)(I), 1906(b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1793"},"text":"90 Stat. 1793","children":[],"tail":", 1834.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44fa79f9-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44fa79fa-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44fa79fb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1901/b/3/I"},"text":"Pub. L. 94–455, § 1901(b)(3)(I)","children":[],"tail":", substituted “ordinary income” for “gain from the sale or exchange of property which is not a capital asset”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/809/s211/b/1"},"text":"Pub. L. 89–809, § 211(b)(1)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/809/s211/b/2"},"text":"Pub. L. 89–809, § 211(b)(2)","children":[],"tail":"–(4), inserted “and certain nonqualified per-unit retain certificates” in heading, inserted provisions to par. (1) for the application of the subsection to any nonqualified per-unit retain certificates which were paid as per-unit retain allocations, and inserted references to per-unit retain certificates in par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44fa79fc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44fa79fd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1901/b/3/I"},"text":"section 1901(b)(3)(I) of Pub. L. 94–455","children":[],"tail":" effective for taxable years beginning after "},{"tag":"date","attrib":{"date":"1976-12-31"},"text":"Dec. 31, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1901/d"},"text":"section 1901(d) of Pub. L. 94–455","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2"},"text":"section 2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44fa79fe-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1966 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/809"},"text":"Pub. L. 89–809","children":[],"tail":" applicable to per-unit retain allocations made during taxable years of an organization described in "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1381/a"},"text":"section 1381(a) of this title","children":[],"tail":" (relating to organizations to which part I of subchapter T of chapter 1 applies) beginning after "},{"tag":"date","attrib":{"date":"1966-04-30"},"text":"Apr. 30, 1966","children":[],"tail":", with respect to products delivered during such years, see "},{"tag":"ref","attrib":{"href":"/us/pl/89/809/s211/e/1"},"text":"section 211(e)(1) of Pub. L. 89–809","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1382"},"text":"section 1382 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id44fa79ff-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable, except as otherwise provided, to taxable years of organizations described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1381/a"},"text":"section 1381(a) of this title","children":[],"tail":" beginning after "},{"tag":"date","attrib":{"date":"1962-12-31"},"text":"Dec. 31, 1962","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/87/834/s17/c"},"text":"section 17(c) of Pub. L. 87–834","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1381"},"text":"section 1381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
