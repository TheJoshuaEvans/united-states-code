{"tag":"section","attrib":{"id":"id4774c8f0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7603"},"text":null,"children":[{"tag":"num","attrib":{"value":"7603"},"text":"§ 7603.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service of summons","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4774c8f1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7603/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A summons issued under section 6420(e)(2), 6421(g)(2), 6427(j)(2), or 7602 shall be served by the Secretary, by an attested copy delivered in hand to the person to whom it is directed, or left at his last and usual place of abode; and the certificate of service signed by the person serving the summons shall be evidence of the facts it states on the hearing of an application for the enforcement of the summons. When the summons requires the production of books, papers, records, or other data, it shall be sufficient if such books, papers, rec­ords, or other data are described with reasonable certainty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4774c8f2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7603/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service by mail to third-party recordkeepers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4774c8f3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7603/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A summons referred to in subsection (a) for the production of books, papers, records, or other data by a third-party recordkeeper may also be served by certified or registered mail to the last known address of such recordkeeper.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4774c8f4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7603/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Third-party recordkeeper","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), the term “third-party recordkeeper” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4774c8f5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7603/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any mutual savings bank, cooperative bank, domestic building and loan association, or other savings institution chartered and supervised as a savings and loan or similar association under Federal or State law, any bank (as defined in section 581), or any credit union (within the meaning of section 501(c)(14)(A)),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4774c8f6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7603/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any consumer reporting agency (as defined under section 603(f) of the Fair Credit Reporting Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681a/f"},"text":"15 U.S.C. 1681a(f)","children":[],"tail":")),"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4774c8f7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7603/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person extending credit through the use of credit cards or similar devices,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4774c8f8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7603/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any broker (as defined in section 3(a)(4) of the Securities Exchange Act of 1934 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c/a/4"},"text":"15 U.S.C. 78c(a)(4)","children":[],"tail":")),"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4774c8f9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7603/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any attorney,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4774c8fa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7603/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any accountant,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4774c8fb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7603/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any barter exchange (as defined in section 6045(c)(3)),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4774c8fc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7603/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any regulated investment company (as defined in section 851) and any agent of such regulated investment company when acting as an agent thereof,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4774c8fd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7603/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any enrolled agent, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4774c8fe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7603/b/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any owner or developer of a computer software source code (as defined in section 7612(d)(2)).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Subparagraph (J) shall apply only with respect to a summons requiring the production of the source code referred to in subparagraph (J) or the program and data described in section 7612(b)(1)(A)(ii) to which such source code relates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4774c8ff-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/902"},"text":"68A Stat. 902","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1956-04-02/ch160/s4/i"},"text":"Apr. 2, 1956, ch. 160, § 4(i)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/91"},"text":"70 Stat. 91","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1956-06-29/ch462"},"text":"June 29, 1956, ch. 462","children":[],"tail":", title II, § 208(d)(4), "},{"tag":"ref","attrib":{"href":"/us/stat/70/396"},"text":"70 Stat. 396","children":[],"tail":"; "},