{"tag":"section","attrib":{"id":"id4751144b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7427"},"text":null,"children":[{"tag":"num","attrib":{"value":"7427"},"text":"§ 7427.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax return preparers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In any proceeding involving the issue of whether or not a tax return preparer has willfully attempted in any manner to understate the liability for tax (within the meaning of section 6694(b)), the burden of proof in respect to such issue shall be upon the Secretary.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4751144c-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXII/s1203/b/2/A"},"text":"Pub. L. 94–455, title XII, § 1203(b)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1690"},"text":"90 Stat. 1690","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/28/tVIII/s8246/a/2/J/i"},"text":"Pub. L. 110–28, title VIII, § 8246(a)(2)(J)(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-05-25"},"text":"May 25, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/202"},"text":"121 Stat. 202","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4751144d-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4751144e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4751144f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7427 was renumbered 7437 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id47511450-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/28"},"text":"Pub. L. 110–28","children":[],"tail":" substituted “Tax return preparers” for “Income tax return preparers” in section catchline and “a tax return preparer” for “an income tax return preparer” in text."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47511451-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47511452-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/28"},"text":"Pub. L. 110–28","children":[],"tail":" applicable to returns prepared after "},{"tag":"date","attrib":{"date":"2007-05-25"},"text":"May 25, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/28/s8246/c"},"text":"section 8246(c) of Pub. L. 110–28","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6060"},"text":"section 6060 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
