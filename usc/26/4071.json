{"tag":"section","attrib":{"id":"id45b231a3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4071"},"text":null,"children":[{"tag":"num","attrib":{"value":"4071"},"text":"§ 4071.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of tax","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45b231a4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4071/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition and rate of tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby imposed on taxable tires sold by the manufacturer, producer, or importer thereof a tax at the rate of 9.45 cents (4.725 cents in the case of a biasply tire or super single tire) for each 10 pounds so much of the maximum rated load capacity thereof as exceeds 3,500 pounds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45b231a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4071/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for manufacturers who sell at retail","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under regulations prescribed by the Secretary, if the manufacturer, producer, or importer of any tire delivers such tire to a retail store or retail outlet of such manufacturer, producer, or importer, he shall be liable for tax under subsection (a) in respect of such tire in the same manner as if it had been sold at the time it was delivered to such retail store or outlet. This subsection shall not apply to an article in respect to which tax has been imposed by subsection (a). Subsection (a) shall not apply to an article in respect of which tax has been imposed by this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45b231a6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4071/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tires on imported articles","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of subsection (a), if an article imported into the United States is equipped with tires—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45b231a7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4071/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the importer of the article shall be treated as the importer of the tires with which such article is equipped, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45b231a8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4071/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sale of the article by the importer thereof shall be treated as the sale of the tires with which such article is equipped.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"This subsection shall not apply with respect to the sale of an automobile bus chassis or an automobile bus body.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45b231a9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4071/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On and after ","children":[{"tag":"date","attrib":{"date":"2028-10-01"},"text":"October 1, 2028","children":[],"tail":", the taxes imposed by subsection (a) shall not apply."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45b231aa-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/482"},"text":"68A Stat. 482","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1956-06-29/ch462"},"text":"June 29, 1956, ch. 462","children":[],"tail":", title II, § 204(a), "},{"tag":"ref","attrib":{"href":"/us/stat/70/388"},"text":"70 Stat. 388","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/440/s1/a"},"text":"Pub. L. 86–440, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-04-22"},"text":"Apr. 22, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/80"},"text":"74 Stat. 80","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/61/tII/s202"},"text":"Pub. L. 87–61, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-06-29"},"text":"June 29, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/124"},"text":"75 Stat. 124","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/523/s1/a"},"text":"Pub. L. 89–523, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-08-01"},"text":"Aug. 1, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/331"},"text":"80 Stat. 331","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/605/tIII/s303/a/5"},"text":"Pub. L. 91–605, title III, § 303(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1744"},"text":"84 Stat. 1744","children":[],"tail":"; "},{"tag":"ref"