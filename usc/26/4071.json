tI/s40102/a/2/C"},"text":"Pub. L. 112–141, div. D, title I, § 40102(a)(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/844"},"text":"126 Stat. 844","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dC/tXXXI/s31102/a/2/C"},"text":"Pub. L. 114–94, div. C, title XXXI, § 31102(a)(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1727"},"text":"129 Stat. 1727","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dH/tI/s80102/a/2/C"},"text":"Pub. L. 117–58, div. H, title I, § 80102(a)(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1327"},"text":"135 Stat. 1327","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45b231ab-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45b231ac-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45b231ad-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2028-10-01"},"text":"October 1, 2028","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2022-10-01"},"text":"October 1, 2022","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2022-10-01"},"text":"October 1, 2022","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2016-10-01"},"text":"October 1, 2016","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2016-10-01"},"text":"October 1, 2016","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2012-07-01"},"text":"July 1, 2012","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/140"},"text":"Pub. L. 112–140","children":[],"tail":", §§ 1(c), 402(a)(2)(C), temporarily substituted “"},{"tag":"date","attrib":{"date":"2012-07-07"},"text":"July 7, 2012","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2012-07-01"},"text":"July 1, 2012","children":[],"tail":"”. See Effective and Termination Dates of 2012 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/102"},"text":"Pub. L. 112–102","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2012-07-01"},"text":"July 1, 2012","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2012-04-01"},"text":"April 1, 2012","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/30"},"text":"Pub. L. 112–30","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2012-04-01"},"text":"April 1, 2012","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2011-10-01"},"text":"October 1, 2011","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":" substituted “2011” for “2005”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s869/a"},"text":"Pub. L. 108–357, § 869(a)","children":[],"tail":", reenacted heading without change and amended text of subsec. (a) generally. Prior to amendment, subsec. (a) imposed tax and set forth table of rates providing for no tax if the tire weighed not more than 40 lbs., tax of 15 cents per lb. in excess of 40 lbs. if the tire weighed more than 40 lbs. but not more than 70 lbs., tax of $4.50 plus 30 cents per lb. in excess of 70 lbs. if the tire weighed more than 70 lbs. but not more than 90 lbs., and tax of $10.50 plus 50 cents per lb. in excess of 90 lbs. if the tire weighed more than 90 lbs."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s869/d/1"},"text":"Pub. L. 108–357, § 869(d)(1)","children":[],"tail":", redesignated subsec. (e) as (c) and struck out heading and text of former subsec. (c). Text read as follows: “For purposes of this section, weight shall be based on total weight exclusive of metal rims or rim bases. Total weight of the articles shall be determined under regulations prescribed by the Secretary.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s869/d/1"},"text":"Pub. L. 108–357, § 869(d)(1)","children":[],"tail":", redesignated subsec. (e) as (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178"},"text":"Pub. L. 105–178","children":[],"tail":" substituted “2005” for “1999”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/240"},"text":"Pub. L. 102–240","children":[],"tail":" substituted “1999” for “1995”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" substituted “1995” for “1993”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/17"},"text":"Pub. L. 100–17","children":[],"tail":" substituted “1993” for “1988”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s735/c/2/A"},"text":"Pub. L. 98–369, § 735(c)(2)(A)","children":[],"tail":", struck out “or inner tube” after “any tire”, and struck out “or tube” after “such tire” in two places in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s735/c/2/B"},"text":"Pub. L. 98–369, § 735(c)(2)(B)","children":[],"tail":", substituted “on total weight exclusive” for “on total weight, except that in the case of tires such total weight shall be exclusive”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s735/c/2/C"},"text":"Pub. L. 98–369, § 735(c)(2)(C)","children":[],"tail":", struck out “or inner tubes (other than bicycle tires and inner tubes)” after “equipped with tires” in provisions preceding par. (1), struck out “and inner tubes” before “with which such article is equipped” in pars. (1) and (2), and substituted “sale of an automobile bus chassis or an automobile bus body” for “sale of an article if a tax on such sale is imposed under section 4061 or if such article is an automobile bus chassis or an automobile bus body” in provisions following par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s735/c/2/D"},"text":"Pub. L. 98–369, § 735(c)(2)(D)","children":[],"tail":", struck out subsec. (f) which related to imported recapped or retreaded United States tires."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/424/s514/a"},"text":"Pub. L. 97–424, § 514(a)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows: “There is hereby imposed upon the following articles, if wholly or in part of rubber, sold by the manufacturer, producer, or importer, a tax at the following rates:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) Tires of the type used on highway vehicles, 9.75 cents a pound.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) Other tires (other than laminated tires to which paragraph (5) applies), 4.875 cents a pound.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) Inner tubes, for tires, 10 cents a pound.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) Tread rubber, 5 cents a pound.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(5) Laminated tires (not of the type used on highway vehicles) which consist wholly of scrap rubber from used tire casings with an internal metal fastening agent, 1 cent a pound.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/424/s516/a/2"},"text":"Pub. L. 97–424, § 516(a)(2)","children":[],"tail":", substituted provision that, on and after "},{"tag":"date","attrib":{"date":"1988-10-01"},"text":"Oct. 1, 1988","children":[],"tail":", the taxes imposed by subsec. (a) shall not apply, for provision that, on and after "},{"tag":"date","attrib":{"date":"1984-10-01"},"text":"Oct. 1, 1984","children":[],"tail":", the tax imposed by subsec. (a)(1) would be 4.875 cents a pound, that by subsec. (a)(3) would be 9 cents a pound, and that subsec. (a)(4) would not apply."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/596/s4/a/1/A"},"text":"Pub. L. 96–596, § 4(a)(1)(A)","children":[],"tail":", substituted “9.75 cents” for “10 cents”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/596/s4/a/1/B"},"text":"Pub. L. 96–596, § 4(a)(1)(B)","children":[],"tail":", substituted “4.875 cents” for “5 cents”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/596/s4/a/1/C"},"text":"Pub. L. 96–596, § 4(a)(1)(C)","children":[],"tail":", substituted “4.875 cents” for “5 cents”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/222"},"text":"Pub. L. 96–222","children":[],"tail":" inserted references to an automobile bus chassis or body."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/598"},"text":"Pub. L. 96–598","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/599"},"text":"Pub. L. 95–599","children":[],"tail":" substituted “1984” for “1979”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/280"},"text":"Pub. L. 94–280","children":[],"tail":" substituted “1979” for “1977”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1971—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/178"},"text":"Pub. L. 92–178","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/605"},"text":"Pub. L. 91–605","children":[],"tail":" substituted “1977” for “1972”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsecs. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/523"},"text":"Pub. L. 89–523","children":[],"tail":" added subsec. (b) and redesignated former subsec. (b) and (c) as (c) and (d), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1961—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/61/s202/a"},"text":"Pub. L. 87–61, § 202(a)","children":[],"tail":", increased tax from 8 to 10 cents a pound."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/61/s202/c"},"text":"Pub. L. 87–61, § 202(c)","children":[],"tail":", increased tax from 9 to 10 cents a pound."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/61/s202/c"},"text":"Pub. L. 87–61, § 202(c)","children":[],"tail":", increased tax from 3 to 5 cents a pound."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/61/s202/d"},"text":"Pub. L. 87–61, § 202(d)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"1972-10-01"},"text":"October 1, 1972","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1972-07-01"},"text":"July 1, 1972","children":[],"tail":"”, added par. (2), and redesignated former par. (2) as (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1960—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/440/s1/a/1"},"text":"Pub. L. 86–440, § 1(a)(1)","children":[],"tail":", inserted “(other than laminated tires to which paragraph (5) applies)” after “other tires”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/440/s1/a/2"},"text":"Pub. L. 86–440, § 1(a)(2)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1956—Act ","children":[{"tag":"date","attrib":{"date":"1956-06-29"},"text":"June 29, 1956","children":[],"tail":", increased tax on tires of type used on highway vehicles from 5 cents a pound to 8 cents a pound, provided for a tax of 3 cents a pound on tread rubber, and required on and after "},{"tag":"date","attrib":{"date":"1972-07-01"},"text":"July 1, 1972","children":[],"tail":", a reduction in tax on tires of type used on highway vehicles from 8 cents a pound to 5 cents a pound, and elimination of tax on tread rubber."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45b231ae-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45b231af-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2021-10-01"},"text":"Oct. 1, 2021","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/s80102/f"},"text":"section 80102(f) of Pub. L. 117–58","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4041"},"text":"section 4041 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45b231b0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib"