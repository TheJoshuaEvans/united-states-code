:"Pub. L. 96–598, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-24"},"text":"Dec. 24, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3486"},"text":"94 Stat. 3486","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/424/tV"},"text":"Pub. L. 97–424, title V","children":[],"tail":", §§ 514(a), 516(a)(2), "},{"tag":"date","attrib":{"date":"1983-01-06"},"text":"Jan. 6, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2181"},"text":"96 Stat. 2181","children":[],"tail":", 2182; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tVII/s735/c/2"},"text":"Pub. L. 98–369, div. A, title VII, § 735(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/982"},"text":"98 Stat. 982","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/17/tV/s502/a/3"},"text":"Pub. L. 100–17, title V, § 502(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-04-02"},"text":"Apr. 2, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/256"},"text":"101 Stat. 256","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11211/c/2"},"text":"Pub. L. 101–508, title XI, § 11211(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-426"},"text":"104 Stat. 1388–426","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/240/tVIII/s8002/a/2"},"text":"Pub. L. 102–240, title VIII, § 8002(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-18"},"text":"Dec. 18, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2203"},"text":"105 Stat. 2203","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/178/tIX/s9002/a/1/E"},"text":