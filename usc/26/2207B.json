{"tag":"section","attrib":{"id":"id453d4f7f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2207B"},"text":null,"children":[{"tag":"num","attrib":{"value":"2207B"},"text":"§ 2207B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right of recovery where decedent retained interest","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id453d4f80-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2207B/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Estate tax","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id453d4f81-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2207B/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If any part of the gross estate on which tax has been paid consists of the value of property included in the gross estate by reason of section 2036 (relating to transfers with retained life estate), the decedent’s estate shall be entitled to recover from the person receiving the property the amount which bears the same ratio to the total tax under this chapter which has been paid as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id453d4f82-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2207B/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value of such property, bears to","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id453d4f83-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2207B/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taxable estate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id453d4f84-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2207B/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Decedent may otherwise direct","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply with respect to any property to the extent that the decedent in his will (or a revocable trust) specifically indicates an intent to waive any right of recovery under this subchapter with respect to such property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id453d4f85-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2207B/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" More than one recipient","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, if there is more than 1 person receiving the property, the right of recovery shall be against each such person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id453d4f86-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2207B/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties and interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of penalties and interest attributable to the additional taxes described in subsection (a), rules similar to the rules of subsections (a) and (b) shall apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id453d4f87-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2207B/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No right of recovery against charitable remainder trusts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No person shall be entitled to recover any amount by reason of this section from a trust to which section 664 applies (determined without regard to this section).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id453d4f88-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tIII/s3031/f/1"},"text":"Pub. L. 100–647, title III, § 3031(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3637"},"text":"102 Stat. 3637","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11601/b/1"},"text":"Pub. L. 101–508, title XI, § 11601(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-490"},"text":"104 Stat. 1388–490","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXIII/s1302/b"},"text":"Pub. L. 105–34, title XIII, § 1302(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1039"},"text":"111 Stat. 1039","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id453d4f89-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id453d4f8a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id453d4f8b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" amended heading and text of par. (2) generally. Prior to amendment, text read as follows: “Paragraph (1) shall not apply if the decedent otherwise directs in a provision of his will (or a revocable trust) specifically referring to this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s11601/b/1/A"},"text":"Pub. L. 101–508, § 11601(b)(1)(A)","children":[],"tail":", redesignated former subsec. (c) as (b) and struck out former subsec. (b) which read as follows: “If for any calendar year tax is paid under chapter 12 with respect to any person by reason of property treated as transferred by such person under section 2036(c)(4), such person shall be entitled to recover from the original transferee (as defined in section 2036(c)(4)(C)(ii)) the amount which bears the same ratio to the total tax for such year under chapter 12 as—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) the value of such property for purposes of chapter 12, bears to","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) the total amount of the taxable gifts for such year.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s11601/b/1"},"text":"Pub. L. 101–508, § 11601(b)(1)","children":[],"tail":", redesignated subsec. (d) as (c) and substituted “subsection (a)” for “subsections (a) and (b)” and “subsections (a) and (b)” for “subsections (a), (b), and (c)”. Former subsec. (c) redesignated (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s11601/b/1/A"},"text":"Pub. L. 101–508, § 11601(b)(1)(A)","children":[],"tail":", redesignated subsecs. (d) and (e) as (c) and (d), respectively. Former subsec. (d) redesignated (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id453d4f8c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id453d4f8d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" applicable with respect to estates of decedents dying after "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1302/c"},"text":"section 1302(c) of Pub. L. 105–34","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2207A"},"text":"section 2207A of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id453d4f8e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" applicable in the case of property transferred after "},{"tag":"date","attrib":{"date":"1987-12-17"},"text":"Dec. 17, 1987","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/s11601/c"},"text":"section 11601(c) of Pub. L. 101–508","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2036"},"text":"section 2036 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id453d4f8f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective as if included in provisions of Revenue Act of 1987, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX"},"text":"Pub. L. 100–203, title X","children":[],"tail":", except that if an amount is included in the gross estate of a decedent under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2036"},"text":"section 2036 of this title","children":[],"tail":" other than solely by reason of "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2036/c"},"text":"section 2036(c) of this title","children":[],"tail":", section applicable to such amount only with respect to property transferred after "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", see section 3031(h)(1), (3) of "},{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":", set out as an Effective Date of 1988 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2036"},"text":"section 2036 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
