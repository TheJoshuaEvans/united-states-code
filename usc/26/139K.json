{"tag":"section","attrib":{"id":"id41810af6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139K"},"text":null,"children":[{"tag":"num","attrib":{"value":"139K"},"text":"§ 139K.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scholarships for qualified elementary or secondary education expenses of eligible students","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id41810af7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139K/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an individual, gross income shall not include any amounts provided to such individual or any dependent of such individual pursuant to a scholarship for qualified elementary or secondary education expenses of an eligible student which is provided by a scholarship granting organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id41810af8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139K/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the terms “qualified elementary or secondary education expense”, “eligible student”, and “scholarship granting organization” have the same meaning given such terms under section 25F(c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id41810af9-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70411/b/1"},"text":"Pub. L. 119–21, title VII, § 70411(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/217"},"text":"139 Stat. 217","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id41810afa-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id41810afb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Delayed Effective Date of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For delayed effective date of section, see Effective Date note below.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id41810afc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id41810afd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to amounts received after ","children":[{"tag":"date","attrib":{"date":"2026-12-31"},"text":"Dec. 31, 2026","children":[],"tail":", in taxable years ending after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70411/c/2"},"text":"section 70411(c)(2) of Pub. L. 119–21","children":[],"tail":", set out in an Effective Date of 2025 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s25"},"text":"section 25 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
