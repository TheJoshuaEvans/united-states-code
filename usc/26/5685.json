{"tag":"section","attrib":{"id":"id46439c88-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5685"},"text":null,"children":[{"tag":"num","attrib":{"value":"5685"},"text":"§ 5685.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty and forfeiture relating to possession of devices for emitting gas, smoke, etc., explosives and firearms, when violating liquor laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46439c89-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5685/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for possession of devices for emitting gas, smoke, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whoever, when violating any law of the United States, or of any possession of the United States, or of the District of Columbia, in regard to the manufacture, taxation, or transportation of or traffic in distilled spirits, wines, or beer, or when aiding in any such violation, has in his possession or in his control any device capable of causing emission of gas, smoke, or fumes, and which may be used for the purpose of hindering, delaying, or preventing pursuit or capture, any explosive, or any firearm (as defined in section 5845), except a machine gun, or a shotgun having a barrel or barrels less than 18 inches in length, or a rifle having a barrel or barrels less than 16 inches in length, shall be fined not more than $5,000, or imprisoned not more than 10 years, or both, and all persons engaged in any such violation or in aiding in any such violation shall be held to be in possession or control of such device, firearm, or explosive.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46439c8a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5685/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for possession of machine gun, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whoever, when violating any such law, has in his possession or in his control a machine gun, or any shotgun having a barrel or barrels less than 18 inches in length, or a rifle having a barrel or barrels less than 16 inches in length, shall be imprisoned not more than 20 years; and all persons engaged in any such violation or in aiding in any such violation shall be held to be in possession and control of such machine gun, shotgun, or rifle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46439c8b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5685/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forfeiture of firearms, devices, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every such firearm or device for emitting gas, smoke, or fumes, and every such explosive, machine gun, shotgun, or rifle, in the possession or control of any person when violating any such law, shall be seized and shall be forfeited and disposed of in the manner provided by section 5872.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46439c8c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5685/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of machine gun","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in this section the term “machine gun” means a machine gun as defined in section 5845(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46439c8d-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1411"},"text":"72 Stat. 1411","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/86/478/s4"},"text":"Pub. L. 86–478, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-06-01"},"text":"June 1, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/150"},"text":"74 Stat. 150","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1905/a/23"},"text":"Pub. L. 94–455, title XIX, § 1905(a)(23)","children":[],"tail":", (c)(6), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1821"},"text":"90 Stat. 1821","children":[],"tail":", 1823.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46439c8e-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46439c8f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id46439c90-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5685, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/699"},"text":"68A Stat. 699","children":[],"tail":", consisted of provisions similar to those comprising this section, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46439c91-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1905/a/23/A"},"text":"Pub. L. 94–455, § 1905(a)(23)(A)","children":[],"tail":", (c)(6), struck out “Territory or” after “United States, or of any” and substituted “section 5845” for “section 5848”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1905/a/23/B"},"text":"Pub. L. 94–455, § 1905(a)(23)(B)","children":[],"tail":", substituted “section 5872” for “section 5862”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1905/a/23/C"},"text":"Pub. L. 94–455, § 1905(a)(23)(C)","children":[],"tail":", substituted “means a machinegun as defined in section 5845(b)” for “means any weapon which shoots, or is designed to shoot, automatically or semiautomatically, more than one shot, without manual reloading, by a single function of the trigger”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1960—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/478"},"text":"Pub. L. 86–478","children":[],"tail":" substituted “shotgun having a barrel or barrels less than 18 inches in length, or a rifle having a barrel or barrels less than 16 inches in length” for “shotgun or rifle having a barrel or barrels less than 18 inches in length”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46439c92-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46439c93-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" effective on first day of first month which begins more than 90 days after "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1905/d"},"text":"section 1905(d) of Pub. L. 94–455","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5005"},"text":"section 5005 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46439c94-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1960 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/478"},"text":"Pub. L. 86–478","children":[],"tail":" effective on first day of first month which begins more than 10 days after "},{"tag":"date","attrib":{"date":"1960-06-01"},"text":"June 1, 1960","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/86/478/s5"},"text":"section 5 of Pub. L. 86–478","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-06-01"},"text":"June 1, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/150"},"text":"74 Stat. 150","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
