{"tag":"section","attrib":{"id":"id4632fb10-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5273"},"text":null,"children":[{"tag":"num","attrib":{"value":"5273"},"text":"§ 5273.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale, use, and recovery of denatured distilled spirits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4632fb11-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5273/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of specially denatured distilled spirits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person using specially denatured distilled spirits in the manufacture of articles shall file such formulas and statements of process, submit such samples, and comply with such other requirements, as the Secretary shall by regulations prescribe, and no person shall use specially denatured distilled spirits in the manufacture or production of any article until approval of the article, formula, and process has been obtained from the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4632fb12-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5273/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Internal medicinal preparations and flavoring extracts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4632fb13-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5273/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manufacture","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No person shall use denatured distilled spirits in the manufacture of medicinal preparations or flavoring extracts for internal human use where any of the spirits remains in the finished product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4632fb14-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5273/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No person shall sell or offer for sale for internal human use any medicinal preparations or flavoring extracts manufactured from denatured distilled spirits where any of the spirits remains in the finished product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4632fb15-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5273/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery of spirits for reuse in manufacturing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Manufacturers employing processes in which denatured distilled spirits withdrawn under section 5214(a)(1) are expressed, evaporated, or otherwise removed, from the articles manufactured shall be permitted to recover such distilled spirits and to have such distilled spirits restored to a condition suitable solely for reuse in manufacturing processes under such regulations as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4632fb16-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5273/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited withdrawal or sale","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No person shall withdraw or sell denatured distilled spirits, or sell any article containing denatured distilled spirits for beverage purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4632fb17-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5273/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross references","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4632fb18-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5273/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For penalty and forfeiture for unlawful use or concealment of denatured distilled spirits, see section 5607.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4632fb19-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5273/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For applicability of all provisions of law relating to distilled spirits that are not denatured, including those requiring payment of tax, to denatured distilled spirits or articles produced, withdrawn, sold, transported, or used in violation of law or regulations, see section 5001(a)(5).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4632fb1a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5273/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For definition of “articles”, see section 5002(a)(14).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4632fb1b-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1372"},"text":"72 Stat. 1372","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/tVIII/s807/a/39"},"text":"Pub. L. 96–39, title VIII, § 807(a)(39)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/286"},"text":"93 Stat. 286","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/244"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(244)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1195"},"text":"132 Stat. 1195","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4632fb1c-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4632fb1d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4632fb1e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":