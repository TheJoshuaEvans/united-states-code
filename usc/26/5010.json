{"tag":"section","attrib":{"id":"id461d75eb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5010"},"text":null,"children":[{"tag":"num","attrib":{"value":"5010"},"text":"§ 5010.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit for wine content and for flavors content","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id461d75ec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5010/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowance of credit","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id461d75ed-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5010/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wine content","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On each proof gallon of the wine content of distilled spirits, there shall be allowed a credit against the tax imposed by section 5001 (or 7652) equal to the excess of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id461d75ee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5010/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $13.50, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id461d75ef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5010/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate of tax which would be imposed on the wine under section 5041(b) but for its removal to bonded premises.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id461d75f0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5010/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Flavors content","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On each proof gallon of the flavors content of distilled spirits, there shall be allowed a credit against the tax imposed by section 5001 (or 7652) equal to $13.50.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id461d75f1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5010/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fractional part of proof gallon","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any fractional part of a proof gallon of the wine content, or of the flavors content, of distilled spirits, a proportionate credit shall be allowed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id461d75f2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5010/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for determining and allowing credit","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id461d75f3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5010/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The credit allowable by subsection (a)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id461d75f4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5010/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be determined at the same time the tax is determined under section 5006 (or 7652) on the distilled spirits containing the wine or flavors, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id461d75f5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5010/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be allowable at the time the tax imposed by section 5001 (or 7652) on such distilled spirits is payable as if the credit allowable by this section constituted a reduction in the rate of tax.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id461d75f6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5010/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of content in the case of imports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the wine content, and the flavors content, of imported distilled spirits shall be established by such chemical analysis, certification, or other methods as may be set forth in regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id461d75f7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5010/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id461d75f8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5010/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wine content","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id461d75f9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5010/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “wine content” means alcohol derived from wine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id461d75fa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5010/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wine","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “wine”—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id461d75fb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5010/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means wine on which tax would be imposed by paragraph (1), (2), or (3) of section 5041(b) but for its removal to bonded premises, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id461d75fc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5010/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include any substance which has been subject to distillation at a distilled spirits plant after receipt in bond.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id461d75fd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5010/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Flavors content","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id461d75fe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5010/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), the term “flavors content” means alcohol derived from flavors of a type for which drawback is allowable under section 5114.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id461d75ff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5010/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “flavors content” does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id461d7600-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5010/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alcohol derived from flavors made at a distilled spirits plant,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id461d7601-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5010/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alcohol derived from flavors distilled at a distilled spirits plant, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id461d7602-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5010/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any distilled spirits product, alcohol derived from flavors to the extent such alcohol exceeds (on a proof gallon basis) 2½ percent of the finished product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id461d7603-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/598/s6/a"},"text":"Pub. L. 96–598, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-24"},"text":"Dec. 24, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3488"},"text":"94 Stat. 3488","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s27/a/2"},"text":"Pub. L. 98–369, div. A, title I, § 27(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/507"},"text":"98 Stat. 507","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tV/s5063/a"},"text":"Pub. L. 100–647, title V, § 5063(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3681"},"text":"102 Stat. 3681","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11201/a/2"},"text":"Pub. L. 101–508, title XI, § 11201(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-415"},"text":"104 Stat. 1388–415","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tXI/s11125/b/14"},"text":"Pub. L. 109–59, title XI, § 11125(b)(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1956"},"text":"119 Stat. 1956","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id461d7604-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id461d7605-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id461d7606-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5010, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/603"},"text":"68A Stat. 603","children":[],"tail":", related to miscellaneous stamp provisions, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id461d7607-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":" substituted “section 5114” for “section 5134”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" substituted “$13.50” for “$12.50”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" added cl. (ii) and redesignated former cl. (ii) as (iii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" substituted “$12.50” for “$10.50”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id461d7608-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id461d7609-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-07-01"},"text":"July 1, 2008","children":[],"tail":", but inapplicable to taxes imposed for periods before such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/s11125/c"},"text":"section 11125(c) of Pub. L. 109–59","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5002"},"text":"section 5002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id461d760a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1991-01-01"},"text":"Jan. 1, 1991","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/s11201/d"},"text":"section 11201(d) of Pub. L. 101–508","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5001"},"text":"section 5001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id461d760b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tV/s5063/b"},"text":"Pub. L. 100–647, title V, § 5063(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3681"},"text":"102 Stat. 3681","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/647/tV/s5063/b"},"text":"“The amendments made by this section [amending this section] shall apply with respect to distilled spirits withdrawn from bond after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id461d760c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1985-10-01"},"text":"Oct. 1, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s27/d/1"},"text":"section 27(d)(1) of Pub. L. 98–369","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5001"},"text":"section 5001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id461d760d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/598/s6/c"},"text":"Pub. L. 96–598, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-24"},"text":"Dec. 24, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3489"},"text":"94 Stat. 3489","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/598/s6/c"},"text":"“The amendments made by subsections (a) and (b) [enacting this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1980-01-01"},"text":"January 1, 1980","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
