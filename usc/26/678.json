{"tag":"section","attrib":{"id":"id43f69f0a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s678"},"text":null,"children":[{"tag":"num","attrib":{"value":"678"},"text":"§ 678.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person other than grantor treated as substantial owner","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id43f69f0b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s678/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person other than the grantor shall be treated as the owner of any portion of a trust with respect to which:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43f69f0c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s678/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such person has a power exercisable solely by himself to vest the corpus or the income therefrom in himself, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43f69f0d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s678/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such person has previously partially released or otherwise modified such a power and after the release or modification retains such control as would, within the principles of sections 671 to 677, inclusive, subject a grantor of a trust to treatment as the owner thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43f69f0e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s678/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception where grantor is taxable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not apply with respect to a power over income, as originally granted or thereafter modified, if the grantor of the trust or a transferor (to whom section 679 applies) is otherwise treated as the owner under the provisions of this subpart other than this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43f69f0f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s678/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obligations of support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not apply to a power which enables such person, in the capacity of trustee or cotrustee, merely to apply the income of the trust to the support or maintenance of a person whom the holder of the power is obligated to support or maintain except to the extent that such income is so applied. In cases where the amounts so applied or distributed are paid out of corpus or out of other than income of the taxable year, such amounts shall be considered to be an amount paid or credited within the meaning of paragraph (2) of section 661(a) and shall be taxed to the holder of the power under section 662.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43f69f10-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s678/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of renunciation or disclaimer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not apply with respect to a power which has been renounced or disclaimed within a reasonable time after the holder of the power first became aware of its existence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43f69f11-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s678/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For provision under which beneficiary of trust is treated as owner of the portion of the trust which consists of stock in an S corporation, see section 1361(d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id43f69f12-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/231"},"text":"68A Stat. 231","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tX/s1013/b"},"text":"Pub. L. 94–455, title X, § 1013(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1615"},"text":"90 Stat. 1615","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/448/tI/s102/i/2"},"text":"Pub. L. 97–448, title I, § 102(i)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2373"},"text":"96 Stat. 2373","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tIII/s319/8/A"},"text":"Pub. L. 106–554, § 1(a)(7) [title III, § 319(8)(A)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–646.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id43f69f13-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id43f69f14-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id43f69f15-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554"},"text":"Pub. L. 106–554","children":[],"tail":" substituted “an S corporation” for “an electing small business corporation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/448"},"text":"Pub. L. 97–448","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" substituted “if the grantor of the trust or a transferor (to whom section 679 applies) is otherwise treated as the owner under the provisions of this subpart other than this section” for “if the grantor of the trust is otherwise treated as the owner under sections 671 to 677, inclusive”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id43f69f16-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43f69f17-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1983 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/448"},"text":"Pub. L. 97–448","children":[],"tail":" effective, except as otherwise provided, as if it had been included in the provision of the Economic Recovery Tax Act of 1981, "},{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/97/448/s109"},"text":"section 109 of Pub. L. 97–448","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43f69f18-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1013/f/1"},"text":"section 1013(f)(1) of Pub. L. 94–455","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s679"},"text":"section 679 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
