{"tag":"section","attrib":{"id":"id467f4510-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Q"},"text":null,"children":[{"tag":"num","attrib":{"value":"6050Q"},"text":"§ 6050Q.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain long-term care benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id467f4511-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Q/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of reporting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person who pays long-term care benefits shall make a return, according to the forms or regulations prescribed by the Secretary, setting forth—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467f4512-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Q/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amount of such benefits paid by such person to any individual during any calendar year,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467f4513-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Q/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether or not such benefits are paid in whole or in part on a per diem or other periodic basis without regard to the expenses incurred during the period to which the payments relate,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467f4514-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Q/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address, and TIN of such individual, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467f4515-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Q/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address, and TIN of the chronically ill or terminally ill individual on account of whose condition such benefits are paid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467f4516-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Q/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statements to be furnished to persons with respect to whom information is required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Every person required to make a return under subsection (a) shall furnish to each individual whose name is required to be set forth in such return a written statement showing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467f4517-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Q/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address, and phone number of the information contact of the person making the payments, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467f4518-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Q/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amount of long-term care benefits paid to the individual which are required to be shown on such return.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The written statement required under the preceding sentence shall be furnished to the individual on or before January 31 of the year following the calendar year for which the return under subsection (a) was required to be made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467f4519-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Q/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Long-term care benefits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “long-term care benefit” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467f451a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Q/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any payment under a product which is advertised, marketed, or offered as long-term care insurance, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467f451b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050Q/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any payment which is excludable from gross income by reason of section 101(g).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id467f451c-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191/tIII/s323/a"},"text":"Pub. L. 104–191, title III, § 323(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2062"},"text":"110 Stat. 2062","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXVI/s1602/d/1"},"text":"Pub. L. 105–34, title XVI, § 1602(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1094"},"text":"111 Stat. 1094","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id467f451d-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id467f451e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id467f451f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" inserted “, address, and phone number of the information contact” after “name”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id467f4520-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id467f4521-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" effective as if included in the provisions of the Health Insurance Portability and Accountability Act of 1996, "},{"tag":"ref","attrib":{"href":"/us/pl/104/191"},"text":"Pub. L. 104–191","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1602/i"},"text":"section 1602(i) of Pub. L. 105–34","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s26"},"text":"section 26 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id467f4522-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191/tIII/s323/d"},"text":"Pub. L. 104–191, title III, § 323(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2063"},"text":"110 Stat. 2063","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/191/tIII/s323/d"},"text":"“The amendments made by this section [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6724"},"text":"section 6724 of this title","children":[],"tail":"] shall apply to benefits paid after "},{"tag":"date","attrib":{"date":"1996-12-31"},"text":"December 31, 1996","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
