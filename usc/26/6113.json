{"tag":"section","attrib":{"id":"id46ac96f9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6113"},"text":null,"children":[{"tag":"num","attrib":{"value":"6113"},"text":"§ 6113.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure of nondeductibility of contributions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46ac96fa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6113/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each fundraising solicitation by (or on behalf of) an organization to which this section applies shall contain an express statement (in a conspicuous and easily recognizable format) that contributions or gifts to such organization are not deductible as charitable contributions for Federal income tax purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46ac96fb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6113/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organizations to which section applies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46ac96fc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6113/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this subsection, this section shall apply to any organization which is not described in section 170(c) and which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46ac96fd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6113/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is described in subsection (c) (other than paragraph (1) thereof) or (d) of section 501 and exempt from taxation under section 501(a),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46ac96fe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6113/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a political organization (as defined in section 527(e)), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46ac96ff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6113/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was an organization described in subparagraph (A) or (B) at any time during the 5-year period ending on the date of the fundraising solicitation or is a successor to an organization so described at any time during such 5-year period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46ac9700-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6113/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for small organizations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46ac9701-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6113/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual gross receipts do not exceed $100,000","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to any organization the gross receipts of which in each taxable year are normally not more than $100,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46ac9702-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6113/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiple organization rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may treat any group of 2 or more organizations as 1 organization for purposes of subparagraph (A) where necessary or appropriate to prevent the avoidance of this section through the use of multiple organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46ac9703-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6113/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for certain fraternal organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1), an organization described in section 170(c)(4) shall be treated as described in section 170(c) only with respect to solicitations for contributions or gifts which are to be used exclusively for purposes referred to in section 170(c)(4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46ac9704-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6113/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fundraising solicitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46ac9705-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6113/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (2), the term “fundraising solicitation” means any solicitation of contributions or gifts which is made—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46ac9706-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6113/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in written or printed form,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46ac9707-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6113/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by television or radio, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46ac9708-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6113/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by telephone.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46ac9709-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6113/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for certain letters or calls","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “fundraising solicitation” shall not include any letter or telephone call if such letter or call is not part of a coordinated fundraising campaign soliciting more than 10 persons during the calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46ac970a-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX/s10701/a"},"text":"Pub. L. 100–203, title X, § 10701(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-457"},"text":"101 Stat. 1330–457","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46ac970b-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46ac970c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id46ac970d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6113 was renumbered 6116 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46ac970e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id46ac970f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX/s10701/d"},"text":"Pub. L. 100–203, title X, § 10701(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-459"},"text":"101 Stat. 1330–459","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/203/tX/s10701/d"},"text":"“The amendments made by this section [enacting this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6710"},"text":"section 6710 of this title","children":[],"tail":" and renumbering former section 6113 as "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6114"},"text":"section 6114 of this title","children":[],"tail":"] shall apply to solicitations after "},{"tag":"date","attrib":{"date":"1988-01-31"},"text":"January 31, 1988","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
