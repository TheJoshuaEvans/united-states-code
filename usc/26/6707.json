{"tag":"section","attrib":{"id":"id47321b29-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6707"},"text":null,"children":[{"tag":"num","attrib":{"value":"6707"},"text":"§ 6707.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to furnish information regarding reportable transactions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47321b2a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6707/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a person who is required to file a return under section 6111(a) with respect to any reportable transaction—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47321b2b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6707/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fails to file such return on or before the date prescribed therefor, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47321b2c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6707/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" files false or incomplete information with the Secretary with respect to such transaction,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"such person shall pay a penalty with respect to such return in the amount determined under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47321b2d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6707/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of penalty","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47321b2e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6707/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), the penalty imposed under subsection (a) with respect to any failure shall be $50,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47321b2f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6707/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Listed transactions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The penalty imposed under subsection (a) with respect to any listed transaction shall be an amount equal to the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47321b30-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6707/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $200,000, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47321b31-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6707/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent of the gross income derived by such person with respect to aid, assistance, or advice which is provided with respect to the listed transaction before the date the return is filed under section 6111.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Subparagraph (B) shall be applied by substituting “75 percent” for “50 percent” in the case of an intentional failure or act described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47321b32-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6707/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rescission authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of section 6707A(d) (relating to authority of Commissioner to rescind penalty) shall apply to any penalty imposed under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47321b33-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6707/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reportable and listed transactions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the terms “reportable transaction” and “listed transaction” have the respective meanings given to such terms by section 6707A(c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47321b34-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s141/b"},"text":"Pub. L. 98–369, div. A, title I, § 141(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/680"},"text":"98 Stat. 680","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXV"},"text":"Pub. L. 99–514, title XV","children":[],"tail":", §§ 1532(a), 1533(a), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2750"},"text":"100 Stat. 2750","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tX/s1028/b"},"text":"Pub. L. 105–34, title X, § 1028(b)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/927"},"text":"111 Stat. 927","children":[],"tail":", 928; "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s816/a"},"text":"Pub. L. 108–357, title VIII, § 816(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1583"},"text":"118 Stat. 1583","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47321b35-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47321b36-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id47321b37-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":" amended section catchline and text generally, substituting provisions relating to penalty for failure to furnish information regarding reportable transactions for provisions relating to penalty for failure to furnish information regarding tax shelters."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1028/d/2"},"text":"Pub. L. 105–34, § 1028(d)(2)","children":[],"tail":", which directed the substitution of “paragraph (2) or (3), as the case may be” for “paragraph (2)” in subpar. (A) of par. (1), was executed by making the substitution in the concluding provisions of par. (1) to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1028/d/1"},"text":"Pub. L. 105–34, § 1028(d)(1)","children":[],"tail":", substituted “Except as provided in paragraph (3), the penalty” for “The penalty”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1028/b"},"text":"Pub. L. 105–34, § 1028(b)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1532/a"},"text":"Pub. L. 99–514, § 1532(a)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “The penalty imposed under paragraph (1) with respect to any tax shelter shall be an amount equal to the greater of—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) $500, or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the lesser of (i) 1 percent of the aggregate amount invested in such tax shelter, or (ii) $10,000.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The $10,000 limitation in subparagraph (B) shall not apply where there is an intentional disregard of the requirements of section 6111(a).”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1533/a"},"text":"Pub. L. 99–514, § 1533(a)","children":[],"tail":", substituted “$250” for “$50”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47321b38-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47321b39-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s816/c"},"text":"Pub. L. 108–357, title VIII, § 816(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1584"},"text":"118 Stat. 1584","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/357/tVIII/s816/c"},"text":"“The amendments made by this section [amending this section] shall apply to returns the due date for which is after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47321b3a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" applicable to any tax shelter, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6111/d"},"text":"section 6111(d) of this title","children":[],"tail":", interests in which are offered to potential participants after Secretary of the Treasury prescribes guidance with respect to meeting requirements added by amendments made by "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1028"},"text":"Pub. L. 105–34, § 1028","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1028/e"},"text":"section 1028(e) of Pub. L. 105–34","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6111"},"text":"section 6111 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47321b3b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXV/s1532/b"},"text":"Pub. L. 99–514, title XV, § 1532(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2750"},"text":"100 Stat. 2750","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/tXV/s1532/b"},"text":"“The amendment made by this section [amending this section] shall apply to failures with respect to tax shelters interests in which are first offered for sale after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXV/s1533/b"},"text":"Pub. L. 99–514, title XV, § 1533(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2750"},"text":"100 Stat. 2750","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/tXV/s1533/b"},"text":"“The amendment made by this section [amending this section] shall apply to returns filed after the date of the enactment of this Act [Oct 22, 1986].”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id47321b3c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to tax shelters (within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6111"},"text":"section 6111 of this title","children":[],"tail":"), any interest in which is first sold to any investor after "},{"tag":"date","attrib":{"date":"1984-08-31"},"text":"Aug. 31, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s141/d"},"text":"section 141(d) of Pub. L. 98–369","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6111"},"text":"section 6111 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
