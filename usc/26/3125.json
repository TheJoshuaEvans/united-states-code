ut specifying where the substitution was to be made, was executed by making the substitution in subsecs. (a) to (d) to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" substituted “applicable contribution base limitation” for “contribution and benefit base limitation” in subsecs. (a) to (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272"},"text":"Pub. L. 99–272","children":[],"tail":" inserted “States” in section catchline, added subsec. (a), and redesignated former subsecs. (a) to (c) as (b) to (d), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" substituted “Mayor of the District of Columbia or such agents as he may designate” for “Commissioners of the District of Columbia or such agents as they may designate”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/233/s5/b/4"},"text":"Pub. L. 93–233, § 5(b)(4)","children":[],"tail":", effective with respect to remuneration paid after 1973, substituted “$13,200” for “$12,600” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/233/s5/d"},"text":"Pub. L. 93–233, § 5(d)","children":[],"tail":", applicable only with respect to remuneration paid after, and taxable years beginning after, 1973 (as provided in "},{"tag":"ref","attrib":{"href":"/us/pl/93/233/s5/e"},"text":"section 5(e) of Pub. L. 93–233","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s409"},"text":"section 409 of Title 42","children":[],"tail":"), amended "},{"tag":"ref","attrib":{"href":"/us/pl/92/336/s203/b/4/C"},"text":"section 203(b)(4)(C) of Pub. L. 92–336","children":[],"tail":" (set out as 1973 Amendment note hereunder) substituting “$13,200” for “$12,600”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/66/s203/b/4"},"text":"Pub. L. 93–66, § 203(b)(4)","children":[],"tail":", effective with respect to remuneration paid after 1973, substituted “$12,600” for “$12,000” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/66/s203/d"},"text":"Pub. L. 93–66, § 203(d)","children":[],"tail":", applicable only with respect to remuneration paid after, and taxable years beginning after, 1973 (as provided in "},{"tag":"ref","attrib":{"href":"/us/pl/93/66/s203/e"},"text":"section 203(e) of Pub. L. 93–66","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s409"},"text":"section 409 of Title 42","children":[],"tail":"), amended "},{"tag":"ref","attrib":{"href":"/us/pl/92/336/s203/b/4/C"},"text":"section 203(b)(4)(C) of Pub. L. 92–336","children":[],"tail":" (set out as 1972 Amendment note hereunder) substituting “$12,600” for “$12,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/336/s203/b/4/A"},"text":"Pub. L. 92–336, § 203(b)(4)(A)","children":[],"tail":", substituted “$10,800” for “$9,000” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/92/336/s203/b/4/B"},"text":"Pub. L. 92–336, § 203(b)(4)(B)","children":[],"tail":", effective with respect to remuneration paid after 1973, substituted “$12,000” for “$10,800” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/92/336/s203/b/4/C"},"text":"Pub. L. 92–336, § 203(b)(4)(C)","children":[],"tail":", effective with respect to remuneration paid after 1974, substituted “contribution and benef