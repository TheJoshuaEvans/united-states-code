{"tag":"section","attrib":{"id":"id45682fea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3125"},"text":null,"children":[{"tag":"num","attrib":{"value":"3125"},"text":"§ 3125.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Returns in the case of governmental employees in States, Guam, American Samoa, and the District of Columbia","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45682feb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3125/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this section, in the case of the taxes imposed by sections 3101(b) and 3111(b) with respect to service performed in the employ of a State or any political subdivision thereof (or any instrumentality of any one or more of the foregoing which is wholly owned thereby), the return and payment of such taxes may be made by the head of the agency or instrumentality having the control of such service, or by such agents as such head may designate. The person making such return may, for convenience of administration, make payments of the tax imposed under section 3111 with respect to the service of such individuals without regard to the contribution and benefit base limitation in section 3121(a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45682fec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3125/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guam","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The return and payment of the taxes imposed by this chapter on the income of individuals who are officers or employees of the Government of Guam or any political subdivision thereof or of any instrumentality of any one or more of the foregoing which is wholly owned thereby, and those imposed on such Government or political subdivision or instrumentality with respect to having such individuals in its employ, may be made by the Governor of Guam or by such agents as he may designate. The person making such return may, for convenience of administration, make payments of the tax imposed under section 3111 with respect to the service of such individuals without regard to the contribution and benefit base limitation in section 3121(a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45682fed-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3125/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" American Samoa","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The return and payment of the taxes imposed by this chapter on the income of individuals who are officers or employees of the Government of American Samoa or any political subdivision thereof or of any instrumentality of any one or more of the foregoing which is wholly owned thereby, and those imposed on such Government or political subdivision or instrumentality with respect to having such individuals in its employ, may be made by the Governor of American Samoa or by such agents as he may designate. The person making such return may, for convenience of administration, make payments of the tax imposed under section 3111 with respect to the service of such individuals without regard to the contribution and benefit base limitation in section 3121(a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id456aa0ee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3125/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" District of Columbia","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of the taxes imposed by this chapter with respect to service performed in the employ of the District of Columbia or in the employ of any instrumentality which is wholly owned thereby, the return and payment of the taxes may be made by the Mayor of the District of Columbia or such agents as he may designate. The person making such return may, for convenience of administration, make payments of the tax imposed by section 3111 with respect to such service without regard to the contribution and benefit base limitation in section 3121(a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id456aa0ef-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/778/tI/s103/q/1"},"text":"Pub. L. 86–778, title I, § 103(q)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-13"},"text":"Sept. 13, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/939"},"text":"74 Stat. 939","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/89/97/tIII"},"text":"Pub. L. 89–97, title III","children":[],"tail":", §§ 317(c)(1), (2), 320(b)(4), "},{"tag":"date","attrib":{"date":"1965-07-30"},"text":"July 30, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/389"},"text":"79 Stat. 389","children":[],"tail":", 393; "},{"tag":"ref","attrib":{"href":"/us/pl/90/248/tI/s108/b/4"},"text":"Pub. L. 90–248, title I, § 108(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-01-02"},"text":"Jan. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/835"},"text":"81 Stat. 835","children":[],"tail":";