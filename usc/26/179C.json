{"tag":"section","attrib":{"id":"id42102b8a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179C"},"text":null,"children":[{"tag":"num","attrib":{"value":"179C"},"text":"§ 179C.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election to expense certain refineries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id42102b8b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179C/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment as expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A taxpayer may elect to treat 50 percent of the cost of any qualified refinery property as an expense which is not chargeable to capital account. Any cost so treated shall be allowed as a deduction for the taxable year in which the qualified refinery property is placed in service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42102b8c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179C/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42102b8d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179C/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An election under this section for any taxable year shall be made on the taxpayer’s return of the tax imposed by this chapter for the taxable year. Such election shall be made in such manner as the Secretary may by regulations prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42102b8e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179C/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election irrevocable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any election made under this section may not be revoked except with the consent of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42102b8f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179C/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified refinery property","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42102b90-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179C/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified refinery property” means any portion of a qualified refinery—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42102b91-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179C/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the original use of which commences with the taxpayer,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42102b92-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179C/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is placed in service by the taxpayer after the date of the enactment of this section and before ","children":[{"tag":"date","attrib":{"date":"2014-01-01"},"text":"January 1, 2014","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42102b93-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179C/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case any portion of a qualified refinery (other than a qualified refinery which is separate from any existing refinery), which meets the requirements of subsection (e),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42102b94-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179C/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which meets all applicable environmental laws in effect on the date such portion was placed in service,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42102b95-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179C/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no written binding contract for the construction of which was in effect on or before ","children":[{"tag":"date","attrib":{"date":"2005-06-14"},"text":"June 14, 2005","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42102b96-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179C/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id42102b97-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179C/c/1/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the construction of which is subject to a written binding construction contract entered into before ","children":[{"tag":"date","attrib":{"date":"2010-01-01"},"text":"January 1, 2010","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id42102b98-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179C/c/1/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is placed in service before ","children":[{"tag":"date","attrib":{"date":"2010-01-01"},"text":"January 1, 2010","children":[],"tail":", or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id42102b99-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179C/c/1/F/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of self-constructed property, the construction of which began after ","children":[{"tag":"date","attrib":{"date":"2005-06-14"},"text":"June 14, 2005","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"2010-01-01"},"text":"January 1, 2010","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42102b9a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179C/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for sale-leasebacks","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1)(A), if property is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42102b9b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179C/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" originally placed in service after the date of the enactment of this section by a person, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42102b9c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179C/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sold and leased back by such person within 3 months after the date such property was originally placed in service,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"such property shall be treated as originally placed in service not earlier than the date on which such property is used under the leaseback referred to in subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42102b9d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179C/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of waiver under Clean Air Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A waiver under the Clean Air Act shall not be taken into account in determining whether the requirements of paragraph (1)(D) are met.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42102b9e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179C/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified refinery","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “qualified refinery” means any refinery located in the United States which is designed to serve the primary purpose of processing liquid fuel from crude oil or qualified fuels (as defined in section 45K(c)), or directly from shale or tar sands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42102b9f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179C/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Production capacity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirements of this subsection are met if the portion of the qualified refinery—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42102ba0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179C/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enables the existing qualified refinery to increase total volume output (determined without regard to asphalt or lube oil) by 5 percent or more on an average daily basis, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42102ba1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179C/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enables the existing qualified refinery to process shale, tar sands, or qualified fuels (as defined in section 45K(c)) at a rate which is equal to or greater than 25 percent of the total throughput of such qualified refinery on an average daily basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42102ba2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179C/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ineligible refinery property","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No deduction shall be allowed under subsection (a) for any qualified refinery property—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42102ba3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179C/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the primary purpose of which is for use as a topping plant, asphalt plant, lube oil facility, crude or product terminal, or blending facility, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42102ba4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179C/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is built solely to comply with consent decrees or projects mandated by Federal, State, or local governments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42102ba5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179C/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election to allocate deduction to cooperative owner","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42102ba6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179C/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42102ba7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179C/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a taxpayer to which subsection (a) applies is an organization to which part I of subchapter T applies, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42102ba8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179C/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more persons directly holding an ownership interest in the taxpayer are organizations to which part I of subchapter T apply,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the taxpayer may elect to allocate all or a portion of the deduction allowable under subsection (a) to such persons. Such allocation shall be equal to the person’s ratable share of the total amount allocated, determined on the basis of the person’s ownership interest in the taxpayer. The taxable income of the taxpayer shall not be reduced under section 1382 by reason of any amount to which the preceding sentence applies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42102ba9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179C/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form and effect of election","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An election under paragraph (1) for any taxable year shall be made on a timely filed return for such year. Such election, once made, shall be irrevocable for such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42102baa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179C/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Written notice to owners","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any portion of the deduction available under subsection (a) is allocated to owners under paragraph (1), the cooperative shall provide any owner receiving an allocation written notice of the amount of the allocation. Such notice shall be provided before the date on which the return described in paragraph (2) is due.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42102bab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s179C/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No deduction shall be allowed under subsection (a) to any taxpayer for any taxable year unless such taxpayer files with the Secretary a report containing such information with respect to the operation of the refineries of the taxpayer as the Secretary shall require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id42102bac-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXIII/s1323/a"},"text":"Pub. L. 109–58, title XIII, § 1323(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1013"},"text":"119 Stat. 1013","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/343/dB/tII/s209/a"},"text":"Pub. L. 110–343, div. B, title II, § 209(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3840"},"text":"122 Stat. 3840","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id42102bad-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id42102bae-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id42102baf-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this section, referred to in subsec. (c)(1)(B), (2)(A), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Clean Air Act, referred to in subsec. (c)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"act July 14, 1955, ch. 360","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/322"},"text":"69 Stat. 322","children":[],"tail":", which is classified generally to chapter 85 (§ 7401 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7401"},"text":"section 7401 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id42102bb0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (c)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343/s209/a/1"},"text":"Pub. L. 110–343, § 209(a)(1)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2014-01-01"},"text":"January 1, 2014","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2012-01-01"},"text":"January 1, 2012","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343/s209/a/2"},"text":"Pub. L. 110–343, § 209(a)(2)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2010-01-01"},"text":"January 1, 2010","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2008-01-01"},"text":"January 1, 2008","children":[],"tail":"” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343/s209/b/1"},"text":"Pub. L. 110–343, § 209(b)(1)","children":[],"tail":", inserted “, or directly from shale or tar sands” after “(as defined in section 45K(c))”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343/s209/b/2"},"text":"Pub. L. 110–343, § 209(b)(2)","children":[],"tail":", inserted “shale, tar sands, or” before “qualified fuels”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id42102bb1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id42102bb2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343/dB/tII/s209/c"},"text":"Pub. L. 110–343, div. B, title II, § 209(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3840"},"text":"122 Stat. 3840","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/343/dB/tII/s209/c"},"text":"“The amendments made by this section [amending this section] shall apply to property placed in service after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id42102bb3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXIII/s1323/c"},"text":"Pub. L. 109–58, title XIII, § 1323(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1015"},"text":"119 Stat. 1015","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/58/tXIII/s1323/c"},"text":"“The amendments made by this section [enacting this section and amending sections 263, 312, and 1245 of this title] shall apply to properties placed in service after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
