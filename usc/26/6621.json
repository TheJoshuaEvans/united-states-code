":"ref","attrib":{"href":"/us/pl/116/25/tI/s1001/b/1/E"},"text":"Pub. L. 116–25, title I, § 1001(b)(1)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-07-01"},"text":"July 1, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/985"},"text":"133 Stat. 985","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id471320bd-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id471320be-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id471320bf-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (c)(2)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/25"},"text":"Pub. L. 116–25","children":[],"tail":" substituted “Internal Revenue Service Independent Office of Appeals” for “Internal Revenue Service Office of Appeals”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s3302/a"},"text":"Pub. L. 105–206, § 3302(a)","children":[],"tail":", amended subpar. (B) generally. Prior to amendment, subpar. (B) read as follows: “2 percentage points.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s3301/a"},"text":"Pub. L. 105–206, § 3301(a)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1604/b/1"},"text":"Pub. L. 105–34, § 1604(b)(1)","children":[],"tail":", substituted “subsection (c)(3), applied by substituting 