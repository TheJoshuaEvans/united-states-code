{"tag":"section","attrib":{"id":"id4713209e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6621"},"text":null,"children":[{"tag":"num","attrib":{"value":"6621"},"text":"§ 6621.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of rate of interest","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4713209f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6621/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id471320a0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6621/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overpayment rate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The overpayment rate established under this section shall be the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id471320a1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6621/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal short-term rate determined under subsection (b), plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id471320a2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6621/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 percentage points (2 percentage points in the case of a corporation).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"To the extent that an overpayment of tax by a corporation for any taxable period (as defined in subsection (c)(3), applied by substituting “overpayment” for “underpayment”) exceeds $10,000, subparagraph (B) shall be applied by substituting “0.5 percentage point” for “2 percentage points”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id471320a3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6621/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Underpayment rate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The underpayment rate established under this section shall be the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id471320a4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6621/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal short-term rate determined under subsection (b), plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id471320a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6621/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 percentage points.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id471320a6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6621/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal short-term rate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id471320a7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6621/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall determine the Federal short-term rate for the first month in each calendar quarter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id471320a8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6621/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period during which rate applies","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id471320a9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6621/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), the Federal short-term rate determined under paragraph (1) for any month shall apply during the first calendar quarter beginning after such month.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id471320aa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6621/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for individual estimated tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining the addition to tax under section 6654 for failure to pay estimated tax for any taxable year, the Federal short-term rate which applies during the 3rd month following such taxable year shall also apply during the first 15 days of the 4th month following such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id471320ab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6621/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal short-term rate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal short-term rate for any month shall be the Federal short-term rate determined during such month by the Secretary in accordance with section 1274(d). Any such rate shall be rounded to the nearest full percent (or, if a multiple of ½ of 1 percent, such rate shall be increased to the next highest full percent).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id471320ac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6621/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increase in underpayment rate for large corporate underpayments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id471320ad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6621/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of determining the amount of interest payable under section 6601 on any large corporate underpayment for periods after the applicable date, paragraph (2) of subsection (a) shall be applied by substituting “5 percentage points” for “3 percentage points”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id471320ae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6621/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable date","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id471320af-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6621/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The applicable date is the 30th day after the earlier of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id471320b0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6621/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the 1st letter of proposed deficiency which allows the taxpayer an opportunity for administrative review in the Internal Revenue Service Independent Office of Appeals is sent, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id471320b1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6621/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the deficiency notice under section 6212 is sent.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The preceding sentence shall be applied without regard to any such letter or notice which is withdrawn by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id471320b2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6621/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id471320b3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6621/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondeficiency procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any underpayment of any tax imposed by this title to which the deficiency procedures do not apply, subparagraph (A) shall be applied by taking into account any letter or notice provided by the Secretary which notifies the taxpayer of the assessment or proposed assessment of the tax.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id471320b4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6621/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception where amounts paid in full","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A), a letter or notice shall be disregarded if, during the 30-day period beginning on the day on which it was sent, the taxpayer makes a payment equal to the amount shown as due in such letter or notice, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id471320b5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6621/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for letters or notices involving small amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this paragraph, any letter or notice shall be disregarded if the amount of the deficiency or proposed deficiency (or the assessment or proposed assessment) set forth in such letter or notice is not greater than $100,000 (determined by not taking into account any interest, penalties, or additions to tax).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id471320b6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6621/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Large corporate underpayment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id471320b7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6621/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “large corporate underpayment” means any underpayment of a tax by a C corporation for any taxable period if the amount of such underpayment for such period exceeds $100,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id471320b8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6621/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subparagraph (A), the term “taxable period” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id471320b9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6621/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any tax imposed by subtitle A, the taxable year, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id471320ba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6621/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any other tax, the period to which the underpayment relates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id471320bb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6621/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elimination of interest on overlapping periods of tax overpayments and underpayments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent that, for any period, interest is payable under subchapter A and allowable under subchapter B on equivalent underpayments and overpayments by the same taxpayer of tax imposed by this title, the net rate of interest under this section on such amounts shall be zero for such period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id471320bc-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/625/s7/a/1"},"text":"Pub. L. 93–625, § 7(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2114"},"text":"88 Stat. 2114","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/167/s4/b"},"text":"Pub. L. 96–167, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-12-29"},"text":"Dec. 29, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1275"},"text":"93 Stat. 1275","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/tVII/s711/a"},"text":"Pub. L. 97–34, title VII, § 711(a)","children":[],"tail":"–(c), "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/340"},"text":"95 Stat. 340","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/248/tIII/s345/a"},"text":"Pub. L. 97–248, title III, § 345(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/636"},"text":"96 Stat. 636","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s144/a"},"text":"Pub. L. 98–369, div. A, title I, § 144(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/682"},"text":"98 Stat. 682","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXV"},"text":"Pub. L. 99–514, title XV","children":[],"tail":", §§ 1511(a), (c)(1), 1535(a), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2744"},"text":"100 Stat. 2744","children":[],"tail":", 2750; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1015/d"},"text":"Pub. L. 100–647, title I, § 1015(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3569"},"text":"102 Stat. 3569","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/