{"tag":"section","attrib":{"id":"id46fd9e19-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6435"},"text":null,"children":[{"tag":"num","attrib":{"value":"6435"},"text":"§ 6435.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dyed fuel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46fd9e1a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6435/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a person establishes to the satisfaction of the Secretary that such person meets the requirements of subsection (b) with respect to diesel fuel or kerosene, then the Secretary shall pay to such person an amount (without interest) equal to the tax described in subsection (b)(2)(A) with respect to such diesel fuel or kerosene.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46fd9e1b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6435/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46fd9e1c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6435/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person meets the requirements of this subsection with respect to diesel fuel or kerosene if such person removes from a terminal eligible indelibly dyed diesel fuel or kerosene.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46fd9e1d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6435/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible indelibly dyed diesel fuel or kerosene defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible indelibly dyed diesel fuel or kerosene” means diesel fuel or kerosene—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46fd9e1e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6435/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to which a tax under section 4081 was previously paid (and not credited or refunded), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46fd9e1f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6435/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is exempt from taxation under section 4082(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46fd9e20-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6435/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For civil penalty for excessive claims under this section, see section 6675.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46fd9e21-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70525/a"},"text":"Pub. L. 119–21, title VII, § 70525(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/282"},"text":"139 Stat. 282","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46fd9e22-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46fd9e23-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id46fd9e24-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to eligible indelibly dyed diesel fuel or kerosene removed on or after the date that is 180 days after ","children":[{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70525/c"},"text":"section 70525(c) of Pub. L. 119–21","children":[],"tail":", set out as an Effective Date of 2025 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6206"},"text":"section 6206 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
