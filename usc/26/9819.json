{"tag":"section","attrib":{"id":"id47d697c8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9819"},"text":null,"children":[{"tag":"num","attrib":{"value":"9819"},"text":"§ 9819.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of price comparison tool","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A group health plan shall offer price comparison guidance by telephone and make available on the Internet website of the plan or issuer a price comparison tool that (to the extent practicable) allows an individual enrolled under such plan, with respect to such plan year, such geographic region, and participating providers with respect to such plan or coverage, to compare the amount of cost-sharing that the individual would be responsible for paying under such plan with respect to the furnishing of a specific item or service by any such provider.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id47d697c9-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dBB/tI/s114/b/1"},"text":"Pub. L. 116–260, div. BB, title I, § 114(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2874"},"text":"134 Stat. 2874","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47d697ca-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47d697cb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id47d697cc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dBB/tI/s114/d"},"text":"Pub. L. 116–260, div. BB, title I, § 114(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2875"},"text":"134 Stat. 2875","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/260/dBB/tI/s114/d"},"text":"“The amendments made by this section [enacting this section, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1185h"},"text":"section 1185h of Title 29","children":[],"tail":", Labor, and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–114"},"text":"section 300gg–114 of Title 42","children":[],"tail":", The Public Health and Welfare] shall apply with respect to plan years beginning on or after "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"January 1, 2022","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
