{"tag":"section","attrib":{"id":"id460f1eb1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980E"},"text":null,"children":[{"tag":"num","attrib":{"value":"4980E"},"text":"§ 4980E.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure of employer to make comparable Archer MSA contributions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id460f1eb2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980E/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an employer who makes a contribution to the Archer MSA of any employee with respect to coverage under a high deductible health plan of the employer during a calendar year, there is hereby imposed a tax on the failure of such employer to meet the requirements of subsection (d) for such calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id460f1eb3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980E/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of the tax imposed by subsection (a) on any failure for any calendar year is the amount equal to 35 percent of the aggregate amount contributed by the employer to Archer MSAs of employees for taxable years of such employees ending with or within such calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id460f1eb4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980E/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a failure which is due to reasonable cause and not to willful neglect, the Secretary may waive part or all of the tax imposed by subsection (a) to the extent that the payment of such tax would be excessive relative to the failure involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id460f1eb5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980E/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employer required to make comparable MSA contributions for all participating employees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id460f1eb6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980E/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An employer meets the requirements of this subsection for any calendar year if the employer makes available comparable contributions to the Archer MSAs of all comparable participating employees for each coverage period during such calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460f1eb7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980E/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comparable contributions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id460f1eb8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980E/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), the term “comparable contributions” means contributions—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id460f1eb9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980E/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which are the same amount, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id460f1eba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980E/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which are the same percentage of the annual deductible limit under the high deductible health plan covering the employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id460f1ebb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980E/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Part-year employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an employee who is employed by the employer for only a portion of the calendar year, a contribution to the Archer MSA of such employee shall be treated as comparable if it is an amount which bears the same ratio to the comparable amount (determined without regard to this subparagraph) as such portion bears to the entire calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460f1ebc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980E/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comparable participating employees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), the term “comparable participating employees” means all employees—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id460f1ebd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980E/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who are eligible individuals covered under any high deductible health plan of the employer, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id460f1ebe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980E/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who have the same category of coverage.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of subparagraph (B), the categories of coverage are self-only and family coverage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id460f1ebf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980E/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Part-time employees","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id460f1ec0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980E/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (3) shall be applied separately with respect to part-time employees and other employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id460f1ec1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980E/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Part-time employee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A), the term “part-time employee” means any employee who is customarily employed for fewer than 30 hours per week.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id460f1ec2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980E/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Controlled groups","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, all persons treated as a single employer under subsection (b), (c), (m), or (","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":") of section 414 shall be treated as 1 employer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id460f1ec3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4980E/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Terms used in this section which are also used in section 220 have the respective meanings given such terms in section 220.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id460f1ec4-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191/tIII/s301/c/4/A"},"text":"Pub. L. 104–191, title III, § 301(c)(4)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2049"},"text":"110 Stat. 2049","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tII/s202/a/8"},"text":"Pub. L. 106–554, § 1(a)(7) [title II, § 202(a)(8), (b)(2)(D)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–629; "},{"tag":"ref","attrib":{"href":"/us/pl/107/147/tIV/s417/17/A"},"text":"Pub. L. 107–147, title IV, § 417(17)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-03-09"},"text":"Mar. 9, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/56"},"text":"116 Stat. 56","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id460f1ec5-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id460f1ec6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id460f1ec7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/147"},"text":"Pub. L. 107–147","children":[],"tail":" substituted “Archer MSA contributions” for “medical savings account contributions” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tII/s202/a/8"},"text":"Pub. L. 106–554, § 1(a)(7) [title II, § 202(a)(8)]","children":[],"tail":", substituted “Archer MSA” for “medical savings account”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tII/s202/b/2/D"},"text":"Pub. L. 106–554, § 1(a)(7) [title II, § 202(b)(2)(D)]","children":[],"tail":", substituted “Archer MSAs” for “medical savings accounts”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tII/s202/a/8"},"text":"Pub. L. 106–554, § 1(a)(7) [title II, § 202(a)(8)]","children":[],"tail":", substituted “Archer MSA” for “medical savings account”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id460f1ec8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id460f1ec9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1996-12-31"},"text":"Dec. 31, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/191/s301/j"},"text":"section 301(j) of Pub. L. 104–191","children":[],"tail":", set out as an Effective Date of 1996 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s62"},"text":"section 62 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
