{"tag":"section","attrib":{"id":"id47d909ed-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832"},"text":null,"children":[{"tag":"num","attrib":{"value":"9832"},"text":"§ 9832.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47d909ee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Group health plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this chapter, the term “group health plan” has the meaning given to such term by section 5000(b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47d909ef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions relating to health insurance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47d909f0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health insurance coverage","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47d909f1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), the term “health insurance coverage” means benefits consisting of medical care (provided directly, through insurance or reimbursement, or otherwise) under any hospital or medical service policy or certificate, hospital or medical service plan contract, or health maintenance organization contract offered by a health insurance issuer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47d909f2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No application to certain excepted benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In applying subparagraph (A), excepted benefits described in subsection (c)(1) shall not be treated as benefits consisting of medical care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47d909f3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health insurance issuer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “health insurance issuer” means an insurance company, insurance service, or insurance organization (including a health maintenance organization, as defined in paragraph (3)) which is licensed to engage in the business of insurance in a State and which is subject to State law which regulates insurance (within the meaning of section 514(b)(2) of the Employee Retirement Income Security Act of 1974, as in effect on the date of the enactment of this section). Such term does not include a group health plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47d909f4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health maintenance organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “health maintenance organization” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47d909f5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a federally qualified health maintenance organization (as defined in section 1301(a) of the Public Health Service Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300e/a"},"text":"42 U.S.C. 300e(a)","children":[],"tail":")),"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47d909f6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an organization recognized under State law as a health maintenance organization, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47d909f7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a similar organization regulated under State law for solvency in the same manner and to the same extent as such a health maintenance organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47d909f8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excepted benefits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter, the term “excepted benefits” means benefits under one or more (or any combination thereof) of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47d909f9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefits not subject to requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47d909fa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coverage only for accident, or disability income insurance, or any combination thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47d909fb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coverage issued as a supplement to liability insurance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47d909fc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Liability insurance, including general liability insurance and automobile liability insurance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47d909fd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Workers’ compensation or similar insurance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47d909fe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Automobile medical payment insurance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47d909ff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Credit-only insurance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47d90a00-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coverage for on-site medical clinics.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47d90a01-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/c/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other similar insurance coverage, specified in regulations, under which benefits for medical care are secondary or incidental to other insurance benefits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47d90a02-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefits not subject to requirements if offered separately","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47d90a03-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Limited scope dental or vision benefits.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47d90a04-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Benefits for long-term care, nursing home care, home health care, community-based care, or any combination thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47d90a05-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other similar, limited benefits as are specified in regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47d90a06-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefits not subject to requirements if offered as independent, noncoordinated benefits","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47d90a07-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coverage only for a specified disease or illness.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47d90a08-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hospital indemnity or other fixed indemnity insurance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47d90a09-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefits not subject to requirements if offered as separate insurance policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Medicare supplemental health insurance (as defined under section 1882(g)(1) of the Social Security Act), coverage supplemental to the coverage provided under chapter 55 of title 10, United States Code, and similar supplemental coverage provided to coverage under a group health plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47d90a0a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47d90a0b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" COBRA continuation provision","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “COBRA continuation provision” means any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47d90a0c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 4980B, other than subsection (f)(1) thereof insofar as it relates to pediatric vaccines.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47d90a0d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Part 6 of subtitle B of title I of the Employee Retirement Income Security Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1161"},"text":"29 U.S.C. 1161","children":[],"tail":" et seq.), other than section 609 of such Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47d90a0e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Title XXII of the Public Health Service Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47d90a0f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Governmental plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “governmental plan” has the meaning given such term by section 414(d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47d90a10-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical care","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “medical care” has the meaning given such term by section 213(d) determined without regard to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47d90a11-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paragraph (1)(C) thereof, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47d90a12-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" so much of paragraph (1)(D) thereof as relates to qualified long-term care insurance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47d90a13-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Network plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “network plan” means health insurance coverage of a health insurance issuer under which the financing and delivery of medical care are provided, in whole or in part, through a defined set of providers under contract with the issuer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47d90a14-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Placed for adoption defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “placement”, or being “placed”, for adoption, in connection with any placement for adoption of a child with any person, means the assumption and retention by such person of a legal obligation for total or partial support of such child in anticipation of adoption of such child. The child’s placement with such person terminates upon the termination of such legal obligation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47d90a15-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Family member","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “family member” means, with respect to any individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47d90a16-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/d/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a dependent (as such term is used for purposes of section 9801(f)(2)) of such individual, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47d90a17-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/d/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other individual who is a first-degree, second-degree, third-degree, or fourth-degree relative of such individual or of an individual described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47d90a18-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Genetic information","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47d90a19-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/d/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “genetic information” means, with respect to any individual, information about—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47db530a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/d/7/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such individual’s genetic tests,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47db530b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/d/7/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the genetic tests of family members of such individual, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47db530c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/d/7/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manifestation of a disease or disorder in family members of such individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47db530d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/d/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion of genetic services and participation in genetic research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such term includes, with respect to any individual, any request for, or receipt of, genetic services, or participation in clinical research which includes genetic services, by such individual or any family member of such individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47db530e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/d/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “genetic information” shall not include information about the sex or age of any individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47db530f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Genetic test","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47db5310-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/d/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “genetic test” means an analysis of human DNA, RNA, chromosomes, proteins, or metabolites, that detects genotypes, mutations, or chromosomal changes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47db5311-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/d/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “genetic test” does not mean—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47db5312-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/d/8/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of proteins or metabolites that does not detect genotypes, mutations, or chromosomal changes, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47db5313-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/d/8/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of proteins or metabolites that is directly related to a manifested disease, disorder, or pathological condition that could reasonably be detected by a health care professional with appropriate training and expertise in the field of medicine involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47db5314-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Genetic services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “genetic services” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47db5315-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/d/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a genetic test;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47db5316-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/d/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" genetic counseling (including obtaining, interpreting, or assessing genetic information); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47db5317-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/d/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" genetic education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47db5318-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/d/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Underwriting purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “underwriting purposes” means, with respect to any group health plan, or health insurance coverage offered in connection with a group health plan—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47db5319-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/d/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rules for, or determination of, eligibility (including enrollment and continued eligibility) for benefits under the plan or coverage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47db531a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/d/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the computation of premium or contribution amounts under the plan or coverage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47db531b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/d/10/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application of any pre-existing condition exclusion under the plan or coverage; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47db531c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9832/d/10/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other activities related to the creation, renewal, or replacement of a contract of health insurance or health benefits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47db531d-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191/tIV/s401/a"},"text":"Pub. L. 104–191, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2080"},"text":"110 Stat. 2080","children":[],"tail":", § 9805; renumbered § 9832, "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXV/s1531/a/2"},"text":"Pub. L. 105–34, title XV, § 1531(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1081"},"text":"111 Stat. 1081","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/233/tI/s103/d"},"text":"Pub. L. 110–233, title I, § 103(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-21"},"text":"May 21, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/898"},"text":"122 Stat. 898","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47db531e-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47db531f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],