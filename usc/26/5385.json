{"tag":"section","attrib":{"id":"id4639feb3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5385"},"text":null,"children":[{"tag":"num","attrib":{"value":"5385"},"text":"§ 5385.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specially sweetened natural wines","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4639feb4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5385/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Specially sweetened natural wine is the product made by adding to natural wine of the winemaker’s own production a sufficient quantity of pure dry sugar, or juice or concentrated juice from the same kind of fruit, separately or in combination, to produce a finished product having a total solids content in excess of 17 percent by weight and an alcoholic content of not more than 14 percent by volume, and shall include extra sweet kosher wine and similarly heavily sweetened wines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4639feb5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5385/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cellar treatment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Specially sweetened natural wines may be blended with each other, or with natural wine or heavy bodied blending wine in the further production of specially sweetened natural wine only, if the wines so blended are made from the same kind of fruit. Wines produced under this section may be cellar treated under the provisions of section 5382(a) and (c). Wine spirits may not be added to specially sweetened natural wine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4639feb6-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1386"},"text":"72 Stat. 1386","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/89/44/tVIII/s806/c/4"},"text":"Pub. L. 89–44, title VIII, § 806(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-06-21"},"text":"June 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/164"},"text":"79 Stat. 164","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/619"},"text":"Pub. L. 90–619","children":[],"tail":", §§ 3(b), 4, "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1237"},"text":"82 Stat. 1237","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4639feb7-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4639feb8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4639feb9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5385, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/671"},"text":"68A Stat. 671","children":[],"tail":", consisted of provisions similar to those comprising this section, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4639feba-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1968—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/619/s3/b"},"text":"Pub. L. 90–619, § 3(b)","children":[],"tail":", substituted “not more than 14 percent” for “less than 14 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/619/s4"},"text":"Pub. L. 90–619, § 4","children":[],"tail":", authorized cellar treatment of specially sweetened natural wines, special natural wines, and agricultural wines."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44"},"text":"Pub. L. 89–44","children":[],"tail":" substituted “total solids content in excess of 17” for “sugar solids content in excess of 15”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4639febb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4639febc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1968 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/619"},"text":"Pub. L. 90–619","children":[],"tail":" effective on first day of first month which begins 90 days or more after "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/619/s6"},"text":"section 6 of Pub. L. 90–619","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5373"},"text":"section 5373 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4639febd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1965 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44"},"text":"Pub. L. 89–44","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1966-01-01"},"text":"Jan. 1, 1966","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/89/44/s806/d/2"},"text":"section 806(d)(2) of Pub. L. 89–44","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5383"},"text":"section 5383 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
