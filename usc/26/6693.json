{"tag":"section","attrib":{"id":"id472d38bb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6693"},"text":null,"children":[{"tag":"num","attrib":{"value":"6693"},"text":"§ 6693.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to provide reports on certain tax-favored accounts or annuities; penalties relating to designated nondeductible contributions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id472d38bc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6693/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id472d38bd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6693/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a person required to file a report under a provision referred to in paragraph (2) fails to file such report at the time and in the manner required by such provision, such person shall pay a penalty of $50 for each failure unless it is shown that such failure is due to reasonable cause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id472d38be-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6693/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The provisions referred to in this paragraph are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id472d38bf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6693/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsections (i) and (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of section 408 (relating to individual retirement plans),"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id472d38c0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6693/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 220(h) (relating to Archer MSAs),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id472d38c1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6693/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 223(h) (relating to health savings accounts),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id472d38c2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6693/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 529(d) (relating to qualified tuition programs),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id472d38c3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6693/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 529A(d) (relating to qualified ABLE programs),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id472d38c4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6693/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 530(h) (relating to Coverdell education savings accounts), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id472d38c5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6693/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 530A(i) (relating to Trump accounts).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"This subsection shall not apply to any report which is an information return described in section 6724(d)(1)(C)(i) or a payee statement described in section 6724(d)(2)(X).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id472d38c6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6693/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties relating to nondeductible contributions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id472d38c7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6693/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overstatement of designated nondeductible contributions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id472d38c8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6693/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is required to furnish information under section 408(","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(4) as to the amount of designated nondeductible contributions made for any taxable year, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id472d38c9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6693/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" overstates the amount of such contributions made for such taxable year,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall pay a penalty of $100 for each such overstatement unless it is shown that such overstatement is due to reasonable cause.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id472d38ca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6693/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to file form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any individual who fails to file a form required to be filed by the Secretary under section 408(","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(4) shall pay a penalty of $50 for each such failure unless it is shown that such failure is due to reasonable cause."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id472d38cb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6693/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties relating to simple retirement accounts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id472d38cc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6693/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employer penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An employer who fails to provide 1 or more notices required by section 408(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2)(C) shall pay a penalty of $50 for each day on which such failures continue."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id472d38cd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6693/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trustee and issuer penalties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A trustee or issuer who fails—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id472d38ce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6693/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide 1 or more statements required by the last sentence of section 408(i) shall pay a penalty of $50 for each day on which such failures continue, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id472d38cf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6693/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide 1 or more summary descriptions required by section 408(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2)(B) shall pay a penalty of $50 for each day on which such failures continue."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id472d38d0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6693/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reasonable cause exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No penalty shall be imposed under this subsection with respect to any failure which the taxpayer shows was due to reasonable cause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id472d38d1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6693/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deficiency procedures not to apply","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subchapter B of chapter 63 (relating to deficiency procedures for income, estate, gift, and certain excise taxes) does not apply to the assessment or collection of any penalty imposed by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id472d38d2-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tII/s2002/f"},"text":"Pub. L. 93–406, title II, § 2002(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/967"},"text":"88 Stat. 967","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/222/tI/s101/a/10/H"},"text":"Pub. L. 96–222, title I, § 101(a)(10)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-04-01"},"text":"Apr. 1, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/203"},"text":"94 Stat. 203","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s147/b"},"text":"Pub. L. 98–369, div. A, title I, § 147(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/687"},"text":"98 Stat. 687","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXI/s1102/d/1"},"text":"Pub. L. 99–514, titl