"},"text":"139 Stat. 185","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id472d38d3-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id472d38d4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id472d38d5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(2)(G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" added subpar. (G)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(2)(E), (F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" added subpar. (E) and redesignated former subpar. (E) as (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (a)(2)(C) to (E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/173"},"text":"Pub. L. 108–173","children":[],"tail":" added subpar. (C) and redesignated former subpars. (C) and (D) as (D) and (E), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (a)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16"},"text":"Pub. L. 107–16","children":[],"tail":" substituted “qualified tuition” for “qualified State tuition”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/22"},"text":"Pub. L. 107–22","children":[],"tail":" substituted “Coverdell education savings” for “education individual retirement”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554"},"text":"Pub. L. 106–554","children":[],"tail":" substituted “Archer MSAs” for “medical savings accounts”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(2)(C), (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" substituted “section” for “Section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s211/e/2/C"},"text":"Pub. L. 105–34, § 211(e)(2)(C)","children":[],"tail":", substituted “certain tax-favored” for “individual retirement” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1602/a/4"},"text":"Pub. L. 105–34, § 1602(a)(4)","children":[],"tail":", inserted concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s211/e/2/B"},"text":"Pub. L. 105–34, § 211(e)(2)(B)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s213/c"},"text":"Pub. L. 105–34, § 213(c)","children":[],"tail":", added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1601/d/1/C/ii"},"text":"Pub. L. 105–34, § 1601(d)(1)(C)(ii)","children":[],"tail":", inserted “and issuer” before “penalties” in heading and “or issuer” before “who fails” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191"},"text":"Pub. L. 104–191","children":[],"tail":" inserted heading and amended text generally. Prior to amendment, text read as follows: “The person required by subsection (i) or ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of section 408 to file a report regarding an individual retirement account or individual retirement annuity at the time and in the manner required by such subsection shall pay a penalty of $50 for each failure unless it is shown that such failure is due to reasonable cause. This subsection shall not apply to any report which is an information return described in section 6724(d)(1)(C)(i) or a payee statement described in section 6724(d)(2)(W).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1455/d/3"},"text":"Pub. L. 104–188, § 1455(d)(3)","children":[],"tail":", inserted at end “This subsection shall not apply to any report which is an information return described in section 6724(d)(1)(C)(i) or a payee statement described in section 6724(d)(2)(W).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1421/b/4/B"},"text":"Pub. L. 104–188, § 1421(b)(4)(B)","children":[],"tail":", added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1011/b/4/B/i"},"text":"Pub. L. 100–647, § 1011(b)(4)(B)(i)","children":[],"tail":", substituted “penalties relating to” for “overstatement of” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1011/b/4/A"},"text":"Pub. L. 100–647, § 1011(b)(4)(A)","children":[],"tail":", substituted “Penalties relating to” for “Overstatement of designated” in heading and amended text generally. Prior to amendment, text read as follows: “Any individual who—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) is required to furnish information under section 408(","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(4) as to the amount of designated nondeductible contributions made for any taxable year, and"}],"tail":"\n"},{"tag":"p","attr