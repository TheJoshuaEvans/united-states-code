l":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4246f31c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1977-02-01"},"text":"Feb. 1, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/d/1"},"text":"section 1906(d)(1) of Pub. L. 94–455","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6013"},"text":"section 6013 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4246f31d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172/tIV/s414/c"},"text":"Pub. L. 91–172, title IV, § 414(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/613"},"text":"83 Stat. 613","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"“The amendments made by this section [enacting this section] shall apply to a convertible bond or other convertible evidence of indebtedness repurchased after ","children":[{"tag":"date","attrib":{"date":"1969-04-22"},"text":"April 22, 1969","children":[],"tail":", other than such a bond or other evidence of indebtedness repurchased pursuant to a binding obligation incurred on or before "},{"tag":"date","attrib":{"date":"1969-04-22"},"text":"April 22, 1969","children":[],"tail":", to repurchase such bond or other evidence of indebtedness at a specified call premium, but no inference shall be drawn from the fact that section 249 of the Internal Revenue Code of 1986 [formerly I.R.C. 1954] (as added by subsection (a) of this section) does not apply to the repurchase of such convertible bond or other convertible evidence of indebtedness.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
