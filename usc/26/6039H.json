{"tag":"section","attrib":{"id":"id466c331c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039H"},"text":null,"children":[{"tag":"num","attrib":{"value":"6039H"},"text":"§ 6039H.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information with respect to Alaska Native Settlement Trusts and Native Corporations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id466c331d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039H/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The fiduciary of an electing Settlement Trust (as defined in section 646(h)(1)) shall include with the return of income of the trust a statement containing the information required under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id466c331e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039H/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application with other requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The filing of any statement under this section shall be in lieu of the reporting requirements under section 6034A to furnish any statement to a beneficiary regarding amounts distributed to such beneficiary (and such other reporting rules as the Secretary deems appropriate).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id466c331f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039H/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The information required under this subsection shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id466c3320-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039H/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of distributions made during the taxable year to each beneficiary,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id466c3321-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039H/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the treatment of such distribution under the applicable provision of section 646, including the amount that is excludable from the recipient beneficiary’s gross income under section 646, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id466c3322-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039H/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount (if any) of any distribution during such year that is deemed to have been made by the sponsoring Native Corporation (as defined in section 646(h)(5)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id466c3323-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039H/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sponsoring Native Corporation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id466c3324-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039H/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The electing Settlement Trust shall, on or before the date on which the statement under subsection (a) is required to be filed, furnish such statement to the sponsoring Native Corporation (as so defined).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id466c3325-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039H/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distributees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The sponsoring Native Corporation shall furnish each recipient of a distribution described in section 646(e)(3) a statement containing the amount deemed to have been distributed to such recipient by such corporation for the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id466c3326-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039H/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deductible contributions by Native Corporations to Alaska Native Settlement Trusts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id466c3327-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039H/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any Native Corporation (as defined in subsection (m) of section 3 of the Alaska Native Claims Settlement Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1602/m"},"text":"43 U.S.C. 1602(m)","children":[],"tail":")) which has made a contribution to a Settlement Trust (as defined in subsection (t) of such section) to which an election under subsection (e) of section 247 applies shall provide such Settlement Trust with a statement regarding such election not later than January 31 of the calendar year subsequent to the calendar year in which the contribution was made."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id466c3328-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039H/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content of statement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The statement described in paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id466c3329-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039H/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount of contributions to which the election under subsection (e) of section 247 applies,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id466c332a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039H/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each contribution, whether such contribution was in cash,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id466c332b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039H/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each contribution which consists of property other than cash, the date that such property was acquired by the Native Corporation and the adjusted basis and fair market value of such property on the date such property was contributed to the Settlement Trust,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id466c332c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039H/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which each contribution was made to the Settlement Trust, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id466c332d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6039H/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such information as the Secretary determines to be necessary or appropriate for the identification of each contribution and the accurate inclusion of income relating to such contributions by the Settlement Trust.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id466c332e-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16/tVI/s671/b"},"text":"Pub. L. 107–16, title VI, § 671(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-06-07"},"text":"June 7, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/147"},"text":"115 Stat. 147","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13821/c/1"},"text":"Pub. L. 115–97, title I, § 13821(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2181"},"text":"131 Stat. 2181","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id466c332f-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id466c3330-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id466c3331-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13821/c/1/A"},"text":"Pub. L. 115–97, § 13821(c)(1)(A)","children":[],"tail":", struck out “sponsoring” before “Native Corporations” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13821/c/1/B"},"text":"Pub. L. 115–97, § 13821(c)(1)(B)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id466c3332-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id466c3333-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13821/c/3"},"text":"Pub. L. 115–97, title I, § 13821(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2182"},"text":"131 Stat. 2182","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/97/tI/s13821/c/3"},"text":"“The amendments made by this subsection [amending this section] shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2016-12-31"},"text":"December 31, 2016","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id466c3334-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to taxable years ending after ","children":[{"tag":"date","attrib":{"date":"2001-06-07"},"text":"June 7, 2001","children":[],"tail":", and to contributions made to electing Settlement Trusts for such year or any subsequent year, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/16/s671/d"},"text":"section 671(d) of Pub. L. 107–16","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s646"},"text":"section 646 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
