{"tag":"section","attrib":{"id":"id46b39b83-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6167"},"text":null,"children":[{"tag":"num","attrib":{"value":"6167"},"text":"§ 6167.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of time for payment of tax attributable to recovery of foreign expropriation losses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46b39b84-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6167/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension allowed by election","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46b39b85-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6167/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a corporation has a recovery of a foreign expropriation loss to which section 1351 applies, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46b39b86-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6167/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the portion of the recovery received in money is less than 25 percent of the amount of such recovery (as defined in section 1351(c)) and is not greater than the tax attributable to such recovery,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the tax attributable to such recovery shall, at the election of the taxpayer, be payable in 10 equal installments on the 15th day of the fourth month of each of the taxable years following the taxable year of the recovery. Such election shall be made at such time and in such manner as the Secretary may prescribe by regulations. If an election is made under this subsection, the provisions of this subtitle shall apply as though the Secretary were extending the time for payment of such tax.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46b39b87-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6167/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension permitted by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a corporation has a recovery of a foreign expropriation loss to which section 1351 applies and if an election is not made under subsection (a), the Secretary may, upon finding that the payment of the tax attributable to such recovery at the time otherwise provided in this subtitle would result in undue hardship, extend the time for payment of such tax for a reasonable period or periods not in excess of 9 years from the date on which such tax is otherwise payable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46b39b88-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6167/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceleration of payments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46b39b89-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6167/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an election is made under subsection (a),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46b39b8a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6167/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" during any taxable year before the tax attributable to such recovery is paid in full—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46b39b8b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6167/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any property (other than money) received on such recovery is sold or exchanged, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46b39b8c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6167/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any property (other than money) received on any sale or exchange described in subparagraph (A) is sold or exchanged, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46b39b8d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6167/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the amount of money received on such sale or exchange (reduced by the amount of the tax imposed under chapter 1 with respect to such sale or exchange), when added to the amount of money—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46b39b8e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6167/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" received on such recovery, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46b39b8f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6167/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" received on previous sales or exchanges described in subparagraphs (A) and (B) of paragraph (2) (as so reduced),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"exceeds the amount of money which may be received under subsection (a)(2),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"an amount of the tax attributable to such recovery equal to such excess shall be payable on the 15th day of the fourth month of the taxable year following the taxable year in which such sale or exchange occurs. The amount of such tax so paid shall be treated, for purposes of this section, as a payment of the first unpaid installment or installments (or portion thereof) which become payable under subsection (a) following such taxable year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46b39b90-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6167/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proration of deficiency to installments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an election is made under subsection (a), and a deficiency attributable to the recovery of a foreign expropriation loss has been assessed, the deficiency shall be prorated to such installments. The part of the deficiency so prorated to any installment the date for payment of which has not arrived shall be collected at the same time as, and as part of, such installment. The part of the deficiency so prorated to any installment the date for payment of which has arrived shall be paid upon notice and demand from the Secretary. This subsection shall not apply if the deficiency is due to negligence, to intentional disregard of rules and regulations, or to fraud with intent to evade tax.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46b39b91-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6167/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for payment of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the time for payment for any amount of tax has been extended under this section, interest payable under section 6601 on any unpaid portion of such amount shall be paid annually at the same time as, and as part of, each installment payment of the tax. Interest, on that part of a deficiency prorated under this section to any installment the date for payment of which has not arrived, for the period before the date fixed for the last installment preceding the assessment of the deficiency, shall be paid upon notice and demand from the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46b39b92-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6167/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax attributable to recovery of foreign expropriation loss","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the tax attributable to a recovery of a foreign expropriation loss is the sum of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46b39b93-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6167/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the additional tax imposed by section 1351(d)(1) on such recovery, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46b39b94-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6167/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount by which the tax imposed under subtitle A is increased by reason of the gain on such recovery which under section 1351(e) is considered as gain on the involuntary conversion of property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46b39b95-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6167/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to pay installment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any installment under this section is not paid on or before the date fixed for its payment by this section (including any extension of time for the payment of such installment), the unpaid portion of the tax payable in installments shall be paid upon notice and demand from the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46b39b96-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6167/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross-references","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46b39b97-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6167/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security.—","children":[],"tail":null},{"tag":"content","attrib":{},"text":"For authority of the Secretary to require security in the case of an extension under this section, see section 6165.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46b39b98-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6167/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of limitation.—","children":[],"tail":null},{"tag":"content","attrib":{},"text":"For extension of the period of limitation in the case of an extension under this section, see section 6503(e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46b39b99-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/384/s1/d"},"text":"Pub. L. 89–384, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-04-08"},"text":"Apr. 8, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/102"},"text":"80 Stat. 102","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/93/625/s7/d/2"},"text":"Pub. L. 93–625, § 7(d)(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2115"},"text":"88 Stat. 2115","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX"},"text":"Pub. L. 94–455, title XIX","children":[],"tail":", §§ 1902(b)(2)(B), 1906(b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1806"},"text":"90 Stat. 1806","children":[],"tail":", 1834; "},{"tag":"ref","attrib":{"href":"/us/pl/114/41/tII/s2006/a/2/D"},"text":"Pub. L. 114–41, title II, § 2006(a)(2)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-07-31"},"text":"July 31, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/457"},"text":"129 Stat. 457","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46b39b9a-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46b39b9b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46b39b9c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsecs. (a), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/41"},"text":"Pub. L. 114–41","children":[],"tail":" substituted “fourth month” for “third month” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsecs. (a), (b), (d), (e), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":", §§ 1902(b)(2)(B), 1906(b)(13)(A), substituted “section 6503(e)” for “section 6503(f)”, and struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/625/s7/d/2"},"text":"Pub. L. 93–625, § 7(d)(2)","children":[],"tail":", struck out provision that in applying section 6601(j) (relating to the application of the 4-percent interest rate in the case of recoveries of foreign expropriation losses to which this section applies) in the case of a deficiency, the entire amount which was prorated to installments under this section shall be treated as an amount of tax the payment of which was extended under this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/625/s7/d/3"},"text":"Pub. L. 93–625, § 7(d)(3)","children":[],"tail":", struck out par. (1) providing a cross reference for payment of interest at 4 percent per annum for period of an extension under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6601/j"},"text":"section 6601(j) of this title","children":[],"tail":", and redesignated pars. (2) and (3) as (1) and (2), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46b39b9d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46b39b9e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/41"},"text":"Pub. L. 114–41","children":[],"tail":" applicable to returns for taxable years beginning after "},{"tag":"date","attrib":{"date":"2015-12-31"},"text":"Dec. 31, 2015","children":[],"tail":", with special rule for certain C corporations, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/41/s2006/a/3"},"text":"section 2006(a)(3) of Pub. L. 114–41","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s170"},"text":"section 170 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46b39b9f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1902/b/2/B"},"text":"section 1902(b)(2)(B) of Pub. L. 94–455","children":[],"tail":" applicable to estates of decedents dying after "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1902/c/1"},"text":"section 1902(c)(1) of Pub. L. 94–455","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2012"},"text":"section 2012 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46b39ba0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1975 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/625"},"text":"Pub. L. 93–625","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1975-07-01"},"text":"July 1, 1975","children":[],"tail":", and applicable to amounts outstanding on such date or arising thereafter, see "},{"tag":"ref","attrib":{"href":"/us/pl/93/625/s7/e"},"text":"section 7(e) of Pub. L. 93–625","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6621"},"text":"section 6621 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id46b39ba1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to amounts received after ","children":[{"tag":"date","attrib":{"date":"1964-12-31"},"text":"Dec. 31, 1964","children":[],"tail":", in respect of foreign expropriation losses (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1351/b"},"text":"section 1351(b) of this title","children":[],"tail":") sustained after "},{"tag":"date","attrib":{"date":"1958-12-31"},"text":"Dec. 31, 1958","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/89/384/s2"},"text":"section 2 of Pub. L. 89–384","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1351"},"text":"section 1351 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
