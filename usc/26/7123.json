{"tag":"section","attrib":{"id":"id4742bd14-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7123"},"text":null,"children":[{"tag":"num","attrib":{"value":"7123"},"text":"§ 7123.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeals dispute resolution procedures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4742bd15-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7123/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Early referral to appeals procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe procedures by which any taxpayer may request early referral of 1 or more unresolved issues from the examination or collection division to the Internal Revenue Service Independent Office of Appeals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4742bd16-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7123/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative dispute resolution procedures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4742bd17-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7123/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mediation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prescribe procedures under which a taxpayer or the Internal Revenue Service Independent Office of Appeals may request non-binding mediation on any issue unresolved at the conclusion of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4742bd18-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7123/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appeals procedures; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4742bd19-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7123/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unsuccessful attempts to enter into a closing agreement under section 7121 or a compromise under section 7122.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4742bd1a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7123/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Arbitration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a pilot program under which a taxpayer and the Internal Revenue Service Independent Office of Appeals may jointly request binding arbitration on any issue unresolved at the conclusion of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4742bd1b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7123/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appeals procedures; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4742bd1c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7123/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unsuccessful attempts to enter into a closing agreement under section 7121 or a compromise under section 7122.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4742bd1d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7123/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative appeal relating to adverse determination of tax-exempt status of certain organizations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4742bd1e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7123/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe procedures under which an organization which claims to be described in section 501(c) may request an administrative appeal (including a conference relating to such appeal if requested by the organization) to the Internal Revenue Service Independent Office of Appeals of an adverse determination described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4742bd1f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7123/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adverse determinations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), an adverse determination is described in this paragraph if such determination is adverse to an organization with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4742bd20-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7123/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the initial qualification or continuing qualification of the organization as exempt from tax under section 501(a) or as an organization described in section 170(c)(2),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4742bd21-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7123/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the initial classification or continuing classification of the organization as a private foundation under section 509(a), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4742bd22-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7123/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the initial classification or continuing classification of the organization as a private operating foundation under section 4942(j)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4742bd23-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/tIII/s3465/a/1"},"text":"Pub. L. 105–206, title III, § 3465(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/768"},"text":"112 Stat. 768","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/113/dQ/tIV/s404/a"},"text":"Pub. L. 114–113, div. Q, title IV, § 404(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/3118"},"text":"129 Stat. 3118","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/25/tI/s1001/b/1/G"},"text":"Pub. L. 116–25, title I, § 1001(b)(1)(G)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-07-01"},"text":"July 1, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/985"},"text":"133 Stat. 985","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4742bd24-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4742bd25-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4742bd26-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7123 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s7124"},"text":"section 7124 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4742bd27-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/25"},"text":"Pub. L. 116–25","children":[],"tail":" substituted “Internal Revenue Service Independent Office of Appeals” for “Internal Revenue Service Office of Appeals” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113"},"text":"Pub. L. 114–113","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4742bd28-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4742bd29-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/dQ/tIV/s404/b"},"text":"Pub. L. 114–113, div. Q, title IV, § 404(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/3118"},"text":"129 Stat. 3118","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/113/dQ/tIV/s404/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply to determinations made on or after ","children":[{"tag":"date","attrib":{"date":"2014-05-19"},"text":"May 19, 2014","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
