{"tag":"section","attrib":{"id":"id4742bd5a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7206"},"text":null,"children":[{"tag":"num","attrib":{"value":"7206"},"text":"§ 7206.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fraud and false statements","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Any person who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4742bd5b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7206/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Declaration under penalties of perjury","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Willfully makes and subscribes any return, statement, or other document, which contains or is verified by a written declaration that it is made under the penalties of perjury, and which he does not believe to be true and correct as to every material matter; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4742bd5c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7206/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aid or assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Willfully aids or assists in, or procures, counsels, or advises the preparation or presentation under, or in connection with any matter arising under, the internal revenue laws, of a return, affidavit, claim, or other document, which is fraudulent or is false as to any material matter, whether or not such falsity or fraud is with the knowledge or consent of the person authorized or required to present such return, affidavit, claim, or document; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4742bd5d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7206/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fraudulent bonds, permits, and entries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Simulates or falsely or fraudulently executes or signs any bond, permit, entry, or other document required by the provisions of the internal revenue laws, or by any regulation made in pursuance thereof, or procures the same to be falsely or fraudulently executed, or advises, aids in, or connives at such execution thereof; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4742bd5e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7206/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal or concealment with intent to defraud","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Removes, deposits, or conceals, or is concerned in removing, depositing, or concealing, any goods or commodities for or in respect whereof any tax is or shall be imposed, or any property upon which levy is authorized by section 6331, with intent to evade or defeat the assessment or collection of any tax imposed by this title; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47452d5f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7206/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compromises and closing agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In connection with any compromise under section 7122, or offer of such compromise, or in connection with any closing agreement under section 7121, or offer to enter into any such agreement, willfully—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47452d60-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7206/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Concealment of property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Conceals from any officer or employee of the United States any property belonging to the estate of a taxpayer or other person liable in respect of the tax, or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47452d61-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7206/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withholding, falsifying, and destroying records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Receives, withholds, destroys, mutilates, or falsifies any book, document, or record, or makes any false statement, relating to the estate or financial condition of the taxpayer or other person liable in respect of the tax;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be guilty of a felony and, upon conviction thereof, shall be fined not more than $100,000 ($500,000 in the case of a corporation), or imprisoned not more than 3 years, or both, together with the costs of prosecution.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47452d62-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/852"},"text":"68A Stat. 852","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/248/tIII/s329/c"},"text":"Pub. L. 97–248, title III, § 329(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/618"},"text":"96 Stat. 618","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47452d63-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47452d64-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id47452d65-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248"},"text":"Pub. L. 97–248","children":[],"tail":" substituted “$100,000 ($500,000 in the case of a corporation)” for “$5,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47452d66-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47452d67-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1982 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248"},"text":"Pub. L. 97–248","children":[],"tail":" applicable to offenses committed after "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/248/s329/e"},"text":"section 329(e) of Pub. L. 97–248","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s7201"},"text":"section 7201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
