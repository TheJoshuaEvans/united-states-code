{"tag":"section","attrib":{"id":"id4244a8b2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s246A"},"text":null,"children":[{"tag":"num","attrib":{"value":"246A"},"text":"§ 246A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dividends received deduction reduced where portfolio stock is debt financed","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4244a8b3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s246A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any dividend on debt-financed portfolio stock, there shall be substituted for the percentage which (but for this subsection) would be used in determining the amount of the deduction allowable under section 243 or 245(a) a percentage equal to the product of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4244a8b4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s246A/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent (65 percent in the case of any dividend from a 20-percent owned corporation as defined in section 243(c)(2)), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4244a8b5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s246A/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 100 percent minus the average indebtedness percentage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4244a8b6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s246A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Section not to apply to dividends for which 100 percent dividends received deduction allowable","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4244a8b7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s246A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" qualifying dividends (as defined in section 243(b)), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4244a8b8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s246A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dividends received by a small business investment company operating under the Small Business Investment Act of 1958.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4244a8b9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s246A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Debt financed portfolio stock","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4244a8ba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s246A/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “debt financed portfolio stock” means any portfolio stock if at some time during the base period there is portfolio indebtedness with respect to such stock.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4244a8bb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s246A/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Portfolio stock","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “portfolio stock” means any stock of a corporation unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4244a8bc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s246A/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" as of the beginning of the ex-dividend date, the taxpayer owns stock of such corporation—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4244a8bd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s246A/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" possessing at least 50 percent of the total voting power of the stock of such corporation, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4244a8be-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s246A/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" having a value equal to at least 50 percent of the total value of the stock of such corporation, or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4244a8bf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s246A/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" as of the beginning of the ex-dividend date—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4244a8c0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s246A/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taxpayer owns stock of such corporation which would meet the requirements of subparagraph (A) if “20 percent” were substituted for “50 percent” each place it appears in such subparagraph, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4244a8c1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s246A/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stock meeting the requirements of subparagraph (A) is owned by 5 or fewer corporate shareholders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4244a8c2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s246A/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for stock in a bank or bank holding company","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4244a8c3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s246A/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, as of the beginning of the ex-dividend date, the taxpayer owns stock of any bank or bank holding company having a value equal to at least 80 percent of the total value of the stock of such bank or bank holding company, for purposes of paragraph (2)(A)(i), the taxpayer shall be treated as owning any stock of such bank or bank holding company which the taxpayer has an option to acquire.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4244a8c4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s246A/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subparagraph (A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4244a8c5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s246A/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bank","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “bank” has the meaning given such term by section 581.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4244a8c6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s246A/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bank holding company","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “bank holding company” means a bank holding company (within the meaning of section 2(a) of the Bank Holding Company Act of 1956).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4244a8c7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s246A/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain preferred stock","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of determining whether the requirements of subparagraph (A) or (B) of paragraph (2) or of subparagraph (A) of paragraph (3) are met, stock described in section 1504(a)(4) shall not be taken into account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4244a8c8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s246A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Average indebtedness percentage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4244a8c9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s246A/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (2), the term “average indebtedness percentage” means the percentage obtained by dividing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4244a8ca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s246A/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average amount (determined under regulations prescribed by the Secretary) of the portfolio indebtedness with respect to the stock during the base period, by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4244a8cb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s246A/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average amount (determined under regulations prescribed by the Secretary) of the adjusted basis of the stock during the base period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4244a8cc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s246A/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule where stock not held throughout base period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any stock which was not held by the taxpayer throughout the base period, paragraph (1) shall be applied as if the base period consisted only of that portion of the base period during which the stock was held by the taxpayer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4244a8cd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s246A/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Portfolio indebtedness","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4244a8ce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s246A/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “portfolio indebtedness” means any indebtedness directly attributable to investment in the portfolio stock.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4244a8cf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s246A/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain amounts received from short sale treated as indebtedness","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A), any amount received from a short sale shall be treated as indebtedness for the period beginning on the day on which such amount is received and ending on the day the short sale is closed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4244a8d0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s246A/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Base period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “base period” means, with respect to any dividend, the shorter of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4244a8d1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s246A/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period beginning on the ex-dividend date for the most recent previous dividend on the stock and ending on the day before the ex-dividend date for the dividend involved, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4244a8d2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s246A/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 1-year period ending on the day before the ex-dividend date for the dividend involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4244a8d3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s246A/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction in dividends received deduction not to exceed allocable interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under regulations prescribed by the Secretary, any reduction under this section in the amount allowable as a deduction under section 243 or 245 with respect to any dividend shall not exceed the amount of any interest deduction (including any deductible short sale expense) allocable to such dividend.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4244a8d4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s246A/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The regulations prescribed for purposes of this section under section 7701(f) shall include regulations providing for the disallowance of interest deductions or other appropriate treatment (in lieu of reducing the dividend received deduction) where the obligor of the indebtedness is a person other than the person receiving the dividend.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4244a8d5-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s51/a"},"text":"Pub. L. 98–369, div. A, title I, § 51(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/562"},"text":"98 Stat. 562","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVI/s611/a/4"},"text":"Pub. L. 99–514, title VI, § 611(a)(4)","children":[],"tail":", title XVIII, § 1804(a), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2249"},"text":"100 Stat. 2249","children":[],"tail":", 2798; "},{"tag":"ref","attrib":