{"tag":"section","attrib":{"id":"id470bf591-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6514"},"text":null,"children":[{"tag":"num","attrib":{"value":"6514"},"text":"§ 6514.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credits or refunds after period of limitation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id470bf592-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6514/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credits or refunds after period of limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A refund of any portion of an internal revenue tax shall be considered erroneous and a credit of any such portion shall be considered void—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id470bf593-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6514/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expiration of period for filing claim","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If made after the expiration of the period of limitation for filing claim therefor, unless within such period claim was filed; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id470bf594-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6514/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disallowance of claim and expiration of period for filing suit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a claim filed within the proper time and disallowed by the Secretary, if the credit or refund was made after the expiration of the period of limitation for filing suit, unless within such period suit was begun by the taxpayer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id470bf595-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6514/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery of erroneous refunds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For procedure by the United States to recover erroneous refunds, see sections 6532(b) and 7405.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id470bf596-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6514/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit after period of limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any credit against a liability in respect of any taxable year shall be void if any payment in respect of such liability would be considered an overpayment under section 6401(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id470bf597-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/812"},"text":"68A Stat. 812","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id470bf598-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id470bf599-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id470bf59a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
