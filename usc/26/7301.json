{"tag":"section","attrib":{"id":"id4749e8b0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7301"},"text":null,"children":[{"tag":"num","attrib":{"value":"7301"},"text":"§ 7301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property subject to tax","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4749e8b1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable articles","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any property on which, or for or in respect whereof, any tax is imposed by this title which shall be found in the possession or custody or within the control of any person, for the purpose of being sold or removed by him in fraud of the internal revenue laws, or with design to avoid payment of such tax, or which is removed, deposited, or concealed, with intent to defraud the United States of such tax or any part thereof, may be seized, and shall be forfeited to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4749e8b2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Raw materials","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All property found in the possession of any person intending to manufacture the same into property of a kind subject to tax for the purpose of selling such taxable property in fraud of the internal revenue laws, or with design to evade the payment of such tax, may also be seized, and shall be forfeited to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4749e8b3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7301/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equipment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All property whatsoever, in the place or building, or any yard or enclosure, where the property described in subsection (a) or (b) is found, or which is intended to be used in the making of property described in subsection (a), with intent to defraud the United States of tax or any part thereof, on the property described in subsection (a) may also be seized, and shall be forfeited to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4749e8b4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7301/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Packages","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All property used as a container for, or which shall have contained, property described in subsection (a) or (b) may also be seized, and shall be forfeited to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4749e8b5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7301/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conveyances","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any property (including aircraft, vehicles, vessels, or draft animals) used to transport or for the deposit or concealment of property described in subsection (a) or (b), or any property used to transport or for the deposit or concealment of property which is intended to be used in the making or packaging of property described in subsection (a), may also be seized, and shall be forfeited to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4749e8b6-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/867"},"text":"68A Stat. 867","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s204/8"},"text":"Pub. L. 85–859, title II, § 204(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1429"},"text":"72 Stat. 1429","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4749e8b7-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4749e8b8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4749e8b9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1958—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" included property used to transport or for the deposit or concealment of property which is intended to be used in the making or packaging of property described in subsec. (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4749e8ba-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4749e8bb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1958 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1958-09-03"},"text":"Sept. 3, 1958","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/s210/a/1"},"text":"section 210(a)(1) of Pub. L. 85–859","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5001"},"text":"section 5001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
