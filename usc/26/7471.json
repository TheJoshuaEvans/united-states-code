{"tag":"section","attrib":{"id":"id4761b671-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7471"},"text":null,"children":[{"tag":"num","attrib":{"value":"7471"},"text":"§ 7471.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4761b672-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7471/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment and compensation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4761b673-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7471/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clerk","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Tax Court may appoint a clerk without regard to the provisions of title 5, United States Code, governing appointments in the competitive service. The clerk shall serve at the pleasure of the Tax Court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4761b674-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7471/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judge-appointed employees","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4761b675-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7471/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The judges and special trial judges of the Tax Court may appoint employees, in such numbers as the Tax Court may approve, without regard to the provisions of title 5, United States Code, governing appointments in the competitive service. Any such employee shall serve at the pleasure of the appointing judge.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4761b676-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7471/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption from Federal leave provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A law clerk appointed under this subsection shall be exempt from the provisions of subchapter I of chapter 63 of title 5, United States Code. Any unused sick leave or annual leave standing to the law clerk’s credit as of the effective date of this subsection shall remain credited to the law clerk and shall be available to the law clerk upon separation from the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4761b677-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7471/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Tax Court may appoint necessary employees without regard to the provisions of title 5, United States Code, governing appointments in the competitive service. Such employees shall be subject to removal by the Tax Court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4761b678-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7471/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pay","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Tax Court may fix and adjust the compensation for the clerk and other employees of the Tax Court without regard to the provisions of chapter 51, subchapter III of chapter 53, or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5373"},"text":"section 5373 of title 5","children":[],"tail":", United States Code. To the maximum extent feasible, the Tax Court shall compensate employees at rates consistent with those for employees holding comparable positions in courts established under Article III of the Constitution of the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4761b679-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7471/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Tax Court may establish programs for employee evaluations, incentive awards, flexible work schedules, premium pay, and resolution of employee grievances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4761b67a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7471/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discrimination prohibited","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Tax Court shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4761b67b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7471/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibit discrimination on the basis of race, color, religion, age, sex, national origin, political affiliation, marital status, or handicapping condition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4761b67c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7471/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promulgate procedures for resolving complaints of discrimination by employees and applicants for employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4761b67d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7471/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Experts and consultants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Tax Court may procure the services of experts and consultants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"section 3109 of title 5","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4761b67e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7471/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights to certain appeals reserved","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, an individual who is an employee of the Tax Court on the day before the effective date of this subsection and who, as of that day, was entitled to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4761b67f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7471/a/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appeal a reduction in grade or removal to the Merit Systems Protection Board under chapter 43 of title 5, United States Code,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4761b680-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7471/a/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appeal an adverse action to the Merit Systems Protection Board under chapter 75 of title 5, United States Code,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4761b681-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7471/a/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appeal a prohibited personnel practice described under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2302/b"},"text":"section 2302(b) of title 5","children":[],"tail":", United States Code, to the Merit Systems Protection Board under chapter 77 of that title,"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4761b682-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7471/a/8/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make an allegation of a prohibited personnel practice described under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2302/b"},"text":"section 2302(b) of title 5","children":[],"tail":", United States Code, with the Office of Special Counsel under chapter 12 of that title for action in accordance with that chapter, or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4761b683-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7471/a/8/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" file an appeal with the Equal Employment Opportunity Commission under part 1614 of title 29 of the Code of Federal Regulations,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall continue to be entitled to file such appeal or make such an allegation so long as the individual remains an employee of the Tax Court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4761b684-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7471/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive status","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, any employee of the Tax Court who has completed at least 1 year of continuous service under a non-temporary appointment with the Tax Court acquires a competitive status for appointment to any position in the competitive service for which the employee possesses the required qualifications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4761b685-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7471/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Merit system principles, prohibited personnel practices, and preference eligibles","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any personnel management system of the Tax Court shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4761b686-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7471/a/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include the principles set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2301/b"},"text":"section 2301(b) of title 5","children":[],"tail":", United States Code;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4761b687-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7471/a/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibit personnel practices prohibited under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2302/b"},"text":"section 2302(b) of title 5","children":[],"tail":", United States Code; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4761b688-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7471/a/10/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any individual who would be a preference eligible in the executive branch, provide preference for that individual in a manner and to an extent consistent with preference accorded to preference eligibles in the executive branch.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4761b689-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7471/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenses for travel and subsistence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The employees of the Tax Court shall receive their necessary traveling expenses, and expenses for subsistence while traveling on duty and away from their designated stations, as provided in chapter 57 of title 5, United States Code.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4761b68a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7471/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special trial judges","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For compensation and travel and subsistence allowances of special trial judges of the Tax Court, see subsections (d) and (e) of section 7443A.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4761b68b-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-06/ch736"},"text":"Aug. 6, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/888"},"text":"68A Stat. 888","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/tIX/s960/g"},"text":"Pub. L. 91–172, title IX, § 960(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/734"},"text":"83 Stat. 734","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/a/47"},"text":"Pub. L. 94–455, title XIX, § 1906(a)(47)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1831"},"text":"90 Stat. 1831","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tIV/s464/d"},"text":"Pub. L. 98–369, div. A, title IV, § 464(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/825"},"text":"98 Stat. 825","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXV/s1556/b/2"},"text":"Pub. L. 99–514, title XV, § 1556(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2755"},"text":"100 Stat. 2755","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/366/s1/a"},"text":"Pub. L. 111–366, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4063"},"text":"124 Stat. 4063","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4761b68c-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4761b68d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4761b68e-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The effective date of this subsection, referred to in subsec. (a)(2)(B), (8), probably means the effective date of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/366/s1/a"},"text":"section 1(a) of Pub. L. 111–366","children":[],"tail":", which amended subsec. (a) generally. See Effective Date of 2011 Amendment note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4761b68f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/366"},"text":"Pub. L. 111–366","children":[],"tail":" amended subsec. (a) generally. Prior to amendment, text read as follows: “The Tax Court is authorized to appoint, in accordance with the provisions of title 5, United States Code, governing appointment in the competitive service, and to fix the basic pay of, in accordance with chapter 51 and subchapter III of chapter 53 of such title, such employees as may be necessary efficiently to execute the functions vested in the Tax Court.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “subsections (d) and (e) of section 7443A” for “section 7456(c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" substituted references to special trial judges for references to commissioners in the subsection heading and text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/a/47/A"},"text":"Pub. L. 94–455, § 1906(a)(47)(A)","children":[],"tail":", among other changes, substituted provisions referring to title 5 of the United States Code for provisions referring to the civil service law, and to chapter 51 and subchapter III of chapter 53 of title 5 for the Classification Act of 1949."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/a/47/B"},"text":"Pub. L. 94–455, § 1906(a)(47)(B)","children":[],"tail":", substituted “as provided in chapter 57 of title 5, United States Code” for “as provided in the Travel Expense Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/stat/63/166"},"text":"63 Stat. 166","children":[],"tail":"; 5 U.S.C. chapter 16)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172"},"text":"Pub. L. 91–172","children":[],"tail":" inserted reference to the compensation of commissioners."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","