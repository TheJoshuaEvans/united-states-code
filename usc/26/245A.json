{"tag":"section","attrib":{"id":"id42423848-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s245A"},"text":null,"children":[{"tag":"num","attrib":{"value":"245A"},"text":"§ 245A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deduction for foreign source-portion of dividends received by domestic corporations from specified 10-percent owned foreign corporations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id42423849-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s245A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any dividend received from a specified 10-percent owned foreign corporation by a domestic corporation which is a United States shareholder with respect to such foreign corporation, there shall be allowed as a deduction an amount equal to the foreign-source portion of such dividend.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4242384a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s245A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specified 10-percent owned foreign corporation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4242384b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s245A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “specified 10-percent owned foreign corporation” means any foreign corporation with respect to which any domestic corporation is a United States shareholder with respect to such corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4242384c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s245A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of passive foreign investment companies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such term shall not include any corporation which is a passive foreign investment company (as defined in section 1297) with respect to the shareholder and which is not a controlled foreign corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4242384d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s245A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign-source portion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4242384e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s245A/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The foreign-source portion of any dividend from a specified 10-percent owned foreign corporation is an amount which bears the same ratio to such dividend as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4242384f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s245A/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the undistributed foreign earnings of the specified 10-percent owned foreign corporation, bears to","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42423850-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s245A/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total undistributed earnings of such foreign corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42423851-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s245A/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Undistributed earnings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “undistributed earnings” means the amount of the earnings and profits of the specified 10-percent owned foreign corporation (computed in accordance with sections 964(a) and 986)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42423852-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s245A/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as of the close of the taxable year of the specified 10-percent owned foreign corporation in which the dividend is distributed, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42423853-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s245A/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without diminution by reason of dividends distributed during such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42423854-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s245A/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Undistributed foreign earnings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “undistributed foreign earnings” means the portion of the undistributed earnings which is attributable to neither—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42423855-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s245A/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" income described in subparagraph (A) of section 245(a)(5), nor","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42423856-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s245A/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dividends described in subparagraph (B) of such section (determined without regard to section 245(a)(12)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42423857-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s245A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disallowance of foreign tax credit, etc.","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42423858-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s245A/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No credit shall be allowed under section 901 for any taxes paid or accrued (or treated as paid or accrued) with respect to any dividend for which a deduction is allowed under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42423859-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s245A/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial of deduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No deduction shall be allowed under this chapter for any tax for which credit is not allowable under section 901 by reason of paragraph (1) (determined by treating the taxpayer as having elected the benefits of subpart A of part III of subchapter N).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4242385a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s245A/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for hybrid dividends","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4242385b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s245A/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not apply to any dividend received by a United States shareholder from a controlled foreign corporation if the dividend is a hybrid dividend.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4242385c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s245A/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hybrid dividends of tiered corporations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a controlled foreign corporation with respect to which a domestic corporation is a United States shareholder receives a hybrid dividend from any other controlled foreign corporation with respect to which such domestic corporation is also a United States shareholder, then, notwithstanding any other provision of this title—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4242385d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s245A/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the hybrid dividend shall be treated for purposes of section 951(a)(1)(A) as subpart F income of the receiving controlled foreign corporation for the taxable year of the controlled foreign corporation in which the dividend was received, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4242385e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s245A/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States shareholder shall include in gross income an amount equal to the shareholder’s pro rata share (determined in the same manner as under section 951(a)(2)) of the subpart F income described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4242385f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s245A/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial of foreign tax credit, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rules of subsection (d) shall apply to any hybrid dividend received by, or any amount included under paragraph (2) in the gross income of, a United States shareholder.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42423860-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s245A/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hybrid dividend","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “hybrid dividend” means an amount received from a controlled foreign corporation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42423861-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s245A/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which a deduction would be allowed under subsection (a) but for this subsection, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42423862-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s245A/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which the controlled foreign corporation received a deduction (or other tax benefit) with respect to any income, war profits, or excess profits taxes imposed by any foreign country or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42423863-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s245A/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for purging distributions of passive foreign investment companies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amount which is treated as a dividend under section 1291(d)(2)(B) shall not be treated as a dividend for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42423864-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s245A/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such regulations or other guidance as may be necessary or appropriate to carry out the provisions of this section, including regulations for the treatment of United States shareholders owning stock of a specified 10 percent ","children":[{"tag":"ref","attrib":{"idref":"fn002091"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002091"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “10-percent”."}],"tail":" owned foreign corporation through a partnership."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id42423865-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s14101/a"},"text":"Pub. L. 115–97, title I, § 14101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2189"},"text":"131 Stat. 2189","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id42423866-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id42423867-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id42423868-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s14101/f"},"text":"Pub. L. 115–97, title I, § 14101(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2192"},"text":"131 Stat. 2192","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/97/tI/s14101/f"},"text":"“The amendments made by this section [enacting this section and amending sections 246, 904, 951, 957, and 1059 of this title] shall apply to distributions made after (and, in the case of the amendments made by subsection (d) [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s904"},"text":"section 904 of this title","children":[],"tail":"], deductions with respect to taxable years ending after) "},{"tag":"date","attrib":{"date":"2017-12-31"},"text":"December 31, 2017","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
