{"tag":"section","attrib":{"id":"id472fa929-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6695B"},"text":null,"children":[{"tag":"num","attrib":{"value":"6695B"},"text":"§ 6695B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for substantial misstatements on certification provided by supplier","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id472fa92a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6695B/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of penalty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id472fa92b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6695B/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id472fa92c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6695B/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides a certification described in clause (iii)(II)(bb) of section 7701(a)(52)(D) with respect to any manufactured product, eligible component, or constituent element, material, or subcomponent of an eligible component, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id472fa92d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6695B/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knows, or reasonably should have known, that the certification would be used in connection with a determination under such section,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id472fa92e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6695B/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such person knows, or reasonably should have known, that such certification is inaccurate or false with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id472fa92f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6695B/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether such property was produced or manufactured by a prohibited foreign entity, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id472fa930-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6695B/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total direct costs or total direct material costs of such property that was not produced or manufactured by a prohibited foreign entity that were provided on such certification, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id472fa931-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6695B/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the inaccuracy or falsity described in paragraph (2) resulted in the disallowance of an applicable energy credit (as defined in section 6662(m)(2)) and an understatement of income tax (within the meaning of section 6662(d)(2)) for the taxable year in an amount which exceeds the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id472fa932-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6695B/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 5 percent of the tax required to be shown on the return for the taxable year, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id472fa933-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6695B/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then such person shall pay a penalty in the amount determined under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id472fa934-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6695B/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of penalty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of the penalty imposed under subsection (a) on any person with respect to a certification shall be equal to the greater of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id472fa935-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6695B/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10 percent of the amount of the underpayment (as defined in section 6664(a)) solely attributable to the inaccuracy or falsity described in subsection (a)(2), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id472fa936-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6695B/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id472fa937-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6695B/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No penalty shall be imposed under subsection (a) if the person establishes to the satisfaction of the Secretary that any inaccuracy or falsity described in subsection (a)(2) is due to a reasonable cause and not willful neglect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id472fa938-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6695B/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any term used in this section which is also used in section 7701(a)(52) shall have the meaning given such term in such section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id472fa939-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70512/k/1"},"text":"Pub. L. 119–21, title VII, § 70512(k)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/268"},"text":"139 Stat. 268","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id472fa93a-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id472fa93b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id472fa93c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to certifications provided after ","children":[{"tag":"date","attrib":{"date":"2025-12-31"},"text":"Dec. 31, 2025","children":[],"tail":", see section 70512("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(3) of "},{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":", set out in an Effective Date of 2025 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s45"},"text":"section 45 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
