{"tag":"section","attrib":{"id":"id449d8d9a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1001"},"text":null,"children":[{"tag":"num","attrib":{"value":"1001"},"text":"§ 1001.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of amount of and recognition of gain or loss","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id449d8d9b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1001/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation of gain or loss","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The gain from the sale or other disposition of property shall be the excess of the amount realized therefrom over the adjusted basis provided in section 1011 for determining gain, and the loss shall be the excess of the adjusted basis provided in such section for determining loss over the amount realized.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id449d8d9c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1001/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount realized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount realized from the sale or other disposition of property shall be the sum of any money received plus the fair market value of the property (other than money) received. In determining the amount realized—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id449d8d9d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1001/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there shall not be taken into account any amount received as reimbursement for real property taxes which are treated under section 164(d) as imposed on the purchaser, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id449d8d9e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1001/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there shall be taken into account amounts representing real property taxes which are treated under section 164(d) as imposed on the taxpayer if such taxes are to be paid by the purchaser.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id449d8d9f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1001/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recognition of gain or loss","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this subtitle, the entire amount of the gain or loss, determined under this section, on the sale or exchange of property shall be recognized.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id449d8da0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1001/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Installment sales","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to prevent (in the case of property sold under contract providing for payment in installments) the taxation of that portion of any installment payment representing gain or profit in the year in which such payment is received.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id449d8da1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1001/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain term interests","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id449d8da2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1001/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining gain or loss from the sale or other disposition of a term interest in property, that portion of the adjusted basis of such interest which is determined pursuant to section 1014, 1015, or 1041 (to the extent that such adjusted basis is a portion of the entire adjusted basis of the property) shall be disregarded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id449d8da3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1001/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term interest in property defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), the term “term interest in property” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id449d8da4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1001/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a life interest in property,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id449d8da5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1001/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an interest in property for a term of years, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id449d8da6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1001/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an income interest in a trust.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id449d8da7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1001/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply to a sale or other disposition which is a part of a transaction in which the entire interest in property is transferred to any person or persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id449d8da8-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/295"},"text":"68A Stat. 295","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/tII/s231/c/2"},"text":"Pub. L. 91–172, title II, § 231(c)(2)","children":[],"tail":", title V, § 516(a), "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/579"},"text":"83 Stat. 579","children":[],"tail":", 646; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1901/a/121"},"text":"Pub. L. 94–455, title XIX, § 1901(a)(121)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "