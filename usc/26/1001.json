{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66"},"text":"Pub. L. 103–66","children":[],"tail":" struck out heading and text of subsec. (f). Text read as follows: “For treatment of certain expenses incident to the sale of a residence which were deducted as moving expenses by the taxpayer or his spouse under section 217(a), see section 217(e).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" inserted reference to section 1041."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/223"},"text":"Pub. L. 96–223","children":[],"tail":" repealed the amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/95/600"},"text":"Pub. L. 95–600","children":[],"tail":". See 1978 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600"},"text":"Pub. L. 95–600","children":[],"tail":" inserted reference to section 1023. See Repeals note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" substituted provision recognizing the entire amount of gain or loss, except as otherwise provided, for provision referring to section 1002 for the determination of the extent of gain or loss to be recognized."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172/s516/a"},"text":"Pub. L. 91–172, § 516(a)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172/s231/c/2"},"text":"Pub. L. 91–172, § 231(c)(2)","