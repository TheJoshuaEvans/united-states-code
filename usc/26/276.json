{"tag":"section","attrib":{"id":"id4298200f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s276"},"text":null,"children":[{"tag":"num","attrib":{"value":"276"},"text":"§ 276.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain indirect contributions to political parties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id42982010-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s276/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disallowance of deduction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No deduction otherwise allowable under this chapter shall be allowed for any amount paid or incurred for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42982011-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s276/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advertising in a convention program of a political party, or in any other publication if any part of the proceeds of such publication directly or indirectly inures (or is intended to inure) to or for the use of a political party or a political candidate,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42982012-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s276/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" admission to any dinner or program, if any part of the proceeds of such dinner or program directly or indirectly inures (or is intended to inure) to or for the use of a political party or a political candidate, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42982013-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s276/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" admission to an inaugural ball, inaugural gala, inaugural parade, or inaugural concert, or to any similar event which is identified with a political party or a political candidate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42982014-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s276/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42982015-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s276/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Political party","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “political party” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42982016-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s276/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a political party;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42982017-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s276/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a National, State, or local committee of a political party; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42982018-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s276/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a committee, association, or organization, whether incorporated or not, which directly or indirectly accepts contributions (as defined in section 271(b)(2)) or make expenditures (as defined in section 271(b)(3)) for the purpose of influencing or attempting to influence the selection, nomination, or election of any individual to any Federal, State, or local elective public office, or the election of presidential and vice-presidential electors, whether or not such individual or electors are selected, nominated, or elected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42982019-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s276/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proceeds inuring to or for the use of political candidates","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Proceeds shall be treated as inuring to or for the use of a political candidate only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4298201a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s276/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such proceeds may be used directly or indirectly for the purpose of furthering his candidacy for selection, nomination, or election to any elective public office, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4298201b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s276/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such proceeds are not received by such candidate in the ordinary course of a trade or business (other than the trade or business of holding elective public office).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4298201c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s276/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For disallowance of certain entertainment, etc., expenses, see section 274.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4298201d-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/368/tIII/s301/a"},"text":"Pub. L. 89–368, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-03-15"},"text":"Mar. 15, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/66"},"text":"80 Stat. 66","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/90/364/tI/s108/a"},"text":"Pub. L. 90–364, title I, § 108(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-06-28"},"text":"June 28, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/268"},"text":"82 Stat. 268","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/443/tIV/s406/d"},"text":"Pub. L. 93–443, title IV, § 406(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-15"},"text":"Oct. 15, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1296"},"text":"88 Stat. 1296","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4298201e-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4298201f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id42982020-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1974—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/443"},"text":"Pub. L. 93–443","children":[],"tail":" struck out subsec. (c) relating to advertising in a convention program of a national political convention, and redesignated subsec. (d) as (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/364"},"text":"Pub. L. 90–364","children":[],"tail":" added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id42982021-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id42982022-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1974 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/443"},"text":"Pub. L. 93–443","children":[],"tail":" applicable with respect to taxable years beginning after "},{"tag":"date","attrib":{"date":"1974-12-31"},"text":"Dec. 31, 1974","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/443/s410/c/1"},"text":"section 410(c)(1) of Pub. L. 93–443","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s30101"},"text":"section 30101 of Title 52","children":[],"tail":", Voting and Elections."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id42982023-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1968 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/364/tI/s108/b"},"text":"Pub. L. 90–364, title I, § 108(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-06-28"},"text":"June 28, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/269"},"text":"82 Stat. 269","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/90/364/tI/s108/b"},"text":"“The amendments made by subsection (a) [amending this section] shall apply with respect to amounts paid or incurred on or after ","children":[{"tag":"date","attrib":{"date":"1968-01-01"},"text":"January 1, 1968","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id42982024-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/368/tIII/s301/c"},"text":"Pub. L. 89–368, title III, § 301(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-03-15"},"text":"Mar. 15, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/67"},"text":"80 Stat. 67","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/89/368/tIII/s301/c"},"text":"“The amendments made by subsections (a) and (b) [enacting this section] shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1965-12-31"},"text":"December 31, 1965","children":[],"tail":", but only with respect to amounts paid or incurred after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1966-03-15"},"text":"Mar. 15, 1966","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id42982025-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Program Advertising for Presidential and Vice-Presidential Nominating Conventions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/346"},"text":"Pub. L. 90–346","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-06-18"},"text":"June 18, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/183"},"text":"82 Stat. 183","children":[],"tail":", provided for advertising in a convention program of a national political convention, applicable with respect to amounts paid or incurred on or after "},{"tag":"date","attrib":{"date":"1968-01-01"},"text":"Jan. 1, 1968","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/93/625/s10/g"},"text":"Pub. L. 93–625, § 10(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2119"},"text":"88 Stat. 2119","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
