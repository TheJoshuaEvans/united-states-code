{"tag":"section","attrib":{"id":"id477e65dd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7651"},"text":null,"children":[{"tag":"num","attrib":{"value":"7651"},"text":"§ 7651.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration and collection of taxes in possessions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this subchapter, and except as otherwise provided in section 28(a) of the Revised Organic Act of the Virgin Islands and section 30 of the Organic Act of Guam (relating to the covering of the proceeds of certain taxes into the treasuries of the Virgin Islands and Guam, respectively)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id477e65de-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7651/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of administrative provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All provisions of the laws of the United States applicable to the assessment and collection of any tax imposed by this title or of any other liability arising under this title (including penalties) shall, in respect of such tax or liability, extend to and be applicable in any possession of the United States in the same manner and to the same extent as if such possession were a State, and as if the term “United States” when used in a geographical sense included such possession.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id477e65df-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7651/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax imposed in possession","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any tax which is imposed by this title in any possession of the United States—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id477e65e0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7651/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Internal revenue collections","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such tax shall be collected under the direction of the Secretary, and shall be paid into the Treasury of the United States as internal revenue collections; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id477e65e1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7651/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All provisions of the laws of the United States applicable to the administration, collection, and enforcement of such tax (including penalties) shall, in respect of such tax, extend to and be applicable in such possession of the United States in the same manner and to the same extent as if such possession were a State, and as if the term “United States” when used in a geographical sense included such possession.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id477e65e2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7651/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other laws relating to possessions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply notwithstanding any other provision of law relating to any possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id477e65e3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7651/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Virgin Islands","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id477e65e4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7651/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this section, the reference in section 28(a) of the Revised Organic Act of the Virgin Islands to “any tax specified in section 3811 of the Internal Revenue Code” shall be deemed to refer to any tax imposed by chapter 2 or by chapter 21.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id477e65e5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7651/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this title, section 28(a) of the Revised Organic Act of the Virgin Islands shall be effective as if such section 28(a) had been enacted before the enactment of this title and such section 28(a) shall have no effect on the amount of income tax liability required to be paid by any person to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id477e65e6-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/906"},"text":"68A Stat. 906","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/513/tIII/s1102/j"},"text":"Pub. L. 91–513, title III, § 1102(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-27"},"text":"Oct. 27, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1293"},"text":"84 Stat. 1293","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s130/c"},"text":"Pub. L. 98–369, div. A, title I, § 130(c)","children":[],"tail":", title VIII, § 801(d)(9), "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/661"},"text":"98 Stat. 661","children":[],"tail":", 997; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXII/s1275/b"},"text":"Pub. L. 99–514, title XII, § 1275(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2598"},"text":"100 Stat. 2598","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/172/s11/a/34/B"},"text":"Pub. L. 110–172, § 11(a)(34)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-29"},"text":"Dec. 29, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2487"},"text":"121 Stat. 2487","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id477e65e7-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id477e65e8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id477e65e9-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 28(a) of the Revised Organic Act of the Virgin Islands, referred to in introductory provisions and par. (4), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1642"},"text":"section 1642 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 30 of the Organic Act of Guam, referred to in introductory provisions, is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1421h"},"text":"section 1421h of Title 48","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id477e65ea-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Pars. (4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/172"},"text":"Pub. L. 110–172","children":[],"tail":" redesignated par. (5) as (4) and struck out heading and text of former par. (4). Text read as follows: “For purposes of this section, the term ‘possession of the United States’ includes the Canal Zone.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Par. (5)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" amended subpar. (B) generally. Prior to amendment, subpar. (B) read as follows: “For purposes of this title (other than section 881(b)(1) or subpart C of part III of subchapter N of chapter 1), section 28(a) of the Revised Organic Act of the Virgin Islands shall be effective as if such section had been enacted subsequent to the enactment of this title.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Par. (5)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s801/d/9"},"text":"Pub. L. 98–369, § 801(d)(9)","children":[],"tail":", inserted “or subpart C of part III of subchapter N of chapter 1”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s130/c"},"text":"Pub. L. 98–369, § 130(c)","children":[],"tail":", inserted “(other than section 881(b)(1))”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Par. (2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513"},"text":"Pub. L. 91–513","children":[],"tail":" struck out reference to exceptions provided for in sections 4705(b), 4735, and 4762 (relating to taxes on narcotic drugs and marihuana) in provisions preceding par. (1)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id477e65eb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id477e65ec-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"1986-12-31"},"text":"Dec. 31, 1986","children":[],"tail":", with certain exceptions and qualifications, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1277"},"text":"section 1277 of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s931"},"text":"section 931 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id477e65ed-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s130/c"},"text":"section 130(c) of Pub. L. 98–369","children":[],"tail":" applicable to payments made after "},{"tag":"date","attrib":{"date":"1984-03-01"},"text":"Mar. 1, 1984","children":[],"tail":", in taxable years ending after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s130/d"},"text":"section 130(d) of Pub. L. 98–369","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s881"},"text":"section 881 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s801/d/9"},"text":"section 801(d)(9) of Pub. L. 98–369","children":[],"tail":" applicable to transactions after "},{"tag":"date","attrib":{"date":"1984-12-31"},"text":"Dec. 31, 1984","children":[],"tail":", in taxable years ending after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s805/a/1"},"text":"section 805(a)(1) of Pub. L. 98–369","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s245"},"text":"section 245 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id477e65ee-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513"},"text":"Pub. L. 91–513","children":[],"tail":" effective on first day of seventh calendar month that begins after "},{"tag":"date","attrib":{"date":"1970-10-26"},"text":"Oct. 26, 1970","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/513/s1105/a"},"text":"section 1105(a) of Pub. L. 91–513","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s951"},"text":"section 951 of Title 21","children":[],"tail":", Food and Drugs."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"id477e65ef-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prosecutions for any violation of law occurring, and civil seizures or forfeitures and injunctive proceedings commenced, prior to the effective date of amendment of this section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513/s1102"},"text":"section 1102 of Pub. L. 91–513","children":[],"tail":" not to be affected or abated by reason thereof, see "},{"tag":"ref","attrib":{"href":"/us/pl/91/513/s1103"},"text":"section 1103 of Pub. L. 91–513","children":[],"tail":", set out as a note under sections 171 to 174 of Title 21, Food and Drugs."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id477e65f0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Compensation to Guam and Virgin Islands for Unexpected Revenue Losses Occasioned by Tax Reduction Act of 1975 and Tax Reform Act of 1976","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/134/tIV/s402"},"text":"Pub. L. 95–134, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-10-15"},"text":"Oct. 15, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1163"},"text":"91 Stat. 1163","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/134/tIV/s402"},"text":"“In order to compensate the territories of Guam and the Virgin Islands for unexpected revenue losses occasioned by the Tax Reduction Act of 1975 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/12"},"text":"Pub. L. 94–12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-03-29"},"text":"Mar. 29, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/26"},"text":"89 Stat. 26","children":[],"tail":", see Tables] and the Tax Reform Act of 1976 ["},{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1525"},"text":"90 Stat. 1525","children":[],"tail":", see Tables] there is hereby authorized to be appropriated to the Secretary for grants to the government of Guam not to exceed $15,000,000 and after "},{"tag":"date","attrib":{"date":"1977-10-01"},"text":"October 1, 1977","children":[],"tail":", for grants to the government of the Virgin Islands not to exceed $14,000,000, such sums being in addition to those previously authorized for such purposes.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id477e65f1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Payments to Government of American Samoa, Guam, and the Virgin Islands","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/30/tIV/s407"},"text":"Pub. L. 95–30, title IV, § 407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-05-23"},"text":"May 23, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/156"},"text":"91 Stat. 156","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/30/tIV/s407"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Treasury is authorized to make separate payments to the government of American Samoa, the government of Guam, and the government of the Virgin Islands. The payment to the government of a particular possession shall be in an amount equal to the loss to that possession with respect to tax returns for the first taxable year beginning after ","children":[{"tag":"date","attrib":{"date":"1976-12-31"},"text":"December 31, 1976","children":[],"tail":", by reason of sections 101 and 102 of this Act [amending sections 1, 3, 21, 42, 57, 63, 143, 161, 172, 211, 402, 441, 443, 511, 584, 613A, 641, 642, 667, 703, 861, 862, 873, 904, 911, 931, 1034, 1211, 1302, 6014, 6212, 6504, and 6654 of this title and repealing sections 36, 141, 142, 144 and 145 of this title]. Such amount shall be determined by the Secretary of the Treasury upon certification to the Secretary by the United States Government Comptrollers for Guam and the Virgin Islands."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are hereby authorized to be appropriated, out of any funds in the Treasury not otherwise appropriated, such sums as may be necessary to carry out the provisions of this section.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
