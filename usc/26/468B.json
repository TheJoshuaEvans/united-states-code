{"tag":"section","attrib":{"id":"id43974157-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468B"},"text":null,"children":[{"tag":"num","attrib":{"value":"468B"},"text":"§ 468B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for designated settlement funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id43974158-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468B/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of section 461(h), economic performance shall be deemed to occur as qualified payments are made by the taxpayer to a designated settlement fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43974159-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468B/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxation of designated settlement fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4397415a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468B/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is imposed on the gross income of any designated settlement fund for any taxable year a tax at a rate equal to the maximum rate in effect for such taxable year under section 1(e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4397415b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468B/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain expenses allowed","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), gross income for any taxable year shall be reduced by the amount of any administrative costs (including State and local taxes) and other incidental expenses of the designated settlement fund (including legal, accounting, and actuarial expenses)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4397415c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468B/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which are incurred in connection with the operation of the fund, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4397415d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468B/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which would be deductible under this chapter for purposes of determining the taxable income of a corporation.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"No other deduction shall be allowed to the fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4397415e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468B/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers to the fund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any qualified payment made to the fund—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4397415f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468B/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of such payment shall not be treated as income of the designated settlement fund,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43974160-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468B/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the basis of the fund in any property which constitutes a qualified payment shall be equal to the fair market value of such property at the time of payment, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43974161-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468B/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fund shall be treated as the owner of the property in the fund (and any earnings thereon).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43974162-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468B/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax in lieu of other taxation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tax imposed by paragraph (1) shall be in lieu of any other taxation under this subtitle of income from assets in the designated settlement fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43974163-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468B/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with subtitle F","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subtitle F—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43974164-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468B/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a designated settlement fund shall be treated as a corporation, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43974165-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468B/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any tax imposed by this subsection shall be treated as a tax imposed by section 11.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43974166-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468B/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deductions not allowed for transfer of insurance amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No deduction shall be allowable for any qualified payment by the taxpayer of any amounts received from the settlement of any insurance claim to the extent such amounts are excluded from the gross income of the taxpayer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43974167-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468B/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43974168-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468B/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified payment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified payment” means any money or property which is transferred to any designated settlement fund pursuant to a court order, other than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43974169-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468B/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amount which may be transferred from the fund to the taxpayer (or any related person), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4397416a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468B/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transfer of any stock or indebtedness of the taxpayer (or any related person).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4397416b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468B/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designated settlement fund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “designated settlement fund” means any fund—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4397416c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468B/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is established pursuant to a court order and which extinguishes completely the taxpayer’s tort liability with respect to claims described in subparagraph (D),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4397416d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468B/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to which no amounts may be transferred other than in the form of qualified payments,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4397416e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468B/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is administered by persons a majority of whom are independent of the taxpayer,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4397416f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468B/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is established for the principal purpose of resolving and satisfying present and future claims against the taxpayer (or any related person or formerly related person) arising out of personal injury, death, or property damage,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43974170-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468B/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under the terms of which the taxpayer (or any related person) may not hold any beneficial interest in the income or corpus of the fund, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43974171-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468B/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to which an election is made under this section by the taxpayer.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"An election under this section shall be made at such time and in such manner as the Secretary shall by regulation prescribe. Such an election, once made, may be revoked only with the consent of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43974172-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468B/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Related person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “related person” means a person related to the taxpayer within the meaning of section 267(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43974173-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468B/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplicability of section","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section (other than subsection (g)) shall not apply with respect to any liability of the taxpayer arising under any workers’ compensation Act or any contested liability of the taxpayer within the meaning of section 461(f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43974174-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468B/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in regulations, any payment in respect of a liability described in subsection (d)(2)(D) (and not described in subsection (e)) to a trust fund or escrow fund which is not a designated settlement fund shall not be treated as constituting economic performance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43974175-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468B/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clarification of taxation of certain funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43974176-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468B/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), nothing in any provision of law shall be construed as providing that an escrow account, settlement fund, or similar fund is not subject to current income tax. The Secretary shall prescribe regulations providing for the taxation of any such account or fund whether as a grantor trust or otherwise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43974177-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468B/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption from tax for certain settlement funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An escrow account, settlement fund, or similar fund shall be treated as beneficially owned by the United States and shall be exempt from taxation under this subtitle if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43974178-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468B/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is established pursuant to a consent decree entered by a judge of a United States District Court,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43974179-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468B/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is created for the receipt of settlement payments as directed by a government entity for the sole purpose of resolving or satisfying one or more claims asserting liability under the Comprehensive Environmental Response, Compensation, and Liability Act of 1980,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4397417a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468B/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authority and control over the expenditure of funds therein (including the expenditure of contributions thereto and any net earnings thereon) is with such government entity, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4397417b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s468B/g/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon termination, any remaining funds will be disbursed to such government entity for use in accordance with applicable law.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of this paragraph, the term “government entity” means the United States, any State or political subdivision thereof, the District of Columbia, any possession of the United States, and any agency or instrumentality of any of the foregoing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4399b17c-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVIII/s1807/a/7/A"},"text":"Pub. L. 99–514, title XVIII, § 1807(a)(7)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2814"},"text":"100 Stat. 2814","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1018/f/1"},"text":"Pub. L. 100–647, title I, § 1018(f)(1)","children":[],"tail":", (2), (4), (5)(A), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3582"},"text":"102 Stat. 3582","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11702/e/1"},"text":"Pub. L. 101–508, title XI, § 11702(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-515"},"text":"104 Stat. 1388–515","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/222/tII/s201/a"},"text":"Pub. L. 109–222, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-05-17"},"text":"May 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/347"},"text":"120 Stat. 347","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/432/dA/tIV/s409/a"},"text":"Pub. L. 109–432, div. A, title IV, § 409(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2963"},"text":"120 Stat. 2963","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4399b17d-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4399b17e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4399b17f-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Comprehensive Environmental Response, Compensation, and Liability Act of 1980, referred to in subsec. (g)(2)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/510"},"text":"Pub. L. 96–510","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-11"},"text":"Dec. 11, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2767"},"text":"94 Stat. 2767","children":[],"tail":", which is classified principally to chapter 103 (§ 9601 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9601"},"text":"section 9601 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4399b180-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/222"},"text":"Pub. L. 109–222","children":[],"tail":" reenacted heading without change and amended text of subsec. (g) generally. Prior to amendment, text read as follows: “Nothing in any provision of law shall be construed as providing that an escrow account, settlement fund, or similar fund is not subject to current income tax. The Secretary shall prescribe regulations providing for the taxation of any such account or fund whether as a grantor trust or otherwise.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432"},"text":"Pub. L. 109–432","children":[],"tail":" struck out heading and text of par. (3). Text read as follows: “Paragraph (2) shall not apply to accounts and funds established after "},{"tag":"date","attrib":{"date":"2010-12-31"},"text":"December 31, 2010","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" substituted “This section (other than subsection (g))” for “This section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1018/f/4/B"},"text":"Pub. L. 100–647, § 1018(f)(4)(B)","children":[],"tail":", substituted “No other” for “no other” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1018/f/4/A"},"text":"Pub. L. 100–647, § 1018(f)(4)(A)","children":[],"tail":", substituted “a corporation.” for “the corporation,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1018/f/1"},"text":"Pub. L. 100–647, § 1018(f)(1)","children":[],"tail":", inserted “(or any related person)” after “taxpayer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1018/f/2"},"text":"Pub. L. 100–647, § 1018(f)(2)","children":[],"tail":", amended subpar. (A) generally. Prior to amendment, subpar. (A) read as follows: “which is established pursuant to a court order,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1018/f/1"},"text":"Pub. L. 100–647, § 1018(f)(1)","children":[],"tail":", inserted “(or any related person)” after “taxpayer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1018/f/5/A"},"text":"Pub. L. 100–647, § 1018(f)(5)(A)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4399b181-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4399b182-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/432/dA/tIV/s409/b"},"text":"Pub. L. 109–432, div. A, title IV, § 409(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2963"},"text":"120 Stat. 2963","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/432/dA/tIV/s409/b"},"text":"“The amendment made by this section [amending this section] shall take effect as if included in section 201 of the Tax Increase Prevention and Reconciliation Act of 2005 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/222"},"text":"Pub. L. 109–222","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/222/tII/s201/b"},"text":"Pub. L. 109–222, title II, § 201(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-05-17"},"text":"May 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/348"},"text":"120 Stat. 348","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/222/tII/s201/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply to accounts and funds established after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2006-05-17"},"text":"May 17, 2006","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4399b183-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" effective as if included in the provision of the Technical and Miscellaneous Revenue Act of 1988, "},{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/s11702/j"},"text":"section 11702(j) of Pub. L. 101–508","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s59"},"text":"section 59 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4399b184-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1019/a"},"text":"section 1019(a) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4399b185-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective, except as otherwise provided, as if included in the provisions of the Tax Reform Act of 1984, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA"},"text":"Pub. L. 98–369, div. A","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1881"},"text":"section 1881 of Pub. L. 99–514","children":[],"tail":", set out as an Effective Date of 1986 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s48"},"text":"section 48 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4399b186-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Plan Amendments Not Required Until January 1, 1989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions directing that if any amendments made by subtitle A or subtitle C of title XI [§§ 1101–1147 and 1171–1177] or title XVIII [§§ 1800–1899A] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" require an amendment to any plan, such plan amendment shall not be required to be made before the first plan year beginning on or after "},{"tag":"date","attrib":{"date":"1989-01-01"},"text":"Jan. 1, 1989","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1140"},"text":"section 1140 of Pub. L. 99–514","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s401"},"text":"section 401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4399b187-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Special Rule for Taxpayer in Bankruptcy Reorganization","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVIII/s1807/a/7/C"},"text":"Pub. L. 99–514, title XVIII, § 1807(a)(7)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2816"},"text":"100 Stat. 2816","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1018/f/3"},"text":"Pub. L. 100–647, title I, § 1018(f)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3582"},"text":"102 Stat. 3582","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/647/tI/s1018/f/3"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In the case of any settlement fund which is established for claimants against a corporation which filed a petition for reorganization under chapter 11 of title 11, United States Code, on ","children":[{"tag":"date","attrib":{"date":"1982-08-26"},"text":"August 26, 1982","children":[],"tail":", and which filed with a United States district court a first amended and restated plan of reorganization before "},{"tag":"date","attrib":{"date":"1986-03-01"},"text":"March 1, 1986","children":[],"tail":"—"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any portion of such fund which is established pursuant to a court order and with qualified payments, which meets the requirements of subparagraphs (C) and (D) of section 468B(d)(2) of the Internal Revenue Code of 1954 [now 1986] (as added by this paragraph), and with respect to which an election is made under subparagraph (F) thereof, shall be treated as a designated settlement fund for purposes of section 468B of such Code,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such corporation (or any successor thereof) shall be liable for the tax imposed by section 468B of such Code on such portion of the fund (and the fund shall not be liable for such tax), such tax shall be deductible by the corporation, and the rate of tax under section 468B of such Code for any taxable year shall be equal to 15 percent, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any transaction by any portion of the fund not described in clause (i) shall be treated as a transaction made by the corporation.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4399b188-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Clarification of Law With Respect to Certain Funds","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVIII/s1807/a/7/D"},"text":"Pub. L. 99–514, title XVIII, § 1807(a)(7)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2816"},"text":"100 Stat. 2816","children":[],"tail":", provided that nothing in any provision of law be construed as providing that an escrow account, settlement fund, or similar fund established after "},{"tag":"date","attrib":{"date":"1986-08-16"},"text":"Aug. 16, 1986","children":[],"tail":", not be subject to current income tax and that if contributions to such account or fund are not deductible then the account or fund be taxed as a grantor trust, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1018/f/5/B"},"text":"Pub. L. 100–647, title I, § 1018(f)(5)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3582"},"text":"102 Stat. 3582","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
