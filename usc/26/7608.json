{"tag":"section","attrib":{"id":"id47773a48-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608"},"text":null,"children":[{"tag":"num","attrib":{"value":"7608"},"text":"§ 7608.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of internal revenue enforcement officers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47773a49-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement of subtitle E and other laws pertaining to liquor, tobacco, and firearms","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any investigator, agent, or other internal revenue officer by whatever term designated, whom the Secretary charges with the duty of enforcing any of the criminal, seizure, or forfeiture provisions of subtitle E or of any other law of the United States pertaining to the commodities subject to tax under such subtitle for the enforcement of which the Secretary is responsible, may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47773a4a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry firearms;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47773a4b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" execute and serve search warrants and arrest warrants, and serve subpoenas and summonses issued under authority of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47773a4c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in respect to the performance of such duty, make arrests without warrant for any offense against the United States committed in his presence, or for any felony cognizable under the laws of the United States if he has reasonable grounds to believe that the person to be arrested has committed, or is committing, such felony; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47773a4d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in respect to the performance of such duty, make seizures of property subject to forfeiture to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47773a4e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement of laws relating to internal revenue other than subtitle E","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47773a4f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any criminal investigator of the Intelligence Division of the Internal Revenue Service whom the Secretary charges with the duty of enforcing any of the criminal provisions of the internal revenue laws, any other criminal provisions of law relating to internal revenue for the enforcement of which the Secretary is responsible, or any other law for which the Secretary has delegated investigatory authority to the Internal Revenue Service, is, in the performance of his duties, authorized to perform the functions described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47773a50-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The functions authorized under this subsection to be performed by an officer referred to in paragraph (1) are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47773a51-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to execute and serve search warrants and arrest warrants, and serve subpoenas and summonses issued under authority of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47773a52-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make arrests without warrant for any offense against the United States relating to the internal revenue laws committed in his presence, or for any felony cognizable under such laws if he has reasonable grounds to believe that the person to be arrested has committed or is committing any such felony; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47773a53-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make seizures of property subject to forfeiture under the internal revenue laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47773a54-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules relating to undercover operations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47773a55-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification required for exemption of undercover operations from certain laws","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to any undercover investigative operation of the Internal Revenue Service (hereinafter in this subsection referred to as the “Service”) which is necessary for the detection and prosecution of offenses under the internal revenue laws, any other criminal provisions of law relating to internal revenue, or any other law for which the Secretary has delegated investigatory authority to the Internal Revenue Service—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47773a56-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" sums authorized to be appropriated for the Service may be used—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47773a57-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to purchase property, buildings, and other facilities, and to lease space, within the United States, the District of Columbia, and the territories and possessions of the United States without regard to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id47773a58-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/c/1/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 1341 and 3324 of title 31, United States Code,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id47773a59-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/c/1/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 6301(a) and (b)(1)–(3) and 6306 of title 41, United States Code,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id47773a5a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/c/1/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 45 of title 41, United States Code,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id47773a5b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/c/1/A/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s8141"},"text":"section 8141 of title 40","children":[],"tail":", United States Code, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id47773a5c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/c/1/A/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s3901"},"text":"section 3901 of title 41","children":[],"tail":", United States Code, and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47773a5d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish or to acquire proprietary corporations or business entities as part of the undercover operation, and to operate such corporations or business entities on a commercial basis, without regard to sections 9102 and 9103 of title 31, United States Code;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47773a5e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sums authorized to be appropriated for the Service and the proceeds from the undercover operations may be deposited in banks or other financial institutions without regard to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s648"},"text":"section 648 of title 18","children":[],"tail":", United States Code, and "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302"},"text":"section 3302 of title 31","children":[],"tail":", United States Code, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47773a5f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proceeds from the undercover operation may be used to offset necessary and reasonable expenses incurred in such operation without regard to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302"},"text":"section 3302 of title 31","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"This paragraph shall apply only upon the written certification of the Commissioner of Internal Revenue (or, if designated by the Commissioner, the Deputy Commissioner or an Assistant Commissioner of Internal Revenue) that any action authorized by subparagraph (A), (B), or (C) is necessary for the conduct of such undercover operation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47773a60-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liquidation of corporations and business entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a corporation or business entity established or acquired as part of an undercover operation under subparagraph (B) of paragraph (1) with a net value over $50,000 is to be liquidated, sold, or otherwise disposed of, the Service, as much in advance as the Commissioner or his delegate determines is practicable, shall report the circumstances to the Secretary. The proceeds of the liquidation, sale, or other disposition, after obligations are met, shall be deposited in the Treasury of the United States as miscellaneous receipts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47773a61-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of proceeds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as the proceeds from an undercover investigative operation with respect to which an action is authorized and carried out under subparagraphs (B) and (C) of paragraph (1) are no longer necessary for the conduct of such operation, such proceeds or the balance of such proceeds remaining at the time shall be deposited into the Treasury of the United States as miscellaneous receipts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47773a62-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audits","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47773a63-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Service shall conduct a detailed financial audit of each undercover investigative operation which is closed in each fiscal year; and","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47773a64-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/c/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit the results of the audit in writing to the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47773a65-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/c/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 180 days after such undercover operation is closed, submit a report to the Congress concerning such audit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47773a66-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Service shall also submit a report annually to the Congress specifying as to its undercover investigative operations—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47773a67-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/c/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number, by programs, of undercover investigative operations pending as of the end of the 1-year period for which such report is submitted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47773a68-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/c/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number, by programs, of undercover investigative operations commenced in the 1-year period for which such report is submitted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47773a69-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/c/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number, by programs, of undercover investigative operations closed in the 1-year period for which such report is submitted, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47773a6a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/c/4/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the following information with respect to each undercover investigative operation pending as of the end of the 1-year period for which such report is submitted or closed during such 1-year period—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id47773a6b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/c/4/B/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date the operation began and the date of the certification referred to in the last sentence of paragraph (1),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id47773a6c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/c/4/B/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total expenditures under the operation and the amount and use of the proceeds from the operation,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id47773a6d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/c/4/B/iv/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed description of the operation including the potential violation being investigated and whether the operation is being conducted under grand jury auspices, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id47773a6e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/c/4/B/iv/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of the operation including the results of criminal proceedings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47773a6f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (4)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47773a70-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Closed","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “closed” means the date on which the later of the following occurs;","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47773a71-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/c/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all criminal proceedings (other than appeals) are concluded, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47773a72-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/c/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" covert activities are concluded, whichever occurs later.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47773a73-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “employees” has the meaning given such term by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2105"},"text":"section 2105 of title 5","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47773a74-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7608/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Undercover investigative operation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “undercover investigative operation” means any undercover investigative operation of the Service; except that, for purposes of subparagraphs (A) and (C) of paragraph (4), such term only includes an operation which is exempt from section 3302 or 9102 of title 31, United States Code.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47773a75-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s204/14"},"text":"Pub. L. 85–859, title II, § 204(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1429"},"text":"72 Stat. 1429","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/87/863/s6/a"},"text":"Pub. L. 87–863, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-23"},"text":"Oct. 23, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1143"},"text":"76 Stat. 1143","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7601/c/1"},"text":"Pub. L. 100–690, title VII, § 7601(c)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4504"},"text":"102 Stat. 4504","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11704/a/32"},"text":"Pub. L. 101–508, title XI, § 11704(a)(32)","children":[],"tail":", (33), "},{