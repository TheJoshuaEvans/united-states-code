{"tag":"section","attrib":{"id":"id4479d820-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s932"},"text":null,"children":[{"tag":"num","attrib":{"value":"932"},"text":"§ 932.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of United States and Virgin Islands income taxes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4479d821-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s932/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of United States residents","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4479d822-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s932/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of subsection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This subsection shall apply to an individual for the taxable year if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4479d823-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s932/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such individual—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4479d824-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s932/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a citizen or resident of the United States (other than a bona fide resident of the Virgin Islands during the entire taxable year), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4479d825-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s932/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has income derived from sources within the Virgin Islands, or effectively connected with the conduct of a trade or business within such possession, for the taxable year, or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4479d826-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s932/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such individual files a joint return for the taxable year with an individual described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4479d827-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s932/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filing requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each individual to whom this subsection applies for the taxable year shall file his income tax return for the taxable year with both the United States and the Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4479d828-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s932/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extent of income tax liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an individual to whom this subsection applies in a taxable year for purposes of so much of this title (other than this section and section 7654) as relates to the taxes imposed by this chapter, the United States shall be treated as including the Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4479d829-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s932/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Portion of United States tax liability payable to the Virgin Islands","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4479d82a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s932/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each individual to whom subsection (a) applies for the taxable year shall pay the applicable percentage of the taxes imposed by this chapter for such taxable year (determined without regard to paragraph (3)) to the Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4479d82b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s932/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable percentage","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4479d82c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s932/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1), the term “applicable percentage” means the percentage which Virgin Islands adjusted gross income bears to adjusted gross income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4479d82d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s932/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Virgin Islands adjusted gross income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A), the term “Virgin Islands adjusted gross income” means adjusted gross income determined by taking into account only income derived from sources within the Virgin Islands and deductions properly apportioned or allocable thereto.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4479d82e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s932/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts paid allowed as credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be allowed as a credit against the tax imposed by this chapter for the taxable year an amount equal to the taxes required to be paid to the Virgin Islands under paragraph (1) which are so paid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4479d82f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s932/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of Virgin Islands residents","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4479d830-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s932/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of subsection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This subsection shall apply to an individual for the taxable year if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4479d831-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s932/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such individual is a bona fide resident of the Virgin Islands during the entire taxable year, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4479d832-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s932/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such individual files a joint return for the taxable year with an individual described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4479d833-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s932/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filing requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each individual to whom this subsection applies for the taxable year shall file an income tax return for the taxable year with the Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4479d834-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s932/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extent of income tax liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an individual to whom this subsection applies in a taxable year for purposes of so much of this title (other than this section and section 7654) as relates to the taxes imposed by this chapter, the Virgin Islands shall be treated as including the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4479d835-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s932/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Residents of the Virgin Islands","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of an individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4479d836-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s932/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is a bona fide resident of the Virgin Islands during the entire taxable year,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4479d837-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s932/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who, on his return of income tax to the Virgin Islands, reports income from all sources and identifies the source of each item shown on such return, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4479d838-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s932/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who fully pays his tax liability referred to in section 934(a) to the Virgin Islands with respect to such income,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"for purposes of calculating income tax liability to the United States, gross income shall not include any amount included in gross income on such return, and allocable deductions and credits shall not be taken into account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4479d839-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s932/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for joint returns","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a joint return, this section shall be applied on the basis of the residence of the spouse who has the greater adjusted gross income (determined without regard to community property laws) for the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4479d83a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s932/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for applying section to tax imposed in Virgin Islands","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In applying this section for purposes of determining income tax liability incurred to the Virgin Islands, the provisions of this section shall not be affected by the provisions of Federal law referred to in section 934(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4479d83b-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXII/s1274/a"},"text":"Pub. L. 99–514, title XII, § 1274(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2596"},"text":"100 Stat. 2596","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1012/w/1"},"text":"Pub. L. 100–647, title I, § 1012(w)(1)","children":[],"tail":"–(3), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3530"},"text":"102 Stat. 3530","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s908/c/2"},"text":"Pub. L. 108–357, title VIII, § 908(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1656"},"text":"118 Stat. 1656","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4479d83c-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4479d83d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4479d83e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 932, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/292"},"text":"68A Stat. 292","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1966-11-13"},"text":"Nov. 13, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/89/809/tI/s103/m"},"text":"Pub. L. 89–809, title I, § 103(m)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1554"},"text":"80 Stat. 1554","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1972-10-31"},"text":"Oct. 31, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/92/606/s1/f/2"},"text":"Pub. L. 92–606, § 1(f)(2)","children":[],"tail":", (3), "},{"tag":"ref","attrib":{"href":"/us/stat/86/1497"},"text":"86 Stat. 1497","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/tXII/s12103/a"},"text":"Pub. L. 99–272, title XII, § 12103(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/285"},"text":"100 Stat. 285","children":[],"tail":", related to income taxation of citizens of possessions of the United States, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXII/s1272/d/1"},"text":"Pub. L. 99–514, title XII, § 1272(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2594"},"text":"100 Stat. 2594","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4479d83f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsecs. (a)(1)(A)(i), (c)(1)(A), (4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":" substituted “during the entire taxable year” for “at the close of the taxable year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1012/w/3"},"text":"Pub. L. 100–647, § 1012(w)(3)","children":[],"tail":", substituted “an income tax return” for “his income tax return”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1012/w/2"},"text":"Pub. L. 100–647, § 1012(w)(2)","children":[],"tail":", amended par. (4) generally. Prior to amendment, par. (4) read as follows: “In the case of an individual who is a bona fide resident of the Virgin Islands at the close of the taxable year and who, on his return of income tax to the Virgin Islands, reports income from all sources and identifies the source of each item shown on such return, for purposes of calculating income tax liability to the United States gross income shall not include any amount included in gross income on such return.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1012/w/1"},"text":"Pub. L. 100–647, § 1012(w)(1)","children":[],"tail":", substituted current heading for “Section not to apply to tax imposed in Virgin Islands” and amended text generally. Prior to amendment, text read as follows: “This section shall not apply for purposes of determining income tax liability incurred to the Virgin Islands.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4479d840-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4479d841-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":" applicable to taxable years ending after "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/s908/d/1"},"text":"section 908(d)(1) of Pub. L. 108–357","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s937"},"text":"section 937 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4479d842-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1019/a"},"text":"section 1019(a) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4479d843-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Enactment of section 932 and repeal of prior section 932 applicable to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"Dec. 31, 1986","children":[],"tail":", with certain exceptions and qualifications, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1277"},"text":"section 1277 of Pub. L. 99–514","children":[],"tail":", set out as an Effective Date of 1986 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s931"},"text":"section 931 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4479d844-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXII/s1274/c"},"text":"Pub. L. 99–514, title XII, § 1274(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2598"},"text":"100 Stat. 2598","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1012/w/4"},"text":"Pub. L. 100–647, title I, § 1012(w)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3530"},"text":"102 Stat. 3530","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/647/tI/s1012/w/4"},"text":"“The Secretary of the Treasury or his delegate shall prescribe such regulations as may be necessary or appropriate for applying the Internal Revenue Code of 1986 [this title] for purposes of determining tax liability incurred to the Virgin Islands.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4479d845-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authority To Impose Nondiscriminatory Local Income Taxes","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXII/s1274/b"},"text":"Pub. L. 99–514, title XII, § 1274(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2597"},"text":"100 Stat. 2597","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/tXII/s1274/b"},"text":"“Nothing in any provision of Federal law shall prevent the Virgin Islands from imposing on any person nondiscriminatory local income taxes. Any taxes so imposed shall be treated in the same manner as State and local income taxes under section 164 of the Internal Revenue Code of 1954 [now 1986] and shall not be treated as taxes to which section 901 of such Code applies.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
