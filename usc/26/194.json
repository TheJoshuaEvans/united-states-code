{"tag":"section","attrib":{"id":"id4219c90d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s194"},"text":null,"children":[{"tag":"num","attrib":{"value":"194"},"text":"§ 194.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of reforestation expenditures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4219c90e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s194/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowance of deduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any qualified timber property with respect to which the taxpayer has made (in accordance with regulations prescribed by the Secretary) an election under this subsection, the taxpayer shall be entitled to a deduction with respect to the amortization of the amortizable basis of qualified timber property based on a period of 84 months. Such amortization deduction shall be an amount, with respect to each month of such period within the taxable year, equal to the amortizable basis at the end of such month divided by the number of months (including the month for which the deduction is computed) remaining in the period. Such amortizable basis at the end of the month shall be computed without regard to the amortization deduction for such month. The 84-month period shall begin on the first day of the first month of the second half of the taxable year in which the amortizable basis is acquired.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id421c11ff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s194/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment as expenses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id421c1200-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s194/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election to treat certain reforestation expenditures as expenses","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id421c1201-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s194/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any qualified timber property with respect to which the taxpayer has made (in accordance with regulations prescribed by the Secretary) an election under this subsection, the taxpayer shall treat reforestation expenditures which are paid or incurred during the taxable year with respect to such property as an expense which is not chargeable to capital account. The reforestation expenditures so treated shall be allowed as a deduction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id421c1202-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s194/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dollar limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The aggregate amount of reforestation expenditures which may be taken into account under subparagraph (A) with respect to each qualified timber property for any taxable year shall not exceed—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id421c1203-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s194/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in clause (ii) or (iii), $10,000,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id421c1204-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s194/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a separate return by a married individual (as defined in section 7703), $5,000, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id421c1205-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s194/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a trust, zero.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id421c1206-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s194/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of dollar limit","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id421c1207-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s194/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Controlled group","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of applying the dollar limitation under paragraph (1)(B)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id421c1208-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s194/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all component members of a controlled group shall be treated as one taxpayer, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id421c1209-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s194/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall, under regulations prescribed by him, apportion such dollar limitation among the component members of such controlled group.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of the preceding sentence, the term “controlled group” has the meaning assigned to it by section 1563(a), except that the phrase “more than 50 percent” shall be substituted for the phrase “at least 80 percent” each place it appears in section 1563(a)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id421c120a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s194/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnerships and S corporations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a partnership, the dollar limitation contained in paragraph (1)(B) shall apply with respect to the partnership and with respect to each partner. A similar rule shall apply in the case of an S corporation and its shareholders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id421c120b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s194/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and special rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id421c120c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s194/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified timber property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified timber property” means a woodlot or other site located in the United States which will contain trees in significant commercial quantities and which is held by the taxpayer for the planting, cultivating, caring for, and cutting of trees for sale or use in the commercial production of timber products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id421c120d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s194/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amortizable basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “amortizable basis” means that portion of the basis of the qualified timber property attributable to reforestation expenditures which have not been taken into account under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id421c120e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s194/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reforestation expenditures","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id421c120f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s194/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “reforestation expenditures” means direct costs incurred in connection with forestation or reforestation by planting or artificial or natural seeding, including costs—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id421c1210-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s194/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the preparation of the site;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id421c1211-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s194/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of seeds or seedlings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id421c1212-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s194/c/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for labor and tools, including depreciation of equipment such as tractors, trucks, tree planters, and similar machines used in planting or seeding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id421c1213-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s194/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-sharing programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Reforestation expenditures shall not include any expenditures for which the taxpayer has been reimbursed under any governmental reforestation cost-sharing program unless the amounts reimbursed have been included in the gross income of the taxpayer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id421c1214-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s194/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of trusts and estates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The aggregate amount of reforestation expenditures incurred by any trust or estate shall be apportioned between the income beneficiaries and the fiduciary under regulations prescribed by the Secretary. Any amount so apportioned to a beneficiary shall be taken into account as expenditures incurred by such beneficiary in applying this section to such beneficiary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id421c1215-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s194/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application with other deductions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No deduction shall be allowed under any other provision of this chapter with respect to any expenditure with respect to which a deduction is allowed or allowable under this section to the taxpayer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id421c1216-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s194/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Life tenant and remainderman","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of property held by one person for life with remainder to another person, the deduction under this section shall be computed as if the life tenant were the absolute owner of the property and shall be allowed to the life tenant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id421c1217-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/451/tIII/s301/a"},"text":"Pub. L. 96–451, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-14"},"text":"Oct. 14, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1989"},"text":"94 Stat. 1989","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/354/s3/g"},"text":"Pub. L. 97–354, § 3(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-19"},"text":"Oct. 19, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1689"},"text":"96 Stat. 1689","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXIII/s1301/j/8"},"text":"Pub. L. 99–514, title XIII, § 1301(j)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2658"},"text":"100 Stat. 2658","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tIII/s322/a"},"text":"Pub. L. 108–357, title III, § 322(a)","children":[],"tail":"–(c)(4), "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1474"},"text":"118 Stat. 1474","children":[],"tail":", 1475; "},{"tag":"ref","attrib":{"href":"/us/pl/109/135/tIV/s403/i/1"},"text":"Pub. L. 109–135, title IV, § 403(i)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-21"},"text":"Dec. 21, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2624"},"text":"119 Stat. 2624","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id421c1218-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id421c1219-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id421c121a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 194 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s194A"},"text":"section 194A of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id421c121b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/135/s403/i/1/A"},"text":"Pub. L. 109–135, § 403(i)(1)(A)","children":[],"tail":", reenacted heading without change and amended text generally. Prior to amendment, text read as follows: “The aggregate amount of reforestation expenditures which may be taken into account under subparagraph (A) with respect to each qualified timber property for any taxable year shall not exceed $10,000 ($5,000 in the case of a separate return by a married individual (as defined in section 7703)).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/135/s403/i/1/B"},"text":"Pub. L. 109–135, § 403(i)(1)(B)","children":[],"tail":", reenacted heading without change and amended text generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—Except as provided in subparagraph (B), this section shall not apply to trusts and estates."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) ","children":[{"tag":"inline","attrib":{},"text":"Amortization deduction allowed to estates","children":[],"tail":".—The benefit of the deduction for amortization provided by subsection (a) shall be allowed to estates in the same manner as in the case of an individual. The allowable deduction shall be apportioned between the income beneficiary and the fiduciary under regulations prescribed by the Secretary. Any amount so apportioned to a beneficiary shall be taken into account for purposes of determining the amount allowable as a deduction under subsection (a) to such beneficiary.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s322/c/4"},"text":"Pub. L. 108–357, § 322(c)(4)","children":[],"tail":", substituted “Treatment” for “Amortization” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s322/a"},"text":"Pub. L. 108–357, § 322(a)","children":[],"tail":", substituted “Treatment as expenses” for “Limitations” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s322/a"},"text":"Pub. L. 108–357, § 322(a)","children":[],"tail":", amended heading and text of par. (1) generally. Prior to amendment, text read as follows: “The aggregate amount of amortizable basis acquired during the taxable year which may be taken into account under subsection (a) for such taxable year shall not exceed $10,000 ($5,000 in the case of a separate return by a married individual (as defined in section 7703)).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s322/c/2"},"text":"Pub. L. 108–357, § 322(c)(2)","children":[],"tail":", substituted “paragraph (1)(B)” for “paragraph (1)” in introductory provisions of subpar. (A) and in subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s322/c/1"},"text":"Pub. L. 108–357, § 322(c)(1)","children":[],"tail":", struck out pars. (3) and (4) which related to inapplicability of section to trusts and applicability of section to estates, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s322/b"},"text":"Pub. L. 108–357, § 322(b)","children":[],"tail":", inserted “which have not been taken into account under subsection (b)” after “expenditures”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s322/c/3"},"text":"Pub. L. 108–357, § 322(c)(3)","children":[],"tail":", added pars. (4) and (5) and struck out former par. (4) which related to basis allocation if the amount of the amortizable basis acquired during the taxable year of all qualified timber property with respect to which the taxpayer had made an election under subsec. (a) exceeded the amount of the limitation under subsec. (b)(1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “section 7703” for “section 143”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/354"},"text":"Pub. L. 97–354","children":[],"tail":" substituted “Partnerships and S corporations” for “Partnerships” in heading, and inserted “A similar rule shall apply in the case of an S corporation and its shareholders.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id421c121c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{