{"tag":"section","attrib":{"id":"id44abe4a3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1036"},"text":null,"children":[{"tag":"num","attrib":{"value":"1036"},"text":"§ 1036.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stock for stock of same corporation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44abe4a4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1036/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No gain or loss shall be recognized if common stock in a corporation is exchanged solely for common stock in the same corporation, or if preferred stock in a corporation is exchanged solely for preferred stock in the same corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44abe4a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1036/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonqualified preferred stock not treated as stock","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, nonqualified preferred stock (as defined in section 351(g)(2)) shall be treated as property other than stock.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44abe4a6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1036/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross references","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44abe4a7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1036/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For rules relating to recognition of gain or loss where an exchange is not solely in kind, see subsections (b) and (c) of section 1031.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44abe4a8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1036/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For rules relating to the basis of property acquired in an exchange described in subsection (a), see subsection (d) of section 1031.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44abe4a9-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/309"},"text":"68A Stat. 309","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tX/s1014/e/3"},"text":"Pub. L. 105–34, title X, § 1014(e)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/921"},"text":"111 Stat. 921","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44abe4aa-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44abe4ab-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44abe4ac-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" added subsec. (b) and redesignated former subsec. (b) as (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44abe4ad-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44abe4ae-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" applicable, with certain exceptions, to transactions after "},{"tag":"date","attrib":{"date":"1997-06-08"},"text":"June 8, 1997","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1014/f"},"text":"section 1014(f) of Pub. L. 105–34","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s351"},"text":"section 351 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
