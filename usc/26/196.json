ag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id421e8368-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 280C(c)(3), referred to in subsec. (c)(4), was redesignated section 280C(c)(2) by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13206/d/2/C"},"text":"Pub. L. 115–97, title I, § 13206(d)(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2113"},"text":"131 Stat. 2113","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id421e8369-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s339/e"},"text":"section 339(e) of Pub. L. 108–357","children":[],"tail":" amended the table of sections for subpart D of part IV of subchapter A of this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id421e836a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":", in heading, struck out “and research credit” after “tax credit” and, in text, substituted “in the case of the investment credit determined under section 46 (other than the rehabilitation credit).” for “in the case of—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) the investment credit determined under section 46 (other than the rehabilitation credit), and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) the research credit determined under section 41(a) for a taxable year beginning before ","children":[{"tag":"date","attrib":{"date":"1990-01-01"},"text":"January 1, 1990","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (c)(14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" added par. (14)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (c)(13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":" added par. (13)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (c)(11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s302/c/2"},"text":"Pub. L. 108–357, § 302(c)(2)","children":[],"tail":", added par. (11)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s339/e"},"text":"Pub. L. 108–357, § 339(e)","children":[],"tail":", added par. (12)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (c)(10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16"},"text":"Pub. L. 107–16","children":[],"tail":" added par. (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (c)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554"},"text":"Pub. L. 106–554","children":[],"tail":" added par. (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (c)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206"},"text":"Pub. L. 105–206","children":[],"tail":" added par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":" substituted “work opportunity credit” for “targeted jobs credit”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (c)(6). ","children":[{"ta