{"tag":"section","attrib":{"id":"id421c1252-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s196"},"text":null,"children":[{"tag":"num","attrib":{"value":"196"},"text":"§ 196.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deduction for certain unused business credits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id421c1253-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s196/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowance of deduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any portion of the qualified business credits determined for any taxable year has not, after the application of section 38(c), been allowed to the taxpayer as a credit under section 38 for any taxable year, an amount equal to the credit not so allowed shall be allowed to the taxpayer as a deduction for the first taxable year following the last taxable year for which such credit could, under section 39, have been allowed as a credit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id421c1254-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s196/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxpayer’s dying or ceasing to exist","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a taxpayer dies or ceases to exist before the first taxable year following the last taxable year for which the qualified business credits could, under section 39, have been allowed as a credit, the amount described in subsection (a) (or the proper portion thereof) shall, under regulations prescribed by the Secretary, be allowed to the taxpayer as a deduction for the taxable year in which such death or cessation occurs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id421e8355-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s196/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified business credits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “qualified business credits” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id421e8356-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s196/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the investment credit determined under section 46 (but only to the extent attributable to property the basis of which is reduced by section 50(c)),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id421e8357-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s196/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the work opportunity credit determined under section 51(a),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id421e8358-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s196/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the alcohol fuels credit determined under section 40(a),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id421e8359-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s196/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the research credit determined under section 41(a) (other than such credit determined under section 280C(c)(3)) ","children":[{"tag":"ref","attrib":{"idref":"fn002085"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002085"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" for taxable years beginning after "},{"tag":"date","attrib":{"date":"1988-12-31"},"text":"December 31, 1988","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id421e835a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s196/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the enhanced oil recovery credit determined under section 43(a),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id421e835b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s196/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the empowerment zone employment credit determined under section 1396(a),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id421e835c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s196/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Indian employment credit determined under section 45A(a),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id421e835d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s196/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employer Social Security credit determined under section 45B(a),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id421e835e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s196/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the new markets tax credit determined under section 45D(a),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id421e835f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s196/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the small employer pension plan startup cost credit determined under section 45E(a),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id421e8360-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s196/c/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the biodiesel fuels credit determined under section 40A(a),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id421e8361-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s196/c/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the low sulfur diesel fuel production credit determined under section 45H(a),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id421e8362-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s196/c/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the new energy efficient home credit determined under section 45L(a), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id421e8363-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s196/c/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the small employer health insurance credit determined under section 45R(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id421e8364-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s196/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for investment tax credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall be applied by substituting “an amount equal to 50 percent of” for “an amount equal to” in the case of the investment credit determined under section 46 (other than the rehabilitation credit).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id421e8365-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/tII/s205/a/2"},"text":"Pub. L. 97–248, title II, § 205(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/428"},"text":"96 Stat. 428","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tIV/s474/r/8/A"},"text":"Pub. L. 98–369, div. A, title IV, § 474(r)(8)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/840"},"text":"98 Stat. 840","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tIV/s4008/b/2"},"text":"Pub. L. 100–647, title IV, § 4008(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3653"},"text":"102 Stat. 3653","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII"},"text":"Pub. L. 101–239, titl