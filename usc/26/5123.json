{"tag":"section","attrib":{"id":"id46295d65-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5123"},"text":null,"children":[{"tag":"num","attrib":{"value":"5123"},"text":"§ 5123.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation and inspection of records, and entry of premises for inspection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46295d66-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5123/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation and inspection of records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any records or other documents required to be kept under this part or regulations issued pursuant thereto shall be preserved by the person required to keep such records or documents, as the Secretary may by regulations prescribe, and shall be kept available for inspection by any internal revenue officer during business hours.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46295d67-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5123/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entry of premises for inspection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may enter during business hours the premises (including places of storage) of any dealer for the purpose of inspecting or examining any records or other documents required to be kept by such dealer under this chapter or regulations issued pursuant thereto and any distilled spirits, wines, or beer kept or stored by such dealer on such premises.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46295d6