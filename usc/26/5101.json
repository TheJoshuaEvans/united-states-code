{"tag":"section","attrib":{"id":"id4626ebf3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5101"},"text":null,"children":[{"tag":"num","attrib":{"value":"5101"},"text":"§ 5101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of manufacture of still; notice of set up of still","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4626ebf4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4626ebf5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5101/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of manufacture of still","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, pursuant to regulations, require any person who manufactures any still, boiler, or other vessel to be used for the purpose of distilling, to give written notice, before the still, boiler, or other vessel is removed from the place of manufacture, setting forth by whom it is to be used, its capacity, and the time of removal from the place of manufacture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4626ebf6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5101/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of set up of still","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, pursuant to regulations, require that no still, boiler, or other vessel be set up without the manufacturer of the still, boiler, or other vessel first giving written notice to the Secretary of that purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4626ebf7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties, etc.","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4626ebf8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5101/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For penalty and forfeiture for failure to give notice of manufacture, or for setting up a still without first giving notice, when required by the Secretary, see sections 5615(2) and 5687.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4626ebf9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5101/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For penalty and forfeiture for failure to register still or distilling apparatus when set up, see section 5601(a)(1) and 5615(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4626ebfa-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tIV/s451/a"},"text":"Pub. L. 98–369, div. A, title IV, § 451(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/818"},"text":"98 Stat. 818","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4626ebfb-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4626ebfc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4626ebfd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5101, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1339"},"text":"72 Stat. 1339","children":[],"tail":", contained provisions relating to imposition and rate of tax, prior to the general revision of this subpart by "},{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 5101, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/617"},"text":"68A Stat. 617","children":[],"tail":", related to special tax on manufacturers of stills, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4626ebfe-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4626ebff-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[