{"tag":"section","attrib":{"id":"id4501a5f7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398"},"text":null,"children":[{"tag":"num","attrib":{"value":"1398"},"text":"§ 1398.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules relating to individuals’ title 11 cases","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4501a5f8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cases to which section applies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b), this section shall apply to any case under chapter 7 (relating to liquidations) or chapter 11 (relating to reorganizations) of title 11 of the United States Code in which the debtor is an individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4501a5f9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions where case is dismissed, etc.","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4501a5fa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Section does not apply where case is dismissed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply if the case under chapter 7 or 11 of title 11 of the United States Code is dismissed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4501a5fb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Section does not apply at partnership level","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsection (a), a partnership shall not be treated as an individual, but the interest in a partnership of a debtor who is an individual shall be taken into account under this section in the same manner as any other interest of the debtor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4501a5fc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation and payment of tax; basic standard deduction","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4501a5fd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation and payment of tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this section, the taxable income of the estate shall be computed in the same manner as for an individual. The tax shall be computed on such taxable income and shall be paid by the trustee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4501a5fe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax rates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tax on the taxable income of the estate shall be determined under subsection (d) of section 1.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4501a5ff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basic standard deduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an estate which does not itemize deductions, the basic standard deduction for the estate for the taxable year shall be the same as for a married individual filing a separate return for such year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4501a600-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable year of debtors","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4501a601-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), the taxable year of the debtor shall be determined without regard to the case under title 11 of the United States Code to which this section applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4501a602-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election to terminate debtor’s year when case commences","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4501a603-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding section 442, the debtor may (without the approval of the Secretary) elect to treat the debtor’s taxable year which includes the commencement date as 2 taxable years—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4501a604-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first of which ends on the day before the commencement date, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4501a605-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the second of which begins on the commencement date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4501a606-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Spouse may join in election","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a married individual (within the meaning of section 7703), the spouse may elect to have the debtor’s election under subparagraph (A) also apply to the spouse, but only if the debtor and the spouse file a joint return for the taxable year referred to in subparagraph (A)(i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4501a607-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No election where debtor has no assets","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No election may be made under subparagraph (A) by a debtor who has no assets other than property which the debtor may treat as exempt property under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s522"},"text":"section 522 of title 11","children":[],"tail":" of the United States Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4501a608-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for making election","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An election under subparagraph (A) or (B) may be made only on or before the due date for filing the return for the taxable year referred to in subparagraph (A)(i). Any such election, once made, shall be irrevocable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4501a609-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Returns","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A return shall be made for each of the taxable years specified in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4501a60a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annualization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsections (b), (c), and (d) of section 443, a return filed for either of the taxable years referred to in subparagraph (A) shall be treated as a return made under paragraph (1) of subsection (a) of section 443.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4501a60b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commencement date defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the term “commencement date” means the day on which the case under title 11 of the United States Code to which this section applies commences.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4501a60c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of income, deductions, and credits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4501a60d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Estate’s share of debtor’s income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The gross income of the estate for each taxable year shall include the gross income of the debtor to which the estate is entitled under title 11 of the United States Code. The preceding sentence shall not apply to any amount received or accrued by the debtor before the commencement date (as defined in subsection (d)(3)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4501a60e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Debtor’s share of debtor’s income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The gross income of the debtor for any taxable year shall not include any item to the extent that such item is included in the gross income of the estate by reason of paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4501a60f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule for making determinations with respect to deductions, credits, and employment taxes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this section, the determination of whether or not any amount paid or incurred by the estate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4501a610-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is allowable as a deduction or credit under this chapter, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4501a611-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is wages for purposes of subtitle C,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be made as if the amount were paid or incurred by the debtor and as if the debtor were still engaged in the trades and busi­nesses, and in the activities, the debtor was engaged in before the commencement of the case.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4501a612-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of transfers between debtor and estate","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4501a613-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer to estate not treated as disposition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A transfer (other than by sale or exchange) of an asset from the debtor to the estate shall not be treated as a disposition for purposes of any provision of this title assigning tax consequences to a disposition, and the estate shall be treated as the debtor would be treated with respect to such asset.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4501a614-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer from estate to debtor not treated as disposition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a termination of the estate, a transfer (other than by sale or exchange) of an asset from the estate to the debtor shall not be treated as a disposition for purposes of any provision of this title assigning tax consequences to a disposition, and the debtor shall be treated as the estate would be treated with respect to such asset.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4501a615-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Estate succeeds to tax attributes of debtor","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The estate shall succeed to and take into account the following items (determined as of the first day of the debtor’s taxable year in which the case commences) of the debtor—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4501a616-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Net operating loss carryovers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The net operating loss carryovers determined under section 172.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4501a617-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Charitable contributions carryovers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The carryover of excess charitable contributions determined under section 170(d)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4501a618-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery of tax benefit items","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amount to which section 111 (relating to recovery of tax benefit items) applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4501a619-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit carryovers, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The carryovers of any credit, and all other items which, but for the commencement of the case, would be required to be taken into account by the debtor with respect to any credit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4501a61a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capital loss carryovers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The capital loss carryover determined under section 1212.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4501a61b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/g/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis, holding period, and character of assets","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any asset acquired (other than by sale or exchange) by the estate from the debtor, the basis, holding period, and character it had in the hands of the debtor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4501a61c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/g/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Method of accounting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The method of accounting used by the debtor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4501a61d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/g/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other attributes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Other tax attributes of the debtor, to the extent provided in regulations prescribed by the Secretary as necessary or appropriate to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4501a61e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration, liquidation, and reorganization expenses; carryovers and carrybacks of certain excess expenses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4501a61f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration, liquidation, and reorganization expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any administrative expense allowed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s503"},"text":"section 503 of title 11","children":[],"tail":" of the United States Code, and any fee or charge assessed against the estate under chapter 123 of title 28 of the United States Code, to the extent not disallowed under any other provision of this title, shall be allowed as a deduction."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4501a620-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carryback and carryover of excess administrative costs, etc., to estate taxable years","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4501a621-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deduction allowed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be allowed as a deduction for the taxable year an amount equal to the aggregate of (i) the administrative expense carryovers to such year, plus (ii) the administrative expense carrybacks to such year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4501a622-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expense loss, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a net operating loss would be created or increased for any estate taxable year if section 172(c) were applied without the modification contained in paragraph (4) of section 172(d), then the amount of the net operating loss so created (or the amount of the increase in the net operating loss) shall be an administrative expense loss for such taxable year which shall be an administrative expense carryback to each of the 3 preceding taxable years and an administrative expense carryover to each of the 7 succeeding taxable years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4501a623-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/h/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of amount carried to each taxable year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The portion of any administrative expense loss which may be carried to any other taxable year shall be determined under section 172(b)(2), except that for each taxable year the computation under section 172(b)(2) with respect to the net operating loss shall be made before the computation under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4501a624-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/h/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expense deductions allowed only to estate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The deductions allowable under this chapter solely by reason of paragraph (1), and the deduction provided by subparagraph (A) of this paragraph, shall be allowable only to the estate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4501a625-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Debtor succeeds to tax attributes of estate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a termination of an estate, the debtor shall succeed to and take into account the items referred to in paragraphs (1), (2), (3), (4), (5), and (6) of subsection (g) in a manner similar to that provided in such paragraphs (but taking into account that the transfer is from the estate to the debtor instead of from the debtor to the estate). In addition, the debtor shall succeed to and take into account the other tax attributes of the estate, to the extent provided in regulations prescribed by the Secretary as necessary or appropriate to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4501a626-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other special rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4501a627-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Change of accounting period without approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding section 442, the estate may change its annual accounting period one time without the approval of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4501a628-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain carrybacks","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4501a629-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/j/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carrybacks from estate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any carryback year of the estate is a taxable year before the estate’s first taxable year, the carryback to such carryback year shall be taken into account for the debtor’s taxable year corresponding to the carryback year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4501a62a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/j/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carrybacks from debtor’s activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The debtor may not carry back to a taxable year before the debtor’s taxable year in which the case commences any carryback from a taxable year ending after the case commences.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4501a62b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/j/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carryback and carryback year defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this paragraph—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4501a62c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/j/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carryback","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “carryback” means a net operating loss carryback under section 172 or a carryback of any credit provided by part IV of subchapter A.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4501a62d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1398/j/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carryback year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “carryback year” means the taxable year to which a carryback is carried.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4501a62e-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/589/s3/a/1"},"text":"Pub. L. 96–589, § 3(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-24"},"text":"Dec. 24, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3397"},"text":"94 Stat. 3397","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tI/s104/b/14"},"text":"Pub. L. 99–514, title I, § 104(b)(14)","children":[],"tail":", title XIII, § 1301(j)(8), title XVIII, § 1812(a)(5), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2105"},"text":"100 Stat. 2105","children":[],"tail":", 2658, 2833.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4501a62f-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4501a630-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4501a631-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Part IV of subchapter A, referred to in subsec. (j)(2)(C)(i), probably means part IV of subchapter A of chapter 1 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4501a632-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s104/b/14/A"},"text":"Pub. L. 99–514, § 104(b)(14)(A)","children":[],"tail":", substituted “basic standard deduction” for “zero bracket amount” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s104/b/14/B"},"text":"Pub. L. 99–514, § 104(b)(14)(B)","children":[],"tail":", amended par. (3) generally, substituting “Basic standard deduction” for “Amount of zero bracket amount” in heading and substituting “In the case of an estate which does not itemize deductions, the basic standard deduction for the estate” for “The amount of the estate’s zero bracket amount” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1301/j/8"},"text":"Pub. L. 99–514, § 1301(j)(8)","children":[],"tail":", substituted “section 7703” for “section 143”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1812/a/5"},"text":"Pub. L. 99–514, § 1812(a)(5)","children":[],"tail":", amended par. (3) generally. Prior to amendment, par. (3), recovery exclusion, read as follows: “Any recovery exclusion under section 111 (relating to recovery of bad debts, prior taxes, and delinquency amounts).”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4501a633-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4501a634-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s104/b/14"},"text":"section 104(b)(14) of Pub. L. 99–514","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"1986-12-31"},"text":"Dec. 31, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s151/a"},"text":"section 151(a) of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1301/j/8"},"text":"section 1301(j)(8) of Pub. L. 99–514","children":[],"tail":" applicable to bonds issued after "},{"tag":"date","attrib":{"date":"1986-08-15"},"text":"Aug. 15, 1986","children":[],"tail":", except as otherwise provided, see sections 1311 to 1318 of "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", set out as an Effective Date; Transitional Rules note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s141"},"text":"section 141 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1812/a/5"},"text":"section 1812(a)(5) of Pub. L. 99–514","children":[],"tail":" effective, except as otherwise provided, as if included in the provisions of the Tax Reform Act of 1984, "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA"},"text":"Pub. L. 98–369, div. A","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1881"},"text":"section 1881 of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s48"},"text":"section 48 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4501a635-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subchapter applicable to bankruptcy cases commencing more than 90 days after ","children":[{"tag":"date","attrib":{"date":"1980-12-24"},"text":"Dec. 24, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/589/s7/b"},"text":"section 7(b) of Pub. L. 96–589","children":[],"tail":", set out as an Effective Date of 1980 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s108"},"text":"section 108 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4501a636-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Plan Amendments Not Required Until January 1, 1989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions directing that if any amendments made by subtitle A or subtitle C of title XI [§§ 1101–1147 and 1171–1177] or title XVIII [§§ 1800–1899A] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" require an amendment to any plan, such plan amendment shall not be required to be made before the first plan year beginning on or after "},{"tag":"date","attrib":{"date":"1989-01-01"},"text":"Jan. 1, 1989","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1140"},"text":"section 1140 of Pub. L. 99–514","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s401"},"text":"section 401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
