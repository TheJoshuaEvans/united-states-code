{"tag":"section","attrib":{"id":"id42a196b4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s280H"},"text":null,"children":[{"tag":"num","attrib":{"value":"280H"},"text":"§ 280H.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on certain amounts paid to employee-owners by personal service corporations electing alternative taxable years","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id42a196b5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s280H/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42a196b6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s280H/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an election by a personal service corporation under section 444 is in effect for a taxable year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42a196b7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s280H/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such corporation does not meet the minimum distribution requirements of subsection (c) for such taxable year,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then the deduction otherwise allowed under this chapter for applicable amounts paid or incurred by such corporation to employee-owners shall not exceed the maximum deductible amount. The preceding sentence shall not apply for purposes of subchapter G (relating to personal holding companies).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42a196b8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s280H/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carryover of nondeductible amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any amount is not allowed as a deduction for a taxable year under subsection (a), such amount shall be treated as paid or incurred in the succeeding taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42a196b9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s280H/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum distribution requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42a196ba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s280H/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A personal service corporation meets the minimum distribution requirements of this subsection if the applicable amounts paid or incurred during the deferral period of the taxable year (determined without regard to subsection (b)) equal or exceed the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42a196bb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s280H/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the product of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id42a196bc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s280H/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicable amounts paid during the preceding taxable year, divided by the number of months in such taxable year, multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id42a196bd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s280H/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of months in the deferral period of the preceding taxable year, or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42a196be-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s280H/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicable percentage of the adjusted taxable income for the deferral period of the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42a196bf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s280H/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable percentage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “applicable percentage” means the percentage (not in excess of 95 percent) determined by dividing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42a196c0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s280H/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicable amounts paid or incurred during the 3 taxable years immediately preceding the taxable year, by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42a196c1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s280H/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adjusted taxable income of such corporation for such 3 taxable years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42a196c2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s280H/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum deductible amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “maximum deductible amount” means the sum of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42a196c3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s280H/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicable amounts paid during the deferral period, plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42a196c4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s280H/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an amount equal to the product of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42a196c5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s280H/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount determined under paragraph (1), divided by the number of months in the deferral period, multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42a196c6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s280H/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of months in the nondeferral period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42a196c7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s280H/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disallowance of net operating loss carrybacks","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No net operating loss carryback shall be allowed to (or from) any taxable year of a personal service corporation to which an election under section 444 applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42a196c8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s280H/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other definitions and special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42a196c9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s280H/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “applicable amount” means any amount paid to an employee-owner which is includible in the gross income of such employee, other than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42a196ca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s280H/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any gain from the sale or exchange of property between the owner-employee and the corporation, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42a196cb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s280H/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any dividend paid by the corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42a196cc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s280H/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee-owner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “employee-owner” has the meaning given such term by section 269A(b)(2) (as modified by section 441(i)(2)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42a196cd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s280H/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondeferral and deferral periods","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42a196ce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s280H/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deferral period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “deferral period” has the meaning given to such term by section 444(b)(4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42a196cf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s280H/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondeferral period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “nondeferral period” means the portion of the taxable year of the personal service corporation which occurs after the portion of such year constituting the deferral period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42a196d0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s280H/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjusted taxable income","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “adjusted taxable income” means taxable income determined without regard to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42a196d1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s280H/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amount paid to an employee-owner which is includible in the gross income of such employee-owner, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42a196d2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s280H/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any net operating loss carryover to the extent such carryover is attributable to amounts described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42a196d3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s280H/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personal service corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “personal service corporation” has the meaning given to such term by section 441(i)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id42a196d4-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX/s10206/c/1"},"text":"Pub. L. 100–203, title X, § 10206(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-401"},"text":"101 Stat. 1330–401","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tII/s2004/e/2/B"},"text":"Pub. L. 100–647, title II, § 2004(e)(2)(B)","children":[],"tail":", (3), (14)(A), (C), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3600"},"text":"102 Stat. 3600","children":[],"tail":", 3602.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id42a196d5-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id42a196d6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id42a196d7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsecs. (c)(1)(A)(i), (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s2004/e/14/C"},"text":"Pub. L. 100–647, § 2004(e)(14)(C)","children":[],"tail":", substituted “amounts paid” for “amounts paid or incurred”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s2004/e/3"},"text":"Pub. L. 100–647, § 2004(e)(3)","children":[],"tail":", substituted “section 269A(b)(2) (as modified by section 441(i)(2))” for “section 296A(b)(2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s2004/e/14/A"},"text":"Pub. L. 100–647, § 2004(e)(14)(A)","children":[],"tail":", amended par. (4) generally. Prior to amendment, par. (4) read as follows: “The term ‘adjusted taxable income’ means taxable income increased by any amount paid or incurred to an employee-owner which was includible in the gross income of such employee-owner.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s2004/e/2/B"},"text":"Pub. L. 100–647, § 2004(e)(2)(B)","children":[],"tail":", added par. (5)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id42a196d8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id42a196d9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provisions of the Revenue Act of 1987, "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX"},"text":"Pub. L. 100–203, title X","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s2004/u"},"text":"section 2004(u) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s56"},"text":"section 56 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id42a196da-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"Dec. 31, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/s10206/d/1"},"text":"section 10206(d)(1) of Pub. L. 100–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s444"},"text":"section 444 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
