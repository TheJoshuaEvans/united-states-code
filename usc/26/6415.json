{"tag":"section","attrib":{"id":"id46e0edb3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6415"},"text":null,"children":[{"tag":"num","attrib":{"value":"6415"},"text":"§ 6415.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credits or refunds to persons who collected certain taxes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46e0edb4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6415/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowance of credits or refunds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Credit or refund of any overpayment of tax imposed by section 4251, 4261, or 4271 may be allowed to the person who collected the tax and paid it to the Secretary if such person establishes, under such regulations as the Secretary may prescribe, that he has repaid the amount of such tax to the person from whom he collected it, or obtains the consent of such person to the allowance of such credit or refund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46e0edb5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6415/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit on returns","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person entitled to a refund of tax imposed by section 4251, 4261, or 4271 paid, or collected and paid, to the Secretary by him may, instead of filing a claim for refund, take credit therefor against taxes imposed by such section due upon any subsequent return.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46e0edb6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6415/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refund of overcollections","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In case any person required under section 4251, 4261, or 4271 to collect any tax shall make an overcollection of such tax, such person shall, upon proper application, refund such overcollection to the person entitled thereto.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46e0edb7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6415/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refund of taxable payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person making a refund of any payment on which tax imposed by section 4251, 4261, or 4271 has been collected may repay therewith the amount of tax collected on such payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46e0edb8-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/798"},"text":"68A Stat. 798","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/475/s4/b/4"},"text":"Pub. L. 85–475, § 4(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-06-30"},"text":"June 30, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/260"},"text":"72 Stat. 260","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/859/tI/s163/d/1"},"text":"Pub. L. 85–859, title I, § 163(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1311"},"text":"72 Stat. 1311","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/44/tVI/s601/b"},"text":"Pub. L. 89–44, title VI, § 601(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-06-21"},"text":"June 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/153"},"text":"79 Stat. 153","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/258/tII/s205/b/2"},"text":"Pub. L. 91–258, title II, § 205(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-05-21"},"text":"May 21, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/241"},"text":"84 Stat. 241","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46e0edb9-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46e0edba-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46e0edbb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/258"},"text":"Pub. L. 91–258","children":[],"tail":" inserted reference to section 4271 in four places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44/s601/b/1"},"text":"Pub. L. 89–44, § 601(b)(1)","children":[],"tail":", (2), substituted “section 4251 or 4261” for “sections 4231(1), 4231(2), 4231(3), 4241, 4245, 4261, or 4286” and struck out last sentence which referred to payment outside the United States of taxes imposed under pars. (1), (2) and (3) of section 4231."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44/s601/b/1"},"text":"Pub. L. 89–44, § 601(b)(1)","children":[],"tail":", substituted “section 4251 or 4261” for “section 4231(1), 4231(2), 4231(3), 4241, 4245, 4261, or 4286” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":" provided that in the case of any payment outside the United States in respect of which tax is imposed under par. (1), (2), or (3) of "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4231"},"text":"section 4231 of this title","children":[],"tail":", the person who paid for the admission or for the use of the box or seat shall be considered the person from whom the tax was collected."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/475"},"text":"Pub. L. 85–475","children":[],"tail":" struck out references to section 4271."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46e0edbc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46e0edbd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/258"},"text":"Pub. L. 91–258","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1970-07-01"},"text":"July 1, 1970","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/258/s211/a"},"text":"section 211(a) of Pub. L. 91–258","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4041"},"text":"section 4041 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46e0edbe-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1965 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/44"},"text":"Pub. L. 89–44","children":[],"tail":" to take effect in a manner consistent with effective date of change of tax provision to which related, see "},{"tag":"ref","attrib":{"href":"/us/pl/89/44/s701/e"},"text":"section 701(e) of Pub. L. 89–44","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6103"},"text":"section 6103 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46e0edbf-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1958 Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/s1/c"},"text":"Pub. L. 85–859, § 1(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1275"},"text":"72 Stat. 1275","children":[],"tail":", provided in part that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/85/859/s1/c"},"text":"“Except as otherwise provided, the amendments and repeals made by title I of this Act [enacting sections 4057, 4143, 4221 to 4225, and 4294 of this title, amending chapter 34, this section, and sections 4001, 4003, 4031, 4041, 4053, 4111, 4121, 4141, 4142, 4192, 4216 to 4218, 4231 to 4233, 4263, 4291, 4501, 4601, 6011, 6412, 6416, 6420, 6421, 6501, and 6805 of this title, and repealing ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s4112"},"text":"section 4112 of this title","children":[],"tail":" and former sections 4143, 4152, 4220 to 4225, and 4316 of this title] shall take effect on the first day of the first calendar quarter which begins more than 60 days after the date on which this Act is enacted ["},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/85/475/s4/c"},"text":"Pub. L. 85–475, § 4(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-06-30"},"text":"June 30, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/261"},"text":"72 Stat. 261","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), the repeals and amendments made by subsections (a) and (b) [repealing sections 4271 to 4273 and 4281 to 4283 of this title and amending this section and sections 4292, 6416, 7012, and 7272 of this title] shall apply only with respect to amounts paid on or after ","children":[{"tag":"date","attrib":{"date":"1958-08-01"},"text":"August 1, 1958","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of transportation with respect to which the second sentence of section 4281 of the Internal Revenue Code of 1986 [formerly I.R.C. 1954] applies, the repeals and amendments made by subsections (a) and (b) [repealing sections 4271 to 4273 and 4281 to 4283 of this title and amending this section and sections 4292, 6416, 7012, and 7272 of this title] shall apply only if the transportation begins on or after ","children":[{"tag":"date","attrib":{"date":"1958-08-01"},"text":"August 1, 1958","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
