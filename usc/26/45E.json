{"tag":"section","attrib":{"id":"id40ce351d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45E"},"text":null,"children":[{"tag":"num","attrib":{"value":"45E"},"text":"§ 45E.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small employer pension plan startup costs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id40ce351e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45E/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of section 38, in the case of an eligible employer, the small employer pension plan startup cost credit determined under this section for any taxable year is an amount equal to 50 percent of the qualified startup costs paid or incurred by the taxpayer during the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40ce351f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45E/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dollar limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of the credit determined under this section for any taxable year shall not exceed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40ce3520-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45E/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for the first credit year and each of the 2 taxable years immediately following the first credit year, the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40ce3521-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45E/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $500, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40ce3522-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45E/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the lesser of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40ce3523-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45E/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $250 for each employee of the eligible employer who is not a highly compensated employee (as defined in section 414(q)) and who is eligible to participate in the eligible employer plan maintained by the eligible employer, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40ce3524-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45E/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40ce3525-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45E/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" zero for any other taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40ce3526-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45E/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible employer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40ce3527-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45E/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible employer” has the meaning given such term by section 408(p)(2)(C)(i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40ce3528-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45E/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement for new qualified employer plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such term shall not include an employer if, during the 3-taxable year period immediately preceding the 1st taxable year for which the credit under this section is otherwise allowable for a qualified employer plan of the employer, the employer or any member of any controlled group including the employer (or any predecessor of either) established or maintained a qualified employer plan with respect to which contributions were made, or benefits were accrued, for substantially the same employees as are in the qualified employer plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40ce3529-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45E/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40ce352a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45E/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified startup costs","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40ce352b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45E/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified startup costs” means any ordinary and necessary expenses of an eligible employer which are paid or incurred in connection with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40ce352c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45E/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment or administration of an eligible employer plan, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40ce352d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45E/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the retirement-related education of employees with respect to such plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40ce352e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45E/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan must have at least 1 participant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such term shall not include any expense in connection with a plan that does not have at least 1 employee eligible to participate who is not a highly compensated employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40ce352f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45E/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible employer plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible employer plan” means a qualified employer plan within the meaning of section 4972(d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40ce3530-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45E/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First credit year","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “first credit year” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40ce3531-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45E/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taxable year which includes the date that the eligible employer plan to which such costs relate becomes effective with respect to the eligible employer, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40ce3532-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45E/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the election of the eligible employer, the taxable year preceding the taxable year referred to in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40ce3533-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45E/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40ce3534-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45E/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aggregation rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All persons treated as a single employer under subsection (a) or (b) of section 52, or subsection (m) or (","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":") of section 414, shall be treated as one person. All eligible employer plans shall be treated as 1 eligible employer plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40ce3535-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45E/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disallowance of deduction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No deduction shall be allowed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40ce3536-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45E/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for that portion of the qualified startup costs paid or incurred for the taxable year which is equal to so much of the portion of the credit determined under subsection (a) as is properly allocable to such costs, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40ce3537-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45E/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for that portion of the employer contributions by the employer for the taxable year which is equal to so much of the credit increase determined under subsection (f) as is properly allocable to such contributions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40ce3538-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45E/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election not to claim credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to a taxpayer for any taxable year if such taxpayer elects to have this section not apply for such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40ce3539-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45E/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increased credit for certain small employers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an employer which would be an eligible employer under subsection (c) if section 408(p)(2)(C)(i) was applied by substituting “50 employees” for “100 employees”, subsection (a) shall be applied by substituting “100 percent” for “50 percent”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40ce353a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45E/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional credit for employer contributions by certain eligible employers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40ce353b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45E/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an eligible employer, the credit allowed for the taxable year under subsection (a) (determined without regard to this subsection) shall be increased by an amount equal to the applicable percentage of employer contributions (other than any elective deferrals (as defined in section 402(g)(3)) by the employer to an eligible employer plan (other than a defined benefit plan (as defined in section 414(j))).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40ce353c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45E/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40ce353d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45E/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dollar limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount determined under paragraph (1) (before the application of subparagraph (B)) with respect to any employee of the employer shall not exceed $1,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40ce353e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45E/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit phase-in","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any eligible employer which had for the preceding taxable year more than 50 employees, the amount determined under paragraph (1) (without regard to this subparagraph) shall be reduced by an amount equal to the product of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40ce353f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45E/f/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount otherwise so determined under paragraph (1), multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40ce3540-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45E/f/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a percentage equal to 2 percentage points for each employee of the employer for the preceding taxable year in excess of 50 employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40ce3541-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45E/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wage limitation","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40ce3542-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45E/f/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No contributions with respect to any employee who receives wages from the employer for the taxable year in excess of $100,000 may be taken into account for such taxable year under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40ce3543-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45E/f/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wages","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of the preceding sentence, the term “wages” has the meaning given such term by section 3121(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40ce3544-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45E/f/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inflation adjustment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any taxable year beginning in a calendar year after 2023, the $100,000 amount under clause (i) shall be increased by an amount equal to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id40ce3545-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45E/f/2/C/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such dollar amount, multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id40ce3546-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45E/f/2/C/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost-of-living adjustment determined under section 1(f)(3) for the calendar year in which the taxable year begins, determined by substituting “calendar year 2007” for “calendar year 2016” in subparagraph (A)(ii) thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":" If any amount as adjusted under this clause is not a multiple of $5,000, such amount shall be rounded to the next lowest multiple of $5,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40ce3547-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45E/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable percentage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the applicable percentage for the taxable year during which the eligible employer plan is established with respect to the eligible employer shall be 100 percent, and for taxable years thereafter shall be determined under the following table:","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id40ce3548-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:b","attrib":{},"text":"In the case of the following taxable year beginning after the taxable year during which plan is established with respect to the eligible employer:","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:b","attrib":{},"text":"The applicable percentage shall be:","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1st","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"100%","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2nd","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"75%","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3rd","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50%","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4th","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"25%","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"ch