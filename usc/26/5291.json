{"tag":"section","attrib":{"id":"id46354432-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5291"},"text":null,"children":[{"tag":"num","attrib":{"value":"5291"},"text":"§ 5291.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46354433-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5291/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every person disposing of any substance of the character used in the manufacture of distilled spirits, or disposing of denatured distilled spirits or articles from which distilled spirits may be recovered, shall, when required by the Secretary, render a correct return, in such form and manner as the Secretary may by regulations prescribe, showing the name and address of the person to whom each disposition was made, with such details, as to the quantity so disposed of or other information which the Secretary may require as to each such disposition, as will enable the Secretary to determine whether all taxes due with respect to any distilled spirits manufactured or recovered from any such substance, denatured, distilled spirits, or articles, have been paid. Every person required to render a return under this section shall keep such records as will enable such person to render a correct return. Such records shall be preserved for such period as the Secretary shall by regulations prescribe, and shall be kept available for inspection by any internal revenue officer during business hours.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46354434-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5291/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross references","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46354435-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5291/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the definition of distilled spirits, see section 5002(a)(8).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46354436-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5291/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the definition of articles, see section 5002(a)(14).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46354437-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5291/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For penalty for violation of subsection (a), see section 5605.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46354438-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1373"},"text":"72 Stat. 1373","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/