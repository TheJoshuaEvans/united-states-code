{"tag":"section","attrib":{"id":"id445ab7ae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s892"},"text":null,"children":[{"tag":"num","attrib":{"value":"892"},"text":"§ 892.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Income of foreign governments and of international organizations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id445ab7af-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s892/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign governments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id445ab7b0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s892/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The income of foreign governments received from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id445ab7b1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s892/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" investments in the United States in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id445ab7b2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s892/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stocks, bonds, or other domestic securities owned by such foreign governments, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id445ab7b3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s892/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financial instruments held in the execution of governmental financial or monetary policy, or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id445ab7b4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s892/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interest on deposits in banks in the United States of moneys belonging to such foreign governments,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall not be included in gross income and shall be exempt from taxation under this subtitle.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id445ab7b5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s892/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Income received directly or indirectly from commercial activities","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id445ab7b6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s892/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall not apply to any income—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id445ab7b7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s892/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" derived from the conduct of any commercial activity (whether within or outside the United States),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id445ab7b8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s892/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" received by a controlled commercial entity or received (directly or indirectly) from a controlled commercial entity, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id445ab7b9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s892/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" derived from the disposition of any interest in a controlled commercial entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id445ab7ba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s892/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Controlled commercial entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subparagraph (A), the term “controlled commercial entity” means any entity engaged in commercial activities (whether within or outside the United States) if the government—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id445ab7bb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s892/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" holds (directly or indirectly) any interest in such entity which (by value or voting interest) is 50 percent or more of the total of such interests in such entity, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id445ab7bc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s892/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" holds (directly or indirectly) any other interest in such entity which provides the foreign government with effective control of such entity.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of the preceding sentence, a central bank of issue shall be treated as a controlled commercial entity only if engaged in commercial activities within the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id445ab7bd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s892/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment as resident","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this title, a foreign government shall be treated as a corporate resident of its country. A foreign government shall be so treated for purposes of any income tax treaty obligation of the United States if such government grants equivalent treatment to the Government of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id445ab7be-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s892/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The income of international organizations received from investments in the United States in stocks, bonds, or other domestic securities owned by such international organizations, or from interest on deposits in banks in the United States of moneys belonging to such international organizations, or from any other source within the United States, shall not be included in gross income and shall be exempt from taxation under this subtitle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id445ab7bf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s892/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such regulations as may be necessary or appropriate to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id445ab7c0-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/284"},"text":"68A Stat. 284","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXII/s1247/a"},"text":"Pub. L. 99–514, title XII, § 1247(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2583"},"text":"100 Stat. 2583","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1012/t/1"},"text":"Pub. L. 100–647, title I, § 1012(t)(1)","children":[],"tail":"–(3), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3527"},"text":"102 Stat. 3527","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11704/a/35"},"text":"Pub. L. 101–508, title XI, § 11704(a)(35)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-519"},"text":"104 Stat. 1388–519","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id445ab7c1-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id445ab7c2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id445ab7c3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" made clarifying amendment to "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1012/t/1"},"text":"Pub. L. 100–647, § 1012(t)(1)","children":[],"tail":". See 1988 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1012/t/1"},"text":"Pub. L. 100–647, § 1012(t)(1)","children":[],"tail":", (2), as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":", amended cl. (ii) generally and added cl. (iii). Prior to amendment, cl. (ii) read as follows: “received from or by a controlled commercial entity.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1012/t/3"},"text":"Pub. L. 100–647, § 1012(t)(3)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “The income of foreign governments or international organizations received from investments in the United States in stocks, bonds, or other domestic securities, owned by such foreign governments or by international organizations, or from interest on deposits in banks in the United States of moneys belonging to such foreign governments or international organizations, or from any other source within the United States, shall not be included in gross income and shall be exempt from taxation under this subtitle.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id445ab7c4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id445ab7c5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1019/a"},"text":"section 1019(a) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id445ab7c6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXII/s1247/b"},"text":"Pub. L. 99–514, title XII, § 1247(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2584"},"text":"100 Stat. 2584","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/tXII/s1247/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply to amounts received on or after ","children":[{"tag":"date","attrib":{"date":"1986-07-01"},"text":"July 1, 1986","children":[],"tail":", except that no amount shall be required to be deducted and withheld by reason of the amendment made by subsection (a) from any payment made before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id445ab7c7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Applicability of Certain Amendments by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" in Relation to Treaty Obligations of United States"}],"tail":null},{"tag":"p","attrib":{},"text":"For nonapplication of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1247/a"},"text":"section 1247(a) of Pub. L. 99–514","children":[],"tail":" to the extent application of such amendment would be contrary to any treaty obligation of the United States in effect on "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", with provision that for such purposes any amendment by title I of "},{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" be treated as if it had been included in the provision of "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" to which such amendment relates, see section 1012(aa)(3), (4) of "},{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s861"},"text":"section 861 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
