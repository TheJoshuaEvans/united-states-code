:"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44c62404-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600/tVII/s701/v/2"},"text":"Pub. L. 95–600, title VII, § 701(v)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2920"},"text":"92 Stat. 2920","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"“The amendment made by paragraph (1) [amending this section] shall apply as if included in the amendment made to section 1239 of the Internal Revenue Code of 1986 [formerly I.R.C. 1954] by section 2129(a) of the Tax Reform Act of 1976 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s2129/a"},"text":"section 2129(a) of Pub. L. 94–455","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44c62405-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXXI/s2129/b"},"text":"Pub. L. 94–455, title XXI, § 2129(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1922"},"text":"90 Stat. 1922","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/455/tXXI/s2129/b"},"text":"“The amendment made by this section [amending this section] shall apply to sales or exchanges after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":"]. For purposes of the preceding sentence, a sale or exchange is considered to have occurred on or before such date of enactment if such sale or exchange is made pursuant to a binding contract entered into on or before that date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
