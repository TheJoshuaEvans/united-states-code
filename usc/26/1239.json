{"tag":"section","attrib":{"id":"id44c3b2eb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1239"},"text":null,"children":[{"tag":"num","attrib":{"value":"1239"},"text":"§ 1239.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gain from sale of depreciable property between certain related taxpayers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44c3b2ec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1239/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of gain as ordinary income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a sale or exchange of property, directly or indirectly, between related persons, any gain recognized to the transferor shall be treated as ordinary income if such property is, in the hands of the transferee, of a character which is subject to the allowance for depreciation provided in section 167.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44c3b2ed-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1239/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Related persons","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a), the term “related persons” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44c3b2ee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1239/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person and all entities which are controlled entities with respect to such person,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44c3b2ef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1239/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a taxpayer and any trust in which such taxpayer (or his spouse) is a beneficiary, unless such beneficiary’s interest in the trust is a remote contingent interest (within the meaning of section 318(a)(3)(B)(i)), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44c3b2f0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1239/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except in the case of a sale or exchange in satisfaction of a pecuniary bequest, an executor of an estate and a beneficiary of such estate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44c3b2f1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1239/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Controlled entity defined","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44c3b2f2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1239/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “controlled entity” means, with respect to any person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44c3b2f3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1239/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a corporation more than 50 percent of the value of the outstanding stock of which is owned (directly or indirectly) by or for such person,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44c3b2f4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1239/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a partnership more than 50 percent of the capital interest or profits interest in which is owned (directly or indirectly) by or for such person, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44c3b2f5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1239/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any entity which is a related person to such person under paragraph (3), (10), (11), or (12) of section 267(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44c3b2f6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1239/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Constructive ownership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, ownership shall be determined in accordance with rules similar to the rules under section 267(c) (other than paragraph (3) thereof).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44c3b2f7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1239/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employer and related employee association","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a), the term “related person” also includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44c3b2f8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1239/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employer and any person related to the employer (within the meaning of subsection (b)), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44c3b2f9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1239/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a welfare benefit fund (within the meaning of section 419(e)) which is controlled directly or indirectly by persons referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44c3b2fa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1239/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Patent applications treated as depreciable prop­erty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, a patent application shall be treated as property which, in the hands of the transferee, is of a character which is subject to the allowance for depreciation provided in section 167.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44c3b2fb-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/332"},"text":"68A Stat. 332","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/866/tI/s56"},"text":"Pub. L. 85–866, title I, § 56","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1645"},"text":"72 Stat. 1645","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXXI/s2129/a"},"text":"Pub. L. 94–455, title XXI, § 2129(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1922"},"text":"90 Stat. 1922","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/600/tVII/s701/v/1"},"text":"Pub. L. 95–600, title VII, § 701(v)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2920"},"text":"92 Stat. 2920","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/471/s5"},"text":"Pub. L. 96–471, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-19"},"text":"Oct. 19, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2255"},"text":"94 Stat. 2255","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/448/tIII/s301"},"text":"Pub. L. 97–448, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2397"},"text":"96 Stat. 2397","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s175/a"},"text":"Pub. L. 98–369, div. A, title I, § 175(a)","children":[],"tail":", (b), title IV, § 421(b)(6)(A), title V, § 557(a), "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/708"},"text":"98 Stat. 708","children":[],"tail":", 794, 898; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVI/s642/a/1/A"},"text":"Pub. L. 99–514, title VI, § 642(a)(1)(A)","children":[],"tail":"–(C), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2283"},"text":"100 Stat. 2283","children":[],"tail":", 2284; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXIII/s1308/b"},"text":"Pub. L. 105–34, title XIII, § 1308(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1041"},"text":"111 Stat. 1041","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44c3b2fc-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44c3b2fd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44c3b2fe-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s642/a/1/A"},"text":"Pub. L. 99–514, § 642(a)(1)(A)","children":[],"tail":", substituted “controlled entities” for “80-percent owned entities”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s642/a/1/B"},"text":"Pub. L. 99–514, § 642(a)(1)(B)","children":[],"tail":", (C), in heading, substituted “Controlled entity” for “80-percent owned entity”, in par. (1), in introductory provisions, substituted “controlled entity” for “80-percent owned entity”, in subpar. (A), substituted “more than 50 percent of the value” for “80 percent or more in value”, in subpar. (B), substituted “more than 50 percent” for “80 percent or more”, and added subpar. (C), and amended par. (2) generally. Prior to amendment, par. (2) read as follows: “For purposes of subparagraphs (A) and (B) of paragraph (1), the principles of section 318 shall apply, except that—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the members of an individual’s family shall consist only of such individual and such individual’s spouse,","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) paragraph (2)(C) of section 318(a) shall be applied without regard to the 50-percent limitation contained therein, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) paragraph (3) of section 318(a) shall not apply.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s421/b/6"},"text":"Pub. L. 98–369, § 421(b)(6)","children":[],"tail":", redesignated pars. (2) and (3) as (1) and (2), respectively. Former par. (1), defining a husband and wife as “related persons”, was struck out."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s175/b"},"text":"Pub. L. 98–369, § 175(b)","children":[],"tail":", amended subsec. (b) generally, adding par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s557/a"},"text":"Pub. L. 98–369, § 557(a)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s175/a"},"text":"Pub. L. 98–369, § 175(a)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/448/s301/a"},"text":"Pub. L. 97–448, § 301(a)","children":[],"tail":", substituted provisions that “related persons” means (1) a husband and wife, and (2) a person and all entities which are 80-percent owned entities with respect to such person, for provisions which provided that “related persons” meant (1) the taxpayer and the taxpayer’s spouse, (2) the taxpayer and an 80-percent owned entity, or (3) two 80-percent owned entities."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/448/s301/b"},"text":"Pub. L. 97–448, § 301(b)","children":[],"tail":", inserted “, with respect to any person” after “means” in introductory provisions and substituted “such person” for “the taxpayer” in subpars. (A) and (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/448/s301/b"},"text":"Pub. L. 97–448, § 301(b)","children":[],"tail":", struck out “and” at end of subpar. (A), substituted “paragraph (2)(C)” for “paragraphs (2)(C) and (3)(C)” in subpar. (B), and added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/471"},"text":"Pub. L. 96–471","children":[],"tail":" substituted “the taxpayer and the taxpayer’s spouse” for “a husband and wife”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/471"},"text":"Pub. L. 96–471","children":[],"tail":" substituted “the taxpayer and an 80-percent owned entity, or” for “an individual and a corporation 80 percent or more in value of the outstanding stock of which is owned, directly or indirectly, by or for such individual, or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/471"},"text":"Pub. L. 96–471","children":[],"tail":" substituted “two 80-percent owned entities” for “two or more corporations 80 percent or more in value of the outstanding stock of each of which is owned, directly or indirectly, by or for the same individual”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/471"},"text":"Pub. L. 96–471","children":[],"tail":" substituted provisions defining an “80-percent owned entity” for provisions relating to constructive ownership of stock."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600"},"text":"Pub. L. 95–600","children":[],"tail":" substituted “of a character which is subject to the allowance for depreciation provided in section 167” for “subject to the allowance for depreciation provided in section 167”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" substituted “sale of depreciable property between certain related taxpayers” for “sale of certain property between spouses or between an individual and a controlled corporation” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" substituted provisions for transactions between related persons for such transactions (1) between a husband and wife; or (2) between an individual and a corporation more than 80 percent in value of the outstanding stock of which is owned by such individual, his spouse, and his minor children and minor grandchildren and “any gain recognized to the transferee shall be treated as ordinary income if such property is, in the hands of the transferee, subject to the allowance for depreciation provided in section 167” for “any gain recognized to the transferor from the sale or exchange of such property shall be considered as gain from the sale or exchange of property which is neither a capital asset nor property described in section 1231”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" substituted definition of “related persons” for prior provision making section applicable only to sales or exchanges of depreciable property."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" substituted provision respecting constructive ownership of stock for prior provision making section inapplicable with respect to sales or exchanges made on or before "},{"tag":"date","attrib":{"date":"1951-05-03"},"text":"May 3, 1951","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/866"},"text":"Pub. L. 85–866","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44c623ff-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44c62400-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1308/c"},"text":"section 1308(c) of Pub. L. 105–34","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s267"},"text":"section 267 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44c62401-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVI/s642/c"},"text":"Pub. L. 99–514, title VI, § 642(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2284"},"text":"100 Stat. 2284","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1006/i/3"},"text":"Pub. L. 100–647, title I, § 1006(i)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3411"},"text":"102 Stat. 3411","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/647/tI/s1006/i/3"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), the amendments made by this section [amending this section and sections 453 and 707 of this title] shall apply to sales after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":"], in taxable years ending after such date."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transitional rule for binding contracts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section shall not apply to sales made after ","children":[{"tag":"date","attrib":{"date":"1986-08-14"},"text":"August 14, 1986","children":[],"tail":", which are made pursuant to a binding contract in effect on "},{"tag":"date","attrib":{"date":"1986-08-14"},"text":"August 14, 1986","children":[],"tail":", and at all times thereafter.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44c62402-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s175/c"},"text":"Pub. L. 98–369, div. A, title I, § 175(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/708"},"text":"98 Stat. 708","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/369/dA/tI/s175/c"},"text":"“The amendments made by this section [amending this section] shall apply to sales or exchanges after ","children":[{"tag":"date","attrib":{"date":"1984-03-01"},"text":"March 1, 1984","children":[],"tail":", in taxable years ending after such date.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s421/b/6"},"text":"section 421(b)(6) of Pub. L. 98–369","children":[],"tail":" applicable to transfers after "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", in taxable years ending after such date, subject to election to have amendment apply to transfers after 1983 or