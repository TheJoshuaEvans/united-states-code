{"tag":"section","attrib":{"id":"id447c223f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s934"},"text":null,"children":[{"tag":"num","attrib":{"value":"934"},"text":"§ 934.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on reduction in income tax liability incurred to the Virgin Islands","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id447c2240-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s934/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Tax liability incurred to the Virgin Islands pursuant to this subtitle, as made applicable in the Virgin Islands by the Act entitled “An Act making appropriations for the naval service for the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1922-06-30"},"text":"June 30, 1922","children":[],"tail":", and for other purposes”, approved "},{"tag":"date","attrib":{"date":"1921-07-12"},"text":"July 12, 1921","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1397"},"text":"48 U.S.C. 1397","children":[],"tail":"), or pursuant to section 28(a) of the Revised Organic Act of the Virgin Islands, approved "},{"tag":"date","attrib":{"date":"1954-07-22"},"text":"July 22, 1954","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1642"},"text":"48 U.S.C. 1642","children":[],"tail":"), shall not be reduced or remitted in any way, directly or indirectly, whether by grant, subsidy, or other similar payment, by any law enacted in the Virgin Islands, except to the extent provided in subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id447c2241-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s934/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reductions permitted with respect to certain income","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id447c2242-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s934/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), subsection (a) shall not apply with respect to so much of the tax liability referred to in subsection (a) as is attributable to income derived from sources within the Virgin Islands or income effectively connected with the conduct of a trade or business within the Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id447c2243-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s934/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for liability paid by citizens or residents of the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply to any liability payable to the Virgin Islands under section 932(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id447c2244-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s934/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for non-United States income of certain foreign corporations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id447c2245-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s934/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a qualified foreign corporation, subsection (a) shall not apply with respect to so much of the tax liability referred to in subsection (a) as is attributable to income which is derived from sources outside the United States and which is not effectively connected with the conduct of a trade or business within the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id447c2246-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s934/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified foreign corporation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subparagraph (A), the term “qualified foreign corporation” means any foreign corporation if less than 10 percent of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id447c2247-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s934/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total voting power of the stock of such corporation, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id447c2248-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s934/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total value of the stock of such corporation, is owned or treated as owned (within the meaning of section 958) by 1 or more United States persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id447c2249-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s934/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of income source, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The determination as to whether income is derived from sources within the United States or is effectively connected with the conduct of a trade or business within the United States shall be made under regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id447c224a-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/779/s4/a/1"},"text":"Pub. L. 86–779, § 4(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-14"},"text":"Sept. 14, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/998"},"text":"74 Stat. 998","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX"},"text":"Pub. L. 94–455, title XIX","children":[],"tail":", §§ 1901(a)(118), 1906(b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1784"},"text":"90 Stat. 1784","children":[],"tail":", 1834; "},{"tag":"ref","attrib":{"href":"/us/pl/97/248/tII/s213/b"},"text":"Pub. L. 97–248, title II, § 213(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/463"},"text":"96 Stat. 463","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/455/s1/c"},"text":"Pub. L. 97–455, § 1(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2498"},"text":"96 Stat. 2498","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tVIII/s801/d/7"},"text":"Pub. L. 98–369, div. A, title VIII, § 801(d)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/996"},"text":"98 Stat. 996","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXII/s1275/a/2/A"},"text":"Pub. L. 99–514, title XII, § 1275(a)(2)(A)","children":[],"tail":", (c)(1), (2), title XVIII, § 1876(f)(2), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2598"},"text":"100 Stat. 2598","children":[],"tail":", 2900; "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s908/c/3"},"text":"Pub. L. 108–357, title VIII, § 908(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1656"},"text":"118 Stat. 1656","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id447c224b-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id447c224c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id447c224d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":" struck out “the Virgin Islands or” before “the United States” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1275/c/2/A"},"text":"Pub. L. 99–514, § 1275(c)(2)(A)","children":[],"tail":", struck out “or (c) or in section 934A” after “subsection (b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1275/c/1"},"text":"Pub. L. 99–514, § 1275(c)(1)","children":[],"tail":", (2)(B), added subsec. (b) and struck out former subsec. (b) which excepted from subsec. (a) domestic or Virgin Islands corporations to the extent they derived income from sources without the United States under certain conditions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1275/c/1"},"text":"Pub. L. 99–514, § 1275(c)(1)","children":[],"tail":", struck out subsec. (c) which provided an exception to subsec. (a) of this section for individual citizens of the United States residing in the Virgin Islands to the extent their income is derived from sources within the Virgin Islands."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1275/c/1"},"text":"Pub. L. 99–514, § 1275(c)(1)","children":[],"tail":", struck out subsec. (d) which related to requirement to supply information."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1275/a/2/A"},"text":"Pub. L. 99–514, § 1275(a)(2)(A)","children":[],"tail":", struck out subsec. (e) which provided for tax treatment of intangible property income of certain domestic corporations."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1275/a/2/A"},"text":"Pub. L. 99–514, § 1275(a)(2)(A)","children":[],"tail":", struck out subsec. (f) which provided a transitional rule for applying subsec. (b)(2) of this section with respect to taxable years beginning after "},{"tag":"date","attrib":{"date":"1982-12-31"},"text":"Dec. 31, 1982","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"1985-01-01"},"text":"Jan. 1, 1985","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1876/f/2"},"text":"Pub. L. 99–514, § 1876(f)(2)","children":[],"tail":", struck out subsec. (f) which provided that subsec. (a) of this section not apply in the case of a Virgin Islands corporation which is a FSC."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" added subsec. (f) relating to FSC."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/455"},"text":"Pub. L. 97–455","children":[],"tail":" inserted “or in section 934A” after “subsection (b) or (c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/s213/b/1"},"text":"Pub. L. 97–248, § 213(b)(1)","children":[],"tail":", substituted “65 percent” for “50 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/s213/b/2"},"text":"Pub. L. 97–248, § 213(b)(2)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/s213/b/2"},"text":"Pub. L. 97–248, § 213(b)(2)","children":[],"tail":", added a temporary subsec. (f) which provided that in applying subsec. (b)(2) with respect to taxable years beginning after "},{"tag":"date","attrib":{"date":"1982-12-31"},"text":"December 31, 1982","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"1985-01-01"},"text":"January 1, 1985","children":[],"tail":", “55 percent” shall be substituted for “65 percent” for taxable years beginning in calendar year 1983 and “60 percent” shall be substituted for “65 percent” for taxable years beginning in calendar year 1984."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1901/a/118"},"text":"Pub. L. 94–455, § 1901(a)(118)","children":[],"tail":", struck out “For the purposes of this subsection, all amounts received by such corporation within the United States, whether derived from sources within or without the United States, shall be considered as being derived from sources within the United States”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” after “Secretary” in two places."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id447c224e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id447c224f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":" applicable to taxable years ending after "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/s908/d/1"},"text":"section 908(d)(1) of Pub. L. 108–357","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s937"},"text":"section 937 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id447c2250-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by section 1275(a)(2)(A), (c)(1), (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"1986-12-31"},"text":"Dec. 31, 1986","children":[],"tail":", with certain exceptions and qualifications, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1277"},"text":"section 1277 of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s931"},"text":"section 931 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1876/f/2"},"text":"section 1876(f)(2) of Pub. L. 99–514","children":[],"tail":" effective, except as otherwise provided, as if included in the provisions of the Tax Reform Act of 1984, "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA"},"text":"Pub. L. 98–369, div. A","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1881"},"text":"section 1881 of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s48"},"text":"section 48 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id447c2251-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attr