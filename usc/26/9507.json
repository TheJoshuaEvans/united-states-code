{"tag":"section","attrib":{"id":"id47becaa3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9507"},"text":null,"children":[{"tag":"num","attrib":{"value":"9507"},"text":"§ 9507.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hazardous Substance Superfund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47becaa4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9507/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Creation of Trust Fund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established in the Treasury of the United States a trust fund to be known as the “Hazardous Substance Superfund” (hereinafter in this section referred to as the “Superfund”), consisting of such amounts as may be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47becaa5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9507/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriated to the Superfund as provided in this section,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47becaa6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9507/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriated to the Superfund pursuant to section 517(b) of the Superfund Revenue Act of 1986, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47becaa7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9507/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" credited to the Superfund as provided in section 9602(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47becaa8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9507/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers to Superfund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are hereby appropriated to the Superfund amounts equivalent to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47becaa9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9507/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taxes received in the Treasury under section 4611, 4661, or 4671 (relating to environmental taxes),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47becaaa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9507/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts recovered on behalf of the Superfund under the Comprehensive Environmental Response, Compensation, and Liability Act of 1980 (hereinafter in this section referred to as “CERCLA”),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47becaab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9507/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all moneys recovered or collected under section 311(b)(6)(B) of the Clean Water Act,","children":[{"tag":"ref","attrib":{"idref":"fn002356"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002356"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47becaac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9507/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" penalties assessed under title I of CERCLA, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47becaad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9507/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" punitive damages under section 107(c)(3) of CERCLA.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"In the case of the tax imposed by section 4611, paragraph (1) shall apply only to so much of such tax as is attributable to the Hazardous Substance Superfund financing rate under section 4611(c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47becaae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9507/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures from Superfund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47becaaf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9507/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts in the Superfund shall be available, as provided in appropriation Acts, only for purposes of making expenditures—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47becab0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9507/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to carry out the purposes of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47becab1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9507/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paragraphs (1), (2), (5), and (6) of section 111(a) of CERCLA as in effect on the date of the enactment of the Superfund Amendments and Reauthorization Act of 1986,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47becab2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9507/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 111(c) of CERCLA (as so in effect), other than paragraphs (1) and (2) thereof, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47becab3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9507/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 111(m) of CERCLA (as so in effect), or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47becab4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9507/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hereafter authorized by a law which does not authorize the expenditure out of the Superfund for a general purpose not covered by subparagraph (A) (as so in effect).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47becab5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9507/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for certain transfers, etc., of hazardous substances","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No amount in the Superfund or derived from the Superfund shall be available or used for the transfer or disposal of hazardous waste carried out pursuant to a cooperative agreement between the Administrator of the Environmental Protection Agency and a State if the following conditions apply—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47becab6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9507/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transfer or disposal, if made on ","children":[{"tag":"date","attrib":{"date":"1985-12-13"},"text":"December 13, 1985","children":[],"tail":", would not comply with a State or local requirement,"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47becab7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9507/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transfer is to a facility for which a final permit under section 3005(a) of the Solid Waste Disposal Act was issued after ","children":[{"tag":"date","attrib":{"date":"1983-01-01"},"text":"January 1, 1983","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"1984-11-01"},"text":"November 1, 1984","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47becab8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9507/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transfer is from a facility identified as the McColl Site in Fullerton, California.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47becab9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9507/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to borrow","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47becaba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9507/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Superfund, as repayable advances, such sums as may be necessary to carry out the purposes of the Superfund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47becabb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9507/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on aggregate advances","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The maximum aggregate amount of repayable advances to the Superfund which is outstanding at any one time shall not exceed an amount equal to the amount which the Secretary estimates will be equal to the sum of the amounts appropriated to the Superfund under subsection (b)(1) during the following 24 months.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47becabc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9507/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment of advances","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47becabd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9507/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Advances made to the Superfund shall be repaid, and interest on such advances shall be paid, to the general fund of the Treasury when the Secretary determines that moneys are available for such purposes in the Superfund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47becabe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9507/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final repayment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No advance shall be made to the Superfund after ","children":[{"tag":"date","attrib":{"date":"2032-12-31"},"text":"December 31, 2032","children":[],"tail":", and all advances to such Fund shall be repaid on or before such date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47becabf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9507/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rate of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Interest on advances made to the Superfund shall be at a rate determined by the Secretary of the Treasury (as of the close of the calendar month preceding the month in which the advance is made) to be equal to the current average market yield on outstanding marketable obligations of the United States with remaining periods to maturity comparable to the anticipated period during which the advance will be outstanding and shall be compounded annually.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47becac0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9507/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability of United States limited to amount in Trust Fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47becac1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9507/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any claim filed against the Superfund may be paid only out of the Superfund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47becac2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9507/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with other provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in CERCLA or the Superfund Amendments and Reauthorization Act of 1986 (or in any amendment made by either of such Acts) shall authorize the payment by the United States Government of any amount with respect to any such claim out of any source other than the Superfund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47becac3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9507/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Order in which unpaid claims are to be paid","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If at any time the Superfund has insufficient funds to pay all of the claims payable out of the Superfund at such time, such claims shall, to the extent permitted under paragraph (1), be paid in full in the order in which they were finally determined.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47becac4-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/499/tV/s517/a"},"text":"Pub. L. 99–499, title V, § 517(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1772"},"text":"100 Stat. 1772","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/509/tVIII/s8032/c/4"},"text":"Pub. L. 99–509, title VIII, § 8032(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1959"},"text":"100 Stat. 1959","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11231/c"},"text":"Pub. L. 101–508, title XI, § 11231(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-445"},"text":"104 Stat. 1388–445","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dA/tII/s221/a/12/L"},"text":"Pub. L. 113–295, div. A, title II, § 221(a)(12)(L)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4039"},"text":"128 Stat. 4039","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/169/tI/s13601/b"},"text":"Pub. L. 117–169, title I, § 13601(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1982"},"text":"136 Stat. 1982","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47becac5-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47becac6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id47becac7-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 517(b) of the Superfund Revenue Act of 1986, referred to in subsec. (a)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/499/s517/b"},"text":"section 517(b) of Pub. L. 99–499","children":[],"tail":", which is set out as a note under this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Comprehensive Environmental Response, Compensation, and Liability Act of 1980 and CERCLA, referred to in subsecs. (b)(2), (4), (5), (c)(1)(A), and (e)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/510"},"text":"Pub. L. 96–510","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-11"},"text":"Dec. 11, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2767"},"text":"94 Stat. 2767","children":[],"tail":", which is classified principally to chapter 103 (§ 9601 et seq.) of Title 42, The Public Health and Welfare. Title I of CERCLA is classified to subchapter I (§ 9601 et seq.) of chapter 103 of Title 42. Sections 107(c)(3) and 111(a)(1), (2), (5), and (6), (c), and (m) of CERCLA are classified to sections 9607(c)(3) and 9611(a)(1), (2), (5), and (6), (c), and (m) of Title 42, respectively. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9601"},"text":"section 9601 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 311(b)(6)(B) of the Clean Water Act, referred to in subsec. (b)(3), which was classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1321/b/6/B"},"text":"section 1321(b)(6)(B) of Title 33","children":[],"tail":", Navigation and Navigable Waters, and which related to civil actions by the Administrator to impose penalties for prohibited discharges was struck out by "},{"tag":"ref","attrib":{"href":"/us/pl/101/380/tIV/s4301/b"},"text":"Pub. L. 101–380, title IV, § 4301(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/533"},"text":"104 Stat. 533","children":[],"tail":", which added a new section 311(b)(6)(B) relating to classes of civil penalties imposed by the Secretary of the department in which the Coast Guard is operating or the Administrator for prohibited discharges or violations of regulations."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of the enactment of the Superfund Amendments and Reauthorization Act of 1986, referred to in subsec. (c)(1)(A)(i), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/499"},"text":"Pub. L. 99–499","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3005(a) of the Solid Waste Disposal Act, referred to in subsec. (c)(2)(B), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6925/a"},"text":"section 6925(a) of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Superfund Amendments and Reauthorization Act of 1986, referred to in subsec. (e)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/499"},"text":"Pub. L. 99–499","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1613"},"text":"100 Stat. 1613","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1986 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9601"},"text":"section 9601 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id47becac8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (d)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169"},"text":"Pub. L. 117–169","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2032-12-31"},"text":"December 31, 2032","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1995-12-31"},"text":"December 31, 1995","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" struck out “59A,” before “4611,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (d)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1995-12-31"},"text":"December 31, 1995","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1991-12-31"},"text":"December 31, 1991","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509"},"text":"Pub. L. 99–509","children":[],"tail":" inserted at end “In the case of the tax imposed by section 4611, paragraph (1) shall apply only to so much of such tax as is attributable to the Hazardous Substance Superfund financing rate under section 4611(c).”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47becac9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47becaca-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169"},"text":"Pub. L. 117–169","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2023-01-01"},"text":"Jan. 1, 2023","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/169/s13601/c"},"text":"section 13601(c) of Pub. L. 117–169","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4611"},"text":"section 4611 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47becacb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", subject to a savings provision, see "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/s221/b"},"text":"section 221(b) of Pub. L. 113–295","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47becacc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509"},"text":"Pub. L. 99–509","children":[],"tail":" effective on commencement date as defined in former section 4611(f)(2), see "},{"tag":"ref","attrib":{"href":"/us/pl/99/509/s8032/d"},"text":"section 8032(d) of Pub. L. 99–509","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4611"},"text":"section 4611 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id47becacd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/499/tV/s517/e"},"text":"Pub. L. 99–499, title V, § 517(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1774"},"text":"100 Stat. 1774","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/499/tV/s517/e"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section [enacting this section, amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9601"},"text":"section 9601 of Title 42","children":[],"tail":", The Public Health and Welfare, and repealing sections 9631 to 9633 of Title 42] shall take effect on "},{"tag":"date","attrib":{"date":"1987-01-01"},"text":"January 1, 1987","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Superfund treated as continuation of old trust fund","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Hazardous Substance Superfund established by the amendments made by this section shall be treated for all purposes of law as a continuation of the Hazardous Substance Response Trust Fund established by section 221 of the Hazardous Substance Response Revenue Act of 1980 [former ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9631"},"text":"42 U.S.C. 9631","children":[],"tail":"]. Any reference in any law to the Hazardous Substance Response Trust Fund established by such section 221 shall be deemed to include (wherever appropriate) a reference to the Hazardous Substance Superfund established by the amendments made by this section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id47becace-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Availability of Funds","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dG/tIV/s443/b"},"text":"Pub. L. 117–328, div. G, title IV, § 443(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4833"},"text":"136 Stat. 4833","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dG/tIV/s443/b"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For this fiscal year [Fiscal Year 2023] and each fiscal year thereafter, such sums as are available in the Hazardous Substance Superfund established under section 9507 of the Internal Revenue Code of 1986 at the end of the preceding fiscal year from taxes received in the Treasury under subsection (b)(1) of such section shall be available, without further appropriation, to remain available until expended, to be used to carry out the Comprehensive Environmental Response, Compensation, and Liability Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9601"},"text":"42 U.S.C. 9601","children":[],"tail":" et seq.): "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the amount provided by this subsection is designated by the Congress as being for an emergency requirement pursuant to section 4001(a)(1) of S. Con. Res. 14 (117th Congress), the concurrent resolution on the budget for fiscal year 2022, and section 1(e) of H. Res. 1151 (117th Congress), as engrossed in the House of Representatives on "},{"tag":"date","attrib":{"date":"2022-06-08"},"text":"June 8, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Expenditures made pursuant to section 613 of title VI of division J of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Public Law 117–58","children":[],"tail":" [see below] shall be charged to the appropriation in subsection (b).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/74/dC/tII"},"text":"Pub. L. 119–74, div. C, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2026-01-23"},"text":"Jan. 23, 2026","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/140/128"},"text":"140 Stat. 128","children":[],"tail":", provided in part: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/74/dC/tII"},"text":"“That the matter preceding the first proviso in section 443(b) of title IV of division G of the Consolidated Appropriations Act, 2023 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Public Law 117–328","children":[],"tail":") [set out above] shall be applied in this fiscal year by inserting before the semicolon ‘, including for the hire, maintenance, and operation of aircraft’ ”"}],"tail":"\n.]"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dJ/tVI/s613"},"text":"Pub. L. 117–58, div. J, title VI, § 613","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1406"},"text":"135 Stat. 1406","children":[],"tail":", which provided that in fiscal year 2022 and thereafter, sums available in the Hazardous Substance Superfund under section 9507 at the end of the preceding fiscal year from taxes received in the Treasury under subsection (b)(1) of such section would be available without further appropriation to carry out the Comprehensive Environmental Response, Compensation, and Liability Act of 1980, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dG/tIV/s443/a"},"text":"Pub. L. 117–328, div. G, title IV, § 443(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4833"},"text":"136 Stat. 4833","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id47becacf-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/499/tV/s517/b"},"text":"Pub. L. 99–499, title V, § 517(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1773"},"text":"100 Stat. 1773","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11231/d"},"text":"Pub. L. 101–508, title XI, § 11231(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-445"},"text":"104 Stat. 1388–445","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/508/tXI/s11231/d"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":""},"text":null,"children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"“There is authorized to be appropriated, out of any money in the Treasury not otherwise appropriated, to the Hazardous Substance Superfund for fiscal year—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1987, $250,000,000,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1988, $250,000,000,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1989, $250,000,000,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1990, $250,000,000,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1991, $250,000,000, and [sic]","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1992, $250,000,000,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1993, $250,000,000,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"“(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1994, $250,000,000, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"“(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1995, $250,000,000,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"plus for each fiscal year an amount equal to so much of the aggregate amount authorized to be appropriated under this subsection (and paragraph (2) of section 221(b) of the Hazardous Substance Response Act of 1980 [probably means section 221(b)(2) of the Hazardous Substance Response Revenue Act of 1980, which was classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9631/b/2"},"text":"42 U.S.C. 9631(b)(2)","children":[],"tail":" before its repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/499/s517/c/1"},"text":"section 517(c)(1) of Pub. L. 99–499","children":[],"tail":"], as in effect before its repeal) as has not been appropriated before the beginning of the fiscal year involved.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11231/d"},"text":"Pub. L. 101–508, title XI, § 11231(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-445"},"text":"104 Stat. 1388–445","children":[],"tail":", directed that "},{"tag":"ref","attrib":{"href":"/us/pl/99/499/s517/b"},"text":"section 517(b) of Pub. L. 99–499","children":[],"tail":", set out above, be “amended by striking ‘and’ at the end of paragraph (4), by striking the period at the end of paragraph (5) and inserting ‘, and’, and by adding at the end thereof” new pars. (6) to (9), with par. (9) ending in a period. "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1704/t/44"},"text":"Pub. L. 104–188, title I, § 1704(t)(44)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1889"},"text":"110 Stat. 1889","children":[],"tail":", provided that "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/s11231/d"},"text":"section 11231(d) of Pub. L. 101–508","children":[],"tail":" “shall be applied as if ‘comma’ appeared instead of ‘period’ [in the directory language amending "},{"tag":"ref","attrib":{"href":"/us/pl/99/499/s517/b/5"},"text":"section 517(b)(5) of Pub. L. 99–499","children":[],"tail":"] and as if the paragraph (9) proposed to be added ended with a comma”.]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
