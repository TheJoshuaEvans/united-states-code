{"tag":"section","attrib":{"id":"id41810afe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139L"},"text":null,"children":[{"tag":"num","attrib":{"value":"139L"},"text":"§ 139L.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest on loans secured by rural or agricultural real property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id41810aff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139L/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Gross income shall not include 25 percent of the interest received by a qualified lender on any qualified real estate loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id41810b00-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139L/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified lender","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “qualified lender” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id41810b01-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139L/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any bank or savings association the deposits of which are insured under the Federal Deposit Insurance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1811"},"text":"12 U.S.C. 1811","children":[],"tail":" et seq.),"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41810b02-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139L/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any State- or federally-regulated insurance company,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41810b03-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139L/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any entity wholly owned, directly or indirectly, by a company that is treated as a bank holding company for purposes of section 8 of the International Banking Act of 1978 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3106"},"text":"12 U.S.C. 3106","children":[],"tail":") if—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id41810b04-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139L/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such entity is organized, incorporated, or established under the laws of the United States or any State, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id41810b05-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139L/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the principal place of business of such entity is in the United States (including any territory of the United States),","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41810b06-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139L/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any entity wholly owned, directly or indirectly, by a company that is considered an insurance holding company under the laws of any State if such entity satisfies the requirements described in subparagraphs (A) and (B) of paragraph (3), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41810b07-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139L/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to interest received on a qualified real estate loan secured by real estate described in subsection (c)(3)(A), any federally chartered instrumentality of the United States established under section 8.1(a) of the Farm Credit Act of 1971 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2279aa–1/a"},"text":"12 U.S.C. 2279aa–1(a)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id41810b08-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139L/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified real estate loan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id41810b09-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139L/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified real estate loan” means any loan—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id41810b0a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139L/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" secured by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id41810b0b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139L/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rural or agricultural real estate, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id41810b0c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139L/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a leasehold mortgage (with a status as a lien) on rural or agricultural real estate,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id41810b0d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139L/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made to a person other than a specified foreign entity (as defined in section 7701(a)(51)), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id41810b0e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139L/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made after the date of the enactment of this section.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of the preceding sentence, the determination of whether property securing such loan is rural or agricultural real estate shall be made as of the time the interest income on such loan is accrued.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41810b0f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139L/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refinancings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraphs (A) and (C) of paragraph (1), a loan shall not be treated as made after the date of the enactment of this section to the extent that the proceeds of such loan are used to refinance a loan which was made on or before the date of the enactment of this section (or, in the case of any series of refinancings, the original loan was made on or before such date).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41810b10-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139L/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural or agricultural real estate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “rural or agricultural real estate” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id41810b11-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139L/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any real property which is substantially used for the production of one or more agricultural products,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id41810b12-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139L/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any real property which is substantially used in the trade or business of fishing or seafood processing, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id41810b13-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139L/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any aquaculture facility.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such term shall not include any property which is not located in a State or a possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41810b14-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139L/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aquaculture facility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “aquaculture facility” means any land, structure, or other appurtenance that is used for aquaculture (including any hatchery, rearing pond, raceway, pen, or incubator).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id41810b15-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139L/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with section 265","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any qualified real estate loan, section 265 shall be applied—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id41810b16-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139L/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by treating any qualified real estate loan for purposes of subsection (a)(2) thereof as an obligation the interest on which is wholly exempt from the taxes imposed by this subtitle,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41810b17-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139L/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by substituting “25 percent of the interest on indebtedness” for “Interest on indebtedness” in such subsection (a)(2),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41810b18-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139L/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by treating 25 percent of the adjusted basis of any qualified real estate loan as adjusted basis of a tax-exempt obligation described in subsection (b)(4)(B) thereof, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41810b19-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139L/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by substituting “25 percent of the amount of such indebtedness” for “the amount of such indebtedness” in subsection (b)(6)(A)(a)(ii) ","children":[{"tag":"ref","attrib":{"idref":"fn002064"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002064"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “(b)(6)(A)(ii)”."}],"tail":" thereof."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id41810b1a-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70435/a"},"text":"Pub. L. 119–21, title VII, § 70435(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/246"},"text":"139 Stat. 246","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id41810b1b-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id41810b1c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id41810b1d-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Deposit Insurance Act, referred to in subsec. (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-21/ch967/s2"},"text":"act Sept. 21, 1950, ch. 967, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/873"},"text":"64 Stat. 873","children":[],"tail":", which is classified generally to chapter 16 (§ 1811 et seq.) of Title 12, Banks and Banking. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1811"},"text":"section 1811 of Title 12","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of the enactment of this section, referred to in subsec. (c)(1)(C), (2), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id41810b1e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id41810b1f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70435/c"},"text":"Pub. L. 119–21, title VII, § 70435(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/247"},"text":"139 Stat. 247","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/21/tVII/s70435/c"},"text":"“The amendments made by this section [enacting this section] shall apply to taxable years ending after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
