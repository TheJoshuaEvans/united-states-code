":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/722/s1/c"},"text":"Pub. L. 89–722, § 1(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1152"},"text":"80 Stat. 1152","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"“If the taxpayer establishes a reserve described in section 166(g)(1) of the Internal Revenue Code of 1986 [formerly I.R.C. 1954] (as amended by subsection (a) of this section) for a taxable year ending after ","children":[{"tag":"date","attrib":{"date":"1965-10-21"},"text":"October 21, 1965","children":[],"tail":", and beginning before "},{"tag":"date","attrib":{"date":"1966-08-02"},"text":"August 2, 1966","children":[],"tail":", the establishment of such reserve shall not be considered as a change in method of accounting for purposes of section 446(e) of such Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
