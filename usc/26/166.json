{"tag":"section","attrib":{"id":"id41cb0c1f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s166"},"text":null,"children":[{"tag":"num","attrib":{"value":"166"},"text":"§ 166.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bad debts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id41cb0c20-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s166/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id41cb0c21-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s166/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wholly worthless debts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be allowed as a deduction any debt which becomes worthless within the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41cb0c22-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s166/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partially worthless debts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When satisfied that a debt is recoverable only in part, the Secretary may allow such debt, in an amount not in excess of the part charged off within the taxable year, as a deduction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id41cb0c23-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s166/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of deduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsection (a), the basis for determining the amount of the deduction for any bad debt shall be the adjusted basis provided in section 1011 for determining the loss from the sale or other disposition of property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id41cb0c24-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s166/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"[(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVIII/s805/a"},"text":"Pub. L. 99–514, title VIII, § 805(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2361"},"text":"100 Stat. 2361","children":[],"tail":"]"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id41cb0c25-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s166/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonbusiness debts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id41cb0c26-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s166/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a taxpayer other than a corporation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id41cb0c27-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s166/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (a) shall not apply to any nonbusiness debt; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id41cb0c28-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s166/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where any nonbusiness debt becomes worthless within the taxable year, the loss resulting therefrom shall be considered a loss from the sale or exchange, during the taxable year, of a capital asset held for not more than 1 year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41cb0c29-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s166/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonbusiness debt defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), the term “nonbusiness debt” means a debt other than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id41cb0c2a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s166/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a debt created or acquired (as the case may be) in connection with a trade or business of the taxpayer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id41cb0c2b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s166/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a debt the loss from the worthlessness of which is incurred in the taxpayer’s trade or business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id41cb0c2c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s166/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Worthless securities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to a debt which is evidenced by a security as defined in section 165(g)(2)(C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id41cb0c2d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s166/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross references","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id41cb0c2e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s166/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For disallowance of deduction for worthlessness of debts owed by political parties and similar organizations, see section 271.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41cb0c2f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s166/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For special rule for banks with respect to worthless securities, see section 582.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id41cb0c30-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/50"},"text":"68A Stat. 50","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/866/tI/s8"},"text":"Pub. L. 85–866, title I, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1608"},"text":"72 Stat. 1608","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/722/s1/a"},"text":"Pub. L. 89–722, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1151"},"text":"80 Stat. 1151","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/tIV/s431/c/1"},"text":"Pub. L. 91–172, title IV, § 431(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/619"},"text":"83 Stat. 619","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tVI/s605/a"},"text":"Pub. L. 94–455, title VI, § 605(a)","children":[],"tail":", title XIV, § 1402(b)(1)(A), (2), title XIX, § 1906(b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1575"},"text":"90 Stat. 1575","children":[],"tail":", 1731, 1732, 1834; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tX/s1001/b/1"},"text":"Pub. L. 98–369, div. A, title X, § 1001(b)(1)","children":[],"tail":", (e), "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1011"},"text":"98 Stat. 1011","children":[],"tail":", 1012; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVIII/s805/a"},"text":"Pub. L. 99–514, title VIII, § 805(a)","children":[],"tail":", (b), title IX, § 901(d)(4)(A), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2361"},"text":"100 Stat. 2361","children":[],"tail":", 2379; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1008/d/1"},"text":"Pub. L. 100–647, title I, § 1008(d)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3439"},"text":"102 Stat. 3439","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id41cb0c31-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id41cb0c32-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id41cb0c33-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (d)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1008/d/1"},"text":"Pub. L. 100–647, § 1008(d)(1)","children":[],"tail":", substituted “subsection (a)” for “subsections (a) and (c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1008/d/2"},"text":"Pub. L. 100–647, § 1008(d)(2)","children":[],"tail":", made clarifying amendment to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s805/b"},"text":"Pub. L. 99–514, § 805(b)","children":[],"tail":", see 1986 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s805/a"},"text":"Pub. L. 99–514, § 805(a)","children":[],"tail":", struck out subsec. (c), reserve for bad debts, which read as follows: “In lieu of any deduction under subsection (a), there shall be allowed (in the discretion of the Secretary) a deduction for a reasonable addition to a reserve for bad debts.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s805/b"},"text":"Pub. L. 99–514, § 805(b)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1008/d/2"},"text":"Pub. L. 100–647, § 1008(d)(2)","children":[],"tail":", redesignated subsec. (g) as (f) and struck out former subsec. (f) which related to reserve for certain guaranteed debt obligations, par. (1) thereof providing for allowance of deduction, par. (2) disallowing deduction in other cases, par. (3) relating to opening balance of reserve, and par. (4) relating to suspense account."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s805/b"},"text":"Pub. L. 99–514, § 805(b)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1008/d/2"},"text":"Pub. L. 100–647, § 1008(d)(2)","children":[],"tail":", redesignated subsec. (g) as (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s901/d/4/A"},"text":"Pub. L. 99–514, § 901(d)(4)(A)","children":[],"tail":", struck out pars. (3) and (4) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) For special rule for bad debt reserves of certain mutual savings banks, domestic building and loan associations, and cooperative banks, see section 593.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) For special rule for bad debt reserves of banks, small business investment-companies, etc., see sections 585 and 586.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (d)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" substituted “6 months” for “1 year”, applicable to property acquired after "},{"tag":"date","attrib":{"date":"1984-06-22"},"text":"June 22, 1984","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"1988-01-01"},"text":"Jan. 1, 1988","children":[],"tail":". See Effective Date of 1984 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsecs. (a)(2), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1401/b/1/A"},"text":"Pub. L. 94–455, § 1401(b)(1)(A)","children":[],"tail":", (2), provided that “6 months” would be changed to “9 months” for taxable years beginning in 1977, and “9 months” would be changed to “1 year” for taxable years beginning after "},{"tag":"date","attrib":{"date":"1977-12-31"},"text":"Dec. 31, 1977","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":", §§ 605(a), 1906(b)(13)(A), redesignated subsec. (g) as (f) and struck out “or his delegate” after “Secretary” in pars. (1), (3) and (4)(D). Former subsec. (f), which related to treatment of payments made by guarantors of certain noncorporate obligations, was struck out."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (g), (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s605/a"},"text":"Pub. L. 94–455, § 605(a)","children":[],"tail":", redesignated subsecs. (g) and (h) as (f) and (g), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—Subsec. (h)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172"},"text":"Pub. L. 91–172","children":[],"tail":" added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsecs. (g), (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/722"},"text":"Pub. L. 89–722","children":[],"tail":" added subsec. (g) and redesignated former subsec. (g) as (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (d)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/866"},"text":"Pub. L. 85–866","children":[],"tail":" substituted “a trade or business of the taxpayer” for “a taxpayer’s trade or business”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id41cb0c34-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id41cb0c35-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1019/a"},"text":"section 1019(a) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id41cb0c36-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVIII/s805/d"},"text":"Pub. L. 99–514, title VIII, § 805(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2362"},"text":"100 Stat. 2362","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/tVIII/s805/d"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section [amending this section and sections 81, 108, 461, and 805 of this title] shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Change in method of accounting","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any taxpayer who maintained a reserve for bad debts for such taxpayer’s last taxable year beginning before ","children":[{"tag":"date","attrib":{"date":"1987-01-01"},"text":"January 1, 1987","children":[],"tail":", and who is required by the amendments made by this section to change its method of accounting for any taxable year—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such change shall be treated as initiated by the taxpayer,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such change shall be treated as made with the consent of the Secretary, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the net amount of adjustments required by section 481 of the Internal Revenue Code of 1986 to be taken into account by the taxpayer shall—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a taxpayer maintaining a reserve under section 166(f), be reduced by the balance in the suspense account under section 166(f)(4) of such Code as of the close of such last taxable year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be taken into account ratably in each of the first 4 taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tIX/s901/e"},"text":"Pub. L. 99–514, title IX, § 901(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2380"},"text":"100 Stat. 2380","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/tIX/s901/e"},"text":"“The amendments made by this section [amending this section and sections 172, 291, 582, 585, 593, 596, 856, 1277, and 1361 of this title and repealing ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s586"},"text":"section 586 of this title","children":[],"tail":"] shall apply to taxable years beginning after "},{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id41cb0c37-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tX/s1001/e"},"text":"Pub. L. 98–369, div. A, title X, § 1001(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1012"},"text":"98 Stat. 1012","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/369/dA/tX/s1001/e"},"text":"“The amendments made by this section [amending this section and sections 341, 402, 403, 423, 582, 584, 631, 642, 702, 818, 852, 856, 857, 1222, 1223, 1231, 1232, 1233, 1234, 1235, 1246, 1247, 1248, 1251, and 1278 of this title] shall apply to property acquired after ","children":[{"tag":"date","attrib":{"date":"1984-06-22"},"text":"June 22, 1984","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"1988-01-01"},"text":"January 1, 1988","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id41cb0c38-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tVI/s605/c"},"text":"Pub. L. 94–455, title VI, § 605(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"te