{"tag":"section","attrib":{"id":"id452cad86-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2033"},"text":null,"children":[{"tag":"num","attrib":{"value":"2033"},"text":"§ 2033.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property in which the decedent had an interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The value of the gross estate shall include the value of all property to the extent of the interest therein of the decedent at the time of his death.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id452cad87-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/381"},"text":"68A Stat. 381","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/834/s18/a/2/A"},"text":"Pub. L. 87–834, § 18(a)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-16"},"text":"Oct. 16, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1052"},"text":"76 Stat. 1052","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id452cad88-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id452cad89-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id452cad8a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1962—","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/834"},"text":"Pub. L. 87–834","children":[],"tail":"