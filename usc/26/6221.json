{"tag":"section","attrib":{"id":"id46bd38e4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6221"},"text":null,"children":[{"tag":"num","attrib":{"value":"6221"},"text":"§ 6221.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination at partnership level","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46bd38e5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6221/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any adjustment to a partnership-related item shall be determined, and any tax attributable thereto shall be assessed and collected, and the applicability of any penalty, addition to tax, or additional amount which relates to an adjustment to any such item shall be determined, at the partnership level, except to the extent otherwise provided in this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46bd38e6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6221/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election out for certain partnerships with 100 or fewer partners, etc.","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46bd38e7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6221/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This subchapter shall not apply with respect to any partnership for any taxable year if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46bd38e8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6221/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the partnership elects the application of this subsection for such taxable year,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46bd38e9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6221/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for such taxable year the partnership is required to furnish 100 or fewer statements under section 6031(b) with respect to its partners,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46bd38ea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6221/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each of the partners of such partnership is an individual, a C corporation, any foreign entity that would be treated as a C corporation were it domestic, an S corporation, or an estate of a deceased partner,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46bd38eb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6221/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the election—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id46bd38ec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6221/b/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is made with a timely filed return for such taxable year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46bd38ed-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6221/b/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes (in the manner prescribed by the Secretary) a disclosure of the name and taxpayer identification number of each partner of such partnership, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46bd38ee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6221/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the partnership notifies each such partner of such election in the manner prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46bd38ef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6221/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules relating to certain partners","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46bd38f0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6221/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" S corporation partners","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a partner that is an S corporation—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id46bd38f1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6221/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the partnership shall only be treated as meeting the requirements of paragraph (1)(C) with respect to such partner if such partnership includes (in the manner prescribed by the Secretary) a disclosure of the name and taxpayer identification number of each person with respect to whom such S corporation is required to furnish a statement under section 6037(b) for the taxable year of the S corporation ending with or within the partnership taxable year for which the application of this subsection is elected, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46bd38f2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6221/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the statements such S corporation is required to so furnish shall be treated as statements furnished by the partnership for purposes of paragraph (1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46bd38f3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6221/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign partners","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1)(D)(ii), the Secretary may provide for alternative identification of any foreign partners.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46bd38f4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6221/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other partners","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may by regulation or other guidance prescribe rules similar to the rules of subparagraph (A) with respect to any partners not described in such subparagraph or paragraph (1)(C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46bd38f5-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/74/tXI/s1101/c/1"},"text":"Pub. L. 114–74, title XI, § 1101(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-02"},"text":"Nov. 2, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/625"},"text":"129 Stat. 625","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tII/s201/c/2"},"text":"Pub. L. 115–141, div. U, title II, § 201(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1173"},"text":"132 Stat. 1173","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46bd38f6-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46bd38f7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id46bd38f8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6221, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/tIV/s402/a"},"text":"Pub. L. 97–248, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/648"},"text":"96 Stat. 648","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXII/s1238/a"},"text":"Pub. L. 105–34, title XII, § 1238(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1026"},"text":"111 Stat. 1026","children":[],"tail":", related to tax treatment determined at partnership level, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/114/74/tXI/s1101/a"},"text":"Pub. L. 114–74, title XI, § 1101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-02"},"text":"Nov. 2, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/625"},"text":"129 Stat. 625","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46bd38f9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" amended subsec. (a) generally. Prior to amendment, text read as follows: “Any adjustment to items of income, gain, loss, deduction, or credit of a partnership for a partnership taxable year (and any partner’s distributive share thereof) shall be determined, any tax attributable thereto shall be assessed and collected, and the applicability of any penalty, addition to tax, or additional amount which relates to an adjustment to any such item or share shall be determined, at the partnership level pursuant to this subchapter.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46bd38fa-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46bd38fb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" effective as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/114/74/s1101"},"text":"section 1101 of Pub. L. 114–74","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/s207"},"text":"section 207 of Pub. L. 115–141","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6031"},"text":"section 6031 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id46bd38fc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/74/tXI/s1101/g"},"text":"Pub. L. 114–74, title XI, § 1101(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-02"},"text":"Nov. 2, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/638"},"text":"129 Stat. 638","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/74/tXI/s1101/g"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided in this subsection, the amendments made by this section [enacting this subchapter, amending sections 6031, 6330, 6422, 6501, 6503, 6504, 6511, 6512, 6515, 6601, 7421, 7422, 7459, 7482, and 7485 of this title, and repealing this subchapter, subchapter D of this chapter, and part IV of subchapter K of chapter 1 of this title] shall apply to returns filed for partnership taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2017-12-31"},"text":"December 31, 2017","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative adjustment requests","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of [an] administrative adjustment request under section 6227 of such Code [Internal Revenue Code of 1986], the amendments made by this section shall apply to requests with respect to returns filed for partnership taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2017-12-31"},"text":"December 31, 2017","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Adjusted partners statements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of a partnership electing the application of section 6226 of such Code, the amendments made by this section shall apply to elections with respect to returns filed for partnership taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2017-12-31"},"text":"December 31, 2017","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Election","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A partnership may elect (at such time and in such form and manner as the Secretary of the Treasury may prescribe) for the amendments made by this section (other than the election under section 6221(b) of such Code (as added by this Act)) to apply to any return of the partnership filed for partnership taxable years beginning after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2015-11-02"},"text":"Nov. 2, 2015","children":[],"tail":"] and before "},{"tag":"date","attrib":{"date":"2018-01-01"},"text":"January 1, 2018","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
