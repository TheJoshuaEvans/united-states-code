{"tag":"section","attrib":{"id":"id463c704c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5412"},"text":null,"children":[{"tag":"num","attrib":{"value":"5412"},"text":"§ 5412.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal of beer in containers or by pipeline","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Beer may be removed from the brewery for consumption or sale only in hogsheads, packages, and similar containers, marked, branded, or labeled in such manner as the Secretary may by regulation require, except that beer may be removed from the brewery pursuant to section 5414 or by pipeline to contiguous distilled spirits plants under section 5222.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id463c704d-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1389"},"text":"72 Stat. 1389","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/91/673/s3/d"},"text":"Pub. L. 91–673, § 3(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-12"},"text":"Jan. 12, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/2057"},"text":"84 Stat. 2057","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13803/b"},"text":"Pub. L. 115–97, title I, § 13803(b)","children":[],"t