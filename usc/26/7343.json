{"tag":"section","attrib":{"id":"id4749e920-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7343"},"text":null,"children":[{"tag":"num","attrib":{"value":"7343"},"text":"§ 7343.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of term “person”","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The term “person” as used in this chapter includes an officer or employee of a corporation, or a member or employee of a partnership, who as such officer, employee, or member is under a duty to perform the act in respect of which the violation occurs.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4749e921-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/872"},"text":"68A Stat. 872","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
