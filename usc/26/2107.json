{"tag":"section","attrib":{"id":"id453adefc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2107"},"text":null,"children":[{"tag":"num","attrib":{"value":"2107"},"text":"§ 2107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expatriation to avoid tax","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id453adefd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2107/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of expatriates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A tax computed in accordance with the table contained in section 2001 is hereby imposed on the transfer of the taxable estate, determined as provided in section 2106, of every decedent nonresident not a citizen of the United States if the date of death occurs during a taxable year with respect to which the decedent is subject to tax under section 877(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id453adefe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2107/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gross estate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of the tax imposed by subsection (a), the value of the gross estate of every decedent to whom subsection (a) applies shall be determined as provided in section 2103, except that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id453adeff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2107/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such decedent owned (within the meaning of section 958(a)) at the time of his death 10 percent or more of the total combined voting power of all classes of stock entitled to vote of a foreign corporation, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id453adf00-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2107/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if such decedent owned (within the meaning of section 958(a)), or is considered to have owned (by applying the ownership rules of section 958(b)), at the time of his death, more than 50 percent of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id453adf01-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2107/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total combined voting power of all classes of stock entitled to vote of such corporation, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id453adf02-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2107/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total value of the stock of such corporation,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then that proportion of the fair market value of the stock of such foreign corporation owned (within the meaning of section 958(a)) by such decedent at the time of his death, which the fair market value of any assets owned by such foreign corporation and situated in the United States, at the time of his death, bears to the total fair market value of all assets owned by such foreign corporation at the time of his death, shall be included in the gross estate of such decedent. For purposes of the preceding sentence, a decedent shall be treated as owning stock of a foreign corporation at the time of his death if, at the time of a transfer, by trust or otherwise, within the meaning of sections 2035 to 2038, inclusive, he owned such stock.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id453adf03-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2107/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id453adf04-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2107/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unified credit","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id453adf05-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2107/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A credit of $13,000 shall be allowed against the tax imposed by subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id453adf06-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2107/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation based on amount of tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The credit allowed under this paragraph shall not exceed the amount of the tax imposed by subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id453adf07-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2107/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit for foreign death taxes","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id453adf08-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2107/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tax imposed by subsection (a) shall be credited with the amount of any estate, inheritance, legacy, or succession taxes actually paid to any foreign country in respect of any property which is included in the gross estate solely by reason of subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id453adf09-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2107/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on credit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The credit allowed by subparagraph (A) for such taxes paid to a foreign country shall not exceed the lesser of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id453adf0a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2107/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount which bears the same ratio to the amount of such taxes actually paid to such foreign country as the value of the property subjected to such taxes by such foreign country and included in the gross estate solely by reason of subsection (b) bears to the value of all property subjected to such taxes by such foreign country, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id453adf0b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2107/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such property’s proportionate share of the excess of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id453adf0c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2107/c/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the tax imposed by subsection (a), over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id453adf0d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2107/c/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the tax which would be imposed by section 2101 but for this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id453adf0e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2107/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proportionate share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of property which is included in the gross estate solely by reason of subsection (b), such property’s proportionate share is the percentage which the value of such property bears to the total value of all property included in the gross estate solely by reason of subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id453adf0f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2107/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other credits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tax imposed by subsection (a) shall be credited with the amounts determined in accordance with subsections (a) and (b) of section 2102. For purposes of subsection (a) of section 2102, sections 2012 and 2013 shall be applied as if the credit allowed under paragraph (1) were allowed under section 2010.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id453adf10-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2107/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Burden of proof","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary establishes that it is reasonable to believe that an individual’s loss of United States citizenship would, but for this section, result in a substantial reduction in the estate, inheritance, legacy, and succession taxes in respect of the transfer of his estate, the burden of proving that such loss of citizenship did not have for one of its principal purposes the avoidance of taxes under this subtitle or subtitle A shall be on the executor of such individual’s estate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id453adf11-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2107/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For comparable treatment of long-term lawful permanent residents who ceased to be taxed as residents, see section 877(e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id453adf12-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/809/tI/s108/f"},"text":"Pub. L. 89–809, title I, § 108(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-13"},"text":"Nov. 13, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1573"},"text":"80 Stat. 1573","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX"},"text":"Pub. L. 94–455, title XIX","children":[],"tail":", §§ 1902(a)(6), 1906(b)(13)(A), title XX, § 2001(c)(1)(E)(ii), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1805"},"text":"90 Stat. 1805","children":[],"tail":", 1834, 1851; "},{"tag":"ref","attrib":{"href":"/us/pl/104/191/tV/s511/e/1"},"text":"Pub. L. 104–191, title V, § 511(e)(1)","children":[],"tail":", (f)(2)(A), "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2097"},"text":"110 Stat. 2097","children":[],"tail":", 2099; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXVI/s1602/g/6"},"text":"Pub. L. 105–34, title XVI, § 1602(g)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1095"},"text":"111 Stat. 1095","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/16/tV/s532/c/7/C"},"text":"Pub. L. 107–16, title V, § 532(c)(7)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-06-07"},"text":"June 7, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/75"},"text":"115 Stat. 75","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s804/a/3"},"text":"Pub. L. 108–357, title VIII, § 804(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1570"},"text":"118 Stat. 1570","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id453adf13-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id453adf14-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id453adf15-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":" reenacted heading without change and amended text of subsec. (a) generally, substituting provisions relating to imposition of tax on the transfer of the taxable estate of every decedent nonresident not a citizen of the United States if the date of death occurs during a taxable year with respect to which the decedent is subject to tax under section 877(b), for provisions relating to imposition of tax on the transfer of the taxable estate of every decedent nonresident not a citizen of the United States if, within the 10-year period ending with the date of death, such decedent lost United States citizenship, unless such loss did not have for one of its principal purposes the avoidance of taxes, and provisions describing individuals to be treated as having a principal purpose to avoid taxes."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16"},"text":"Pub. L. 107–16","children":[],"tail":" substituted “2012 and 2013” for “2011 to 2013, inclusive,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (c)(2)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1602/g/6/A"},"text":"Pub. L. 105–34, § 1602(g)(6)(A)","children":[],"tail":", substituted “such foreign country as the value of the property subjected to such taxes by such foreign country and” for “such foreign country in respect of property included in the gross estate as the value of the property”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1602/g/6/B"},"text":"Pub. L. 105–34, § 1602(g)(6)(B)","children":[],"tail":", amended heading and text of subpar. (C) generally. Prior to amendment, text read as follows: “For purposes of subparagraph (B), a property’s proportionate share is the percentage of the value of the property which is included in the gross estate solely by reason of subsection (b) bears to the total value of the gross estate.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191/s511/e/1/A"},"text":"Pub. L. 104–191, § 511(e)(1)(A)","children":[],"tail":", substituted “Treatment of expatriates” for “Rate of tax” in heading and amended text generally. Prior to amendment, text read as follows: “A tax computed in accordance with the table contained in section 2001 is hereby imposed on the transfer of the taxable estate, determined as provided in section 2106, of every decedent nonresident not a citizen of the United States dying after "},{"tag":"date","attrib":{"date":"1966-11-13"},"text":"November 13, 1966","children":[],"tail":", if after "},{"tag":"date","attrib":{"date":"1965-03-08"},"text":"March 8, 1965","children":[],"tail":", and within the 10-year period ending with the date of death such decedent lost United States citizenship, unless such loss did not have for one of its principal purposes the avoidance of taxes under this subtitle or subtitle A.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191/s511/e/1/C"},"text":"Pub. L. 104–191, § 511(e)(1)(C)","children":[],"tail":", substituted “more than 50 percent of—” for “more than 50 percent of the total combined voting power of all classes of stock entitled to vote of such foreign corporation,” and added subpars. (A) and (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191/s511/e/1/B"},"text":"Pub. L. 104–191, § 511(e)(1)(B)","children":[],"tail":", added par. (2) and redesignated former par. (2) as (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191/s511/f/2/A"},"text":"Pub. L. 104–191, § 511(f)(2)(A)","children":[],"tail":", redesignated subsec. (e) as (d) and struck out former subsec. (d) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(d) ","children":[{"tag":"inline","attrib":{},"text":"Exception for Loss of Citizenship for Certain Causes","children":[],"tail":".—Subsection (a) shall not apply to the transfer of the estate of a decedent whose loss of United States citizenship resulted from the application of section 301(b), 350, or 355 of the Immigration and Nationality Act, as amended ("},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1401/b"},"text":"8 U.S.C. 1401(b)","children":[],"tail":", 1482, or 1487).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191/s511/f/2/A"},"text":"Pub. L. 104–191, § 511(f)(2)(A)","children":[],"tail":", added subsec. (e). Former subsec. (e) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1902/a/6"},"text":"Pub. L. 94–455, § 1902(a)(6)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"1966-11-13"},"text":"November 13, 1966","children":[],"tail":"” for “the date of enactment of this section” after “dying after”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s2001/c/1/E/ii"},"text":"Pub. L. 94–455, § 2001(c)(1)(E)(ii)","children":[],"tail":", substituted provisions relating to unified credit for “The tax imposed by subsection (a) shall be credited with the amounts determined in accordance with section 2102.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” after “Secretary”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id453adf16-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id453adf17-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":" applicable to individuals who expatriate after "},{"tag":"date","attrib":{"date":"2004-06-03"},"text":"June 3, 2004","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/s804/f"},"text":"section 804(f) of Pub. L. 108–357","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s877"},"text":"section 877 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendmen