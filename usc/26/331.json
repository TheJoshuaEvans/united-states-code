{"tag":"section","attrib":{"id":"id42b4a957-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s331"},"text":null,"children":[{"tag":"num","attrib":{"value":"331"},"text":"§ 331.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gain or loss to shareholder in corporate liquidations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id42b4a958-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s331/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distributions in complete liquidation treated as exchanges","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts received by a shareholder in a distribution in complete liquidation of a corporation shall be treated as in full payment in exchange for the stock.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42b4a959-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s331/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplication of section 301","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Section 301 (relating to effects on shareholder of distributions of property) shall not apply to any distribution of property (other than a distribution referred to in paragraph (2)(B) of section 316(b)) in complete liquidation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42b4a95a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s331/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For general rule for determination of the amount of gain or loss recognized, see section 1001.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id42b4a95b-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/101"},"text":"68A Stat. 101","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/272/tII/s225/f/2"},"text":"Pub. L. 88–272, title II, § 225(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-02-26"},"text":"Feb. 26, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/88"},"text":"78 Stat. 88","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1901/b/28/A"},"text":"Pub. L. 94–455, title XIX, § 1901(b)(28)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1799"},"text":"90 Stat. 1799","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/248/tII/s222/a"},"text":"Pub. L. 97–248, title II, § 222(a)","children":[],"tail":", (e)(1)(B), "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/478"},"text":"96 Stat. 478","children":[],"tail":", 480; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/63"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(63)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1187"},"text":"132 Stat. 1187","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id42b4a95c-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id42b4a95d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id42b4a95e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" substituted “shareholder” for “shareholders” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/s222/a"},"text":"Pub. L. 97–248, § 222(a)","children":[],"tail":", substituted provisions that amounts received by a shareholder in a distribution in complete liquidation of a corporation shall be treated as in full payment in exchange for the stock for provisions that, in complete liquidations, amounts distributed shall be treated as in full payment in exchange for the stock, while amounts distributed in partial liquidation shall be treated as in part or full payment in exchange for the stock."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/s222/e/1/B"},"text":"Pub. L. 97–248, § 222(e)(1)(B)","children":[],"tail":", struck out “partial or” before “complete liquidation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" substituted “reference” for “references” in heading and struck out cross reference relating to general rule for determination of the amount of gain or loss to the distributee and substituted “section 1001” for “section 1002”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1964—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/272"},"text":"Pub. L. 88–272","children":[],"tail":" inserted “(other than a distribution referred to in paragraph (2)(B) of section 316(b))”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id42b4a95f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id42b4a960-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1982 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248"},"text":"Pub. L. 97–248","children":[],"tail":" applicable to distributions after "},{"tag":"date","attrib":{"date":"1982-08-31"},"text":"Aug. 31, 1982","children":[],"tail":", with exceptions for certain partial liquidations, see "},{"tag":"ref","attrib":{"href":"/us/pl/97/248/s222/f"},"text":"section 222(f) of Pub. L. 97–248","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s302"},"text":"section 302 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id42b4a961-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" effective for taxable years beginning after "},{"tag":"date","attrib":{"date":"1976-12-31"},"text":"Dec. 31, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1901/d"},"text":"secti