{"tag":"section","attrib":{"id":"id44f5bf3f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1375"},"text":null,"children":[{"tag":"num","attrib":{"value":"1375"},"text":"§ 1375.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax imposed when passive investment income of corporation having accumulated earnings and profits exceeds 25 percent of gross receipts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44f5bf40-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1375/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If for the taxable year an S corporation has—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44f5bf41-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1375/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accumulated earnings and profits at the close of such taxable year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44f83042-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1375/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gross receipts more than 25 percent of which are passive investment income,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then there is hereby imposed a tax on the income of such corporation for such taxable year. Such tax shall be computed by multiplying the excess net passive income by the highest rate of tax specified in section 11(b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44f83043-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1375/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44f83044-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1375/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excess net passive income","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44f83045-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1375/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subparagraph (B), the term “excess net passive income” means an amount which bears the same ratio to the net passive income for the taxable year as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44f83046-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1375/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount by which the passive investment income for the taxable year exceeds 25 percent of the gross receipts for the taxable year, bears to","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44f83047-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1375/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the passive investment income for the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44f83048-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1375/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of the excess net passive income for any taxable year shall not exceed the amount of the corporation’s taxable income for such taxable year as determined under section 63(a)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44f83049-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1375/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without regard to the deductions allowed by part VIII of subchapter B (other than the deduction allowed by section 248, relating to organization expenditures), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44f8304a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1375/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without regard to the deduction under section 172.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44f8304b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1375/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Net passive income","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “net passive income” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44f8304c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1375/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" passive investment income, reduced by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44f8304d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1375/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deductions allowable under this chapter which are directly connected with the production of such income (other than deductions allowable under section 172 and part VIII of subchapter B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44f8304e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1375/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Passive investment income, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “passive investment income” and “gross receipts” have the same respective meanings as when used in paragraph (3) of section 1362(d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44f8304f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1375/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with section 1374","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (3), the amount of passive investment income shall be determined by not taking into account any recognized built-in gain or loss of the S corporation for any taxable year in the recognition period. Terms used in the preceding sentence shall have the same respective meanings as when used in section 1374.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44f83050-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1375/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credits not allowable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No credit shall be allowed under part IV of subchapter A of this chapter (other than section 34) against the tax imposed by subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44f83051-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1375/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of tax in certain cases","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the S corporation establishes to the satisfaction of the Secretary that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44f83052-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1375/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it determined in good faith that it had no accumulated earnings and profits at the close of a taxable year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44f83053-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1375/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during a reasonable period of time after it was determined that it did have accumulated earnings and profits at the close of such taxable year such earnings and profits were distributed,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Secretary may waive the tax imposed by subsection (a) for such taxable year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44f83054-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/354/s2"},"text":"Pub. L. 97–354, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-19"},"text":"Oct. 19, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1684"},"text":"96 Stat. 1684","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tIV/s474/r/28"},"text":"Pub. L. 98–369, div. A, title IV, § 474(r)(28)","children":[],"tail":", title VII, § 721(v), "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/844"},"text":"98 Stat. 844","children":[],"tail":", 971; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVI/s632/c/3"},"text":"Pub. L. 99–514, title VI, § 632(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2277"},"text":"100 Stat. 2277","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1006/f/5/B"},"text":"Pub. L. 100–647, title I, § 1006(f)(5)(B)","children":[],"tail":"–(D), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3406"},"text":"102 Stat. 3406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1311/b/2/A"},"text":"Pub. L. 104–188, title I, § 1311(b)(2)(A)","children":[],"tail":"–(C), "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1784"},"text":"110 Stat. 1784","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/135/tIV/s412/qq"},"text":"Pub. L. 109–135, title IV, § 412(qq)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-21"},"text":"Dec. 21, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2640"},"text":"119 Stat. 2640","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44f83055-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44f83056-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id44f83057-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1375, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/866/tI/s64/a"},"text":"Pub. L. 85–866, title I, § 64(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1654"},"text":"72 Stat. 1654","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/88/272/tII"},"text":"Pub. L. 88–272, title II","children":[],"tail":", §§ 201(d)(13), 233(b), "},{"tag":"date","attrib":{"date":"1964-02-26"},"text":"Feb. 26, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/32"},"text":"78 Stat. 32","children":[],"tail":", 112; "},{"tag":"ref","attrib":{"href":"/us/pl/89/389"},"text":"Pub. L. 89–389","children":[],"tail":", §§ 1(a), (b), 2(b)(4), "},{"tag":"date","attrib":{"date":"1966-04-14"},"text":"Apr. 14, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/111"},"text":"80 Stat. 111","children":[],"tail":", 114; "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/tIII/s301/b/11"},"text":"Pub. L. 91–172, title III, § 301(b)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/586"},"text":"83 Stat. 586","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX"},"text":"Pub. L. 94–455, title XIX","children":[],"tail":", §§ 1901(a)(151), (b)(33)(Q), 1906(b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1788"},"text":"90 Stat. 1788","children":[],"tail":", 1802, 1834; "},{"tag":"ref","attrib":{"href":"/us/pl/95/600/tVII/s703/j/6"},"text":"Pub. L. 95–600, title VII, § 703(j)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2941"},"text":"92 Stat. 2941","children":[],"tail":", related to special rules applicable to distributions of electing small business corporations, prior to the general revision of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/97/354/s2"},"text":"section 2 of Pub. L. 97–354","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 1376, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/866/tI/s64/a"},"text":"Pub. L. 85–866, title I, § 64(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1655"},"text":"72 Stat. 1655","children":[],"tail":", related to adjustment to basis of stock of, and indebtedness owing, shareholders, prior to the general revision of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/97/354/s2"},"text":"section 2 of Pub. L. 97–354","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44f83058-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (d)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/135"},"text":"Pub. L. 109–135","children":[],"tail":" substituted “accumulated” for “subchapter C”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1311/b/2/C"},"text":"Pub. L. 104–188, § 1311(b)(2)(C)","children":[],"tail":", substituted “accumulated” for “subchapter C” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1311/b/2/A"},"text":"Pub. L. 104–188, § 1311(b)(2)(A)","children":[],"tail":", substituted “accumulated” for “subchapter C”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1311/b/2/B"},"text":"Pub. L. 104–188, § 1311(b)(2)(B)","children":[],"tail":", amended par. (3) generally. Prior to amendment, par. (3) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) ","children":[{"tag":"inline","attrib":{},"text":"Passive investment income; etc","children":[],"tail":".—The terms ‘subchapter C earnings and profits’, ‘passive investment income’, and ‘gross receipts’ shall have the same respective meanings as when used in paragraph (3) of section 1362(d).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1006/f/5/B"},"text":"Pub. L. 100–647, § 1006(f)(5)(B)","children":[],"tail":", amended subpar. (B) generally. Prior to amendment, subpar. (B) read as follows: “The amount of the excess net passive income for any taxable year shall not exceed the corporation’s taxable income for the taxable year (determined in accordance with section 1374(d)(4)).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1006/f/5/C"},"text":"Pub. L. 100–647, § 1006(f)(5)(C)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":