{"tag":"section","attrib":{"id":"id44e2ac89-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1294"},"text":null,"children":[{"tag":"num","attrib":{"value":"1294"},"text":"§ 1294.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election to extend time for payment of tax on undistributed earnings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44e2ac8a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1294/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension allowed by election","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44e2ac8b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1294/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the election of the taxpayer, the time for payment of any undistributed PFIC earnings tax liability of the taxpayer for the taxable year shall be extended to the extent and subject to the limitations provided in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44e2ac8c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1294/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election not permitted where amounts otherwise includible under section 951","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The taxpayer may not make an election under paragraph (1) with respect to the undistributed PFIC earnings tax liability attributable to a qualified electing fund for the taxable year if any amount is includible in the gross income of the taxpayer under section 951 with respect to such fund for such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44e2ac8d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1294/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44e2ac8e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1294/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Undistributed PFIC earnings tax liability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “undistributed PFIC earnings tax liability” means, in the case of any taxpayer, the excess of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44e2ac8f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1294/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the tax imposed by this chapter for the taxable year, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44e2ac90-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1294/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the tax which would be imposed by this chapter for such year without regard to the inclusion in gross income under section 1293 of the undistributed earnings of a qualified electing fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44e2ac91-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1294/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Undistributed earnings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “undistributed earnings” means, with respect to any qualified electing fund, the excess (if any) of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44e2ac92-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1294/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount includible in gross income by reason of section 1293(a) for the taxable year, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44e2ac93-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1294/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount not includible in gross income by reason of section 1293(c) for such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44e2ac94-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1294/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of extension","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44e2ac95-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1294/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distributions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44e2ac96-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1294/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a distribution is not includible in gross income for the taxable year by reason of section 1293(c), then the extension under subsection (a) for payment of the undistributed PFIC earnings tax liability with respect to the earnings to which such distribution is attributable shall expire on the last date prescribed by law (determined without regard to extensions) for filing the return of tax for such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44e2ac97-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1294/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ordering rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A), a distribution shall be treated as made from the most recently accumulated earnings and profits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44e2ac98-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1294/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers, etc.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44e2ac99-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1294/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stock in a passive foreign investment company is transferred during the taxable year, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44e2ac9a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1294/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a passive foreign investment company ceases to be a qualified electing fund,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"all extensions under subsection (a) for payment of undistributed PFIC earnings tax liability attributable to such stock (or, in the case of such a cessation, attributable to any stock in such company) which had not expired before the date of such transfer or cessation shall expire on the last date prescribed by law (determined without regard to extensions) for filing the return of tax for the taxable year in which such transfer or cessation occurs. To the extent provided in regulations, the preceding sentence shall not apply in the case of a transfer in a transaction with respect to which gain or loss is not recognized (in whole or in part), and the transferee in such transaction shall succeed to the treatment under this section of the transferor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44e2ac9b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1294/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jeopardy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary believes that collection of an amount to which an extension under this section relates is in jeopardy, the Secretary shall immediately terminate such extension with respect to such amount, and notice and demand shall be made by him for payment of such amount.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44e2ac9c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1294/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The election under subsection (a) shall be made not later than the time prescribed by law (including extensions) for filing the return of tax imposed by this chapter for the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44e2ac9d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1294/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to require bond","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Section 6165 shall apply to any extension under this section as though the Secretary were extending the time for payment of the tax.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44e2ac9e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1294/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of loans to shareholder","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section and section 1293, any loan by a qualified electing fund (directly or indirectly) to a shareholder of such fund shall be treated as a distribution to such shareholder.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44e2ac9f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1294/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For provisions providing for interest for the period of the extension under this section, see section 6601.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44e2aca0-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXII/s1235/a"},"text":"Pub. L. 99–514, title XII, § 1235(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2570"},"text":"100 Stat. 2570","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1012/p/4"},"text":"Pub. L. 100–647, title I, § 1012(p)(4)","children":[],"tail":", (8), (25), (34), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3515"},"text":"102 Stat. 3515","children":[],"tail":", 3517, 3519, 3522; "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tIV/s413/c/25"},"text":"Pub. L. 108–357, title IV, § 413(c)(25)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1509"},"text":"118 Stat. 1509","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44e2aca1-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44e2aca2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44e2aca3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":" amended heading and text of par. (2) generally. Prior to amendment, text read as follows: “The taxpayer may not make an election under paragraph (1) with respect to the undistributed PFIC earnings tax liability attributable to a qualified electing fund for the taxable year if—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) any amount is includible in the gross income of the taxpayer under section 551 with respect to such fund for such taxable year, or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) any amount is includible in the gross income of the taxpayer under section 951 with respect to such fund for such taxable year.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1012/p/4"},"text":"Pub. L. 100–647, § 1012(p)(4)","children":[],"tail":", (34), substituted “Transfers” for “Dispositions” in heading and “is transferred” for “is disposed of” in subpar. (A), and in closing provisions substituted “such transfer” for “such disposition” in two places and inserted at end “To the extent provided in regulations, the preceding sentence shall not apply in the case of a transfer in a transaction with respect to which gain or loss is not recognized (in whole or in part), and the transferee in such transaction shall succeed to the treatment under this section of the transferor.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1012/p/25"},"text":"Pub. L. 100–647, § 1012(p)(25)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1012/p/8"},"text":"Pub. L. 100–647, § 1012(p)(8)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44e2aca4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44e2aca5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":" applicable to taxable years of foreign corporations beginning after "},{"tag":"date","attrib":{"date":"2004-12-31"},"text":"Dec. 31, 2004","children":[],"tail":", and to taxable years of United States shareholders with or within which such taxable years of foreign corporations end, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/s413/d/1"},"text":"section 413(d)(1) of Pub. L. 108–357","children":[],"tail":", set out as an Effective and Termination Dates of 2004 Amendments note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44e2aca6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1019/a"},"text":"section 1019(a) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id44e2aca7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to taxable years of foreign corporations beginning after ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"Dec. 31, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1235/h"},"text":"section 1235(h) of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1291"},"text":"section 1291 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
