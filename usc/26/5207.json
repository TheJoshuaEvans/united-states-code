{"tag":"section","attrib":{"id":"id462e18b8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5207"},"text":null,"children":[{"tag":"num","attrib":{"value":"5207"},"text":"§ 5207.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records and reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id462e18b9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5207/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records of distilled spirits plant proprietors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Every distilled spirits plant proprietor shall keep records in such form and manner as the Secretary shall by regulations prescribe of:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id462e18ba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5207/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The following production activities—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id462e18bb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5207/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the receipt of materials intended for use in the production of distilled spirits, and the use thereof,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id462e18bc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5207/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the receipt and use of distilled spirits received for redistillation, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id462e18bd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5207/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the kind and quantity of distilled spirits produced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id462e18be-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5207/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The following storage activities—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id462e18bf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5207/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the kind and quantity of distilled spirits, wines, and alcoholic ingredients entered into storage,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id462e18c0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5207/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the kind and quantity of distilled spirits, wines, and alcoholic ingredients removed, and the purpose for which removed, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id462e18c1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5207/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the kind and quantity of distilled spirits returned to storage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id462e18c2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5207/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The following denaturation activities—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id462e18c3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5207/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the kind and quantity of denaturants received and used or otherwise disposed of,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id462e18c4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5207/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the kind and quantity of distilled spirits denatured, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id462e18c5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5207/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the kind and quantity of denatured distilled spirits removed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id462e18c6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5207/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The following processing activities—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id462e18c7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5207/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all distilled spirits, wines, and alcoholic ingredients received or transferred,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id462e18c8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5207/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the kind and quantity of distilled spirits packaged or bottled, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id462e18c9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5207/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the kind and quantity of distilled spirits removed from his premises.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id462e18ca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5207/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such additional information with respect to activities described in paragraphs (1), (2), (3), and (4), and with respect to other activities, as may by regulations be required.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id462e18cb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5207/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every person required to keep records under subsection (a) shall render such reports covering his operations, at such times and in such form and manner and containing such information, as the Secretary shall by regulations prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id462e18cc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5207/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation and inspection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The records required by subsection (a) and a copy of each report required by subsection (b) shall be available for inspection by any internal revenue officer during business hours, and shall be preserved by the person required to keep such records and reports for such period as the Secretary shall by regulations prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id462e18cd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5207/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For penalty and forfeiture for refusal or neglect to keep records required under this section, or for false entries therein, see sections 5603 and 5615(5).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id462e18ce-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1361"},"text":"72 Stat. 1361","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/176/s2/e"},"text":"Pub. L. 95–