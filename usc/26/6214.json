},"text":"Pub. L. 100–418, title I, § 1941(b)(2)(B)(vi)","children":[],"tail":", (vii), "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1323"},"text":"102 Stat. 1323","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tVI/s6244/b/1"},"text":"Pub. L. 100–647, title VI, § 6244(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3750"},"text":"102 Stat. 3750","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1704/t/16"},"text":"Pub. L. 104–188, title I, § 1704(t)(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1888"},"text":"110 Stat. 1888","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/280/tVIII/s858/a"},"text":"Pub. L. 109–280, title VIII, § 858(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1020"},"text":"120 Stat. 1020","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46bd38b1-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46bd38b2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46bd38b3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280"},"text":"Pub. L. 109–280","children":[],"tail":" inserted at end “Notwithstanding the preceding sentence, the Tax Court may apply the doctrine of equitable recoupment to the same extent that it is available in civil tax cases before the district courts of the United States and the United States Court of Federal Claims.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":" amended subsec. (e) generally, striking par. (2) designation and par. (1) which provided cross reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6621/c/4"},"text":"section 6621(c)(4) of this title","children":[],"tail":" for provision giving Tax Court jurisdiction to determine whether any portion of deficiency is a substantial underpayment attributable to tax motivated transactions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1941/b/2/B/vi"},"text":"Pub. L. 100–418, § 1941(b)(2)(B)(vi)","children":[],"tail":", substituted “or 44” for “44, or 45” in heading and wherever appearing in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/s1941/b/2/B/vii"},"text":"Pub. L. 100–418, § 1941(b)(2)(B)(vii)","children":[],"tail":", substituted “or 44” for “44, or 45”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" substituted “references” for “reference” in heading, designated existing provisions as par. (1), and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1554/a"},"text":"Pub. L. 99–514, § 1554(a)","children":[],"tail":", substituted “any addition to the tax” for “addition to the tax”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1833"},"text":"Pub. L. 99–514, § 1833","children":[],"tail":", substituted “section 4963(b)” for “section 4962(b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1511/c/8"},"text":"Pub. L. 99–514, § 1511(c)(8)","children":[],"tail":", substituted “section 6621(c)(4)” for “section 6621(d)(4)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/596"},"text":"Pub. L. 96–596","children":[],"tail":" inserted provision directing the Tax Court, in redetermining a deficiency of any second tier tax, to make a determination with respect to whether the taxable event has been corrected."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/223/s101/f/1/F"},"text":"Pub. L. 96–223, § 101(f)(1)(F)","children":[],"tail":", inserted reference to chapter 45."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/223/s101/f/1/G"},"text":"Pub. L. 96–223, § 101(f)(1)(G)","children":[],"tail":", inserted reference to chapter 45."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":", §§ 1307(d)(2)(F)(iv), (H), 1605(b)(7)(A), (B), substituted in heading and in text “41, 42, 43, or 44” for “42 or 43”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":", §§ 1307(d)(2)(F)(iv), 1605(b)(7)(C), substituted “41, 42, 43, or 44” for “42 or 43”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/s1016/a/12/A"},"text":"Pub. L. 93–406, § 1016(a)(12)(A)","children":[],"tail":", (B), inserted reference to chapter 43 in heading and in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/s1016/a/12/C"},"text":"Pub. L. 93–406, § 1016(a)(12)(C)","children":[],"tail":", inserted reference to chapter 43."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/614"},"text":"Pub. L. 91–614","children":[],"tail":" inserted reference to calendar quarters in heading and in text in regard to gift tax deficiencies."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172/s960/a"},"text":"Pub. L. 91–172, § 960(a)","children":[],"tail":", inserted reference to exception provided for in "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s7463"},"text":"section 7463 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172/s101/j/43"},"text":"Pub. L. 91–172, § 101(j)(43)","children":[],"tail":", (44), added subsec. (c), redesignated former subsec. (c) as (d), and, in subsec. (d) as so redesignated, inserted reference to chapter 42."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46bd38b4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46bd38b5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/tVIII/s858/b"},"text":"Pub. L. 109–280, title VIII, § 858(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1020"},"text":"120 Stat. 1020","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/280/tVIII/s858/b"},"text":"“The amendment made by this section [amending this section] shall apply to any action or proceeding in the United States Tax Court with respect to which a decision has not become final (as determined under section 7481 of the Internal Revenue Code of 1986) as of the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46bd38b6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tVI/s6244/c"},"text":"Pub. L. 100–647, title VI, § 6244(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3750"},"text":"102 Stat. 3750","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/647/tVI/s6244/c"},"text":"“The amendments made by this section [amending this s