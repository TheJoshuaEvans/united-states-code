topic":"priorProvisions","id":"id45be17fa-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For prior section 4121, see Prior Provisions note set out preceding this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45be17fb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169"},"text":"Pub. L. 117–169","children":[],"tail":" struck out subsec. (e) which related to reduction in amount of tax."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsec. (e)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2021-12-31"},"text":"December 31, 2021","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2020-12-31"},"text":"December 31, 2020","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (e)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94"},"text":"Pub. L. 116–94","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2020-12-31"},"text":"December 31, 2020","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (e)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343/s113/a/1"},"text":"Pub. L. 110–343, § 113(a)(1)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2014-01-01"},"text":"January 1, 2014","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343/s113/a/2"},"text":"Pub. L. 110–343, § 113(a)(2)","children":[],"tail":", substituted “December 31 after 2007” for “January 1 after 1981” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (e)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" substituted “2014” for “1996”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272/s13203/a"},"text":"Pub. L. 99–272, § 13203(a)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment subsec. (a) read as follows: “There is hereby imposed on coal sold by the producer a tax at the rates of—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) 50 cents per ton in the case of coal from underground mines located in the United States, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) 25 cents per ton in the case of coal from surface mines located in the United States.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" struck out “, in the case of sales during any calendar year beginning after "},{"tag":"date","attrib":{"date":"1985-12-31"},"text":"December 31, 1985","children":[],"tail":"” after “subsection (a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272/s13203/a"},"text":"Pub. L. 99–272, § 13203(a)","children":[],"tail":", amended subsec. (b) generally. Prior to amendment subsec. (b), limitation on tax, read as follows: “The amount of the tax imposed by subsection (a) with respect to a ton of coal shall not exceed 2 percent of the price at which such ton of coal is sold by the producer.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272/s13203/c"},"text":"Pub. L. 99–272, § 13203(c)","children":[],"tail":", substituted “Reduction in amount of tax” for “Temporary increase in amount of tax” in heading and amended par. (1) generally. Prior to amendment par. (1) read as follows: “Effective with respect to sales after "},{"tag":"date","attrib":{"date":"1981-12-31"},"text":"December 31, 1981","children":[],"tail":", and before the temporary increase termination date—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) subsection (a) shall be applied—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) by substituting ‘$1’ for ‘50 cents’, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) by substituting ‘50 cents’ for ‘25 cents’, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) subsection (b) shall be applied by substituting ‘4 percent’ for ‘2 percent’.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/119"},"text":"Pub. L. 97–119","children":[],"tail":" added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45be17fc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45be17fd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169/tI/s13901/b"},"text":"Pub. L. 117–169, title I, § 13901(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2013"},"text":"136 Stat. 2013","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/169/tI/s13901/b"},"text":"“The amendment made by this section [amending this section] shall apply to sales in calendar quarters beginning after the date which is 1 day after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45be17fe-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dEE/tI/s149/b"},"text":"Pub. L. 116–260, div. EE, title I, § 149(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3056"},"text":"134 Stat. 3056","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/260/dEE/tI/s149/b"},"text":"“The amendment made by this section [amending this section] shall apply to sales after ","children":[{"tag":"date","attrib":{"date":"2020-12-31"},"text":"December 31, 2020","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45be17ff-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2019 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dQ/tI/s105/b"},"text":"Pub. L. 116–94, div. Q, title I, § 105(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3228"},"text":"133 Stat. 3228","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/94/dQ/tI/s105/b"},"text":"“The amendment made by this section [amending this section] shall apply on and after the first day of the first calendar month beginning after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45be1800-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVIII/s1897/b"},"text":"Pub. L. 99–514, title XVIII, § 1897(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2941"},"text":"100 Stat. 2941","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/tXVIII/s1897/b"},"text":"“The amendment made by subsection (a) [amending this section] shall take effect as if included in the amendment made by section 13203 of the Consolidated Omnibus Budget Reconciliation Act of 1985 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272/s13203"},"text":"section 13203 of Pub. L. 99–272","children":[],"tail":", see note below].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272/tXIII/s13203/d"},"text":"Pub. L. 99–272, title XIII, § 13203(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/313"},"text":"100 Stat. 313","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/272/tXIII/s13203/d"},"text":"“The amendments made by this section [amending this section] shall apply to sales after ","children":[{"tag":"date","attrib":{"date":"1986-03-31"},"text":"March 31, 1986","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45be1801-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/119/tI/s102/b"},"text":"Pub. L. 97–119, title I, § 102(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1635"},"text":"95 Stat. 1635","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/119/tI/s102/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply to sales after ","children":[{"tag":"date","attrib":{"date":"1981-12-31"},"text":"December 31, 1981","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id45be1802-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/227/s2/d"},"text":"Pub. L. 95–227, § 2(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-02-10"},"text":"Feb. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/12"},"text":"92 Stat. 12","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/227/s2/d"},"text":"“The amendments made by this section [enacting this section and amending sections 4218, 4221, 4293, and 6416 of this title] shall apply with respect to sales after ","children":[{"tag":"date","attrib":{"date":"1978-03-31"},"text":"March 31, 1978","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/227/s5"},"text":"Pub. L. 95–227, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-02-10"},"text":"Feb. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/24"},"text":"92 Stat. 24","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/227/s5"},"text":"“Notwithstanding any other provision of this Act [see Short Title of 1978 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"] to the contrary, no provision of this Act (including any amendment made by any such provision) shall take effect or apply unless an Act, enacted after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1978-02-10"},"text":"Feb. 10, 1978","children":[],"tail":"], contains a provision, explicitly in satisfaction of the requirements of this section, which states that it is the intent of the Congress that the provisions of this Act shall take effect.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/239/s20/c"},"text":"Pub. L. 95–239, § 20(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-03-01"},"text":"Mar. 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/106"},"text":"92 Stat. 106","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/239/s20/c"},"text":"“In accordance with the requirements of section 5 of the Black Lung Benefits Revenue Act of 1977 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/227"},"text":"Pub. L. 95–227","children":[],"tail":", set out above], it is hereby provided that such Act shall take effect in accordance with the provisions of such Act. The provisions of this subsection are hereby deemed to be in explicit satisfaction of the requirements of section 5 of such Act.”"}],"tail":"\n]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id45be1803-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For short title of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/227"},"text":"Pub. L. 95–227","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-02-10"},"text":"Feb. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/11"},"text":"92 Stat. 11","children":[],"tail":", as the “Black Lung Benefits Revenue Act of 1977”, see Short Title of 1978 Amendments note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id45be1804-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Special Rules for Refund of the Coal Excise Tax to Certain Coal Producers and Exporters","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/343/dB/tI/s114"},"text":"Pub. L. 110–343, div. B, title I, § 114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3826"},"text":"122 Stat. 3826","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/343/dB/tI/s114"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Refund.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coal producers.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding subsections (a)(1) and (c) of section 6416 and section 6511 of the Internal Revenue Code of 1986, if—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a coal producer establishes that such coal producer, or a party related to such coal producer, exported coal produced by such coal producer to a foreign country or shipped coal produced by such coal producer to a possession of the United States, or caused such coal to be exported or shipped, the export or shipment of which was other than through an exporter who meets the requirements of paragraph (2),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such coal producer filed an excise tax return on or after ","children":[{"tag":"date","attrib":{"date":"1990-10-01"},"text":"October 1, 1990","children":[],"tail":", and on or before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":"], and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such coal producer files a claim for refund with the Secretary not later than the close of the 30-day period beginning on the date of the enactment of this Act,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"  then the Secretary shall pay to such coal producer an amount equal to the tax paid under section 4121 of such Code on such coal exported or shipped by the coal producer or a party related to such coal producer, or caused by the coal producer or a party related to such coal producer to be exported or shipped.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special rules for certain taxpayers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a coal producer or a party related to a coal producer has received a judgment described in clause (iii), such coal producer shall be deemed to have established the export of coal to a foreign country or shipment of coal to a possession of the United States under subparagraph (A)(i).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount of payment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a taxpayer described in clause (i) is entitled to a payment under subparagraph (A), the amount of such payment shall be reduced by any amount paid pursuant to the judgment described in clause (iii).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Judgment described","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A judgment is described in this subparagraph if such judgment—","children":[],"tail":null},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"     “(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is made by a court of competent jurisdiction within the United States,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"     “(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relates to the constitutionality of any tax paid on exported coal under section 4121 of the Internal Revenue Code of 1986, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"     “(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in favor of the coal producer or the party related to the coal producer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exporters","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding subsections (a)(1) and (c) of section 6416 and section 6511 of the Internal Revenue Code of 1986, and a judgment described in paragraph (1)(B)(iii) of this subsection, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an exporter establishes that such exporter exported coal to a foreign country or shipped coal to a possession of the United States, or caused such coal to be so exported or shipped,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such exporter filed a tax return on or after ","children":[{"tag":"date","attrib":{"date":"1990-10-01"},"text":"October 1, 1990","children":[],"tail":", and on or before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":"], and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such exporter files a claim for refund with the Secretary not later than the close of the 30-day period beginning on the date of the enactment of this Act,","children":[{"tag":"p","attrib":{},"text":"  then the Secretary shall pay to such exporter an amount equal to $0.825 per ton of such coal exported by the exporter or caused to be exported or shipped, or caused to be exported or shipped, [sic] by the exporter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) shall not apply with respect to exported coal if a settlement with the Federal Government has been made with and accepted by, the coal producer, a party related to such coal producer, or the exporter, of such coal, as of the date that the claim is filed under this section with respect to such exported coal. For purposes of this subsection, the term ‘settlement with the Federal Government’ shall not include any settlement or stipulation entered into as of the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":"], the terms of which contemplate a judgment concerning which any party has reserved the right to file an appeal, or has filed an appeal."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subsequent Refund Prohibited","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No refund shall be made under this section to the extent that a credit or refund of such tax on such exported or shipped coal has been paid to any person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coal producer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘coal producer’ means the person in whom is vested ownership of the coal immediately after the coal is severed from the ground, without regard to the existence of any contractual arrangement for the sale or other disposition of the coal or the payment of any royalties between the producer and third parties. The term includes any person who extracts coal from coal waste refuse piles or from the silt waste product which results from the wet washing (or similar processing) of coal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exporter","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘exporter’ means a person, other than a coal producer, who does not have a contract, fee arrangement, or any other agreement with a producer or seller of such coal to export or ship such coal to a third party on behalf of the producer or seller of such coal and—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is indicated in the shipper’s export declaration or other documentation as the exporter of record, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actually exported such coal to a foreign country or shipped such coal to a possession of the United States, or caused such coal to be so exported or shipped.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Related party","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘a party related to such coal producer’ means a person who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is related to such coal producer through any degree of common management, stock ownership, or voting control,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is related (within the meaning of section 144(a)(3) of the Internal Revenue Code of 1986) to such coal producer, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a contract, fee arrangement, or any other agreement with such coal producer to sell such coal to a third party on behalf of such coal producer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Secretary’ means the Secretary of [the] Treasury or the Secretary’s designee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timing of Refund","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With respect to any claim for refund filed pursuant to this section, the Secretary shall determine whether the requirements of this section are met not later than 180 days after such claim is filed. If the Secretary determines that the requirements of this section are met, the claim for refund shall be paid not later than 180 days after the Secretary makes such determination.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interest","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any refund paid pursuant to this section shall be paid by the Secretary with interest from the date of overpayment determined by using the overpayment rate and method under section 6621 of the Internal Revenue Code of 1986.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"“(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Denial of Double Benefit","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The payment under subsection (a) with respect to any coal shall not exceed—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a payment to a coal producer, the amount of tax paid under section 4121 of the Internal Revenue Code of 1986 with respect to such coal by such coal producer or a party related to such coal producer, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a payment to an exporter, an amount equal to $0.825 per ton with respect to such coal exported by the exporter or caused to be exported by the exporter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"“(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application of Section","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section applies only to claims on coal exported or shipped on or after ","children":[{"tag":"date","attrib":{"date":"1990-10-01"},"text":"October 1, 1990","children":[],"tail":", through the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2008-10-03"},"text":"Oct. 3, 2008","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standing Not Conferred.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exporters","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With respect to exporters, this section shall not confer standing upon an exporter to commence, or intervene in, any judicial or administrative proceeding concerning a claim for refund by a coal producer of any Federal or State tax, fee, or royalty paid by the coal producer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coal producers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With respect to coal producers, this section shall not confer standing upon a coal producer to commence, or intervene in, any judicial or administrative proceeding concerning a claim for refund by an exporter of any Federal or State tax, fee, or royalty paid by the producer and alleged to have been passed on to an exporter.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id45be1805-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Plan Amendments Not Required Until January 1, 1989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions directing that if any amendments made by subtitle A or subtitle C of title XI [§§ 1101–1147 and 1171–1177] or title XVIII [§§ 1800–1899A] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" require an amendment to any plan, such plan amendment shall not be required to be made before the first plan year beginning on or after "},{"tag":"date","attrib":{"date":"1989-01-01"},"text":"Jan. 1, 1989","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1140"},"text":"section 1140 of Pub. L. 99–514","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s401"},"text":"section 401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
