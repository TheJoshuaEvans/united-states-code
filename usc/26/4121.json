{"tag":"section","attrib":{"id":"id45bba7e9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4121"},"text":null,"children":[{"tag":"num","attrib":{"value":"4121"},"text":"§ 4121.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of tax","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45bba7ea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4121/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax imposed","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45bba7eb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4121/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby imposed on coal from mines located in the United States sold by the producer, a tax equal to the rate per ton determined under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45bba7ec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4121/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of the tax imposed by paragraph (1) with respect to a ton of coal shall not exceed the applicable percentage (determined under subsection (b)) of the price at which such ton of coal is sold by the producer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45bba7ed-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4121/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of rates and limitation on tax","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45bba7ee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4121/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate of tax on coal from underground mines shall be $1.10,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45bba7ef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4121/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate of tax on coal from surface mines shall be $.55, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45bba7f0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4121/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicable percentage shall be 4.4 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45bba7f1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4121/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax not to apply to lignite","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tax imposed by subsection (a) shall not apply in the case of lignite.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45bba7f2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4121/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45bba7f3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4121/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coal from surface mines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Coal shall be treated as produced from a surface mine if all of the geological matter above the coal being mined is removed before the coal is extracted from the earth. Coal extracted by auger shall be treated as coal from a surface mine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45bba7f4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4121/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coal from underground mines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Coal shall be treated as produced from an underground mine if it is not produced from a surface mine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45be17f5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4121/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States” has the meaning given to it by paragraph (1) of section 638.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45be17f6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4121/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ton","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “ton” means 2,000 pounds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45be17f7-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/227/s2/a"},"text":"Pub. L. 95–227, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-02-10"},"text":"Feb. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/11"},"text":"92 Stat. 11","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/119/tI/s102/a"},"text":"Pub. L. 97–119, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1635"},"text":"95 Stat. 1635","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/tXIII/s13203/a"},"text":"Pub. L. 99–272, title XIII, § 13203(a)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/312"},"text":"100 Stat. 312","children":[],"tail":", 313; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVIII/s1897/a"},"text":"Pub. L. 99–514, title XVIII, § 1897(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2941"},"text":"100 Stat. 2941","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX/s10503"},"text":"Pub. L. 100–203, title X, § 10503","children":[],"tail":"