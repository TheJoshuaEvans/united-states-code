{"tag":"section","attrib":{"id":"id4637b524-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5365"},"text":null,"children":[{"tag":"num","attrib":{"value":"5365"},"text":"§ 5365.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Segregation of operations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may require by regulations such segregation of operations within the premises, by partitions or otherwise, as may be necessary to prevent jeopardy to the revenue, to prevent confusion between untaxpaid wine operations and such other operations as are authorized in this subchapter, to prevent substitution with respect to the several methods of producing effervescent wines, and to prevent the commingling of standard wines with other than standard wines.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4637b525-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1381"},"text":"72 Stat. 1381","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/tVIII/s807/a/47"},"text":"Pub. L. 96–39, title VIII, § 807(a)(47)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/287"},"text":"93 Stat. 287","children":[],"tail"