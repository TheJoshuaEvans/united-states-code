{"tag":"section","attrib":{"id":"id44ff5c75-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397A"},"text":null,"children":[{"tag":"num","attrib":{"value":"1397A"},"text":"§ 1397A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increase in expensing under section 179","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44ff5c76-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of an enterprise zone business, for purposes of section 179—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44ff5c77-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397A/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the limitation under section 179(b)(1) shall be increased by the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44ff5c78-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397A/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $35,000, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44ff5c79-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397A/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of section 179 property which is qualified zone property placed in service during the taxable year, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ff5c7a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397A/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount taken into account under section 179(b)(2) with respect to any section 179 property which is qualified zone property shall be 50 percent of the cost thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44ff5c7b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recapture","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rules similar to the rules under section 179(d)(10) shall apply with respect to any qualified zone property which ceases to be used in an empowerment zone by an enterprise zone business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44ff5c7c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1397A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to any property placed in service in taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2020-12-31"},"text":"December 31, 2020","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44ff5c7d-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13301/a"},"text":"Pub. L. 103–66, title XIII, § 13301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/552"},"text":"107 Stat. 552","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tIX/s952/c"},"text":"Pub. L. 105–34, title IX, § 952(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/887"},"text":"111 Stat. 887","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tI/s114/a"},"text":"Pub. L. 106–554, § 1(a)(7) [title I, § 114(a), (b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–601; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dEE/tI/s118/b"},"text":"Pub. L. 116–260, div. EE, title I, § 118(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3051"},"text":"134 Stat. 3051","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44ff5c7e-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44ff5c7f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44ff5c80-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tI/s114/a"},"text":"Pub. L. 106–554, § 1(a)(7) [title I, § 114(a)]","children":[],"tail":", substituted “$35,000” for “$20,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tI/s114/b"},"text":"Pub. L. 106–554, § 1(a)(7) [title I, § 114(b)]","children":[],"tail":", struck out heading and text of subsec. (c). Text read as follows: “For purposes of this section, qualified zone property shall not include any property substantially all of the use of which is in any parcel described in section 1391(g)(3)(A)(iii).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44ff5c81-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id44ff5c82-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"2020-12-31"},"text":"Dec. 31, 2020","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dEE/s118/e"},"text":"section 118(e) of div. EE of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1391"},"text":"section 1391 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44ff