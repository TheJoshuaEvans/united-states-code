tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s881/e"},"text":"Pub. L. 108–357, title VIII, § 881(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1627"},"text":"118 Stat. 1627","children":[],"tail":", directed the Secretary of the Treasury to biennially submit (beginning in 2005) to the Committee on Finance of the Senate and the Committee on Ways and Means of the House of Representatives a report with respect to qualified tax collection contracts under this section, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dC/tXXXII/s32102/f/2"},"text":"Pub. L. 114–94, div. C, title XXXII, § 32102(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1736"},"text":"129 Stat. 1736","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
