{"tag":"section","attrib":{"id":"id46c464bd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306"},"text":null,"children":[{"tag":"num","attrib":{"value":"6306"},"text":"§ 6306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified tax collection contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46c464be-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in any provision of law shall be construed to prevent the Secretary from entering into a qualified tax collection contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46c464bf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified tax collection contract","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “qualified tax collection contract” means any contract which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46c464c0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is for the services of any person (other than an officer or employee of the Treasury Department)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46c464c1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to locate and contact any taxpayer specified by the Secretary,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46c464c2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to request full payment from such taxpayer of an amount of Federal tax specified by the Secretary and, if such request cannot be met by the taxpayer, to offer the taxpayer an installment agreement providing for full payment of such amount during a period not to exceed 7 years, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46c464c3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to obtain financial information specified by the Secretary with respect to such taxpayer,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46c464c4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibits each person providing such services under such contract from committing any act or omission which employees of the Internal Revenue Service are prohibited from committing in the performance of similar services,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46c464c5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" prohibits subcontractors from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46c464c6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" having contacts with taxpayers,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46c464c7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing quality assurance services, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46c464c8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" composing debt collection notices, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46c464c9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permits subcontractors to perform other services only with the approval of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46c464ca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of inactive tax receivables","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46c464cb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary shall enter into one or more qualified tax collection contracts for the collection of all outstanding inactive tax receivables.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46c464cc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inactive tax receivables","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46c464cd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “inactive tax receivable” means any tax receivable if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id46c464ce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at any time after assessment, the Internal Revenue Service removes such receivable from the active inventory for lack of resources or inability to locate the taxpayer,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46c464cf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more than 2 years has passed since assessment and such receivable has not been assigned for collection to any employee of the Internal Revenue Service, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46c464d0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a receivable which has been assigned for collection, more than 365 days have passed without interaction with the taxpayer or a third party for purposes of furthering the collection of such receivable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46c464d1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax receivable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “tax receivable” means any outstanding assessment which the Internal Revenue Service includes in potentially collectible inventory.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46c464d2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain tax receivables not eligible for collection under qualified tax collections contracts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A tax receivable shall not be eligible for collection pursuant to a qualified tax collection contract if such receivable—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46c464d3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is subject to a pending or active offer-in-compromise or installment agreement,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46c464d4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is classified as an innocent spouse case,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46c464d5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" involves a taxpayer identified by the Secretary as being—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46c464d6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deceased,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46c464d7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under the age of 18,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46c464d8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a designated combat zone,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46c464d9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a victim of tax-related identity theft,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46c464da-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/d/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a taxpayer substantially all of whose income consists of disability insurance benefits under section 223 of the Social Security Act or supplemental security income benefits under title XVI of the Social Security Act (including supplemental security income benefits of the type described in section 1616 of such Act or ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/66/s212"},"text":"section 212 of Public Law 93–66","children":[],"tail":"), or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46c464db-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/d/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a taxpayer who is an individual with adjusted gross income, as determined for the most recent taxable year for which such information is available, which does not exceed 200 percent of the applicable poverty level (as determined by the Secretary),","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46c464dc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is currently under examination, litigation, criminal investigation, or levy, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46c464dd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is currently subject to a proper exercise of a right of appeal under this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46c464de-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may retain and use—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46c464df-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount not in excess of 25 percent of the amount collected under any qualified tax collection contract for the costs of services performed under such contract, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46c464e0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount not in excess of 25 percent of such amount collected to fund the special compliance personnel program account under section 6307.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The Secretary shall keep adequate records regarding amounts so retained and used. The amount credited as paid by any taxpayer shall be determined without regard to this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46c464e1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No Federal liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States shall not be liable for any act or omission of any person performing services under a qualified tax collection contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46c464e2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of Fair Debt Collection Practices Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of the Fair Debt Collection Practices Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1692"},"text":"15 U.S.C. 1692","children":[],"tail":" et seq.) shall apply to any qualified tax collection contract, except to the extent superseded by section 6304, section 7602(c), or by any other provision of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46c464e3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracting priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In contracting for the services of any person under this section, the Secretary shall utilize private collection contractors and debt collection centers on the schedule required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3711/g"},"text":"section 3711(g) of title 31","children":[],"tail":", United States Code, including the technology and communications infrastructure established therein, to the extent such private collection contractors and debt collection centers are appropriate to carry out the purposes of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46c464e4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxpayers in presidentially declared disaster areas","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may prescribe procedures under which a taxpayer determined to be affected by a Federally declared disaster (as defined by section 165(i)(5)) may request—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46c464e5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relief from immediate collection measures by contractors under this section, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46c464e6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a return of the inactive tax receivable to the inventory of the Internal Revenue Service to be collected by an employee thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46c464e7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the last day of each fiscal year (beginning with the first such fiscal year ending after the date of the enactment of this subsection), the Secretary shall submit to the Committee on Ways and Means of the House of Representatives and the Committee on Finance of the Senate a report with respect to qualified tax collection contracts under this section which shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46c464e8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" annually, with respect to such fiscal year—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46c464e9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/j/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number and amount of tax receivables provided to each contractor for collection under this section,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46c6aeda-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/j/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amounts collected (and amounts of installment agreements entered into under subsection (b)(1)(B)) with respect to each contractor and the collection costs incurred (directly and indirectly) by the Internal Revenue Service with respect to such amounts,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46c6aedb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/j/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of such contracts on the total number and amount of unpaid assessments, and on the number and amount of assessments collected by Internal Revenue Service personnel after initial contact by a contractor,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46c6aedc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/j/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of fees retained by the Secretary under subsection (e) and a description of the use of such funds, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46c6aedd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/j/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a disclosure safeguard report in a form similar to that required under section 6103(p)(5), and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46c6aede-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" biannually (beginning with the second report submitted under this subsection)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46c6aedf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/j/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an independent evaluation of contractor performance, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46c6aee0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/j/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a measurement plan that includes a comparison of the best practices used by the private collectors to the collection techniques used by the Internal Revenue Service and mechanisms to identify and capture information on successful collection techniques used by the contractors that could be adopted by the Internal Revenue Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46c6aee1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross references","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46c6aee2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For damages for certain unauthorized collection actions by persons performing services under a qualified tax collection contract, see section 7433A.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46c6aee3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6306/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For application of Taxpayer Assistance Orders to persons performing services under a qualified tax collection contract, see section 7811(g).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46c6aee4-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s881/a/1"},"text":"Pub. L. 108–357, title VIII, § 881(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1625"},"text":"118 Stat. 1625","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dC/tXXXII"},"text":"Pub. L. 114–94, div. C, title XXXII","children":[],"tail":", §§ 32102(a)–(c), (e), (f)(1), 32103(a), "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1733-1736"},"text":"129 Stat. 1733–1736","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/351"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(351)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1201"},"text":"132 Stat. 1201","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/25/tI/s1205/a"},"text":"Pub. L. 116–25, title I, § 1205(a)","children":[],"tail":"–(c), "},{"tag":"date","attrib":{"date":"2019-07-01"},"text":"July 1, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/989"},"text":"133 Stat. 989","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46c6aee5-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46c6aee6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id46c6aee7-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsec. (d)(3)(E), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Title XVI of the Act is classified generally to subchapter XVI (§ 1381 et seq.) of chapter 7 of Title 42, The Public Health and Welfare. Sections 223 and 1616 of the Act are classified to sections 423 and 1382e, respectively, of Title 42. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/66/s212"},"text":"Section 212 of Public Law 93–66","children":[],"tail":", referred to in subsec. (d)(3)(E), is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1382"},"text":"section 1382 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Fair Debt Collection Practices Act, referred to in subsec. (e), is title VIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321"},"text":"Pub. L. 90–321","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/95/109"},"text":"Pub. L. 95–109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-09-20"},"text":"Sept. 20, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/874"},"text":"91 Stat. 874","children":[],"tail":", which is classified generally to subchapter V (§ 1692 et seq.) of chapter 41 of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1601"},"text":"section 1601 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46c6aee8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/25/s1205/c"},"text":"Pub. L. 116–25, § 1205(c)","children":[],"tail":", substituted “7 years” for “5 years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/25/s1205/b"},"text":"Pub. L. 116–25, § 1205(b)","children":[],"tail":", substituted “more than 2 years has passed since assessment” for “more than ⅓ of the period of the applicable statute of limitation has lapsed”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3)(E), (F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/25/s1205/a"},"text":"Pub. L. 116–25, § 1205(a)","children":[],"tail":", added subpars. (E) and (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/a/351"},"text":"Pub. L. 115–141, § 401(a)(351)","children":[],"tail":", made technical amendment to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s32103/a"},"text":"Pub. L. 114–94, § 32103(a)","children":[],"tail":". See 2015 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s32102/a"},"text":"Pub. L. 114–94, § 32102(a)","children":[],"tail":", added subsec. (c). Former subsec. (c) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s32102/b"},"text":"Pub. L. 114–94, § 32102(b)","children":[],"tail":", added subsec. (d). Former subsec. (d) redesignated (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s32102/a"},"text":"Pub. L. 114–94, § 32102(a)","children":[],"tail":", (b), successively redesignated subsec. (c) as (d) and then as (e). Former subsec. (e) redesignated (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s32103/a"},"text":"Pub. L. 114–94, § 32103(a)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/a/351"},"text":"Pub. L. 115–141, § 401(a)(351)","children":[],"tail":", substituted “to fund the special compliance personnel program account under section 6307” for “for collection enforcement activities of the Internal Revenue Service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s32102/a"},"text":"Pub. L. 114–94, § 32102(a)","children":[],"tail":", (b), successively redesignated subsec. (d) as (e) and then as (f). Former subsec. (f) redesignated (k)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s32102/a"},"text":"Pub. L. 114–94, § 32102(a)","children":[],"tail":", (b), successively redesignated subsec. (e) as (f) and then as (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s32102/c"},"text":"Pub. L. 114–94, § 32102(c)","children":[],"tail":", added subsec. (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s32102/e"},"text":"Pub. L. 114–94, § 32102(e)","children":[],"tail":", added subsec. (i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s32102/f/1"},"text":"Pub. L. 114–94, § 32102(f)(1)","children":[],"tail":", added subsec. (j)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (k). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s32102/a"},"text":"Pub. L. 114–94, § 32102(a)","children":[],"tail":", (b), (c), (e), (f)(1), successively redesignated subsec. (f) as (g), (h), (i), (j), and then (k)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46c6aee9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46c6aeea-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2019 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/25/tI/s1205/e"},"text":"Pub. L. 116–25, title I, § 1205(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-07-01"},"text":"July 1, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/989"},"text":"133 Stat. 989","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/25/tI/s1205/e"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided in this subsection, the amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6307"},"text":"section 6307 of this title","children":[],"tail":"] shall apply to tax receivables identified by the Secretary (or the Secretary’s delegate) after "},{"tag":"date","attrib":{"date":"2020-12-31"},"text":"December 31, 2020","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum length of installment agreements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendment made by subsection (c) [amending this section] shall apply to contracts entered into after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2019-07-01"},"text":"July 1, 2019","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of special compliance personnel program account","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendment made by subsection (d) [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6307"},"text":"section 6307 of this title","children":[],"tail":"] shall apply to amounts expended from the special compliance personnel program account after the date of the enactment of this Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46c6aeeb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dC/tXXXII/s32102/g/1"},"text":"Pub. L. 114–94, div. C, title XXXII, § 32102(g)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1736"},"text":"129 Stat. 1736","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/94/dC/tXXXII/s32102/g/1"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by subsections (a) and (b) [amending this section] shall apply to tax receivables identified by the Secretary [probably means Secretary of the Treasury] after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contracting priority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall begin entering into contracts and agreements as described in the amendment made by subsection (c) [amending this section] within 3 months after the date of the enactment of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dC/tXXXII/s32102/g/4"},"text":"Pub. L. 114–94, div. C, title XXXII, § 32102(g)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1736"},"text":"129 Stat. 1736","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/94/dC/tXXXII/s32102/g/4"},"text":"“The amendments made by subsections (e) and (f) [amending this section and repealing provisions formerly set out as a note under this section] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dC/tXXXII/s32103/d"},"text":"Pub. L. 114–94, div. C, title XXXII, § 32103(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1738"},"text":"129 Stat. 1738","children":[],"tail":