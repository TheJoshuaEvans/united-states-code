{"tag":"section","attrib":{"id":"id45d12b2a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4282"},"text":null,"children":[{"tag":"num","attrib":{"value":"4282"},"text":"§ 4282.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation by air for other members of affiliated group","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45d12b2b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4282/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under regulations prescribed by the Secretary, if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45d12b2c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4282/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one member of an affiliated group is the owner or lessee of an aircraft, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45d12b2d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4282/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such aircraft is not available for hire by persons who are not members of such group,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"no tax shall be imposed under section 4261 or 4271 upon any payment received by one member of the affiliated group from another member of such group for services furnished to such other member in connection with the use of such aircraft.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45d12b2e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4282/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability for hire","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsection (a), the determination of whether an aircraft is available for hire by persons who are not members of an affiliated group shall be made on a flight-by-flight basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45d12b2f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4282/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affiliated group","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsection (a), the term “affiliated group” has the meaning assigned to such term by section 1504(a), except that all corporations shall be treated as includible corporations (without any exclusion under section 1504(b)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45d12b30-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/258/tII/s205/a/1"},"text":"Pub. L. 91–258, title II, § 205(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-05-21"},"text":"May 21, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/241"},"text":"84 Stat. 241","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1609/f"},"text":"Pub. L. 104–188, title I, § 1609(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1842"},"text":"110 Stat. 1842","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45d12b31-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45d12b32-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id45d12b33-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4282, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/508"},"text":"68A Stat. 508","children":[],"tail":", defined “fair charge” in connection with tax on transportation of oil by pipeline, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/85/475/s4/a"},"text":"Pub. L. 85–475, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-06-30"},"text":"June 30, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/260"},"text":"72 Stat. 260","children":[],"tail":". For effective date of repeal, see "},{"tag":"ref","attrib":{"href":"/us/pl/85/475/s4/c"},"text":"section 4(c) of Pub. L. 85–475","children":[],"tail":", set out as an Effective Date of 1958 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6415"},"text":"section 6415 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45d12b34-3a70-11f1-a967-d35dac11796a"},