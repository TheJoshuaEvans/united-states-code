{"tag":"section","attrib":{"id":"id40defe8c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V"},"text":null,"children":[{"tag":"num","attrib":{"value":"45V"},"text":"§ 45V.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit for production of clean hydrogen","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id40defe8d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of credit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of section 38, the clean hydrogen production credit for any taxable year is an amount equal to the product of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40defe8e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the kilograms of qualified clean hydrogen produced by the taxpayer during such taxable year at a qualified clean hydrogen production facility during the 10-year period beginning on the date such facility was originally placed in service, multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40defe8f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicable amount (as determined under subsection (b)) with respect to such hydrogen.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40defe90-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable amount","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40defe91-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsection (a)(2), the applicable amount shall be an amount equal to the applicable percentage of $0.60. If any amount as determined under the preceding sentence is not a multiple of 0.1 cent, such amount shall be rounded to the nearest multiple of 0.1 cent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40defe92-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable percentage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), the applicable percentage shall be determined as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40defe93-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of any qualified clean hydrogen which is produced through a process that results in a lifecycle greenhouse gas emissions rate of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40defe94-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not greater than 4 kilograms of CO2e per kilogram of hydrogen, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40defe95-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 2.5 kilograms of CO2e per kilogram of hydrogen,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the applicable percentage shall be 20 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40defe96-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of any qualified clean hydrogen which is produced through a process that results in a lifecycle greenhouse gas emissions rate of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40defe97-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" less than 2.5 kilograms of CO2e per kilogram of hydrogen, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40defe98-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 1.5 kilograms of CO2e per kilogram of hydrogen,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the applicable percentage shall be 25 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40defe99-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of any qualified clean hydrogen which is produced through a process that results in a lifecycle greenhouse gas emissions rate of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40defe9a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" less than 1.5 kilograms of CO2e per kilogram of hydrogen, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40defe9b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 0.45 kilograms of CO2e per kilogram of hydrogen,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the applicable percentage shall be 33.4 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40defe9c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of any qualified clean hydrogen which is produced through a process that results in a lifecycle greenhouse gas emissions rate of less than 0.45 kilograms of CO2e per kilogram of hydrogen, the applicable percentage shall be 100 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40defe9d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inflation adjustment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The $0.60 amount in paragraph (1) shall be adjusted by multiplying such amount by the inflation adjustment factor (as determined under section 45(e)(2), determined by substituting “2022” for “1992” in subparagraph (B) thereof) for the calendar year in which the qualified clean hydrogen is produced. If any amount as increased under the preceding sentence is not a multiple of 0.1 cent, such amount shall be rounded to the nearest multiple of 0.1 cent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40defe9e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40defe9f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lifecycle greenhouse gas emissions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40defea0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), the term “lifecycle greenhouse gas emissions” has the same meaning given such term under subparagraph (H) of section 211(","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(1) of the Clean Air Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7545"},"text":"42 U.S.C. 7545","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(1)), as in effect on the date of enactment of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40defea1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" GREET model","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “lifecycle greenhouse gas emissions” shall only include emissions through the point of production (well-to-gate), as determined under the most recent Greenhouse gases, Regulated Emissions, and Energy use in Transportation model (commonly referred to as the “GREET model”) developed by Argonne National Laboratory, or a successor model (as determined by the Secretary).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40defea2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified clean hydrogen","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40defea3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified clean hydrogen” means hydrogen which is produced through a process that results in a lifecycle greenhouse gas emissions rate of not greater than 4 kilograms of CO2e per kilogram of hydrogen.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40defea4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such term shall not include any hydrogen unless—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40defea5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such hydrogen is produced—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id40defea6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/c/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the United States (as defined in section 638(1)) or a possession of the United States (as defined in section 638(2)),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id40defea7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/c/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the ordinary course of a trade or business of the taxpayer, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id40defea8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/c/2/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for sale or use, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40defea9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the production and sale or use of such hydrogen is verified by an unrelated party.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40defeaa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisional emissions rate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any hydrogen for which a lifecycle greenhouse gas emissions rate has not been determined for purposes of this section, a taxpayer producing such hydrogen may file a petition with the Secretary for determination of the lifecycle greenhouse gas emissions rate with respect to such hydrogen.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40defeab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified clean hydrogen production facility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified clean hydrogen production facility” means a facility—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40defeac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned by the taxpayer,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40defead-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which produces qualified clean hydrogen, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40defeae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the construction of which begins before ","children":[{"tag":"date","attrib":{"date":"2028-01-01"},"text":"January 1, 2028","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40defeaf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40defeb0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of facilities owned by more than 1 taxpayer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rules similar to the rules section 45(e)(3) shall apply for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40defeb1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with credit for carbon oxide sequestration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No credit shall be allowed under this section with respect to any qualified clean hydrogen produced at a facility which includes carbon capture equipment for which a credit is allowed to any taxpayer under section 45Q for the taxable year or any prior taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40defeb2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit reduced for tax-exempt bonds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rules similar to the rule under section 45(b)(3) shall apply for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40defeb3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modification of existing facilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a)(1), in the case of any facility which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40defeb4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was originally placed in service before ","children":[{"tag":"date","attrib":{"date":"2023-01-01"},"text":"January 1, 2023","children":[],"tail":", and, prior to the modification described in subparagraph (B), did not produce qualified clean hydrogen, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40defeb5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" after the date such facility was originally placed in service—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40defeb6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/d/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is modified to produce qualified clean hydrogen, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40defeb7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/d/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts paid or incurred with respect to such modification are properly chargeable to capital account of the taxpayer,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"such facility shall be deemed to have been originally placed in service as of the date that the property required to complete the modification described in subparagraph (B) is placed in service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40defeb8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increased credit amount for qualified clean hydrogen production facilities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40defeb9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any qualified clean hydrogen production facility which satisfies the requirements of paragraph (2), the amount of the credit determined under subsection (a) with respect to qualified clean hydrogen described in subsection (b)(2) shall be equal to such amount (determined without regard to this sentence) multiplied by 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40defeba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A facility meets the requirements of this paragraph if it is one of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40defebb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A facility—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40defebc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the construction of which begins prior to the date that is 60 days after the Secretary publishes guidance with respect to the requirements of paragraphs (3)(A) and (4), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40defebd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which meets the requirements of paragraph (3)(A) with respect to alteration or repair of such facility which occurs after such date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40defebe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A facility which satisfies the requirements of paragraphs (3)(A) and (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40defebf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prevailing wage requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40defec0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirements described in this subparagraph with respect to any qualified clean hydrogen production facility are that the taxpayer shall ensure that any laborers and mechanics employed by the taxpayer or any contractor or subcontractor in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40defec1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/e/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the construction of such facility, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40defec2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/e/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to any taxable year, for any portion of such taxable year which is within the period described in subsection (a)(2), the alteration or repair of such facility,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be paid wages at rates not less than the prevailing rates for construction, alteration, or repair of a similar character in the locality in which such facility is located as most recently determined by the Secretary of Labor, in accordance with subchapter IV of chapter 31 of title 40, United States Code. For purposes of determining an increased credit amount under paragraph (1) for a taxable year, the requirement under clause (ii) of this subparagraph is applied to such taxable year in which the alteration or repair of qualified facility occurs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40defec3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Correction and penalty related to failure to satisfy wage requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rules similar to the rules of section 45(b)(7)(B) shall apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40defec4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Apprenticeship requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rules similar to the rules of section 45(b)(8) shall apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40defec5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations and guidance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall issue such regulations or other guidance as the Secretary determines necessary to carry out the purposes of this subsection, including regulations or other guidance which provides for requirements for recordkeeping or information reporting for purposes of administering the requirements of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40defec6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45V/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after the date of enactment of this section, the Secretary shall issue regulations or other guidance to carry out the purposes of this section, including regulations or other guidance for determining lifecycle greenhouse gas emissions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id40defec7-3a70-11f1-a967-d35dac11796a"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169/tI/s13204/a/1"},"text":"Pub. L. 117–169, title I, § 13204(a)(1)","children":[],"tail":"–(3), "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1936"},"text":"136 Stat. 1936","children":[],"tail":", 1938, 1939; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70511"},"text":"Pub. L. 119–21, title VII, § 70511","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/252"},"text":"139 Stat. 252","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id40defec8-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id40defec9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id40defeca-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsecs. (c)(1)(A) and (f), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169"},"text":"Pub. L. 117–169","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id40defecb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (c)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2028-01-01"},"text":"January 1, 2028","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2033-01-01"},"text":"January 1, 2033","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169/s13204/a/2"},"text":"Pub. L. 117–169, § 13204(a)(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169/s13204/a/3"},"text":"Pub. L. 117–169, § 13204(a)(3)","children":[],"tail":", added par. (4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id40defecc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id40defecd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169/tI/s13204/a/5"},"text":"Pub. L. 117–169, title I, § 13204(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1939"},"text":"136 Stat. 1939","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/169/tI/s13204/a/5"},"text":"\n","children":[{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by paragraphs (1) [enacting this section] and (4) [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s38"},"text":"section 38 of this title","children":[],"tail":"] of this subsection shall apply to hydrogen produced after "},{"tag":"date","attrib":{"date":"2022-12-31"},"text":"December 31, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Credit reduced for tax-exempt bonds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendment made by paragraph (2) [amending this section] shall apply to facilities the construction of which begins after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Modification of existing facilities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendment made by paragraph (3) [amending this section] shall apply to modifications made after ","children":[{"tag":"date","attrib":{"date":"2022-12-31"},"text":"December 31, 2022","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
