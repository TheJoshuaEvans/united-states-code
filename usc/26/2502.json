{"tag":"section","attrib":{"id":"id453fc0d5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2502"},"text":null,"children":[{"tag":"num","attrib":{"value":"2502"},"text":"§ 2502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rate of tax","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id453fc0d6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation of tax","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The tax imposed by section 2501 for each calendar year shall be an amount equal to the excess of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id453fc0d7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2502/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a tentative tax, computed under section 2001(c), on the aggregate sum of the taxable gifts for such calendar year and for each of the preceding calendar periods, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id453fc0d8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2502/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a tentative tax, computed under such section, on the aggregate sum of the taxable gifts for each of the preceding calendar periods.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id453fc0d9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preceding calendar period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whenever used in this title in connection with the gift tax imposed by this chapter, the term “preceding calendar period” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id453fc0da-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2502/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" calendar years 1932 and 1970 and all calendar years intervening between calendar year 1932 and calendar year 1970,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id453fc0db-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2502/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first calendar quarter of calendar year 1971 and all calendar quarters intervening between such calendar quarter and the first calendar quarter of calendar year 1982, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id453fc0dc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2502/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all calendar years after 1981 and before the calendar year for which the tax is being computed.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of paragraph (1), the term “calendar year 1932” includes only that portion of such year after ","children":[{"tag":"date","attrib":{"date":"1932-06-06"},"text":"June 6, 1932","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id453fc0dd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2502/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax to be paid by donor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tax imposed by section 2501 shall be paid by the donor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id453fc0de-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/403"},"text":"68A Stat. 403","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/614/tI/s102/a/2"},"text":"Pub. L. 91–614, title I, § 102(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1839"},"text":"84 Stat. 1839","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXX/s2001/b/1"},"text":"Pub. L. 94–455, title XX, § 2001(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1849"},"text":"90 Stat. 1849","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/tIV/s442/a/2"},"text":"Pub. L. 97–34, title IV, § 442(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/320"},"text":"95 Stat. 320","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX/s10401/b/2/B"},"text":"Pub. L. 100–203, title X, § 10401(b)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-431"},"text":"101 Stat. 1330–431","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/16/tV/s511/d"},"text":"Pub. L. 107–16, title V, § 511(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-06-07"},"text":"June 7, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/70"},"text":"115 Stat. 70","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/312/tIII/s302/b/2"},"text":"Pub. L. 111–312, title III, § 302(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-17"},"text":"Dec. 17, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3301"},"text":"124 Stat. 3301","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id453fc0df-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id453fc0e0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id453fc0e1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/312"},"text":"Pub. L. 111–312","children":[],"tail":" amended subsec. (a) to read as if amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/107/16/s511/d"},"text":"Pub. L. 107–16, § 511(d)","children":[],"tail":", had never been enacted. See 2001 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16/s511/d"},"text":"Pub. L. 107–16, § 511(d)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, text read as follows: “The tax imposed by section 2501 for each calendar year shall be an amount equal to the excess of—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) a tentative tax, computed under section 2001(c), on the aggregate sum of the taxable gifts for such calendar year and for each of the preceding calendar periods, over","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) a tentative tax, computed under such section, on the aggregate sum of the taxable gifts for each of the preceding calendar periods.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/s10401/b/2/B/i"},"text":"Pub. L. 100–203, § 10401(b)(2)(B)(i)","children":[],"tail":", substituted “under section 2001(c)” for “in accordance with the rate schedule set forth in section 2001(c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/s10401/b/2/B/ii"},"text":"Pub. L. 100–203, § 10401(b)(2)(B)(ii)","children":[],"tail":", substituted “under such section” for “in accordance with such rate schedule”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":" substituted in introductory text and par. (1) “calendar year” for “calendar quarter” and in pars. (1) and (2) “calendar periods” for “calendar years and calendar quarters”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":" substituted definition of “preceding calendar period” for “calendar quarter”, the latter including only the first calendar quarter of the calendar year 1971 and succeeding calendar quarters (covered in par. (2)), the former incorporating former subsec. (c)(1) definition of “preceding calendar years” as meaning calendar years 1932 and 1970 and all calendar years intervening between calendar year 1932 and calendar year 1970 and “calendar year 1932” as including only the portion of such year after "},{"tag":"date","attrib":{"date":"1932-06-06"},"text":"June 6, 1932","children":[],"tail":", and former subsec. (c)(2) definition of “preceding calendar quarters” as meaning the first calendar quarter of calendar year 1971 and all calendar quarters intervening between such calendar quarter and the calendar quarter for which the tax is being computed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":" redesignated subsec. (d) as (c). Former subsec. (c), defining “preceding calendar years” and “preceding calendar quarters”, was incorporated in subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" inserted “tentative” after “(1) a” and “(2) a” and substituted in par. (1) “section 2001(c)” for “this subsection” after “set forth in”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/614/s102/a/2/A"},"text":"Pub. L. 91–614, § 102(a)(2)(A)","children":[],"tail":", substituted a computation of tax formula based on the current calendar quarter, preceding calendar quarters, and preceding calendar years for a formula based entirely on the current and preceding calendar years."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/614/s102/a/2/B"},"text":"Pub. L. 91–614, § 102(a)(2)(B)","children":[],"tail":", substituted definition of “calendar quarter” for definition of “calendar year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/614/s102/a/2/B"},"text":"Pub. L. 91–614, § 102(a)(2)(B)","children":[],"tail":", substituted definition of “preceding calendar years and quarters” for definition of “preceding calendar years”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id453fc0e2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id453fc0e3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/312/tIII/s302/b/2"},"text":"Pub. L. 111–312, title III, § 302(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-17"},"text":"Dec. 17, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3301"},"text":"124 Stat. 3301","children":[],"tail":", provided that the amendment by section 302(b)(2) is effective on and after "},{"tag":"date","attrib":{"date":"2011-01-01"},"text":"Jan. 1, 2011","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id453fc0e4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2001 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16/tV/s511/f/3"},"text":"Pub. L. 107–16, title V, § 511(f)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-06-07"},"text":"June 7, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/71"},"text":"115 Stat. 71","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/16/tV/s511/f/3"},"text":"“The amendments made by subsections (d) and (e) [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s2511"},"text":"section 2511 of this title","children":[],"tail":"] shall apply to gifts made after "},{"tag":"date","attrib":{"date":"2009-12-31"},"text":"December 31, 2009","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id453fc0e5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1987 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" applicable in the case of decedents dying, and gifts made, after "},{"tag":"date","attrib":{"date":"1987-12-31"},"text":"Dec. 31, 1987","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/s10401/c"},"text":"section 10401(c) of Pub. L. 100–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2001"},"text":"section 2001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id453fc0e6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34"},"text":"Pub. L. 97–34","children":[],"tail":" applicable with respect to gifts made after "},{"tag":"date","attrib":{"date":"1981-12-31"},"text":"Dec. 31, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/s442/e"},"text":"section 442(e) of Pub. L. 97–34","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2501"},"text":"section 2501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id453fc0e7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXX/s2001/d/2"},"text":"Pub. L. 94–455, title XX, § 2001(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1854"},"text":"90 Stat. 1854","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/455/tXX/s2001/d/2"},"text":"“The amendments made by subsections (b) and (c)(2) [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s2505"},"text":"section 2505 of this title","children":[],"tail":", amending this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2504"},"text":"section 2504 of this title","children":[],"tail":", and repealing "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2521"},"text":"section 2521 of this title","children":[],"tail":"] shall apply to gifts made after "},{"tag":"date","attrib":{"date":"1976-12-31"},"text":"December 31, 1976","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id453fc0e8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/614"},"text":"Pub. L. 91–614","children":[],"tail":" applicable with respect to gifts made after "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/614/s102/e"},"text":"section 102(e) of Pub. L. 91–614","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2501"},"text":"section 2501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
