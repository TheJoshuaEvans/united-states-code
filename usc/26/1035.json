{"tag":"section","attrib":{"id":"id44a9748b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1035"},"text":null,"children":[{"tag":"num","attrib":{"value":"1035"},"text":"§ 1035.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain exchanges of insurance policies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44a9748c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1035/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No gain or loss shall be recognized on the exchange of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44a9748d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1035/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contract of life insurance for another contract of life insurance or for an endowment or annuity contract or for a qualified long-term care insurance contract;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44a9748e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1035/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contract of endowment insurance (A) for another contract of endowment insurance which provides for regular payments beginning at a date not later than the date payments would have begun under the contract exchanged, or (B) for an annuity contract, or (C) for a qualified long-term care insurance contract;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44a9748f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1035/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an annuity contract for an annuity contract or for a qualified long-term care insurance contract; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44a97490-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1035/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a qualified long-term care insurance contract for a qualified long-term care insurance contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44a97491-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1035/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44a97492-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1035/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Endowment contract","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A contract of endowment insurance is a contract with an insurance company which depends in part on the life expectancy of the insured, but which may be payable in full in a single payment during his life.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44a97493-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1035/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annuity contract","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An annuity contract is a contract to which paragraph (1) applies but which may be payable during the life of the annuitant only in installments. For purposes of the preceding sentence, a contract shall not fail to be treated as an annuity contract solely because a qualified long-term care insurance contract is a part of or a rider on such contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44a97494-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1035/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Life insurance contract","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A contract of life insurance is a contract to which paragraph (1) applies but which is not ordinarily payable in full during the life of the insured. For purposes of the preceding sentence, a contract shall not fail to be treated as a life insurance contract solely because a qualified long-term care insurance contract is a part of or a rider on such contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44a97495-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1035/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exchanges involving foreign persons","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent provided in regulations, subsection (a) shall not apply to any exchange having the effect of transferring property to any person other than a United States person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44a97496-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1035/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross references","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44a97497-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1035/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For rules relating to recognition of gain or loss where an exchange is not solely in kind, see subsections (b) and (c) of section 1031.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44abe498-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1035/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For rules relating to the basis of property acquired in an exchange described in subsection (a), see subsection (d) of section 1031.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44abe499-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/309"},"text":"68A Stat. 309","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tII"},"text":"Pub. L. 98–369, div. A, title II","children":[],"tail":", §§ 211(b)(15), 224(a), "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/756"},"text":"98 Stat. 756","children":[],"tail":", 776; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVIII/s1828"},"text":"Pub. L. 99–514, title XVIII, § 1828","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2851"},"text":"100 Stat. 2851","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXI/s1131/b/1"},"text":"Pub. L. 105–34, title XI, § 1131(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/979"},"text":"111 Stat. 979","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/280/tVIII/s844/b"},"text":"Pub. L. 109–280, title VIII, § 844(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1010"},"text":"120 Stat. 1010","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/168"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(168)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1192"},"text":"132 Stat. 1192","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44abe49a-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44abe49b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id44abe49c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1131/b"},"text":"section 1131(b) of Pub. L. 105–34","children":[],"tail":" enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s684"},"text":"section 684 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44abe49d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" struck out “or” after semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/s844/b/3/A"},"text":"Pub. L. 109–280, § 844(b)(3)(A)","children":[],"tail":", which directed amendment by inserting “or for a qualified long-term care insurance contract” before semicolon “at the end”, was executed by making the insertion before “; or” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/s844/b/3/B"},"text":"Pub. L. 109–280, § 844(b)(3)(B)","children":[],"tail":", which directed amendment by inserting “, or (C) for a qualified long-term care insurance contract” before semicolon “at the end”, was executed by making the insertion before “; or” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/s844/b/3/C"},"text":"Pub. L. 109–280, § 844(b)(3)(C)","children":[],"tail":", inserted “or for a qualified long-term care insurance contract” after “annuity contract”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/s844/b/4"},"text":"Pub. L. 109–280, § 844(b)(4)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/s844/b/1"},"text":"Pub. L. 109–280, § 844(b)(1)","children":[],"tail":", inserted at end “For purposes of the preceding sentence, a contract shall not fail to be treated as an annuity contract solely because a qualified long-term care insurance contract is a part of or a rider on such contract.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/s844/b/2"},"text":"Pub. L. 109–280, § 844(b)(2)","children":[],"tail":", inserted at end “For purposes of the preceding sentence, a contract shall not fail to be treated as a life insurance contract solely because a qualified long-term care insurance contract is a part of or a rider on such contract.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" struck out “subject to tax under subchapter L” after “with an insurance company”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s224/a"},"text":"Pub. L. 98–369, § 224(a)","children":[],"tail":", which directed the substitution of “an insurance company subject to tax under subchapter L” for “a life insurance company as defined in section 801”, was executed by making such substitution for “a life insurance company as defined in section 816” to reflect the probable intent of Congress and the earlier amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s211/b/15"},"text":"Pub. L. 98–369, § 211(b)(15)","children":[],"tail":", which substituted “as defined in section 816” for “as defined in section 801”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s211/b/15"},"text":"Pub. L. 98–369, § 211(b)(15)","children":[],"tail":", substituted “section 816” for “section 801”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44abe49e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44abe49f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280"},"text":"Pub. L. 109–280","children":[],"tail":" applicable to contracts issued after "},{"tag":"date","attrib":{"date":"1996-12-31"},"text":"Dec. 31, 1996","children":[],"tail":", but only with respect to taxable years beginning after "},{"tag":"date","attrib":{"date":"2009-12-31"},"text":"Dec. 31, 2009","children":[],"tail":", and to exchanges occurring after "},{"tag":"date","attrib":{"date":"2009-12-31"},"text":"Dec. 31, 2009","children":[],"tail":", see section 844(g)(1), (2) of "},{"tag":"ref","attrib":{"href":"/us/pl/109/280"},"text":"Pub. L. 109–280","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s72"},"text":"section 72 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44abe4a0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" effective, except as otherwise provided, as if included in the provisions of the Tax Reform Act of 1984, "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA"},"text":"Pub. L. 98–369, div. A","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1881"},"text":"section 1881 of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s48"},"text":"section 48 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44abe4a1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s211/b/5"},"text":"section 211(b)(5) of Pub. L. 98–369","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"1983-12-31"},"text":"Dec. 31, 1983","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s215"},"text":"section 215 of Pub. L. 98–369","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tII/s224/b"},"text":"Pub. L. 98–369, div. A, title II, § 224(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/776"},"text":"98 Stat. 776","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/369/dA/tII/s224/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply to all exchanges whether before, on, or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id44abe4a2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Plan Amendments Not Required Until January 1, 1989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions directing that if any amendments made by subtitle A or subtitle C of title XI [§§ 1101–1147 and 1171–1177] or title XVIII [§§ 1800–1899A] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" require an amendment to any plan, such plan amendment shall not be required to be made before the first plan year beginning on or after "},{"tag":"date","attrib":{"date":"1989-01-01"},"text":"Jan. 1, 1989","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1140"},"text":"section 1140 of Pub. L. 99–514","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s401"},"text":"section 401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
