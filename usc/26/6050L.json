{"tag":"section","attrib":{"id":"id467cd4ac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050L"},"text":null,"children":[{"tag":"num","attrib":{"value":"6050L"},"text":"§ 6050L.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Returns relating to certain donated property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id467cd4ad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050L/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dispositions of donated property","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467cd4ae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050L/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the donee of any charitable deduction property sells, exchanges, or otherwise disposes of such property within 3 years after its receipt, the donee shall make a return (in accordance with forms and regulations prescribed by the Secretary) showing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id467cd4af-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050L/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address, and TIN of the donor,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467cd4b0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050L/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the property,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467cd4b1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050L/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of the contribution,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467cd4b2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050L/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount received on the disposition,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467cd4b3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050L/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of such disposition,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467cd4b4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050L/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the donee’s use of the property, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467cd4b5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050L/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement indicating whether the use of the property was related to the purpose or function constituting the basis for the donee’s exemption under section 501.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"In any case in which the donee indicates that the use of applicable property (as defined in section 170(e)(7)(C)) was related to the purpose or function constituting the basis for the exemption of the donee under section 501 under subparagraph (G), the donee shall include with the return the certification described in section 170(e)(7)(D) if such certification is made under section 170(e)(7).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467cd4b6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050L/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id467cd4b7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050L/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Charitable deduction property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “charitable deduction property” means any property (other than publicly traded securities) contributed in a contribution for which a deduction was claimed under section 170 if the claimed value of such property (plus the claimed value of all similar items of property donated by the donor to 1 or more donees) exceeds $5,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467cd4b8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050L/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publicly traded securities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “publicly traded securities” means securities for which (as of the date of the contribution) market quotations are readily available on an established securities market.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467cd4b9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050L/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified intellectual property contributions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467cd4ba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050L/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each donee with respect to a qualified intellectual property contribution shall make a return (at such time and in such form and manner as the Secretary may by regulations prescribe) with respect to each specified taxable year of the donee showing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id467cd4bb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050L/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address, and TIN of the donor,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467cd4bc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050L/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the qualified intellectual property contributed,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467cd4bd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050L/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of the contribution, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467cd4be-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050L/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of net income of the donee for the taxable year which is properly allocable to the qualified intellectual property (determined without regard to paragraph (10)(B) of section 170(m) and with the modifications described in paragraphs (5) and (6) of such section).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467cd4bf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050L/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id467cd4c0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050L/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Terms used in this subsection which are also used in section 170(m) have the respective meanings given such terms in such section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467cd4c1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050L/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specified taxable year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “specified taxable year” means, with respect to any qualified intellectual property contribution, any taxable year of the donee any portion of which is part of the 10-year period beginning on the date of such contribution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467cd4c2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050L/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement to be furnished to donors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every person making a return under subsection (a) or (b) shall furnish a copy of such return to the donor at such time and in such manner as the Secretary may by regulations prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id467cd4c3-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s155/b/1"},"text":"Pub. L. 98–369, div. A, title I, § 155(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/692"},"text":"98 Stat. 692","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s882/c/1"},"text":"Pub. L. 108–357, title VIII, § 882(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1629"},"text":"118 Stat. 1629","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/280/tXII/s1215/b"},"text":"Pub. L. 109–280, title XII, § 1215(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1078"},"text":"120 Stat. 1078","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id467cd4c4-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id467cd4c5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id467cd4c6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280"},"text":"Pub. L. 109–280","children":[],"tail":", which directed the amendment of section 6050L by adding subpars. (F) and (G) and concluding provisions and substituting “3 years” for “2 years” in introductory provisions without specifying the act to be amended, was executed to this section, which is section 6050L of the Internal Revenue Code of 1986, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":" amended section catchline and text generally, substituting provisions consisting of subsecs. (a) to (c) for provisions which, in subsec. (a) required return to be made by donee and set forth contents requirements, in subsec. (b) defined “charitable deduction property” for purposes of this section, in subsec. (c) required copy of return to be furnished to donor by donee, and in subsec. (d) defined “publicly traded securities”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id467cd4c7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id467cd4c8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/tXII/s1215/d/2"},"text":"Pub. L. 109–280, title XII, § 1215(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1079"},"text":"120 Stat. 1079","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/280/tXII/s1215/d/2"},"text":"“The amendments made by subsection (b) [amending this section] shall apply to returns filed after ","children":[{"tag":"date","attrib":{"date":"2006-09-01"},"text":"September 1, 2006","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id467cd4c9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":" applicable to contributions made after "},{"tag":"date","attrib":{"date":"2004-06-03"},"text":"June 3, 2004","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/s882/f"},"text":"section 882(f) of Pub. L. 108–357","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s170"},"text":"section 170 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id467cd4ca-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s155/d/1"},"text":"Pub. L. 98–369, div. A, title I, § 155(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/695"},"text":"98 Stat. 695","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/369/dA/tI/s155/d/1"},"text":"“The amendments made by subsections (a) and (b) [enacting this section, amending sections 6652 and 6678 of this title, and enacting provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s170"},"text":"section 170 of this title","children":[],"tail":"] shall apply to contributions made after "},{"tag":"date","attrib":{"date":"1984-12-31"},"text":"December 31, 1984","children":[],"tail":", in taxable years ending after such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
