{"tag":"section","attrib":{"id":"id41810a93-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139D"},"text":null,"children":[{"tag":"num","attrib":{"value":"139D"},"text":"§ 139D.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian health care benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id41810a94-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139D/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this section, gross income does not include the value of any qualified Indian health care benefit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id41810a95-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139D/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified Indian health care benefit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “qualified Indian health care benefit” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id41810a96-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139D/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any health service or benefit provided or purchased, directly or indirectly, by the Indian Health Service through a grant to or a contract or compact with an Indian tribe or tribal organization, or through a third-party program funded by the Indian Health Service,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41810a97-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139D/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" medical care provided or purchased by, or amounts to reimburse for such medical care provided by, an Indian tribe or tribal organization for, or to, a member of an Indian tribe, including a spouse or dependent of such a member,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41810a98-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139D/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coverage under accident or health insurance (or an arrangement having the effect of accident or health insurance), or an accident or health plan, provided by an Indian tribe or tribal organization for medical care to a member of an Indian tribe, include a spouse or dependent of such a member, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41810a99-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139D/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other medical care provided by an Indian tribe or tribal organization that supplements, replaces, or substitutes for a program or service relating to medical care provided by the Federal government to Indian tribes or members of such a tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id41810a9a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139D/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id41810a9b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139D/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian tribe” has the meaning given such term by section 45A(c)(6).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41810a9c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139D/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “tribal organization” has the meaning given such term by section 4(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of the Indian Self-Determination and Education Assistance Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41810a9d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139D/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical care","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “medical care” has the same meaning as when used in section 213.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41810a9e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139D/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accident or health insurance; accident or health plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “accident or health insurance” and “accident or health plan” have the same meaning as when used in section 105.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41810a9f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139D/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dependent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “dependent” has the meaning given such term by section 152, determined without regard to subsections (b)(1), (b)(2), and (d)(1)(B) thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id41810aa0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139D/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial of double benefit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not apply to the amount of any qualified Indian health care benefit which is not includible in gross income of the beneficiary of such benefit under any other provision of this chapter, or to the amount of any such benefit for which a deduction is allowed to such beneficiary under any other provision of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id41810aa1-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIX/s9021/a"},"text":"Pub. L. 111–148, title IX, § 9021(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/873"},"text":"124 Stat. 873","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id41810aa2-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id41810aa3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id41810aa4-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 4(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of the Indian Self-Determination and Education Assistance Act, referred to in subsec. (c)(2), is classified to section 5304("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of Title 25, Indians."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id41810aa5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 139D, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10108/f/1"},"text":"Pub. L. 111–148, title X, § 10108(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/913"},"text":"124 Stat. 913","children":[],"tail":", related to free choice vouchers, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/112/10/dB/tVIII/s1858/b/2/A"},"text":"Pub. L. 112–10, div. B, title VIII, § 1858(b)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-04-15"},"text":"Apr. 15, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/168"},"text":"125 Stat. 168","children":[],"tail":", effective as if included in the provisions of, and the amendments made by, the provisions of "},{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" to which it relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/112/10/s1858/d"},"text":"section 1858(d) of Pub. L. 112–10","children":[],"tail":", set out as an Effective Date of 2011 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s36B"},"text":"section 36B of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id41810aa6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id41810aa7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIX/s9021/c"},"text":"Pub. L. 111–148, title IX, § 9021(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/874"},"text":"124 Stat. 874","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/148/tIX/s9021/c"},"text":"“The amendments made by this section [enacting this section] shall apply to benefits and coverage provided after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id41810aa8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"No Inference With Respect to Exclusion From Gross Income of Certain Benefits","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIX/s9021/d"},"text":"Pub. L. 111–148, title IX, § 9021(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/874"},"text":"124 Stat. 874","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/148/tIX/s9021/d"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Nothing in the amendments made by this section [enacting this section] shall be construed to create an inference with respect to the exclusion from gross income of—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" benefits provided by an Indian tribe or tribal organization that are not within the scope of this section, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" benefits provided prior to the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
