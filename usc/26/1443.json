{"tag":"section","attrib":{"id":"id4514b904-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1443"},"text":null,"children":[{"tag":"num","attrib":{"value":"1443"},"text":"§ 1443.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign tax-exempt organizations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4514b905-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1443/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Income subject to section 511","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of income of a foreign organization subject to the tax imposed by section 511, this chapter shall apply to income includible under section 512 in computing its unrelated business taxable income, but only to the extent and subject to such conditions as may be provided under regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4514b906-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1443/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Income subject to section 4948","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of income of a foreign organization subject to the tax imposed by section 4948(a), this chapter shall apply, except that the deduction and withholding shall be at the rate of 4 percent and shall be subject to such conditions as may be provided under regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4514b907-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},