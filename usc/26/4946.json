{"tag":"section","attrib":{"id":"id45edb387-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4946"},"text":null,"children":[{"tag":"num","attrib":{"value":"4946"},"text":"§ 4946.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and special rules","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45edb388-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4946/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disqualified person","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45edb389-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4946/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter, the term “disqualified person” means, with respect to a private foundation, a person who is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45edb38a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4946/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a substantial contributor to the foundation,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45edb38b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4946/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a foundation manager (within the meaning of subsection (b)(1)),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45edb38c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4946/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an owner of more than 20 percent of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45edb38d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4946/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total combined voting power of a corporation,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45edb38e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4946/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the profits interest of a partnership, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45edb38f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4946/a/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the beneficial interest of a trust or unincorporated enterprise,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"which is a substantial contributor to the foundation,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45edb390-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4946/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the family (as defined in subsection (d)) of any individual described in subparagraph (A), (B), or (C),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45edb391-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4946/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a corporation of which persons described in subparagraph (A), (B), (C), or (D) own more than 35 percent of the total combined voting power,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45edb392-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4946/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a partnership in which persons described in subparagraph (A), (B), (C), or (D) own more than 35 percent of the profits interest,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45edb393-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4946/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a trust or estate in which persons described in subparagraph (A), (B), (C), or (D) hold more than 35 percent of the beneficial interest,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45edb394-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4946/a/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" only for purposes of section 4943, a private foundation—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45edb395-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4946/a/1/H/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is effectively controlled (directly or indirectly) by the same person or persons who control the private foundation in question, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45edb396-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4946/a/1/H/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substantially all of the contributions to which were made (directly or indirectly) by the same person or persons described in subparagraph (A), (B), or (C), or members of their families (within the meaning of subsection (d)), who made (directly or indirectly) substantially all of the contributions to the private foundation in question, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45edb397-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4946/a/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only for purposes of section 4941, a government official (as defined in subsection (c)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45edb398-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4946/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substantial contributors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1), the term “substantial contributor” means a person who is described in section 507(d)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45edb399-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4946/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stockholdings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraphs (1)(C)(i) and (1)(E), there shall be taken into account indirect stockholdings which would be taken into account under section 267(c), except that, for purposes of this paragraph, section 267(c)(4) shall be treated as providing that the members of the family of an individual are the members within the meaning of subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45edb39a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4946/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnerships; trusts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraphs (1)(C)(ii) and (iii), (1)(F), and (1)(G), the ownership of profits or beneficial interests shall be determined in accordance with the rules for constructive ownership of stock provided in section 267(c) (other than paragraph (3) thereof), except that section 267(c)(4) shall be treated as providing that the members of the family of an individual are the members within the meaning of subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45edb39b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4946/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foundation manager","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter, the term “foundation manager” means, with respect to any private foundation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45edb39c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4946/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an officer, director, or trustee of a foundation (or an individual having powers or responsibilities similar to those of officers, directors, or trustees of the foundation), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45edb39d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4946/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to any act (or failure to act), the employees of the foundation having authority or responsibility with respect to such act (or failure to act).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45edb39e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4946/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Government official","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a)(1)(I) and section 4941, the term “government official” means, with respect to an act of self-dealing described in section 4941, an individual who, at the time of such act, holds any of the following offices or positions (other than as a “special Government employee”, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s202/a"},"text":"section 202(a) of title 18","children":[],"tail":", United States Code):"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id45edb39f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4946/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an elective public office in the executive or legislative branch of the Government of the United States,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45edb3a0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4946/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an office in the executive or judicial branch of the Government of the United States, appointment to which was made by the President,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45edb3a1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4946/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a position in the executive, legislative, or judicial branch of the Government of the United States—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45edb3a2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4946/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is listed in schedule C of rule VI of the Civil Service Rules, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45edb3a3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4946/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the compensation for which is equal to or greater than the lowest rate of basic pay for the Senior Executive Service under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5382"},"text":"section 5382 of title 5","children":[],"tail":", United States Code,"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45edb3a4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4946/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a position under the House of Representatives or the Senate of the United States held by an individual receiving gross compensation at an annual rate of $15,000 or more,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45edb3a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4946/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an elective or appointive public office in the executive, legislative, or judicial branch of the government of a State, possession of the United States, or political subdivision or other area of any of the foregoing, or of the District of Columbia, held by an individual receiving gross compensation at an annual rate of $20,000 or more,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45edb3a6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4946/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a position as personal or executive assistant or secretary to any of the foregoing, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45edb3a7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4946/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the Internal Revenue Service Oversight Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45edb3a8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4946/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members of family","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsection (a)(1), the family of any individual shall include only his spouse, ancestors, children, grandchildren, great grandchildren, and the spouses of children, grandchildren, and great grandchildren.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45edb3a9-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172/tI/s101/b"},"text":"Pub. L. 91–172, title I, § 101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/515"},"text":"83 Stat. 515","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/227/s4/c/2/B"},"text":"Pub. L. 95–227, § 4(c)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-02-10"},"text":"Feb. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/22"},"text":"92 Stat. 22","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tIII/s306/a"},"text":"Pub. L. 98–369, div. A, title III, § 306(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/784"},"text":"98 Stat. 784","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVI/s1606/a"},"text":"Pub. L. 99–514, title XVI, § 1606(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2771"},"text":"100 Stat. 2771","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tI/s1101/c/1"},"text":"Pub. L. 105–206, title I, § 1101(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/696"},"text":"112 Stat. 696","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tIII/s319/16"},"text":"Pub. L. 106–554, § 1(a)(7) [title III, § 319(16)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–647.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45edb3aa-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45edb3ab-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45edb3ac-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (c)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554"},"text":"Pub. L. 106–554","children":[],"tail":" substituted “the lowest rate of basic pay for the Senior Executive Service under section 5382” for “the lowest rate of compensation prescribed for GS–16 of the General Schedule under section 5332”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (c)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206"},"text":"Pub. L. 105–206","children":[],"tail":" added par. (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “$20,000” for “$15,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" amended subsec. (d) generally, substituting references to children, grandchildren, and great grandchildren for references to lineal descendants in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsecs. (a)(1), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/227"},"text":"Pub. L. 95–227","children":[],"tail":" substituted “subchapter” for “chapter”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45edb3ad-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45edb3ae-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVI/s1606/b"},"text":"Pub. L. 99–514, title XVI, § 1606(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2771"},"text":"100 Stat. 2771","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/tXVI/s1606/b"},"text":"“The amendment made by this section [amending this section] shall apply to compensation received after ","children":[{"tag":"date","attrib":{"date":"1985-12-31"},"text":"December 31, 1985","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45edb3af-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tIII/s306/c"},"text":"Pub. L. 98–369, div. A, title III, § 306(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/784"},"text":"98 Stat. 784","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/369/dA/tIII/s306/c"},"text":"“The amendments made by this subsection [probably should be “section”, amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6104"},"text":"section 6104 of this title","children":[],"tail":"] shall take effect on "},{"tag":"date","attrib":{"date":"1985-01-01"},"text":"January 1, 1985","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45edb3b0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/227"},"text":"Pub. L. 95–227","children":[],"tail":" applicable with respect to contributions, acts, and expenditures made after "},{"tag":"date","attrib":{"date":"1977-12-31"},"text":"Dec. 31, 1977","children":[],"tail":", in and for taxable years beginning after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/95/227/s4/f"},"text":"section 4(f) of Pub. L. 95–227","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s192"},"text":"section 192 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
