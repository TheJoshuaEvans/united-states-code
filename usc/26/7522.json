{"tag":"section","attrib":{"id":"id47700e5b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7522"},"text":null,"children":[{"tag":"num","attrib":{"value":"7522"},"text":"§ 7522.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content of tax due, deficiency, and other notices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47700e5c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7522/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any notice to which this section applies shall describe the basis for, and identify the amounts (if any) of, the tax due, interest, additional amounts, additions to the tax, and assessable penalties included in such notice. An inadequate description under the preceding sentence shall not invalidate such notice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47700e5d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7522/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notices to which section applies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section shall apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47700e5e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7522/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any tax due notice or deficiency notice described in section 6155, 6212, or 6303,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47700e5f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7522/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any notice generated out of any information return matching program, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47700e60-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7522/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 1st letter of proposed deficiency which allows the taxpayer an opportunity for administrative review in the Internal Revenue Service Independent Office of Appeals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47700e61-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tVI/s6233/a"},"text":"Pub. L. 100–647, title VI, § 6233(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3735"},"text":"102 Stat. 3735","children":[],"tail":", § 7521; renumbered § 7522, "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11704/a/30"},"text":"Pub. L. 101–508, title XI, § 11704(a)(30)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-519"},"text":"104 Stat. 1388–519","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/25/tI/s1001/b/1/I"},"text":"Pub. L. 116–25, title I, § 1001(b)(1)(I)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-07-01"},"text":"July 1, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/985"},"text":"133 Stat. 985","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47700e62-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47700e63-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id47700e64-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/25"},"text":"Pub. L. 116–25","children":[],"tail":" substituted “Internal Revenue Service Independent Office of Appeals” for “Internal Revenue Service Office of Appeals”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47700e65-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id47700e66-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tVI/s6233/c"},"text":"Pub. L. 100–647, title VI, § 6233(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3735"},"text":"102 Stat. 3735","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/647/tVI/s6233/c"},"text":"“The amendments made by this section [enacting this section] shall apply to mailings made on or after ","children":[{"tag":"date","attrib":{"date":"1990-01-01"},"text":"January 1, 1990","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
