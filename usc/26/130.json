{"tag":"section","attrib":{"id":"id4175248c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s130"},"text":null,"children":[{"tag":"num","attrib":{"value":"130"},"text":"§ 130.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain personal injury liability assignments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4175248d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s130/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amount received for agreeing to a qualified assignment shall not be included in gross income to the extent that such amount does not exceed the aggregate cost of any qualified funding assets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4175248e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s130/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of qualified funding asset","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any qualified funding asset—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4175248f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s130/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the basis of such asset shall be reduced by the amount excluded from gross income under subsection (a) by reason of the purchase of such asset, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41752490-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s130/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any gain recognized on a disposition of such asset shall be treated as ordinary income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id41752491-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s130/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified assignment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “qualified assignment” means any assignment of a liability to make periodic payments as damages (whether by suit or agreement), or as compensation under any workmen’s compensation act, on account of personal injury or sickness (in a case involving physical injury or physical sickness)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id41752492-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s130/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the assignee assumes such liability from a person who is a party to the suit or agreement, or the workmen’s compensation claim, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41752493-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s130/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id41752494-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s130/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such periodic payments are fixed and determinable as to amount and time of payment,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id41752495-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s130/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such periodic payments cannot be accelerated, deferred, increased, or decreased by the recipient of such payments,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id41752496-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s130/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the assignee’s obligation on account of the personal injuries or sickness is no greater than the obligation of the person who assigned the liability, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id41752497-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s130/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such periodic payments are excludable from the gross income of the recipient under paragraph (1) or (2) of section 104(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The determination for purposes of this chapter of when the recipient is treated as having received any payment with respect to which there has been a qualified assignment shall be made without regard to any provision of such assignment which grants the recipient rights as a creditor greater than those of a general creditor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id41752498-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s130/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified funding asset","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “qualified funding asset” means any annuity contract issued by a company licensed to do business as an insurance company under the laws of any State, or any obligation of the United States, if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id41752499-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s130/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such annuity contract or obligation is used by the assignee to fund periodic payments under any qualified assignment,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4175249a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s130/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the periods of the payments under the annuity contract or obligation are reasonably related to the periodic payments under the qualified assignment, and the amount of any such payment under the contract or obligation does not exceed the periodic payment to which it relates,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4175249b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s130/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such annuity contract or obligation is designated by the taxpayer (in such manner as the Secretary shall by regulations prescribe) as being taken into account under this section with respect to such qualified assignment, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4175249c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s130/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such annuity contract or obligation is purchased by the taxpayer not more than 60 days before the date of the qualified assignment and not later than 60 days after the date of such assignment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4175249d-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/473/tI/s101/b/1"},"text":"Pub. L. 97–473, title I, § 101(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-14"},"text":"Jan. 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2605"},"text":"96 Stat. 2605","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tX/s1002/a"},"text":"Pub. L. 99–514, title X, § 1002(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2388"},"text":"100 Stat. 2388","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tVI/s6079/b/1"},"text":"Pub. L. 100–647, title VI, § 6079(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3709"},"text":"102 Stat. 3709","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tIX/s962/a"},"text":"Pub. L. 105–34, title IX, § 962(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/891"},"text":"111 Stat. 891","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4175249e-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4175249f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id417524a0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 130 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s140"},"text":"section 140 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id417524a1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s962/a/1"},"text":"Pub. L. 105–34, § 962(a)(1)","children":[],"tail":", inserted “, or as compensation under any workmen’s compensation act,” after “(whether by suit or agreement)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s962/a/2"},"text":"Pub. L. 105–34, § 962(a)(2)","children":[],"tail":", inserted “or the workmen’s compensation claim,” after “agreement,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s962/a/3"},"text":"Pub. L. 105–34, § 962(a)(3)","children":[],"tail":", substituted “paragraph (1) or (2) of section 104(a)” for “section 104(a)(2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":", in par. (2), redesignated subpars. (D) and (E) as (C) and (D), respectively, struck out former subpar. (C) which provided that the assignee does not provide to the recipient of such payments rights against the assignee which are greater than those of a general creditor, and as concluding provisions, inserted at end “The determination for purposes of this chapter of when the recipient is treated as having received any payment with respect to which there has been a qualified assignment shall be made without regard to any provision of such assignment which grants the recipient rights as a creditor greater than those of a general creditor.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" inserted “(in a case involving physical injury or physical sickness)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id417524a2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id417524a3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/tIX/s962/b"},"text":"Pub. L. 105–34, title IX, § 962(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/892"},"text":"111 Stat. 892","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/34/tIX/s962/b"},"text":"“The amendments made by subsection (a) [amending this section] shall apply to claims under workmen’s compensation acts filed after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id417524a4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tVI/s6079/b/2"},"text":"Pub. L. 100–647, title VI, § 6079(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3710"},"text":"102 Stat. 3710","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/647/tVI/s6079/b/2"},"text":"“The amendment made by paragraph (1) [amending this section] shall apply to assignments after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id417524a5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tX/s1002/b"},"text":"Pub. L. 99–514, title X, § 1002(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2388"},"text":"100 Stat. 2388","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/tX/s1002/b"},"text":"“The amendment made by this section [amending this section] shall apply to assignments entered into after ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":", in taxable years ending after such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id417524a6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/473/tI/s101/c"},"text":"Pub. L. 97–473, title I, § 101(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-14"},"text":"Jan. 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2606"},"text":"96 Stat. 2606","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/473/tI/s101/c"},"text":"“The amendments made by this section [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s104"},"text":"section 104 of this title","children":[],"tail":"] shall apply to taxable years ending after "},{"tag":"date","attrib":{"date":"1982-12-31"},"text":"December 31, 1982","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
