{"tag":"section","attrib":{"id":"id4755cfac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7443"},"text":null,"children":[{"tag":"num","attrib":{"value":"7443"},"text":"§ 7443.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4755cfad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7443/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Tax Court shall be composed of 19 members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4755cfae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7443/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Judges of the Tax Court shall be appointed by the President, by and with the advice and consent of the Senate, solely on the grounds of fitness to perform the duties of the office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4755cfaf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7443/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Salary","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4755cfb0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7443/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each judge shall receive salary at the same rate and in the same installments as judges of the district courts of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4755cfb1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7443/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For rate of salary and frequency of installment see section 135, title 28, United States Code, and section 5505, title 5, United States Code.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4755cfb2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7443/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenses for travel and subsistence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Judges of the Tax Court shall receive necessary traveling expenses, and expenses actually incurred for subsistence while traveling on duty and away from their designated stations, subject to the same limitations in amount as are now or may hereafter be applicable to the United States Court of International Trade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4755cfb3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7443/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term of office of any judge of the Tax Court shall expire 15 years after he takes office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4755cfb4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7443/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal from office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Judges of the Tax Court may be removed by the President, after notice and opportunity for public hearing, for inefficiency, neglect of duty, or malfeasance in office, but for no other cause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4755cfb5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7443/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disbarment of removed judges","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A judge of the Tax Court removed from office in accordance with subsection (f) shall not be permitted at any time to practice before the Tax Court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4755cfb6-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/879"},"text":"68A Stat. 879","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1955-03-02/ch9/s1/h"},"text":"Mar. 2, 1955, ch. 9, § 1(h)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/10"},"text":"69 Stat. 10","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/426/tIV/s403/i"},"text":"Pub. L. 88–426, title IV, § 403(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-08-14"},"text":"Aug. 14, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/434"},"text":"78 Stat. 434","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/tIX"},"text":"Pub. L. 91–172, title IX","children":[],"tail":", §§ 952, 953, "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/730"},"text":"83 Stat. 730","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/417/tVI/s601/10"},"text":"Pub. L. 96–417, title VI, § 601(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-10"},"text":"Oct. 10, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1744"},"text":"94 Stat. 1744","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/439/s1/a"},"text":"Pub. L. 96–439, § 1(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1980-10-13"},"text":"Oct. 13, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1878"},"text":"94 Stat. 1878","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4755cfb7-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4755cfb8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4755cfb9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/439/s1/a"},"text":"Pub. L. 96–439, § 1(a)","children":[],"tail":", increased number of judges from 16 to 19."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/439/s1/b"},"text":"Pub. L. 96–439, § 1(b)","children":[],"tail":", struck out age limitation that no one could be appointed a member of the Tax Court unless appointed before attaining age 65."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/417"},"text":"Pub. L. 96–417","children":[],"tail":" substituted “Court of International Trade” for “Customs Court”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172/s952/a"},"text":"Pub. L. 91–172, § 952(a)","children":[],"tail":", provided that an individual may not be appointed a judge of the Tax Court after reaching age 65."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172/s953"},"text":"Pub. L. 91–172, § 953","children":[],"tail":", substituted provisions fixing salary of Tax Court judges at the same rate and same installments as District Court judges, for provisions that each judge of the Tax Court receive a salary of $30,000 per annum, to be paid in monthly installments."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172/s952/b"},"text":"Pub. L. 91–172, § 952(b)","children":[],"tail":", substituted provisions that a term in office of any Tax Court judge would expire 15 years after he takes office, for provisions that a term in office of any Tax Court judge would expire 12 years after the expiration of the term for which his predecessor was appointed, and any judge appointed to fill a vacancy occurring prior to the expiration of the term for which his predecessor was appointed would be appointed only for the unexpired term of his predecessor."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1964—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/426"},"text":"Pub. L. 88–426","children":[],"tail":" increased salary of judges from $22,500 to $30,000."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1955—Subsec. (c). Act ","children":[{"tag":"date","attrib":{"date":"1955-03-02"},"text":"Mar. 2, 1955","children":[],"tail":", increased salary of judges from $15,000 to $22,500."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4755cfba-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4755cfbb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/439/s1/c"},"text":"Pub. L. 96–439, § 1(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-13"},"text":"Oct. 13, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1878"},"text":"94 Stat. 1878","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/439/s1/c"},"text":"“The amendments made by this section [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1981-02-01"},"text":"February 1, 1981","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/417"},"text":"Pub. L. 96–417","children":[],"tail":" effective, except as otherwise provided, "},{"tag":"date","attrib":{"date":"1980-11-01"},"text":"Nov. 1, 1980","children":[],"tail":", and applicable with respect to civil actions pending on or commenced on or after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/96/417/s701/a"},"text":"section 701(a) of Pub. L. 96–417","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s251"},"text":"section 251 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4755cfbc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1969 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172/tIX/s962/b"},"text":"Pub. L. 91–172, title IX, § 962(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/736"},"text":"83 Stat. 736","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/91/172/tIX/s962/b"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendment made by section 952(a) [amending this section] shall apply to judges appointed after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The amendment made by section 952(b) [amending this section] shall take effect on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":"], except that—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term of office being served by a judge of the Tax Court on that date shall expire on the date it would have expired under the law in effect on the date preceding the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a judge of the Tax Court on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":"] may be reappointed in the same manner as a judge of the Tax Court hereafter appointed.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172/s953"},"text":"section 953 of Pub. L. 91–172","children":[],"tail":" to take effect on "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/s962/a"},"text":"section 962(a) of Pub. L. 91–172","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s7441"},"text":"section 7441 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4755cfbd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1964 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/426"},"text":"Pub. L. 88–426","children":[],"tail":" effective on first day of first pay period which begins on or after "},{"tag":"date","attrib":{"date":"1964-07-01"},"text":"July 1, 1964","children":[],"tail":", except to the extent provided in "},{"tag":"ref","attrib":{"href":"/us/pl/88/426/s501/c"},"text":"section 501(c) of Pub. L. 88–426","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/88/426/s501"},"text":"section 501 of Pub. L. 88–426","children":[],"tail":", title V, "},{"tag":"date","attrib":{"date":"1964-08-14"},"text":"Aug. 14, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/435"},"text":"78 Stat. 435","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4755cfbe-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1955 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by act ","children":[{"tag":"date","attrib":{"date":"1955-03-02"},"text":"Mar. 2, 1955","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1955-03-01"},"text":"Mar. 1, 1955","children":[],"tail":", see section 5 of act "},{"tag":"date","attrib":{"date":"1955-03-02"},"text":"Mar. 2, 1955","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s4501"},"text":"section 4501 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4755cfbf-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Salary Increases","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1987—Salaries of judges increased to $89,500 per annum, on recommendation of the President of the United States, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s358"},"text":"section 358 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Salaries of judges increased to $54,500 per annum, on recommendation of the President of the United States, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s358"},"text":"section 358 of Title 2","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—Salaries of judges increased to $40,000 per annum, on recommendation of the President of the United States, see note set out under ",