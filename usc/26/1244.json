{"tag":"section","attrib":{"id":"id44c62424-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1244"},"text":null,"children":[{"tag":"num","attrib":{"value":"1244"},"text":"§ 1244.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Losses on small business stock","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44c62425-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1244/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an individual, a loss on section 1244 stock issued to such individual or to a partnership which would (but for this section) be treated as a loss from the sale or exchange of a capital asset shall, to the extent provided in this section, be treated as an ordinary loss.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44c62426-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1244/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount for any taxable year","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For any taxable year the aggregate amount treated by the taxpayer by reason of this section as an ordinary loss shall not exceed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44c62427-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1244/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $50,000, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44c62428-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1244/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000, in the case of a husband and wife filing a joint return for such year under section 6013.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44c62429-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1244/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Section 1244 stock defined","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44c6242a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1244/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “section 1244 stock” means stock in a domestic corporation if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44c6242b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1244/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the time such stock is issued, such corporation was a small business corporation,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44c6242c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1244/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such stock was issued by such corporation for money or other property (other than stock and securities), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44c6242d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1244/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such corporation, during the period of its 5 most recent taxable years ending before the date the loss on such stock was sustained, derived more than 50 percent of its aggregate gross receipts from sources other than royalties, rents, dividends, interests, annuities, and sales or exchanges of stocks or securities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44c6242e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1244/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules for application of paragraph (1)(C)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44c6242f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1244/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period taken into account with respect to new corporations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1)(C), if the corporation has not been in existence for 5 taxable years ending before the date the loss on the stock was sustained, there shall be substituted for such 5-year period—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44c62430-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1244/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period of the corporation’s taxable years ending before such date, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44c62431-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1244/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the corporation has not been in existence for 1 taxable year ending before such date, the period such corporation has been in existence before such date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44c62432-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1244/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gross receipts from sales of securities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1)(C), gross receipts from the sales or exchanges of stock or securities shall be taken into account only to the extent of gains therefrom.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44c62433-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1244/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplication where deductions exceed gross income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1)(C) shall not apply with respect to any corporation if, for the period taken into account for purposes of paragraph (1)(C), the amount of the deductions allowed by this chapter (other than by sections 172, 243, and 245) exceeds the amount of gross income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44c62434-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1244/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small business corporation defined","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44c62435-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1244/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, a corporation shall be treated as a small business corporation if the aggregate amount of money and other property received by the corporation for stock, as a contribution to capital, and as paid-in surplus, does not exceed $1,000,000. The determination under the preceding sentence shall be made as of the time of the issuance of the stock in question but shall include amounts received for such stock and for all stock theretofore issued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44c62436-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1244/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount taken into account with respect to property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A), the amount taken into account with respect to any property other than money shall be the amount equal to the adjusted basis to the corporation of such property for determining gain, reduced by any liability to which the property was subject or which was assumed by the corporation. The determination under the preceding sentence shall be made as of the time the property was received by the corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44c62437-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1244/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44c62438-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1244/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on amount of ordinary loss","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44c62439-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1244/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contributions of property having basis in excess of value","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44c6243a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1244/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 1244 stock was issued in exchange for property,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44c6243b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1244/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the basis of such stock in the hands of the taxpayer is determined by reference to the basis in his hands of such property, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44c6243c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1244/d/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adjusted basis (for determining loss) of such property immediately before the exchange exceeded its fair market value at such time,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then in computing the amount of the loss on such stock for purposes of this section the basis of such stock shall be reduced by an amount equal to the excess described in clause (iii).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44c6243d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1244/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increases in basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In computing the amount of the loss on stock for purposes of this section, any increase in the basis of such stock (through contributions to the capital of the corporation, or otherwise) shall be treated as allocable to stock which is not section 1244 stock.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44c6243e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1244/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recapitalizations, changes in name, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent provided in regulations prescribed by the Secretary, stock in a corporation, the basis of which (in the hands of a taxpayer) is determined in whole or in part by reference to the basis in his hands of stock in such corporation which meets the requirements of subsection (c)(1) (other than subparagraph (C) thereof), or which is received in a reorganization described in section 368(a)(1)(F) in exchange for stock which meets such requirements, shall be treated as meeting such requirements. For purposes of paragraphs (1)(C) and (3)(A) of subsection (c), a successor corporation in a reorganization described in section 368(a)(1)(F) shall be treated as the same corporation as its predecessor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44c6243f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1244/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to net operating loss deduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of section 172 (relating to the net operating loss deduction), any amount of loss treated by reason of this section as an ordinary loss shall be treated as attributable to a trade or business of the taxpayer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44c62440-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1244/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individual defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “individual” does not include a trust or estate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44c62441-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1244/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such regulations as may be necessary to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44c62442-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/866/tII/s202/b"},"text":"Pub. L. 85–866, title II, § 202(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1676"},"text":"72 Stat. 1676","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX"},"text":"Pub. L. 94–455, title XIX","children":[],"tail":", §§ 1901(b)(1)(W), (3)(G), 1906(b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1792"},"text":"90 Stat. 1792","children":[],"tail":", 1793, 1834; "},{"tag":"ref","attrib":{"href":"/us/pl/95/600/tIII/s345/a"},"text":"Pub. L. 95–600, title III, § 345(a)","children":[],"tail":"–(d), "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2844"},"text":"92 Stat. 2844","children":[],"tail":", 2845; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tIV/s481/a"},"text":"Pub. L. 98–369, div. A, title IV, § 481(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/847"},"text":"98 Stat. 847","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dA/tII/s221/a/41/H"},"text":"Pub. L. 113–295, div. A, title II, § 221(a)(41)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4044"},"text":"128 Stat. 4044","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44c62443-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44c62444-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44c62445-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (c)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" struck out “244,” after “243,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsecs. (c)(1), (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" substituted “stock in a” for “common stock in a”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600/s345/b"},"text":"Pub. L. 95–600, § 345(b)","children":[],"tail":", substituted in par. (1) “$50,000” for “$25,000” and in par. (2) “$100,000” for “$50,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600/s345/a"},"text":"Pub. L. 95–600, § 345(a)","children":[],"tail":", (c), among other changes, substituted provisions permitting a corporation to issue common stock under the provisions of this section without a written plan for provisions requiring that a written plan to issue section 1244 stock must be adopted by the issuing corporation and increased the amount of section 1244 stock that a qualified small business corporation may issue from $500,000 to $1,000,000."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600/s345/d"},"text":"Pub. L. 95–600, § 345(d)","children":[],"tail":", substituted “subparagraph (C)” for “subparagraph (E)” and “paragraphs (1)(C) and (3)(A)” for “paragraphs (1)(E) and (2)(A)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1901/b/3/G"},"text":"Pub. L. 94–455, § 1901(b)(3)(G)","children":[],"tail":", substituted “an ordinary loss” for “a loss from the sale or exchange of an asset which is not a capital asset”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1901/b/1/W"},"text":"Pub. L. 94–455, § 1901(b)(1)(W)","children":[],"tail":", struck out reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s242"},"text":"section 242 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1901/b/3/G"},"text":"Pub. L. 94–455, § 1901(b)(3)(G)","children":[],"tail":", substituted “an ordinary loss” for “a loss from the sale or exchange of an asset which is not a capital asset”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44c62446-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44c62447-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" not applicable to preferred stock issued before "},{"tag":"date","attrib":{"date":"1942-10-01"},"text":"Oct. 1, 1942","children":[],"tail":" (determined in the same manner as under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s247"},"text":"section 247 of this title","children":[],"tail":" as in effect before its repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/s221/a/41/K"},"text":"section 221(a)(41)(K) of Pub. L. 113–295","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s172"},"text":"section 172 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Except as otherwise provided in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295/s221/a"},"text":"section 221(a) of Pub. L. 113–295","children":[],"tail":", amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", subject to a savings provision, see "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/s221/b"},"text":"section 221(b) of Pub. L. 113–295","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44c62448-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tIV/s481/b"},"text":"Pub. L. 98–369, div. A, title IV, § 481(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/847"},"text":"98 Stat. 847","children":[],"tail":", provided that: "