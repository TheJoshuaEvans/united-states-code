{"tag":"section","attrib":{"id":"id41241d80-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s58"},"text":null,"children":[{"tag":"num","attrib":{"value":"58"},"text":"§ 58.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial of certain losses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id41241d81-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s58/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial of farm loss","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id41241d82-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s58/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of computing the amount of the alternative minimum taxable income for any taxable year of a taxpayer other than a corporation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id41241d83-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s58/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disallowance of farm loss","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No loss of the taxpayer for such taxable year from any tax shelter farm activity shall be allowed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id41241d84-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s58/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deduction in succeeding taxable year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any loss from a tax shelter farm activity disallowed under subparagraph (A) shall be treated as a deduction allocable to such activity in the 1st succeeding taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41241d85-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s58/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax shelter farm activity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “tax shelter farm activity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id41241d86-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s58/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any farming syndicate as defined in section 461(k), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id41241d87-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s58/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other activity consisting of farming which is a passive activity (within the meaning of section 469(c)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41241d88-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s58/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of loss","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining the amount of the loss from any tax shelter farm activity, the adjustments of sections 56 and 57 shall apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id41241d89-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s58/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disallowance of passive activity loss","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In computing the alternative minimum taxable income of the taxpayer for any taxable year, section 469 shall apply, except that in applying section 469—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id41241d8a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s58/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adjustments of sections 56 and 57 shall apply, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41241d8b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s58/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in lieu of applying section 469(j)(7), the passive activity loss of a taxpayer shall be computed without regard to qualified housing interest (as defined in section 56(e)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id41241d8c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s58/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id41241d8d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s58/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for insolvent taxpayers","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id41241d8e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s58/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of losses to which subsection (a) or (b) applies shall be reduced by the amount (if any) by which the taxpayer is insolvent as of the close of the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id41241d8f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s58/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insolvent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this paragraph, the term “insolvent” means the excess of liabilities over the fair market value of assets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id41241d90-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s58/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loss allowed for year of disposition of farm shelter activity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the taxpayer disposes of his entire interest in any tax shelter farm activity during any taxable year, the amount of the loss attributable to such activity (determined after carryovers under subsection (a)(1)(B)) shall (to the extent otherwise allowable) be allowed for such taxable year in computing alternative minimum taxable income and not treated as a loss from a tax shelter farm activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id41241d91-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVII/s701/a"},"text":"Pub. L. 99–514, title VII, § 701(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2335"},"text":"100 Stat. 2335","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX/s10212/b"},"text":"Pub. L. 100–203, title X, § 10212(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-406"},"text":"101 Stat. 1330–406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1007/d"},"text":"Pub. L. 100–647, title I, § 1007(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3432"},"text":"102 Stat. 3432","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dA/tII/s221/a/58/E"},"text":"Pub. L. 113–295, div. A, title II, § 221(a)(58)(E)","children":[],"tail":", (60)(B), "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4047"},"text":"128 Stat. 4047","children":[],"tail":", 4048; "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s12001/b/9"},"text":"Pub. L. 115–97, title I, § 12001(b)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2093"},"text":"131 Stat. 2093","children":[],"tail":"; "