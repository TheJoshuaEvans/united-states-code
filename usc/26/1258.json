{"tag":"section","attrib":{"id":"id44d20b36-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1258"},"text":null,"children":[{"tag":"num","attrib":{"value":"1258"},"text":"§ 1258.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recharacterization of gain from certain financial transactions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44d20b37-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1258/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any gain—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44d20b38-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1258/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which (but for this section) would be treated as gain from the sale or exchange of a capital asset, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d20b39-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1258/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is recognized on the disposition or other termination of any position which was held as part of a conversion transaction,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"such gain (to the extent such gain does not exceed the applicable imputed income amount) shall be treated as ordinary income.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44d20b3a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1258/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable imputed income amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a), the term “applicable imputed income amount” means, with respect to any disposition or other termination referred to in subsection (a), an amount equal to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44d20b3b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1258/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of interest which would have accrued on the taxpayer’s net investment in the conversion transaction for the period ending on the date of such disposition or other termination (or, if earlier, the date on which the requirements of subsection (c) ceased to be satisfied) at a rate equal to 120 percent of the applicable rate, reduced by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d20b3c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1258/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount treated as ordinary income under subsection (a) with respect to any prior disposition or other termination of a position which was held as a part of such transaction.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The Secretary shall by regulations provide for such reductions in the applicable imputed income amount as may be appropriate by reason of amounts capitalized under section 263(g), ordinary income received, or otherwise.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44d4542d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1258/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conversion transaction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “conversion transaction” means any transaction—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44d4542e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1258/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substantially all of the taxpayer’s expected return from which is attributable to the time value of the taxpayer’s net investment in such transaction, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d4542f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1258/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" which is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44d45430-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1258/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the holding of any property (whether or not actively traded), and the entering into a contract to sell such property (or substantially identical property) at a price determined in accordance with such contract, but only if such property was acquired and such contract was entered into on a substantially contemporaneous basis,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d45431-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1258/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an applicable straddle,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d45432-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1258/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other transaction which is marketed or sold as producing capital gains from a transaction described in paragraph (1), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d45433-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1258/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other transaction specified in regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44d45434-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1258/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44d45435-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1258/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable straddle","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “applicable straddle” means any straddle (within the meaning of section 1092(c)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d45436-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1258/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable rate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “applicable rate” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44d45437-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1258/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicable Federal rate determined under section 1274(d) (compounded semiannually) as if the conversion transaction were a debt instrument, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d45438-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1258/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the term of the conversion transaction is indefinite, the Federal short-term rates in effect under section 6621(b) during the period of the conversion transaction (compounded daily).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d45439-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1258/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of built-in losses","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44d4543a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1258/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If any position with a built-in loss becomes part of a conversion transaction—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44d4543b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1258/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for purposes of applying this subtitle to such position for periods after such position becomes part of such transaction, such position shall be taken into account at its fair market value as of the time it became part of such transaction, except that","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44d4543c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1258/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon the disposition or other termination of such position in a transaction in which gain or loss is recognized, such built-in loss shall be recognized and shall have a character determined without regard to this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d4543d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1258/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Built-in loss","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A), the term “built-in loss” means the loss (if any) which would have been realized if the position had been disposed of or otherwise terminated at its fair market value as of the time such position became part of the conversion transaction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d4543e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1258/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Position taken into account at fair market value","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining the taxpayer’s net investment in any conversion transaction, there shall be included the fair market value of any position which becomes part of such transaction (determined as of the time such position became part of such transaction).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44d4543f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1258/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for options dealers and commodities traders","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44d45440-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1258/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply to transactions—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44d45441-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1258/d/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of an options dealer in the normal course of the dealer’s trade or business of dealing in options, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44d45442-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1258/d/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of a commodities trader in the normal course of the trader’s trade or business of trading section 1256 contracts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d45443-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1258/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this paragraph—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44d45444-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1258/d/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Options dealer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “options dealer” has the meaning given such term by section 1256(g)(8).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44d45445-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1258/d/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commodities trader","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “commodities trader” means any person who is a member (or, except as otherwise provided in regulations, is entitled to trade as a member) of a domestic board of trade which is designated as a contract market by the Commodity Futures Trading Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44d45446-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1258/d/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited partners and limited entrepreneurs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any gain from a transaction recognized by an entity which is allocable to a limited partner or limited entrepreneur (within the meaning of section 461(k)(4)), subparagraph (A) shall not apply if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44d45447-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1258/d/5/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substantially all of the limited partner’s (or limited entrepreneur’s) expected return from the entity is attributable to the time value of the partner’s (or entrepreneur’s) net investment in such entity,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44d45448-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1258/d/5/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transaction (or the interest in the entity) was marketed or sold as producing capital gains treatment from a transaction described in subsection (c)(1), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44d45449-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1258/d/5/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transaction (or the interest in the entity) is a transaction (or interest) specified in regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44d4544a-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13206/a/1"},"text":"Pub. L. 103–66, title XIII, § 13206(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/462"},"text":"107 Stat. 462","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s888/c/2"},"text":"Pub. L. 108–357, title VIII, § 888(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1643"},"text":"118 Stat. 1643","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/176/B"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(176)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1192"},"text":"132 Stat. 1192","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44d4544b-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44d4544c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44d4544d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (d)(5)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" substituted “section 461(k)(4)” for “section 464(e)(2)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":" struck out “; except that the term ‘personal property’ shall include stock” before period at end."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44d4544e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44d4544f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":" applicable to positions established on or after "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/s888/e"},"text":"section 888(e) of Pub. L. 108–357","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s246"},"text":"section 246 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id44d45450-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13206/a/3"},"text":"Pub. L. 103–66, title XIII, § 13206(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/465"},"text":"107 Stat. 465","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1703/n/11"},"text":"Pub. L. 104–188, title I, § 1703(n)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1877"},"text":"110 Stat. 1877","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/188/tI/s1703/n/11"},"text":"“The amendments made by this subsection [enacting this section] shall apply to conversion transactions entered into after ","children":[{"tag":"date","attrib":{"date":"1993-04-30"},"text":"April 30, 1993","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
