{"tag":"section","attrib":{"id":"id44db803e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1278"},"text":null,"children":[{"tag":"num","attrib":{"value":"1278"},"text":"§ 1278.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and special rules","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44db803f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1278/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44db8040-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1278/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Market discount bond","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44db8041-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1278/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), the term “market discount bond” means any bond having market discount.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44db8042-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1278/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “market discount bond” shall not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44db8043-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1278/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short-term obligations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any obligation with a fixed maturity date not exceeding 1 year from the date of issue.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44db8044-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1278/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States savings bonds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any United States savings bond.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44db8045-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1278/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Installment obligations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any installment obligation to which section 453B applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44db8046-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1278/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Section 1277 not applicable to tax-exempt obligations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of section 1277, the term “market discount bond” shall not include any tax-exempt obligation (as defined in section 1275(a)(3)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44db8047-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1278/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of bonds acquired at original issue","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44db8048-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1278/a/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this subparagraph or in regulations, the term “market discount bond” shall not include any bond acquired by the taxpayer at its original issue.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44db8049-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1278/a/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of bonds acquired for less than issue price","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Clause (i) shall not apply to any bond if—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id44db804a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1278/a/1/D/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the basis of the taxpayer in such bond is determined under section 1012, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id44ddf14b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1278/a/1/D/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such basis is less than the issue price of such bond determined under subpart A of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44ddf14c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1278/a/1/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bonds acquired in certain reorganizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Clause (i) shall not apply to any bond issued pursuant to a plan of reorganization (within the meaning of section 368(a)(1)) in exchange for another bond having market discount. Solely for purposes of section 1276, the preceding sentence shall not apply if such other bond was issued on or before ","children":[{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":" (the date of the enactment of section 1276) and if the bond issued pursuant to such plan of reorganization has the same term and the same interest rate as such other bond had."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44ddf14d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1278/a/1/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain transferred basis property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of clause (i), if the adjusted basis of any bond in the hands of the taxpayer is determined by reference to the adjusted basis of such bond in the hands of a person who acquired such bond at its original issue, such bond shall be treated as acquired by the taxpayer at its original issue.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ddf14e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1278/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Market discount","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44ddf14f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1278/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “market discount” means the excess (if any) of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id44ddf150-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1278/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the stated redemption price of the bond at maturity, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id44ddf151-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1278/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the basis of such bond immediately after its acquisition by the taxpayer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44ddf152-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1278/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination where bond has original issue discount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any bond having original issue discount, for purposes of subparagraph (A), the stated redemption price of such bond at maturity shall be treated as equal to its revised issue price.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44ddf153-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1278/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" De minimis rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the market discount is less than ¼ of 1 percent of the stated redemption price of the bond at maturity multiplied by the number of complete years to maturity (after the taxpayer acquired the bond), then the market discount shall be considered to be zero.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ddf154-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1278/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bond","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “bond” means any bond, debenture, note, certificate, or other evidence of indebtedness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ddf155-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1278/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revised issue price","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “revised issue price” means the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44ddf156-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1278/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the issue price of the bond, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44ddf157-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1278/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amount of the original issue discount includible in the gross income of all holders for periods before the acquisition of the bond by the taxpayer (determined without regard to section 1272(a)(7)) or, in the case of a tax-exempt obligation, the aggregate amount of the original issue discount which accrued in the manner provided by section 1272(a) (determined without regard to paragraph (7) thereof) during periods before the acquisition of the bond by the taxpayer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ddf158-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1278/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Original issue discount, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “original issue discount”, “stated redemption price at maturity”, and “issue price” have the respective meanings given such terms by subpart A of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44ddf159-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1278/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election to include market discount currently","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44ddf15a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1278/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the taxpayer makes an election under this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44ddf15b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1278/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 1276 and 1277 shall not apply, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44ddf15c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1278/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" market discount on any market discount bond shall be included in the gross income of the taxpayer for the taxable years to which it is attributable (as determined under the rules of subsection (b) of section 1276).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Except for purposes of sections 103, 871(a), 881, 1441, 1442, and 6049 (and such other provisions as may be specified in regulations), any amount included in gross income under subparagraph (B) shall be treated as interest for purposes of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ddf15d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1278/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of election","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An election under this subsection shall apply to all market discount bonds acquired by the taxpayer on or after the 1st day of the 1st taxable year to which such election applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ddf15e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1278/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period to which election applies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An election under this subsection shall apply to the taxable year for which it is made and for all subsequent taxable years, unless the taxpayer secures the consent of the Secretary to the revocation of such election.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ddf15f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1278/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis adjustment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The basis of any bond in the hands of the taxpayer shall be increased by the amount included in gross income pursuant to this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44ddf160-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1278/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such regulations as may be necessary to carry out the purposes of this subpart, including regulations providing proper adjustments in the case of a bond the principal of which may be paid in 2 or more payments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44ddf161-3a70-11f1-a967-d35dac11796a"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s41/a"},"text":"Pub. L. 98–369, div. A, title I, § 41(a)","children":[],"tail":", title X, § 1001(b)(24), "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/547"},"text":"98 Stat. 547","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVIII"},"text":"Pub. L. 99–514, title XVIII","children":[],"tail":", §§ 1803(a)(6), 1878(a), 1899A(32), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2793"},"text":"100 Stat. 2793","children":[],"tail":", 2903, 2960; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI"},"text":"Pub. L. 100–647, title I","children":[],"tail":", §§ 1006(u)(2), 1018(c)(2), (3), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3427"},"text":"102 Stat. 3427","children":[],"tail":", 3578; "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13206/b/2"},"text":"Pub. L. 103–66, title XIII, § 13206(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/465"},"text":"107 Stat. 465","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/181"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(181)","children":[],"tail":", (c)(1)(G), "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1193"},"text":"132 Stat. 1193","children":[],"tail":", 1205.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44ddf162-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44ddf163-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44ddf164-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/c/1/G"},"text":"Pub. L. 115–141, § 401(c)(1)(G)","children":[],"tail":", struck out “or (b)(4)” after “1272(a)(7)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/a/181"},"text":"Pub. L. 115–141, § 401(a)(181)","children":[],"tail":", substituted “871(a),” for “871(a),,” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a)(1)(B)(ii)–(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/s13206/b/2/A/i"},"text":"Pub. L. 103–66, § 13206(b)(2)(A)(i)","children":[],"tail":", redesignated cls. (iii) and (iv) as (ii) and (iii), respectively, and struck out heading and text of former cl. (ii). Text read as follows: “Any tax-exempt obligation (as defined in section 1275(a)(3)).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(C), (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/s13206/b/2/A/ii"},"text":"Pub. L. 103–66, § 13206(b)(2)(A)(ii)","children":[],"tail":", (iii), added subpar. (C) and redesignated former subpar. (C) as (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/s13206/b/2/B/ii"},"text":"Pub. L. 103–66, § 13206(b)(