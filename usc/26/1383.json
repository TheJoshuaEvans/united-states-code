{"tag":"section","attrib":{"id":"id44fa79d0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1383"},"text":null,"children":[{"tag":"num","attrib":{"value":"1383"},"text":"§ 1383.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation of tax where cooperative redeems nonqualified written notices of allocation or nonqualified per-unit retain certificates","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44fa79d1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1383/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, under section 1382(b)(2) or (4), or (c)(2)(B), a deduction is allowable to an organization for the taxable year for amounts paid in redemption of nonqualified written notices of allocation or nonqualified per-unit retain certificates, then the tax imposed by this chapter on such organization for the taxable year shall be the lesser of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44fa79d2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1383/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the tax for the taxable year computed with such deduction; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44fa79d3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1383/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an amount equal to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44fa79d4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1383/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the tax for the taxable year computed without such deduction, minus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44fa79d5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1383/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the decrease in tax under this chapter for any prior taxable year (or years) which would result solely from treating such nonqualified written notices of allocation or nonqualified per-unit retain certificates as qualified written notices of allocation or qualified per-unit retain certificates (as the case may be).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44fa79d6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1383/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44fa79d7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1383/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the decrease in tax ascertained under subsection (a)(2)(B) exceeds the tax for the taxable year (computed without the deduction described in subsection (a)) such excess shall be considered to be a payment of tax on the last day prescribed by law for the payment of tax for the taxable year, and shall be refunded or credited in the same manner as if it were an overpayment for such taxable year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44fa79d8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1383/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of determining the decrease in tax under subsection (a)(2)(B), the stated dollar amount of any nonqualified written notice of allocation or nonqualified per-unit retain certificate which is to be treated under such subsection as a qualified written notice of allocation or qualified per-unit retain certificate (as the case may be) shall be the amount paid in redemption of such written notice of allocation or per-unit retain certificate which is allowable as a deduction under section 1382(b)(2) or (4), or (c)(2)(B) for the taxable year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44fa79d9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1383/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the tax imposed by this chapter for the taxable year is the amount determined under subsection (a)(2), then the deduction described in subsection (a) shall not be taken into account for any purpose of this subtitle other than for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44fa79da-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/834/s17/a"},"text":"Pub. L. 87–834, § 17(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-16"},"text":"Oct. 16, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1047"},"text":"76 Stat. 1047","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/89/809/tII/s211/a/5"},"text":"Pub. L. 89–809, title II, § 211(a)(5)","children":[],"tail":"–(7), "},{"tag":"date","attrib":{"date":"1966-11-13"},"text":"Nov. 13, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1581"},"text":"80 Stat. 1581","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44fa79db-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44fa79dc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44fa79dd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1966—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/809/s211/a/5"},"text":"Pub. L. 89–809, § 211(a)(5)","children":[],"tail":", inserted “or nonqualified per-unit retain certificates” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/809/s211/a/6"},"text":"Pub. L. 89–809, § 211(a)(6)","children":[],"tail":", substituted “section 1382(b)(2) or (4)” for “1382(b)(2)” and inserted references to per-unit retain certificates."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/809/s211/a/7"},"text":"Pub. L. 89–809, § 211(a)(7)","children":[],"tail":", substituted “section 1382(b)(2) or (4)” for “section 1382(b)(2)” and inserted references to per-unit retain certificates."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44fa79de-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44fa79df-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1966 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/809"},"text":"Pub. L. 89–809","children":[],"tail":" applicable to per-unit retain allocations made during taxable years of an organization described in "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1381/a"},"text":"section 1381(a) of this title","children":[],"tail":" (relating to organizations to which part I of subchapter T of chapter 1 applies) beginning after "},{"tag":"date","attrib":{"date":"1966-04-30"},"text":"Apr. 30, 1966","children":[],"tail":", with respect to products delivered during such years, see "},{"tag":"ref","attrib":{"href":"/us/pl/89/809/s211/e/1"},"text":"section 211(e)(1) of Pub. L. 89–809","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1382"},"text":"section 1382 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id44fa79e0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable, except as otherwise provided, to taxable years of organizations described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1381/a"},"text":"section 1381(a) of this title","children":[],"tail":" beginning after "},{"tag":"date","attrib":{"date":"1962-12-31"},"text":"Dec. 31, 1962","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/87/834/s17/c"},"text":"section 17(c) of Pub. L. 87–834","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1381"},"text":"section 1381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
