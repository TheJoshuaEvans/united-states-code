{"tag":"section","attrib":{"id":"id473b903d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6726"},"text":null,"children":[{"tag":"num","attrib":{"value":"6726"},"text":"§ 6726.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to comply with information reporting requirements relating to qualified opportunity funds and qualified rural opportunity funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id473b903e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6726/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any person required to file a return under section 6039K fails to file a complete and correct return under such section in the time and in the manner prescribed therefor, such person shall pay a penalty of $500 for each day during which such failure continues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id473b903f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6726/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id473b9040-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6726/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The maximum penalty under this section on failures with respect to any 1 return shall not exceed $10,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id473b9041-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6726/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Large qualified opportunity funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any failure described in subsection (a) with respect to a fund the gross assets of which (determined on the last day of the taxable year) are in excess of $10,000,000, paragraph (1) shall be applied by substituting “$50,000” for “$10,000”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id473b9042-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6726/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty in cases of intentional disregard","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a failure described in subsection (a) is due to intentional disregard, then—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id473b9043-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6726/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (a) shall be applied by substituting “$2,500” for “$500”,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id473b9044-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6726/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (b)(1) shall be applied by substituting “$50,000” for “$10,000”, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id473b9045-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6726/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (b)(2) shall be applied by substituting “$250,000” for “$50,000”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id473b9046-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6726/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inflation adjustment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id473b9047-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6726/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any failure relating to a return required to be filed in a calendar year beginning after 2025, each of the dollar amounts in subsections (a), (b), and (c) shall be increased by an amount equal to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id473b9048-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6726/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such dollar amount, multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id473b9049-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6726/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost-of-living adjustment determined under section 1(f)(3) for the calendar year determined by substituting “calendar year 2024” for “calendar year 2016” in subparagraph (A)(ii) thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id473b904a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6726/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rounding","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id473b904b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6726/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the $500 dollar amount in subsection (a) and (c)(1) or the $2,500 amount in subsection (c)(1), after being increased under paragraph (1), is not a multiple of $10, such dollar amount shall be rounded to the next lowest multiple of $10.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id473b904c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6726/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Asset threshold","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the $10,000,000 dollar amount in subsection (b)(2), after being increased under paragraph (1), is not a multiple of $10,000, such dollar amount shall be rounded to the next lowest multiple of $10,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id473b904d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6726/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other dollar amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any dollar amount in subsection (b) or (c) (other than any amount to which subparagraph (A) or (B) applies), after being increased under paragraph (1), is not a multiple of $1,000, such dollar amount shall be rounded to the next lowest multiple of $1,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id473b904e-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70421/d/2/A"},"text":"Pub. L. 119–21, title VII, § 70421(d)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/230"},"text":"139 Stat. 230","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id473b904f-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id473b9050-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id473b9051-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70421/d/5"},"text":"section 70421(d)(5) of Pub. L. 119–21","children":[],"tail":", set out as an Effective Date of 2025 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6011"},"text":"section 6011 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
