{"tag":"section","attrib":{"id":"id42c57218-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s362"},"text":null,"children":[{"tag":"num","attrib":{"value":"362"},"text":"§ 362.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis to corporations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id42c57219-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s362/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property acquired by issuance of stock or as paid-in surplus","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If property was acquired by a corporation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42c5721a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s362/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in connection with a transaction to which section 351 (relating to transfer of property to corporation controlled by transferor) applies, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42c5721b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s362/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as paid-in surplus or as a contribution to capital,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then the basis shall be the same as it would be in the hands of the transferor, increased in the amount of gain recognized to the transferor on such transfer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42c5721c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s362/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers to corporations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If property was acquired by a corporation in connection with a reorganization to which this part applies, then the basis shall be the same as it would be in the hands of the transferor, increased in the amount of gain recognized to the transferor on such transfer. This subsection shall not apply if the property acquired consists of stock or securities in a corporation a party to the reorganization, unless acquired by the exchange of stock or securities of the transferee (or of a corporation which is in control of the transferee) as the consideration in whole or in part for the transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42c5721d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s362/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for certain contributions to capital","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42c5721e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s362/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property other than money","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding subsection (a)(2), if property other than money—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42c5721f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s362/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is acquired by a corporation as a contribution to capital, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42c57220-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s362/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not contributed by a shareholder as such,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then the basis of such property shall be zero.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42c57221-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s362/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Money","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding subsection (a)(2), if money—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42c57222-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s362/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is received by a corporation as a contribution to capital, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42c57223-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s362/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not contributed by a shareholder as such,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then the basis of any property acquired with such money during the 12-month period beginning on the day the contribution is received shall be reduced by the amount of such contribution. The excess (if any) of the amount of such contribution over the amount of the reduction under the preceding sentence shall be applied to the reduction (as of the last day of the period specified in the preceding sentence) of the basis of any other property held by the taxpayer. The particular properties to which the reductions required by this paragraph shall be allocated shall be determined under regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42c57224-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s362/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on basis increase attributable to assumption of liability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42c57225-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s362/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In no event shall the basis of any property be increased under subsection (a) or (b) above the fair market value of such property (determined without regard to section 7701(g)) by reason of any gain recognized to the transferor as a result of the assumption of a liability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42c57226-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s362/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of gain not subject to tax","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in regulations, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42c57227-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s362/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gain is recognized to the transferor as a result of an assumption of a nonrecourse liability by a transferee which is also secured by assets not transferred to such transferee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42c57228-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s362/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no person is subject to tax under this title on such gain,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then, for purposes of determining basis under subsections (a) and (b), the amount of gain recognized by the transferor as a result of the assumption of the liability shall be determined as if the liability assumed by the transferee equaled such transferee’s ratable portion of such liability determined on the basis of the relative fair market values (determined without regard to section 7701(g)) of all of the assets subject to such liability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42c57229-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s362/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on built-in losses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42c5722a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s362/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on importation of built-in losses","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42c5722b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s362/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If in any transaction described in subsection (a) or (b) there would (but for this subsection) be an importation of a net built-in loss, the basis of each property described in subparagraph (B) which is acquired in such transaction shall (notwithstanding subsections (a) and (b)) be its fair market value immediately after such transaction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42c5722c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s362/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subparagraph (A), property is described in this subparagraph if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id42c5722d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s362/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gain or loss with respect to such property is not subject to tax under this subtitle in the hands of the transferor immediately before the transfer, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id42c5722e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s362/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gain or loss with respect to such property is subject to such tax in the hands of the transferee immediately after such transfer.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"In any case in which the transferor is a partnership, the preceding sentence shall be applied by treating each partner in such partnership as holding such partner’s proportionate share of the property of such partnership.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42c5722f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s362/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Importation of net built-in loss","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A), there is an importation of a net built-in loss in a transaction if the transferee’s aggregate adjusted bases of property described in subparagraph (B) which is transferred in such transaction would (but for this paragraph) exceed the fair market value of such property immediately after such transaction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42c57230-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s362/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on transfer of built-in losses in section 351 transactions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42c57231-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s362/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id42c57232-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s362/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" property is transferred by a transferor in any transaction which is described in subsection (a) and which is not described in paragraph (1) of this subsection, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id42c57233-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s362/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transferee’s aggregate adjusted bases of such property so transferred would (but for this paragraph) exceed the fair market value of such property immediately after such transaction,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then, notwithstanding subsection (a), the transferee’s aggregate adjusted bases of the property so transferred shall not exceed the fair market value of such property immediately after such transaction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42c57234-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s362/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of basis reduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The aggregate reduction in basis by reason of subparagraph (A) shall be allocated among the property so transferred in proportion to their respective built-in losses immediately before the transaction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42c57235-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s362/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election to apply limitation to transferor’s stock basis","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id42c57236-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s362/e/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the transferor and transferee of a transaction described in subparagraph (A) both elect the application of this subparagraph—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id42c57237-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s362/e/2/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subparagraph (A) shall not apply, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id42c57238-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s362/e/2/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transferor’s basis in the stock received for property to which subparagraph (A) does not apply by reason of the election shall not exceed its fair market value immediately after the transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id42c57239-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s362/e/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any election under clause (i) shall be made at such time and in such form and manner as the Secretary may prescribe, and, once made, shall be irrevocable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id42c5723a-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/118"},"text":"68A Stat. 118","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/621/s2/b"},"text":"Pub. L. 90–621, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1311"},"text":"82 Stat. 1311","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", title XXI, § 2120(b), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":", 1913; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVIII/s824/b"},"text":"Pub. L. 99–514, title VIII, § 824(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2374"},"text":"100 Stat. 2374","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/36/tIII/s3001/b/2"},"text":"Pub. L. 106–36, title III, § 3001(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-06-25"},"text":"June 25, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/182"},"text":"113 Stat. 182","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s836/a"},"text":"Pub. L. 108–357, title VIII, § 836(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1594"},"text":"118 Stat. 1594","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/135/tIV/s403/dd/2"},"text":"Pub. L. 109–135, title IV, § 403(dd)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-21"},"text":"Dec. 21, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2631"},"text":"119 Stat. 2631","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dA/tII/s221/a/51"},"text":"Pub. L. 113–295, div. A, title II, § 221(a)(51)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4045"},"text":"128 Stat. 4045","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/67"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(67)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1187"},"text":"132 Stat. 1187","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id42c5723b-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id42c5723c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id42c5723d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" struck out comma after “acquired” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" struck out “on or after "},{"tag":"date","attrib":{"date":"1954-06-22"},"text":"June 22, 1954","children":[],"tail":"” after “If property was acquired” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(A), (2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" struck out “, on or after "},{"tag":"date","attrib":{"date":"1954-06-22"},"text":"June 22, 1954","children":[],"tail":",” after “by a corporation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (e)(2)(C)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/135"},"text":"Pub. L. 109–135","children":[],"tail":" reenacted heading without change and amended text generally. Prior to amendment, text read as follows: “An election under clause (i) shall be included with the return of tax for the taxable year in which the transaction occurred, shall be in such form and manner as the Secretary may prescribe, and, once made, shall be irrevocable.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/36"},"text":"Pub. L. 106–36","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" struck out par. (3) relating to exceptions for contributions in aid of construction."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s2120/b"},"text":"Pub. L. 94–455, § 2120(b)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"ta