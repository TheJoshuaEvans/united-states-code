{"tag":"section","attrib":{"id":"id44f34ec2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1371"},"text":null,"children":[{"tag":"num","attrib":{"value":"1371"},"text":"§ 1371.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with subchapter C","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44f34ec3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1371/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of subchapter C rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this title, and except to the extent inconsistent with this subchapter, subchapter C shall apply to an S corporation and its shareholders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44f34ec4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1371/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No carryover between C year and S year","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44f34ec5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1371/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" From C year to S year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No carryforward, and no carryback, arising for a taxable year for which a corporation is a C corporation may be carried to a taxable year for which such corporation is an S corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44f5bec6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1371/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No carryover from S year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No carryforward, and no carryback, shall arise at the corporate level for a taxable year for which a corporation is an S corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44f5bec7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1371/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of S year as elapsed year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in paragraphs (1) and (2) shall prevent treating a taxable year for which a corporation is an S corporation as a taxable year for purposes of determining the number of taxable years to which an item may be carried back or carried forward.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44f5bec8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1371/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Earnings and profits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44f5bec9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1371/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraphs (2) and (3) and subsection (d)(3), no adjustment shall be made to the earnings and profits of an S corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44f5beca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1371/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustments for redemptions, liquidations, reorganizations, divisives, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any transaction involving the application of subchapter C to any S corporation, proper adjustment to any accumulated earnings and profits of the corporation shall be made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44f5becb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1371/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustments in case of distributions treated as dividends under section 1368(c)(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply with respect to that portion of a distribution which is treated as a dividend under section 1368(c)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44f5becc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1371/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with investment credit recapture","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44f5becd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1371/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No recapture by reason of election","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any election under section 1362 shall be treated as a mere change in the form of conducting a trade or business for purposes of the second sentence of section 50(a)(6).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44f5bece-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1371/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corporation continues to be liable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding an election under section 1362, an S corporation shall continue to be liable for any increase in tax under section 49(b) or 50(a) attributable to credits allowed for taxable years for which such corporation was not an S corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44f5becf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1371/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment to earnings and profits for amount of recapture","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) of subsection (c) shall not apply to any increase in tax under section 49(b) or 50(a) for which the S corporation is liable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44f5bed0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1371/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cash distributions during post-termination transition period","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44f5bed1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1371/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any distribution of money by a corporation with respect to its stock during a post-termination transition period shall be applied against and reduce the adjusted basis of the stock, to the extent that the amount of the distribution does not exceed the accumulated adjustments account (within the meaning of section 1368(e)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44f5bed2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1371/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election to distribute earnings first","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An S corporation may elect to have paragraph (1) not apply to all distributions made during a post-termination transition period described in section 1377(b)(1)(A). Such election shall not be effective unless all shareholders of the S corporation to whom distributions are made by the S corporation during such post-termination transition period consent to such election.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44f5bed3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1371/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cash distributions following post-termination transition period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a distribution of money by an eligible terminated S corporation (as defined in section 481(d)) after the post-termination transition period, the accumulated adjustments account shall be allocated to such distribution, and the distribution shall be chargeable to accumulated earnings and profits, in the same ratio as the amount of such accumulated adjustments account bears to the amount of such accumulated earnings and profits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44f5bed4-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/354/s2"},"text":"Pub. L. 97–354, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-19"},"text":"Oct. 19, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1681"},"text":"96 Stat. 1681","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tVII/s721/e"},"text":"Pub. L. 98–369, div. A, title VII, § 721(e)","children":[],"tail":", ("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"), (x)(3), "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/967"},"text":"98 Stat. 967","children":[],"tail":", 970, 971; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVIII/s1899A/33"},"text":"Pub. L. 99–514, title XVIII, § 1899A(33)","children":[],"tail":", (34), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2960"},"text":"100 Stat. 2960","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11813/b/23"},"text":"Pub. L. 101–508, title XI, § 11813(b)(23)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-555"},"text":"104 Stat. 1388–555","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1310"},"text":"Pub. L. 104–188, title I, § 1310","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1784"},"text":"110 Stat. 1784","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13543/b"},"text":"Pub. L. 115–97, title I, § 13543(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2155"},"text":"131 Stat. 2155","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dA/s107/b/3/C"},"text":"Pub. L. 117–167, div. A, § 107(b)(3)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1398"},"text":"136 Stat. 1398","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70513/b/3/B/i"},"text":"Pub. L. 119–21, title VII, § 70513(b)(3)(B)(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/272"},"text":"139 Stat. 272","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44f5bed5-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44f5bed6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id44f5bed7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1371, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/866/tI/s64/a"},"text":"Pub. L. 85–866, title I, § 64(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1650"},"text":"72 Stat. 1650","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/86/376/s2/a"},"text":"Pub. L. 86–376, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-23"},"text":"Sept. 23, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/699"},"text":"73 Stat. 699","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/272/tII/s233/a"},"text":"Pub. L. 88–272, title II, § 233(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-02-26"},"text":"Feb. 26, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/112"},"text":"78 Stat. 112","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tIX/s902/a/1"},"text":"Pub. L. 94–455, title IX, § 902(a)(1)","children":[],"tail":", (2), (c)(1), (2), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1608"},"text":"90 Stat. 1608","children":[],"tail":", 1609; "},{"tag":"ref","attrib":{"href":"/us/pl/95/600/tIII"},"text":"Pub. L. 95–600, title III","children":[],"tail":", §§ 341, 342, title VII, § 701(y)(1), "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2843"},"text":"92 Stat. 2843","children":[],"tail":", 2921; "},{"tag":"ref","attrib":{"href":"/us/pl/96/589/s5/d"},"text":"Pub. L. 96–589, § 5(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-24"},"text":"Dec. 24, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3406"},"text":"94 Stat. 3406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/tII"},"text":"Pub. L. 97–34, title II","children":[],"tail":", §§ 233(a), 234(a), (b), "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/250"},"text":"95 Stat. 250","children":[],"tail":", 251; "},{"tag":"ref","attrib":{"href":"/us/pl/97/448/tI/s102/i/1"},"text":"Pub. L. 97–448, title I, § 102(i)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2372"},"text":"96 Stat. 2372","children":[],"tail":", related to definitions applicable to election of small business corporations as to taxable status, prior to the general revision of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/97/354/s2"},"text":"section 2 of Pub. L. 97–354","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44f5bed8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" substituted “section 50(a)(6)” for “section 50(a)(5)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167"},"text":"Pub. L. 117–167","children":[],"tail":" substituted “section 50(a)(5)” for “section 50(a)(4)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188"},"text":"Pub. L. 104–188","children":[],"tail":" reenacted heading without change and amended text generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—Except as otherwise provided in this title, and except to the extent inconsistent with this subchapter, subchapter C shall apply to an S corporation and its shareholders."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) S ","children":[{"tag":"inline","attrib":{},"text":"corporation as shareholder treated like individual","children":[],"tail":".—For purposes of subchapter C, an S corporation in its capacity as a shareholder of another corporation shall be treated as an individual.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s11813/b/23/A"},"text":"Pub. L. 101–508, § 11813(b)(23)(A)","children":[],"tail":", substituted “section 50(a)(4)” for “section 47(b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s11813/b/23/B"},"text":"Pub. L. 101–508, § 11813(b)(23)(B)","children":[],"tail":", substituted “section 49(b) or 50(a)” for “section 47”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1899A/33"},"text":"Pub. L. 99–514, § 1899A(33)","children":[],"tail":", inserted “(within the meaning of section 1368(e))”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1899A/34"},"text":"Pub. L. 99–514, § 1899A(34)","children":[],"tail":", struck out “(within the meaning of section 1368(e))” after “to such election”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s621/e/2"},"text":"Pub. L. 98–369, § 621(e)(2)","children":[],"tail":", substituted “paragraphs (2) and (3) and subsection (d)(3)” for “paragraphs (2) and (3)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s721/e/1"},"text":"Pub. L. 98–369, § 721(e)(1)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s721"},"text":"Pub. L. 98–369, § 721","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"), amended subsec. (e) generally, designating existing provisions as par. (1) and adding par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s721/x/3"},"text":"Pub. L. 98–369, § 721(x)(3)","children":[],"tail":", inserted “(within the meaning of section 1368(e))”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44f5bed9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44f5beda-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70513/g/1"},"text":"section 70513(g)(1) of Pub. L. 119–21","children":[],"tail":", set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s48"},"text":"section 48 of this title","children":[],"