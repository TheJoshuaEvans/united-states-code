{"tag":"section","attrib":{"id":"id42175796-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s186"},"text":null,"children":[{"tag":"num","attrib":{"value":"186"},"text":"§ 186.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recoveries of damages for antitrust violations, etc.","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id42175797-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s186/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowance of deduction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a compensatory amount which is included in gross income is received or accrued during the taxable year for a compensable injury, there shall be allowed as a deduction for the taxable year an amount equal to the lesser of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42175798-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s186/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of such compensatory amount, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42175799-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s186/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the unrecovered losses sustained as a result of such compensable injury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4217579a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s186/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensable injury","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “compensable injury” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4217579b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s186/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" injuries sustained as a result of an infringement of a patent issued by the United States,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4217579c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s186/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" injuries sustained as a result of a breach of contract or a breach of fiduciary duty or relationship, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4217579d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s186/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" injuries sustained in business, or to property, by reason of any conduct forbidden in the antitrust laws for which a civil action may be brought under section 4 of the Act entitled “An Act to supplement existing laws against unlawful restraints and monopolies, and for other purposes”, approved ","children":[{"tag":"date","attrib":{"date":"1914-10-15"},"text":"October 15, 1914","children":[],"tail":" (commonly known as the Clayton Act)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4217579e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s186/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensatory amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “compensatory amount” means the amount received or accrued during the taxable year as damages as a result of an award in, or in settlement of, a civil action for recovery for a compensable injury, reduced by any amounts paid or incurred in the taxable year in securing such award or settlement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4217579f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s186/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unrecovered losses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id421757a0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s186/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the amount of any unrecovered loss sustained as a result of any compensable injury is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id421757a1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s186/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sum of the amount of the net operating losses (as determined under section 172) for each taxable year in whole or in part within the injury period, to the extent that such net operating losses are attributable to such compensable injury, reduced by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id421757a2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s186/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the sum of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id421757a3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s186/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the net operating losses described in subparagraph (A) which were allowed for any prior taxable year as a deduction under section 172 as a net operating loss carryback or carryover to such taxable year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id421757a4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s186/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amounts allowed as a deduction under subsection (a) for any prior taxable year for prior recoveries of compensatory amounts for such compensable injury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id421757a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s186/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Injury period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), the injury period is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id421757a6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s186/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to any infringement of a patent, the period in which such infringement occurred,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id421757a7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s186/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a breach of contract or breach of fiduciary duty or relationship, the period during which amounts would have been received or accrued but for the breach of contract or breach of fiduciary duty or relationship, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id421757a8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s186/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to injuries sustained by reason of any conduct forbidden in the antitrust laws, the period in which such injuries were sustained.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id421757a9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s186/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Net operating losses attributable to compensable injuries","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id421757aa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s186/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a net operating loss for any taxable year shall be treated as attributable to a compensable injury to the extent of the compensable injury sustained during such taxable year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id421757ab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s186/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if only a portion of a net operating loss for any taxable year is attributable to a compensable injury, such portion shall (in applying section 172 for purposes of this section) be considered to be a separate net operating loss for such year to be applied after the other portion of such net operating loss.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id421757ac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s186/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on net operating loss carryovers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If for the taxable year in which a compensatory amount is received or accrued any portion of a net operating loss carryover to such year is attributable to the compensable injury for which such amount is received or accrued, such portion of such net operating loss carryover shall be reduced by an amount equal to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id421757ad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s186/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deduction allowed under subsection (a) with respect to such compensatory amount, reduced by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id421757ae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s186/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any portion of the unrecovered losses sustained as a result of the compensable injury with respect to which the period for carryover under section 172 has expired.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id421757af-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172/tIX/s904/a"},"text":"Pub. L. 91–172, title IX, § 904(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/711"},"text":"83 Stat. 711","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id421757b0-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id421757b1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id421757b2-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 4 of the Clayton Act, referred to in subsec. (b)(3), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s15"},"text":"section 15 of Title 15","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id421757b3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id421757b4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172/tIX/s904/c"},"text":"Pub. L. 91–172, title IX, § 904(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/712"},"text":"83 Stat. 712","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/91/172/tIX/s904/c"},"text":"“The amendments made by this section [enacting this section] shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1968-12-31"},"text":"December 31, 1968","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
