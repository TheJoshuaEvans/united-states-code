{"tag":"section","attrib":{"id":"id475a8a35-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7447A"},"text":null,"children":[{"tag":"num","attrib":{"value":"7447A"},"text":"§ 7447A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retirement for special trial judges","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id475a8a36-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7447A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id475a8a37-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7447A/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any special trial judge appointed pursuant to section 7443A may retire from service as a special trial judge if the individual meets the age and service requirements set forth in the following table:","children":[{"tag":"html:table","attrib":{"width":"100%","id":"id475a8a38-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"If the special trial judge has attained age:","children":[],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"And the years of service as a special trial judge are at least:","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"65","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"66","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"14","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"67","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"13","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"68","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"12","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"69","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"11","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"70","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10.","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id475a8a39-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7447A/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Length of service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making any determination of length of service as a special trial judge there shall be included all periods (whether or not consecutive) during which an individual served as a special trial judge","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id475a8a3a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7447A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retirement upon disability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any special trial judge appointed pursuant to section 7443A who becomes permanently disabled from performing such individual’s duties shall retire from service as a special trial judge.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id475a8a3b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7447A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recalling of retired special trial judges","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any individual who has retired pursuant to subsection (a) may be called upon by the chief judge to perform such judicial duties with the Tax Court as may be requested of such individual for a period or periods specified by the chief judge, except that in the case of any such individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id475a8a3c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7447A/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate of such periods in any 1 calendar year shall not (without the consent of such individual) exceed 90 calendar days, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id475a8a3d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7447A/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such individual shall be relieved of performing such duties during any period in which illness or disability precludes the performance of such duties.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Any act, or failure to act, by an individual performing judicial duties pursuant to this subsection shall have the same force and effect as if it were the act (or failure to act) of a special trial judge. Any individual who is performing judicial duties pursuant to this subsection shall be paid the same compensation (in lieu of retired pay) and allowances for travel and other expenses as a special trial judge.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id475a8a3e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7447A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retired pay","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id475a8a3f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7447A/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any individual who retires pursuant to subsection (a) and elects under subsection (e) to receive retired pay under this subsection shall receive retired pay during any period of retirement from service as a special trial judge at a rate which bears the same ratio to the rate of the salary payable to a special trial judge during such period as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id475a8a40-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7447A/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of years such individual has served as special trial judge bears to,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id475a8a41-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7447A/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 15,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"except that the rate of such retired pay shall not be more than the rate of such salary for such period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id475a8a42-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7447A/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retirement upon disability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any individual who retires pursuant to subsection (b) and elects under subsection (e) to receive retired pay under this subsection shall receive retired pay during any period of retirement from service as a special trial judge—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id475a8a43-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7447A/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at a rate equal to the rate of the salary payable to a special trial judge during such period, if the individual had at least 10 years of service as a special trial judge before retirement, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id475a8a44-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7447A/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at a rate equal to ½ the rate described in subparagraph (A), if the individual had fewer than 10 years of service as a special trial judge before retirement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id475a8a45-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7447A/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Beginning date and payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Retired pay under this subsection shall begin to accrue on the day following the date on which the individual’s salary as a special trial judge ceases to accrue, and shall continue to accrue during the remainder of such individual’s life. Retired pay under this subsection shall be paid in the same manner as the salary of a special trial judge.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id475a8a46-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7447A/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partial years","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In computing the rate of the retired pay for an individual to whom paragraph (1) applies, any portion of the aggregate number of years such individual has served as a special trial judge which is a fractional part of 1 year shall be eliminated if it is less than 6 months, or shall be counted as a full year if it is 6 months or more.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id475a8a47-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7447A/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recalled service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In computing the rate of the retired pay for an individual to whom paragraph (1) applies, any period during which such individual performs services under subsection (c) on a substantially full-time basis shall be treated as a period during which such individual has served as a special trial judge.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id475a8a48-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7447A/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election to Receive Retired Pay","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any special trial judge may elect to receive retired pay under subsection (d). Such an election—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id475a8a49-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7447A/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be made only while an individual is a special trial judge (except that in the case of an individual who fails to be reappointed as a special trial judge, such election may be made within 60 days after such individual leaves office as a special trial judge),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id475a8a4a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7447A/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" once made, shall be irrevocable, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id475a8a4b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7447A/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be made by filing notice thereof in writing with the chief judge.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The chief judge shall transmit to the Office of Personnel Management a copy of each notice filed with the chief judge under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id475a8a4c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7447A/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other rules made applicable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rules of subsections (f), (g), (h)(2), (i), and (j), and the first sentence of subsection (h)(1), of section 7447 shall apply to a special trial judge in the same manner as a judge of the Tax Court. For purposes of the preceding sentence, any reference to the President in such subsections shall be applied as if it were a reference to the chief judge.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id475a8a4d-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dT/tVII/s702/a"},"text":"Pub. L. 117–328, div. T, title VII, § 702(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5402"},"text":"136 Stat. 5402","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id475a8a4e-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id475a8a4f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id475a8a50-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dT/tVII/s702/d"},"text":"Pub. L. 117–328, div. T, title VII, § 702(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5404"},"text":"136 Stat. 5404","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dT/tVII/s702/d"},"text":"“The amendments made by this section [enacting this section and amending sections 3121 and 7448 of this title and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s410"},"text":"section 410 of Title 42","children":[],"tail":", The Public Health and Welfare] shall take effect on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":"], except that section 7447A(e) of the Internal Revenue Code of 1986 (as added by this section) shall take effect on the date that is 180 days after such date of enactment. Special trial judges retiring on or after the date of the enactment of this Act, and before the date that is 180 days after the date of such enactment, may file an election under such section not later than 60 days after such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
