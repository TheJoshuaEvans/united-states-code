{"tag":"section","attrib":{"id":"id47abb808-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9033"},"text":null,"children":[{"tag":"num","attrib":{"value":"9033"},"text":"§ 9033.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47abb809-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9033/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive payments under section 9037, a candidate shall, in writing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47abb80a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9033/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agree to obtain and furnish to the Commission any evidence it may request of qualified campaign expenses,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47abb80b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9033/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agree to keep and furnish to the Commission any records, books, and other information it may request, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47abb80c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9033/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agree to an audit and examination by the Commission under section 9038 and to pay any amounts required to be paid under such section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47abb80d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9033/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expense limitation; declaration of intent; minimum contributions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive payments under section 9037, a candidate shall certify to the Commission that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47abb80e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9033/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the candidate and his authorized committees will not incur qualified campaign expenses in excess of the limitations on such expenses under section 9035,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47abb80f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9033/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the candidate is seeking nomination by a political party for election to the office of President of the United States,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47abb810-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9033/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the candidate has received matching contributions which in the aggregate, exceed $5,000 in contributions from residents of each of at least 20 States, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47abb811-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9033/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate of contributions certified with respect to any person under paragraph (3) does not exceed $250.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47abb812-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9033/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47abb813-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9033/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided by paragraph (2), no payment shall be made to any individual under section 9037—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47abb814-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9033/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such individual ceases to be a candidate as a result of the operation of the last sentence of section 9032(2); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47abb815-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9033/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more than 30 days after the date of the second consecutive primary election in which such individual receives less than 10 percent of the number of votes cast for all candidates of the same party for the same office in such primary election, if such individual permitted or authorized the appearance of his name on the ballot, unless such individual certifies to the Commission that he will not be an active candidate in the primary involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47abb816-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9033/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified campaign expenses; payments to Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any candidate who is ineligible under paragraph (1) to receive any payments under section 9037 shall be eligible to continue to receive payments under section 9037 to defray qualified campaign expenses incurred before the date upon which such candidate becomes ineligible under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47abb817-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9033/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Calculation of voting percentage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1)(B), if the primary elections involved are held in more than one State on the same date, a candidate shall be treated as receiving that percentage of the votes on such date which he received in the primary election conducted on such date in which he received the greatest percentage vote.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47abb818-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9033/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reestablishment of eligibility","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47abb819-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9033/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any case in which an individual is ineligible to receive payments under section 9037 as a result of the operation of paragraph (1)(A), the Commission may subsequently determine that such individual is a candidate upon a finding that such individual is actively seeking election to the office of President of the United States in more than one State. The Commission shall make such determination without requiring such individual to reestablish his eligibility to receive payments under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47abb81a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9033/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding the provisions of paragraph (1)(B), a candidate whose payments have been terminated under paragraph (1)(B) may again receive payments (including amounts he would have received but for paragraph (1)(B)) if he receives 20 percent or more of the total number of votes cast for candidates of the same party in a primary election held after the date on which the election was held which was the basis for terminating payments to him.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47abb81b-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/443/tIV/s408/c"},"text":"Pub. L. 93–443, title IV, § 408(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-15"},"text":"Oct. 15, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1299"},"text":"88 Stat. 1299","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/283/tIII"},"text":"Pub. L. 94–283, title III","children":[],"tail":", §§ 305(c), 306(b)(2), "},{"tag":"date","attrib":{"date":"1976-05-11"},"text":"May 11, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/499"},"text":"90 Stat. 499","children":[],"tail":", 500.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47abb81c-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47abb81d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id47abb81e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/283/s305/c"},"text":"Pub. L. 94–283, § 305(c)","children":[],"tail":", substituted “limitations” for “limitation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/283/s306/b/2"},"text":"Pub. L. 94–283, § 306(b)(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47abb81f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47abb820-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/283/s306/b/2"},"text":"section 306(b)(2) of Pub. L. 94–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1976-05-11"},"text":"May 11, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/283/s306/c"},"text":"section 306(c) of Pub. L. 94–283","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s9002"},"text":"section 9002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id47abb821-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1974-12-31"},"text":"Dec. 31, 1974","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/443/s410/c/1"},"text":"section 410(c)(1) of Pub. L. 93–443","children":[],"tail":", set out as an Effective Date of 1974 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s30101"},"text":"section 30101 of Title 52","children":[],"tail":", Voting and Elections."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
