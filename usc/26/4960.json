{"tag":"section","attrib":{"id":"id45f295aa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4960"},"text":null,"children":[{"tag":"num","attrib":{"value":"4960"},"text":"§ 4960.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax on excess tax-exempt organization executive compensation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45f295ab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4960/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax imposed","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is hereby imposed a tax equal to the product of the rate of tax under section 11 and the sum of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45f295ac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4960/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" so much of the remuneration paid (other than any excess parachute payment) by an applicable tax-exempt organization for the taxable year with respect to employment of any covered employee in excess of $1,000,000, plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f295ad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4960/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any excess parachute payment paid by such an organization to any covered employee.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of the preceding sentence, remuneration shall be treated as paid when there is no substantial risk of forfeiture (within the meaning of section 457(f)(3)(B)) of the rights to such remuneration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45f295ae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4960/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability for tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The employer shall be liable for the tax imposed under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45f295af-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4960/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45f295b0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4960/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable tax-exempt organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “applicable tax-exempt organization” means any organization which for the taxable year—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45f295b1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4960/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is exempt from taxation under section 501(a),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f295b2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4960/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a farmers’ cooperative organization described in section 521(b)(1),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f295b3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4960/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has income excluded from taxation under section 115(1), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f295b4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4960/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a political organization described in section 527(e)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f295b5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4960/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered employee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “covered employee” means any employee of an applicable tax-exempt organization (or any predecessor of such an organization) and any former employee of such an organization (or predecessor) who was such an employee during any taxable year beginning after ","children":[{"tag":"date","attrib":{"date":"2016-12-31"},"text":"December 31, 2016","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f295b6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4960/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remuneration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45f295b7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4960/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “remuneration” means wages (as defined in section 3401(a)), except that such term shall not include any designated Roth contribution (as defined in section 402A(c)) and shall include amounts required to be included in gross income under section 457(f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f295b8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4960/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for remuneration for medical services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “remuneration” shall not include the portion of any remuneration paid to a licensed medical professional (including a veterinarian) which is for the performance of medical or veterinary services by such professional.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f295b9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4960/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remuneration from related organizations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45f295ba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4960/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Remuneration of a covered employee by an applicable tax-exempt organization shall include any remuneration paid with respect to employment of such employee by any related person or governmental entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f295bb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4960/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Related organizations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person or governmental entity shall be treated as related to an applicable tax-exempt organization if such person or governmental entity—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45f295bc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4960/c/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" controls, or is controlled by, the organization,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45f295bd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4960/c/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is controlled by one or more persons which control the organization,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45f295be-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4960/c/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a supported organization (as defined in section 509(f)(3)) during the taxable year with respect to the organization,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45f295bf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4960/c/4/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a supporting organization described in section 509(a)(3) during the taxable year with respect to the organization, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45f295c0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4960/c/4/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an organization which is a voluntary employees’ beneficiary association described in section 501(c)(9), establishes, maintains, or makes contributions to such voluntary employees’ beneficiary association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f295c1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4960/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability for tax","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any case in which remuneration from more than one employer is taken into account under this paragraph in determining the tax imposed by subsection (a), each such employer shall be liable for such tax in an amount which bears the same ratio to the total tax determined under subsection (a) with respect to such remuneration as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45f295c2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4960/c/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of remuneration paid by such employer with respect to such employee, bears to","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45f295c3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4960/c/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of remuneration paid by all such employers to such employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f295c4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4960/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excess parachute payment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of determining the tax imposed by subsection (a)(2)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45f295c5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4960/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “excess parachute payment” means an amount equal to the excess of any parachute payment over the portion of the base amount allocated to such payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f295c6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4960/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parachute payment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “parachute payment” means any payment in the nature of compensation to (or for the benefit of) a covered employee if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45f295c7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4960/c/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such payment is contingent on such employee’s separation from employment with the employer, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45f295c8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4960/c/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate present value of the payments in the nature of compensation to (or for the benefit of) such individual which are contingent on such separation equals or exceeds an amount equal to 3 times the base amount.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f295c9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4960/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such term does not include any payment—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45f295ca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4960/c/5/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" described in section 280G(b)(6) (relating to exemption for payments under qualified plans),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45f295cb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4960/c/5/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made under or to an annuity contract described in section 403(b) or a plan described in section 457(b),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45f295cc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4960/c/5/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a licensed medical professional (including a veterinarian) to the extent that such payment is for the performance of medical or veterinary services by such professional, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45f295cd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4960/c/5/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to an individual who is not a highly compensated employee as defined in section 414(q).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f295ce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4960/c/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Base amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rules similar to the rules of 280G(b)(3) shall apply for purposes of determining the base amount.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45f295cf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4960/c/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property transfers; present value","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rules similar to the rules of paragraphs (3) and (4) of section 280G(d) shall apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45f295d0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4960/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with deduction limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Remuneration the deduction for which is not allowed by reason of section 162(m) shall not be taken into account for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45f295d1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4960/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such regulations as may be necessary to prevent avoidance of the tax under this section, including regulations to prevent avoidance of such tax through the performance of services other than as an employee or by providing compensation through a pass-through or other entity to avoid such tax.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45f295d2-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13602/a"},"text":"Pub. L. 115–97, title I, § 13602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2157"},"text":"131 Stat. 2157","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70416/a"},"text":"Pub. L. 119–21, title VII, § 70416(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/223"},"text":"139 Stat. 223","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45f295d3-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45f295d4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45f295d5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" amended par. (2) generally. Prior to amendment, text read as follows: “For purposes of this section, the term ‘covered employee’ means any employee (including any former employee) of an applicable tax-exempt organization if the employee—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) is one of the 5 highest compensated employees of the organization for the taxable year, or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) was a covered employee of the organization (or any predecessor) for any preceding taxable year beginning after ","children":[{"tag":"date","attrib":{"date":"2016-12-31"},"text":"December 31, 2016","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45f295d6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45f295d7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70416/b"},"text":"Pub. L. 119–21, title VII, § 70416(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/223"},"text":"139 Stat. 223","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/21/tVII/s70416/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2025-12-31"},"text":"December 31, 2025","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id45f295d8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13602/c"},"text":"Pub. L. 115–97, title I, § 13602(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2159"},"text":"131 Stat. 2159","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/97/tI/s13602/c"},"text":"“The amendments made by this section [enacting this section] shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2017-12-31"},"text":"December 31, 2017","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
