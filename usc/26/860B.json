{"tag":"section","attrib":{"id":"id443973f5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860B"},"text":null,"children":[{"tag":"num","attrib":{"value":"860B"},"text":"§ 860B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxation of holders of regular interests","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id443973f6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860B/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining the tax under this chapter of any holder of a regular interest in a REMIC, such interest (if not otherwise a debt instrument) shall be treated as a debt instrument.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id443973f7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860B/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Holders must use accrual method","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amounts includible in gross income with respect to any regular interest in a REMIC shall be determined under the accrual method of accounting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id443973f8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860B/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Portion of gain treated as ordinary income","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Gain on the disposition of a regular interest shall be treated as ordinary income to the extent such gain does not exceed the excess (if any) of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id443973f9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860B/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount which would have been includible in the gross income of the taxpayer with respect to such interest if the yield on such interest were 110 percent of the applicable Federal rate (as defined in section 1274(d) without regard to paragraph (2) thereof) as of the beginning of the taxpayer’s holding period, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id443973fa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860B/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount actually includible in gross income with respect to such interest by the taxpayer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id443973fb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s860B/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For special rules in determining inclusion of original issue discount on regular interests, see section 1272(a)(6).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id443973fc-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVI/s671/a"},"text":"Pub. L. 99–514, title VI, § 671(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2309"},"text":"100 Stat. 2309","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
