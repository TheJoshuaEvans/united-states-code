n":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4065"},"text":"128 Stat. 4065","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/b/40"},"text":"Pub. L. 115–141, div. U, title IV, § 401(b)(40)","children":[],"tail":", (41), "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1204"},"text":"132 Stat. 1204","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45ad4fa6-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45ad4fa7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id45ad4fa8-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 206 of the Inland Waterways Revenue Act of 1978, referred to in subsec. (d)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/502/s206"},"text":"section 206 of Pub. L. 95–502","children":[],"tail":", title II, "},{"tag":"date","attrib":{"date":"1978-10-21"},"text":"Oct. 21, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1700"},"text":"92 Stat. 1700","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1804"},"text":"section 1804 of Title 33","children":[],"tail":", Navigation and Navigable Waters."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id45ad4fa9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4042, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/478"},"text":"68A Stat. 478","children":[],"tail":", provided a cross reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4222"},"text":"section 4222 of this title","children":[],"tail":" for exemption from tax where special motor fuels are sold for use for certain vessels, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1904/a/1/D"},"text":"Pub. L. 94–455, title XIX, § 1904(a)(1)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1811"},"text":"90 Stat. 1811","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45ad4faa-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/b/40"},"text":"Pub. L. 115–141, § 401(b)(40)","children":[],"tail":", struck out subpar. (C) which read as follows: “the deficit reduction rate.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/b/41"},"text":"Pub. L. 115–141, § 401(b)(41)","children":[],"tail":", struck out subpar. (C) which read as follows: “The deficit reduction rate is—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) 3.3 cents per gallon after ","children":[{"tag":"date","attrib":{"date":"2004-12-31"},"text":"December 31, 2004","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"2005-07-01"},"text":"July 1, 2005","children":[],"tail":","}],"tail":"\