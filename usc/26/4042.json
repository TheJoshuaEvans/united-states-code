{"tag":"section","attrib":{"id":"id45ad4f8e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4042"},"text":null,"children":[{"tag":"num","attrib":{"value":"4042"},"text":"§ 4042.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax on fuel used in commercial transportation on inland waterways","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45ad4f8f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4042/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby imposed a tax on any liquid used during any calendar quarter by any person as a fuel in a vessel in commercial waterway transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45ad4f90-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4042/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of tax","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45ad4f91-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4042/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The rate of the tax imposed by subsection (a) is the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45ad4f92-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4042/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Inland Waterways Trust Fund financing rate, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45ad4f93-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4042/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Leaking Underground Storage Tank Trust Fund financing rate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45ad4f94-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4042/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rates","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45ad4f95-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4042/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Inland Waterways Trust Fund financing rate is 29 cents per gallon.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45ad4f96-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4042/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Leaking Underground Storage Tank Trust Fund financing rate is 0.1 cent per gallon.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45ad4f97-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4042/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for fuel on which Leaking Underground Storage Tank Trust Fund financing rate separately imposed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Leaking Underground Storage Tank Trust Fund financing rate under paragraph (2)(B) shall not apply to the use of any fuel if tax was imposed with respect to such fuel under section 4041(d) or 4081 at the Leaking Underground Storage Tank Trust Fund financing rate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45ad4f98-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4042/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of Leaking Underground Storage Tank Trust Fund financing rate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Leaking Underground Storage Tank Trust Fund financing rate under paragraph (2)(B) shall not apply during any period during which the Leaking Underground Storage Tank Trust Fund financing rate under section 4081 does not apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45ad4f99-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4042/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemptions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45ad4f9a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4042/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deep-draft ocean-going vessels","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tax imposed by subsection (a) shall not apply with respect to any vessel designed primarily for use on the high seas which has a draft of more than 12 feet.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45ad4f9b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4042/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Passenger vessels","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tax imposed by subsection (a) shall not apply with respect to any vessel used primarily for the transportation of persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45ad4f9c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4042/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use by State or local government in transporting property in a state or local business","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subparagraph (B) of subsection (d)(1) shall not apply with respect to use by a State or political subdivision thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45ad4f9d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4042/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use in moving lash and seabee ocean-going barges","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tax imposed by subsection (a) shall not apply with respect to use for movement by tug of exclusively LASH (Lighter-aboard-ship) and SEABEE ocean-going barges released by their ocean-going carriers solely to pick up or deliver international cargoes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45ad4f9e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4042/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45ad4f9f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4042/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercial waterway transportation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “commercial waterway transportation” means any use of a vessel on any inland or intracoastal waterway of the United States—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45ad4fa0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4042/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the business of transporting property for compensation or hire, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45ad4fa1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4042/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in transporting property in the business of the owner, lessee, or operator of the vessel (other than fish or other aquatic animal life caught on the voyage).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45ad4fa2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4042/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inland or intracoastal waterway of the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “inland or intracoastal waterway of the United States” means any inland or intracoastal waterway of the United States which is described in section 206 of the Inland Waterways Revenue Act of 1978.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45ad4fa3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4042/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person” includes the United States, a State, a political subdivision of a State, or any agency or instrumentality of any of the foregoing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45ad4fa4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4042/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Date for filing return","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The date for filing the return of the tax imposed by this section for any calendar quarter shall be the last day of the first month following such quarter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45ad4fa5-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/502/tII/s202/a"},"text":"Pub. L. 95–502, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-21"},"text":"Oct. 21, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1696"},"text":"92 Stat. 1696","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/499/tV/s521/a/3"},"text":"Pub. L. 99–499, title V, § 521