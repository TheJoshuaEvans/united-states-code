{"tag":"section","attrib":{"id":"id417524a7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s131"},"text":null,"children":[{"tag":"num","attrib":{"value":"131"},"text":"§ 131.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain foster care payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id417524a8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s131/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Gross income shall not include amounts received by a foster care provider during the taxable year as qualified foster care payments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id417794a9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s131/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified foster care payment defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id417794aa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s131/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified foster care payment” means any payment made pursuant to a foster care program of a State or political subdivision thereof—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id417794ab-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s131/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" which is paid by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id417794ac-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s131/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State or political subdivision thereof, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id417794ad-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s131/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a qualified foster care placement agency, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id417794ae-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s131/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" which is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id417794af-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s131/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paid to the foster care provider for caring for a qualified foster individual in the foster care provider’s home, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id417794b0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s131/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a difficulty of care payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id417794b1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s131/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified foster individual","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified foster individual” means any individual who is living in a foster family home in which such individual was placed by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id417794b2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s131/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agency of a State or political subdivision thereof, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id417794b3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s131/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a qualified foster care placement agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id417794b4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s131/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified foster care placement agency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified foster care placement agency” means any placement agency which is licensed or certified by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id417794b5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s131/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State or political subdivision thereof, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id417794b6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s131/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity designated by a State or political subdivision thereof,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"for the foster care program of such State or political subdivision to make foster care payments to providers of foster care.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id417794b7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s131/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation based on number of individuals over the age of 18","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any foster home in which there is a qualified foster care individual who has attained age 19, foster care payments (other than difficulty of care payments) for any period to which such payments relate shall not be excludable from gross income under subsection (a) to the extent such payments are made for more than 5 such qualified foster individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id417794b8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s131/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Difficulty of care payments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id417794b9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s131/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Difficulty of care payments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “difficulty of care payments” means payments to individuals which are not described in subsection (b)(1)(B)(i), and which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id417794ba-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s131/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" are compensation for providing the additional care of a qualified foster individual which is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id417794bb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s131/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" required by reason of a physical, mental, or emotional handicap of such individual with respect to which the State has determined that there is a need for additional compensation, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id417794bc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s131/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provided in the home of the foster care provider, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id417794bd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s131/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are designated by the payor as compensation described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id417794be-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s131/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation based on number of individuals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any foster home, difficulty of care payments for any period to which such payments relate shall not be excludable from gross income under subsection (a) to the extent such payments are made for more than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id417794bf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s131/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10 qualified foster individuals who have not attained age 19, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id417794c0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s131/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 5 qualified foster individuals not described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id417794c1-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/473/tI/s102/a"},"text":"Pub. L. 97–473, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-14"},"text":"Jan. 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2606"},"text":"96 Stat. 2606","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVII/s1707/a"},"text":"Pub. L. 99–514, title XVII, § 1707(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2781"},"text":"100 Stat. 2781","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/147/tIV/s404/a"},"text":"Pub. L. 107–147, title IV, § 404(a)","children":[],"tail":"–(c), "},{"tag":"date","attrib":{"date":"2002-03-09"},"text":"Mar. 9, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/41"},"text":"116 Stat. 41","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id417794c2-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id417794c3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id417794c4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 131 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s140"},"text":"section 140 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id417794c5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/147/s404/a"},"text":"Pub. L. 107–147, § 404(a)","children":[],"tail":", amended provisions preceding subpar. (B) generally. Prior to amendment, text of such provisions read as follows: “The term ‘qualified foster care payment’ means any amount—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) which is paid by a State or political subdivision thereof or by a placement agency which is described in section 501(c)(3) and exempt from tax under section 501(a), and”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/147/s404/b"},"text":"Pub. L. 107–147, § 404(b)","children":[],"tail":", amended subpar. (B) generally. Prior to amendment, subpar. (B) read as follows: “in the case of an individual who has not attained age 19, an organization which is licensed by a State (or political subdivision thereof) as a placement agency and which is described in section 501(c)(3) and exempt from tax under section 501(a).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/147/s404/c"},"text":"Pub. L. 107–147, § 404(c)","children":[],"tail":", added par. (3) and redesignated former par. (3) as (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows: “Gross income shall not include amounts received by a foster parent during the taxable year as qualified foster care payments.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" amended subsec. (b) generally. Prior to amendment, par. (1) “In general” read as follows: “The term ‘qualified foster care payment’ means any amount—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) which is paid by a State or political subdivision thereof or by a child-placing agency which is described in section 501(c)(3) and exempt from tax under section 501(a), and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) which is—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) paid to reimburse the foster parent for the expenses of caring for a qualified foster child in the foster parent’s home, or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) a difficulty of care payment.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"and par. (2) “Qualified foster child” read as follows: “The term ‘qualified foster child’ means any individual who—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) has not attained age 19, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) is living in a foster family home in which such individual was placed by—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) an agency of a State or political subdivision thereof, or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) an organization which is licensed by a State (or political subdivision thereof) as a child-placing agency and which is described in section 501(c)(3) and exempt from tax under section 501(a).”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", in amending subsec. (c) generally, in par. (1)(A), substituted references to “qualified foster individual”, “such individual”, and “foster care provider” for references to “qualified foster child”, “such child”, and “foster parent”, respectively, and in par. (2) substituted “more than (A) 10 qualified foster individuals who have not attained age 19, and (B) 5 qualified foster individuals not described in subparagraph (A)” for “more than 10 qualified foster children”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id417794c6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id417794c7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/147/tIV/s404/d"},"text":"Pub. L. 107–147, title IV, § 404(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-03-09"},"text":"Mar. 9, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/42"},"text":"116 Stat. 42","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/147/tIV/s404/d"},"text":"“The amendments made by this section [amending this section] shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2001-12-31"},"text":"December 31, 2001","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id417794c8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVII/s1707/b"},"text":"Pub. L. 99–514, title XVII, § 1707(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2782"},"text":"100 Stat. 2782","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/tXVII/s1707/b"},"text":"“The amendment made by this section [amending this section] shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1985-12-31"},"text":"December 31, 1985","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id417794c9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/473/tI/s102/c"},"text":"Pub. L. 97–473, title I, § 102(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-14"},"text":"Jan. 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2607"},"text":"96 Stat. 2607","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/473/tI/s102/c"},"text":"“The amendments made by this section [enacting this section] shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1978-12-31"},"text":"December 31, 1978","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
