{"tag":"section","attrib":{"id":"id476d9df1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519"},"text":null,"children":[{"tag":"num","attrib":{"value":"7519"},"text":"§ 7519.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required payments for entities electing not to have required taxable year","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id476d9df2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section applies to a partnership or S corporation for any taxable year, if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id476d9df3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an election under section 444 is in effect for the taxable year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id476d9df4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the required payment determined under subsection (b) for such taxable year (or any preceding taxable year) exceeds $500.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id476d9df5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required payment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “required payment” means, with respect to any applicable election year of a partnership or S corporation, an amount equal to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id476d9df6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the excess of the product of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id476d9df7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicable percentage of the adjusted highest section 1 rate, multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id476d9df8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the net base year income of the entity, over","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id476d9df9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the net required payment balance.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of paragraph (1)(A), the term “adjusted highest section 1 rate” means the highest rate of tax in effect under section 1 as of the end of the base year plus 1 percentage point (or, in the case of applicable election years beginning in 1987, 36 percent).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id476d9dfa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refund of payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id476d9dfb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, for any applicable election year, the amount determined under subsection (b)(2) exceeds the amount determined under subsection (b)(1), the entity shall be entitled to a refund of such excess for such year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47700dfc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of elections, etc.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47700dfd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an election under section 444 is terminated effective with respect to any year, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47700dfe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the entity is liquidated during any year, the entity shall be entitled to a refund of the net required payment balance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47700dff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Date on which refund payable","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any refund under this subsection shall be payable on the later of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47700e00-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" April 15 of the calendar year following—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47700e01-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the year referred to in paragraph (1), the calendar year in which it begins,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47700e02-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the year referred to in paragraph (2), the calendar year in which it ends, or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47700e03-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the day 90 days after the day on which claim therefor is filed with the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47700e04-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Net base year income","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47700e05-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity’s net base year income shall be equal to the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47700e06-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deferral ratio multiplied by the entity’s net income for the base year, plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47700e07-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the excess (if any) of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47700e08-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deferral ratio multiplied by the aggregate amount of applicable payments made by the entity during the base year, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47700e09-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amount of such applicable payments made during the deferral period of the base year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of this paragraph, the term “deferral ratio” means the ratio which the number of months in the deferral period of the base year bears to the number of months in the partnership’s or S corporation’s taxable year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47700e0a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Net income","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Net income is determined by taking into account the aggregate amount of the following items—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47700e0b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnerships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a partnership, net income shall be the amount (not below zero) determined by taking into account the aggregate amount of the partnership’s items described in section 702(a) (other than credits and tax-exempt income).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47700e0c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" S corporations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an S corporation, net income shall be the amount (not below zero) determined by taking into account the aggregate amount of the S corporation’s items described in section 1366(a) (other than credits and tax-exempt income). If the S corporation was a C corporation for the base year, its taxable income for such year shall be treated as its net income for such year (and such corporation shall be treated as an S corporation for such taxable year for purposes of paragraph (3)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47700e0d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain limitations disregarded","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A) or (B), any limitation on the amount of any item described in either such paragraph which may be taken into account for purposes of computing the taxable income of a partner or shareholder shall be disregarded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47700e0e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable payments","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47700e0f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “applicable payment” means amounts paid by a partnership or S corporation which are includible in gross income of a partner or shareholder.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47700e10-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “applicable payment” shall not include any—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47700e11-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gain from the sale or exchange of property between the partner or shareholder and the partnership or S corporation, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47700e12-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dividend paid by the S corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47700e13-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable percentage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The applicable percentage is the percentage determined in accordance with the following table:","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id47700e14-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:b","attrib":{},"text":"If the applicable election year of","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:b","attrib":{},"text":" the partnership or S corporation","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:b","attrib":{},"text":" begins during:","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:b","attrib":{},"text":"The applicable percentage is:","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1987","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"25  ","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1988","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50  ","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1989","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"75  ","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1990 or thereafter","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"100.","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Notwithstanding the preceding provisions of this paragraph, the applicable percentage for any partnership or S corporation shall be 100 percent unless more than 50 percent of such entity’s net income for the short taxable year which would have resulted if the entity had not made an election under section 444 would have been allocated to partners or shareholders who would have been entitled to the benefits of section 806(e)(2)(C) of the Tax Reform Act of 1986 with respect to such income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47700e15-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of guaranteed payments","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47700e16-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any guaranteed payment by a partnership shall not be treated as an applicable payment, and the amount of the net income of the partnership shall be determined by not taking such guaranteed payment into account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47700e17-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guaranteed payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A), the term “guaranteed payment” means any payment referred to in section 707(c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47700e18-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other definitions and special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47700e19-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deferral period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “deferral period” has the meaning given to such term by section 444(b)(4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47700e1a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Years","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47700e1b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Base year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “base year” means, with respect to any applicable election year, the taxable year of the partnership or S corporation preceding such applicable election year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47700e1c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable election year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “applicable election year” means any taxable year of a partnership or S corporation with respect to which an election is in effect under section 444.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47700e1d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each partnership or S corporation which makes an election under section 444 shall include on any required return or statement such information as the Secretary shall prescribe as is necessary to carry out the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47700e1e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Net required payment balance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “net required payment balance” means the excess (if any) of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47700e1f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate of the required payments under this section for all preceding applicable election years, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47700e20-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amount allowable as a refund to the entity under subsection (c) for all preceding applicable election years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47700e21-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative provisions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47700e22-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this subsection or in regulations prescribed by the Secretary, any payment required by this section shall be assessed and collected in the same manner as if it were a tax imposed by subtitle C.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47700e23-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Due date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of any payment required by this section shall be paid on or before April 15 of the calendar year following the calendar year in which the applicable election year begins (or such later date as may be prescribed by the Secretary).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47700e24-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of determining interest, any payment required by this section shall be treated as a tax; except that no interest shall be allowed with respect to any refund of a payment made under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47700e25-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47700e26-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any failure by any person to pay on the date prescribed therefor any amount required by this section, there shall be imposed on such person a penalty of 10 percent of the underpayment. For purposes of the preceding sentence, the term “underpayment” means the excess of the amount of the payment required under this section over the amount (if any) of such payment paid on or before the date prescribed therefor. No penalty shall be imposed under this subparagraph on any failure which is shown to be due to reasonable cause and not willful neglect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47700e27-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Negligence and fraud penalties made applicable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of part II of subchapter A of chapter 68, any payment required by this section shall be treated as a tax.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47700e28-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/f/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Willful failure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any partnership or S corporation willfully fails to comply with the requirements of this section, section 444 shall cease to apply with respect to such partnership or S corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47700e29-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prescribe such regulations as may be necessary or appropriate to carry out the provisions of this section and section 280H, including regulations providing for appropriate adjustments in the application of this section and sections 280H and 444 in cases where—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47700e2a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 or more applicable election years begin in the same calendar year, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47700e2b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7519/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the base year is a taxable year of less than 12 months.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47700e2c-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX/s10206/b/1"},"text":"Pub. L. 100–203, title X, § 10206(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-398"},"text":"101 Stat. 1330–398","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tII/s2004/e/4"},"text":"Pub. L. 100–647, title II, § 2004(e)(4)","children":[],"tail":"–(10), (14)(B), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3601"},"text":"102 Stat. 3601","children":[],"tail":", 3602; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII"},"text":"Pub. L. 101–239, title VII","children":[],"tail":", §§ 7721(c)(12), 7821(b), "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2400"},"text":"103 Stat. 2400","children":[],"tail":", 2424; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11704/a/29"},"text":"Pub. L. 101–508, title XI, § 11704(a)(29)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-519"},"text":"104 Stat. 1388–519","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXII/s1281/d"},"text":"Pub. L. 105–34, title XII, § 1281(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1037"},"text":"111 Stat. 1037","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47700e2d-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47700e2e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id47700e2f-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 806(e)(2)(C) of the Tax Reform Act of 1986, referred to in subsec. (d)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s806/e/2/C"},"text":"section 806(e)(2)(C) of Pub. L. 99–514","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1378"},"text":"section 1378 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id47700e30-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (f)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" inserted at end “No penalty shall be imposed under this subparagraph on any failure which is shown to be due to reasonable cause and not willful neglect.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" substituted “payable on the later of” for “payable on later of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7821/b"},"text":"Pub. L. 101–239, § 7821(b)","children":[],"tail":", struck out “for taxable years beginning after 1987,” before “the applicable percentage” and substituted “unless more than 50 percent” for “if more than 50 percent” and “who would have been entitled” for “who would not have been entitled”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7721/c/12"},"text":"Pub. L. 101–239, § 7721(c)(12)","children":[],"tail":", substituted “part II of subchapter A of chapter 68” for “section 6653”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s2004/e/4/A"},"text":"Pub. L. 100–647, § 2004(e)(4)(A)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “the amount of the required payment for the preceding applicable election year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s2004/e/5"},"text":"Pub. L. 100–647, § 2004(e)(5)","children":[],"tail":", amended subsec. (c) generally. Prior to amendment, subsec. (c) read as follows: “If the amount determined under subsection (b)(2) exceeds the amount determined under subsection (b)(1), then the entity shall be entitled to a refund of such excess.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s2004/e/10"},"text":"Pub. L. 100–647, § 2004(e)(10)","children":[],"tail":", substituted “(other than credits and tax-exempt income)” for “(other than credits)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s2004/e/7"},"text":"Pub. L. 100–647, § 2004(e)(7)","children":[],"tail":", (10), substituted “(other than credits and tax-exempt income)” for “(other than credits)” and inserted before period at end “(and such corporation shall be treated as an S corporation for such taxable year for purposes of paragraph (3))”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s2004/e/14/B"},"text":"Pub. L. 100–647, § 2004(e)(14)(B)","children":[],"tail":", struck out “or incurred” after “amounts paid”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s2004/e/9"},"text":"Pub. L. 100–647, § 2004(e)(9)","children":[],"tail":", inserted at end “Notwithstanding the preceding provisions of this paragraph, for taxable years beginning after 1987, the applicable percentage for any partnership or S corporation shall be 100 percent if more than 50 percent of such entity’s net income for the short taxable year which would have resulted if the entity had not made an election under section 444 would have been allocated to partners or shareholders who would not have been entitled to the benefits of section 806(e)(2)(C) of the Tax Reform Act of 1986 with respect to such income.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s2004/e/8"},"text":"Pub. L. 100–647, § 2004(e)(8)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s2004/e/4/B"},"text":"Pub. L. 100–647, § 2004(e)(4)(B)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s2004/e/6"},"text":"Pub. L. 100–647, § 2004(e)(6)","children":[],"tail":", substituted “including regulations providing for appropriate adjustments in the application of this section and sections 280H and 444 in cases where—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) 2 or more applicable election years begin in the same calendar year, or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) the base year is a taxable year of less than 12 months” for “including regulations for annualizing the income and applicable payments of an entity if the base year is a taxable year of less than 12 months”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47700e31-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47700e32-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1281/e"},"text":"section 1281(e) of Pub. L. 105–34","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6652"},"text":"section 6652 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47700e33-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7721/c/12"},"text":"section 7721(c)(12) of Pub. L. 101–239","children":[],"tail":" applicable to returns the due date for which (determined without regard to extensions) is after "},{"tag":"date","attrib":{"date":"1989-12-31"},"text":"Dec. 31, 1989","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7721/d"},"text":"section 7721(d) of Pub. L. 101–239","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s461"},"text":"section 461 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7821/b"},"text":"Pub. L. 101–239, title VII, § 7821(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2424"},"text":"103 Stat. 2424","children":[],"tail":", provided that the amendment made by that section is effective with respect to taxable years beginning after 1988."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id47700e34-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provisions of the Revenue Act of 1987, "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tX"},"text":"Pub. L. 100–203, title X","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s2004/u"},"text":"section 2004(u) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s56"},"text":"section 56 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id47700e35-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to applicable election years beginning after ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"Dec. 31, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/s10206/d/2"},"text":"section 10206(d)(2) of Pub. L. 100–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s444"},"text":"section 444 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
