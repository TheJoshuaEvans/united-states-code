{"tag":"section","attrib":{"id":"id468671bf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6055"},"text":null,"children":[{"tag":"num","attrib":{"value":"6055"},"text":"§ 6055.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting of health insurance coverage","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id468671c0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6055/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every person who provides minimum essential coverage to an individual during a calendar year shall, at such time as the Secretary may prescribe, make a return described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id468671c1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6055/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form and manner of return","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id468671c2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6055/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A return is described in this subsection if such return—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id468671c3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6055/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in such form as the Secretary may prescribe, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id468671c4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6055/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" contains—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id468671c5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6055/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address and TIN of the primary insured and the name and TIN of each other individual obtaining coverage under the policy,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id468671c6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6055/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the dates during which such individual was covered under minimum essential coverage during the calendar year,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id468671c7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6055/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of minimum essential coverage which consists of health insurance coverage, information concerning—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id468671c8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6055/b/1/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether or not the coverage is a qualified health plan offered through an Exchange established under section 1311 of the Patient Protection and Affordable Care Act, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id468671c9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6055/b/1/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a qualified health plan, the amount (if any) of any advance payment under section 1412 of the Patient Protection and Affordable Care Act of any cost-sharing reduction under section 1402 of such Act or of any premium tax credit under section 36B with respect to such coverage, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id468671ca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6055/b/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of subparagraph (B)(i), in the case of any individual whose name is required to be set forth in a return under subsection (a), if the person required to make a return under such subsection is unable to collect information on the TINs of such individuals, the Secretary may allow the individual’s full name and date of birth to be substituted for the name and TIN.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id468671cb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6055/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information relating to employer-provided coverage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If minimum essential coverage provided to an individual under subsection (a) consists of health insurance coverage of a health insurance issuer provided through a group health plan of an employer, a return described in this subsection shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id468671cc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6055/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address, and employer identification number of the employer maintaining the plan,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id468671cd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6055/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the portion of the premium (if any) required to be paid by the employer, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id468671ce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6055/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the health insurance coverage is a qualified health plan in the small group market offered through an Exchange, such other information as the Secretary may require for administration of the credit under section 45R (relating to credit for employee health insurance expenses of small employers).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id468671cf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6055/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statements to be furnished to individuals with respect to whom information is reported","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id468671d0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6055/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Every person required to make a return under subsection (a) shall furnish to each individual whose name is required to be set forth in such return a written statement showing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id468671d1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6055/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name and address of the person required to make such return and the phone number of the information contact for such person, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id468671d2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6055/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information required to be shown on the return with respect to such individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id468671d3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6055/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for furnishing statements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The written statement required under paragraph (1) shall be furnished on or before January 31 of the year following the calendar year for which the return under subsection (a) was required to be made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id468671d4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6055/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002285"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002285"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Two pars. (3) have been enacted."}],"tail":" Alternative manner of furnishing statements"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, any person required to make a return under subsection (a) shall be treated as timely furnishing the written statement required under paragraph (1) if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id468671d5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6055/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such person provides clear, conspicuous, and accessible notice (at such time and in such manner as the Secretary may provide) that any individual to whom a statement would otherwise be required to be furnished under paragraph (1) may request a copy of such statement, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id468671d6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6055/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such person, on request of any such individual, furnishes a copy of such statement to such individual not later than the later of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id468671d7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6055/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" January 31 of the year following the calendar year for which the return under subsection (a) was required to be made, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id468671d8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6055/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 30 days after the date of such request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id468671d9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6055/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" Electronic delivery"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual shall be deemed to have consented to receive the statement under this subsection in electronic form if such individual has affirmatively consented at any prior time, to the person required to make such statement, to receive such statement in electronic form. The preceding sentence shall not apply if the individual revokes such consent in writing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id468671da-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6055/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coverage provided by governmental units","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of coverage provided by any governmental unit or any agency or instrumentality thereof, the officer or employee who enters into the agreement to provide such coverage (or the person appropriately designated for purposes of this section) shall make the returns and statements required by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id468671db-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6055/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum essential coverage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “minimum essential coverage” has the meaning given such term by section 5000A(f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id468671dc-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI/s1502/a"},"text":"Pub. L. 111–148, title I, § 1502(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/250"},"text":"124 Stat. 250","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/167/s2/a"},"text":"Pub. L. 118–167, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2584"},"text":"138 Stat. 2584","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/168"},"text":"Pub. L. 118–168","children":[],"tail":", §§ 2(a), 3(b), "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2586"},"text":"138 Stat. 2586","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id468671dd-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id468671de-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id468671df-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 1311, 1402, and 1412 of the Patient Protection and Affordable Care Act, referred to in subsec. (b)(1)(B)(iii), are classified to sections 18031, 18071, and 18082, respectively, of Title 42, The Public Health and Welfare.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id468671e0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/168/s2/a"},"text":"Pub. L. 118–168, § 2(a)","children":[],"tail":", inserted concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/168/s3/b"},"text":"Pub. L. 118–168, § 3(b)","children":[],"tail":", added par. (3) relating to electronic delivery."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/167"},"text":"Pub. L. 118–167","children":[],"tail":" added par. (3) relating to alternative manner of furnishing statements."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id468671e1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id468671e2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2024 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/168/s2/b"},"text":"Pub. L. 118–168, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2586"},"text":"138 Stat. 2586","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/168/s2/b"},"text":"“The amendment made by this section [amending this section] shall apply to returns the due date for which is after ","children":[{"tag":"date","attrib":{"date":"2024-12-31"},"text":"December 31, 2024","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/168/s3/c"},"text":"Pub. L. 118–168, § 3(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2587"},"text":"138 Stat. 2587","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/168/s3/c"},"text":"“The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6056"},"text":"section 6056 of this title","children":[],"tail":"] shall apply to statements the due date for which is after "},{"tag":"date","attrib":{"date":"2024-12-31"},"text":"December 31, 2024","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/167/s2/c"},"text":"Pub. L. 118–167, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2585"},"text":"138 Stat. 2585","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/167/s2/c"},"text":"“The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6056"},"text":"section 6056 of this title","children":[],"tail":"] shall apply to statements with respect to returns for calendar years after 2023.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id468671e3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI/s1502/e"},"text":"Pub. L. 111–148, title I, § 1502(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/252"},"text":"124 Stat. 252","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/148/tI/s1502/e"},"text":"“The amendments made by this section [enacting this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s18092"},"text":"section 18092 of Title 42","children":[],"tail":", The Public Health and Welfare, and amending "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6724"},"text":"section 6724 of this title","children":[],"tail":"] shall apply to calendar years beginning after 2013.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
