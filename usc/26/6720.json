{"tag":"section","attrib":{"id":"id4736d607-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6720"},"text":null,"children":[{"tag":"num","attrib":{"value":"6720"},"text":"§ 6720.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fraudulent acknowledgments with respect to donations of motor vehicles, boats, and airplanes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Any donee organization required under section 170(f)(12)(A) to furnish a contemporaneous written acknowledgment to a donor which knowingly furnishes a false or fraudulent acknowledgment, or which knowingly fails to furnish such acknowledgment in the manner, at the time, and showing the information required under section 170(f)(12), or regulations prescribed thereunder, shall for each such act, or for each such failure, be subject to a penalty equal to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4736d608-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6720/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of an acknowledgment with respect to a qualified vehicle to which section 170(f)(12)(A)(ii) applies, the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4736d609-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6720/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the product of the highest rate of tax specified in section 1 and the sales price stated on the acknowledgment, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4736d60a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6720/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the gross proceeds from the sale of such vehicle, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4736d60b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6720/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of an acknowledgment with respect to any other qualified vehicle to which section 170(f)(12) applies, the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4736d60c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6720/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the product of the highest rate of tax specified in section 1 and the claimed value of the vehicle, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4736d60d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6720/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4736d60e-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s884/b/1"},"text":"Pub. L. 108–357, title VIII, § 884(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1634"},"text":"118 Stat. 1634","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4736d60f-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4736d610-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4736d611-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to contributions made after ","children":[{"tag":"date","attrib":{"date":"2004-12-31"},"text":"Dec. 31, 2004","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/s884/c"},"text":"section 884(c) of Pub. L. 108–357","children":[],"tail":", set out as an Effective Date of 2004 Amendments note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s170"},"text":"section 170 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
