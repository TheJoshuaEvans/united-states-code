his section] shall apply with respect to transportation beginning after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4749e8aa-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1971 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/680/s4"},"text":"Pub. L. 91–680, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-12"},"text":"Jan. 12, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/2065"},"text":"84 Stat. 2065","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/91/680/s4"},"text":"“The amendments made by the third section of this Act [amending this section] shall apply to transportation beginning after ","children":[{"tag":"date","attrib":{"date":"1970-06-30"},"text":"June 30, 1970","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4749e8ab-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to transportation beginning after ","children":[{"tag":"date","attrib":{"date":"1970-06-30"},"text":"June 30, 1970","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/258/s211/b"},"text":"section 211(b) of Pub. L. 91–258","children":[],"tail":", set out as Effective Date of 1970 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4041"},"text":"section 4041 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
