{"tag":"section","attrib":{"id":"id4546c581-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2613"},"text":null,"children":[{"tag":"num","attrib":{"value":"2613"},"text":"§ 2613.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Skip person and non-skip person defined","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4546c582-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2613/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Skip person","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter, the term “skip person” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4546c583-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2613/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a natural person assigned to a generation which is 2 or more generations below the generation assignment of the transferor, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4546c584-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2613/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a trust—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4546c585-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2613/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if all interests in such trust are held by skip persons, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4546c586-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2613/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4546c587-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2613/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is no person holding an interest in such trust, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4546c588-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2613/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at no time after such transfer may a distribution (including distributions on termination) be made from such trust to a nonskip person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4546c589-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2613/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-skip person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this chapter, the term “non-skip person” means any person who is not a skip person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4546c58a-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXX/s2006/a"},"text":"Pub. L. 94–455, title XX, § 2006(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1884"},"text":"90 Stat. 1884","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/600/tVII/s702/n/2"},"text":"Pub. L. 95–600, title VII, § 702(n)(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2935"},"text":"92 Stat. 2935","children":[],"tail":", 2936; "},{"tag":"ref","attrib":{"href":"/us/pl/96/222/tI/s107/a/2/B"},"text":"Pub. L. 96–222, title I, § 107(a)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-04-01"},"text":"Apr. 1, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/222"},"text":"94 Stat. 222","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXIV/s1431/a"},"text":"Pub. L. 99–514, title XIV, § 1431(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2720"},"text":"100 Stat. 2720","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1014/g/5/A"},"text":"Pub. L. 100–647, title I, § 1014(g)(5)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3564"},"text":"102 Stat. 3564","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4549368b-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4549368c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4549368d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" inserted “natural” before “person”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" amended section generally, substituting definitions of “skip person” and “non-skip person” for former provisions which defined and applied the terms “taxable distribution”, “taxable termination”, “younger generation beneficiary”, and “related or subordinate trustee”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (e)(2)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/222/s107/a/2/B/i"},"text":"Pub. L. 96–222, § 107(a)(2)(B)(i)","children":[],"tail":", inserted “(other than as a potential appointee under a power of appointment held by another)” after “trust”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/222/s107/a/2/B/ii"},"text":"Pub. L. 96–222, § 107(a)(2)(B)(ii)","children":[],"tail":", redesignated cls. (iii) to (v) as (iv) to (vi), added cl. (iii), and struck out cl. (vi) which related to an employee of a corporation in which the grantor or any beneficiary of the trust is an executive."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600/s702/n/3"},"text":"Pub. L. 95–600, § 702(n)(3)","children":[],"tail":", substituted “a present interest and a present power” for “an interest and a power” and “present interest or present power” for “interest or power” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600/s702/n/2"},"text":"Pub. L. 95–600, § 702(n)(2)","children":[],"tail":", inserted provisions relating to powers of independent trustees and definition of a related or subordinate trustee."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id454936