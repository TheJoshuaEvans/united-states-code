{"tag":"section","attrib":{"id":"id472aef5d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6679"},"text":null,"children":[{"tag":"num","attrib":{"value":"6679"},"text":"§ 6679.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to file returns, etc., with respect to foreign corporations or foreign partnerships","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id472aef5e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6679/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalty","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id472aef5f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6679/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to any criminal penalty provided by law, any person required to file a return under section 6046 or 6046A who fails to file such return at the time provided in such section, or who files a return which does not show the information required pursuant to such section, shall pay a penalty of $10,000, unless it is shown that such failure is due to reasonable cause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id472aef60-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6679/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increase in penalty where failure continues after notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any failure described in paragraph (1) continues for more than 90 days after the day on which the Secretary mails notice of such failure to the United States person, such person shall pay a penalty (in addition to the amount required under paragraph (1)) of $10,000 for each 30-day period (or fraction thereof) during which such failure continues after the expiration of such 90-day period. The increase in any penalty under this paragraph shall not exceed $50,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id472aef61-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6679/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deficiency procedures not to apply","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subchapter B of chapter 63 (relating to deficiency procedure for income, estate, gift, and certain excise taxes) shall not apply in respect of the assessment or collection of any penalty imposed by subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id472aef62-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/834/s20/c"},"text":"Pub. L. 87–834, § 20(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-16"},"text":"Oct. 16, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1062"},"text":"76 Stat. 1062","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/tI/s101/j/54"},"text":"Pub. L. 91–172, title I, § 101(j)(54)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/532"},"text":"83 Stat. 532","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/406/tII/s1016/a/22"},"text":"Pub. L. 93–406, title II, § 1016(a)(22)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/931"},"text":"88 Stat. 931","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/248/tIII/s340/b/1"},"text":"Pub. L. 97–248, title III, § 340(b)(1)","children":[],"tail":", (2), title IV, § 405(b), (c)(2), "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/634"},"text":"96 Stat. 634","children":[],"tail":", 670; "},{"tag":"ref","attrib":{"href":"/us/pl/97/448/tIII/s306/c/2"},"text":"Pub. L. 97–448, title III, § 306(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2406"},"text":"96 Stat. 2406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXI/s1143/b"},"text":"Pub. L. 105–34, title XI, § 1143(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/983"},"text":"111 Stat. 983","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tIV/s413/c/29"},"text":"Pub. L. 108–357, title IV, § 413(c)(29)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1509"},"text":"118 Stat. 1509","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/308"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(308)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1199"},"text":"132 Stat. 1199","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id472aef63-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id472aef64-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id472aef65-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" substituted “section 6046 or 6046A” for “section 6046 and 6046A”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s413/c/29/A"},"text":"Pub. L. 108–357, § 413(c)(29)(A)","children":[],"tail":", which directed substitution of “6046 and 6046A” for “6035, 6046, and 6046A” was executed by making the substitution for “6035, 6046, or 6046A” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s413/c/29/B"},"text":"Pub. L. 108–357, § 413(c)(29)(B)","children":[],"tail":", struck out heading and text of par. (3). Text read as follows: “In the case of a return required under section 6035, paragraph (1) shall be applied by substituting ‘$1,000’ for ‘$10,000’, and paragraph (2) shall not apply.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" reenacted heading without change and amended text generally. Prior to amendment, text read as follows: “In addition to any criminal penalty provided by law, any person required to file a return under section 6035, 6046, or 6046A who fails to file such return at the time provided in such section, or who files a return which does not show the information required pursuant to such section, shall pay a penalty of $1,000, unless it is shown that such failure is due to reasonable cause.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/448"},"text":"Pub. L. 97–448","children":[],"tail":" amended language of "},{"tag":"ref","attrib":{"href":"/us/pl/97/248/s405/b"},"text":"Pub. L. 97–248, § 405(b)","children":[],"tail":", (c)(2), to clarify an ambiguity created by the conflicting language of §§ 340(b)(1), (2) and 405(b), (c)(2) of "},{"tag":"ref","attrib":{"href":"/us/pl/97/248"},"text":"Pub. L. 97–248","children":[],"tail":". See 1982 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248"},"text":"Pub. L. 97–248","children":[],"tail":", §§ 340(b)(2), 405(c)(2), as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/97/448/s306/c/2/B"},"text":"Pub. L. 97–448, § 306(c)(2)(B)","children":[],"tail":", substituted “Failure to file returns, etc., with respect to foreign corporations or foreign partnerships” for “Failure to file returns as to organization or reorganization of foreign corporations and as to acquisitions of their stock” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248"},"text":"Pub. L. 97–248","children":[],"tail":", §§ 340(b)(1), 405(b), as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/97/448/s306/a/2/A"},"text":"Pub. L. 97–448, § 306(a)(2)(A)","children":[],"tail":", substituted “section 6035, 6046, or 6046A” for “section 6046”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406"},"text":"Pub. L. 93–406","children":[],"tail":" substituted “and certain excise” for “chapter 42”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172"},"text":"Pub. L. 91–172","children":[],"tail":" inserted reference to chapter 42 taxes."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id472aef66-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id472aef67-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":" applicable to taxable years of foreign corporations beginning after "},{"tag":"date","attrib":{"date":"2004-12-31"},"text":"Dec. 31, 2004","children":[],"tail":", and to taxable years of United States shareholders with or within which such taxable years of foreign corporations end, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/s413/d/1"},"text":"section 413(d)(1) of Pub. L. 108–357","children":[],"tail":", set out as an Effective and Termination Dates of 2004 Amendments note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id472aef68-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" applicable to transfers and changes after "},{"tag":"date","attrib":{"date":"1997-08-05"},