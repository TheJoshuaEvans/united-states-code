nd ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6035"},"text":"section 6035 of this title","children":[],"tail":"] shall apply to taxable years of foreign corporations beginning after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by section 405(b), (c)(2) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248"},"text":"Pub. L. 97–248","children":[],"tail":" applicable with respect to acquisitions or dispositions of, or substantial changes in, interests in foreign partnerships occurring after "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/248/s407/b"},"text":"section 407(b) of Pub. L. 97–248","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6046A"},"text":"section 6046A of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id472aef6b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1974 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406"},"text":"Pub. L. 93–406","children":[],"tail":" applicable, except as otherwise provided in section 1017(c) through (i) of "},{"tag":"ref","attrib":{"href":"/us/pl/93/406"},"text":"Pub. L. 93–406","children":[],"tail":", for plan years beginning after "},{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", but, in the case of plans in existence on "},{"tag":"date","attrib":{"date":"1974-01-01"},"text":"Jan. 1, 1974","children":[],"tail":", amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/93/406"},"text":"Pub. L. 93–406","children":[