{"tag":"section","attrib":{"id":"id44514191-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s873"},"text":null,"children":[{"tag":"num","attrib":{"value":"873"},"text":"§ 873.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deductions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44514192-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s873/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a nonresident alien individual, the deductions shall be allowed only for purposes of section 871(b) and (except as provided by subsection (b)) only if and to the extent that they are connected with income which is effectively connected with the conduct of a trade or business within the United States; and the proper apportionment and allocation of the deductions for this purpose shall be determined as provided in regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44514193-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s873/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following deductions shall be allowed whether or not they are connected with income which is effectively connected with the conduct of a trade or business within the United States:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44514194-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s873/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Losses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The deduction allowed by section 165 for casualty or theft losses described in paragraph (2) or (3) of section 165(c), but only if the loss is of property located within the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44514195-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s873/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Charitable contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The deduction for charitable contributions and gifts allowed by section 170.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44514196-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s873/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personal exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The deduction for personal exemptions allowed by section 151, except that only one exemption shall be allowed under section 151 unless the taxpayer is a resident of a contiguous country or is a national of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44514197-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s873/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For rule that certain foreign taxes are not to be taken into account in determining deduction or credit, see section 906(b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44514198-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/280"},"text":"68A Stat. 280","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/809/tI/s103/c/1"},"text":"Pub. L. 89–809, title I, § 103(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-13"},"text":"Nov. 13, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1550"},"text":"80 Stat. 1550","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/580/s1/b"},"text":"Pub. L. 92–580, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1276"},"text":"86 Stat. 1276","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/30/tI/s101/d/11"},"text":"Pub. L. 95–30, title I, § 101(d)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-05-23"},"text":"May 23, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/134"},"text":"91 Stat. 134","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tVII/s711/c/2/A/iv"},"text":"Pub. L. 98–369, div. A, title VII, § 711(c)(2)(A)(iv)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/945"},"text":"98 Stat. 945","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dJ/tIV/s4004/b/3"},"text":"Pub. L. 105–277, div. J, title IV, § 4004(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-911"},"text":"112 Stat. 2681–911","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44514199-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4451419a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4451419b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" amended heading and text of par. (1) generally. Prior to amendment, text read as follows: “The deduction for losses allowed by section 165(c)(3), but only if the loss is of property located within the United States.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" substituted “for losses” for “, for losses of property not connected with the trade or business if arising from certain casualties or theft,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/30"},"text":"Pub. L. 95–30","children":[],"tail":" struck out par. (1) which made a cross reference to section 142(b)(1) for disallowance of the standard deduction and struck out “(2)” at beginning of single remaining cross reference."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/580"},"text":"Pub. L. 92–580","children":[],"tail":" substituted exception that only one exemption be allowed under section 151 unless the taxpayer is a resident of a contiguous country or is a national of the United States, for exception that in the case of a non-resident alien individual who is not a resident of a contiguous country only one exception be allowed under section 151."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/809"},"text":"Pub. L. 89–809","children":[],"tail":" amended section generally, substituting “connected with income which is effectively connected with the conduct of a trade or business within the United States” for “connected with income from sources within the United States” in subsec. (a), striking out provisions relating to the deduction of losses not connected with a trade or business but incurred in transactions entered into for profit in subsec. (b), making the casualty loss deduction available even if the property giving rise to the loss is not effectively connected with the conduct of a trade or business in the United States if the property is located in this country, making the charitable contribution deduction available even though not related to the trade or business, and adding subsec. (c)(2) making a cross reference to section 906(b)(1) for rule that certain foreign taxes are not to be taken into account in determining deduction or credit."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4451419c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4451419d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"1983-12-31"},"text":"Dec. 31, 1983","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s4004/c/1"},"text":"section 4004(c)(1) of Pub. L. 105–277","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s172"},"text":"section 172 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4451419e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"1983-12-31"},"text":"Dec. 31, 1983","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s711/c/2/A/v"},"text":"section 711(c)(2)(A)(v) of Pub. L. 98–369","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s165"},"text":"section 165 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4451419f-3a70-11f1-a967-d35dac1179