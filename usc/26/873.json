t":"Dec. 31, 1966","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/89/809/s103/n/1"},"text":"section 103(n)(1) of Pub. L. 89–809","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s871"},"text":"section 871 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
