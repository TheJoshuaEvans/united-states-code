{"tag":"section","attrib":{"id":"id474c5994-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7408"},"text":null,"children":[{"tag":"num","attrib":{"value":"7408"},"text":"§ 7408.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions to enjoin specified conduct related to tax shelters and reportable transactions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id474c5995-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7408/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to seek injunction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A civil action in the name of the United States to enjoin any person from further engaging in specified conduct may be commenced at the request of the Secretary. Any action under this section shall be brought in the district court of the United States for the district in which such person resides, has his principal place of business, or has engaged in specified conduct. The court may exercise its jurisdiction over such action (as provided in section 7402(a)) separate and apart from any other action brought by the United States against such person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id474c5996-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7408/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjudication and decree","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any action under subsection (a), if the court finds—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id474c5997-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7408/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the person has engaged in any specified conduct, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id474c5998-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7408/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that injunctive relief is appropriate to prevent recurrence of such conduct,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the court may enjoin such person from engaging in such conduct or in any other activity subject to penalty under this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id474c5999-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7408/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specified conduct","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “specified conduct” means any action, or failure to take action, which is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id474c599a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7408/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to penalty under section 6700, 6701, 6707, or 6708, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id474c599b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7408/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in violation of any requirement under regulations issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s330"},"text":"section 330 of title 31","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id474c599c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7408/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Citizens and residents outside the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any citizen or resident of the United States does not reside in, and does not have his principal place of business in, any United States judicial district, such citizen or resident shall be treated for purposes of this section as residing in the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id474c599d-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/tIII/s321/a"},"text":"Pub. L. 97–248, title III, § 321(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/612"},"text":"96 Stat. 612","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s143/b"},"text":"Pub. L. 98–369, div. A, title I, § 143(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/682"},"text":"98 Stat. 682","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s820/a"},"text":"Pub. L. 108–357, title VIII, § 820(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1585"},"text":"118 Stat. 1585","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id474c599e-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id474c599f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id474c59a0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7408 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s7410"},"text":"section 7410 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id474c59a1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s820/b/1"},"text":"Pub. L. 108–357, § 820(b)(1)","children":[],"tail":", amended section catchline generally, substituting “Actions to enjoin specified conduct related to tax shelters and reportable transactions” for “Action to enjoin promoters of abusive tax shelters, etc.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s820/a"},"text":"Pub. L. 108–357, § 820(a)","children":[],"tail":", added subsecs. (a) to (c), redesignated former subsec. (c) as (d), and struck out former subsecs. (a) and (b), which authorized a civil action to enjoin any person from further engaging in conduct subject to penalty under section 6700 or 6701 of this title and authorized the court, if it found that the person had engaged in such conduct and that injunctive relief was appropriate, to enjoin such person from engaging in such conduct or in any other activity subject to penalty under section 6700 or 6701."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s143/b/1"},"text":"Pub. L. 98–369, § 143(b)(1)","children":[],"tail":", (2), inserted “or section 6701 (relating to penalties for aiding and abetting understatement of tax liability)” and inserted reference to section 6701 at end of second sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s143/b/1"},"text":"Pub. L. 98–369, § 143(b)(1)","children":[],"tail":", (3), inserted “or section 6701 (relating to penalties for aiding and abetting understatement of tax liability),” in par. (1) and inserted reference to section 6701 at end."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id474c59a2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id474c59a3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s820/c"},"text":"Pub. L. 108–357, title VIII, § 820(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1585"},"text":"118 Stat. 1585","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/357/tVIII/s820/c"},"text":"“The amendment made by this section [amending this section] shall take effect on the day after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id474c59a4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" effective on day after "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s143/c"},"text":"section 143(c) of Pub. L. 98–369","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6700"},"text":"section 6700 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id474c59a5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/tIII/s321/c"},"text":"Pub. L. 97–248, title III, § 321(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/612"},"text":"96 Stat. 612","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/248/tIII/s321/c"},"text":"“The amendments made by this section [enacting this section] shall take effect on the day after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
