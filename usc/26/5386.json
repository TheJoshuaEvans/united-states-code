{"tag":"section","attrib":{"id":"id4639febe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5386"},"text":null,"children":[{"tag":"num","attrib":{"value":"5386"},"text":"§ 5386.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special natural wines","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4639febf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5386/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Special natural wines are the products made, pursuant to a formula approved under this section, from a base of natural wine (including heavy-bodied blending wine) exclusively, with the addition, before, during or after fermentation, of natural herbs, spices, fruit juices, aromatics, essences, and other natural flavorings in such quantities or proportions as to enable such products to be distinguished from any natural wine not so treated, and with or without carbon dioxide naturally or artificially added, and with or without the addition, separately or in combination, of pure dry sugar or a solution of pure dry sugar and water, or caramel. No added wine spirits or alcohol or other spirits shall be used in any wine under this section except as may be contained in the natural wine (including heavy-bodied blending wine) used as a base or except as may be necessary in the production of approved essences or similar approved flavorings. The Brix degree of any solution of pure dry sugar and water used may be limited by regulations prescribed by the Secretary in accordance with good commercial practice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4639fec0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5386/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cellar treatment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Special natural wines may be cellar treated under the provisions of section 5382(a) and (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4639fec1-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1386"},"text":"72 Stat. 1386","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/90/619/s5"},"text":"Pub. L. 90–619, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1237"},"text":"82 Stat. 1237","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4639fec2-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4639fec3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4639fec4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"