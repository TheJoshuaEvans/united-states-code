which begins 90 days or more after "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/619/s6"},"text":"section 6 of Pub. L. 90–619","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5373"},"text":"section 5373 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
