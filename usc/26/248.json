{"tag":"section","attrib":{"id":"id4244a90e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s248"},"text":null,"children":[{"tag":"num","attrib":{"value":"248"},"text":"§ 248.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organizational expenditures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4244a90f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s248/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election to deduct","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a corporation elects the application of this subsection (in accordance with regulations prescribed by the Secretary) with respect to any organizational expenditures—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4244a910-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s248/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the corporation shall be allowed a deduction for the taxable year in which the corporation begins business in an amount equal to the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4244a911-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s248/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of organizational expenditures with respect to the taxpayer, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4244a912-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s248/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000, reduced (but not below zero) by the amount by which such organizational expenditures exceed $50,000, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4244a913-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s248/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the remainder of such organizational expenditures shall be allowed as a deduction ratably over the 180-month period beginning with the month in which the corporation begins business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4244a914-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s248/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organizational expenditures defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “organizational expenditures” means any expenditure which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4244a915-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s248/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is incident to the creation of the corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4244a916-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s248/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is chargeable to capital account; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4246f307-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s248/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is of a character which, if expended incident to the creation of a corporation having a limited life, would be amortizable over such life.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4246f308-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s248/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for and scope of election","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The election provided by subsection (a) may be made for any taxable year but only if made not later than the time prescribed by law for filing the return for such taxable year (including extensions thereof). The period so elected shall be adhered to in computing the taxable income of the corporation for the taxable year for which the election is made and all subsequent taxable years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4246f309-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/76"},"text":"68A Stat. 76","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX"},"text":"Pub. L. 94–455, title XIX","children":[],"tail":", §§ 1901(a)(36), 1906(b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1770"},"text":"90 Stat. 1770","children":[],"tail":", 1834; "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s902/b"},"text":"Pub. L. 108–357, title VIII, § 902(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1651"},"text":"118 Stat. 1651","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dA/tII/s221/a/42"},"text":"Pub. L. 113–295, div. A, title II, § 221(a)(42)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4044"},"text":"128 Stat. 4044","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4246f30a-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4246f30b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4246f30c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" struck out “beginning after "},{"tag":"date","attrib":{"date":"1953-12-31"},"text":"December 31, 1953","children":[],"tail":",” after “any taxable year” and “The election shall apply only with respect to expenditures paid or incurred on or after "},{"tag":"date","attrib":{"date":"1954-08-16"},"text":"August 16, 1954","children":[],"tail":".” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":" amended heading and text of subsec. (a) generally. Prior to amendment, text read as follows: “The organizational expenditures of a corporation may, at the election of the corporation (made in accordance with regulations prescribed by the Secretary, be treated as deferred expenses. In computing taxable income, such deferred expenses shall be allowed as a deduction ratably over such period of not less than 60 months as may be selected by the corporation (beginning with the month in which the corporation begins business).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1901/a/36"},"text":"Pub. L. 94–455, § 1901(a)(36)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"1954-08-16"},"text":"August 16, 1954","children":[],"tail":"” for “the date of enactment of this title”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4246f30d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4246f30e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", subject to a savings provision, see "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/s221/b"},"text":"section 221(b) of Pub. L. 113–295","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4246f30f-3a70-11f1-a967-d35dac11796a"},"text":null,"children"