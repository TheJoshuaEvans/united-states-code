{"tag":"section","attrib":{"id":"id441cc450-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s845"},"text":null,"children":[{"tag":"num","attrib":{"value":"845"},"text":"§ 845.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain reinsurance agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id441cc451-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s845/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation in case of reinsurance agreement involving tax avoidance or evasion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of 2 or more related persons (within the meaning of section 482) who are parties to a reinsurance agreement (or where one of the parties to a reinsurance agreement is, with respect to any contract covered by the agreement, in effect an agent of another party to such agreement or a conduit between related persons), the Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id441cc452-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s845/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allocate between or among such persons income (whether investment income, premium, or otherwise), deductions, assets, reserves, credits, and other items related to such agreement,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id441cc453-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s845/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recharacterize any such items, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id441cc454-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s845/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make any other adjustment,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"if he determines that such allocation, recharacterization, or adjustment is necessary to reflect the proper amount, source, or character of the taxable income (or any item described in paragraph (1) relating to such taxable income) of each such person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id441cc455-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s845/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reinsurance contract having significant tax avoidance effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines that any reinsurance contract has a significant tax avoidance effect on any party to such contract, the Secretary may make proper adjustments with respect to such party to eliminate such tax avoidance effect (including treating such contract with respect to such party as terminated on December 31 of each year and reinstated on January 1 of the next year).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id441cc456-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tII/s212/a"},"text":"Pub. L. 98–369, div. A, title II, § 212(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/757"},"text":"98 Stat. 757","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s803/a"},"text":"Pub. L. 108–357, title VIII, § 803(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1569"},"text":"118 Stat. 1569","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id441cc457-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id441cc458-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id441cc459-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":" substituted “amount, source, or character” for “source and character” in concluding provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id441cc45a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id441cc45b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s803/b"},"text":"Pub. L. 108–357, title VIII, § 803(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1569"},"text":"118 Stat. 1569","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/357/tVIII/s803/b"},"text":"“The amendments made by this section [amending this section] shall apply to any risk reinsured after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id441cc45c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tII/s217/d"},"text":"Pub. L. 98–369, div. A, title II, § 217(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/762"},"text":"98 Stat. 762","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (a) of section 845 of the Internal Revenue Code of 1986 [formerly I.R.C. 1954] (as added by this title) shall apply with respect to any risk reinsured on or after ","children":[{"tag":"date","attrib":{"date":"1983-09-27"},"text":"September 27, 1983","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (b) of section 845 of such Code (as so added) shall apply with respect to risks reinsured after ","children":[{"tag":"date","attrib":{"date":"1984-12-31"},"text":"December 31, 1984","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
