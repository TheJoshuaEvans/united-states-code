{"tag":"section","attrib":{"id":"id47d69805-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9823"},"text":null,"children":[{"tag":"num","attrib":{"value":"9823"},"text":"§ 9823.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Air ambulance report requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47d69806-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9823/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each group health plan shall submit to the Secretary, jointly with the Secretary of Labor and the Secretary of Health and Human Services—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47d69807-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9823/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than the date that is 90 days after the last day of the first calendar year beginning on or after the date on which a final rule is promulgated pursuant to the rulemaking described in section 106(d) of the No Surprises Act, the information described in subsection (b) with respect to such plan year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47d69808-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9823/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than the date that is 90 days after the last day of the calendar year immediately succeeding the plan year described in paragraph (1), such information with respect to such immediately succeeding plan year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47d69809-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9823/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a), information described in this subsection, with respect to a group health plan is each of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47d6980a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9823/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Claims data for air ambulance services furnished by providers of such services, disaggregated by each of the following factors:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47d6980b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9823/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether such services were furnished on an emergent or nonemergent basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47d6980c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9823/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether the provider of such services is part of a hospital-owned or sponsored program, municipality-sponsored program, hospital independent partnership (hybrid) program, independent program, or tribally operated program in Alaska.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47d6980d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9823/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether the transport in which the services were furnished originated in a rural or urban area.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47d6980e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9823/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The type of aircraft (such as rotor transport or fixed wing transport) used to furnish such services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47d6980f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9823/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether the provider of such services has a contract with the plan or issuer, as applicable, to furnish such services under the plan or coverage, respectively.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47d69810-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9823/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other information regarding providers of air ambulance services as the Secretary may specify.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47d69811-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dBB/tI/s106/b/3/A"},"text":"Pub. L. 116–260, div. BB, title I, § 106(b)(3)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2854"},"text":"134 Stat. 2854","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47d69812-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47d69813-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id47d69814-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 106(d) of the No Surprises Act, referred to in subsec. (a)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dBB/s106/d"},"text":"section 106(d) of div. BB of Pub. L. 116–260","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–118"},"text":"section 300gg–118 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
