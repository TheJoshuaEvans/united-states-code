{"tag":"section","attrib":{"id":"id479d5fd4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7806"},"text":null,"children":[{"tag":"num","attrib":{"value":"7806"},"text":"§ 7806.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction of title","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id479d5fd5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7806/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross references","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The cross references in this title to other portions of the title, or other provisions of law, where the word “see” is used, are made only for convenience, and shall be given no legal effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id479d5fd6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7806/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Arrangement and classification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No inference, implication, or presumption of legislative construction shall be drawn or made by reason of the location or grouping of any particular section or provision or portion of this title, nor shall any table of contents, table of cross references, or similar outline, analysis, or descriptive matter relating to the contents of this title be given any legal effect. The preceding sentence also applies to the sidenotes and ancillary tables contained in the various prints of this Act before its enactment into law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id479d5fd7-3a70-11f1-a967-d35dac11796a"},"text":"(","children