{"tag":"section","attrib":{"id":"id46aee07f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6159"},"text":null,"children":[{"tag":"num","attrib":{"value":"6159"},"text":"§ 6159.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements for payment of tax liability in installments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46aee080-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6159/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to enter into written agreements with any taxpayer under which such taxpayer is allowed to make payment on any tax in installment payments if the Secretary determines that such agreement will facilitate full or partial collection of such liability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46aee081-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6159/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extent to which agreements remain in effect","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46aee082-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6159/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this subsection, any agreement entered into by the Secretary under subsection (a) shall remain in effect for the term of the agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46aee083-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6159/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inadequate information or jeopardy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may terminate any agreement entered into by the Secretary under subsection (a) if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46aee084-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6159/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information which the taxpayer provided to the Secretary prior to the date such agreement was entered into was inaccurate or incomplete, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46aee085-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6159/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary believes that collection of any tax to which an agreement under this section relates is in jeopardy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46aee086-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6159/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent change in financial conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary makes a determination that the financial condition of a taxpayer with whom the Secretary has entered into an agreement under subsection (a) has significantly changed, the Secretary may alter, modify, or terminate such agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46aee087-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6159/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to pay an installment or any other tax liability when due or to provide requested financial information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may alter, modify, or terminate an agreement entered into by the Secretary under subsection (a) in the case of the failure of the taxpayer—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46aee088-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6159/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pay any installment at the time such installment payment is due under such agreement,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46aee089-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6159/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pay any other tax liability at the time such liability is due, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46aee08a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6159/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide a financial condition update as requested by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46aee08b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6159/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not take any action under paragraph (2), (3), or (4) unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46aee08c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6159/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a notice of such action is provided to the taxpayer not later than the day 30 days before the date of such action, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46aee08d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6159/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such notice includes an explanation why the Secretary intends to take such action.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The preceding sentence shall not apply in any case in which the Secretary believes that collection of any tax to which an agreement under this section relates is in jeopardy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46aee08e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6159/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary required to enter into installment agreements in certain cases","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a liability for tax of an individual under subtitle A, the Secretary shall enter into an agreement to accept the full payment of such tax in installments if, as of the date the individual offers to enter into the agreement—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46aee08f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6159/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amount of such liability (determined without regard to interest, penalties, additions to the tax, and additional amounts) does not exceed $10,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46aee090-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6159/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the taxpayer (and, if such liability relates to a joint return, the taxpayer’s spouse) has not, during any of the preceding 5 taxable years—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46aee091-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6159/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" failed to file any return of tax imposed by subtitle A;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46aee092-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6159/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" failed to pay any tax required to be shown on any such return; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46aee093-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6159/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entered into an installment agreement under this section for payment of any tax imposed by subtitle A,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46aee094-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6159/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that the taxpayer is financially unable to pay such liability in full when due (and the taxpayer submits such information as the Secretary may require to make such determination);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46aee095-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6159/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agreement requires full payment of such liability within 3 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46aee096-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6159/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taxpayer agrees to comply with the provisions of this title for the period such agreement is in effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46aee097-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6159/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary required to review installment agreements for partial collection every two years","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an agreement entered into by the Secretary under subsection (a) for partial collection of a tax liability, the Secretary shall review the agreement at least once every 2 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46aee098-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6159/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish procedures for an independent administrative review of terminations of installment agreements under this section for taxpayers who request such a review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46aee099-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6159/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Installment agreement fees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46aee09a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6159/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on fee amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of any fee imposed on an installment agreement under this section may not exceed the amount of such fee as in effect on the date of the enactment of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46aee09b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6159/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver or reimbursement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any taxpayer with an adjusted gross income, as determined for the most recent year for which such information is available, which does not exceed 250 percent of the applicable poverty level (as determined by the Secretary)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46aee09c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6159/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the taxpayer has agreed to make payments under the installment agreement by electronic payment through a debit instrument, no fee shall be imposed on an installment agreement under this section, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46aee09d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6159/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the taxpayer is unable to make payments under the installment agreement by electronic payment through a debit instrument, the Secretary shall, upon completion of the installment agreement, pay the taxpayer an amount equal to any such fees imposed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46aee09e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6159/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For rights to administrative review and appeal, see section 7122(e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46aee09f-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tVI/s6234/a"},"text":"Pub. L. 100–647, title VI, § 6234(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3735"},"text":"102 Stat. 3735","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/168/tII"},"text":"Pub. L. 104–168, title II","children":[],"tail":", §§ 201(a), (b), 202(a), "},{"tag":"date","attrib":{"date":"1996-07-30"},"text":"July 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1456"},"text":"110 Stat. 1456","children":[],"tail":", 1457; "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tIII"},"text":"Pub. L. 105–206, title III","children":[],"tail":", §§ 3462(c)(2), 3467(a), "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/766"},"text":"112 Stat. 766","children":[],"tail":", 769; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dJ/tIV/s4002/g"},"text":"Pub. L. 105–277, div. J, title IV, § 4002(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-907"},"text":"112 Stat. 2681–907","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s843/a"},"text":"Pub. L. 108–357, title VIII, § 843(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1600"},"text":"118 Stat. 1600","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/222/tV/s509/c"},"text":"Pub. L. 109–222, title V, § 509(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-05-17"},"text":"May 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/363"},"text":"120 Stat. 363","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/123/dD/tII/s41105/a"},"text":"Pub. L. 115–123, div. D, title II, § 41105(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-09"},"text":"Feb. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/157"},"text":"132 Stat. 157","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46aee0a0-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46aee0a1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id46aee0a2-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this subsection, referred to in subsec. (f)(1), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123"},"text":"Pub. L. 115–123","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2018-02-09"},"text":"Feb. 9, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46aee0a3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123"},"text":"Pub. L. 115–123","children":[],"tail":" added subsec. (f) and redesignated former subsec. (f) as (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/222"},"text":"Pub. L. 109–222","children":[],"tail":" substituted “section 7122(e)” for “section 7122(d)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s843/a/1"},"text":"Pub. L. 108–357, § 843(a)(1)","children":[],"tail":", substituted “make payment on” for “satisfy liability for payment of” and inserted “full or partial” after “facilitate”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s843/a/2"},"text":"Pub. L. 108–357, § 843(a)(2)","children":[],"tail":", inserted “full” before “payment” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s843/b"},"text":"Pub. L. 108–357, § 843(b)","children":[],"tail":", added subsec. (d) and redesignated former subsecs. (d) and (e) as (e) and (f), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s3467/a"},"text":"Pub. L. 105–206, § 3467(a)","children":[],"tail":", added subsec. (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" redesignated subsec. (d), relating to cross reference, as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s3467/a"},"text":"Pub. L. 105–206, § 3467(a)","children":[],"tail":", redesignated former subsec. (c), relating to administrative review, as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s3462/c/2"},"text":"Pub. L. 105–206, § 3462(c)(2)","children":[],"tail":", added subsec. (d), relating to cross reference."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" redesignated subsec. (d), relating to cross reference, as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/168/s201/b"},"text":"Pub. L. 104–168, § 201(b)","children":[],"tail":", amended par. (3) generally. Prior to amendment, par. (3) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—If the Secretary makes a determination that the financial condition of a taxpayer with whom the Secretary has entered into an agreement under subsection (a) has significantly changed, the Secretary may alter, modify, or terminate such agreement."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) ","children":[{"tag":"inline","attrib":{},"text":"Notice","children":[],"tail":".—Action may be taken by the Secretary under subparagraph (A) only if—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) notice of such determination is provided to the taxpayer no later than 30 days prior to the date of such action, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) such notice includes the reasons why the Secretary believes a significant change in the financial condition of the taxpayer has occurred.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/168/s201/a"},"text":"Pub. L. 104–168, § 201(a)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/168/s202/a"},"text":"Pub. L. 104–168, § 202(a)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46aee0a4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46aee0a5-3a70-11f1-a967-d35dac11796a"},"text"