{"tag":"section","attrib":{"id":"id46354466-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5312"},"text":null,"children":[{"tag":"num","attrib":{"value":"5312"},"text":"§ 5312.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Production and use of distilled spirits for experimental research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46354467-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5312/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scientific institutions and colleges of learning","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under such regulations as the Secretary may prescribe and on the filing of such bonds and applications as he may require, any scientific university, college of learning, or institution of scientific research may produce, receive, blend, treat, test, and store distilled spirits, without payment of tax, for experimental or research use but not for consumption (other than organoleptic tests) or sale, in such quantities as may be reasonably necessary for such purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46354468-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5312/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Experimental distilled spirits plants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under such regulations as the Secretary may prescribe and on the filing of such bonds and applications as he may require, experimental distilled spirits plants may, at the discretion of the Secretary, be established and operated for specific and limited periods of time solely for experimentation in, or development of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46354469-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5312/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sources of materials from which distilled spirits may be produced;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4635446a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5312/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" processes by which distilled spirits may be produced or refined; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4635446b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5312/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" industrial uses of distilled spirits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4635446c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5312/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to exempt","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may by regulations provide for the waiver of any provision of this chapter (other than this section) to the extent he deems necessary to effectuate the purposes of this section, except that he may not waive the payment of any tax on distilled spirits removed from any such university, college, institution, or plant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4635446d-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1375"},"text":"72 Stat. 1375","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4635446e-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4635446f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id46354470-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5312, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/659"},"text":"68A Stat. 659","children":[],"tail":", made a cross reference to remission and refund of tax on alcohol for loss or leakage, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/85/859"},"text":"Pub. L. 85–859","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those comprising this section were contained in prior sections of act ","children":[{"tag":"date","attrib":{"date":"1954-08-16"},"text":"Aug. 16, 1954","children":[],"tail":", prior to the gen