ildren":[],"tail":" be construed to affect treatment of certain transactions occurring, property acquired, or items of income, loss, deduction, or credit taken into account prior to "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", for purposes of determining liability for tax for periods ending after "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/s401/e"},"text":"section 401(e) of Pub. L. 115–141","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s23"},"text":"section 23 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id47a48bd6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Time for Joint Review","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/311/tIII/s321/c"},"text":"Pub. L. 108–311, title III, § 321(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-04"},"text":"Oct. 4, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1182"},"text":"118 Stat. 1182","children":[],"tail":", provided that the joint review required by section 8021(f)(2) of the Internal Revenue Code of 1986 ("},{"tag":"ref","attrib":{"href":"/us/usc/t26/s8021/f/2"},"text":"26 U.S.C. 8021(f)(2)","children":[],"tail":") to be made before "},{"tag":"date","attrib":{"date":"2004-06-01"},"text":"June 1, 2004","children":[],"tail":", was to be treated as timely if made before "},{"tag":"date","attrib":{"date":"2005-06-01"},"text":"June 1, 2005","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
