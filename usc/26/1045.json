{"tag":"section","attrib":{"id":"id44ae2f89-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1045"},"text":null,"children":[{"tag":"num","attrib":{"value":"1045"},"text":"§ 1045.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rollover of gain from qualified small business stock to another qualified small business stock","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44ae2f8a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1045/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonrecognition of gain","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any sale of qualified small business stock held by a taxpayer other than a corporation for more than 6 months and with respect to which such taxpayer elects the application of this section, gain from such sale shall be recognized only to the extent that the amount realized on such sale exceeds—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44ae2f8b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1045/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of any qualified small business stock purchased by the taxpayer during the 60-day period beginning on the date of such sale, reduced by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ae2f8c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1045/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any portion of such cost previously taken into account under this section.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"This section shall not apply to any gain which is treated as ordinary income for purposes of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44ae2f8d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1045/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44ae2f8e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1045/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified small business stock","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified small business stock” has the meaning given such term by section 1202(c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ae2f8f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1045/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchase","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A taxpayer shall be treated as having purchased any property if, but for paragraph (3), the unadjusted basis of such property in the hands of the taxpayer would be its cost (within the meaning of section 1012).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44ae2f90-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1045/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis adjustments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If gain from any sale is not recognized by reason of subsection (a), such gain shall be applied to reduce (in the order acquired) the basis for determining gain or loss of any qualified small business stock which is purchased by the taxpayer during the 60-day period described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44b09f91-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1045/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Holding period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of determining whether the nonrecognition of gain under subsection (a) applies to stock which is sold—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id44b09f92-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1045/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taxpayer’s holding period for such stock and the stock referred to in subsection (a)(1) shall be determined without regard to section 1223, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id44b09f93-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1045/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only the first 6 months of the taxpayer’s holding period for the stock referred to in subsection (a)(1) shall be taken into account for purposes of applying section 1202(c)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44b09f94-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1045/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain rules to apply","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rules similar to the rules of subsections (f), (g), (h), (i), (j), and (k) of section 1202 shall apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44b09f95-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/tIII/s313/a"},"text":"Pub. L. 105–34, title III, § 313(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/841"},"text":"111 Stat. 841","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tVI/s6005/f"},"text":"Pub. L. 105–206, title VI, § 6005(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/806"},"text":"112 Stat. 806","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44b09f96-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44b09f97-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44b09f98-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s6005/f/1"},"text":"Pub. L. 105–206, § 6005(f)(1)","children":[],"tail":", in introductory provisions, substituted “a taxpayer other than a corporation” for “an individual” and “such taxpayer” for “such individual”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/s6005/f/2"},"text":"Pub. L. 105–206, § 6005(f)(2)","children":[],"tail":", added par. (5)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id44b09f99-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id44b09f9a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206"},"text":"Pub. L. 105–206","children":[],"tail":" effective, except as otherwise provided, as if included in the provisions of the Taxpayer Relief Act of 1997, "},{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/s6024"},"text":"section 6024 of Pub. L. 105–206","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id44b09f9b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to sales after ","children":[{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/s313/c"},"text":"section 313(c) of Pub. L. 105–34","children":[],"tail":", set out as an Effective Date of 1997 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1016"},"text":"section 1016 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
