{"tag":"section","attrib":{"id":"id40c004c4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s44"},"text":null,"children":[{"tag":"num","attrib":{"value":"44"},"text":"§ 44.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures to provide access to disabled individuals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id40c004c5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s44/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of section 38, in the case of an eligible small business, the amount of the disabled access credit determined under this section for any taxable year shall be an amount equal to 50 percent of so much of the eligible access expenditures for the taxable year as exceed $250 but do not exceed $10,250.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40c004c6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s44/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible small business","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “eligible small business” means any person if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40c004c7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s44/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" either—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40c004c8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s44/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the gross receipts of such person for the preceding taxable year did not exceed $1,000,000, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40c004c9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s44/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a person to which subparagraph (A) does not apply, such person employed not more than 30 full-time employees during the preceding taxable year, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40c004ca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s44/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such person elects the application of this section for the taxable year.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of paragraph (1)(B), an employee shall be considered full-time if such employee is employed at least 30 hours per week for 20 or more calendar weeks in the taxable year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40c004cb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s44/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible access expenditures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40c004cc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s44/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible access expenditures” means amounts paid or incurred by an eligible small business for the purpose of enabling such eligible small business to comply with applicable requirements under the Americans With Disabilities Act of 1990 (as in effect on the date of the enactment of this section).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40c004cd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s44/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain expenditures included","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible access expenditures” includes amounts paid or incurred—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40c004ce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s44/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the purpose of removing architectural, communication, physical, or transportation barriers which prevent a business from being accessible to, or usable by, individuals with disabilities,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40c004cf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s44/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide qualified interpreters or other effective methods of making aurally delivered materials available to individuals with hearing impairments,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40c004d0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s44/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide qualified readers, taped texts, and other effective methods of making visually delivered materials available to individuals with visual impairments,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40c004d1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s44/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to acquire or modify equipment or devices for individuals with disabilities, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40c004d2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s44/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide other similar services, modifications, materials, or equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40c004d3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s44/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures must be reasonable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts paid or incurred for the purposes described in paragraph (2) shall include only expenditures which are reasonable and shall not include expenditures which are unnecessary to accomplish such purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40c004d4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s44/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenses in connection with new construction are not eligible","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible access expenditures” shall not include amounts described in paragraph (2)(A) which are paid or incurred in connection with any facility first placed in service after the date of the enactment of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40c004d5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s44/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures must meet standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible access expenditures” shall not include any amount unless the taxpayer establishes, to the satisfaction of the Secretary, that the resulting removal of any barrier (or the provision of any services, modifications, materials, or equipment) meets the standards promulgated by the Secretary with the concurrence of the Architectural and Transportation Barriers Compliance Board and set forth in regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40c004d6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s44/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of disability; special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40c004d7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s44/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “disability” has the same meaning as when used in the Americans With Disabilities Act of 1990 (as in effect on the date of the enactment of this section).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40c004d8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s44/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Controlled groups","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40c004d9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s44/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All members of the same controlled group of corporations (within the meaning of section 52(a)) and all persons under common control (within the meaning of section 52(b)) shall be treated as 1 person for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40c004da-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s44/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dollar limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall apportion the dollar limitation under subsection (a) among the members of any group described in subparagraph (A) in such manner as the Secretary shall by regulations prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40c004db-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s44/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnerships and S corporations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a partnership, the limitation under subsection (a) shall apply with respect to the partnership and each partner. A similar rule shall apply in the case of an S corporation and its shareholders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40c004dc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s44/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short years","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such adjustments as may be appropriate for purposes of paragraph (1) of subsection (b) if the preceding taxable year is a taxable year of less than 12 months.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40c004dd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s44/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gross receipts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Gross receipts for any taxable year shall be reduced by returns and allowances made during such year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40c004de-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s44/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of predecessors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The reference to any person in paragraph (1) of subsection (b) shall be treated as including a reference to any predecessor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40c004df-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s44/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial of double benefit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of the amount of the credit determined under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40c004e0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s44/d/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no deduction or credit shall be allowed for such amount under any other provision of this chapter, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40c004e1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s44/d/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no increase in the adjusted basis of any property shall result from such amount.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40c004e2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s44/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe regulations necessary to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id40c004e3-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11611/a"},"text":"Pub. L. 101–508, title XI, § 11611(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-501"},"text":"104 Stat. 1388–501","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id40c004e4-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id40c004e5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id40c004e6-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Americans With Disabilities Act of 1990, referred to in subsecs. (c)(1) and (d)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/336"},"text":"Pub. L. 101–336","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-07-26"},"text":"July 26, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/327"},"text":"104 Stat. 327","children":[],"tail":", which is classified principally to chapter 126 (§ 12101 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12101"},"text":"section 12101 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of the enactment of this section, referred to in subsecs. (c)(1), (4) and (d)(1), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id40c004e7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 44, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/12/tII/s208/a"},"text":"Pub. L. 94–12, title II, § 208(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-03-29"},"text":"Mar. 29, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/32"},"text":"89 Stat. 32","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/45/tIV/s401/a"},"text":"Pub. L. 94–45, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-06-30"},"text":"June 30, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/243"},"text":"89 Stat. 243","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":", related to purchase of new principal residence, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tIV/s474/m/1"},"text":"Pub. L. 98–369, div. A, title IV, § 474(m)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/833"},"text":"98 Stat. 833","children":[],"tail":", applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"1983-12-31"},"text":"Dec. 31, 1983","children":[],"tail":", and to carrybacks from such years."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 44 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s37"},"text":"section 37 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id40c004e8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id40c004e9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to expenditures paid or incurred after ","children":[{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/s11611/e/1"},"text":"section 11611(e)(1) of Pub. L. 101–508","children":[],"tail":", set out as an Effective Date of 1990 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s38"},"text":"section 38 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
