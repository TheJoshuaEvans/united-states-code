{"tag":"section","attrib":{"id":"id473b9054-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6751"},"text":null,"children":[{"tag":"num","attrib":{"value":"6751"},"text":"§ 6751.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedural requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id473b9055-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6751/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation of penalty included in notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall include with each notice of penalty under this title information with respect to the name of the penalty, the section of this title under which the penalty is imposed, and a computation of the penalty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id473b9056-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6751/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of assessment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id473b9057-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6751/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No penalty under this title shall be assessed unless the initial determination of such assessment is personally approved (in writing) by the immediate supervisor of the individual making such determination or such higher level official as the Secretary may designate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id473b9058-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6751/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall not apply to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id473b9059-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6751/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any addition to tax under section 6651, 6654, 6655, or 6662 (but only with respect to an addition to tax by reason of paragraph (9) or (10) of subsection (b) thereof); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id473b905a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6751/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other penalty automatically calculated through electronic means.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id473b905b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6751/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “penalty” includes any addition to tax or any additional amount.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id473b905c-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/tIII/s3306/a"},"text":"Pub. L. 105–206, title III, § 3306(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/744"},"text":"112 Stat. 744","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dEE/tII/s212/b/3"},"text":"Pub. L. 116–260, div. EE, title II, § 212(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3067"},"text":"134 Stat. 3067","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dT/tVI/s605/a/2/D"},"text":"Pub. L. 117–328, div. T, title VI, § 605(a)(2)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5395"},"text":"136 Stat. 5395","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id473b905d-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id473b905e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id473b905f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dEE/s212/b"},"text":"section 212(b) of div. EE of Pub. L. 116–260","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s63"},"text":"section 63 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id473b9060-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" substituted “paragraph (9) or (10) of subsection (b)” for “subsection (b)(9)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" substituted “6655, or 6662 (but only with respect to an addition to tax by reason of subsection (b)(9) thereof)” for “or 6655”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id473b9061-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id473b9062-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" applicable to contributions made after "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/s605/c/1"},"text":"section 605(c)(1) of Pub. L. 117–328","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s170"},"text":"section 170 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id473b9063-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"2020-12-31"},"text":"Dec. 31, 2020","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dEE/s212/d"},"text":"section 212(d) of div. EE of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s62"},"text":"section 62 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id473b9064-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/tIII/s3306/c"},"text":"Pub. L. 105–206, title III, § 3306(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/744"},"text":"112 Stat. 744","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tIII/s302/b"},"text":"Pub. L. 106–554, § 1(a)(7) [title III, § 302(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–632, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/554/s1/a/7/tIII/s302/b"},"text":"“The amendments made by this section [enacting this subchapter] shall apply to notices issued, and penalties assessed, after ","children":[{"tag":"date","attrib":{"date":"2001-06-30"},"text":"June 30, 2001","children":[],"tail":". In the case of any notice of penalty issued after "},{"tag":"date","attrib":{"date":"2001-06-30"},"text":"June 30, 2001","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"2003-07-01"},"text":"July 1, 2003","children":[],"tail":", the requirements of section 6751(a) of the Internal Revenue Code of 1986 shall be treated as met if such notice contains a telephone number at which the taxpayer can request a copy of the taxpayer’s assessment and payment history with respect to such penalty.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
