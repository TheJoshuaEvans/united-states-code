{"tag":"section","attrib":{"id":"id417c4fed-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s136"},"text":null,"children":[{"tag":"num","attrib":{"value":"136"},"text":"§ 136.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy conservation subsidies provided by public utilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id417c4fee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s136/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Gross income shall not include the value of any subsidy provided (directly or indirectly) by a public utility to a customer for the purchase or installation of any energy conservation measure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id417c4fef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s136/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial of double benefit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this subtitle, no deduction or credit shall be allowed for, or by reason of, any expenditure to the extent of the amount excluded under subsection (a) for any subsidy which was provided with respect to such expenditure. The adjusted basis of any property shall be reduced by the amount excluded under subsection (a) which was provided with respect to such property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id417c4ff0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s136/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy conservation measure","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id417c4ff1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s136/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “energy conservation measure” means any installation or modification primarily designed to reduce consumption of electricity or natural gas or to improve the management of energy demand with respect to a dwelling unit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id417c4ff2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s136/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id417c4ff3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s136/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dwelling unit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “dwelling unit” has the meaning given such term by section 280A(f)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id417c4ff4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s136/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public utility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “public utility” means a person engaged in the sale of electricity or natural gas to residential, commercial, or industrial customers for use by such customers. For purposes of the preceding sentence, the term “person” includes the Federal Government, a State or local government or any political subdivision thereof, or any instrumentality of any of the foregoing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id417c4ff5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s136/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to any payment to or from a qualified cogeneration facility or qualifying small power production facility pursuant to section 210 of the Public Utility Regulatory Policy Act of 1978.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id417c4ff6-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXIX/s1912/a"},"text":"Pub. L. 102–486, title XIX, § 1912(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3014"},"text":"106 Stat. 3014","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1617/a"},"text":"Pub. L. 104–188, title I, § 1617(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1858"},"text":"110 Stat. 1858","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id417c4ff7-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id417c4ff8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id417c4ff9-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 210 of the Public Utility Regulatory Policy Act of 1978, referred to in subsec. (d), probably means section 210 of the Public Utility Regulatory Policies Act of 1978, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/617"},"text":"Pub. L. 95–617","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s824a–3"},"text":"section 824a–3 of Title 16","children":[],"tail":", Conservation."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id417c4ffa-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 136 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s140"},"text":"section 140 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id417c4ffb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1617/b/1"},"text":"Pub. L. 104–188, § 1617(b)(1)","children":[],"tail":", reenacted heading without change and amended text generally, substituting present provisions for former provisions which consisted of general exclusion in par. (1) and limitation for exclusion on nonresidential property in par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1617/a"},"text":"Pub. L. 104–188, § 1617(a)","children":[],"tail":", substituted “energy demand with respect to a dwelling unit.” for “energy demand—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) with respect to a dwelling unit, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) on or after ","children":[{"tag":"date","attrib":{"date":"1995-01-01"},"text":"January 1, 1995","children":[],"tail":", with respect to property other than dwelling units."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The purchase and installation of specially defined energy property shall be treated as an energy conservation measure described in subparagraph (B).”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1617/b/2"},"text":"Pub. L. 104–188, § 1617(b)(2)","children":[],"tail":", struck out “and special rules” after “definitions” in heading, redesignated subpars. (B) and (C) as (A) and (B), respectively, and struck out former subpar. (A) which related to “specially defined energy property”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id417c4ffc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id417c4ffd-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1617/c"},"text":"Pub. L. 104–188, title I, § 1617(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1858"},"text":"110 Stat. 1858","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/188/tI/s1617/c"},"text":"“The amendments made by this section [amending this section] shall apply to amounts received after ","children":[{"tag":"date","attrib":{"date":"1996-12-31"},"text":"December 31, 1996","children":[],"tail":", unless received pursuant to a written binding contract in effect on "},{"tag":"date","attrib":{"date":"1995-09-13"},"text":"September 13, 1995","children":[],"tail":", and at all times thereafter.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id417c4ffe-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXIX/s1912/c"},"text":"Pub. L. 102–486, title XIX, § 1912(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3016"},"text":"106 Stat. 3016","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/486/tXIX/s1912/c"},"text":"“The amendments made by this section [enacting this section and renumbering former section 136 as 137] shall apply to amounts received after ","children":[{"tag":"date","attrib":{"date":"1992-12-31"},"text":"December 31, 1992","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
