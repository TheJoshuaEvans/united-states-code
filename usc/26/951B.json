{"tag":"section","attrib":{"id":"id447e93cd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s951B"},"text":null,"children":[{"tag":"num","attrib":{"value":"951B"},"text":"§ 951B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts included in gross income of foreign controlled United States shareholders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id447e93ce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s951B/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any foreign controlled United States shareholder of a foreign controlled foreign corporation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id447e93cf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s951B/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" this subpart (other than sections 951A, 951(b), and 957) shall be applied with respect to such shareholder (separately from, and in addition to, the application of this subpart without regard to this section)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id447e93d0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s951B/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by substituting “foreign controlled United States shareholder” for “United States shareholder” each place it appears therein, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id447e93d1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s951B/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by substituting “foreign controlled foreign corporation” for “controlled foreign corporation” each place it appears therein, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id447e93d2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s951B/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" section 951A (and such other provisions of this subpart as provided by the Secretary) shall be applied with respect to such shareholder—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id447e93d3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s951B/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by treating each reference to “United States shareholder” in such section as including a reference to such shareholder, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id447e93d4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s951B/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by treating each reference to “controlled foreign corporation” in such section as including a reference to such foreign controlled foreign corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id447e93d5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s951B/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign controlled United States shareholder","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “foreign controlled United States shareholder” means, with respect to any foreign corporation, any United States person which would be a United States shareholder with respect to such foreign corporation if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id447e93d6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s951B/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 951(b) were applied by substituting “more than 50 percent” for “10 percent or more”, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id447e93d7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s951B/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 958(b) were applied without regard to paragraph (4) thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id447e93d8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s951B/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign controlled foreign corporation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “foreign controlled foreign corporation” means a foreign corporation, other than a controlled foreign corporation, which would be a controlled foreign corporation if section 957(a) were applied—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id447e93d9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s951B/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by substituting “foreign controlled United States shareholders” for “United States shareholders”, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id447e93da-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s951B/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by substituting “section 958(b) (other than paragraph (4) thereof)” for “section 958(b)”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id447e93db-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s951B/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prescribe such regulations or other guidance as may be necessary or appropriate to carry out the purposes of this section, including regulations or other guidance—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id447e93dc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s951B/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to treat a foreign controlled United States shareholder or a foreign controlled foreign corporation as a United States shareholder or as a controlled foreign corporation, respectively, for purposes of provisions of this title other than this subpart (including any reporting requirement), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id447e93dd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s951B/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the treatment of foreign controlled foreign corporations that are passive foreign investment companies (as defined in section 1297).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id447e93de-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70353/b"},"text":"Pub. L. 119–21, title VII, § 70353(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/209"},"text":"139 Stat. 209","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id447e93df-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id447e93e0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id447e93e1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70353/d"},"text":"Pub. L. 119–21, title VII, § 70353(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/210"},"text":"139 Stat. 210","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/21/tVII/s70353/d"},"text":"“The amendments made by this section [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s958"},"text":"section 958 of this title","children":[],"tail":"] shall apply to taxable years of foreign corporations beginning after "},{"tag":"date","attrib":{"date":"2025-12-31"},"text":"December 31, 2025","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id447e93e2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70353/f"},"text":"Pub. L. 119–21, title VII, § 70353(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/210"},"text":"139 Stat. 210","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/21/tVII/s70353/f"},"text":"“The amendments made by this section [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s958"},"text":"section 958 of this title","children":[],"tail":"] shall not be construed to create any inference with respect to the proper application of any provision of the Internal Revenue Code of 1986 with respect to taxable years beginning before the taxable years to which such amendments apply.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id447e93e3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Special Rule","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70353/e"},"text":"Pub. L. 119–21, title VII, § 70353(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/210"},"text":"139 Stat. 210","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/21/tVII/s70353/e"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except to the extent provided by the Secretary of the Treasury (or the Secretary’s delegate), the effective date of any amendment to the Internal Revenue Code of 1986 shall be applied by treating references to United States shareholders as including references to foreign controlled United States shareholders, and by treating references to controlled foreign corporations as including references to foreign controlled foreign corporations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any term used in paragraph (1) which is used in subpart F of part III of subchapter N of chapter 1 of the Internal Revenue Code of 1986 (as amended by this section) shall have the meaning given such term in such subpart.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
