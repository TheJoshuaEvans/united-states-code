{"tag":"section","attrib":{"id":"id46840089-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6053"},"text":null,"children":[{"tag":"num","attrib":{"value":"6053"},"text":"§ 6053.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting of tips","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4684008a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6053/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports by employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every employee who, in the course of his employment by an employer, receives in any calendar month tips which are wages (as defined in section 3121(a) or section 3401(a)) or which are compensation (as defined in section 3231(e)) shall report all such tips in one or more written statements furnished to his employer on or before the 10th day following such month. Such statements shall be furnished by the employee under such regulations, at such other times before such 10th day, and in such form and manner, as may be prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4684008b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6053/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statements furnished by employers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the tax imposed by section 3101 or section 3201 (as the case may be) with respect to tips reported by an employee pursuant to subsection (a) exceeds the tax which can be collected by the employer pursuant to section 3102 or section 3202 (as the case may be), the employer shall furnish to the employee a written statement showing the amount of such excess. The statement required to be furnished pursuant to this subsection shall be furnished at such time, shall contain such other information, and shall be in such form as the Secretary may by regulations prescribe. When required by such regulations, a duplicate of any such statement shall be filed with the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4684008c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6053/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirements relating to certain large food or beverage establishments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4684008d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6053/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a large food or beverage establishment, each employer shall report to the Secretary, at such time and manner as the Secretary may prescribe by regulation, the following information with respect to each calendar year:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4684008e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6053/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The gross receipts of such establishment from the provision of food and beverages (other than nonallocable receipts).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4684008f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6053/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The aggregate amount of charge receipts (other than nonallocable receipts).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46840090-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6053/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The aggregate amount of charged tips shown on such charge receipts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46840091-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6053/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The sum of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id46840092-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6053/c/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amount reported by employees to the employer under subsection (a), plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46840093-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6053/c/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount the employer is required to report under section 6051 with respect to service charges of less than 10 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46840094-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6053/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to each employee, the amount allocated to such employee under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46840095-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6053/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Furnishing of statement to employees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each employer described in paragraph (1) shall furnish, in such manner as the Secretary may prescribe by regulations, to each employee of the large food or beverage establishment a written statement for each calendar year showing the following information:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46840096-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6053/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The name and address of such employer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46840097-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6053/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The name of the employee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46840098-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6053/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount allocated to the employee under paragraph (3) for all payroll periods ending within the calendar year.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Any statement under this paragraph shall be furnished to the employee during January of the calendar year following the calendar year for which such statement is made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46840099-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6053/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee allocation of 8 percent of gross receipts","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4684009a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6053/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraphs (1)(E) and (2)(C), the employer of a large food or beverage establishment shall allocate (as tips for purposes of the requirements of this subsection) among employees performing services during any payroll period who customarily receive tip income an amount equal to the excess of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4684009b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6053/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 8 percent of the gross receipts (other than nonallocable receipts) of such establishment for the payroll period, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4684009c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6053/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amount reported by such employees to the employer under subsection (a) for such period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4686719d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6053/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Method of allocation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The employer shall allocate the amount under subparagraph (A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4686719e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6053/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the basis of a good faith agreement by the employer and the employees, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4686719f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6053/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the absence of an agreement under clause (i), in the manner determined under regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id468671a0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6053/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" The Secretary may lower the percentage required to be allocated","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the petition of the employer or the majority of employees of such employer, the Secretary may reduce (but not below 2 percent) the percentage of gross receipts required to be allocated under subparagraph (A) where he determines that the percentage of gross receipts constituting tips is less than 8 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id468671a1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6053/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Large food or beverage establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “large food or beverage establishment” means any trade or business (or portion thereof)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id468671a2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6053/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which provides food or beverages,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id468671a3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6053/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to which the tipping of employees serving food or beverages by customers is customary, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id468671a4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6053/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which normally employed more than 10 employees on a typical business day during the preceding calendar year.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of subparagraph (C), rules similar to the rules of subsections (a) and (b) of section 52 shall apply under regulations prescribed by the Secretary, and an individual who owns 50 percent or more in value of the stock of the corporation operating the establishment shall not be treated as an employee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id468671a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6053/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employer not to be liable for wrong allocations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The employer shall not be liable to any person if any amount is improperly allocated under paragraph (3)(B) if such allocation is done in accordance with the regulations prescribed under paragraph (3)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id468671a6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6053/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonallocable receipts defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “nonallocable receipts” means receipts which are allocable to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id468671a7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6053/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carryout sales, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id468671a8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6053/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" services with respect to which a service charge of 10 percent or more is added.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id468671a9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6053/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to new businesses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe regulations for the application of this subsection to new businesses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id468671aa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6053/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certified professional employer organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of any report required by this subsection, in the case of a certified professional employer organization that is treated under section 3511 as the employer of a work site employee, the customer with respect to whom a work site employee performs services shall be the employer for purposes of reporting under this section and the certified professional employer organization shall furnish to the customer and the Secretary any information the Secretary prescribes as necessary to complete such reporting no later than such time as the Secretary shall prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id468671ab-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/97/tIII/s313/e/2/A"},"text":"Pub. L. 89–97, title III, § 313(e)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-07-30"},"text":"July 30, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/384"},"text":"79 Stat. 384","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/89/212/s2/d"},"text":"Pub. L. 89–212, § 2(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-09-29"},"text":"Sept. 29, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/859"},"text":"79 Stat. 859","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/248/tIII/s314/a"},"text":"Pub. L. 97–248, title III, § 314(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/603"},"text":"96 Stat. 603","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tX/s1072/a"},"text":"Pub. L. 98–369, div. A, title X, § 1072(a)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1052"},"text":"98 Stat. 1052","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dB/tII/s206/c/3"},"text":"Pub. L. 113–295, div. B, title II, § 206(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4071"},"text":"128 Stat. 4071","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id468671ac-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id468671ad-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id468671ae-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (c)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" added par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (c)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s1072/a"},"text":"Pub. L. 98–369, § 1072(a)","children":[],"tail":", substituted “Upon the petition of the employer or the majority of employees of such employer, the Secretary” for “The Secretary” and “2 percent” for “5 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s1072/c/1"},"text":"Pub. L. 98–369, § 1072(c)(1)","children":[],"tail":", inserted provision that an individual who owns 50 percent or more in value of the stock of the corporation operating the establishment shall not be treated as an employee."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248"},"text":"Pub. L. 97–248","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/212/s2/d/1"},"text":"Pub. L. 89–212, § 2(d)(1)","children":[],"tail":", inserted “or which are compensation (as defined in section 3231(e)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/212/s2/d/2"},"text":"Pub. L. 89–212, § 2(d)(2)","children":[],"tail":", inserted “or section 3201 (as the case may be)” and “or section 3202 (as the case may be)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id468671af-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id468671b0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" applicable with respect to wages for services performed on or after Jan. 1 of the first calendar year beginning more than 12 months after "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/s206/g/1"},"text":"section 206(g)(1) of Pub. L. 113–295","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s3302"},"text":"section 3302 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id468671b1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tX/s1072/c/2"},"text":"Pub. L. 98–369, div. A, title X, § 1072(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1052"},"text":"98 Stat. 1052","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/369/dA/tX/s1072/c/2"},"text":"“The amendment made by paragraph (1) [amending this section] shall apply to calendar years beginning after ","children":[{"tag":"date","attrib":{"date":"1982-12-31"},"text":"December 31, 1982","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id468671b2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1982 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/tIII/s314/e"},"text":"Pub. L. 97–248, title III, § 314(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/605"},"text":"96 Stat. 605","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section [amending this section and sections 6001 and 6678 of this title, and enacting provisions set out as a note under this section] shall apply to calendar years beginning after ","children":[{"tag":"date","attrib":{"date":"1982-12-31"},"text":"December 31, 1982","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special rule for 1983","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of section 6053(c) of the Internal Revenue Code of 1986 [formerly I.R.C. 1954], in the case of payroll periods ending before ","children":[{"tag":"date","attrib":{"date":"1983-04-01"},"text":"April 1, 1983","children":[],"tail":", an employer must only report with respect to such periods—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts described in subparagraphs (A), (B), (C), and (D) of section 6053(c)(1) of such Code, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, and identification number, wages paid to, and tips reported by, each tipped employee.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id468671b3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1965 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/212"},"text":"Pub. L. 89–212","children":[],"tail":" effective only with respect to tips received after 1965, see "},{"tag":"ref","attrib":{"href":"/us/pl/89/212/s6"},"text":"section 6 of Pub. L. 89–212","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s3201"},"text":"section 3201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id468671b4-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/97/tIII/s313/f"},"text":"Pub. L. 89–97, title III, § 313(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-07-30"},"text":"July 30, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/385"},"text":"79 Stat. 385","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/89/97/tIII/s313/f"},"text":"“The amendments made by this section [enacting this section and amending sections 451, 3102, 3121, 3401, 3402, 6051, 6652, and 6674 of this title and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s409"},"text":"section 409 of Title 42","children":[],"tail":", The Public Health and Welfare] shall apply only with respect to tips received by employees after 1965.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id468671b5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tX/s1072/b"},"text":"Pub. L. 98–369, div. A, title X, § 1072(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1052"},"text":"98 Stat. 1052","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/369/dA/tX/s1072/b"},"text":"“The Secretary of the Treasury shall prescribe by regulations within 1 year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":"] the applicable recordkeeping requirements for tipped employees.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id468671b6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Threat of Audit Prohibited To Coerce Tip Reporting Alternative Commitment Agreements","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/tIII/s3414"},"text":"Pub. L. 105–206, title III, § 3414","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/755"},"text":"112 Stat. 755","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/206/tIII/s3414"},"text":"“The Secretary of the Treasury or the Secretary’s delegate shall instruct employees of the Internal Revenue Service that they may not threaten to audit any taxpayer in an attempt to coerce the taxpayer into entering into a Tip Reporting Alternative Commitment Agreement.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id468671b7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Modification of Tips Allocation Method","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXV/s1571"},"text":"Pub. L. 99–514, title XV, § 1571","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2765"},"text":"100 Stat. 2765","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/tXV/s1571"},"text":"“Effective for any payroll period beginning after ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":", an establishment may utilize the optional method of tips allocation described in the last sentence of section 31.6053–3(f)(1)(iv) of the Internal Revenue Regulations only if such establishment employs less than the equivalent of 25 full-time employees during such payroll period.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id468671b8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study of Tip Compliance","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/tIII/s314/c"},"text":"Pub. L. 97–248, title III, § 314(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/605"},"text":"96 Stat. 605","children":[],"tail":", directed Secretary of the Treasury or his delegate to submit before "},{"tag":"date","attrib":{"date":"1987-01-01"},"text":"Jan. 1, 1987","children":[],"tail":", to Committee on Ways and Means of House of Representatives and to Committee on Finance of Senate a report with respect to tip compliance in food and beverage service industry. Such study to include, but not be limited to, an analysis of tipping patterns, tip-sharing arrangements, and tip compliance patterns."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
