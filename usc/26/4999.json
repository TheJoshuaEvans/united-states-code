{"tag":"section","attrib":{"id":"id46118ff6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4999"},"text":null,"children":[{"tag":"num","attrib":{"value":"4999"},"text":"§ 4999.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Golden parachute payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46118ff7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4999/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby imposed on any person who receives an excess parachute payment a tax equal to 20 percent of the amount of such payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46118ff8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4999/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excess parachute payment defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “excess parachute payment” has the meaning given to such term by section 280G(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46118ff9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4999/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative provisions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46118ffa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4999/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withholding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any excess parachute payment which is wages (within the meaning of section 3401) the amount deducted and withheld under section 3402 shall be increased by the amount of the tax imposed by this section on such payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46118ffb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4999/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other administrative provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subtitle F, any tax imposed by this section shall be treated as a tax imposed by subtitle A.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46118ffc-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s67/b/1"},"text":"Pub. L. 98–369, div. A, title I, § 67(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/587"},"text":"98 Stat. 587","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46118ffd-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46118ffe-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id46118fff-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to payments under agreements entered into or renewed after ","children":[{"tag":"date","attrib":{"date":"1984-06-14"},"text":"June 14, 1984","children":[],"tail":", in taxable years ending after such date, with contracts entered into before "},{"tag":"date","attrib":{"date":"1984-06-15"},"text":"June 15, 1984","children":[],"tail":", which are amended after "},{"tag":"date","attrib":{"date":"1984-06-14"},"text":"June 14, 1984","children":[],"tail":", in any significant relevant aspect to be treated as a contract entered into after "},{"tag":"date","attrib":{"date":"1984-06-14"},"text":"June 14, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s67/e"},"text":"section 67(e) of Pub. L. 98–369","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s280G"},"text":"section 280G of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
