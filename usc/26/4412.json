{"tag":"section","attrib":{"id":"id45d5e618-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4412"},"text":null,"children":[{"tag":"num","attrib":{"value":"4412"},"text":"§ 4412.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45d5e619-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4412/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each person required to pay a special tax under this subchapter shall register with the official in charge of the internal revenue district—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45d5e61a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4412/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" his name and place of residence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45d5e61b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4412/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if he is liable for tax under subchapter A, each place of business where the activity which makes him so liable is carried on, and the name and place of residence of each person who is engaged in receiving wagers for him or on his behalf; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45d5e61c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4412/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if he is engaged in receiving wagers for or on behalf of any person liable for tax under subchapter A, the name and place of residence of each such person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45d5e61d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4412/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Firm or company","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Where subsection (a) requires the name and place of residence of a firm or company to be registered, the names and places of residence of the several persons constituting the firm or company shall be registered.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45d5e61e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4412/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplemental information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with regulations prescribed by the Secretary, the Secretary may require from time to time such supplemental information from any person required to register under this section as may be needful to the enforcement of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45d5e61f-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/527"},"text":"68A Stat. 527","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/I"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(I)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1835"},"text":"90 Stat. 1835","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45d5e620-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45d5e621-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45d5e622-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" substituted “the Secretary may” for “he or his delegate may”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45d5e623-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id45d5e624-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Persons Paying Tax and Registering Before ","children":[{"tag":"date","attrib":{"date":"1974-12-01"},"text":"December 1, 1974","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"Persons registered before ","children":[{"tag":"date","attrib":{"date":"1974-12-01"},"text":"Dec. 1, 1974","children":[],"tail":" under this section (as in effect on "},{"tag":"date","attrib":{"date":"1974-07-01"},"text":"July 1, 1974","children":[],"tail":") for the year ending "},{"tag":"date","attrib":{"date":"1975-06-30"},"text":"June 30, 1975","children":[],"tail":", not required to reregister under this section for such year, see "},{"tag":"ref","attrib":{"href":"/us/pl/93/499/s3/d/2"},"text":"section 3(d)(2) of Pub. L. 93–499","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4411"},"text":"section 4411 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
