{"tag":"section","attrib":{"id":"id46fb2c65-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6430"},"text":null,"children":[{"tag":"num","attrib":{"value":"6430"},"text":"§ 6430.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of tax imposed at Leaking Underground Storage Tank Trust Fund financing rate","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"No refunds, credits, or payments shall be made under this subchapter for any tax imposed at the Leaking Underground Storage Tank Trust Fund financing rate, except in the case of fuels—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46fb2c66-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6430/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which are exempt from tax under section 4081(a) by reason of section 4082(f)(2),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46fb2c67-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6430/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which are exempt from tax under section 4041(d) by reason of the last sentence of paragraph (5) thereof,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46fb2c68-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6430/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to which the rate increase under section 4081(a)(2)(B) is zero by reason of section 4082(e)(2), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46fb2c69-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6430/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which are removed as eligible indelibly dyed diesel fuel or kerosene under section 6435.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46fb2c6a-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXIII/s1362/b/3/A"},"text":"Pub. L. 109–58, title XIII, § 1362(b)(3)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1059"},"text":"119 Stat. 1059","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/172/s6/d/2/D"},"text":"Pub. L. 110–172, § 6(d)(2)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-29"},"text":"Dec. 29, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2481"},"text":"121 Stat. 2481","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70525/b/2"},"text":"Pub. L. 119–21, title VII, § 70525(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/282"},"text":"139 Stat. 282","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46fb2c6b-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46fb2c6c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id46fb2c6d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6430, added ","children":[{"tag":"ref","attrib