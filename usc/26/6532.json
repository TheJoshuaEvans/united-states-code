{"tag":"section","attrib":{"id":"id470bf5c6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6532"},"text":null,"children":[{"tag":"num","attrib":{"value":"6532"},"text":"§ 6532.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periods of limitation on suits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id470bf5c7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6532/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suits by taxpayers for refund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id470bf5c8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6532/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No suit or proceeding under section 7422(a) for the recovery of any internal revenue tax, penalty, or other sum, shall be begun before the expiration of 6 months from the date of filing the claim required under such section unless the Secretary renders a decision thereon within that time, nor after the expiration of 2 years from the date of mailing by certified mail or registered mail by the Secretary to the taxpayer of a notice of the disallowance of the part of the claim to which the suit or proceeding relates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id470bf5c9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6532/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of time","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The 2-year period prescribed in paragraph (1) shall be extended for such period as may be agreed upon in writing between the taxpayer and the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id470bf5ca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6532/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of notice of disallowance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any person files a written waiver of the requirement that he be mailed a notice of disallowance, the 2-year period prescribed in paragraph (1) shall begin on the date such waiver is filed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id470bf5cb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6532/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reconsideration after mailing of notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any consideration, reconsideration, or action by the Secretary with respect to such claim following the mailing of a notice by certified mail or registered mail of disallowance shall not operate to extend the period within which suit may be begun.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id470bf5cc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6532/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For substitution of 120-day period for the 6-month period contained in paragraph (1) in a title 11 case, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s505/a/2"},"text":"section 505(a)(2) of title 11","children":[],"tail":" of the United States Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id470bf5cd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6532/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suits by United States for recovery of erroneous refunds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Recovery of an erroneous refund by suit under section 7405 shall be allowed only if such suit is begun within 2 years after the making of such refund, except that such suit may be brought at any time within 5 years from the making of the refund if it appears that any part of the refund was induced by fraud or misrepresentation of a material fact.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id470e3ebe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6532/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suits by persons other than taxpayers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id470e3ebf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6532/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided by paragraph (2), no suit or proceeding under section 7426 shall be begun after the expiration of 2 years from the date of the levy or agreement giving rise to such action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id470e3ec0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6532/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period when claim is filed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a request is made for the return of property described in section 6343(b), the 2-year period prescribed in paragraph (1) shall be extended for a period of 12 months from the date of filing of such request or for a period of 6 months from the date of mailing by registered or certified mail by the Secretary to the person making such request of a notice of disallowance of the part of the request to which the action relates, whichever is shorter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id470e3ec1-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/816"},"text":"68A Stat. 816","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/866/tI/s89/b"},"text":"Pub. L. 85–866, title I, § 89(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1665"},"text":"72 Stat. 1665","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/719/tI/s110/b"},"text":"Pub. L. 89–719, title I, § 110(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1144"},"text":"80 Stat. 1144","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":