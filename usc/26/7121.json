{"tag":"section","attrib":{"id":"id4742bcde-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7121"},"text":null,"children":[{"tag":"num","attrib":{"value":"7121"},"text":"§ 7121.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Closing agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4742bcdf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7121/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to enter into an agreement in writing with any person relating to the liability of such person (or of the person or estate for whom he acts) in respect of any internal revenue tax for any taxable period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4742bce0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7121/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finality","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If such agreement is approved by the Secretary (within such time as may be stated in such agreement, or later agreed to) such agreement shall be final and conclusive, and, except upon a showing of fraud or malfeasance, or misrepresentation of a material fact—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4742bce1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7121/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the case shall not be reopened as to the matters agreed upon or the agreement modified by any officer, employee, or agent of the United States, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4742bce2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7121/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any suit, action, or proceeding, such agreement, or any determination, assessment, collection, payment, abatement, refund, or credit made in accordance therewith, shall not be annulled, modified, set aside, or disregarded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4742bce3-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/849"},"text":"68A Stat. 849","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4742bce4-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4742bce5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4742bce6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
