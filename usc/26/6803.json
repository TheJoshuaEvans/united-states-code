{"tag":"section","attrib":{"id":"id473e017c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6803"},"text":null,"children":[{"tag":"num","attrib":{"value":"6803"},"text":"§ 6803.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accounting and safeguarding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id473e017d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6803/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bond","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In cases coming within the provisions of paragraph (2) of section 6802, the Secretary may require a bond, with sufficient sureties, in a sum to be fixed by the Secretary, conditioned for the faithful return, whenever so required, of all quantities or amounts undisposed of and for the payment monthly for all quantities or amounts sold or not remaining on hand.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id473e017e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6803/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may from time to time make such regulations as he may find necessary to insure the safekeeping or prevent the illegal use of all adhesive stamps referred to in paragraph (2) of section 6802.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id473e017f-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/830"},"text":"68A Stat. 830","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/310/tII/s230/a"},"text":"Pub. L. 92–310, title II, § 230(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-06-06"},"text":"June 6, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/209"},"text":"86 Stat. 209","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/a/37"},"text":"Pub. L. 94–455, title XIX, § 1906(a)(37)","children":[],"tail":", (b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1829"},"text":"90 Stat. 1829","children":[],"tail":", 1834.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id473e0180-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id473e0181-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id473e0182-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" redesignated subsec. (b)(1) as (a), substituted “paragraph (2)” for “paragraph (2) or (3)”, and struck out “or his delegate” after “Secretary” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" redesignated par. (2) as entire subsection, struck out “or his delegate” after “Secretary” and substituted “paragraph (2)” for “paragraphs (2) and (3)”. Par. (1) redesignated subsec. (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/310"},"text":"Pub. L. 92–310","children":[],"tail":" repealed subsec. (a) which related to bonds, deposits of receipts, and accounts of postmasters, and which required the Postmaster General to transfer all receipts to the Treasury."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
