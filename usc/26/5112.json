{"tag":"section","attrib":{"id":"id4626ec19-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5112"},"text":null,"children":[{"tag":"num","attrib":{"value":"5112"},"text":"§ 5112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration and regulation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Every person claiming drawback under this subpart shall register annually with the Secretary; keep such books and records as may be necessary to establish the fact that distilled spirits received by him and on which the tax has been determined were used in the manufacture or production of medicines, medicinal preparations, food products, flavors, flavoring extracts, or perfume, which were unfit for use for beverage purposes; and be subject to such rules and regulations in relation thereto as the Secretary shall prescribe to secure the Treasury against frauds.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4626ec1a-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1345"},"text":"72 Stat. 1345","children":[],"tail":", § 5132; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/tI/s136/b"},"text":"Pub. L. 103–465, title I, § 136(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":"