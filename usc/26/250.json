{"tag":"section","attrib":{"id":"id4246f31e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250"},"text":null,"children":[{"tag":"num","attrib":{"value":"250"},"text":"§ 250.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign-derived deduction eligible income and net CFC tested income","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4246f31f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowance of deduction","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4246f320-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a domestic corporation for any taxable year, there shall be allowed as a deduction an amount equal to the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4246f321-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 33.34 percent of the foreign-derived deduction eligible income of such domestic corporation for such taxable year, plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4246f322-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 40 percent of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4246f323-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the net CFC tested income amount (if any) which is included in the gross income of such domestic corporation under section 951A for such taxable year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4246f324-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount treated as a dividend received by such corporation under section 78 which is attributable to the amount described in clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4246f325-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation based on taxable income","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4246f326-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, for any taxable year—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4246f327-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sum of the foreign-derived deduction eligible income and the net CFC tested income amount otherwise taken into account by the domestic corporation under paragraph (1), exceeds","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4246f328-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taxable income of the domestic corporation (determined without regard to this section),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then the amount of the foreign-derived deduction eligible income and the net CFC tested income amount so taken into account shall be reduced as provided in subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4246f329-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subparagraph (A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4246f32a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign-derived deduction eligible income shall be reduced by an amount which bears the same ratio to the excess described in subparagraph (A) as such foreign-derived deduction eligible income bears to the sum described in subparagraph (A)(i), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4246f32b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the net CFC tested income amount shall be reduced by the remainder of such excess.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4246f32c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign-derived deduction eligible income","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4246f32d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign-derived deduction eligible income","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “foreign-derived deduction eligible income” means, with respect to any taxpayer for any taxable year, any deduction eligible income of such taxpayer which is derived in connection with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4246f32e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" property—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4246f32f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is sold by the taxpayer to any person who is not a United States person, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4246f330-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which the taxpayer establishes to the satisfaction of the Secretary is for a foreign use, or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4246f331-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" services provided by the taxpayer which the taxpayer establishes to the satisfaction of the Secretary are provided to any person, or with respect to property, not located within the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4246f332-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules relating to foreign use property or services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4246f333-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “foreign use” means any use, consumption, or disposition which is not within the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4246f334-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property or services provided to domestic intermediaries","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4246f335-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a taxpayer sells property to another person (other than a related party) for further manufacture or other modification within the United States, such property shall not be treated as sold for a foreign use even if such other person subsequently uses such property for a foreign use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4246f336-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a taxpayer provides services to another person (other than a related party) located within the United States, such services shall not be treated as described in paragraph (1)(B) even if such other person uses such services in providing services which are so described.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4246f337-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules with respect to related party transactions","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4246f338-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sales to related parties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If property is sold to a related party who is not a United States person, such sale shall not be treated as for a foreign use unless—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4246f339-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/b/2/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such property is ultimately sold by a related party, or used by a related party in connection with property which is sold or the provision of services, to another person who is an unrelated party who is not a United States person, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4246f33a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/b/2/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taxpayer establishes to the satisfaction of the Secretary that such property is for a foreign use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":" For purposes of this clause, a sale of property shall be treated as a sale of each of the components thereof.","children":[],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4246f33b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service provided to related parties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a service is provided to a related party who is not located in the United States, such service shall not be treated described ","children":[{"tag":"ref","attrib":{"idref":"fn002094"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002094"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be preceded by “as”."}],"tail":" in subparagraph (A)(ii) "},{"tag":"ref","attrib":{"idref":"fn002095"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002095"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “(B)(ii)”."}],"tail":" unless the taxpayer established to the satisfaction of the Secretary that such service is not substantially similar to services provided by such related party to persons located within the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4246f33c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Related party","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this paragraph, the term “related party” means any member of an affiliated group as defined in section 1504(a), determined—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4246f33d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by substituting “more than 50 percent” for “at least 80 percent” each place it appears, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4246f33e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without regard to paragraphs (2) and (3) of section 1504(b).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Any person (other than a corporation) shall be treated as a member of such group if such person is controlled by members of such group (including any entity treated as a member of such group by reason of this sentence) or controls any such member. For purposes of the preceding sentence, control shall be determined under the rules of section 954(d)(3).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4246f33f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sold","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection (other than paragraph (3)(A)(i)(VII)), the terms “sold”, “sells”, and “sale” shall include any lease, license, exchange, or other disposition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4246f340-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deduction eligible income","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4246f341-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “deduction eligible income” means, with respect to any domestic corporation, the excess (if any) of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4246f342-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" gross income of such corporation determined without regard to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4246f343-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/b/3/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amount included in the gross income of such corporation under section 951(a)(1),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4246f344-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/b/3/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the net CFC tested income included in the gross income of such corporation under section 951A,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4246f345-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/b/3/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any financial services income (as defined in section 904(d)(2)(D)) of such corporation,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4246f346-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/b/3/A/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any dividend received from a corporation which is a controlled foreign corporation of such domestic corporation,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4246f347-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/b/3/A/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any domestic oil and gas extraction income of such corporation,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4246f348-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/b/3/A/i/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any foreign branch income (as defined in section 904(d)(2)(J)), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4246f349-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/b/3/A/i/VII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VII"},"text":"(VII)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" except as otherwise provided by the Secretary, any income and gain from the sale or other disposition (including pursuant to the deemed sale or other deemed disposition or a transaction subject to section 367(d)) of—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id4246f34a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/b/3/A/i/VII/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intangible property (as defined in section 367(d)(4)), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id4246f34b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/b/3/A/i/VII/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other property of a type that is subject to depreciation, amortization, or depletion by the seller, over","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4246f34c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expenses and deductions (including taxes), other than interest expense and research or experimental expenditures, properly allocable to such gross income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4246f34d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Domestic oil and gas extraction income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A), the term “domestic oil and gas extraction income” means income described in section 907(c)(1), determined by substituting “within the United States” for “without the United States”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4246f34e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s250/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such regulations or other guidance as may be necessary or appropriate to carry out the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4246f34f-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s14202/a"},"text":"Pub. L. 115–97, title I, § 14202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2213"},"text":"131 Stat. 2213","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII"},"text":"Pub. L. 119–21, title VII","children":[],"tail":", §§ 70321(a), 70322(a)(1), (2), (b)(1), 70323(