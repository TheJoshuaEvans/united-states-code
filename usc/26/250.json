rib":{},"text":"Subsec. (b)(3)(A)(i)(VII). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70322/a/1"},"text":"Pub. L. 119–21, § 70322(a)(1)","children":[],"tail":", added subcl. (VII)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70322/b/1"},"text":"Pub. L. 119–21, § 70322(b)(1)","children":[],"tail":", amended cl. (ii) generally. Prior to amendment, cl. (ii) read as follows: “the deductions (including taxes) properly allocable to such gross income.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70322/a/2"},"text":"Pub. L. 119–21, § 70322(a)(2)","children":[],"tail":", inserted “(other than paragraph (3)(A)(i)(VII))” after “For purposes of this subsection”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4246f354-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4246f355-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70321/b"},"text":"Pub. L. 119–21, title VII, § 70321(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/204"},"text":"139 Stat. 204","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/21/tVII/s70321/b"},"text":"“The amendments made by this section [amending this section] shall apply to taxable years beginning aft