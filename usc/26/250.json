substituted “Foreign-derived deduction eligible” for “Foreign-derived intangible” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70323/a/3/A/ii"},"text":"Pub. L. 119–21, § 70323(a)(3)(A)(ii)","children":[],"tail":", substituted “net CFC tested income” for “global intangible low-taxed income” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70323/b/1"},"text":"Pub. L. 119–21, § 70323(b)(1)","children":[],"tail":", substituted “foreign-derived deduction eligible income” for “foreign-derived intangible income”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70321/a/1"},"text":"Pub. L. 119–21, § 70321(a)(1)","children":[],"tail":", substituted “33.34 percent” for “37.5 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70321/a/2"},"text":"Pub. L. 119–21, § 70321(a)(2)","children":[],"tail":", substituted “40 percent” for “50 percent” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70323/a/3/A/i"},"text":"Pub. L. 119–21, § 70323(a)(3)(A)(i)","children":[],"tail":", substituted “net CFC tested income” for “global intangible low-taxed income”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70323/b/2/A"},"text":"Pub. L. 119–21, § 70323(b)(2)(A)","children":[],"tail":", substituted “foreign-derived deduction eligible income” for “foreign-derived intangible income” in cl. (i) and concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70323/a/3/A/i"},"text":"Pub. L. 119–21, § 70323(a)(3)(A)(i)","