{"tag":"section","attrib":{"id":"id43fdca76-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706"},"text":null,"children":[{"tag":"num","attrib":{"value":"706"},"text":"§ 706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable years of partner and partnership","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id43fdca77-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Year in which partnership income is includible","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In computing the taxable income of a partner for a taxable year, the inclusions required by section 702 and section 707(c) with respect to a partnership shall be based on the income, gain, loss, deduction, or credit of the partnership for any taxable year of the partnership ending within or with the taxable year of the partner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43fdca78-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable year","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43fdca79-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnership’s taxable year","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43fdca7a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnership treated as taxpayer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The taxable year of a partnership shall be determined as though the partnership were a taxpayer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43fdca7b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable year determined by reference to partners","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subparagraph (C), a partnership shall not have a taxable year other than—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id43fdca7c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the majority interest taxable year (as defined in paragraph (4)),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43fdca7d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if there is no taxable year described in clause (i), the taxable year of all the principal partners of the partnership, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43fdca7e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if there is no taxable year described in clause (i) or (ii), the calendar year unless the Secretary by regulations prescribes another period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43fdca7f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Business purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A partnership may have a taxable year not described in subparagraph (B) if it establishes, to the satisfaction of the Secretary, a business purpose therefor. For purposes of this subparagraph, any deferral of income to partners shall not be treated as a business purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43fdca80-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partner’s taxable year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A partner may not change to a taxable year other than that of a partnership in which he is a principal partner unless he establishes, to the satisfaction of the Secretary, a business purpose therefor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43fdca81-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Principal partner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of this subsection, a principal partner is a partner having an interest of 5 percent or more in partnership profits or capital.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43fdca82-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Majority interest taxable year; limitation on required changes","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43fdca83-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Majority interest taxable year defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1)(B)(i)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id43fdca84-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “majority interest taxable year” means the taxable year (if any) which, on each testing day, constituted the taxable year of 1 or more partners having (on such day) an aggregate interest in partnership profits and capital of more than 50 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43fdca85-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Testing days","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The testing days shall be—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id43fdca86-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/b/4/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 1st day of the partnership taxable year (determined without regard to clause (i)), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id43fdca87-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/b/4/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the days during such representative period as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43fdca88-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Further change not required for 3 years","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in regulations necessary to prevent the avoidance of this section, if, by reason of paragraph (1)(B)(i), the taxable year of a partnership is changed, such partnership shall not be required to change to another taxable year for either of the 2 taxable years following the year of change.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43fdca89-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application with other sections","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in regulations, for purposes of determining the taxable year to which a partnership is required to change by reason of this subsection, changes in taxable years of other persons required by this subsection, section 441(i), section 584(i), section 644, or section 1378(a) shall be taken into account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43fdca8a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Closing of partnership year","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43fdca8b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except in the case of a termination of a partnership and except as provided in paragraph (2) of this subsection, the taxable year of a partnership shall not close as the result of the death of a partner, the entry of a new partner, the liquidation of a partner’s interest in the partnership, or the sale or exchange of a partner’s interest in the partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43fdca8c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of dispositions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43fdca8d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of entire interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The taxable year of a partnership shall close with respect to a partner whose entire interest in the partnership terminates (whether by reason of death, liquidation, or otherwise).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43fdca8e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of less than entire interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The taxable year of a partnership shall not close (other than at the end of a partnership’s taxable year as determined under subsection (b)(1)) with respect to a partner who sells or exchanges less than his entire interest in the partnership or with respect to a partner whose interest is reduced (whether by entry of a new partner, partial liquidation of a partner’s interest, gift, or otherwise).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43fdca8f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of distributive share when partner’s interest changes","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43fdca90-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraphs (2) and (3), if during any taxable year of the partnership there is a change in any partner’s interest in the partnership, each partner’s distributive share of any item of income, gain, loss, deduction, or credit of the partnership for such taxable year shall be determined by the use of any method prescribed by the Secretary by regulations which takes into account the varying interests of the partners in the partnership during such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43fdca91-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain cash basis items prorated over period to which attributable","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43fdca92-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If during any taxable year of the partnership there is a change in any partner’s interest in the partnership, then (except to the extent provided in regulations) each partner’s distributive share of any allocable cash basis item shall be determined—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id43fdca93-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by assigning the appropriate portion of such item to each day in the period to which it is attributable, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43fdca94-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by allocating the portion assigned to any such day among the partners in proportion to their interests in the partnership at the close of such day.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43fdca95-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocable cash basis item","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this paragraph, the term “allocable cash basis item” means any of the following items with respect to which the partnership uses the cash receipts and disbursements method of accounting:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id43fdca96-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43fdca97-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Taxes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43fdca98-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/d/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payments for services or for the use of property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43fdca99-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/d/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other item of a kind specified in regulations prescribed by the Secretary as being an item with respect to which the application of this paragraph is appropriate to avoid significant misstatements of the income of the partners.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43fdca9a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Items attributable to periods not within taxable year","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If any portion of any allocable cash basis item is attributable to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id43fdca9b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/d/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any period before the beginning of the taxable year, such portion shall be assigned under subparagraph (A)(i) to the first day of the taxable year, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43fdca9c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/d/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any period after the close of the taxable year, such portion shall be assigned under subparagraph (A)(i) to the last day of the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43fdca9d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of deductible items attributable to prior periods","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If any portion of a deductible cash basis item is assigned under subparagraph (C)(i) to the first day of any taxable year—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id43fdca9e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/d/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such portion shall be allocated among persons who are partners in the partnership during the period to which such portion is attributable in accordance with their varying interests in the partnership during such period, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43fdca9f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/d/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amount allocated under clause (i) to a person who is not a partner in the partnership on such first day shall be capitalized by the partnership and treated in the manner provided for in section 755.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43fdcaa0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Items attributable to interest in lower tier partnership prorated over entire taxable year","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43fdcaa1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during any taxable year of the partnership there is a change in any partner’s interest in the partnership (hereinafter in this paragraph referred to as the “upper tier partnership”), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43fdcaa2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such partnership is a partner in another partnership (hereinafter in this paragraph referred to as the “lower tier partnership”),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then (except to the extent provided in regulations) each partner’s distributive share of any item of the upper tier partnership attributable to the lower tier partnership shall be determined by assigning the appropriate portion (determined by applying principles similar to the principles of subparagraphs (C) and (D) of paragraph (2)) of each such item to the appropriate days during which the upper tier partnership is a partner in the lower tier partnership and by allocating the portion assigned to any such day among the partners in proportion to their interests in the upper tier partnership at the close of such day.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43fdcaa3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s706/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable year determined without regard to subsection (c)(2)(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the taxable year of a partnership shall be determined without regard to subsection (c)(2)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id43fdcaa4-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/242"},"text":"68A Stat. 242","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tII/s213/c/1"},"text":"Pub. L. 94–455, title II, § 213(c)(1)","children":[],"tail":", title XIX, § 1906(b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1547"},"text":"90 Stat. 1547","children":[],"tail":", 1834; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s72/a"},"text":"Pub. L. 98–369, div. A, title I, § 72(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/589"},"text":"98 Stat. 589","children":[],"tail":", 591; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tVIII/s806/a"},"text":"Pub. L. 99–514, title VIII, § 806(a)","children":[],"tail":", title XVIII, § 1805(a), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2362"},"text":"100 Stat. 2362","children":[],"tail":", 2810; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1008/e/1"},"text":"Pub. L. 100–647, title I, § 1008(e)(1)","children":[],"tail":"–(3), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3439"},"text":"102 Stat. 3439","children":[],"tail":", 3440; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tV/s507/b/2"},"text":"Pub. L. 105–34, title V, § 507(b)(2)","children":[],"tail":", title XII, § 1246(a), (b), "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/857"},"text":"111 Stat. 857","children":[],"tail":", 1030; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/139"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(139)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1191"},"text":"132 Stat. 1191","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id43fdcaa5-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id43fdcaa6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id43fdcaa7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" substituted “section 584(i)” for “section 584(h)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s507/b/2"},"text":"Pub. L. 105–34, § 507(b)(2)","children":[],"tail":", substituted “section 644” for “section 645”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1246/b"},"text":"Pub. L. 105–34, § 1246(b)","children":[],"tail":", substituted “Treatment of dispositions” for “Partner who retires or sells interest in partnership” as heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s1246/a"},"text":"Pub. L. 105–34, § 1246(a)","children":[],"tail":", amended heading and text of subpar. (A) generally. Prior to amendment, text read as follows: “The taxable year of a partnership shall close—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) with respect to a partner who sells or exchanges his entire interest in a partnership, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) with respect to a partner whose interest is liquidated, except that the taxable year of a partnership with respect to a partner who dies shall not close prior to the end of the partnership’s taxable year.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(1)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1008/e/1/A"},"text":"Pub. L. 100–647, § 1008(e)(1)(A)","children":[],"tail":", amended cl. (i) generally. Prior to amendment, cl. (i) read as follows: “the taxable year of 1 or more of its partners who have an aggregate interest in partnership profits and capital of greater than 50 percent,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1008/e/2"},"text":"Pub. L. 100–647, § 1008(e)(2)","children":[],"tail":", substituted “unless the Secretary by regulations prescribes another period” for “or such other period as the Secretary may prescribe in regulations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1008/e/1/B"},"text":"Pub. L. 100–647, § 1008(e)(1)(B)","children":[],"tail":", substituted “Majority interest taxable year; limitation on required changes” for “Application of majority interest rule” in heading and amended text generally. Prior to amendment, text read as follows: “Clause (i) of paragraph (1)(B) shall not apply to any taxable year of a partnership unless the period which constitutes the taxable year of 1 or more of its partners who have an aggregate interest in partnership profits and capital of greater than 50 percent has been the same for—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the 3-taxable year period of such partner or partners ending on or before the beginning of such taxable year of the partnership, or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) if the partnership has not been in existence during all of such 3-taxable year period, the taxable years of such partner or partners ending with or within the period of existence.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"This paragraph shall apply without regard to whether the same partners or interests are taken into account in determining the 50 percent interest during any period.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1008/e/3"},"text":"Pub. L. 100–647, § 1008(e)(3)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s806/a/3"},"text":"Pub. L. 99–514, § 806(a)(3)","children":[],"tail":", struck out “Adoption of” before “taxable year” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s806/a/1"},"text":"Pub. L. 99–514, § 806(a)(1)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “The taxable year of a partnership shall be determined as though the partnership were a taxpayer. A partnership may not change to, or adopt, a taxable year other than that of all its principal partners unless it establishes, to the satisfaction of the Secretary, a business purpose therefor.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s806/a/2"},"text":"Pub. L. 99–514, § 806(a)(2)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1805/a/1/A"},"text":"Pub. L. 99–514, § 1805(a)(1)(A)","children":[],"tail":", substituted “such item” for “each such item”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1805/a/1/B"},"text":"Pub. L. 99–514, § 1805(a)(1)(B)","children":[],"tail":", in introductory provisions, struck out “which are described in paragraph (1) and” after “the following items”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(C)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1805/a/2"},"text":"Pub. L. 99–514, § 1805(a)(2)","children":[],"tail":", substituted “the first day of the taxable year” for “the first day of such taxable year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s72/b/1"},"text":"Pub. L. 98–369, § 72(b)(1)","children":[],"tail":", struck out last sentence providing that such partner’s distributive share of item described in section 702(a) for such year shall be determined, under regulations prescribed by the Secretary, for the period ending with such sale, exchange, or liquidation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s72/b/2"},"text":"Pub. L. 98–369, § 72(b)(2)","children":[],"tail":", struck out “, but such partner’s distributive share of items described in section 702(a) shall be determined by taking into account his varying interests in the partnership during the taxable year” after “otherwise)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s72/a"},"text":"Pub. L. 98–369, § 72(a)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (b)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1906/b/13/A"},"text":"Pub. L. 94–455, § 1906(b)(13)(A)","children":[],"tail":", struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":", §§ 213(c)(1), 1906(b)(13)(A), substituted “or with respect to a partner whose interest is reduced (whether by entry of a new partner, partial liquidation of a partner’s interest, gift, or otherwise)” for “or with respect to a partner whose interest is reduced”, in par. (B), and struck out “or his delegate” after “Secretary” in par. (A)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id43fdcaa8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43fdcaa9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/s507/b/2"},"text":"section 507(b)(2) of Pub. L. 105–34","children":[],"tail":" applicable to sales or exchanges after "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/s507/c/2"},"text":"section 507(c)(2) of Pub. L. 105–34","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s644"},"text":"section 644 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXII/s1246/c"},"text":"Pub. L. 105–34, title XII, § 1246(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1030"},"text":"111 Stat. 1030","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/34/tXII/s1246/c"},"text":"“The amendments made by this section [amending this section] shall apply to partnership taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1997-12-31"},"text":"December 31, 1997","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43fdcaaa-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1019/a"},"text":"section 1019(a) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43fdcaab-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s806/a"},"text":"section 806(a) of Pub. L. 99–514","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"1986-12-31"},"text":"Dec. 31, 1986","children":[],"tail":", with special provisions applicable to taxpayers who are required to change their accounting periods, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s806/e"},"text":"section 806(e) of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1378"},"text":"section 1378 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1805/a"},"text":"section 1805(a) of Pub. L. 99–514","children":[],"tail":" effective, except as otherwise provided, as if included in the provisions of the Tax Reform Act of 1984, "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA"},"text":"Pub. L. 98–369, div. A","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1881"},"text":"section 1881 of Pub. L. 99–514","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s48"},"text":"section 48 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43fdcaac-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s72/c"},"text":"Pub. L. 98–369, div. A, title I, § 72(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/591"},"text":"98 Stat. 591","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The amendments made by this section [amending this section] shall apply—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of items described in section 706(d)(2) of the Internal Revenue Code of 1986 [formerly I.R.C. 1954] (as added by subsection (a)), to amounts attributable to periods after ","children":[{"tag":"date","attrib":{"date":"1984-03-31"},"text":"March 31, 1984","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of items described in section 706(d)(3) of such Code (as added by subsection (a)), to amounts paid or accrued by the other partnership after ","children":[{"tag":"date","attrib":{"date":"1984-03-31"},"text":"March 31, 1984","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id43fdcaad-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/s213/c/1"},"text":"section 213(c)(1) of Pub. L. 94–455","children":[],"tail":" applicable in the case of partnership taxable years beginning after "},{"tag":"date","attrib":{"date":"1975-12-31"},"text":"Dec. 31, 1975","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/s213/f"},"text":"section 213(f) of Pub. L. 94–455","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s709"},"text":"section 709 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id43fdcaae-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s806"},"text":"Section 806 of Pub. L. 99–514","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"Nothing in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s806"},"text":"section 806 of Pub. L. 99–514","children":[],"tail":" or in any legislative history relating thereto to be construed as requiring the Secretary of the Treasury or his delegate to permit an automatic change of a taxable year, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1008/e/9"},"text":"section 1008(e)(9) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1378"},"text":"section 1378 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id43fdcaaf-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Plan Amendments Not Required Until January 1, 1989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions directing that if any amendments made by subtitle A or subtitle C of title XI [§§ 1101–1147 and 1171–1177] or title XVIII [§§ 1800–1899A] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" require an amendment to any plan, such plan amendment shall not be required to be made before the first plan year beginning on or after "},{"tag":"date","attrib":{"date":"1989-01-01"},"text":"Jan. 1, 1989","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1140"},"text":"section 1140 of Pub. L. 99–514","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s401"},"text":"section 401 of this title","children":[],"tail":"."}],"tail":"\n"}]