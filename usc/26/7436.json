{"tag":"section","attrib":{"id":"id4755cf6b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7436"},"text":null,"children":[{"tag":"num","attrib":{"value":"7436"},"text":"§ 7436.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proceedings for determination of employment status","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4755cf6c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7436/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Creation of remedy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, in connection with an audit of any person, there is an actual controversy involving a determination by the Secretary as part of an examination that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4755cf6d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7436/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more individuals performing services for such person are employees of such person for purposes of subtitle C, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4755cf6e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7436/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such person is not entitled to the treatment under subsection (a) of section 530 of the Revenue Act of 1978 with respect to such an individual,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"upon the filing of an appropriate pleading, the Tax Court may determine whether such a determination by the Secretary is correct and the proper amount of employment tax under such determination. Any such redetermination by the Tax Court shall have the force and effect of a decision of the Tax Court and shall be reviewable as such.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4755cf6f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7436/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4755cf70-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7436/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petitioner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A pleading may be filed under this section only by the person for whom the services are performed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4755cf71-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7436/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for filing action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary sends by certified or registered mail notice to the petitioner of a determination by the Secretary described in subsection (a), no proceeding may be initiated under this section with respect to such determination unless the pleading is filed before the 91st day after the date of such mailing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4755cf72-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7436/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No adverse inference from treatment while action is pending","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, during the pendency of any proceeding brought under this section, the petitioner changes his treatment for employment tax purposes of any individual whose employment status as an employee is involved in such proceeding (or of any individual holding a substantially similar position) to treatment as an employee, such change shall not be taken into account in the Tax Court’s determination under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4755cf73-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7436/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small case procedures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4755cf74-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7436/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the option of the petitioner, concurred in by the Tax Court or a division thereof before the hearing of the case, proceedings under this section may (notwithstanding the provisions of section 7453) be conducted subject to the rules of evidence, practice, and procedure applicable under section 7463 if the amount of employment taxes placed in dispute is $50,000 or less for each calendar quarter involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4755cf75-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7436/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finality of decisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A decision entered in any proceeding conducted under this subsection shall not be reviewed in any other court and shall not be treated as a precedent for any other case not involving the same petitioner and the same determinations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4755cf76-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7436/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain rules to apply","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rules similar to the rules of the last sentence of subsection (a), and subsections (c), (d), and (e), of section 7463 shall apply to proceedings conducted under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4755cf77-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7436/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4755cf78-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7436/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions on assessment and collection pending action, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The principles of subsections (a), (b), (c), (d), and (f) of section 6213, section 6214(a), section 6215, section 6503(a), section 6512, and section 7481 shall apply to proceedings brought under this section in the same manner as if the Secretary’s determination described in subsection (a) were a notice of deficiency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4755cf79-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7436/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awarding of costs and certain fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Section 7430 shall apply to proceedings brought under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4755cf7a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7436/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “employment tax” means any tax imposed by subtitle C.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4755cf7b-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXIV/s1454/a"},"text":"Pub. L. 105–34, title XIV, § 1454(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1055"},"text":"111 Stat. 1055","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tIII/s3103/b/1"},"text":"Pub. L. 105–206, title III, § 3103(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/731"},"text":"112 Stat. 731","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tIII/s314/f"},"text":"Pub. L. 106–554, § 1(a)(7) [title III, § 314(f)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–643.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4755cf7c-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4755cf7d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4755cf7e-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 530 of the Revenue Act of 1978, referred to in subsec. (a)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/600/s530"},"text":"section 530 of Pub. L. 95–600","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s3401"},"text":"section 3401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4755cf7f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7436 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s7437"},"text":"section 7437 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4755cf80-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554"},"text":"Pub. L. 106–554","children":[],"tail":" inserted “and the proper amount of employment tax under such determination” before period at end of first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206"},"text":"Pub. L. 105–206","children":[],"tail":" substituted “$50,000” for “$10,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4755cf81-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4755cf82-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554"},"text":"Pub. L. 106–554","children":[],"tail":" effective as if included in the provisions of the Taxpayer Relief Act of 1997, "},{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":", to which such amendment relates, see section 1(a)(7) [title III, § 314(g)] of "},{"tag":"ref","attrib":{"href":"/us/pl/106/554"},"text":"Pub. L. 106–554","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s56"},"text":"section 56 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4755cf83-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/tIII/s3103/c"},"text":"Pub. L. 105–206, title III, § 3103(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/731"},"text":"112 Stat. 731","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/206/tIII/s3103/c"},"text":"“The amendments made by this section [amending this section and sections 7443A and 7463 of this title] shall apply to proceedings commenced after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
