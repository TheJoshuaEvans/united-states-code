{"tag":"section","attrib":{"id":"id4595820f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3321"},"text":null,"children":[{"tag":"num","attrib":{"value":"3321"},"text":"§ 3321.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of tax","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45958210-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3321/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby imposed on every rail employer for each calendar month an excise tax, with respect to having individuals in his employ, equal to 4 percent of the total rail wages paid by him during such month.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45958211-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3321/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax on employee representatives","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45958212-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3321/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby imposed on the income of each employee representative a tax equal to 4 percent of the rail wages paid to him during the calendar month.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45958213-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3321/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of wages","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rail wages of an employee representative for purposes of paragraph (1) shall be determined in the same manner and with the same effect as if the employee organization by which such employee representative is employed were a rail employer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45958214-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3321/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination if loans to railroad unemployment fund repaid","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The tax imposed by this section shall not apply to rail wages paid on or after the 1st day of any calendar month if, as of such 1st day, there is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45958215-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3321/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no balance of transfers made before ","children":[{"tag":"date","attrib":{"date":"1985-10-01"},"text":"October 1, 1985","children":[],"tail":", to the railroad unemployment insurance account under section 10(d) of the Railroad Unemployment Insurance Act, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45958216-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3321/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no unpaid interest on such transfers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45958217-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/76/tII/s231/a"},"text":"Pub. L. 98–76, title II, § 231(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-12"},"text":"Aug. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/426"},"text":"97 Stat. 426","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/tXIII/s13301/a"},"text":"Pub. L. 99–272, title XIII, § 13301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/325"},"text":"100 Stat. 325","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1018/u/17"},"text":"Pub. L. 100–647, title I, § 1018(u)(17)","children":[],"tail":", title VIII, § 7106(a), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3590"},"text":"102 Stat. 3590","children":[],"tail":", 3772.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45958218-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45958219-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4595821a-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 10(d) of the Railroad Unemployment Insurance Act, referred to in subsec. (c)(1), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s360/d"},"text":"section 360(d) of Title 45","children":[],"tail":", Railroads."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4595821b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s7106/a"},"text":"Pub. L. 100–647, § 7106(a)","children":[],"tail":", amended section generally, revising and restating provisions of subsecs. (a) and (b) and specifying imposition of 4 percent tax on rail wages rather than a tax based on the “applicable percentage” of rail wages, and in subsec. (c) substituting provisions relating to termination if loans to railroad unemployment fund repaid for provisions relating to rates of tax."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1018/u/17"},"text":"Pub. L. 100–647, § 1018(u)(17)","children":[],"tail":", added a period at end of par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272"},"text":"Pub. L. 99–272","children":[],"tail":" amended subsec. (c) generally. Prior to amendment subsec. (c) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(c) ","children":[{"tag":"inline","attrib":{},"text":"Rate of Tax","children":[],"tail":".—For purposes of this section—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"For taxable period july 1 through ","children":[{"tag":"date","attrib":{"date":"1986-12-31"},"text":"december 31, 1986","children":[],"tail":null}],"tail":".—The applicable percentage for the taxable period beginning on "},{"tag":"date","attrib":{"date":"1986-07-01"},"text":"July 1, 1986","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":", shall be 2 percent."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Subsequent taxable periods","children":[],"tail":".—The applicable percentage for any taxable period beginning after 1986 shall be the sum of—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) 2 percent, plus","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) 0.3 percent for each preceding taxable period.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In no event shall the applicable percentage exceed 5 percent.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4595821c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4595821d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1018/u/17"},"text":"section 1018(u)(17) of Pub. L. 100–647","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1019/a"},"text":"section 1019(a) of Pub. L. 100–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tVII/s7106/d"},"text":"Pub. L. 100–647, title VII, § 7106(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3774"},"text":"102 Stat. 3774","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/647/tVII/s7106/d"},"text":"“The amendments made by this section [amending this section and sections 3322, 6157, 6201, 6317, 6513, and 6601 of this title, omitting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s3323"},"text":"section 3323 of this title","children":[],"tail":", and amending provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s231n"},"text":"section 231n of Title 45","children":[],"tail":", Railroads], and the provisions of subsection (b) [set out below], shall apply to remuneration paid after "},{"tag":"date","attrib":{"date":"1988-12-31"},"text":"December 31, 1988","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4595821e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/76/tII/s231/d"},"text":"Pub. L. 98–76, title II, § 231(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-12"},"text":"Aug. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/429"},"text":"97 Stat. 429","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/76/tII/s231/d"},"text":"“The amendments made by this section [enacting this chapter and amending sections 6157, 6201, 6317, 6513, and 6601 of this title] shall apply to remuneration paid after ","children":[{"tag":"date","attrib":{"date":"1986-06-30"},"text":"June 30, 1986","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4595821f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Continuation of Surtax Rate Through 1990","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tVII/s7106/b"},"text":"Pub. L. 100–647, title VII, § 7106(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3773"},"text":"102 Stat. 3773","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/647/tVII/s7106/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any calendar month beginning before ","children":[{"tag":"date","attrib":{"date":"1991-01-01"},"text":"January 1, 1991","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" there shall be substituted for ‘4 percent’ in subsections (a) and (b) of section 3321 of the 1986 Code the percentage equal to the sum of—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 4 percent, plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the surtax rate (if any) for such calendar month, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (c) of such section shall not apply to so much of the tax imposed by such section as is attributable to the surtax rate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Surtax rate","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), the surtax rate shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3.5 percent for each month during a calendar year if, as of September 30, of the preceding calendar year, there was a balance of transfers (or unpaid interest thereon) made after ","children":[{"tag":"date","attrib":{"date":"1985-09-30"},"text":"September 30, 1985","children":[],"tail":", to the railroad unemployment insurance account under section 10(d) of the Railroad Unemployment Insurance Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t45/s360/d"},"text":"45 U.S.C. 360(d)","children":[],"tail":"], and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" zero for any other calendar month.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
