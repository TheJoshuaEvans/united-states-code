{"tag":"section","attrib":{"id":"id46d2bcef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6339"},"text":null,"children":[{"tag":"num","attrib":{"value":"6339"},"text":"§ 6339.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Legal effect of certificate of sale of personal property and deed of real property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46d2bcf0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6339/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certificate of sale of property other than real property","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In all cases of sale pursuant to section 6335 of property (other than real property), the certificate of such sale—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46d2bcf1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6339/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" As evidence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Shall be prima facie evidence of the right of the officer to make such sale, and conclusive evidence of the regularity of his proceedings in making the sale; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46d2bcf2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6339/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" As conveyances","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Shall transfer to the purchaser all right, title, and interest of the party delinquent in and to the property sold; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46d2bcf3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6339/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" As authority for transfer of corporate stock","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If such property consists of stocks, shall be notice, when received, to any corporation, company, or association of such transfer, and shall be authority to such corporation, company, or association to record the transfer on its books and records in the same manner as if the stocks were transferred or assigned by the party holding the same, in lieu of any original or prior certificate, which shall be void, whether canceled or not; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46d2bcf4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6339/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" As receipts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the subject of sale is securities or other evidences of debt, shall be a good and valid receipt to the person holding the same, as against any person holding or claiming to hold possession of such securities or other evidences of debt; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46d2bcf5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6339/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" As authority for transfer of title to motor vehicle","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If such property consists of a motor vehicle, shall be notice, when received, to any public official charged with the registration of title to motor vehicles, of such transfer and shall be authority to such official to record the transfer on his books and records in the same manner as if the certificate of title to such motor vehicle were transferred or assigned by the party holding the same, in lieu of any original or prior certificate, which shall be void, whether canceled or not.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46d2bcf6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6339/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deed of real property","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of the sale of real property pursuant to section 6335—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46d2bcf7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6339/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deed as evidence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The deed of sale given pursuant to section 6338 shall be prima facie evidence of the facts therein stated; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46d2bcf8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6339/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deed as conveyance of title","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the proceedings of the Secretary as set forth have been substantially in accordance with the provisions of law, such deed shall be considered and operate as a conveyance of all the right, title, and interest the party delinquent had in and to the real property thus sold at the time the lien of the United States attached thereto.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46d2bcf9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6339/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of junior encumbrances","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A certificate of sale of personal property given or a deed to real property executed pursuant to section 6338 shall discharge such property from all liens, encumbrances, and titles over which the lien of the United States with respect to which the levy was made had priority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46d2bcfa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6339/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross references","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46d2bcfb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6339/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For distribution of surplus proceeds, see section 6342(b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46d2bcfc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6339/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For judicial procedure with respect to surplus proceeds, see section 7426(a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id46d2bcfd-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/788"},"text":"68A Stat. 788","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/866/tI/s79"},"text":"Pub. L. 85–866, title I, § 79","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1662"},"text":"72 Stat. 1662","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/719/tI/s104/g"},"text":"Pub. L. 89–719, title I, § 104(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1137"},"text":"80 Stat. 1137","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id46d2bcfe-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id46d2bcff-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id46d2bd00-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/719"},"text":"Pub. L. 89–719","children":[],"tail":" added subsecs. (c) and (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/866"},"text":"Pub. L. 85–866","children":[],"tail":" substituted “as” for “of” after “Deed” in heading."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id46d2bd01-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46d2bd02-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1966 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/719"},"text":"Pub. L. 89–719","children":[],"tail":" applicable after "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", regardless of when title or lien of United States arose or when lien or interest of another person was acquired, with certain exceptions, see section 114(a)–(c) of "},{"tag":"ref","attrib":{"href":"/us/pl/89/719"},"text":"Pub. L. 89–719","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6323"},"text":"section 6323 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46d505f3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1958 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/866"},"text":"Pub. L. 85–866","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1954-08-17"},"text":"Aug. 17, 1954","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/85/866/s1/c/2"},"text":"section 1(c)(2) of Pub. L. 85–866","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s165"},"text":"section 165 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
