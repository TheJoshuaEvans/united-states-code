{"tag":"section","attrib":{"id":"id4632fac2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s5242"},"text":null,"children":[{"tag":"num","attrib":{"value":"5242"},"text":"§ 5242.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denaturing materials","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Methanol or other denaturing materials suitable to the use for which the denatured distilled spirits are intended to be withdrawn shall be used for the denaturation of distilled spirits. Denaturing materials shall be such as to render the spirits with which they are admixed unfit for beverage or internal human medicinal use. The character and the quantity of denaturing materials used shall be as prescribed by the Secretary by regulations.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4632fac3-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/859/tII/s201"},"text":"Pub. L. 85–859, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1369"},"text":"72 Stat. 1369","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4632fac4-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4632fac5-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Edi