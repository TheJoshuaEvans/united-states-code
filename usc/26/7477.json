{"tag":"section","attrib":{"id":"id4761b6d1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7477"},"text":null,"children":[{"tag":"num","attrib":{"value":"7477"},"text":"§ 7477.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Declaratory judgments relating to value of certain gifts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4761b6d2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7477/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Creation of remedy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In a case of an actual controversy involving a determination by the Secretary of the value of any gift shown on the return of tax imposed by chapter 12 or disclosed on such return or in any statement attached to such return, upon the filing of an appropriate pleading, the Tax Court may make a declaration of the value of such gift. Any such declaration shall have the force and effect of a decision of the Tax Court and shall be reviewable as such.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4761b6d3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7477/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4761b6d4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7477/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petitioner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A pleading may be filed under this section only by the donor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4761b6d5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7477/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exhaustion of administrative remedies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The court shall not issue a declaratory judgment or decree under this section in any proceeding unless it determines that the petitioner has exhausted all available administrative remedies within the Internal Revenue Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id476426d6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7477/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for bringing action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary sends by certified or registered mail notice of his determination as described in subsection (a) to the petitioner, no proceeding may be initiated under this section unless the pleading is filed before the 91st day after the date of such mailing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id476426d7-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/tV/s506/c/1"},"text":"Pub. L. 105–34, title V, § 506(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/855"},"text":"111 Stat. 855","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id476426d8-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id476426d9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id476426da-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7477, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tX/s1042/d/1"},"text":"Pub. L. 94–455, title X, § 1042(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1637"},"text":"90 Stat. 1637","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/600/tIII/s336/b/2/B"},"text":"Pub. L. 95–600, title III, § 336(b)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2842"},"text":"92 Stat. 2842","children":[],"tail":", provided for declaratory judgments relating to transfers of property from the United States, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s131/e/1"},"text":"Pub. L. 98–369, div. A, title I, § 131(e)(1)","children":[],"tail":", (g), "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/664"},"text":"98 Stat. 664","children":[],"tail":", 665, applicable to transfers or exchanges after "},{"tag":"date","attrib":{"date":"1984-12-31"},"text":"Dec. 31, 1984","children":[],"tail":", in taxable years ending after such date, with special rules for certain transfers and ruling requests before "},{"tag":"date","attrib":{"date":"1984-03-01"},"text":"Mar. 1, 1984","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id476426db-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id476426dc-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to gifts made after ","children":[{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/s506/e/1"},"text":"section 506(e)(1) of Pub. L. 105–34","children":[],"tail":", set out as an Effective Date of 1997 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2001"},"text":"section 2001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
