{"tag":"section","attrib":{"id":"id471320db-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6631"},"text":null,"children":[{"tag":"num","attrib":{"value":"6631"},"text":"§ 6631.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall include with each notice to an individual taxpayer which includes an amount of interest required to be paid by such taxpayer under this title information with respect to the section of this title under which the interest is imposed and a computation of the interest.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id471320dc-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/tIII/s3308/a"},"text":"Pub. L. 105–206, title III, § 3308(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/745"},"text":"112 Stat. 745","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id471320dd-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id471320de-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id471320df-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/tIII/s3308/c"},"text":"Pub. L. 105–206, title III, § 3308(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/745"},"text":"112 Stat. 745","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tIII/s302/c"},"text":"Pub. L. 106–554, § 1(a)(7) [title III, § 302(c)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–632, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/554/s1/a/7/tIII/s302/c"},"text":"“The amendments made by this section [enacting this subchapter] shall apply to notices issued after ","children":[{"tag":"date","attrib":{"date":"2001-06-30"},"text":"June 30, 2001","children":[],"tail":". In the case of any notice issued after "},{"tag":"date","attrib":{"date":"2001-06-30"},"text":"June 30, 2001","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"2003-07-01"},"text":"July 1, 2003","children":[],"tail":", to which section 6631 of the Internal Revenue Code of 1986 applies, the requirements of section 6631 of such Code shall be treated as met if such notice contains a telephone number at which the taxpayer can request a copy of the taxpayer’s payment history relating to interest amounts included in such notice.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
