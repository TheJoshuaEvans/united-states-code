.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Over $3,600,000 but not over $4,100,000","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"$298,500 plus 13 percent of the excess over $3,600,000.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Over $4,100,000 but not over $5,100,000","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"$363,500 plus 14 percent of the excess over $4,100,000.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Over $5,100,000 but not over $6,100,000","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"$503,500 plus 15 percent of the excess over $5,100,000.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Over $6,100,000 but not over $7,100,000","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"$653,500 plus 16 percent of the excess over $6,100,000.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Over $7,100,000 but not over $8,100,000","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"$813,500 plus 17 percent of the excess over $7,100,000.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Over $8,100,000 but not over $9,100,000","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"$983,500 plus 18 percent of the excess over $8,100,000.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Over $9,100,000 but not over $10,100,000","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"$1,163,500 plus 19 percent of the excess over $9,100,000.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Over $10,100,000","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"$1,353,500 plus 20 percent of the excess over $10,100,000.","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id453d4f3b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2201/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of unified credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an estate to which this section applies, subsection (a) shall not apply in determining the credit under section 2010.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id453d4f3c-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/401"},"text":"68A Stat. 401","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/597/s6/b/1"},"text":"Pub. L. 93–597, § 6(b)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1975-01-02"},"text":"Jan. 2, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1953"},"text":"88 Stat. 1953","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1902/a/7/A"},"text":"Pub. L. 94–455, title XIX, § 1902(a)(7)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1805"},"text":"90 Stat. 1805","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/16/tV/s532/c/9"},"text":"Pub. L. 107–16, title V, § 532(c)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-06-07"},"text":"June 7, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/75"},"text":"115 Stat. 75","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/134/tI/s103/a"},"text":"Pub. L. 107–134, title I, § 103(a)","children":[],"tail":", (b)(3), "},{"tag":"date","attrib":{"date":"2002-01-23"},"text":"Jan. 23, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2430"},"text":"115 Stat. 2430","children":[],"tail":", 2431; "},{"tag":"ref","attrib":{"href":"/us/pl/108/121/tI/s110/c/1"},"text":"Pub. L. 108–121, title I, § 110(c)(1)","children":[],"tail":", (2)(A), "},{"tag":"date","attrib":{"date":"2003-11-11"},"text":"Nov. 11, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1342"},"text":"117 Stat. 1342","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id453d4f3d-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id453d4f3e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id453d4f3f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/121/s110/c/2/A"},"text":"Pub. L. 108–121, § 110(c)(2)(A)","children":[],"tail":", inserted “, deaths of astronauts,” after “Forces” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/121/s110/c/1"},"text":"Pub. L. 108–121, § 110(c)(1)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/134"},"text":"Pub. L. 107–134","children":[],"tail":" amended section catchline and text of section generally, substituting present provisions for provisions which had stated that the additional estate tax as defined in former section 2011(d) should not apply to the transfer of the taxable estate of a citizen or resident of the United States dying while in active service as a member of the Armed Forces of the United States, if such decedent was killed in action while serving in a combat zone, as determined under section 112(c), or died as a result of wounds, disease, or injury suffered, while serving in a combat zone (as determined under section 112(c)), and while in line of duty, by reason of a hazard to which he was subjected as an incident of such service."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16/s532/c/9/B"},"text":"Pub. L. 107–16, § 532(c)(9)(B)","children":[],"tail":", which added concluding provisions which read as follows: “For purposes of this section, the additional estate tax is the difference between the tax imposed by section 2001 or 2101 and the amount equal to 125 percent of the maximum credit provided by section 2011(b), as in effect before its repeal by the Economic Growth and Tax Relief Reconciliation Act of 2001.”, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/107/134/s103/b/3"},"text":"Pub. L. 107–134, § 103(b)(3)","children":[],"tail":". See Effective Date of 2002 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16/s532/c/9/A"},"text":"Pub. L. 107–16, § 532(c)(9)(A)","children":[],"tail":", which struck out “as defined in section 2011(d)” after “The additional estate tax” in introductory provisions, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/107/134/s103/b/3"},"text":"Pub. L. 107–134, § 103(b)(3)","children":[],"tail":". See Effective Date of 2002 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/597"},"text":"Pub. L. 93–597","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/s1902/a/7/A"},"text":"Pub. L. 94–455, § 1902(a)(7)(A)","children":[],"tail":", struck out “during an induction period (as defined in section 112(c)(5))” after “resident of the United States dying”, and substituted “Members of the Armed Forces dying in combat zone or by reason of combat-zone-incurred wounds, etc.” for “Members of the Armed Forces dying during an induction period” in section catchline."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeadin