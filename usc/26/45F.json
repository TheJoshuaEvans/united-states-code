{"tag":"section","attrib":{"id":"id40ce3554-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F"},"text":null,"children":[{"tag":"num","attrib":{"value":"45F"},"text":"§ 45F.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employer-provided child care credit","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id40ce3555-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of section 38, the employer-provided child care credit determined under this section for the taxable year is an amount equal to the sum of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40ce3556-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 40 percent (50 percent in the case of an eligible small business) of the qualified child care expenditures, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40ce3557-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10 percent of the qualified child care resource and referral expenditures,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"of the taxpayer for such taxable year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40ce3558-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dollar limitation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40ce3559-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The credit allowable under subsection (a) for any taxable year shall not exceed $500,000 ($600,000 in the case of an eligible small business).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40ce355a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inflation adjustment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any taxable year beginning after 2026, the $500,000 and $600,000 amounts in paragraph (1) shall each be increased by an amount equal to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40ce355b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such dollar amount, multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40ce355c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost-of-living adjustment determined under section 1(f)(3) for the calendar year in which the taxable year begins, determined by substituting “calendar year 2025” for “calendar year 2016” in subparagraph (A)(ii) thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40ce355d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40ce355e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified child care expenditure","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40ce355f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified child care expenditure” means any amount paid or incurred—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40ce3560-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to acquire, construct, rehabilitate, or expand property—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id40ce3561-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/c/1/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is to be used as part of a qualified child care facility of the taxpayer,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id40ce3562-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/c/1/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to which a deduction for depreciation (or amortization in lieu of depreciation) is allowable, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id40ce3563-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/c/1/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which does not constitute part of the principal residence (within the meaning of section 121) of the taxpayer or any employee of the taxpayer,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40ce3564-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the operating costs of a qualified child care facility of the taxpayer, including costs related to the training of employees, to scholarship programs, and to the providing of increased compensation to employees with higher levels of child care training, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40ce3565-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under a contract with a qualified child care facility to provide child care services to employees of the taxpayer, or under a contract with an intermediate entity that contracts with one or more qualified child care facilities to provide such child care services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40ce3566-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fair market value","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified child care expenditures” shall not include expenses in excess of the fair market value of such care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40ce3567-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified child care facility","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40ce3568-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified child care facility” means a facility—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40ce3569-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the principal use of which is to provide child care assistance, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40ce356a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which meets the requirements of all applicable laws and regulations of the State or local government in which it is located, including the licensing of the facility as a child care facility.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Clause (i) shall not apply to a facility which is the principal residence (within the meaning of section 121) of the operator of the facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40ce356b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules with respect to a taxpayer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A facility shall not be treated as a qualified child care facility with respect to a taxpayer unless—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40ce356c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enrollment in the facility is open to employees of the taxpayer during the taxable year,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40ce356d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the facility is the principal trade or business of the taxpayer, at least 30 percent of the enrollees of such facility are dependents of employees of the taxpayer, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40ce356e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of such facility (or the eligibility to use such facility) does not discriminate in favor of employees of the taxpayer who are highly compensated employees (within the meaning of section 414(q)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40ce356f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of jointly owned or operated child care facility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A facility shall not fail to be treated as a qualified child care facility of the taxpayer merely because such facility is jointly owned or operated by the taxpayer and other persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d0a670-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified child care resource and referral expenditure","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40d0a671-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified child care resource and referral expenditure” means any amount paid or incurred under a contract to provide child care resource and referral services to an employee of the taxpayer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40d0a672-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondiscrimination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The services shall not be treated as qualified unless the provision of such services (or the eligibility to use such services) does not discriminate in favor of employees of the taxpayer who are highly compensated employees (within the meaning of section 414(q)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d0a673-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible small business","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible small business” means a business that meets the gross receipts test of section 448(c), determined—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40d0a674-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by substituting “5-taxable-year” for “3-taxable-year” in paragraph (1) thereof, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40d0a675-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by substituting “5-year” for “3-year” in paragraph (3)(A) thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40d0a676-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recapture of acquisition and construction credit","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40d0a677-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, as of the close of any taxable year, there is a recapture event with respect to any qualified child care facility of the taxpayer, then the tax of the taxpayer under this chapter for such taxable year shall be increased by an amount equal to the product of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40d0a678-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicable recapture percentage, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40d0a679-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate decrease in the credits allowed under section 38 for all prior taxable years which would have resulted if the qualified child care expenditures of the taxpayer described in subsection (c)(1)(A) with respect to such facility had been zero.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d0a67a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable recapture percentage","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40d0a67b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the applicable recapture percentage shall be determined from the following table:","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id40d0a67c-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:b","attrib":{},"text":null,"children":[],"tail":" If the recapture event occurs in:"}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:b","attrib":{},"text":"The applicable recapture percentage is:","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Years 1–3","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"100  ","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Year 4","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"85  ","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Year 5","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"70  ","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Year 6","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"55  ","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Year 7","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40  ","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Year 8","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"25  ","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Years 9 and 10","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10  ","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Years 11 and thereafter","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"0.","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40d0a67d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Years","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A), year 1 shall begin on the first day of the taxable year in which the qualified child care facility is placed in service by the taxpayer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d0a67e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recapture event defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “recapture event” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40d0a67f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cessation of operation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The cessation of the operation of the facility as a qualified child care facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40d0a680-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Change in ownership","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40d0a681-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in clause (ii), the disposition of a taxpayer’s interest in a qualified child care facility with respect to which the credit described in subsection (a) was allowable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40d0a682-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement to assume recapture liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Clause (i) shall not apply if the person acquiring such interest in the facility agrees in writing to assume the recapture liability of the person disposing of such interest in effect immediately before such disposition. In the event of such an assumption, the person acquiring the interest in the facility shall be treated as the taxpayer for purposes of assessing any recapture liability (computed as if there had been no change in ownership).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d0a683-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40d0a684-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax benefit rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tax for the taxable year shall be increased under paragraph (1) only with respect to credits allowed by reason of this section which were used to reduce tax liability. In the case of credits not so used to reduce tax liability, the carryforwards and carrybacks under section 39 shall be appropriately adjusted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40d0a685-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No credits against tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any increase in tax under this subsection shall not be treated as a tax imposed by this chapter for purposes of determining the amount of any credit under this chapter or for purposes of section 55.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40d0a686-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No recapture by reason of casualty loss","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The increase in tax under this subsection shall not apply to a cessation of operation of the facility as a qualified child care facility by reason of a casualty loss to the extent such loss is restored by reconstruction or replacement within a reasonable period established by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40d0a687-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40d0a688-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aggregation rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All persons which are treated as a single employer under subsections (a) and (b) of section 52 shall be treated as a single taxpayer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d0a689-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pass-thru in the case of estates and trusts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under regulations prescribed by the Secretary, rules similar to the rules of subsection (d) of section 52 shall apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d0a68a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation in the case of partnerships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of partnerships, the credit shall be allocated among partners under regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40d0a68b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No double benefit","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40d0a68c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction in basis","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subtitle—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40d0a68d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a credit is determined under this section with respect to any property by reason of expenditures described in subsection (c)(1)(A), the basis of such property shall be reduced by the amount of the credit so determined.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40d0a68e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain dispositions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, during any taxable year, there is a recapture amount determined with respect to any property the basis of which was reduced under subparagraph (A), the basis of such property (immediately before the event resulting in such recapture) shall be increased by an amount equal to such recapture amount. For purposes of the preceding sentence, the term “recapture amount” means any increase in tax (or adjustment in carrybacks or carryovers) determined under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40d0a68f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other deductions and credits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No deduction or credit shall be allowed under any other provision of this chapter with respect to the amount of the credit determined under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40d0a690-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45F/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations and guidance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall issue such regulations or other guidance as may be necessary to carry out the purposes of this section, including guidance to carry out the purposes of paragraphs (1)(A)(iii) and (2)(C) of subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id40d0a691-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16/tII/s205/a"},"text":"Pub. L. 107–16, title II, § 205(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-06-07"},"text":"June 7, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/50"},"text":"115 Stat. 50","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/147/tIV/s411/d/1"},"text":"Pub. L. 107–147, title IV, § 411(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-03-09"},"text":"Mar. 9, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/46"},"text":"116 Stat. 46","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70401/a"},"text":"Pub. L. 119–21, title VII, § 70401(a)","children":[],"tail":"–(f), "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/212"},"text":"139 Stat. 212","children":[],"tail":", 213.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id40d0a692-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id40d0a693-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id40d0a694-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70401/a"},"text":"Pub. L. 119–21, § 70401(a)","children":[],"tail":", substituted “40 percent (50 percent in the case of an eligible small business)” for “25 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70401/b"},"text":"Pub. L. 119–21, § 70401(b)","children":[],"tail":", amended subsec. (b) generally. Prior to amendment, text read as follows: “The credit allowable under subsection (a) for any taxable year shall not exceed $150,000.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(A)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70401/d"},"text":"Pub. L. 119–21, § 70401(d)","children":[],"tail":", inserted “, or under a contract with an intermediate entity that contracts with one or more qualified child care facilities to provide such child care services” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70401/e"},"text":"Pub. L. 119–21, § 70401(e)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70401/c"},"text":"Pub. L. 119–21, § 70401(c)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70401/f"},"text":"Pub. L. 119–21, § 70401(f)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (d)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/147"},"text":"Pub. L. 107–147","children":[],"tail":" substituted “this chapter or for purposes of section 55” for “subpart A, B, or D of this part”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id40d0a695-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id40d0a696-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70401/g"},"text":"Pub. L. 119–21, title VII, § 70401(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/213"},"text":"139 Stat. 213","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/21/tVII/s70401/g"},"text":"“The amendments made by this section [amending this section] shall apply to amounts paid or incurred after ","children":[{"tag":"date","attrib":{"date":"2025-12-31"},"text":"December 31, 2025","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id40d0a697-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/147"},"text":"Pub. L. 107–147","children":[],"tail":" effective as if included in the provisions of the Economic Growth and Tax Relief Reconciliation Act of 2001, "},{"tag":"ref","attrib":{"href":"/us/pl/107/16"},"text":"Pub. L. 107–16","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/147/s411/x"},"text":"section 411(x) of Pub. L. 107–147","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s25B"},"text":"section 25B of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id40d0a698-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2001-12-31"},"text":"Dec. 31, 2001","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/16/s205/c"},"text":"section 205(c) of Pub. L. 107–16","children":[],"tail":", set out as an Effective Date of 2001 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s38"},"text":"section 38 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
