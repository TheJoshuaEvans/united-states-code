xt":"Pub. L. 97–34","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/97/448/s109"},"text":"section 109 of Pub. L. 97–448","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id42ab3343-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/tIII/s321/c"},"text":"Pub. L. 97–34, title III, § 321(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/289"},"text":"95 Stat. 289","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/34/tIII/s321/c"},"text":"“The amendments made by this section [amending this section] shall apply to distributions after ","children":[{"tag":"date","attrib":{"date":"1981-12-31"},"text":"December 31, 1981","children":[],"tail":", in taxable years ending after such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id42ab3344-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1969 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/172/tIV/s421/b"},"text":"Pub. L. 91–172, title IV, § 421(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/615"},"text":"83 Stat. 615","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise provided in this subsection, the amendment made by subsection (a) [amending this section] shall apply with respect to distributions (or deemed distributions) made after ","children":[{"tag":"date","attrib":{"date":"1969-01-10"},"text":"January 10, 1969","children":[],"tail":", in taxable years ending after such date."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 305(b)(2) of the Internal Revenue Code of 1986 [formerly I.R.C. 1954] (as added by subsection (a)) shall not apply to a distribution (or deemed distribution) of stock made before ","children":[{"tag":"date","attrib":{"date":"1991-01-01"},"text":"January 1, 1991","children":[],"tail":", with respect to stock (i) outstanding on "},{"tag":"date","attrib":{"date":"1969-01-10"},"text":"January 10, 1969","children":[],"tail":", (ii) issued pursuant to a contract binding on "},{"tag":"date","attrib":{"date":"1969-01-10"},"text":"January 10, 1969","children":[],"tail":", on the distributing corporation, (iii) which is additional stock of that class of stock which (as of "},{"tag":"date","attrib":{"date":"1969-01-10"},"text":"January 10, 1969","children":[],"tail":") had the largest fair market value of all classes of stock of the corporation (taking into account only stock outstanding on "},{"tag":"date","attrib":{"date":"1969-01-10"},"text":"January 10, 1969","children":[],"tail":", or issued pursuant to a contract binding on "},{"tag":"date","attrib":{"date":"1969-01-10"},"text":"January 10, 1969","children":[],"tail":"), (iv) described in subparagraph (C)(iii), or (v) issued in a prior distribution described in clause (i), (ii), (iii), or (iv)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subparagraph (A) shall apply only if—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the stock as to which there is a receipt of property was outstanding on ","children":[{"tag":"date","attrib":{"date":"1969-01-10"},"text":"January 10, 1969","children":[],"tail":" (or was issued pursuant to a contract binding on "},{"tag":"date","attrib":{"date":"1969-01-10"},"text":"January 10, 1969","children":[],"tail":", on the distributing corporation), and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such stock and any stock described in subparagraph (A)(i) were also outstanding on ","children":[{"tag":"date","attrib":{"date":"1968-01-10"},"text":"January 10, 1968","children":[],"tail":", a distribution of property was made on or before "},{"tag":"date","attrib":{"date":"1969-01-10"},"text":"January 10, 1969","children":[],"tail":", with respect to such stock, and a distribution of stock was made on or before "},{"tag":"date","attrib":{"date":"1969-01-10"},"text":"January 10, 1969","children":[],"tail":", with respect t