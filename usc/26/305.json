{"tag":"section","attrib":{"id":"id42ab3310-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s305"},"text":null,"children":[{"tag":"num","attrib":{"value":"305"},"text":"§ 305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distributions of stock and stock rights","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id42ab3311-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s305/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this section, gross income does not include the amount of any distribution of the stock of a corporation made by such corporation to its shareholders with respect to its stock.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42ab3312-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s305/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply to a distribution by a corporation of its stock, and the distribution shall be treated as a distribution of property to which section 301 applies—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42ab3313-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s305/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distributions in lieu of money","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the distribution is, at the election of any of the shareholders (whether exercised before or after the declaration thereof), payable either—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42ab3314-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s305/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in its stock, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42ab3315-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s305/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42ab3316-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s305/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disproportionate distributions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the distribution (or a series of distributions of which such distribution is one) has the result of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42ab3317-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s305/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the receipt of property by some shareholders, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42ab3318-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s305/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an increase in the proportionate interests of other shareholders in the assets or earnings and profits of the corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42ab3319-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s305/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distributions of common and preferred stock","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the distribution (or a series of distributions of which such distribution is one) has the result of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42ab331a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s305/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the receipt of preferred stock by some common shareholders, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42ab331b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s305/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the receipt of common stock by other common shareholders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42ab331c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s305/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distributions on preferred stock","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the distribution is with respect to preferred stock, other than an increase in the conversion ratio of convertible preferred stock made solely to take account of a stock dividend or stock split with respect to the stock into which such convertible stock is convertible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42ab331d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s305/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distributions of convertible preferred stock","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the distribution is of convertible preferred stock, unless it is established to the satisfaction of the Secretary that such distribution will not have the result described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42ab331e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s305/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain transactions treated as distributions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section and section 301, the Secretary shall prescribe regulations under which a change in conversion ratio, a change in redemption price, a difference between redemption price and issue price, a redemption which is treated as a distribution to which section 301 applies, or any transaction (including a recapitalization) having a similar effect on the interest of any shareholder shall be treated as a distribution with respect to any shareholder whose proportionate interest in the earnings and profits or assets of the corporation is increased by such change, difference, redemption, or similar transaction. Regulations prescribed under the preceding sentence shall provide that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42ab331f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s305/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where the issuer of stock is required to redeem the stock at a specified time or the holder of stock has the option to require the issuer to redeem the stock, a redemption premium resulting from such requirement or option shall be treated as reasonable only if the amount of such premium does not exceed the amount determined under the principles of section 1273(a)(3),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42ab3320-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s305/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a redemption premium shall not fail to be treated as a distribution (or series of distributions) merely because the stock is callable, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42ab3321-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s305/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any case in which a redemption premium is treated as a distribution (or series of distributions), such premium shall be taken into account under principles similar to the principles of section 1272(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42ab3322-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s305/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42ab3323-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s305/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights to acquire stock","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “stock” includes rights to acquire such stock.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42ab3324-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s305/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Shareholders","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsections (b) and (c), the term “shareholder” includes a holder of rights or of convertible securities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42ab3325-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s305/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of purchaser of stripped preferred stock","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42ab3326-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s305/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If any person purchases after ","children":[{"tag":"date","attrib":{"date":"1993-04-30"},"text":"April 30, 1993","children":[],"tail":", any stripped preferred stock, then such person, while holding such stock, shall include in gross income amounts equal to the amounts which would have been so includible if such stripped preferred stock were a bond issued on the purchase date and having original issue discount equal to the excess, if any, of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42ab3327-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s305/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the redemption price for such stock, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42ab3328-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s305/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the price at which such person purchased such stock.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The preceding sentence shall also apply in the case of any person whose basis in such stock is determined by reference to the basis in the hands of such purchaser.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42ab3329-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s305/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis adjustments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Appropriate adjustments to basis shall be made for amounts includible in gross income under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42ab332a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s305/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax treatment of person stripping stock","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any person strips the rights to 1 or more dividends from any stock described in paragraph (5)(B) and after ","children":[{"tag":"date","attrib":{"date":"1993-04-30"},"text":"April 30, 1993","children":[],"tail":", disposes of such dividend rights, for purposes of paragraph (1), such person shall be treated as having purchased the stripped preferred stock on the date of such disposition for a purchase price equal to such person’s adjusted basis in such stripped preferred stock."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42ab332b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s305/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts treated as ordinary income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amount included in gross income under paragraph (1) shall be treated as ordinary income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42ab332c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s305/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stripped preferred stock","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42ab332d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s305/e/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “stripped preferred stock” means any stock described in subparagraph (B) if there has been a separation in ownership between such stock and any dividend on such stock which has not become payable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42ab332e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s305/e/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Description of stock","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Stock is described in this subsection if such stock—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id42ab332f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s305/e/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is limited and preferred as to dividends and does not participate in corporate growth to any significant extent, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id42ab3330-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s305/e/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a fixed redemption price.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42ab3331-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s305/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchase","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “purchase” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id42ab3332-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s305/e/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any acquisition of stock, where","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id42ab3333-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s305/e/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the basis of such stock is not determined in whole or in part by the reference to the adjusted basis of such stock in the hands of the person from whom acquired.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42ab3334-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s305/e/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For treatment of stripped interests in certain accounts or entities holding preferred stock, see section 1286(e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id42ab3335-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s305/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross references","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For special rules—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id42ab3336-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s305/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Relating to the receipt of stock and stock rights in corporate organizations and reorganizations, see part III (sec. 351 and following).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42ab3337-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s305/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a distribution which results in a gift, see section 2501 and following.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id42ab3338-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s305/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a distribution which has the effect of the payment of compensation, see section 61(a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id42ab3339-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/90"},"text":"68A Stat. 90","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/tIV/s421/a"},"text":"Pub. L. 91–172, title IV, § 421(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/614"},"text":"83 Stat. 614","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/tIII/s321/a"},"text":"Pub. L. 97–34, title III, § 321(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/287"},"text":"95 Stat. 287","children":[],"tail":", 289; "},{"tag":"ref","attrib":{"href":"/us/pl/97/448/tI/s103/f"},"text":"Pub. L. 97–448, title I, § 103(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2378"},"text":"96 Stat. 2378","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI"},"text":"Pub. L. 101–508, title XI","children":[],"tail":", §§ 11322(a), 11801(a)(17), (c)(7), "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-463"},"text":"104 Stat. 1388–463","children":[],"tail":", 1388–521, 1388–524; "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13206/c/1"},"text":"Pub. L. 103–66, title XIII, § 13206(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/465"},"text":"107 Stat. 465","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s831/b"},"text":"Pub. L. 108–357, title VIII, § 831(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1587"},"text":"118 Stat. 1587","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/c/2/D"},"text":"Pub. L. 115–141, div. U, title IV, § 401(c)(2)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1206"},"text":"132 Stat. 1206","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id42ab333a-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id42ab333b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id42ab333c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (e)(7). ","children":[{"tag":"ref","attrib"