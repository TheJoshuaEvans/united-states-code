{"tag":"section","attrib":{"id":"id47c5f667-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706"},"text":null,"children":[{"tag":"num","attrib":{"value":"9706"},"text":"§ 9706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assignment of eligible beneficiaries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47c5f668-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter, the Commissioner of Social Security shall, before ","children":[{"tag":"date","attrib":{"date":"1993-10-01"},"text":"October 1, 1993","children":[],"tail":", assign each coal industry retiree who is an eligible beneficiary to a signatory operator which (or any related person with respect to which) remains in business in the following order:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id47c5f669-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" First, to the signatory operator which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47c5f66a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was a signatory to the 1978 coal wage agreement or any subsequent coal wage agreement, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47c5f66b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was the most recent signatory operator to employ the coal industry retiree in the coal industry for at least 2 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c5f66c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Second, if the retiree is not assigned under paragraph (1), to the signatory operator which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47c5f66d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was a signatory to the 1978 coal wage agreement or any subsequent coal wage agreement, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47c5f66e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was the most recent signatory operator to employ the coal industry retiree in the coal industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c5f66f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Third, if the retiree is not assigned under paragraph (1) or (2), to the signatory operator which employed the coal industry retiree in the coal industry for a longer period of time than any other signatory operator prior to the effective date of the 1978 coal wage agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47c5f670-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules relating to employment and reassignment upon purchase","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47c5f671-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aggregation rules","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47c5f672-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Related person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any employment of a coal industry retiree in the coal industry by a signatory operator shall be treated as employment by any related persons to such operator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47c5f673-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain employment disregarded","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Employment with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47c5f674-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person which is (and all related persons with respect to which are) no longer in business, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47c5f675-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person during a period during which such person was not a signatory to a coal wage agreement,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall not be taken into account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c5f676-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reassignment upon purchase","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a person becomes a successor of an assigned operator after the enactment date, the assigned operator may transfer the assignment of an eligible beneficiary under subsection (a) to such successor, and such successor shall be treated as the assigned operator with respect to such eligible beneficiary for purposes of this chapter. Notwithstanding the preceding sentence, the assigned operator transferring such assignment (and any related person) shall remain the guarantor of the benefits provided to the eligible beneficiary under this chapter. An assigned operator shall notify the trustees of the Combined Fund of any transfer described in this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47c5f677-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of eligible beneficiaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The 1950 UMWA Benefit Plan and the 1974 UMWA Benefit Plan shall, by the later of ","children":[{"tag":"date","attrib":{"date":"1992-10-01"},"text":"October 1, 1992","children":[],"tail":", or the twentieth day after the enactment date, provide to the Commissioner of Social Security a list of the names and social security account numbers of each eligible beneficiary, including each deceased eligible beneficiary if any other individual is an eligible beneficiary by reason of a relationship to such deceased eligible beneficiary. In addition, the plans shall provide, where ascertainable from plan records, the names of all persons described in subsection (a) with respect to any eligible beneficiary or deceased eligible beneficiary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47c5f678-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation by other agencies and persons","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47c5f679-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The head of any department, agency, or instrumentality of the United States shall cooperate fully and promptly with the Commissioner of Social Security in providing information which will enable the Commissioner to carry out his responsibilities under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c5f67a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Providing of information","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47c5f67b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, including section 6103, the head of any other agency, department, or instrumentality shall, upon receiving a written request from the Commissioner of Social Security in connection with this section, cause a search to be made of the files and records maintained by such agency, department, or instrumentality with a view to determining whether the information requested is contained in such files or records. The Commissioner shall be advised whether the search disclosed the information requested, and, if so, such information shall be promptly transmitted to the Commissioner, except that if the disclosure of any requested information would contravene national policy or security interests of the United States, or the confidentiality of census data, the information shall not be transmitted and the Commissioner shall be so advised.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47c5f67c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any information provided under subparagraph (A) shall be limited to information necessary for the Commissioner to carry out his duties under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c5f67d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trustees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The trustees of the Combined Fund, the 1950 UMWA Benefit Plan, the 1974 UMWA Benefit Plan, the 1950 UMWA Pension Plan, and the 1974 UMWA Pension Plan shall fully and promptly cooperate with the Commissioner in furnishing, or assisting the Commissioner to obtain, any information the Commissioner needs to carry out the Commissioner’s responsibilities under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47c5f67e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice by Commissioner","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47c5f67f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner of Social Security shall advise the trustees of the Combined Fund of the name of each person identified under this section as an assigned operator, and the names and social security account numbers of eligible beneficiaries with respect to whom he is identified.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c5f680-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner of Social Security shall notify each assigned operator of the names and social security account numbers of eligible beneficiaries who have been assigned to such person under this section and a brief summary of the facts related to the basis for such assignments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47c5f681-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reconsideration by Commissioner","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47c5f682-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any assigned operator receiving a notice under subsection (e)(2) with respect to an eligible beneficiary may, within 30 days of receipt of such notice, request from the Commissioner of Social Security detailed information as to the work history of the beneficiary and the basis of the assignment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c5f683-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An assigned operator may, within 30 days of receipt of the information under paragraph (1), request review of the assignment. The Commissioner of Social Security shall conduct such review if the Commissioner finds the operator provided evidence with the request constituting a prima facie case of error.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c5f684-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Results of review","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47c5f685-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Error","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Commissioner of Social Security determines under a review under paragraph (2) that an assignment was in error—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id47c5f686-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/f/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commissioner shall notify the assigned operator and the trustees of the Combined Fund and the trustees shall reduce the premiums of the operator under section 9704 by (or if there are no such premiums, repay) all premiums paid under section 9704 with respect to the eligible beneficiary, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id47c5f687-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/f/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commissioner shall review the beneficiary’s record for reassignment under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47c5f688-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No error","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Commissioner of Social Security determines under a review conducted under paragraph (2) that no error occurred, the Commissioner shall notify the assigned operator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c5f689-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any determination by the Commissioner of Social Security under paragraph (2) or (3) shall be final.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c5f68a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment pending review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An assigned operator shall pay the premiums under section 9704 pending review by the Commissioner of Social Security or by a court under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c5f68b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall preclude the right of any person to bring a separate civil action against another person for responsibility for assigned premiums, notwithstanding any prior decision by the Commissioner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47c8407c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person to which information is provided by the Commissioner of Social Security under this section shall not disclose such information except in any proceedings related to this section. Any civil or criminal penalty which is applicable to an unauthorized disclosure under section 6103 shall apply to any unauthorized disclosure under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47c8407d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assignments as of ","children":[{"tag":"date","attrib":{"date":"2007-10-01"},"text":"October 1, 2007","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id47c8407e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the premium obligation set forth in paragraph (3), the Commissioner of Social Security shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47c8407f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" revoke all assignments to persons other than 1988 agreement operators for purposes of assessing premiums for plan years beginning on and after ","children":[{"tag":"date","attrib":{"date":"2007-10-01"},"text":"October 1, 2007","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47c84080-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make no further assignments to persons other than 1988 agreement operators, except that no individual who becomes an unassigned beneficiary by reason of subparagraph (A) may be assigned to a 1988 agreement operator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c84081-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reassignment upon purchase","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall not be construed to prohibit the reassignment under subsection (b)(2) of an eligible beneficiary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47c84082-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability of persons during three fiscal years beginning on and after ","children":[{"tag":"date","attrib":{"date":"2007-10-01"},"text":"October 1, 2007","children":[],"tail":null}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of each of the fiscal years beginning on ","children":[{"tag":"date","attrib":{"date":"2007-10-01"},"text":"October 1, 2007","children":[],"tail":", 2008, and 2009, each person other than a 1988 agreement operator shall pay to the Combined Fund the following percentage of the amount of annual premiums that such person would otherwise be required to pay under section 9704(a), determined on the basis of assignments in effect without regard to the revocation of assignments under paragraph (1)(A):"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47c84083-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/h/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the fiscal year beginning on ","children":[{"tag":"date","attrib":{"date":"2007-10-01"},"text":"October 1, 2007","children":[],"tail":", 55 percent."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47c84084-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/h/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the fiscal year beginning on ","children":[{"tag":"date","attrib":{"date":"2008-10-01"},"text":"October 1, 2008","children":[],"tail":", 40 percent."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47c84085-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9706/h/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the fiscal year beginning on ","children":[{"tag":"date","attrib":{"date":"2009-10-01"},"text":"October 1, 2009","children":[],"tail":", 15 percent."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47c84086-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXIX/s19143/a"},"text":"Pub. L. 102–486, title XIX, § 19143(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3047"},"text":"106 Stat. 3047","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/296/tI/s108/h/9/B"},"text":"Pub. L. 103–296, title I, § 108(h)(9)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-15"},"text":"Aug. 15, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1487"},"text":"108 Stat. 1487","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/432/dC/tII/s212/a/3"},"text":"Pub. L. 109–432, div. C, title II, § 212(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3025"},"text":"120 Stat. 3025","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47c84087-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47c84088-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id47c84089-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":nul