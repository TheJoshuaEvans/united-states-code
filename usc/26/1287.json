{"tag":"section","attrib":{"id":"id44e03ae4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1287"},"text":null,"children":[{"tag":"num","attrib":{"value":"1287"},"text":"§ 1287.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial of capital gain treatment for gains on certain obligations not in registered form","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id44e03ae5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1287/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any registration-required obligation is not in registered form, any gain on the sale or other disposition of such obligation shall be treated as ordinary income (unless the issuance of such obligation was subject to tax under section 4701).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id44e03ae6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1287/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id44e03ae7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1287/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration-required obligation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “registration-required obligation” has the meaning given to such term by section 163(f)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id44e03ae8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1287/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registered form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “registered form” has the same meaning as when used in section 163(f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id44e03ae9-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tI/s41/a"},"text":"Pub. L. 98–369, div. A, title I, § 41(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/552"},"text":"98 Stat. 552","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/147/tV/s502/a/2/D"},"text":"Pub. L. 111–147, title V, § 502(a)(2)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-18"},"text":"Mar. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/107"},"text":"124 Stat. 107","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id44e03aea-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id44e03aeb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id44e03aec-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"hre