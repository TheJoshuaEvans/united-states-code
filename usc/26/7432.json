{"tag":"section","attrib":{"id":"id47535f17-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7432"},"text":null,"children":[{"tag":"num","attrib":{"value":"7432"},"text":"§ 7432.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil damages for failure to release lien","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47535f18-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7432/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any officer or employee of the Internal Revenue Service knowingly, or by reason of negligence, fails to release a lien under section 6325 on property of the taxpayer, such taxpayer may bring a civil action for damages against the United States in a district court of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47535f19-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7432/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Damages","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any action brought under subsection (a), upon a finding of liability on the part of the defendant, the defendant shall be liable to the plaintiff in an amount equal to the sum of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47535f1a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7432/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actual, direct economic damages sustained by the plaintiff which, but for the actions of the defendant, would not have been sustained, plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47535f1b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7432/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs of the action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47535f1c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7432/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Claims pursuant to this section shall be payable out of funds appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1304"},"text":"section 1304 of title 31","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47535f1d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7432/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47535f1e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7432/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement that administrative remedies be exhausted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A judgment for damages shall not be awarded under subsection (b) unless the court determines that the plaintiff has exhausted the administrative remedies available to such plaintiff within the Internal Revenue Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47535f1f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7432/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mitigation of damages","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of damages awarded under subsection (b)(1) shall be reduced by the amount of such damages which could have reasonably been mitigated by the plaintiff.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47535f20-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7432/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period for bringing action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, an action to enforce liability created under this section may be brought without regard to the amount in controversy and may be brought only within 2 years after the date the right of action accrues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47535f21-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s7432/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of failure to release lien","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall by regulation prescribe reasonable procedures for a taxpayer to notify the Secretary of the failure to release a lien under section 6325 on property of the taxpayer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47535f22-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tVI/s6240/a"},"text":"Pub. L. 100–647, title VI, § 6240(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3746"},"text":"102 Stat. 3746","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47535f23-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id47535f24-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id47535f25-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7432 was renumbered 7437 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id47535f26-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4755cf27-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/tVI/s6240/c"},"text":"Pub. L. 100–647, title VI, § 6240(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3747"},"text":"102 Stat. 3747","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/647/tVI/s6240/c"},"text":"“The amendments made by this section [enacting this section] shall apply to notices provided by the taxpayer of the failure to release a lien, and damages arising, after ","children":[{"tag":"date","attrib":{"date":"1988-12-31"},"text":"December 31, 1988","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
