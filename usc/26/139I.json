{"tag":"section","attrib":{"id":"id41810ae8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s139I"},"text":null,"children":[{"tag":"num","attrib":{"value":"139I"},"text":"§ 139I.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation coverage premium assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In the case of an assistance eligible individual (as defined in subsection (a)(3) of section 9501 of the American Rescue Plan Act of 2021), gross income does not include any premium assistance provided under subsection (a)(1) of such section.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id41810ae9-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2/tIX/s9501/b/4/A"},"text":"Pub. L. 117–2, title IX, § 9501(b)(4)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/137"},"text":"135 Stat. 137","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id41810aea-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id41810aeb-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id41810aec-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 9501 of the American Rescue Plan Act of 2021, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2/s9501"},"text":"section 9501 of Pub. L. 117–2","children":[],"tail":",