{"tag":"section","attrib":{"id":"id45d12b1a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4281"},"text":null,"children":[{"tag":"num","attrib":{"value":"4281"},"text":"§ 4281.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small aircraft on nonestablished lines","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45d12b1b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4281/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The taxes imposed by sections 4261 and 4271 shall not apply to transportation by an aircraft having a maximum certificated takeoff weight of 6,000 pounds or less, except when such aircraft is operated on an established line or when such aircraft is a jet aircraft.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45d12b1c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4281/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum certificated takeoff weight","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “maximum certificated takeoff weight” means the maximum such weight contained in the type certificate or airworthiness certificate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45d12b1d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4281/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sightseeing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, an aircraft shall not be considered as operated on an established line at any time during which such aircraft is being operated on a flight the sole purpose of which is sightseeing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45d12b1e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4281/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jet aircraft","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “jet aircraft” shall not include any aircraft which is a rotorcraft or propeller aircraft.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45d12b1f-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/258/tII/s205/a/1"},"text":"Pub. L. 91–258, title II, § 205(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-05-21"},"text":"May 21, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/241"},"text":"84 Stat. 241","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/248/tII/s280/c/2/B"},"text":"Pub. L. 97–248, title II, § 280(c)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/564"},"text":"96 Stat. 564","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tXI/s11124/a"},"text":"Pub. L. 109–59, title XI, § 11124(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1952"},"text":"119 Stat. 1952","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/95/tXI/s1107/a"},"text":"Pub. L. 112–95, title XI, § 1107(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/154"},"text":"126 Stat. 154","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dA/tII/s204/a"},"text":"Pub. L. 113–295, div. A, title II, § 204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4025"},"text":"128 Stat. 4025","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45d12b20-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45d12b21-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id45d12b22-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4281, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/508"},"text":"68A Stat. 508","children":[],"tail":", related to tax on transportation of oil by pipeline, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/85/475/s4/a"},"text":"Pub. L. 85–475, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-06-30"},"text":"June 30, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/260"},"text":"72 Stat. 260","children":[],"tail":". For effective date of repeal, see "},{"tag":"ref","attrib":{"href":"/us/pl/85/475/s4/c"},"text":"section 4(c) of Pub. L. 85–475","children":[],"tail":", set out as an Effective Date of 1958 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6415"},"text":"section 6415 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45d12b23-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" amended section generally. Prior to amendment, text read as follows: “The taxes imposed by sections 4261 and 4271 shall not apply to transportation by an aircraft having a maximum certificated takeoff weight of 6,000 pounds or less, except when such aircraft is operated on an established line or when such aircraft is a jet aircraft. For purposes of the preceding sentence, the term ‘maximum certificated takeoff weight’ means the maximum such weight contained in the type certificate or airworthiness certificate. For purposes of this section, an aircraft shall not be considered as operated on an established line at any time during which such aircraft is being operated on a flight the sole purpose of which is sightseeing.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95"},"text":"Pub. L. 112–95","children":[],"tail":" inserted “or when such aircraft is a jet aircraft” after “an established line” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":" inserted at end “For purposes of this section, an aircraft shall not be considered as operated on an established line at any time during which such aircraft is being operated on a flight the sole purpose of which is sightseeing.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248"},"text":"Pub. L. 97–248","children":[],"tail":" struck out “(as defined in section 4492(b))” after “certificated takeoff weight”, and inserted provision defining “maximum certificated takeoff weight”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45d12b24-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45d12b25-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295/dA/tII/s204/b"},"text":"Pub. L. 113–295, div. A, title II, § 204(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4025"},"text":"128 Stat. 4025","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/295/dA/tII/s204/b"},"text":"“The amendment made by subsection (a) [amending this section] shall take effect as if included in section 1107 of the FAA Modernization and Reform Act of 2012 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95"},"text":"Pub. L. 112–95","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45d12b26-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/tXI/s1107/b"},"text