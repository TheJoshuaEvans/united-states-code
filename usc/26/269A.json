{"tag":"section","attrib":{"id":"id4290f4f5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s269A"},"text":null,"children":[{"tag":"num","attrib":{"value":"269A"},"text":"§ 269A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personal service corporations formed or availed of to avoid or evade income tax","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4290f4f6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s269A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4290f4f7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s269A/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substantially all of the services of a personal service corporation are performed for (or on behalf of) 1 other corporation, partnership, or other entity, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4290f4f8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s269A/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the principal purpose for forming, or availing of, such personal service corporation is the avoidance or evasion of Federal income tax by reducing the income of, or securing the benefit of any expense, deduction, credit, exclusion, or other allowance for, any employee-owner which would not otherwise be available,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then the Secretary may allocate all income, deductions, credits, exclusions, and other allowances between such personal service corporation and its employee-owners, if such allocation is necessary to prevent avoidance or evasion of Federal income tax or clearly to reflect the income of the personal service corporation or any of its employee-owners.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4290f4f9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s269A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4290f4fa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s269A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personal service corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “personal service corporation” means a corporation the principal activity of which is the performance of personal services and such services are substantially performed by employee-owners.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4290f4fb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s269A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee-owner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “employee-owner” means any employee who owns, on any day during the taxable year, more than 10 percent of the outstanding stock of the personal service corporation. For purposes of the preceding sentence, section 318 shall apply, except that “5 percent” shall be substituted for “50 percent” in section 318(a)(2)(C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4290f4fc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s269A/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Related persons","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All related persons (within the meaning of section 144(a)(3)) shall be treated as 1 entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4290f4fd-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/tII/s250/a"},"text":"Pub. L. 97–248, title II, § 250(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/528"},"text":"96 Stat. 528","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXIII/s1301/j/4"},"text":"Pub. L. 99–514, title XIII, § 1301(j)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2657"},"text":"100 Stat. 2657","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4290f4fe-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4290f4ff-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4290f500-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “section 144(a)(3)” for “section 103(b)(6)(C)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4290f501-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4290f502-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" applicable to bonds issued after "},{"tag":"date","attrib":{"date":"1986-08-15"},"text":"Aug. 15, 1986","children":[],"tail":", except as otherwise provided, see sections 1311 to 1318 of "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", set out as an Effective Date; Transitional Rules note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s141"},"text":"section 141 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4290f503-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/tII/s250/c"},"text":"Pub. L. 97–248, title II, § 250(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/529"},"text":"96 Stat. 529","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/248/tII/s250/c"},"text":"“The amendments made by this section [enacting this section] shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1982-12-31"},"text":"December 31, 1982","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
