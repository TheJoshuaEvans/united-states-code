{"tag":"section","attrib":{"id":"id45199b37-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1473"},"text":null,"children":[{"tag":"num","attrib":{"value":"1473"},"text":"§ 1473.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45199b38-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1473/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withholdable payment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided by the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45199b39-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1473/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “withholdable payment” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45199b3a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1473/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any payment of interest (including any original issue discount), dividends, rents, salaries, wages, premiums, annuities, compensations, remunerations, emoluments, and other fixed or determinable annual or periodical gains, profits, and income, if such payment is from sources within the United States, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45199b3b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1473/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any gross proceeds from the sale or other disposition of any property of a type which can produce interest or dividends from sources within the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45199b3c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1473/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for income connected with United States business","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such term shall not include any item of income which is taken into account under section 871(b)(1) or 882(a)(1) for the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45199b3d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1473/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for sourcing interest paid by foreign branches of domestic financial institutions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subparagraph (B) of section 861(a)(1) shall not apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45199b3e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1473/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substantial United States owner","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45199b3f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1473/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “substantial United States owner” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45199b40-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1473/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to any corporation, any specified United States person which owns, directly or indirectly, more than 10 percent of the stock of such corporation (by vote or value),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45199b41-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1473/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to any partnership, any specified United States person which owns, directly or indirectly, more than 10 percent of the profits interests or capital interests in such partnership, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45199b42-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1473/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a trust—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id45199b43-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1473/2/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any specified United States person treated as an owner of any portion of such trust under subpart E of part I of subchapter J of chapter 1, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id45199b44-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1473/2/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent provided by the Secretary in regulations or other guidance, any specified United States person which holds, directly or indirectly, more than 10 percent of the beneficial interests of such trust.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45199b45-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1473/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for investment vehicles","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any financial institution described in section 1471(d)(5)(C), clauses (i), (ii), and (iii) of subparagraph (A) shall be applied by substituting “0 percent” for “10 percent”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45199b46-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1473/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specified United States person","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided by the Secretary, the term “specified United States person” means any United States person other than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45199b47-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1473/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any corporation the stock of which is regularly traded on an established securities market,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45199b48-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1473/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any corporation which is a member of the same expanded affiliated group (as defined in section 1471(e)(2) without regard to the last sentence thereof) as a corporation the stock of which is regularly traded on an established securities market,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45199b49-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1473/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any organization exempt from taxation under section 501(a) or an individual retirement plan,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45199b4a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1473/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States or any wholly owned agency or instrumentality thereof,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45199b4b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1473/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any State, the District of Columbia, any possession of the United States, any political subdivision of any of the foregoing, or any wholly owned agency or instrumentality of any one or more of the foregoing,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45199b4c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1473/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any bank (as defined in section 581),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45199b4d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1473/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any real estate investment trust (as defined in section 856),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45199b4e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1473/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any regulated investment company (as defined in section 851),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45199b4f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1473/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any common trust fund (as defined in section 584(a)), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45199b50-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1473/3/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any trust which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45199b51-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1473/3/J/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is exempt from tax under section 664(c), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45199b52-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1473/3/J/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is described in section 4947(a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45199b53-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1473/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withholding agent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “withholding agent” means all persons, in whatever capacity acting, having the control, receipt, custody, disposal, or payment of any withholdable payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45199b54-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s1473/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “foreign entity” means any entity which is not a United States person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45199b55-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/147/tV/s501/a"},"text":"Pub. L. 111–147, title V, § 501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-18"},"text":"Mar. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/103"},"text":"124 Stat. 103","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
