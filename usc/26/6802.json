{"tag":"section","attrib":{"id":"id473b9070-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6802"},"text":null,"children":[{"tag":"num","attrib":{"value":"6802"},"text":"§ 6802.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supply and distribution","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall furnish, without prepayment, to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id473b9071-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6802/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Postmaster General","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Postmaster General a suitable quantity of adhesive stamps, coupons, tickets, or such other devices as may be prescribed by the Secretary pursuant to section 6302(b) or this chapter, to be distributed to, and kept on sale by, the various postmasters in the United States in all post offices of the first and second classes, and such post offices of the third and fourth classes as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id473b9072-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6802/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are located in county seats, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id473b9073-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6802/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are certified by the Secretary to the Postmaster General as necessary;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id473b9074-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6802/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designated depositary of the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any designated depositary of the United States a suitable quantity of adhesive stamps to be kept on sale by such designated depositary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id473b9075-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/829"},"text":"68A Stat. 829","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/44/tVI/s601/d"},"text":"Pub. L. 89–44, title VI, § 601(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-06-21"},"text":"June 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/154"},"text":"79 Stat. 154","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/a/36"},"text":"Pub. L. 94–455, title XIX, § 1906(a)(36)","children":[],"tail":", (b)(13)(A), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1829"},"text":"90 Stat. 1829","children":[],"tail":", 1834.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id473b9076-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id473b9077-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id473b9078-3a70-11f1-a967-d35dac11796a"},"text":null,"childr