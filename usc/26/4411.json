{"tag":"section","attrib":{"id":"id45d5e60b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4411"},"text":null,"children":[{"tag":"num","attrib":{"value":"4411"},"text":"§ 4411.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of tax","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45d5e60c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4411/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be imposed a special tax of $500 per year to be paid by each person who is liable for the tax imposed under section 4401 or who is engaged in receiving wagers for or on behalf of any person so liable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45d5e60d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4411/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized persons","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall be applied by substituting “$50” for “$500” in the case of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45d5e60e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4411/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person whose liability for tax under section 4401 is determined only under paragraph (1) of section 4401(a), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45d5e60f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4411/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person who is engaged in receiving wagers only for or on behalf of persons described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45d5e610-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/527"},"text":"68A Stat. 527","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/499/s3/b"},"text":"Pub. L. 93–499, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-29"},"text":"Oct. 29, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1550"},"text":"88 Stat. 1550","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/362/tI/s109/b"},"text":"Pub. L. 97–362, title I, § 109(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-25"},"text":"Oct. 25, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1731"},"text":"96 Stat. 1731","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45d5e611-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45d5e612-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45d5e613-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/362"},"text":"Pub. L. 97–362","children":[],"tail":" designated existing provisions as subsec. (a), in subsec. (a), as so designated, substituted “liable for the tax imposed” for “liable for tax”, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/499"},"text":"Pub. L. 93–499","children":[],"tail":" substituted “$500” for “$50”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45d5e614-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45d5e615-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1982 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/362/tI/s109/c/2"},"text":"Pub. L. 97–362, title I, § 109(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-25"},"text":"Oct. 25, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1731"},"text":"96 Stat. 1731","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/362/tI/s109/c/2"},"text":"“The amendment made by subsection (b) [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1983-07-01"},"text":"July 1, 1983","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45d5e616-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1974 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/499"},"text":"Pub. L. 93–499","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1974-12-01"},"text":"Dec. 1, 1974","children":[],"tail":", and applicable only with respect to wagers placed on or after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/93/499/s3/d/1"},"text":"section 3(d)(1) of Pub. L. 93–499","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4401"},"text":"section 4401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id45d5e617-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Persons Engaged in Activities on ","children":[{"tag":"date","attrib":{"date":"1974-12-01"},"text":"December 1, 1974","children":[],"tail":", Requiring Payment of Tax; Persons Paying Tax and Registering Before "},{"tag":"date","attrib":{"date":"1974-12-01"},"text":"December 1, 1974","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/499/s3/d/2"},"text":"Pub. L. 93–499, § 3(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-29"},"text":"Oct. 29, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1551"},"text":"88 Stat. 1551","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/s2"},"text":"\n","children":[{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person who, on ","children":[{"tag":"date","attrib":{"date":"1974-12-01"},"text":"December 1, 1974","children":[],"tail":", is engaged in an activity which makes him liable for payment of the tax imposed by section 4411 of the Internal Revenue Code of 1986 [formerly I.R.C. 1954] (as in effect on such date) shall be treated as commencing such activity on such date for purposes of such section and section 4901 of such Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Any person who, before ","children":[{"tag":"date","attrib":{"date":"1974-12-01"},"text":"December 1, 1974","children":[],"tail":".—"}],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" became liable for and paid the tax imposed by section 4411 of the Internal Revenue Code of 1986 (as in effect on ","children":[{"tag":"date","attrib":{"date":"1974-07-01"},"text":"July 1, 1974","children":[],"tail":") for the year ending "},{"tag":"date","attrib":{"date":"1975-06-30"},"text":"June 30, 1975","children":[],"tail":", shall not be liable for any additional tax under such section for such year, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" registered under section 4412 of such Code (as in effect on ","children":[{"tag":"date","attrib":{"date":"1974-07-01"},"text":"July 1, 1974","children":[],"tail":") for the year ending "},{"tag":"date","attrib":{"date":"1975-06-30"},"text":"June 30, 1975","children":[],"tail":", shall not be required to reregister under such section for such year.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
