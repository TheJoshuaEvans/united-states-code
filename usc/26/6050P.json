{"tag":"section","attrib":{"id":"id467cd4f5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050P"},"text":null,"children":[{"tag":"num","attrib":{"value":"6050P"},"text":"§ 6050P.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Returns relating to the cancellation of indebtedness by certain entities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id467cd4f6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050P/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any applicable entity which discharges (in whole or in part) the indebtedness of any person during any calendar year shall make a return (at such time and in such form as the Secretary may by regulations prescribe) setting forth—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467cd4f7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050P/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address, and TIN of each person whose indebtedness was discharged during such calendar year,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467cd4f8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050P/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of the discharge and the amount of the indebtedness discharged, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467cd4f9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050P/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467cd4fa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050P/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not apply to any discharge of less than $600.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467cd4fb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050P/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467cd4fc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050P/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “applicable entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id467cd4fd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050P/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an executive, judicial, or legislative agency (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3701/a/4"},"text":"section 3701(a)(4) of title 31","children":[],"tail":", United States Code), and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467cd4fe-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050P/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an applicable financial entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467cd4ff-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050P/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable financial entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “applicable financial entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id467cd500-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050P/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any financial institution described in section 581 or 591(a) and any credit union,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467cd501-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050P/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Deposit Insurance Corporation, the Resolution Trust Corporation, the National Credit Union Administration, and any other Federal executive agency (as defined in section 6050M), and any successor or subunit of any of the foregoing,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467cd502-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050P/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other corporation which is a direct or indirect subsidiary of an entity referred to in subparagraph (A) but only if, by virtue of being affiliated with such entity, such other corporation is subject to supervision and examination by a Federal or State agency which regulates entities referred to in subparagraph (A), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id467cd503-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050P/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any organization a significant trade or business of which is the lending of money.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467cd504-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050P/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Governmental units","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an entity described in paragraph (1)(A) or (2)(B), any return under this section shall be made by the officer or employee appropriately designated for the purpose of making such return.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467cd505-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050P/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statements to be furnished to persons with respect to whom information is required to be furnished","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Every applicable entity required to make a return under subsection (a) shall furnish to each person whose name is required to be set forth in such return a written statement showing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id467cd506-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050P/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name and address of the entity required to make such return, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id467cd507-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050P/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information required to be shown on the return with respect to such person.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The written statement required under the preceding sentence shall be furnished to the person on or before January 31 of the year following the calendar year for which the return under subsection (a) was made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467f4508-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050P/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative procedure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In lieu of making a return required under subsection (a), an agency described in subsection (c)(1)(A) may submit to the Secretary (at such time and in such form as the Secretary may by regulations prescribe) information sufficient for the Secretary to complete such a return on behalf of such agency. Upon receipt of such information, the Secretary shall complete such return and provide a copy of such return to such agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id467f4509-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13252/a"},"text":"Pub. L. 103–66, title XIII, § 13252(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/531"},"text":"107 Stat. 531","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/134/tIII/s31001/m/2/A"},"text":"Pub. L. 104–134, title III, § 31001(m)(2)(A)","children":[],"tail":"–(D)(ii), "},{"tag":"date","attrib":{"date":"1996-04-26"},"text":"Apr. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1321-368"},"text":"110 Stat. 1321–368","children":[],"tail":", 1321–369; "},{"tag":"ref","attrib":{"href":"/us/pl/106/170/tV/s533/a"},"text":"Pub. L. 106–170, title V, § 533(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-17"},"text":"Dec. 17, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1931"},"text":"113 Stat. 1931","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id467f450a-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id467f450b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id467f450c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Subsec. (c)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/170"},"text":"Pub. L. 106–170","children":[],"tail":" added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134/s31001/m/2/D/ii"},"text":"Pub. L. 104–134, § 31001(m)(2)(D)(ii)","children":[],"tail":", amended section catchline generally, striking out “financial” before “entities”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134/s31001/m/2/A"},"text":"Pub. L. 104–134, § 31001(m)(2)(A)","children":[],"tail":", struck out “financial” before “entity” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134/s31001/m/2/B"},"text":"Pub. L. 104–134, § 31001(m)(2)(B)","children":[],"tail":", added par. (1), redesignated former par. (1) as (2), and redesignated former par. (2) as (3) and substituted “(1)(A) or (2)(B)” for “(1)(B)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134/s31001/m/2/D/i"},"text":"Pub. L. 104–134, § 31001(m)(2)(D)(i)","children":[],"tail":", struck out “financial” before “entity” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134/s31001/m/2/C"},"text":"Pub. L. 104–134, § 31001(m)(2)(C)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id467f450d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id467f450e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1999 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/170/tV/s533/b"},"text":"Pub. L. 106–170, title V, § 533(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-17"},"text":"Dec. 17, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1931"},"text":"113 Stat. 1931","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/170/tV/s533/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply to discharges of indebtedness after ","children":[{"tag":"date","attrib":{"date":"1999-12-31"},"text":"December 31, 1999","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id467f450f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13252/d"},"text":"Pub. L. 103–66, title XIII, § 13252(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/532"},"text":"107 Stat. 532","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/66/tXIII/s13252/d"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), the amendments made by this section [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6724"},"text":"section 6724 of this title","children":[],"tail":"] shall apply to discharges of indebtedness after "},{"tag":"date","attrib":{"date":"1993-12-31"},"text":"December 31, 1993","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Governmental entities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of an entity referred to in section 6050P(c)(1)(B) of the Internal Revenue Code of 1986 (as added by this section), the amendments made by this section shall apply to discharges of indebtedness after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
