{"tag":"section","attrib":{"id":"id467a63cc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050D"},"text":null,"children":[{"tag":"num","attrib":{"value":"6050D"},"text":"§ 6050D.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Returns relating to energy grants and financing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id467a63cd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050D/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every person who administers a Federal, State, or local program a principal purpose of which is to provide subsidized financing or grants for projects to conserve or produce energy shall, to the extent required under regulations prescribed by the Secretary, make a return setting forth the name and address of each taxpayer receiving financing or a grant under such program and the aggregate amount so received by such individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id467a63ce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6050D/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “person” means the officer or employee having control of the program, or the person appropriately designated for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id467a63cf-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/223/tII/s203/b/1"},"text":"Pub. L. 96–223, title II, § 203(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-04-02"},"text":"Apr. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/259"},"text":"94 Stat. 259","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id467a63d0-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id467a63d1-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id467a63d2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/223/tII/s203/c"},"text":"Pub. L. 96–223, title II, § 203(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-04-02"},"text":"Apr. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/259"},"text":"94 Stat. 259","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/223/tII/s203/c"},"text":"“The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s23"},"text":"section 23 of this title","children":[],"tail":"] shall apply to taxable years beginning after "},{"tag":"date","attrib":{"date":"1980-12-31"},"text":"December 31, 1980","children":[],"tail":", but only with respect to financing or grants made after such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
