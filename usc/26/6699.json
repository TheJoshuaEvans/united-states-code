attrib":{},"text":"2008—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/458"},"text":"Pub. L. 110–458","children":[],"tail":" substituted “$89” for “$85”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id472fa99b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id472fa99c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97"},"text":"Pub. L. 115–97","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"2017-12-31"},"text":"Dec. 31, 2017","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/s11002/e"},"text":"section 11002(e) of Pub. L. 115–97","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id472fa99d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295"},"text":"Pub. L. 113–295","children":[],"tail":" applicable to returns required to be filed, and statements required to be furnished, after "},{"tag":"date","attrib":{"date":"2014-12-31"},"text":"Dec. 31, 2014","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/s208/h"},"text":"section 208(h) of Pub. L. 113–295","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6651"},"text":"section 6651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id472fa99e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/92"},"text":"Pub. L. 111–92","children":[],"tail":" applicable to returns for taxable years beginning after "},{"tag":"date","attrib":{"date":"2009-12-31"},"text":"Dec. 31, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/92/s16/b"},"text":"section 16(b) of Pub. L. 111–92","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6698"},"text":"section 6698 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id472fa99f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/458/tI/s128/b"},"text":"Pub. L. 110–458, title I, § 128(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-12-23"},"text":"Dec. 23, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/5116"},"text":"122 Stat. 5116","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/458/tI/s128/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply to returns required to be filed after ","children":[{"tag":"date","attrib":{"date":"2008-12-31"},"text":"December 31, 2008","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id472fa9a0-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/142/s9/c"},"text":"Pub. L. 110–142, § 9(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-20"},"text":"Dec. 20, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1808"},"text":"121 Stat. 1808","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/142/s9/c"},"text":"“The amendments made by this section [enacting this section] shall apply to returns required to be filed after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2007-12-20"},"text":"Dec. 20, 2007","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
