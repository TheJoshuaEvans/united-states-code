{"tag":"section","attrib":{"id":"id472fa988-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6699"},"text":null,"children":[{"tag":"num","attrib":{"value":"6699"},"text":"§ 6699.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to file S corporation return","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id472fa989-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6699/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the penalty imposed by section 7203 (relating to willful failure to file return, supply information, or pay tax), if any S corporation required to file a return under section 6037 for any taxable year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id472fa98a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6699/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fails to file such return at the time prescribed therefor (determined with regard to any extension of time for filing), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id472fa98b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6699/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" files a return which fails to show the information required under section 6037,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"such S corporation shall be liable for a penalty determined under subsection (b) for each month (or fraction thereof) during which such failure continues (but not to exceed 12 months), unless it is shown that such failure is due to reasonable cause.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id472fa98c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6699/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount per month","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a), the amount determined under this subsection for any month is the product of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id472fa98d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6699/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $195, multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id472fa98e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6699/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of persons who were shareholders in the S corporation during any part of the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id472fa98f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6699/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment of penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The penalty imposed by subsection (a) shall be assessed against the S corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id472fa990-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6699/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deficiency procedures not to apply","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subchapter B of chapter 63 (relating to deficiency procedures for income, estate, gift, and certain excise taxes) shall not apply in respect of the assessment or collection of any penalty imposed by subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id472fa991-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6699/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment for inflation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id472fa992-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6699/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any return required to be filed in a calendar year beginning after 2014, the $195 dollar amount under subsection (b)(1) shall be increased by an amount equal to such dollar amount multiplied by the cost-of-living adjustment determined under section 1(f)(3) for the calendar year determined by substituting “calendar year 2013” for “calendar year 2016” in subparagraph (A)(ii) thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id472fa993-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6699/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rounding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any amount adjusted under paragraph (1) is not a multiple of $5, such amount shall be rounded to the next lowest multiple of $5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id472fa994-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/142/s9/a"},"text":"Pub. L. 110–142, § 9(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-20"},"text":"Dec. 20, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1807"},"text":"121 Stat. 1807","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/458/tI/s128/a"},"text":"Pub. L. 110–458, title I, § 128(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-12-23"},"text":"Dec. 23, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/5116"},"text":"122 Stat. 5116","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/92/s16/a"},"text":"Pub. L. 111–92, § 16(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-11-06"},"text":"Nov. 6, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2996"},"text":"123 Stat. 2996","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/dB/tII/s208/e"},"text":"Pub. L. 113–295, div. B, title II, § 208(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4073"},"text":"128 Stat. 4073","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s11002/d/1/OO"},"text":"Pub. L. 115–97, title I, § 11002(d)(1)(OO)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2061"},"text":"131 Stat. 2061","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dU/tIV/s401/a/299/E"},"text":"Pub. L. 115–141, div. U, title IV, § 401(a)(299)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1198"},"text":"132 Stat. 1198","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id472fa995-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id472fa996-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Inflation Adjusted Items for Certain Years","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For inflation adjustment of certain items in this section, see Revenue Procedures listed in a table under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id472fa997-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id472fa998-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/142/s9/a"},"text":"Section 9(a) of Pub. L. 110–142","children":[],"tail":", which directed amendment of this part by adding this section at the end, was executed by inserting this section after section 6698, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id472fa999-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6699, added ","children":[{"tag":"ref","a