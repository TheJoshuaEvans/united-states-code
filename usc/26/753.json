{"tag":"section","attrib":{"id":"id4404f755-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s753"},"text":null,"children":[{"tag":"num","attrib":{"value":"753"},"text":"§ 753.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partner receiving income in respect of decedent","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The amount includible in the gross income of a successor in interest of a deceased partner under section 736(a) shall be considered income in respect of a decedent under section 691.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4404f756-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/251"},"text":"68A Stat. 251","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
