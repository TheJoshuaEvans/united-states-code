{"tag":"section","attrib":{"id":"id47a6d615-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9003"},"text":null,"children":[{"tag":"num","attrib":{"value":"9003"},"text":"§ 9003.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Condition for eligibility for payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47a6d616-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9003/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to be eligible to receive any payments under section 9006, the candidates of a political party in a presidential election shall, in writing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47a6d617-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9003/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agree to obtain and furnish to the Commission such evidence as it may request of the qualified campaign expenses of such candidates,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47a6d618-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9003/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agree to keep and furnish to the Commission such records, books, and other information as it may request, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47a6d619-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9003/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agree to an audit and examination by the Commission under section 9007 and to pay any amounts required to be paid under such section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47a6d61a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9003/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Major parties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to be eligible to receive any payments under section 9006, the candidates of a major party in a presidential election shall certify to the Commission, under penalty of perjury, that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47a6d61b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9003/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such candidates and their authorized committees will not incur qualified campaign expenses in excess of the aggregate payments to which they will be entitled under section 9004, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47a6d61c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9003/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no contributions to defray qualified campaign expenses have been or will be accepted by such candidates or any of their authorized committees except to the extent necessary to make up any deficiency in payments received out of the fund on account of the application of section 9006(c), and no contributions to defray expenses which would be qualified campaign expenses but for subparagraph (C) of section 9002(11) have been or will be accepted by such candidates or any of their authorized committees.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such certification shall be made within such time prior to the day of the presidential election as the Commission shall prescribe by rules or regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47a6d61d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9003/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minor and new parties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to be eligible to receive any payments under section 9006, the candidates of a minor or new party in a presidential election shall certify to the Commission, under penalty of perjury, that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47a6d61e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9003/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such candidates and their authorized committees will not incur qualified campaign expenses in excess of the aggregate payments to which the eligible candidates of a major party are entitled under section 9004, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47a6d61f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9003/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such candidates and their authorized committees will accept and expend or retain contributions to defray qualified campaign expenses only to the extent that the qualified campaign expenses incurred by such candidates and their authorized committees certified to under paragraph (1) exceed the aggregate payments received by such candidates out of the fund pursuant to section 9006.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such certification shall be made within such time prior to the day of the presidential election as the Commission shall prescribe by rules or regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47a6d620-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9003/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal by candidate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any case in which an individual ceases to be a candidate as a result of the operation of the last sentence of section 9002(2), such individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47a6d621-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9003/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall no longer be eligible to receive any payments under section 9006, except that such individual shall be eligible to receive payments under such section to defray qualified campaign expenses incurred while actively seeking election to the office of President of the United States or to the office of Vice President of the United States in more than one State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47a6d622-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9003/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall pay to the Secretary, as soon as practicable after the date upon which such individual ceases to be a candidate, an amount equal to the amount of payments received by such individual under section 9006 which are not used to defray qualified campaign expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47a6d623-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s9003/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Closed captioning requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No candidate for the office of President or Vice President may receive amounts from the Presidential Election Campaign Fund under this chapter or chapter 96 unless such candidate has certified that any television commercial prepared or distributed by the candidate will be prepared in a manner which ensures that the commercial contains or is accompanied by closed captioning of the oral content of the commercial to be broadcast in line 21 of the vertical blanking interval, or is capable of being viewed by deaf and hearing impaired individuals via any comparable successor technology to line 21 of the vertical blanking interval.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47a6d624-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/178/tVIII/s801"},"text":"Pub. L. 92–178, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-10"},"text":"Dec. 10, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/564"},"text":"85 Stat. 564","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/93/53/s6/c"},"text":"Pub. L. 93–53, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-07-01"},"text":"July 1, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/139"},"text":"87 Stat. 139","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/443/tIV"},"text":"Pub. L. 93–443, title IV","children":[],"tail":", §§ 404(c)(4), (5), 405(b), "},{"tag":"date","attrib":{"date":"1974-10-15"},"text":"Oct. 15, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1292"},"text":"8