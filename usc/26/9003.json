ll},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" substituted “section 9006(c)” for “section 9006(d)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/393"},"text":"Pub. L. 102–393","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" struck out “or his delegate” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/283"},"text":"Pub. L. 94–283","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/443"},"text":"Pub. L. 93–443","children":[],"tail":", §§ 404(c)(4), 405(b), substituted “Commission” and “it” for “Comptroller General” and “he”, respectively, wherever appearing, struck out in par. (1) “with respect to which payment is sought” after “campaign expenses” and struck out par. (4) requirement for an agreement to furnish statements of qualified campaign expenses and proposed qualified campaign expenses required under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s9008"},"text":"section 9008 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/443/s404/c/5"},"text":"Pub. L. 93–443, § 404(c)(5)","children":[],"tail":", substituted “Commission” for “Comptroller General” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/53"},"text":"Pub. L. 93–53","children":[],"tail":" substituted section “9006(d)” for “9006(c)”."}],"tail":"\n"}],"tail":"\n"},{"tag"