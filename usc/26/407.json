{"tag":"section","attrib":{"id":"id430f4bd8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s407"},"text":null,"children":[{"tag":"num","attrib":{"value":"407"},"text":"§ 407.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain employees of domestic subsidiaries engaged in business outside the United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id430f4bd9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s407/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment as employees of domestic parent corporation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id430f4bda-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s407/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of applying this part with respect to a pension, profit-sharing, or stock bonus plan described in section 401(a) or an annuity plan described in section 403(a), of a domestic parent corporation, an individual who is a citizen or resident of the United States and who is an employee of a domestic subsidiary (within the meaning of paragraph (2)) of such domestic parent corporation shall be treated as an employee of such domestic parent corporation, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id430f4bdb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s407/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan of such domestic parent corporation expressly provides for contributions or benefits for individuals who are citizens or residents of the United States and who are employees of its domestic subsidiaries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id430f4bdc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s407/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contributions under a funded plan of deferred compensation (whether or not a plan described in section 401(a) or 403(a)) are not provided by any other person with respect to the remuneration paid to such individual by the domestic subsidiary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id430f4bdd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s407/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id430f4bde-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s407/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Domestic subsidiary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A corporation shall be treated as a domestic subsidiary for any taxable year only if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id430f4bdf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s407/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such corporation is a domestic corporation 80 percent or more of the outstanding voting stock of which is owned by another domestic corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id430f4be0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s407/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 95 percent or more of its gross income for the three-year period immediately preceding the close of its taxable year which ends on or before the close of the taxable year of such other domestic corporation (or for such part of such period during which the corporation was in existence), was derived from sources without the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id430f4be1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s407/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 90 percent or more of its gross income for such period (or such part) was derived from the active conduct of a trade or business.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"If for the period (or part thereof) referred to in clauses (ii) and (iii) such corporation has no gross income, the provisions of clauses (ii) and (iii) shall be treated as satisfied if it is reasonable to anticipate that, with respect to the first taxable year thereafter for which such corporation has gross income, the provisions of such clauses will be satisfied.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id430f4be2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s407/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Domestic parent corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The domestic parent corporation of any domestic subsidiary is the domestic corporation which owns 80 percent or more of the outstanding voting stock of such domestic subsidiary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id430f4be3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s407/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for application of section 401(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id430f4be4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s407/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondiscrimination requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of applying section 401(a)(4) and section 410(b) with respect to an individual who is treated as an employee of a domestic parent corporation under subsection (a)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id430f4be5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s407/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such individual is a highly compensated employee (within the meaning of section 414(q)), he shall be treated as having such capacity with respect to such domestic parent corporation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id430f4be6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s407/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the determination of whether such individual is a highly compensated employee (as so defined) shall be made by treating such individual’s total compensation (determined with the application of paragraph (2) of this subsection) as compensation paid by such domestic parent corporation and by determining such individual’s status with regard to such domestic parent corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id430f4be7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s407/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of applying paragraph (5) of section 401(a) with respect to an individual who is treated as an employee of a domestic parent corporation under subsection (a), the total compensation of such individual shall be the remuneration paid to such individual by the domestic subsidiary which would constitute his total compensation if his services had been performed for such domestic parent corporation, and the basic or regular rate of compensation of such individual shall be determined under regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id430f4be8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s407/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"[(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI/s1401/b/8"},"text":"Pub. L. 104–188, title I, § 1401(b)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1789"},"text":"110 Stat. 1789","children":[],"tail":"]"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id430f4be9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s407/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deductibility of contributions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of applying section 404 with respect to contributions made to or under a pension, profit-sharing, stock bonus, or annuity plan by a domestic parent corporation, or by another corporation which is entitled to deduct its contributions under section 404(a)(3)(B), on behalf of an individual who is treated as an employee of such domestic corporation under subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id430f4bea-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s407/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in paragraph (2), no deduction shall be allowed to such domestic parent corporation or to any other corporation which is entitled to deduct its contributions under such sections,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id430f4beb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s407/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there shall be allowed as a deduction to the domestic subsidiary of which such individual is an employee an amount equal to the amount which (but for paragraph (1)) would be deductible under section 404 by the domestic parent corporation if he were an employee of the domestic parent corporation, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id430f4bec-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s407/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any reference to compensation shall be considered to be a reference to the total compensation of such individual (determined with the application of subsection (b)(2)).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Any amount deductible by a domestic subsidiary under this subsection shall be deductible for its taxable year with or within which the taxable year of such domestic parent corporation ends.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id430f4bed-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s407/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment as employee under related provisions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual who is treated as an employee of a domestic parent corporation under subsection (a) shall also be treated as an employee of such domestic parent corporation, with respect to the plan described in subsection (a)(1)(A), for purposes of applying the following provisions of this title:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id430f4bee-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s407/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 72(f) (relating to special rules for computing employees’ contributions).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id430f4bef-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s407/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 2039 (relating to annuities).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id430f4bf0-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/272/tII/s220/b"},"text":"Pub. L. 88–272, title II, § 220(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-02-26"},"text":"Feb. 26, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/60"},"text":"78 Stat. 60","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/91/172/tV/s515/c/3"},"text":"Pub. L. 91–172, title V, § 515(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/646"},"text":"83 Stat. 646","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/406/tII"},"text":"Pub. L. 93–406, title II","children":[],"tail":", §§ 1016(a)(5), 2005(c)(13), "},{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/929"},"text":"88 Stat. 929","children":[],"tail":", 992; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIX/s1906/b/13/A"},"text":"Pub. L. 94–455, title XIX, § 1906(b)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1834"},"text":"90 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/21/tIII/s321/d"},"text":"Pub. L. 98–21, title III, § 321(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-04-20"},"text":"Apr. 20, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/119"},"text":"97 Stat. 119","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tIV/s491/d/16"},"text":"Pub. L. 98–369, div. A, title IV, § 491(d)(16)","children":[],"tail":"–(18), "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/850"},"text":"98 Stat. 850","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXI"},"text":"Pub. L. 99–514, title XI","children":[],"tail":", §§ 1112(d)(3), 1114(b)(9)(B), (C), title XVIII, § 1852(e)(2)(D), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2445"},"text":"100 Stat. 2445","children":[],"tail":", 2451, 2868; "},{"tag":"ref","attrib":{"href":"/us/pl/100/647/tI/s1011A/b/1/C"},"text":"Pub. L. 100–647, title I, § 1011A(b)(1)(C)","children":[],"tail":", (16), "},{"tag":"date","attrib":{"date":"1988-11-10"},"text":"Nov. 10, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3472"},"text":"102 Stat. 3472","children":[],"tail":", 3475; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII"},"text":"Pub. L. 101–239, title VII","children":[],"tail":", §§ 7811(g)(3), 7831(f), "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2409"},"text":"103 Stat. 2409","children":[],"tail":", 2427; "},{"tag":"ref","attrib":{"href":"/us/pl/102/318/tV/s521/b/15"},"text":"Pub. L. 102–318, title V, § 521(b)(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-03"},"text":"July 3, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/311"},"text":"106 Stat. 311","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/188/tI"},"text":"Pub. L. 104–188, title I","children":[],"tail":", §§ 1401(b)(8), 1402(b)(2), "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1789"},"text":"110 Stat. 1789","children":[],"tail":", 1790.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id430f4bf1-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id430f4bf2-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id430f4bf3-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1401/b/8"},"text":"Pub. L. 104–188, § 1401(b)(8)","children":[],"tail":", struck out subsec. (c) which related to treatment of termination of status as deemed employee."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/188/s1402/b/2"},"text":"Pub. L. 104–188, § 1402(b)(2)","children":[],"tail":", redesignated par. (3) as (2) and struck out former par. (2) which read as follows: “Section 101(b) (relating to employees’ death benefits).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/318"},"text":"Pub. L. 102–318","children":[],"tail":" substituted “402(d)” for “402(e)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7831/f"},"text":"Pub. L. 101–239, § 7831(f)","children":[],"tail":", made technical correction to "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1114/b/9/B"},"text":"Pub. L. 99–514, § 1114(b)(9)(B)","children":[],"tail":", see 1986 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7811/g/3"},"text":"Pub. L. 101–239, § 7811(g)(3)","children":[],"tail":", substituted “purposes of limitation” for “purposes limitation” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1011A/b/16"},"text":"Pub. L. 100–647, § 1011A(b)(16)","children":[],"tail":", struck out “of capital gain provisions and” after “service for purposes” in heading and substituted “applying section 402(e)” for “applying subsections (a)(2) and (e) of section 402, and section 403(a)(2)” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647/s1011A/b/1/C"},"text":"Pub. L. 100–647, § 1011A(b)(1)(C)","children":[],"tail":", redesignated pars. (2) to (4) as (1) to (3), respectively, and struck out former par. (1) which read as follows: “Section 72(d) (relating to employees’ annuities).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1112/d/3"},"text":"Pub. L. 99–514, § 1112(d)(3)","children":[],"tail":", struck out “(without regard to paragraph (1)(A) thereof)” after “section 410(b)” in introductory text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1114/b/9/B"},"text":"Pub. L. 99–514, § 1114(b)(9)(B)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7831/f"},"text":"Pub. L. 101–239, § 7831(f)","children":[],"tail":", substituted “a highly compensated employee (within the meaning of section 414(q))” for “an officer, shareholder, or person whose principal duties consist in supervising the work of other employees of a domestic subsidiary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1114/b/9/C"},"text":"Pub. L. 99–514, § 1114(b)(9)(C)","children":[],"tail":", inserted “(as so defined)” after “employee”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1852/e/2/D"},"text":"Pub. L. 99–514, § 1852(e)(2)(D)","children":[],"tail":", struck out par. (5) which read as follows: “Section 2517 (relating to certain annuities under qualified plans).”"}],"tail":"\n"},{"tag":"p","attrib":{},"te