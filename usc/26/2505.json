{"tag":"section","attrib":{"id":"id45420a16-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2505"},"text":null,"children":[{"tag":"num","attrib":{"value":"2505"},"text":"§ 2505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unified credit against gift tax","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45420a17-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2505/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a citizen or resident of the United States, there shall be allowed as a credit against the tax imposed by section 2501 for each calendar year an amount equal to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45420a18-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2505/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicable credit amount in effect under section 2010(c) which would apply if the donor died as of the end of the calendar year, reduced by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45420a19-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2505/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sum of the amounts allowable as a credit to the individual under this section for all preceding calendar periods.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of applying paragraph (2) for any calendar year, the rates of tax in effect under section 2502(a)(2) for such calendar year shall, in lieu of the rates of tax in effect for preceding calendar periods, be used in determining the amounts allowable as a credit under this section for all preceding calendar periods.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45420a1a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2505/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment to credit for certain gifts made before 1977","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount allowable under subsection (a) shall be reduced by an amount equal to 20 percent of the aggregate amount allowed as a specific exemption under section 2521 (as in effect before its repeal by the Tax Reform Act of 1976) with respect to gifts made by the individual after ","children":[{"tag":"date","attrib":{"date":"1976-09-08"},"text":"September 8, 1976","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45420a1b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s2505/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation based on amount of tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of the credit allowed under subsection (a) for any calendar year shall not exceed the amount of the tax imposed by section 2501 for such calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45420a1c-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXX/s2001/b/2"},"text":"Pub. L. 94–455, title XX, § 2001(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1849"},"text":"90 Stat. 1849","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/34/tIV"},"text":"Pub. L. 97–34, title IV","children":[],"tail":", §§ 401(b), 442(a)(5), "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/299"},"text":"95 Stat. 299","children":[],"tail":", 321; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXI/s11801/a/40"},"text":"Pub. L. 101–508, title XI, § 11801(a)(40)","children":[],"tail":", (c)(19)(B), "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-521"},"text":"104 Stat. 1388–521","children":[],"tail":", 1388–528; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tV/s501/a/2"},"text":"Pub. L. 105–34, title V, § 501(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/845"},"text":"111 Stat. 845","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/16/tV/s521/b"},"text":"Pub. L. 107–16, title V, § 521(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-06-07"},"text":"June 7, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/71"},"text":"115 Stat. 71","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/312/tIII"},"text":"Pub. L. 111–312, title III","children":[],"tail":", §§ 301(b), 302(b)(1)(A), (d)(2), 303(b)(1), "},{"tag":"date","attrib":{"date":"2010-12-17"},"text":"Dec. 17, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3300-3303"},"text":"124 Stat. 3300–3303","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45420a1d-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45420a1e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id45420a1f-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Tax Reform Act of 1976, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1520"},"text":"90 Stat. 1520","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s2521"},"text":"Section 2521 of this title","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/s2001/b/3"},"text":"section 2001(b)(3) of Pub. L. 94–455","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45420a20-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/312/s302/d/2"},"text":"Pub. L. 111–312, § 302(d)(2)","children":[],"tail":", inserted concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/312/s303/b/1"},"text":"Pub. L. 111–312, § 303(b)(1)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “the applicable credit amount in effect under section 2010(c) for such calendar year, reduced by”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/312/s302/b/1/A"},"text":"Pub. L. 111–312, § 302(b)(1)(A)","children":[],"tail":", struck out “(determined as if the applicable exclusion amount were $1,000,000)” after “calendar year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/312/s301/b"},"text":"Pub. L. 111–312, § 301(b)","children":[],"tail":", amended subsec. (a)(1) to read as if amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/107/16/s521/b/2"},"text":"Pub. L. 107–16, § 521(b)(2)","children":[],"tail":", had never been enacted. See 2001 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16/s521/b/2"},"text":"Pub. L. 107–16, § 521(b)(2)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “the applicable credit amount in effect under section 2010(c) for such calendar year (determined as if the applicable exclusion amount were $1,000,000), reduced by”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16/s521/b/1"},"text":"Pub. L. 107–16, § 521(b)(1)","children":[],"tail":", inserted “(determined as if the applicable exclusion amount were $1,000,000)” after “calendar year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" substituted “the applicable credit amount in effect under section 2010(c) for such calendar year” for “$192,800”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsecs. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" redesignated subsecs. (c) and (d) as subsecs. (b) and (c), respectively, and struck out former subsec. (b) which provided for a phase-in of the unified credit against gift tax."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s442/a/5/A"},"text":"Pub. L. 97–34, § 442(a)(5)(A)","children":[],"tail":", substituted in provision preceding par. (1) “year” for “quarter”, and “periods” for “quarters” in par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s401/b/1"},"text":"Pub. L. 97–34, § 401(b)(1)","children":[],"tail":", substituted “$192,800” for “$47,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/34/s401/b/2"},"text":"Pub. L. 97–34, § 401(b)(2)","children":[],"tail":", struck out from heading “$47,000” before “credit”, substituted subsec. (a)(1) substitutions for “$192,800” of amounts of “$62,800”, “$79,300”, “$96,300”, “$121,800”, and “$155,800” in the case of gifts made in 1982, 1983, 1984, 1985, and 1986, respectively, for subsec. (a)(1) substitutions for “$47,000” of amounts of “$6,000”, “$30,000”, “$34,000”, “$38,000”, and “$42,500” in the case of gifts made after "},{"tag":"date","attrib":{"date":"1976-12-31"},"text":"Dec. 31, 1976","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"1977-07-01"},"text":"July 1, 1977","children":[],"tail":", after "},{"tag":"date","attrib":{"date":"1977-06-30"},"text":"June 30, 1977","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"1978-01-01"},"text":"Jan. 1, 1978","children":[],"tail":"; after "},{"tag":"date","attrib":{"date":"1977-12-31"},"text":"Dec. 31, 1977","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"1979-01-01"},"text":"Jan. 1, 1979","children":[],"tail":", after "},{"tag":"date","attrib":{"date":"1978-12-31"},"text":"Dec. 31, 1978","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"1980-01-01"},"text":"Jan. 1, 1980","children":[],"tail":", and after "},{"tag":"date","attrib":{"date":"1979-12-31"},"text":"Dec. 31, 1979","children":[],"tail":",