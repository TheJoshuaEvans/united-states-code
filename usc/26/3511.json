{"tag":"section","attrib":{"id":"id45a3d9c2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3511"},"text":null,"children":[{"tag":"num","attrib":{"value":"3511"},"text":"§ 3511.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certified professional employer organizations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id45a3d9c3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3511/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of the taxes, and other obligations, imposed by this subtitle—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45a3d9c4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3511/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certified professional employer organization shall be treated as the employer (and no other person shall be treated as the employer) of any work site employee performing services for any customer of such organization, but only with respect to remuneration remitted by such organization to such work site employee, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45a3d9c5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3511/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the exemptions, exclusions, definitions, and other rules which are based on type of employer and which would (but for paragraph (1)) apply shall apply with respect to such taxes imposed on such remuneration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45a3d9c6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3511/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Successor employer status","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of sections 3121(a)(1), 3231(e)(2)(C), and 3306(b)(1)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45a3d9c7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3511/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certified professional employer organization entering into a service contract with a customer with respect to a work site employee shall be treated as a successor employer and the customer shall be treated as a predecessor employer during the term of such service contract, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45a3d9c8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3511/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a customer whose service contract with a certified professional employer organization is terminated with respect to a work site employee shall be treated as a successor employer and the certified professional employer organization shall be treated as a predecessor employer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45a3d9c9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3511/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability of certified professional employer organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Solely for purposes of its liability for the taxes and other obligations imposed by this subtitle—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45a3d9ca-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3511/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certified professional employer organization shall be treated as the employer of any individual (other than a work site employee or a person described in subsection (f)) who is performing services covered by a contract meeting the requirements of section 7705(e)(2), but only with respect to remuneration remitted by such organization to such individual, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45a3d9cb-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3511/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the exemptions, exclusions, definitions, and other rules which are based on type of employer and which would (but for paragraph (1)) apply shall apply with respect to such taxes imposed on such remuneration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45a3d9cc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3511/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of credits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45a3d9cd-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3511/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of any credit specified in paragraph (2)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45a3d9ce-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3511/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such credit with respect to a work site employee performing services for the customer applies to the customer, not the certified professional employer organization,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45a3d9cf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3511/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the customer, and not the certified professional employer organization, shall take into account wages and employment taxes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id45a3d9d0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3511/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paid by the certified professional employer organization with respect to the work site employee, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id45a3d9d1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3511/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which the certified professional employer organization receives payment from the customer, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45a3d9d2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3511/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the certified professional employer organization shall furnish the customer and the Secretary with any information necessary for the customer to claim such credit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45a3d9d3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3511/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credits specified","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A credit is specified in this paragraph if such credit is allowed under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id45a3d9d4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3511/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 41 (credit for increasing research activity),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45a3d9d5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3511/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 45A (Indian employment credit),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45a3d9d6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3511/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 45B (credit for portion of employer social security taxes paid with respect to employee cash tips),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45a3d9d7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3511/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 45C (clinical testing expenses for certain drugs for rare diseases or conditions),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45a3d9d8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3511/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 45R (employee health insurance expenses of small employers),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45a3d9d9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3511/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 45AA (military spouse retirement plan eligibility credit),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45a3d9da-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3511/d/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 51 (work opportunity credit),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45a3d9db-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3511/d/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 1396 (empowerment zone employment credit), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id45a3d9dc-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3511/d/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other section as provided by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45a64add-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3511/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for related party","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply in the case of a customer which bears a relationship to a certified professional employer organization described in section 267(b) or 707(b). For purposes of the preceding sentence, such sections shall be applied by substituting “10 percent” for “50 percent”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45a64ade-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3511/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for certain individuals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of the taxes imposed under this subtitle, an individual with net earnings from self-employment derived from the customer’s trade or business (including a partner in a partnership that is a customer) is not a work site employee with respect to remuneration paid by a certified professional employer organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45a64adf-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3511/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirements and obligations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall develop such reporting and recordkeeping rules, regulations, and procedures as the Secretary determines necessary or appropriate to ensure compliance with this title by certified professional employer organizations or persons that have been so certified. Such rules shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45a64ae0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3511/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notification of the Secretary in such manner as the Secretary shall prescribe in the case of the commencement or termination of a service contract described in section 7705(e)(2) between such a person and a customer, and the employer identification number of such customer,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45a64ae1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3511/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such information as the Secretary determines necessary for the customer to claim the credits identified in subsection (d) and the manner in which such information is to be provided, as prescribed by the Secretary, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45a64ae2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3511/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Secretary determines is essential to promote compliance with respect to the credits identified in subsection (d) and section 3302, and","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be designed in a manner which streamlines, to the extent possible, the application of requirements of this section and section 7705, the exchange of information between a certified professional employer organization and its customers, and the reporting and recordkeeping obligations of the certified professional employer organization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id45a64ae3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s3511/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such regulations as may be necessary or appropriate to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45a64ae4-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/295/dB/tII/s206/a"},"text":"Pub. L. 113–295, div. B, title II, § 206(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/4065"},"text":"128 Stat. 4065","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dT/tI/s112/c"},"text":"Pub. L. 117–328, div. T, title I, § 112(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5295"},"text":"136 Stat. 5295","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id45a64ae5-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id45a64ae6-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id45a64ae7-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (d)(2)(F) to (I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" added subpar. (F) and redesignated former subpars. (F) to (H) as (G) to (I), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id45a64ae8-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id45a64ae9-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" applicable to taxable years beginning after "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/s112/e"},"text":"section 112(e) of Pub. L. 117–328","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s38"},"text":"section 38 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id45a64aea-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to wages for services performed on or after January 1 of the first calendar year beginning more than 12 months after ","children":[{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/113/295/s206/g/1"},"text":"section 206(g)(1) of Pub. L. 113–295","children":[],"tail":", set out as an Effective Date of 2014 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s3302"},"text":"section 3302 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
