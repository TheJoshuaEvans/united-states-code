{"tag":"section","attrib":{"id":"id40dc8d16-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S"},"text":null,"children":[{"tag":"num","attrib":{"value":"45S"},"text":"§ 45S.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employer credit for paid family and medical leave","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id40dc8d17-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of credit","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40dc8d18-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of section 38, in the case of an eligible employer, the paid family and medical leave credit is an amount equal to either of the following (as elected by such employer):","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40dc8d19-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The applicable percentage of the amount of wages paid to qualifying employees with respect to any period in which such employees are on family and medical leave.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40dc8d1a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If such employer has an insurance policy with regards to the provision of paid family and medical leave which is in force during the taxable year, the applicable percentage of the total amount of premiums paid or incurred by such employer during such taxable year with respect to such insurance policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40dc8d1b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable percentage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1), the term “applicable percentage” means 12.5 percent increased (but not above 25 percent) by 0.25 percentage points for each percentage point by which the rate of payment (as described under subsection (c)(1)(B)) exceeds 50 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40dc8d1c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rate of payment determined without regard to whether leave is taken","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of determining the applicable percentage with respect to paragraph (1)(B), the rate of payment under the insurance policy shall be determined without regard to whether any qualifying employees were on family and medical leave during the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40dc8d1d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40dc8d1e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The wages taken into account under subsection (a) with respect to any employee for any taxable year shall not exceed an amount equal to the product of the normal hourly wage rate of such employee for each hour (or fraction thereof) of actual services performed for the employer and the number of hours (or fraction thereof) for which family and medical leave is taken.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40dc8d1f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-hourly wage rate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1), in the case of any employee who is not paid on an hourly wage rate, the wages of such employee shall be prorated to an hourly wage rate under regulations established by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40dc8d20-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount of leave subject to credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of family and medical leave that may be taken into account with respect to any employee under subsection (a) for any taxable year shall not exceed 12 weeks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40dc8d21-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible employer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40dc8d22-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible employer” means any employer who has in place a written policy that meets the following requirements:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40dc8d23-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The policy provides—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40dc8d24-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a qualifying employee who is not a part-time employee (as defined in section 4980E(d)(4)(B)), not less than 2 weeks of annual paid family and medical leave, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40dc8d25-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a qualifying employee who is a part-time employee, an amount of annual paid family and medical leave that is not less than an amount which bears the same ratio to the amount of annual paid family and medical leave that is provided to a qualifying employee described in clause (i) as—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id40dc8d26-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/c/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of hours the employee is expected to work during any week, bears to","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id40dc8d27-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/c/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of hours an equivalent qualifying employee described in clause (i) is expected to work during the week.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40dc8d28-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The policy requires that the rate of payment under the program is not less than 50 percent of the wages normally paid to such employee for services performed for the employer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40dc8d29-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for certain employers","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40dc8d2a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An added employer shall not be treated as an eligible employer unless such employer provides paid family and medical leave in compliance with a written policy which ensures that the employer—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40dc8d2b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will not interfere with, restrain, or deny the exercise of or the attempt to exercise, any right provided under the policy, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40dc8d2c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will not discharge or in any other manner discriminate against any individual for opposing any practice prohibited by the policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40dc8d2d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Added employer; added employee","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this paragraph—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40dc8d2e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Added employee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “added employee” means a qualifying employee who is not covered by title I of the Family and Medical Leave Act of 1993, as amended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40dc8d2f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Added employer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “added employer” means an eligible employer (determined without regard to this paragraph), whether or not covered by that title I, who offers paid family and medical leave to added employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40dc8d30-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aggregation rule","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40dc8d31-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), all persons which are treated as a single employer under subsections (b) and (c) of section 414 shall be treated as a single employer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40dc8d32-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id40dc8d33-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subparagraph (A) shall not apply to any person who establishes to the satisfaction of the Secretary that such person has a substantial and legitimate business reason for failing to provide a written policy described in paragraph (1) or (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id40dc8d34-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substantial and legitimate business reason","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of clause (i), the term “substantial and legitimate business reason” shall not include the operation of a separate line of business, the rate of wages or category of jobs for employees (or any similar basis), or the application of State or local laws relating to family and medical leave, but may include the grouping of employees of a common law employer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40dc8d35-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of benefits mandated or paid for by State or local governments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, any leave which is paid by a State or local government or required by State or local law—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id40dc8d36-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in subparagraph (B), shall be taken into account in determining the amount of paid family and medical leave provided by the employer, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id40dc8d37-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be taken into account in determining the amount of the paid family and medical leave credit under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40dc8d38-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No inference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection shall be construed as subjecting an employer to any penalty, liability, or other consequence (other than ineligibility for the credit allowed by reason of subsection (a) or recapturing the benefit of such credit) for failure to comply with the requirements of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40dc8d39-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying employees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “qualifying employee” means any employee (as defined in section 3(e) of the Fair Labor Standards Act of 1938, as amended) who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40dc8d3a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been employed by the employer for 1 year or more (or, at the election of the employer, for not less than 6 months), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40dc8d3b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the preceding year, had compensation, as determined on an annualized basis (pro-rata for part-time employees), not in excess of an amount equal to 60 percent of the amount applicable for such year under clause (i) of section 414(q)(1)(B), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40dc8d3c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is customarily employed for not less than 20 hours per week.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40dc8d3d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Family and medical leave","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40dc8d3e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), for purposes of this section, the term “family and medical leave” means leave for any 1 or more of the purposes described under subparagraph (A), (B), (C), (D), or (E) of paragraph (1), or paragraph (3), of section 102(a) of the Family and Medical Leave Act of 1993, as amended, whether the leave is provided under that Act or by a policy of the employer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40dc8d3f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an employer provides paid leave as vacation leave, personal leave, or medical or sick leave (other than leave specifically for 1 or more of the purposes referred to in paragraph (1)), that paid leave shall not be considered to be family and medical leave under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40dc8d40-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the terms “vacation leave”, “personal leave”, and “medical or sick leave” mean those 3 types of leave, within the meaning of section 102(d)(2) of that Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40dc8d41-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinations made by Secretary of Treasury","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, any determination as to whether an employer or an employee satisfies the applicable requirements for an eligible employer (as described in subsection (c)) or qualifying employee (as described in subsection (d)), respectively, shall be made by the Secretary based on such information, to be provided by the employer, as the Secretary determines to be necessary or appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40dc8d42-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wages","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “wages” has the meaning given such term by subsection (b) of section 3306 (determined without regard to any dollar limitation contained in such section). Such term shall not include any amount taken into account for purposes of determining any other credit allowed under this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id40dc8d43-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election to have credit not apply","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id40dc8d44-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A taxpayer may elect to have this section not apply for any taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id40dc8d45-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s45S/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rules similar to the rules of paragraphs (2) and (3) of section 51(j) shall apply for purposes of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id40dc8d46-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/97/tI/s13403/a/1"},"text":"Pub. L. 115–97, title I, § 13403(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2135"},"text":"131 Stat. 2135","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/dQ/tI/s142/a"},"text":"Pub. L. 116–94, div. Q, title I, § 142(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3234"},"text":"133 Stat. 3234","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dEE/tI/s119/a"},"text":"Pub. L. 116–260, div. EE, title I, § 119(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3051"},"text":"134 Stat. 3051","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70304/a"},"text":"Pub. L. 119–21, title VII, § 70304(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/195"},"text":"139 Stat. 195","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id40dc8d47-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id40dc8d48-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id40dc8d49-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Family and Medical Leave Act of 1993 and that Act, referred to in subsecs. (c)(2)(B) and (e)(1), (3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/3"},"text":"Pub. L. 103–3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-02-05"},"text":"Feb. 5, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/6"},"text":"107 Stat. 6","children":[],"tail":". Title I of the Act is classified generally to subchapter I (§ 2611 et seq.) of chapter 28 of Title 29, Labor. Section 102 of the Act is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612"},"text":"section 2612 of Title 29","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2601"},"text":"section 2601 of Title 29","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3(e) of the Fair Labor Standards Act of 1938, referred to in subsec. (d), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s203/e"},"text":"section 203(e) of Title 29","children":[],"tail":", Labor."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id40dc8d4a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70304/a/1/A"},"text":"Pub. L. 119–21, § 70304(a)(1)(A)","children":[],"tail":", added par. (1) and struck out former par. (1). Prior to amendment, text read as follows: “For purposes of section 38, in the case of an eligible employer, the paid family and medical leave credit is an amount equal to the applicable percentage of the amount of wages paid to qualifying employees during any period in which such employees are on family and medical leave.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70304/a/1/B"},"text":"Pub. L. 119–21, § 70304(a)(1)(B)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70304/a/2"},"text":"Pub. L. 119–21, § 70304(a)(2)","children":[],"tail":", substituted “wages taken into account” for “credit allowed”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70304/a/3"},"text":"Pub. L. 119–21, § 70304(a)(3)","children":[],"tail":", added pars. (3) and (4) and struck out former pars. (3) and (4) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) ","children":[{"tag":"inline","attrib":{},"text":"Aggregation rule","children":[],"tail":".—All persons which are treated as a single employer under subsections (a) and (b) of section 52 shall be treated as a single taxpayer."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) ","children":[{"tag":"inline","attrib":{},"text":"Treatment of benefits mandated or paid for by state or local governments","children":[],"tail":".—For purposes of this section, any leave which is paid by a State or local government or required by State or local law shall not be taken into account in determining the amount of paid family and medical leave provided by the employer.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70304/a/4/A"},"text":"Pub. L. 119–21, § 70304(a)(4)(A)","children":[],"tail":", inserted “(or, at the election of the employer, for not less than 6 months)” after “1 year or more”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70304/a/4/B/i"},"text":"Pub. L. 119–21, § 70304(a)(4)(B)(i)","children":[],"tail":", inserted “, as determined on an annualized basis (pro-rata for part-time employees),” after “compensation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70304/a/4/B/ii"},"text":"Pub. L. 119–21, § 70304(a)(4)(B)(ii)","children":[],"tail":", (C), added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s70304/a/5"},"text":"Pub. L. 119–21, § 70304(a)(5)","children":[],"tail":", struck out subsec. (i). Text read as follows: “This section shall not apply to wages paid in taxable years beginning after "},{"tag":"date","attrib":{"date":"2025-12-31"},"text":"December 31, 2025","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2025-12-31"},"text":"December 31, 2025","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2020-12-31"},"text":"December 31, 2020","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94"},"text":"Pub. L. 116–94","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2020-12-31"},"text":"December 31, 2020","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2019-12-31"},"text":"December 31, 2019","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id40dc8d4b-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id40dc8d4c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s70304/c"},"text":"Pub. L. 119–21, title VII, § 70304(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/197"},"text":"139 Stat. 197","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/21/tVII/s70304/c"},"text":"“The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s280C"},"text":"section 280C of this title","children":[],"tail":"] shall apply to taxable years beginning after "},{"tag":"date","attrib":{"date":"2025-12-31"},"text":"December 31, 2025","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id40dc8d4d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dEE/tI/s119/b"},"text":"Pub. L. 116–260, div. EE, title I, § 119(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3051"},"text":"134 Stat. 3051","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/260/dEE/tI/s119/b"},"text":"“The amendment made by this section [amending this section] shall apply to wages paid in taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2020-12-31"},"text":"December 31, 2020","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id40dc8d4e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2019 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dQ/tI/s142/b"},"text":"Pub. L. 116–94, div. Q, title I, § 142(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3234"},"text":"133 Stat. 3234","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/94/dQ/tI/s142/b"},"text":"“The amendment made by this section [amending this section] shall apply to wages paid in taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2019-12-31"},"text":"December 31, 2019","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id40dc8d4f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to wages paid in taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2017-12-31"},"text":"Dec. 31, 2017","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/97/s13403/e"},"text":"section 13403(e) of Pub. L. 115–97","children":[],"tail":", set out as an Effective Date of 2017 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s38"},"text":"section 38 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
