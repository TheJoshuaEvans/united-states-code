{"tag":"section","attrib":{"id":"id45d37585-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4373"},"text":null,"children":[{"tag":"num","attrib":{"value":"4373"},"text":"§ 4373.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemptions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The tax imposed by section 4371 shall not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id45d37586-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4373/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effectively connected items","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amount which is effectively connected with the conduct of a trade or business within the United States unless such amount is exempt from the application of section 882(a) pursuant to a treaty obligation of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id45d37587-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s4373/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indemnity bond","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any indemnity bond required to be filed by any person to secure payment of any pension, allowance, allotment, relief, or insurance by the United States, or to secure a duplicate for, or the payment of, any bond, note, certificate of indebtedness, war-saving certificate, warrant or check, issued by the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id45d37588-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"