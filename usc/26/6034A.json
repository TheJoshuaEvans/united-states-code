{"tag":"section","attrib":{"id":"id46650662-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6034A"},"text":null,"children":[{"tag":"num","attrib":{"value":"6034A"},"text":"§ 6034A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information to beneficiaries of estates and trusts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id46650663-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6034A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The fiduciary of any estate or trust required to file a return under section 6012(a) for any taxable year shall, on or before the date on which such return was required to be filed, furnish to each beneficiary (or nominee thereof)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46650664-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6034A/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who receives a distribution from such estate or trust with respect to such taxable year, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46650665-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6034A/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to whom any item with respect to such taxable year is allocated,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"a statement containing such information required to be shown on such return as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46650666-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6034A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nominee reporting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person who holds an interest in an estate or trust as a nominee for another person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id46650667-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6034A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall furnish to the estate or trust, in the manner prescribed by the Secretary, the name and address of such other person, and any other information for the taxable year as the Secretary may by form and regulations prescribe, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46650668-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6034A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall furnish in the manner prescribed by the Secretary to such other person the information provided by the estate or trust under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id46650669-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6034A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Beneficiary’s return must be consistent with estate or trust return or Secretary notified of inconsistency","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4665066a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6034A/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A beneficiary of any estate or trust to which subsection (a) applies shall, on such beneficiary’s return, treat any reported item in a manner which is consistent with the treatment of such item on the applicable entity’s return.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4665066b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6034A/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of inconsistent treatment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4665066c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6034A/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any reported item, if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4665066d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6034A/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4665066e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6034A/c/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicable entity has filed a return but the beneficiary’s treatment on such beneficiary’s return is (or may be) inconsistent with the treatment of the item on the applicable entity’s return, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4665066f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6034A/c/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicable entity has not filed a return, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46650670-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6034A/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the beneficiary files with the Secretary a statement identifying the inconsistency,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"paragraph (1) shall not apply to such item.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46650671-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6034A/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Beneficiary receiving incorrect information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A beneficiary shall be treated as having complied with clause (ii) of subparagraph (A) with respect to a reported item if the beneficiary—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id46650672-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6034A/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates to the satisfaction of the Secretary that the treatment of the reported item on the beneficiary’s return is consistent with the treatment of the item on the statement furnished under subsection (a) to the beneficiary by the applicable entity, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id46650673-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6034A/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" elects to have this paragraph apply with respect to that item.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46650674-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6034A/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of failure to notify","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any case—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46650675-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6034A/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" described in subparagraph (A)(i)(I) of paragraph (2), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46650676-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6034A/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which the beneficiary does not comply with subparagraph (A)(ii) of paragraph (2),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"any adjustment required to make the treatment of the items by such beneficiary consistent with the treatment of the items on the applicable entity’s return shall be treated as arising out of mathematical or clerical errors and assessed according to section 6213(b)(1). Paragraph (2) of section 6213(b) shall not apply to any assessment referred to in the preceding sentence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id46650677-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6034A/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id46650678-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6034A/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reported item","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “reported item” means any item for which information is required to be furnished under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id46650679-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6034A/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “applicable entity” means the estate or trust of which the taxpayer is the beneficiary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4665067a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6034A/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Addition to tax for failure to comply with section","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For addition to tax in the case of a beneficiary’s negligence in connection with, or disregard of, the requirements of this section, see part II of subchapter A of chapter 68.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4665067b-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tVII/s714/q/1"},"text":"Pub. L. 98–369, div. A, title VII, § 714(q)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/965"},"text":"98 Stat. 965","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXV/s1501/c/15"},"text":"Pub. L. 99–514, title XV, § 1501(c)(15)","children":[],"tail":", title XVIII, § 1875(d)(3)(A), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2740"},"text":"100 Stat. 2740","children":[],"tail":", 2896; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tX/s1027/a"},"text":"Pub. L. 105–34, title X, § 1027(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/925"},"text":"111 Stat. 925","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4665067c-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4665067d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4665067e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1501/c/15"},"text":"Pub. L. 99–514, § 1501(c)(15)","children":[],"tail":", in introductory provisions, substituted “required to file a return” for “making the return required to be filed” and “was required to be filed” for “was filed”, and in concluding provisions, substituted “required to be shown on such return” for “shown on such return”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1875/d/3/A/i"},"text":"Pub. L. 99–514, § 1875(d)(3)(A)(i)","children":[],"tail":", (ii), designated existing provisions as subsec. (a), inserted heading “General rule”, and substituted “each beneficiary (or nominee thereof)” for “each beneficiary” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1875/d/3/A/iii"},"text":"Pub. L. 99–514, § 1875(d)(3)(A)(iii)","children":[],"tail":", added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4665067f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46650680-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34/tX/s1027/c"},"text":"Pub. L. 105–34, title X, § 1027(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/926"},"text":"111 Stat. 926","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/34/tX/s1027/c"},"text":"“The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6048"},"text":"section 6048 of this title","children":[],"tail":"] shall apply to returns of beneficiaries and owners filed after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id46650681-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1501/c/15"},"text":"section 1501(c)(15) of Pub. L. 99–514","children":[],"tail":" applicable to returns the due date for which (determined without regard to extensions) is after "},{"tag":"date","attrib":{"date":"1986-12-31"},"text":"Dec. 31, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1501/e"},"text":"section 1501(e) of Pub. L. 99–514","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6721"},"text":"section 6721 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVIII/s1875/d/3/B"},"text":"Pub. L. 99–514, title XVIII, § 1875(d)(3)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2897"},"text":"100 Stat. 2897","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/514/tXVIII/s1875/d/3/B"},"text":"“The amendments made by this paragraph [amending this section] shall apply to taxable years of estates and trusts beginning after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id46650682-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tVII/s714/q/5"},"text":"Pub. L. 98–369, div. A, title VII, § 714(q)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/966"},"text":"98 Stat. 966","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/369/dA/tVII/s714/q/5"},"text":"“The amendments made by this subsection [enacting this section and amending sections 6037 and 6678 of this title] shall apply to taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"1984-12-31"},"text":"December 31, 1984","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id46650683-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Plan Amendments Not Required Until January 1, 1989","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions directing that if any amendments made by subtitle A or subtitle C of title XI [§§ 1101–1147 and 1171–1177] or title XVIII [§§ 1800–1899A] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" require an amendment to any plan, such plan amendment shall not be required to be made before the first plan year beginning on or after "},{"tag":"date","attrib":{"date":"1989-01-01"},"text":"Jan. 1, 1989","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1140"},"text":"section 1140 of Pub. L. 99–514","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s401"},"text":"section 401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
