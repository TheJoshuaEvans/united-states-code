{"tag":"section","attrib":{"id":"id47321b3d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6707A"},"text":null,"children":[{"tag":"num","attrib":{"value":"6707A"},"text":"§ 6707A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for failure to include reportable transaction information with return","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id47321b3e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6707A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who fails to include on any return or statement any information with respect to a reportable transaction which is required under section 6011 to be included with such return or statement shall pay a penalty in the amount determined under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47321b3f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6707A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of penalty","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47321b40-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6707A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this subsection, the amount of the penalty under subsection (a) with respect to any reportable transaction shall be 75 percent of the decrease in tax shown on the return as a result of such transaction (or which would have resulted from such transaction if such transaction were respected for Federal tax purposes).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47321b41-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6707A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum penalty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of the penalty under subsection (a) with respect to any reportable transaction shall not exceed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47321b42-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6707A/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a listed transaction, $200,000 ($100,000 in the case of a natural person), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47321b43-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6707A/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any other reportable transaction, $50,000 ($10,000 in the case of a natural person).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47321b44-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6707A/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of the penalty under subsection (a) with respect to any transaction shall not be less than $10,000 ($5,000 in the case of a natural person).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47321b45-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6707A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47321b46-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6707A/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reportable transaction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “reportable transaction” means any transaction with respect to which information is required to be included with a return or statement because, as determined under regulations prescribed under section 6011, such transaction is of a type which the Secretary determines as having a potential for tax avoidance or evasion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47321b47-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6707A/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Listed transaction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “listed transaction” means a reportable transaction which is the same as, or substantially similar to, a transaction specifically identified by the Secretary as a tax avoidance transaction for purposes of section 6011.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47321b48-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6707A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to rescind penalty","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47321b49-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6707A/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commissioner of Internal Revenue may rescind all or any portion of any penalty imposed by this section with respect to any violation if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4734643a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6707A/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the violation is with respect to a reportable transaction other than a listed transaction, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4734643b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6707A/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rescinding the penalty would promote compliance with the requirements of this title and effective tax administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4734643c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6707A/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No judicial appeal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, any determination under this subsection may not be reviewed in any judicial proceeding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4734643d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6707A/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a penalty is rescinded under paragraph (1), the Commissioner shall place in the file in the Office of the Commissioner the opinion of the Commissioner with respect to the determination, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4734643e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6707A/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of the facts and circumstances relating to the violation,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4734643f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6707A/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reasons for the rescission, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47346440-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6707A/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the penalty rescinded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47346441-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6707A/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty reported to SEC","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id47346442-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6707A/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is required to file periodic reports under section 13 or 15(d) of the Securities Exchange Act of 1934 or is required to be consolidated with another person for purposes of such reports, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id47346443-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6707A/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id47346444-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6707A/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is required to pay a penalty under this section with respect to a listed transaction,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47346445-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6707A/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is required to pay a penalty under section 6662A with respect to any reportable transaction at a rate prescribed under section 6662A(c), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id47346446-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6707A/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is required to pay a penalty under section 6662(h) with respect to any reportable transaction and would (but for section 6662A(e)(2)(B)) have been subject to penalty under section 6662A at a rate prescribed under section 6662A(c),","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the requirement to pay such penalty shall be disclosed in such reports filed by such person for such periods as the Secretary shall specify. Failure to make a disclosure in accordance with the preceding sentence shall be treated as a failure to which the penalty under subsection (b)(2) applies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id47346447-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6707A/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with other penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The penalty imposed by this section shall be in addition to any other penalty imposed by this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id47346448-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s811/a"},"text":"Pub. L. 108–357, title VIII, § 811(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1575"},"text":"118 Stat. 1575","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/172/s11/a/41"},"text":"Pub. L. 110–172, § 11(a)(41)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-29"},"text":"Dec. 29, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2488"},"text":"121 Stat. 2488","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/240/tII/s2041/a"},"text":"Pub. L. 111–240, title II, § 2041(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-09-27"},"text":"Sept. 27, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2560"},"text":"124 Stat. 2560","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id47346449-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4734644a-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4734644b-3a70-11f1-a967-d35dac11796a"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 13 and 15(d) of the Securities Exchange Act of 1934, referred to in subsec. (e)(1), are classified to sections 78m and 78","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(d), respectively, of Title 15, Commerce and Trade."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4734644c-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/240"},"text":"Pub. L. 111–240","children":[],"tail":" amended subsec. (b) generally. Prior to amendment, subsec. (b) specified the amount of the penalty under subsec. (a), both in general and with respect to a listed transaction, in the case of a natural person or in any other case."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (e)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/172"},"text":"Pub. L. 110–172","children":[],"tail":" substituted “section 6662A(e)(2)(B)” for “section 6662A(e)(2)(C)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4734644d-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4734644e-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/240/tII/s2041/b"},"text":"Pub. L. 111–240, title II, § 2041(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-09-27"},"text":"Sept. 27, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2560"},"text":"124 Stat. 2560","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/240/tII/s2041/b"},"text":"“The amendment made by this section [amending this section] shall apply to penalties assessed after ","children":[{"tag":"date","attrib":{"date":"2006-12-31"},"text":"December 31, 2006","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4734644f-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s811/c"},"text":"Pub. L. 108–357, title VIII, § 811(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1577"},"text":"118 Stat. 1577","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/135/tIV/s403/w"},"text":"Pub. L. 109–135, title IV, § 403(w)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-21"},"text":"Dec. 21, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2629"},"text":"119 Stat. 2629","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/135/tIV/s403/w"},"text":"“The amendments made by this section [enacting this section] shall apply to returns and statements the due date for which is after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":"] and which were not filed before such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id47346450-3a70-11f1-a967-d35dac11796a"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVIII/s811/d"},"text":"Pub. L. 108–357, title VIII, § 811(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1577"},"text":"118 Stat. 1577","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/357/tVIII/s811/d"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Commissioner of Internal Revenue shall annually report to the Committee on Ways and Means of the House of Representatives and the Committee on Finance of the Senate—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the total number and aggregate amount of penalties imposed, and rescinded, under section 6707A of the Internal Revenue Code of 1986, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of each penalty rescinded under section 6707(c) of such Code and the reasons therefor.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
