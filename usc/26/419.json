{"tag":"section","attrib":{"id":"id43522171-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419"},"text":null,"children":[{"tag":"num","attrib":{"value":"419"},"text":"§ 419.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of funded welfare benefit plans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id43522172-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Contributions paid or accrued by an employer to a welfare benefit fund—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43522173-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be deductible under this chapter, but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43522174-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if they would otherwise be deductible, shall (subject to the limitation of subsection (b)) be deductible under this section for the taxable year in which paid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43522175-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of the deduction allowable under subsection (a)(2) for any taxable year shall not exceed the welfare benefit fund’s qualified cost for the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43522176-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified cost","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43522177-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this subsection, the term “qualified cost” means, with respect to any taxable year, the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43522178-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the qualified direct cost for such taxable year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43522179-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to the limitation of section 419A(b), any addition to a qualified asset account for the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4352217a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction for funds after-tax income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any welfare benefit fund, the qualified cost for any taxable year shall be reduced by such fund’s after-tax income for such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4352217b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified direct cost","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4352217c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified direct cost” means, with respect to any taxable year, the aggregate amount (including administrative expenses) which would have been allowable as a deduction to the employer with respect to the benefits provided during the taxable year, if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4352217d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such benefits were provided directly by the employer, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4352217e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employer used the cash receipts and disbursements method of accounting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4352217f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time when benefits provided","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A), a benefit shall be treated as provided when such benefit would be includible in the gross income of the employee if provided directly by the employer (or would be so includible but for any provision of this chapter excluding such benefit from gross income).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43522180-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 60-month amortization of child care facilities","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id43522181-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/c/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining qualified direct costs with respect to any child care facility for purposes of subparagraph (A), in lieu of depreciation the adjusted basis of such facility shall be allowable as a deduction ratably over a period of 60 months beginning with the month in which the facility is placed in service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43522182-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/c/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Child care facility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “child care facility” means any tangible property which qualifies under regulations prescribed by the Secretary as a child care center primarily for children of employees of the employer; except that such term shall not include any property—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id43522183-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/c/3/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not of a character subject to depreciation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id43522184-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/c/3/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" located outside the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43522185-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" After-tax income","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43522186-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “after-tax income” means, with respect to any taxable year, the gross income of the welfare benefit fund reduced by the sum of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id43522187-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/c/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deductions allowed by this chapter which are directly connected with the production of such gross income, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id43522188-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/c/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the tax imposed by this chapter on the fund for the taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43522189-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain amounts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining the gross income of any welfare benefit fund—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4352218a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/c/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contributions and other amounts received from employees shall be taken into account, but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4352218b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/c/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contributions from the employer shall not be taken into account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4352218c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Item only taken into account once","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No item may be taken into account more than once in determining the qualified cost of any welfare benefit fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4352218d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carryover of excess contributions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4352218e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the contributions paid (or deemed paid under this subsection) by the employer during any taxable year to a welfare benefit fund, exceeds","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4352218f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the limitation of subsection (b),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"such excess shall be treated as an amount paid by the employer to such fund during the succeeding taxable year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id43522190-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Welfare benefit fund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id43522191-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “welfare benefit fund” means any fund—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43522192-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is part of a plan of an employer, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43522193-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through which the employer provides welfare benefits to employees or their beneficiaries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43522194-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Welfare benefit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “welfare benefit” means any benefit other than a benefit with respect to which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43522195-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 83(h) applies,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43522196-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 404 applies (determined without regard to section 404(b)(2)), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id43522197-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 404A applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id43522198-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “fund” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id43522199-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any organization described in paragraph (7), (9), or (17) of section 501(c),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4352219a-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any trust, corporation, or other organization not exempt from the tax imposed by this chapter, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4352219b-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent provided in regulations, any account held for an employer by any person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4352219c-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of amounts held pursuant to certain insurance contracts","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4352219d-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding paragraph (3)(C), the term “fund” shall not include amounts held by an insurance company pursuant to an insurance contract if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4352219e-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/e/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such contract is a life insurance contract described in section 264(a)(1), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4352219f-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/e/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such contract is a qualified nonguaranteed contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id435221a0-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified nonguaranteed contract","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id435221a1-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/e/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this paragraph, the term “qualified nonguaranteed contract” means any insurance contract (including a reasonable premium stabilization reserve held thereunder) if—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id435221a2-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/e/4/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is no guarantee of a renewal of such contract, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id435221a3-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/e/4/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other than insurance protection, the only payments to which the employer or employees are entitled are experience rated refunds or policy dividends which are not guaranteed and which are determined by factors other than the amount of welfare benefits paid to (or on behalf of) the employees of the employer or their beneficiaries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id435221a4-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/e/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any qualified nonguaranteed contract, subparagraph (A) shall not apply unless the amount of any experience rated refund or policy dividend payable to an employer with respect to a policy year is treated by the employer as received or accrued in the taxable year in which the policy year ends.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id435221a5-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Method of contributions, etc., having the effect of a plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id435221a6-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is no plan, but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id435221a7-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a method or arrangement of employer contributions or benefits which has the effect of a plan,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"this section shall apply as if there were a plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id435221a8-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension to plans for independent contractors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If any fund would be a welfare benefit fund (as modified by subsection (f)) but for the fact that there is no employee-employer relationship—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id435221a9-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this section shall apply as if there were such a relationship, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id435221aa-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s419/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any reference in this section to the employer shall be treated as a reference to the person for whom services are provided, and any reference in this section to an employee shall be treated as a reference to the person providing the services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id435221ab-3a70-11f1-a967-d35dac11796a"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tV/s511/a"},"text":"Pub. L. 98–369, div. A, title V, § 511(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/854"},"text":"98 Stat. 854","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVIII/s1851/a/1"},"text":"Pub. L. 99–514, title XVIII, § 1851(a)(1)","children":[],"tail":", (8)(A), (b)(2)(C)(iv), "},{"tag":"date","attrib":{