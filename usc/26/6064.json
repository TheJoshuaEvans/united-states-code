{"tag":"section","attrib":{"id":"id4688bb85-3a70-11f1-a967-d35dac11796a","identifier":"/us/usc/t26/s6064"},"text":null,"children":[{"tag":"num","attrib":{"value":"6064"},"text":"§ 6064.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Signature presumed authentic","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The fact that an individual’s name is signed to a return, statement, or other document shall be prima facie evidence for all purposes that the return, statement, or other document was actually signed by him.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4688bb86-3a70-11f1-a967-d35dac11796a"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"Aug. 16, 1954, ch. 736","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68A/749"},"text":"68A Stat. 749","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
