{"tag":"section","attrib":{"id":"idcfcafae7-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2212"},"text":null,"children":[{"tag":"num","attrib":{"value":"2212"},"text":"§ 2212.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Position of Revitalization Coordinator","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcfcafae8-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2212/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established, under the Oversight Board, the position of the Revitalization Coordinator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfcafae9-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2212/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcfcafaea-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2212/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Revitalization Coordinator shall be appointed by the Governor as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcfcafaeb-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2212/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Prior to the appointment of the Revitalization Coordinator and within 60 days of the appointment of the full membership of the Oversight Board, the Oversight Board shall submit to the Governor no less than three nominees for appointment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfcafaec-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2212/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In consultation with the Oversight Board, not later than 10 days after receiving the nominations under subparagraph (A), the Governor shall appoint one of the nominees as the Revitalization Coordinator. Such appointment shall be effective immediately.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfcafaed-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2212/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Governor fails to select a Revitalization Coordinator, the Oversight Board shall, by majority vote, appoint a Revitalization Coordinator from the list of nominees provided under paragraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfcafaee-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2212/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting nominees under paragraph (1)(A), the Oversight Board shall only nominate persons who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcfcafaef-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2212/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have substantial knowledge and expertise in the planning, predevelopment, financing, development, operations, engineering, or market participation of infrastructure projects, provided that stronger consideration may be given to candidates who have experience with Energy Projects and the laws and regulations of Puerto Rico that may be subject to an Expedited Permitting Process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfcafaf0-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2212/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does ","children":[{"tag":"ref","attrib":{"idref":"fn002061"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002061"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “do”."}],"tail":" not currently provide goods or services to the government of Puerto Rico (and, as applicable, is "},{"tag":"ref","attrib":{"idref":"fn002062"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002062"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “are”."}],"tail":" not the spouse, parent, child, or sibling of a person who provides or has provided goods and services to the government of Puerto Rico in the preceding 3 calendar years); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfcafaf1-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2212/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be an officer, employee of, or former officer or employee of the government of Puerto Rico in the preceding 3 calendar years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfcafaf2-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2212/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Revitalization Coordinator shall be compensated at an annual rate determined by the Oversight Board sufficient in the judgment of the Oversight Board to obtain the services of a person with the skills and experience required to discharge the duties of the position, but such compensation shall not exceed the annual salary of the Executive Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfcd6af3-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2212/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assignment of personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Executive Director of the Oversight Board may assign Oversight Board personnel to assist the Revitalization Coordinator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfcd6af4-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2212/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcfcd6af5-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2212/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Revitalization Coordinator may be removed for any reason, in the Oversight Board’s discretion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfcd6af6-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2212/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of position","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the termination of the Oversight Board pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s2149"},"text":"section 2149 of this title","children":[],"tail":", the position of the Revitalization Coordinator shall terminate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcfcd6af7-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/187/tV/s502"},"text":"Pub. L. 114–187, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-30"},"text":"June 30, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/597"},"text":"130 Stat. 597","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
