{"tag":"section","attrib":{"id":"idcfc88959-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2150"},"text":null,"children":[{"tag":"num","attrib":{"value":"2150"},"text":"§ 2150.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No full faith and credit of the United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcfc8895a-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2150/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The full faith and credit of the United States is not pledged for the payment of any principal of or interest on any bond, note, or other obligation issued by a covered territory or covered territorial instrumentality. The United States is not responsible or liable for the payment of any principal of or interest on any bond, note, or other obligation issued by a covered territory or covered territorial instrumentality.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfc8895b-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2150/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subject to appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any claim to which the United States is determined to be liable under this chapter shall be subject to appropriations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfc8895c-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2150/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No Federal funds shall be authorized by this chapter for the payment of any liability of the territory or territorial instrumentality.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcfc8895d-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/187/tII/s210"},"text":"Pub. L. 114–187, title II, § 210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-30"},"text":"June 30, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/576"},"text":"130 Stat. 576","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcfc8895e-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcfc8895f-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcfc88960-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (b) and (c), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/187"},"text":"Pub. L. 114–187","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-30"},"text":"June 30, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/549"},"text":"130 Stat. 549","children":[],"tail":", known as the Puerto Rico Oversight, Management, and Economic Stability Act and also as PROMESA, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s2101"},"text":"section 2101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
