{"tag":"section","attrib":{"id":"idcfc889da-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2173"},"text":null,"children":[{"tag":"num","attrib":{"value":"2173"},"text":"§ 2173.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modification of plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Oversight Board, after the issuance of a certification pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s2124/j"},"text":"section 2124(j) of this title","children":[],"tail":", may modify the plan at any time before confirmation, but may not modify the plan so that the plan as modified fails to meet the requirements of this subchapter. After the Oversight Board files a modification, the plan as modified becomes the plan."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcfc889db-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/187/tIII/s313"},"text":"Pub. L. 114–187, title III, § 313","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-30"},"text":"June 30, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/583"},"text":"130 Stat. 583","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
