{"tag":"section","attrib":{"id":"idcf61ff2a-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s795"},"text":null,"children":[{"tag":"num","attrib":{"value":"795"},"text":"§ 795.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Government expenses payable out of revenues","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All expenses that may be incurred on account of the government of Puerto Rico for salaries of officials and the conduct of their offices and departments, and all expenses and obligations contracted for the internal improvement or development of the island, not, however, including defenses, barracks, harbors, lighthouses, buoys, and other works undertaken by the United States, shall, except as otherwise specifically provided by the Congress, be paid by the treasurer of Puerto Rico out of the revenue in his custody.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf61ff2b-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1917-03-02/ch145/s6"},"text":"Mar. 2, 1917, ch. 145, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/953"},"text":"39 Stat. 953","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1932-05-17/ch190"},"text":"May 17, 1932, ch. 190","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/158"},"text":"47 Stat. 158","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf61ff2c-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf61ff2d-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcf61ff2e-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/act/1900-04-12/ch191/s12"},"text":"act Apr. 12, 1900, ch. 191, § 12","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/31/80"},"text":"31 Stat. 80","children":[],"tail":", with the exception of the words “except as otherwise specifically provided by the Congress”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcf61ff2f-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idcf61ff30-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Puerto Rico” substituted in text for “Porto Rico” pursuant to act ","children":[{"tag":"date","attrib":{"date":"1932-05-17"},"text":"May 17, 1932","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s731a"},"text":"section 731a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
