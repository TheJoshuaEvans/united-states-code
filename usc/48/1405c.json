{"tag":"section","attrib":{"id":"idcf6b9bcc-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1405c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1405c"},"text":"§ 1405c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of property to government","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcf6b9bcd-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1405c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property not reserved","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All property which may have been acquired by the United States from Denmark in the Virgin Islands under the convention entered into ","children":[{"tag":"date","attrib":{"date":"1916-08-04"},"text":"August 4, 1916","children":[],"tail":", not reserved by the United States for public purposes prior to "},{"tag":"date","attrib":{"date":"1937-06-22"},"text":"June 22, 1937","children":[],"tail":", is placed under the control of the Government of the Virgin Islands."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf6b9bce-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1405c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of United States law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise expressly provided, all laws of the United States for the protection and improvement of the navigable waters of the United States shall apply to the Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf6b9bcf-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1405c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of tonnage duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No Federal laws levying tonnage duties, light money, or entrance and clearance fees shall apply to the Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf6b9bd0-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1405c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presidential determination of applicable laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The legislature of the Virgin Islands shall have power to enact navigation, boat inspection, and safety laws of local application; but the President shall have power to make applicable to the Virgin Islands such of the navigation, vessel inspection, and coastwise laws of the United States as he may find and declare to be necessary in the public interest, and, to the extent that the laws so made applicable conflict with any laws of local application enacted by the legislature, such laws enacted by the legislature shall have no force and effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf6b9bd1-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1405c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing powers of United States officers unaf­fected","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to affect or impair in any manner the terms and conditions of any authorizations, permits, or other powers heretofore lawfully granted or exercised in or in respect of the Virgin Islands by any authorized officer or agent of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcf6b9bd2-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-06-22/ch699/s4"},"text":"June 22, 1936, ch. 699, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1808"},"text":"49 Stat. 1808","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1939-08-07/ch515"},"text":"Aug. 7, 1939, ch. 515","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/1242"},"text":"53 Stat. 1242","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1951-10-31/ch654/s1/127"},"text":"Oct. 31, 1951, ch. 654, § 1(127)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/65/706"},"text":"65 Stat. 706","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/357/tIII/s306"},"text":"Pub. L. 97–357, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-19"},"text":"Oct. 19, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1709"},"text":"96 Stat. 1709","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf6b9bd3-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf6b9bd4-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcf6b9bd5-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1982—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/357"},"text":"Pub. L. 97–357","children":[],"tail":" substituted “legislature” for “Legislative Assembly” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1951—Subsec. (f). Act ","children":[{"tag":"date","attrib":{"date":"1951-10-31"},"text":"Oct. 31, 1951","children":[],"tail":", repealed subsec. (f) which authorized the Secretary of the Interior to lease or sell any property under his administrative supervision in the Virgin Islands not needed for public purposes."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1939—Act ","children":[{"tag":"date","attrib":{"date":"1939-08-07"},"text":"Aug. 7, 1939","children":[],"tail":", designated existing provisions as subsecs. (a), (b), (e), and (f) and added subsecs. (c) and (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcf6b9bd6-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcf6b9bd7-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of Virgin Islands Projects by Secretary of the Army","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/640/tIV/s406"},"text":"Pub. L. 101–640, title IV, § 406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4647"},"text":"104 Stat. 4647","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/640/tIV/s406"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Rule","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon request of the Governor of the Virgin Islands with respect to a construction project in the Virgin Islands for which Federal financial assistance is available under any law of the United States, the Federal official administering such assistance may make such assistance available to the Secretary instead of the Virgin Islands. The Secretary shall use such assistance to carry out such project in accordance with the provisions of such law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Statutory Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed as relieving the Virgin Islands from complying with any requirements for non-Federal cooperation with respect to a construction project carried out with Federal financial assistance provided to the Secretary pursuant to this section; except that the Secretary shall be responsible for complying with administrative and fiscal requirements associated with utilization of such assistance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination Date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) shall not be effective after the last day of the 3-year period beginning on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":"]; except that the Secretary shall complete construction of any project commenced under subsection (a) before such day.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idcf6b9bd8-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"executiveOrder","id":"idcf6b9bd9-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Ex. Ord. No. 9170. Certain Navigation Laws Made Applicable to Virgin Islands","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 9170, eff. ","children":[{"tag":"date","attrib":{"date":"1942-05-21"},"text":"May 21, 1942","children":[],"tail":", 7 F.R. 384, provided in part:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"It is ordered that all of the navigation and vessel inspection laws of the United States be, and they are hereby, made applicable to the Virgin Islands of the United States, with the following exceptions:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(1) The coastwise laws of the United States.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(2) The act of Congress approved ","children":[{"tag":"date","attrib":{"date":"1897-06-07"},"text":"June 7, 1897","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/30/96"},"text":"30 Stat. 96","children":[],"tail":"), as amended by the acts of "},{"tag":"date","attrib":{"date":"1900-02-19"},"text":"February 19, 1900","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/31/30"},"text":"31 Stat. 30","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1914-05-25"},"text":"May 25, 1914","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/38/381"},"text":"38 Stat. 381","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1933-03-01"},"text":"March 1, 1933","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/47/1417"},"text":"47 Stat. 1417","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1935-08-21"},"text":"Aug. 21, 1935","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/49/668"},"text":"49 Stat. 668","children":[],"tail":", 669), "},{"tag":"date","attrib":{"date":"1936-05-20"},"text":"May 20, 1936","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/49/1367"},"text":"49 Stat. 1367","children":[],"tail":"), and "},{"tag":"date","attrib":{"date":"1940-04-22"},"text":"April 22, 1940","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/54/150"},"text":"54 Stat. 150","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(3) So much of the vessel inspection laws of the United States as requires the inspection as a passenger vessel of any cargo vessel, foreign or domestic, when carrying more than twelve passengers or persons in addition to the crew.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(4) Federal laws levying tonnage duties, light money, or entrance and clearance fees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
