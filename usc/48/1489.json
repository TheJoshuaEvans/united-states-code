{"tag":"section","attrib":{"id":"idcf79f423-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1489"},"text":null,"children":[{"tag":"num","attrib":{"value":"1489"},"text":"§ 1489.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loss of title of United States to lands in territories through adverse possession or prescription forbidden","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"On and after ","children":[{"tag":"date","attrib":{"date":"1934-03-27"},"text":"March 27, 1934","children":[],"tail":", no prescription or statute of limitations shall run, or continue to run, against the title of the United States to lands in any territory or possession or place or territory under the jurisdiction or control of the United States; and no title to any such lands of the United States or any right therein shall be acquired by adverse possession or prescription, or otherwise than by conveyance from the United States."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf79f424-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-03-27/ch99"},"text":"Mar. 27, 1934, ch. 99","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/507"},"text":"48 Stat. 507","children":[],"tail":"; Proc. No. 2695, eff. "},{"tag":"date","attrib":{"date":"1946-07-04"},"text":"July 4, 1946","children":[],"tail":", 11 F.R. 7517, "},{"tag":"ref","attrib":{"href":"/us/stat/60/1352"},"text":"60 Stat. 1352","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf79f425-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf79f426-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail"