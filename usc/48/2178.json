{"tag":"section","attrib":{"id":"idcfcafa0b-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2178"},"text":null,"children":[{"tag":"num","attrib":{"value":"2178"},"text":"§ 2178.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure by professional persons seeking approval of compensation under section 2176 or 2177 of this title","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcfcafa0c-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2178/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcfcafa0d-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2178/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" List of Material Interested Parties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “List of Material Interested Parties” means the List of Material Interested Parties established under subsection (c)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfcafa0e-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2178/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oversight Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Oversight Board” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s2104"},"text":"section 2104 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfcafa0f-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2178/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required disclosure","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcfcafa10-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2178/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In a case commenced under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s2164"},"text":"section 2164 of this title","children":[],"tail":", no attorney, accountant, appraiser, auctioneer, agent, or other professional person may be compensated under section 2176 or 2177 of this title unless prior to making a request for compensation, the professional person has filed with the court a verified statement conforming to the disclosure requirements of rule 2014(a) of the Federal Rules of Bankruptcy Procedure setting forth the connection of the professional person with any entity or person on the List of Material Interested Parties."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfcafa11-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2178/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A professional person that submits a statement under paragraph (1) shall promptly supplement the statement with any additional relevant information that becomes known to the person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfcafa12-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2178/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to any other applicable law, rule, or regulation, a professional person that fails to file or update a statement required under paragraph (1) or files a statement that the court determines does not represent a good faith effort to comply with this section shall disclose such failure in any filing required to conform to the disclosure requirements under rule 2014(a) of the Federal Rules of Bankruptcy Procedure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfcafa13-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2178/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" List of Material Interested Parties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcfcafa14-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2178/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preparation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days after ","children":[{"tag":"date","attrib":{"date":"2022-01-20"},"text":"January 20, 2022","children":[],"tail":", the Oversight Board shall establish a List of Material Interested Parties subject to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcfcafa15-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2178/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the approval of the court; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfcafa16-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2178/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the right of the United States trustee or any party in interest to be heard on the approval.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfcafa17-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2178/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (3), the List of Material Interested Parties shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcfcafa18-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2178/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the debtor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfcafa19-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2178/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any creditor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfcafa1a-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2178/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other party in interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfcafa1b-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2178/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any attorney or accountant of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcfcafa1c-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2178/c/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the debtor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcfcafa1d-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2178/c/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any creditor; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcfcafa1e-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2178/c/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other party in interest;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfcafa1f-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2178/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States trustee and any person employed in the office of the United States trustee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfcafa20-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2178/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Oversight Board, including the members, the Executive Director, and the employees of the Oversight Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfcafa21-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2178/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The List of Material Interested Parties may not include any person with a claim, the amount of which is below a threshold dollar amount established by the court that is consistent with the purpose of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfcafa22-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2178/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcfcafa23-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2178/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States trustee shall review each verified statement submitted pursuant to subsection (b) and may file with the court comments on such verified statements before the professionals filing such statements seek compensation under section 2176 or 2177 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfcafa24-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2178/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Objection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States trustee may object to applications filed under section 2176 or 2177 of this title that fail to satisfy the requirements of subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfcafa25-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2178/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on compensation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In a case commenced under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s2164"},"text":"section 2164 of this title","children":[],"tail":", in connection with the review and approval of professional compensation under section 2176 or 2177 of this title filed after "},{"tag":"date","attrib":{"date":"2022-01-20"},"text":"January 20, 2022","children":[],"tail":", the court may deny allowance of compensation or reimbursement of expenses if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcfcafa26-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2178/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the professional person has failed to file the verified disclosure statements required under subsection (b)(1) or has filed inadequate disclosure statements under that subsection; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfcafa27-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2178/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" during the professional person’s employment in connection with the case, the professional person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcfcafa28-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2178/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not a disinterested person (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of title 11","children":[],"tail":") relative to any entity or person on the List of Material Interested Parties; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfcafa29-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2178/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represents or holds an adverse interest in connection with the case.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcfcafa2a-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/82/s2"},"text":"Pub. L. 117–82, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-01-20"},"text":"Jan. 20, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3"},"text":"136 Stat. 3","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcfcafa2b-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcfcafa2c-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcfcafa2d-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Rules of Bankruptcy Procedure, referred to in subsec. (b)(1), (3), are set out in the Appendix to Title 11, Bankruptcy.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section, referred to in subsec. (c)(3), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/82"},"text":"Pub. L. 117–82","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-01-20"},"text":"Jan. 20, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3"},"text":"136 Stat. 3","children":[],"tail":", known as the Puerto Rico Recovery Accuracy in Disclosures Act of 2021 and also as PRRADA, which enacted this section and provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s2101"},"text":"section 2101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcfcafa2e-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Puerto Rico Recovery Accuracy in Disclosures Act of 2021, also known as PRRADA, and not as part of the Puerto Rico Oversight, Management, and Economic Stability Act, also known as PROMESA, which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
