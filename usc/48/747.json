{"tag":"section","attrib":{"id":"idcf61febd-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s747"},"text":null,"children":[{"tag":"num","attrib":{"value":"747"},"text":"§ 747.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public property transferred; “control” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All property which may have been acquired in Puerto Rico by the United States under the cession of Spain in the treaty of peace entered into on the 10th day of December 1898, in any public bridges, road houses, water powers, highways, unnavigable streams and the beds thereof, subterranean waters, mines or minerals under the surface of private lands, all property which at the time of the cession belonged, under the laws of Spain then in force, to the various harbor works boards of Puerto Rico, all the harbor shores, docks, slips, reclaimed lands, and all public lands and buildings not reserved by the United States for public purposes prior to ","children":[{"tag":"date","attrib":{"date":"1917-03-02"},"text":"March 2, 1917","children":[],"tail":", is placed under the control of the government of Puerto Rico, to be administered for the benefit of the people of Puerto Rico; and the Legislature of Puerto Rico shall have authority, subject to the limitations imposed upon all its acts, to legislate with respect to all matters, as it may deem advisable. Notwithstanding any other provision of law, as used in this section “control” includes all right, title, and interest in and to and jurisdiction and authority over the aforesaid property and includes proprietary rights of ownership, and the rights of management, administration, leasing, use, and development of such property."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf61febe-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1917-03-02/ch145/s7"},"text":"Mar. 2, 1917, ch. 145, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/954"},"text":"39 Stat. 954","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1932-05-17/ch190"},"text":"May 17, 1932, ch. 190","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/158"},"text":"47 Stat. 158","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/205/tVI/s606/b"},"text":"Pub. L. 96–205, title VI, § 606(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-03-12"},"text":"Mar. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/91"},"text":"94 Stat. 91","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf61febf-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf61fec0-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcf61fec1-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of that part of section 7 of act ","children":[{"tag":"date","attrib":{"date":"1917-03-02"},"text":"Mar. 2, 1917","children":[],"tail":", preceding the proviso clause. The remainder of section 7 is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s748"},"text":"section 748 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcf61fec2-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/act/1900-04-12/ch191/s13"},"text":"act Apr. 12, 1900, ch. 191, § 13","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/31/80"},"text":"31 Stat. 80","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcf61fec3-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/205"},"text":"Pub. L. 96–205","children":[],"tail":" inserted provisions defining “control”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcf61fec4-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idcf61fec5-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Puerto Rico” substituted in text for “Porto Rico” pursuant to act ","children":[{"tag":"date","attrib":{"date":"1932-05-17"},"text":"May 17, 1932","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s731a"},"text":"section 731a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
