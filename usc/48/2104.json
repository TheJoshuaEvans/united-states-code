{"tag":"section","attrib":{"id":"idcfc3ced7-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2104"},"text":null,"children":[{"tag":"num","attrib":{"value":"2104"},"text":"§ 2104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcfc3ced8-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2104/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreed accounting standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “agreed accounting standards” means modified accrual accounting standards or, for any period during which the Oversight Board determines in its sole discretion that a territorial government is not reasonably capable of comprehensive reporting that complies with modified accrual accounting standards, such other accounting standards as proposed by the Oversight Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc3ced9-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2104/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bond","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Bond” means a bond, loan, letter of credit, other borrowing title, obligation of insurance, or other financial indebtedness for borrowed money, including rights, entitlements, or obligations whether such rights, entitlements, or obligations arise from contract, statute, or any other source of law, in any case, related to such a bond, loan, letter of credit, other borrowing title, obligation of insurance, or other financial indebtedness in physical or dematerialized form of which the issuer, obligor, or guarantor is the territorial government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc3ceda-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2104/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bond Claim","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Bond Claim” means, as it relates to a Bond—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcfc3cedb-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2104/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" right to payment, whether or not such right is reduced to judgment, liquidated, unliquidated, fixed, contingent, matured, unmatured, disputed, undisputed, legal, equitable, secured, or unsecured; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfc3cedc-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2104/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" right to an equitable remedy for breach of performance if such breach gives rise to a right to payment, whether or not such right to an equitable remedy is reduced to judgment, fixed, contingent, matured, unmatured, disputed, undisputed, secured, or unsecured.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc3cedd-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2104/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budget","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Budget” means the Territory Budget or an Instrumentality Budget, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc3cede-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2104/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Puerto Rico","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Puerto Rico” means the Commonwealth of Puerto Rico.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc3cedf-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2104/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliant budget","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “compliant budget” means a budget that is prepared in accordance with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcfc3cee0-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2104/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agreed accounting standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfc3cee1-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2104/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicable Fiscal Plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc3cee2-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2104/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered territorial instrumentality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered territorial instrumentality” means a territorial instrumentality designated by the Oversight Board pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s2121"},"text":"section 2121 of this title","children":[],"tail":" to be subject to the requirements of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc3cee3-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2104/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered territory","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered territory” means a territory for which an Oversight Board has been established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s2121"},"text":"section 2121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc3cee4-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2104/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Executive Director” means an Executive Director appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s2123/a"},"text":"section 2123(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc3cee5-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2104/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal Plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Fiscal Plan” means a Territory Fiscal Plan or an Instrumentality Fiscal Plan, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc3cee6-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2104/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Government of Puerto Rico","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Government of Puerto Rico” means the Commonwealth of Puerto Rico, including all its territorial instrumentalities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc3cee7-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2104/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Governor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Governor” means the chief executive of a covered territory.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc3cee8-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2104/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Instrumentality Budget","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Instrumentality Budget” means a budget for a covered territorial instrumentality, designated by the Oversight Board in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s2121"},"text":"section 2121 of this title","children":[],"tail":", submitted, approved, and certified in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s2142"},"text":"section 2142 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc3cee9-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2104/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Instrumentality Fiscal Plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Instrumentality Fiscal Plan” means a fiscal plan for a covered territorial instrumentality, designated by the Oversight Board in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s2121"},"text":"section 2121 of this title","children":[],"tail":", submitted, approved, and certified in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s2141"},"text":"section 2141 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc3ceea-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2104/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Legislature","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Legislature” means the legislative body responsible for enacting the laws of a covered territory.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc3ceeb-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2104/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modified accrual accounting standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “modified accrual accounting standards” means recognizing revenues as they become available and measurable and recognizing expenditures when liabilities are incurred, in each case as defined by the Governmental Accounting Standards Board, in accordance with generally accepted accounting principles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc3ceec-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2104/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oversight Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Oversight Board” means a Financial Oversight and Management Board established in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s2121"},"text":"section 2121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc3ceed-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2104/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Territorial government","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “territorial government” means the government of a covered territory, including all covered territorial instrumentalities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc3ceee-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2104/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Territorial instrumentality","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcfc3ceef-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2104/19/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “territorial instrumentality” means any political subdivision, public agency, instrumentality—including any instrumentality that is also a bank—or public corporation of a territory, and this term should be broadly construed to effectuate the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfc3cef0-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2104/19/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “territorial instrumentality” does not include an Oversight Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc3cef1-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2104/20"},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"(20)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Territory","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “territory” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcfc3cef2-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2104/20/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Puerto Rico;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfc3cef3-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2104/20/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Guam;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfc3cef4-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2104/20/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" American Samoa;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfc3cef5-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2104/20/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commonwealth of the Northern Mariana Islands; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfc3cef6-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2104/20/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc3cef7-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2104/21"},"text":null,"children":[{"tag":"num","attrib":{"value":"21"},"text":"(21)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Territory Budget","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Territory Budget” means a budget for a territorial government submitted, approved, and certified in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s2142"},"text":"section 2142 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc3cef8-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2104/22"},"text":null,"children":[{"tag":"num","attrib":{"value":"22"},"text":"(22)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Territory Fiscal Plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Territory Fiscal Plan” means a fiscal plan for a territorial government submitted, approved, and certified in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s2141"},"text":"section 2141 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcfc3cef9-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/187/s5"},"text":"Pub. L. 114–187, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-30"},"text":"June 30, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/551"},"text":"130 Stat. 551","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcfc3cefa-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcfc3cefb-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcfc3cefc-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/187"},"text":"Pub. L. 114–187","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-30"},"text":"June 30, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/549"},"text":"130 Stat. 549","children":[],"tail":", known as the Puerto Rico Oversight, Management, and Economic Stability Act and also as PROMESA, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s2101"},"text":"section 2101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
