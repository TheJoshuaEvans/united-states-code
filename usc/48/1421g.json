{"tag":"section","attrib":{"id":"idcf7056f3-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1421g"},"text":null,"children":[{"tag":"num","attrib":{"value":"1421g"},"text":"§ 1421g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and maintenance of public bodies and offices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcf7056f4-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1421g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public health services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the laws of Guam, the Governor shall establish, maintain, and operate public-health services in Guam, including hospitals, dispensaries, and quarantine stations, at such places in Guam as may be necessary, and he shall promulgate quarantine and sanitary regulations for the protection of Guam against the importation and spread of disease.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf7056f5-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1421g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public educational system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Government of Guam shall provide an adequate public educational system of Guam, and to that end shall establish, maintain, and operate public schools according to the laws of Guam.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf7056f6-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1421g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Public Prosecutor; Office of Public Auditor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Government of Guam may by law establish an Office of Public Prosecutor and an Office of Public Auditor. The Public Prosecutor and Public Auditor may be removed as provided by the laws of Guam.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf7056f7-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1421g/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attorney General","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcf7056f8-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1421g/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General of Guam shall be the Chief Legal Officer of the Government of Guam. At such time as the Office of the Attorney General of Guam shall next become vacant, the Attorney General of Guam shall be appointed by the Governor of Guam with the advice and consent of the legislature, and shall serve at the pleasure of the Governor of Guam.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcf7056f9-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1421g/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Instead of an appointed Attorney General, the legislature may, by law, provide for the election of the Attorney General of Guam by the qualified voters of Guam in general elections after 1998 in which the Governor of Guam is elected. The term of an elected Attorney General shall be 4 years. The Attorney General may be removed by the people of Guam according to the procedures specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1422d"},"text":"section 1422d of this title","children":[],"tail":" or may be removed for cause in accordance with procedures established by the legislature in law. A vacancy in the office of an elected Attorney General shall be filled—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcf7056fa-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1421g/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by appointment by the Governor of Guam if such vacancy occurs less than 6 months before a general election for the Office of Attorney General of Guam; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcf7056fb-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1421g/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by a special election held no sooner than 3 months after such vacancy occurs and no later than 6 months before a general election for Attorney General of Guam, and by appointment by the Governor of Guam pending a special election under this subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcf7056fc-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-08-01/ch512/s29"},"text":"Aug. 1, 1950, ch. 512, § 29","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/392"},"text":"64 Stat. 392","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/396"},"text":"Pub. L. 99–396","children":[],"tail":", §§ 5, 13, "},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/839"},"text":"100 Stat. 839","children":[],"tail":", 842; "},{"tag":"ref","attrib":{"href":"/us/pl/105/291/s2"},"text":"Pub. L. 105–291, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-27"},"text":"Oct. 27, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2785"},"text":"112 Stat. 2785","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf7056fd-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf7056fe-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcf7056ff-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/291"},"text":"Pub. L. 105–291","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/396/s13/a/1"},"text":"Pub. L. 99–396, § 13(a)(1)","children":[],"tail":", substituted “according to the laws of Guam” for “at such places in Guam as may be necessary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/396/s5"},"text":"Pub. L. 99–396, § 5","children":[],"tail":", substituted “Government of Guam” for “Governor”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/396/s13/a/2"},"text":"Pub. L. 99–396, § 13(a)(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
