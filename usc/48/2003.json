{"tag":"section","attrib":{"id":"idcfc3ceae-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2003"},"text":null,"children":[{"tag":"num","attrib":{"value":"2003"},"text":"§ 2003.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conference","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcfc3ceaf-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2003/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meeting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Prior to submitting the reports required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s2002/b"},"text":"section 2002(b) of this title","children":[],"tail":", the Secretary of the Interior, in consultation with the Secretary of State, shall convene a conference to obtain the views of the noncontiguous Pacific areas on the matters required to be addressed in such reports."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfc3ceb0-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2003/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Representatives of each of the noncontiguous Pacific areas; and the heads of all executive departments and agencies, and other public and private organizations concerned with the noncontiguous Pacific areas as requested by the Secretary of the Interior shall be entitled to be participants in the conference.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfc3ceb1-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2003/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Written comments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior shall afford participants in the conference an opportunity to submit written comments for inclusion in the reports required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s2002"},"text":"section 2002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcfc3ceb2-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/239/tIII/s303"},"text":"Pub. L. 99–239, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-01-14"},"text":"Jan. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1837"},"text":"99 Stat. 1837","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcfc3ceb3-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcfc3ceb4-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcfc3ceb5-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1681"},"text":"section 1681 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
