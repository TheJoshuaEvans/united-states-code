 Compact, 2023 Amended U.S.-RMI Compact, or the U.S.-Palau Compact, by mutual agreement or unilateral action of the Government of the United States, shall not enter into force until the date on which Congress has incorporated the applicable amendment, change, or termination into an Act of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfbf1328-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1983/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional actions and agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the Compacts described in paragraph (1), the requirements of that paragraph shall apply to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcfbf1329-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1983/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any action of the Government of the United States under the 2023 Amended U.S.-FSM Compact, 2023 Amended U.S.-RMI Compact, or U.S.-Palau Compact, including an action taken pursuant to section 431, 441, or 442 of the 2023 Amended U.S.-FSM Compact, 2023 Amended U.S.-RMI Compact, or U.S.-Palau Compact; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfbf132a-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1983/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any amendment to, change to, or termination of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcfbf132b-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1983/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agreement described in section 462(a)(2) of the 2023 Amended U.S.-FSM Compact;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcfbf132c-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1983/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agreement described in section 462(a)(5) of the 2023 Amended U.S.-RMI Compact;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcfbf132d-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1983/d/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agreement concluded pursuant to section 265 of the 2023 Amended U.S.-FSM Compact;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcfbf132e-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1983/d/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agreement concluded pursuant to section 265 of the 2023 Amended U.S.-RMI Compact;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcfbf132f-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1983/d/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agreement concluded pursuant to section 177 of the 2023 Amended U.S.-RMI Compact;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcfbf1330-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1983/d/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Articles III and IV of the agreement described in section 462(b)(6) of the 2023 Amended U.S.-FSM Compact;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcfbf1331-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1983/d/2/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Articles III, IV, and X of the agreement described in section 462(b)(6) of the 2023 Amended U.S.-RMI Compact;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcfbf1332-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1983/d/2/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agreement described in section 462(h) of the U.S.-Palau Compact; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcfbf1333-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1983/d/2/B/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Articles VI, XV, and XVII of the agreement described in section 462(b)(7) of the 2023 Amended U.S.-FSM Compact and 2023 Amended U.S.-RMI Compact and section 462(i) of the U.S.-Palau Compact.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfbf1334-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1983/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entry into force of future amendments to subsidiary agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcfbf1335-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1983/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An agreement between the United States and the Government of the Federated States of Micronesia, the Government of the Republic of the Marshall Islands, or the Government of the Republic of Palau that would amend, change, or terminate any subsidiary agreement or portion of a subsidiary agreement (other than an amendment to, change to, or termination of an agreement described in subsection (d)) shall not enter into force until the date that is 90 days after the date on which the President has transmitted to the President of the Senate and the Speaker of the House of Representatives—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcfbf1336-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1983/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agreement to amend, change, or terminate the subsidiary agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfbf1337-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1983/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation of the amendment, change, or termination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfbf1338-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1983/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the reasons for the amendment, change, or termination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfbf1339-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1983/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of an agreement that would amend, change, or terminate any agreement described in section 462(b)(3) of the 2023 Amended U.S.-FSM Compact or the 2023 Amended U.S.-RMI Compact, a statement by the Secretary of Labor that describes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcfbf133a-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1983/e/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the necessity of the amendment, change, or termination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcfbf133b-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1983/e/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any impacts of the amendment, change, or termination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfbf133c-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1983/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal programs and services agreement with the republic of Palau","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subparagraphs (A) and (D)(iii) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1931/c/2"},"text":"section 1931(c)(2) of this title","children":[],"tail":" and subsection (d)(2)(A) shall not apply to an agreement that would amend, change, or terminate the agreement described in section 462(f) of the U.S.-Palau Compact."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcfbf133d-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/1