{"tag":"section","attrib":{"id":"idcf72c896-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1422c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1422c"},"text":"§ 1422c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive agencies and instrumentalities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcf72c897-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1422c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment of heads; establishment of merit system; Civil Service Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Governor shall, except as otherwise provided in this chapter or the laws of Guam, appoint, by and with the advice and consent of the legislature, all heads of executive agencies and instrumentalities. The legislature shall establish a merit system and, as far as practicable, appointments and promotions shall be made in accordance with such merit system. The Government of Guam may by law establish a Civil Service Commission to administer the merit system. Members of the commission may be removed as provided by the laws of Guam.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf72c898-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1422c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers and duties of officers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All officers shall have such powers and duties as may be conferred or imposed on them by law or by executive regulation of the Governor not inconsistent with any law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf72c899-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1422c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reorganization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Governor shall, from time to time, examine the organization of the executive branch of the government of Guam, and shall determine and carry out such changes therein as are necessary to promote effective management and to execute faithfully the purposes of this chapter and the laws of Guam.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf72c89a-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1422c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation in office of incumbents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All persons holding office in Guam on ","children":[{"tag":"date","attrib":{"date":"1950-08-01"},"text":"August 1, 1950","children":[],"tail":" may, except as otherwise provided in this chapter, continue to hold their respective offices until their successors are appointed and qualified."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcf72c89b-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-08-01/ch512/s9"},"text":"Aug. 1, 1950, ch. 512, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/387"},"text":"64 Stat. 387","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/497/s4"},"text":"Pub. L. 90–497, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-09-11"},"text":"Sept. 11, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/845"},"text":"82 Stat. 845","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/396/s18/a"},"text":"Pub. L. 99–396, § 18(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/843"},"text":"100 Stat. 843","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf72c89c-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf72c89d-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcf72c89e-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/396"},"text":"Pub. L. 99–396","children":[],"tail":" inserted provisions authorizing establishment of Civil Service Commission and removal of commission members as provided by laws of Guam."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/497/s4/a"},"text":"Pub. L. 90–497, § 4(a)","children":[],"tail":", struck out requirement that, in making appointments, preference be given persons of Guamanian ancestry and that opportunities for higher education and use of service training facilities be provided to qualified persons of Guamanian ancestry."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/497/s4/b"},"text":"Pub. L. 90–497, § 4(b)","children":[],"tail":", struck out provision authorizing the Governor to appoint or remove any officer whose appointment or removal is not otherwise provided for."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcf72c89f-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcf72c8a0-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1968 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Pub. L 90–497, § 4(a), ","children":[{"tag":"date","attrib":{"date":"1968-09-11"},"text":"Sept. 11, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/845"},"text":"82 Stat. 845","children":[],"tail":", provided that the amendment made by such section 4(a) is effective on date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/90/497"},"text":"Pub. L. 90–497","children":[],"tail":", which was approved on "},{"tag":"date","attrib":{"date":"1968-09-11"},"text":"Sept. 11, 1968","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/497"},"text":"Pub. L. 90–497","children":[],"tail":" necessary to authorize the holding of an election for Governor and Lieutenant Governor on "},{"tag":"date","attrib":{"date":"1970-11-03"},"text":"Nov. 3, 1970","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", and all other amendments unless otherwise provided effective "},{"tag":"date","attrib":{"date":"1971-01-04"},"text":"Jan. 4, 1971","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/497/s13"},"text":"section 13 of Pub. L. 90–497","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1422"},"text":"section 1422 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
