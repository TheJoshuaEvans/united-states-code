{"tag":"section","attrib":{"id":"idcf8a95e5-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1752"},"text":null,"children":[{"tag":"num","attrib":{"value":"1752"},"text":"§ 1752.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election of Delegate","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcf8a95e6-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1752/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electors and time of election","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Delegate shall be elected—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcf8a95e7-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1752/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the people qualified to vote for the popularly elected officials of the Commonwealth of the Northern Mariana Islands; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcf8a95e8-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1752/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the Federal general election of 2008 and at such Federal general election every 2d year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf8a95e9-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1752/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manner of election","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcf8a95ea-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1752/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Delegate shall be elected at large and by a plurality of the votes cast for the office of Delegate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcf8a95eb-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1752/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of establishment of primary elections","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (1), if the Government of the Commonwealth of the Northern Mariana Islands, acting pursuant to legislation enacted in accordance with the Constitution of the Commonwealth of the Northern Mariana Islands, provides for primary elections for the election of the Delegate, the Delegate shall be elected by a majority of the votes cast in any general election for the office of Delegate for which such primary elections were held.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf8a95ec-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1752/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In case of a permanent vacancy in the office of Delegate, the office of Delegate shall remain vacant until a successor is elected and qualified.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf8a95ed-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1752/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commencement of term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term of the Delegate shall commence on the 3d day of January following the date of the election.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcf8a95ee-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/229/tVII/s712"},"text":"Pub. L. 110–229, title VII, § 712","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-08"},"text":"May 8, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/868"},"text":"122 Stat. 868","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
