{"tag":"section","attrib":{"id":"idcfc15ca7-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1986"},"text":null,"children":[{"tag":"num","attrib":{"value":"1986"},"text":"§ 1986.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements with and other provisions related to the Republic of Palau","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcfc15ca8-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1986/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bilateral economic consultations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"United States participation in the annual economic consultations referred to in Article 8 of the 2023 U.S.-Palau Compact Review Agreement shall be by officers or employees of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfc15ca9-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1986/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Economic Advisory Group","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcfc15caa-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1986/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Economic Advisory Group described in Article 7 of the 2023 U.S.-Palau Compact Review Agreement (referred to in this subsection as the “Advisory Group”) who is appointed by the Secretary of the Interior shall be an individual who, by reason of knowledge, experience, or training, is especially qualified in private sector business development, economic development, or national development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc15cab-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1986/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to the Advisory Group, the Secretary of the Interior may use available funds for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcfc15cac-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1986/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs of the 2 members of the Advisory Group designated by the United States in accordance with Article 7 of the 2023 U.S.-Palau Compact Review Agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfc15cad-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1986/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent of the costs of the 5th member of the Advisory Group designated by the Secretary of the Interior in accordance with the Article described in subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfc15cae-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1986/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the costs of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcfc15caf-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1986/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical and administrative assistance for the Advisory Group; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcfc15cb0-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1986/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other support necessary for the Advisory Group to accomplish the purpose of the Advisory Group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc15cb1-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1986/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after the date on which the Advisory Group receives or completes any report required under the 2023 U.S.-Palau Compact Review Agreement, or any related subsidiary agreement, the Secretary of the Interior shall submit the report to the appropriate committees of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfc15cb2-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1986/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcfc15cb3-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1986/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after the date on which the Government of the Republic of Palau completes any report required under the 2023 U.S.-Palau Compact Review Agreement, or any related subsidiary agreement, the Secretary of the Interior shall submit the report to the appropriate committees of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc15cb4-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1986/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the date on which the Government of the Republic of Palau submits a report required under the 2023 U.S.-Palau Compact Review Agreement, or any related subsidiary agreement, the Secretary of the Interior shall submit to the appropriate committees of Congress—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcfc15cb5-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1986/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the report is submitted by the applicable deadline, written notice attesting that the report is complete and accurate; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfc15cb6-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1986/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the report is not submitted by the applicable deadline, written notice that the report has not been timely submitted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcfc15cb7-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/42/dG/tII/s207"},"text":"Pub. L. 118–42, div. G, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-03-09"},"text":"Mar. 9, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/433"},"text":"138 Stat. 433","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
