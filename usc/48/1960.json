{"tag":"section","attrib":{"id":"idcfbca272-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1960"},"text":null,"children":[{"tag":"num","attrib":{"value":"1960"},"text":"§ 1960.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modification of energy assistance funding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcfbca273-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1960/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fulfillment of United States obligations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President is authorized to negotiate and conclude an agreement, including the obligation of United States funds, with the Government of Palau which shall provide the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcfbca274-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1960/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The sum of $28,000,000, adjusted by section 215 of the Compact at the time of its availability to Palau, shall be provided to Palau pursuant to section 211(b) of the Compact and upon entry into force of the Compact.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfbca275-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1960/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Palau shall pay to the United States, on or before the 15th anniversary of the effective date of the Compact, an amount equal to the net economic cost to the United States of making available the section 211(b) funds in the manner specified in this subsection rather than as provided in section 211(b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfbca276-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1960/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such economic cost shall reflect the time value of money and be determined using the rate determined for an equivalent loan by the Federal Financing Bank as of the date these funds are advanced, and using an inflation rate consistent with the determinations made under the provisions of section 215 of the Compact.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfbca277-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1960/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Government of Palau has not paid such net economic costs to the United States by the 15th anniversary of the effective date of the Compact, then the United States shall be automatically paid such sums from the fund established under section 211(f) of the Compact.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfbf1278-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1960/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provision of section 211(b) funds, as appropriated by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/349"},"text":"Public Law 99–349","children":[],"tail":" and pursuant to this subsection, shall be in fulfillment of all United States obligations under such section 211(b) of the Compact and shall be subject to section 236 of the Compact."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfbf1279-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1960/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment and payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the provisions of subsection (a) and upon the request of the Government of Palau, the sum of $28 million appropriated by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/349"},"text":"Public Law 99–349","children":[],"tail":" to fulfill the obligations of the United States under section 211(b) of the Compact (approved in "},{"tag":"ref","attrib":{"href":"/us/pl/99/658"},"text":"Public Law 99–658","children":[],"tail":"), adjusted by section 215 of such Compact, shall be provided to Palau upon entry into force of the Compact."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfbf127a-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1960/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of appropriation account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funding provided in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/121"},"text":"Public Law 101–121","children":[],"tail":" under the “Trust Territory of the Pacific Islands” appropriation account shall remain available until expended."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcfbf127b-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/219/tI/s111"},"text":"Pub. L. 101–219, title I, § 111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-12"},"text":"Dec. 12, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1873"},"text":"103 Stat. 1873","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcfbf127c-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcfbf127d-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcfbf127e-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Compact, referred to in subsecs. (a) and (b), is the Compact of Free Association between the United States and the Government of Palau, which is contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/658/s201"},"text":"section 201 of Pub. L. 99–658","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1931"},"text":"section 1931 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For ","children":[{"tag":"date","attrib":{"date":"1994-10-01"},"text":"Oct. 1, 1994","children":[],"tail":", as the date the Compact of Free Association with Palau entered into full force and effect, referred to in subsecs. (a)(1), (2), (4) and (b), see Proc. No. 6726, "},{"tag":"date","attrib":{"date":"1994-09-27"},"text":"Sept. 27, 1994","children":[],"tail":", 59 F.R. 49777, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1931"},"text":"section 1931 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/349"},"text":"Public Law 99–349","children":[],"tail":", referred to in subsecs. (a)(5) and (b), is "},{"tag":"ref","attrib":{"href":"/us/pl/99/349"},"text":"Pub. L. 99–349","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-07-02"},"text":"July 2, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/710"},"text":"100 Stat. 710","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/658"},"text":"Public Law 99–658","children":[],"tail":", referred to in subsec. (b), is "},{"tag":"ref","attrib":{"href":"/us/pl/99/658"},"text":"Pub. L. 99–658","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3672"},"text":"100 Stat. 3672","children":[],"tail":", which is classified generally to part A of this subchapter. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/121"},"text":"Public Law 101–121","children":[],"tail":", referred to in subsec. (c), is "},{"tag":"ref","attrib":{"href":"/us/pl/101/121"},"text":"Pub. L. 101–121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-10-23"},"text":"Oct. 23, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/701"},"text":"103 Stat. 701","children":[],"tail":". Provisions relating to the Trust Territory of the Pacific Islands appear at "},{"tag":"ref","attrib":{"href":"/us/stat/103/717"},"text":"103 Stat. 717","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcfbf127f-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1681"},"text":"section 1681 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcfbf1280-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcfbf1281-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Palau Road Maintenance","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/229/tVIII/s808"},"text":"Pub. L. 110–229, title VIII, § 808","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-08"},"text":"May 8, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/874"},"text":"122 Stat. 874","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/229/tVIII/s808"},"text":"\n","children":[{"tag":"p","attrib":{},"text":"“The Government of the Republic of Palau may deposit the payment otherwise payable to the Government of the United States under ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/219/s111"},"text":"section 111 of Public Law 101–219","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1960"},"text":"48 U.S.C. 1960","children":[],"tail":") into a trust fund if—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the earnings of the trust fund are expended solely for maintenance of the road system constructed pursuant to section 212 of the Compact of Free Association between the Government of the United States of America and the Government of Palau (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1931"},"text":"48 U.S.C. 1931","children":[],"tail":" note); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the trust fund is established and operated pursuant to an agreement entered into between the Government of the United States and the Government of the Republic of Palau.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
