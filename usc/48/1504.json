{"tag":"section","attrib":{"id":"idcf7c3df8-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1504"},"text":null,"children":[{"tag":"num","attrib":{"value":"1504"},"text":"§ 1504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conveyance of lands in Territories by aliens before escheat proceedings","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any alien who shall hold lands in any of the Territories of the United States in contravention of the provisions of this chapter may nevertheless convey his title thereto at any time before the institution of escheat proceedings as hereinafter provided. If any such conveyance shall be made by such alien, either to an alien or to a citizen of the United States, in trust and for the purpose and with the intention of evading the provisions of this chapter, such conveyance shall be null and void, and any such lands so conveyed shall be forfeited and escheat to the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf7c3df9-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1887-03-03/ch340/s4"},"text":"Mar. 3, 1887, ch. 340, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/24/477"},"text":"24 Stat. 477","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1897-03-02/ch363"},"text":"Mar. 2, 1897, ch. 363","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/29/618"},"text":"29 Stat. 618","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf7c3dfa-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf7c3dfb-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcf7c3dfc-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s74"},"text":"section 74 of Title 8","children":[],"tail":", Aliens and Nationality."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
