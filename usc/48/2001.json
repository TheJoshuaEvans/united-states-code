{"tag":"section","attrib":{"id":"idcfc3ce90-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2001"},"text":null,"children":[{"tag":"num","attrib":{"value":"2001"},"text":"§ 2001.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcfc3ce91-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2001/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States does not have a clearly defined policy for United States noncontiguous Pacific areas (including the Commonwealth of the Northern Mariana Islands, American Samoa, Guam, the State of Hawaii, and the State of Alaska) and for United States-associated noncontiguous Pacific areas (including the Federated States of Micronesia, the Marshall Islands, and Palau);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc3ce92-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2001/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Government has often failed to consider the implications for, effects on, and potential of noncontiguous Pacific areas in the formulation and conduct of foreign and domestic policy, to the detriment of both the attainment of the objectives of Federal policy and noncontiguous Pacific areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc3ce93-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2001/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" policies and programs designed for the United States as a whole may impose inappropriate standards on noncontiguous Pacific areas because of their unique circumstances and needs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc3ce94-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2001/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the present Federal organizational arrangements for liaison with (and providing assistance to) the insular areas may not be adequate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcfc3ce95-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2001/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to coordinate the delivery of Federal programs and services to noncontiguous Pacific areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfc3ce96-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2001/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide a consistent basis for administration of programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfc3ce97-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2001/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to adapt policy to the special requirements of each area and modify the application of Federal programs, laws, and regulations accordingly;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfc3ce98-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2001/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be responsive to the Congress in the discharge of its responsibilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfc3ce99-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2001/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to attain the international obligations of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcfc3ce9a-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/239/tIII/s301"},"text":"Pub. L. 99–239, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-01-14"},"text":"Jan. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1836"},"text":"99 Stat. 1836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcfc3ce9b-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcfc3ce9c-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcfc3ce9d-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1681"},"text":"section 1681 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
