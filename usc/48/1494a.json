{"tag":"section","attrib":{"id":"idcf7c3da6-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1494a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1494a"},"text":"§ 1494a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports to Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcf7c3da7-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1494a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall report annually to the Congress as to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcf7c3da8-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1494a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the efforts and success of Federal agencies in preventing the illegal entry into the United States of controlled substances from the insular areas of the United States outside the customs territory of the United States, the Trust Territory of the Pacific Islands, and states freely associated with the United States and the nature and extent of such illegal entry, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcf7c3da9-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1494a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the efforts and success of Federal agencies in preventing the illegal entry from other nations, including states freely associated with the United States, of controlled substances into the United States territories, the Trust Territory of the Pacific Islands, and the commonwealths for use in the territories, the Trust Territory of the Pacific Islands, and commonwealths or for transshipment to the United States and the nature and extent of such illegal entry and use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf7c3daa-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1494a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmission date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The annual reports required by subsection (a) shall be transmitted to the Committee on Natural Resources of the United States House of Representatives and to the Committee on Energy and Natural Resources of the United States Senate not later than the first day of October each year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcf7c3dab-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/tV/s5003"},"text":"Pub. L. 99–570, title V, § 5003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-155"},"text":"100 Stat. 3207–155","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tIX/s9309"},"text":"Pub. L. 100–690, title IX, § 9309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4539"},"text":"102 Stat. 4539","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/437/s17/a/3"},"text":"Pub. L. 103–437, § 17(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4595"},"text":"108 Stat. 4595","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf7c3dac-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf7c3dad-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcf7c3dae-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/437"},"text":"Pub. L. 103–437","children":[],"tail":" substituted “Natural Resources” for “Interior and Insular Affairs” before “of the United States House”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" designated existing provisions as subsec. (a) and inserted heading, inserted “, the Trust Territory of the Pacific Islands,” before “and states” in par. (1) and after “territories” in two places in par. (2), and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idcf7c3daf-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcf7c3db0-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Termination of Trust Territory of the Pacific Islands","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For termination of Trust Territory of the Pacific Islands, see note set out preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1681"},"text":"section 1681 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
