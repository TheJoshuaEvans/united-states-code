{"tag":"section","attrib":{"id":"idcf7eae37-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1543"},"text":null,"children":[{"tag":"num","attrib":{"value":"1543"},"text":"§ 1543.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States citizenship requirement for government officials","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All members of the Legislature of the Virgin Islands, the Governor, the Lieutenant Governor, all judges and all officials of the government of the Virgin Islands who report directly to the Governor shall be citizens of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf7eae38-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-22/ch558/s29"},"text":"July 22, 1954, ch. 558, § 29","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/509"},"text":"68 Stat. 509","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/213/s5/a"},"text":"Pub. L. 98–213, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-12-08"},"text":"Dec. 8, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1460"},"text":"97 Stat. 1460","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf7eae39-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf7eae3a-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcf7eae3b-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/213"},"text":"Pub. L. 98–213","children":[],"tail":" amended section generally, substituting provisions requiring United States citizenship for all members of the Legislature of the Virgin Islands, the Governor, Lieutenant Governor and all officials who report directly to the Governor for provisions requiring such citizenship for all officers of the Virgin Islands, and struck out provisions requiring written oaths and prescribing the oath."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
