{"tag":"section","attrib":{"id":"idcf7eae3e-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1545"},"text":null,"children":[{"tag":"num","attrib":{"value":"1545"},"text":"§ 1545.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lease and sale of public property; conveyance of title in certain lands to the government of Virgin Islands","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcf7eae3f-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1545/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Interior shall be authorized to lease or to sell upon such terms as he may deem advantageous to the Government of the United States any property of the United States under his administrative supervision in the Virgin Islands not needed for public purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf7eae40-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1545/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcf7eae41-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1545/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All right, title, and interest of the United States in the property placed under the control of the government of the Virgin Islands by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1405c/a"},"text":"section 1405c(a) of this title","children":[],"tail":", not reserved to the United States by the Secretary of the Interior within one hundred and twenty days after "},{"tag":"date","attrib":{"date":"1974-10-05"},"text":"October 5, 1974","children":[],"tail":", is hereby conveyed to such government. The conveyance effected by the preceding sentence shall not apply to that land and other property which on "},{"tag":"date","attrib":{"date":"1974-10-05"},"text":"October 5, 1974","children":[],"tail":", is administered by the Secretary of the Interior as part of the National Park System and such lands and other property shall be retained by the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcf7eae42-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1545/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to valid existing rights, title to all property in the Virgin Islands which may have been acquired by the United States from Denmark under the Convention entered into ","children":[{"tag":"date","attrib":{"date":"1916-08-16"},"text":"August 16, 1916","children":[],"tail":", not reserved or retained by the United States in accordance with the provisions of "},{"tag":"ref","attrib":{"href":"/us/pl/93/435"},"text":"Public Law 93–435","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/88/1210"},"text":"88 Stat. 1210","children":[],"tail":") is hereby transferred to the Virgin Islands government."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcf7eae43-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-22/ch558/s31"},"text":"July 22, 1954, ch. 558, § 31","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/510"},"text":"68 Stat. 510","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/435/s3"},"text":"Pub. L. 93–435, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-05"},"text":"Oct. 5, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1211"},"text":"88 Stat. 1211","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/205/tIV/s401/a"},"text":"Pub. L. 96–205, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-03-12"},"text":"Mar. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/88"},"text":"94 Stat. 88","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf7eae44-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf7eae45-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcf7eae46-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/435"},"text":"Public Law 93–435","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/88/1210"},"text":"88 Stat. 1210","children":[],"tail":"), referred to in subsec. (b)(2), is "},{"tag":"ref","attrib":{"href":"/us/pl/93/435"},"text":"Pub. L. 93–435","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-05"},"text":"Oct. 5, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1210"},"text":"88 Stat. 1210","children":[],"tail":", which enacted sections 1705 to 1708 of this title, amended this section, and repealed sections 1701 to 1703 of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcf7eae47-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/205"},"text":"Pub. L. 96–205","children":[],"tail":" designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/435"},"text":"Pub. L. 93–435","children":[],"tail":" substituted provisions conveying to the government of Virgin Islands title in lands now under its control with power to the Secretary of the Interior to reserve rights to the United States within 120 days after "},{"tag":"date","attrib":{"date":"1974-10-05"},"text":"Oct. 5, 1974","children":[],"tail":", with the exception of land and property being administered by the Secretary of the Interior as part of the National Park System, for provisions that the government of Virgin Islands shall continue to have control over all public property under its control on "},{"tag":"date","attrib":{"date":"1954-07-22"},"text":"July 22, 1954","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcf7eae48-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcf7eae49-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Submerged Lands, Conveyance to Territory","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Conveyance of submerged lands to the government of the Virgin Islands, see section 1701 et seq. of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
