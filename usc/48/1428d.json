{"tag":"section","attrib":{"id":"idcf77827d-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1428d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1428d"},"text":"§ 1428d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report for inclusion in annual report by Governor","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Governor of Guam shall include in the annual report to Congress required pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1422"},"text":"section 1422 of this title","children":[],"tail":" a report on the administration of this subchapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf77827e-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/601/s6"},"text":"Pub. L. 90–601, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-17"},"text":"Oct. 17, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1173"},"text":"82 Stat. 1173","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/470/tII/s206/c"},"text":"Pub. L. 96–470, title II, § 206(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-19"},"text":"Oct. 19, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2244"},"text":"94 Stat. 2244","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf77827f-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf778280-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcf778281-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Organic Act of Guam which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcf778282-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/470"},"text":"Pub. L. 96–470","children":[],"tail":" substituted provision requiring the Governor of Guam to include in his report to Congress under "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1422"},"text":"section 1422 of this title","children":[],"tail":" a report on the administration of this subchapter for provision requiring the Governor of Guam to make an annual report to the Secretary of the Interior on administration of this subchapter, copies of which were to be forwarded to the Speaker of the House of Representatives and the President of the Senate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
