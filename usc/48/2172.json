{"tag":"section","attrib":{"id":"idcfc889d6-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2172"},"text":null,"children":[{"tag":"num","attrib":{"value":"2172"},"text":"§ 2172.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filing of plan of adjustment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcfc889d7-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2172/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusivity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Only the Oversight Board, after the issuance of a certificate pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s2124/j"},"text":"section 2124(j) of this title","children":[],"tail":", may file a plan of adjustment of the debts of the debtor."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfc889d8-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2172/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline for filing plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Oversight Board does not file a plan of adjustment with the petition, the Oversight Board shall file a plan of adjustment at the time set by the court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcfc889d9-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/187/tIII/s312"},"text":"Pub. L. 114–187, title III, § 312","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-30"},"text":"June 30, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/583"},"text":"130 Stat. 583","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
