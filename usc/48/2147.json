{"tag":"section","attrib":{"id":"idcfc88942-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2147"},"text":null,"children":[{"tag":"num","attrib":{"value":"2147"},"text":"§ 2147.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oversight Board authority related to debt issuance","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For so long as the Oversight Board remains in operation, no territorial government may, without the prior approval of the Oversight Board, issue debt or guarantee, exchange, modify, repurchase, redeem, or enter into similar transactions with respect to its debt.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcfc88943-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/187/tII/s207"},"text":"Pub. L. 114–187, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-30"},"text":"June 30, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/575"},"text":"130 Stat. 575","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
