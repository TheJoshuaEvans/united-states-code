{"tag":"section","attrib":{"id":"idcf7056e0-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1421f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1421f"},"text":"§ 1421f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Title to property transferred","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcf7056e1-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1421f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property employed by naval government of Guam","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The title to all property, real and personal, owned by the United States and employed by the naval government of Guam in the administration of the civil affairs of the inhabitants of Guam, including automotive and other equipment, tools and machinery, water and sewerage facilities, bus lines and other utilities, hospitals, schools, and other buildings, shall be transferred to the government of Guam within ninety days after ","children":[{"tag":"date","attrib":{"date":"1950-08-01"},"text":"August 1, 1950","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf7056e2-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1421f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other property not reserved","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All other property, real and personal, owned by the United States in Guam, not reserved by the President of the United States within ninety days after ","children":[{"tag":"date","attrib":{"date":"1950-08-01"},"text":"August 1, 1950","children":[],"tail":", is placed under the control of the government of Guam, to be administered for the benefit of the people of Guam, and the legislature shall have authority, subject to such limitations as may be imposed upon its acts by this chapter or subsequent Act of the Congress, to legislate with respect to such property, real and personal, in such manner as it may deem desirable."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf7056e3-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1421f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary of the Interior; sale or lease","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All property owned by the United States in Guam, the title to which is not transferred to the government of Guam by subsection (a) hereof, or which is not placed under the control of the government of Guam by subsection (b) hereof, is transferred to the administrative supervision of the Secretary of the Interior, except as the President may from time to time otherwise prescribe: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the Secretary of the Interior shall be authorized to lease or to sell, on such terms as he may deem in the public interest, any property, real and personal, of the United States under his administrative supervision in Guam not needed for public purposes."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcf7056e4-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-08-01/ch512/s28"},"text":"Aug. 1, 1950, ch. 512, § 28","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/392"},"text":"64 Stat. 392","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/497/s12/b"},"text":"Pub. L. 90–497, § 12(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-09-11"},"text":"Sept. 11, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/848"},"text":"82 Stat. 848","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf7056e5-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf7056e6-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcf7056e7-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1968—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/497"},"text":"Pub. L. 90–497","children":[],"tail":" substituted “The Secretary of the Interior” for “the head of the department or agency designated by the President under "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1421a"},"text":"section 1421a of this title","children":[],"tail":"” in text of subsec. (c) and “the Secretary of the Interior” for “the head of such department or agency” in proviso."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcf7056e8-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcf7056e9-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1968 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/497"},"text":"Pub. L. 90–497",