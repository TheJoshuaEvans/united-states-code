{"tag":"section","attrib":{"id":"idcfbca255-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1956"},"text":null,"children":[{"tag":"num","attrib":{"value":"1956"},"text":"§ 1956.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of defense sites","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The provisions of title III of the Compact relating to future use by the United States of defense sites in Palau do not restrict the authority of the President of the United States to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcfbca256-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1956/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" request additional funding, subject to appropriation, related to the use of privately owned land in Palau pursuant to article II of title III of the Compact as may be appropriate in light of actual land use requirements, independent appraisals of such privately owned land accepted by both governments, and other appropriate documentation of actual land use costs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfbca257-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1956/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consent to an extension of the time set forth in a subsidiary agreement to such article in which the Government of Palau is required to make such land available to the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcfbca258-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/219/tI/s107"},"text":"Pub. L. 101–219, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-12"},"text":"Dec. 12, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1872"},"text":"103 Stat. 1872","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcfbca259-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcfbca25a-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcfbca25b-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Compact, referred to in text, is the Compact of Free Association between the United States and the Government of Palau, which is contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/658/s201"},"text":"section 201 of Pub. L. 99–658","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1931"},"text":"section 1931 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcfbca25c-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1681"},"text":"section 1681 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
