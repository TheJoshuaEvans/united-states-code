{"tag":"section","attrib":{"id":"idcf6b9bc1-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1403a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1403a"},"text":"§ 1403a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditure of bond proceeds for public improvements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The proceeds of the bond issues or other obligations herein authorized shall be expended only for the public improvements set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1403"},"text":"section 1403 of this title","children":[],"tail":", or for the reduction of the debt created by such bond issue or obligation, unless otherwise authorized by the Congress."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf6b9bc2-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-10-27/ch769/s2"},"text":"Oct. 27, 1949, ch. 769, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/941"},"text":"63 Stat. 941","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
