{"tag":"section","attrib":{"id":"idcf647008-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s910b"},"text":null,"children":[{"tag":"num","attrib":{"value":"910b"},"text":"§ 910b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ratification of prior acts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All legislation heretofore enacted by the Legislature of the Territory of Puerto Rico dealing with the subject matter of this Act and not inconsistent herewith is ratified and confirmed.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf647009-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-07-18/ch466"},"text":"July 18, 1950, ch. 466","children":[],"tail":", title I, § 103, "},{"tag":"ref","attrib":{"href":"/us/stat/64/345"},"text":"64 Stat. 345","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf64700a-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf64700b-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcf64700c-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, means ","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-07-18/ch466"},"text":"act July 18, 1950, ch. 466","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/344"},"text":"64 Stat. 344","children":[],"tail":", known as the Territorial Enabling Act of 1950, which enacted sections 480 to 480b, 483a, 483b, 721 to 721b, 910 to 910b, 1408 to 1408e of this title, amended sections 481 to 483 and 722 of this title, and enacted provisions set out as notes under sections 480, 481, and 722 of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcf64700d-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Puerto Rican Federal Relations Act which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 103 of act ","children":[{"tag":"date","attrib":{"date":"1950-07-18"},"text":"July 18, 1950","children":[],"tail":", cited as a credit to this section, as applicable to Alaska and Hawaii, was classified to sections 480b and 721b of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
