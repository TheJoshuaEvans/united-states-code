{"tag":"section","attrib":{"id":"idcf61fec6-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s748"},"text":null,"children":[{"tag":"num","attrib":{"value":"748"},"text":"§ 748.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conveyance by President to people of lands, buildings, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President may, from time to time, in his discretion, convey to the people of Puerto Rico, such lands, buildings, or interests in lands, or other property now owned by the United States, and within the territorial limits of Puerto Rico as in his opinion are no longer needed for purposes of the United States. And he may from time to time accept by legislative grant from Puerto Rico any lands, buildings, or other interests or property which may be needed for public purposes by the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf61fec7-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1917-03-02/ch145/s7"},"text":"Mar. 2, 1917, ch. 145, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/954"},"text":"39 Stat. 954","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1932-05-17/ch190"},"text":"May 17, 1932, ch. 190","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/158"},"text":"47 Stat. 158","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf61fec8-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf61fec9-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcf61feca-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of proviso clause of section 7 of act ","children":[{"tag":"date","attrib":{"date":"1917-03-02"},"text":"Mar. 2, 1917","children":[],"tail":". The text preceding the proviso clause of section 7 is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s747"},"text":"section 747 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcf61fecb-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idcf61fecc-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Puerto Rico” substituted in text for “Porto Rico” pursuant to act ","children":[{"tag":"date","attrib":{"date":"1932-05-17"},"text":"May 17, 1932","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s731a"},"text":"section 731a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idcf61fecd-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"idcf61fece-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation to Secretary of the Interior of authority vested in President by this section, see Ex. Ord. No. 10250, eff. ","children":[{"tag":"date","attrib":{"date":"1951-06-05"},"text":"June 5, 1951","children":[],"tail":", 16 F.R. 5385, set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of Title 3","children":[],"tail":", The President."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
