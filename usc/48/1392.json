{"tag":"section","attrib":{"id":"idcf692b74-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1392"},"text":null,"children":[{"tag":"num","attrib":{"value":"1392"},"text":"§ 1392.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local laws continued; courts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Until Congress shall otherwise provide, insofar as compatible with the changed sovereignty and not in conflict with the provisions of this section and sections 1391 ","children":[{"tag":"ref","attrib":{"idref":"fn002001"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002001"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and 1394 to 1396 of this title, the laws regulating elections and the electoral franchise as set forth in the code of laws published at Amalienborg the 6th day of April, 1906, and the other local laws, in force and effect in said islands on the 17th day of January, 1917, shall remain in force and effect in said islands, and the same shall be administered by the civil officials and through the local judicial tribunals established in said islands, respectively; and the orders, judgments, and decrees of said judicial tribunals shall be duly enforced. With the approval of the President, or under such rules and regulations as the President may prescribe, any of said laws may be repealed, altered, or amended by the colonial council having jurisdiction. The jurisdiction of the judicial tribunals of said islands shall extend to all judicial proceedings and controversies in said islands to which the United States or any citizen thereof may be a party."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf6b9b75-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1917-03-03/ch171/s2"},"text":"Mar. 3, 1917, ch. 171, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/1132"},"text":"39 Stat. 1132","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646/s39"},"text":"June 25, 1948, ch. 646, § 39","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/992"},"text":"62 Stat. 992","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf6b9b76-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf6b9b77-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcf6b9b78-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1391"},"text":"Section 1391 of this title","children":[],"tail":", referred to in text, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s8/a"},"text":"Pub. L. 89–554, § 8(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/643"},"text":"80 Stat. 643","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcf6b9b79-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1948—Act ","children":[{"tag":"date","attrib":{"date":"1948-06-25"},"text":"June 25, 1948","children":[],"tail":", repealed last sentence relating to appeals. See "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1294"},"text":"section 1294 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcf6b9b7a-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcf6b9b7b-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1948 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by act ","children":[{"tag":"date","attrib":{"date":"1948-06-25"},"text":"June 25, 1948","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1948-09-01"},"text":"Sept. 1, 1948","children":[],"tail":", see section 38 of that act set out as an Effective Date note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1"},"text":"section 1 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
