{"tag":"section","attrib":{"id":"idcf5fb518-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s731b"},"text":null,"children":[{"tag":"num","attrib":{"value":"731b"},"text":"§ 731b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organization of a government pursuant to a constitution","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Fully recognizing the principle of government by consent, sections 731b to 731e of this title are now adopted in the nature of a compact so that the people of Puerto Rico may organize a government pursuant to a constitution of their own adoption.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf5fb519-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-07-03/ch446/s1"},"text":"July 3, 1950, ch. 446, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/319"},"text":"64 Stat. 319","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf5fb51a-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf5fb51b-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcf5fb51c-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Puerto Rican Federal Relations Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcf5fb51d-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"repeals","id":"idcf5fb51e-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeals","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1950-07-03/ch446/s6"},"text":"Act July 3, 1950, ch. 446, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/320"},"text":"64 Stat. 320","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1950-07-03/ch446/s6"},"text":"“All laws or parts of laws inconsistent with this Act [enacting sections 731b to 731e of this title] are hereby repealed.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
