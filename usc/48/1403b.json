{"tag":"section","attrib":{"id":"idcf6b9bc3-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1403b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1403b"},"text":"§ 1403b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bond liability of United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Bonds or other obligations issued pursuant to sections 1403 to 1403b of this title shall not be a debt of the United States, nor shall the United States be liable thereon.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf6b9bc4-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-10-27/ch769/s3"},"text":"Oct. 27, 1949, ch. 769, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/941"},"text":"63 Stat. 941","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
