{"tag":"section","attrib":{"id":"idcfcd6b89-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2232"},"text":null,"children":[{"tag":"num","attrib":{"value":"2232"},"text":"§ 2232.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable law","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In any judicial proceeding regarding this subchapter, Federal, State, or territorial laws of the United States, as applicable, shall govern and be applied without regard or reference to any law of any international or foreign jurisdiction.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcfcd6b8a-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/187/tVI/s602"},"text":"Pub. L. 114–187, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-30"},"text":"June 30, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/609"},"text":"130 Stat. 609","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
