{"tag":"section","attrib":{"id":"idcf66e129-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s916"},"text":null,"children":[{"tag":"num","attrib":{"value":"916"},"text":"§ 916.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ratification of previous legislation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All legislation heretofore enacted by the Legislature of Puerto Rico dealing with the subject matter of sections 911 to 916 of this title and not inconsistent herewith is ratified and confirmed.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf66e12a-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch703/s6"},"text":"June 25, 1938, ch. 703, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1203"},"text":"52 Stat. 1203","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf66e12b-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf66e12c-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcf66e12d-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Puerto Rican Federal Relations Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
