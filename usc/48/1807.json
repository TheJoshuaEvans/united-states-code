{"tag":"section","attrib":{"id":"idcf940ae8-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1807"},"text":null,"children":[{"tag":"num","attrib":{"value":"1807"},"text":"§ 1807.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcf940ae9-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1807/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Interior, in consultation with the Governor of the Commonwealth, the Secretary of Labor, and the Secretary of Commerce, and as provided in the Interagency Agreements required to be negotiated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1806/a/4"},"text":"section 1806(a)(4) of this title","children":[],"tail":", as added by subsection (a),"},{"tag":"ref","attrib":{"idref":"fn002025"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002025"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" shall provide—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcf940aea-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1807/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical assistance and other support to the Commonwealth to identify opportunities for, and encourage diversification and growth of, the economy of the Commonwealth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcf940aeb-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1807/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical assistance, including assistance in recruiting, training, and hiring of workers, to assist employers in the Commonwealth in securing employees first from among United States citizens and nationals resident in the Commonwealth and if an adequate number of such workers are not available, from among legal permanent residents, including lawfully admissible citizens of the freely associated states; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcf940aec-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1807/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical assistance, including assistance to identify types of jobs needed, identify skills needed to fulfill such jobs, and assistance to Commonwealth educational entities to develop curricula for such job skills to include training teachers and students for such skills.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcf940aed-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1807/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In providing such technical assistance under paragraph (1), the Secretaries shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcf940aee-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1807/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with the Government of the Commonwealth, local businesses, regional banks, educational institutions, and other experts in the economy of the Commonwealth; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcf940aef-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1807/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist in the development and implementation of a process to identify opportunities for and encourage diversification and growth of the economy of the Commonwealth and to identify and encourage opportunities to meet the labor needs of the Commonwealth.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcf940af0-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1807/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the provision of technical assistance or support under this paragraph (other than that required to pay the salaries and expenses of Federal personnel), the Secretary of the Interior shall require a non-Federal matching contribution of 10 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcf940af1-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/229/tVII/s702/e"},"text":"Pub. L. 110–229, title VII, § 702(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-08"},"text":"May 8, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/863"},"text":"122 Stat. 863","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf940af2-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf940af3-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcf940af4-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1806/a/4"},"text":"Section 1806(a)(4) of this title","children":[],"tail":", as added by subsection (a), referred to in par. (1), probably means "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1806/a/5"},"text":"section 1806(a)(5) of this title","children":[],"tail":", as added by subsection (a) of "},{"tag":"ref","attrib":{"href":"/us/pl/110/229/s702"},"text":"section 702 of Pub. L. 110–229","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcf940af5-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Consolidated Natural Resources Act of 2008, and not as part of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/241"},"text":"Pub. L. 94–241","children":[],"tail":" which comprises this subchapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcf940af6-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcf940af7-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Department of the Interior Technical Assistance","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/218/s3/c"},"text":"Pub. L. 115–218, § 3(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-07-24"},"text":"July 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1554"},"text":"132 Stat. 1554","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/218/s3/c"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Not later than ","children":[{"tag":"date","attrib":{"date":"2019-10-01"},"text":"October 1, 2019","children":[],"tail":", and biennially thereafter, the Secretary of the Interior shall submit a report to Congress that describes the fulfillment of the Department of the Interior’s responsibilities to the Commonwealth of the Northern Mariana Islands—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify opportunities for economic growth and diversification;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide assistance in recruiting, training, and hiring United States workers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide such other technical assistance and consultation as outlined in section 702(e) of the Consolidated Natural Resources Act of 2008 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1807"},"text":"48 U.S.C. 1807","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
