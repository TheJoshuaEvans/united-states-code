{"tag":"section","attrib":{"id":"idcfcd6b2b-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2215"},"text":null,"children":[{"tag":"num","attrib":{"value":"2215"},"text":"§ 2215.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal agency requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcfcd6b2c-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2215/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Points of Contact","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the request of the Revitalization Coordinator and within 30 days of receiving such a request, each Federal agency with jurisdiction over the permitting, or administrative or environmental review of private or public projects in Puerto Rico, shall name a Point of Contact who will serve as that agency’s liaison with the Revitalization Coordinator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfcd6b2d-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2215/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal grants and loans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each Critical Project with a pending or potential Federal grant, loan, or loan guarantee application, the Revitalization Coordinator and the relevant Point of Contact shall cooperate with each other to ensure expeditious review of such application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfcd6b2e-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2215/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expedited reviews and actions of Federal agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All reviews conducted and actions taken by any Federal agency relating to a Critical Project shall be expedited in a manner consistent with completion of the necessary reviews and approvals by the deadlines under the Expedited Permitting Process, but in no way shall the deadlines established through the Expedited Permitting Process be binding on any Federal agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcfcd6b2f-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/187/tV/s505"},"text":"Pub. L. 114–187, title V, § 505","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-30"},"text":"June 30, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/602"},"text":"130 Stat. 602","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcfcd6b30-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcfcd6b31-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcfcd6b32-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/187/s505"},"text":"section 505 of Pub. L. 114–187","children":[],"tail":". Subsec. (d) of "},{"tag":"ref","attrib":{"href":"/us/pl/114/187/s505"},"text":"section 505 of Pub. L. 114–187","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1492a"},"text":"section 1492a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
