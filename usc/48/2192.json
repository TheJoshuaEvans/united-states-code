{"tag":"section","attrib":{"id":"idcfcafa39-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2192"},"text":null,"children":[{"tag":"num","attrib":{"value":"2192"},"text":"§ 2192.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right of Puerto Rico to determine its future political status","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be interpreted to restrict Puerto Rico’s right to determine its future political status, including by conducting the plebiscite as authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/76"},"text":"Public Law 113–76","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcfcafa3a-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/187/tIV/s402"},"text":"Pub. L. 114–187, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-30"},"text":"June 30, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/586"},"text":"130 Stat. 586","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcfcafa3b-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcfcafa3c-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcfcafa3d-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/187"},"text":"Pub. L. 114–187","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-30"},"text":"June 30, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/549"},"text":"130 Stat. 549","children":[],"tail":", known as the Puerto Rico Oversight, Management, and Economic Stability Act and also as PROMESA, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s2101"},"text":"section 2101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/76"},"text":"Public Law 113–76","children":[],"tail":", referred to in text, is "},{"tag":"ref","attrib":{"href":"/us/pl/113/76"},"text":"Pub. L. 113–76","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-01-17"},"text":"Jan. 17, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/5"},"text":"128 Stat. 5","children":[],"tail":", known as the Consolidated Appropriations Act, 2014. Provisions relating to appropriations for a plebiscite on Puerto Rico’s future political status appear at "},{"tag":"ref","attrib":{"href":"/us/stat/128/61"},"text":"128 Stat. 61","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
