{"tag":"section","attrib":{"id":"idcf6de66e-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1413"},"text":null,"children":[{"tag":"num","attrib":{"value":"1413"},"text":"§ 1413.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Completion of proof on death of discoverer","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If the discoverer dies before perfecting proof of discovery or fully complying with the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1412"},"text":"section 1412 of this title","children":[],"tail":", his widow, heir, executor, or administrator shall be entitled to the benefits of such discovery, upon complying with the provisions of this chapter. Nothing herein shall be held to impair any rights of discovery or any assignment by a discoverer recognized prior to "},{"tag":"date","attrib":{"date":"1872-04-02"},"text":"April 2, 1872","children":[],"tail":", by the United States."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf6de66f-3a70-11f1-9e44-df1065572ea0"},"text":"(R.S. § 5572.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf6de670-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf6de671-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcf6de672-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 5572 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1872-04-02/ch81/s1"},"text":"act Apr. 2, 1872, ch. 81, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/17/48"},"text":"17 Stat. 48","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
