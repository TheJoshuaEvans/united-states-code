{"tag":"section","attrib":{"id":"idcf836a20-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1599"},"text":null,"children":[{"tag":"num","attrib":{"value":"1599"},"text":"§ 1599.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of functions from government comptroller for Virgin Islands to Inspector General, Department of the Interior","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcf836a21-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1599/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions, powers, and duties transferred","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following functions, powers, and duties heretofore vested in the government comptroller for the Virgin Islands are hereby transferred to the Inspector General, Department of the Interior, for the purpose of establishing an organization which will maintain a satisfactory level of independent audit oversight of the government of the Virgin Islands:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcf836a22-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1599/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority to audit all accounts pertaining to the revenue and receipts of the government of the Virgin Islands, and of funds derived from bond issues, and the authority to audit, in accordance with law and administrative regulations, all expenditures of funds and property pertaining to the government of the Virgin Islands including those pertaining to trust funds held by the government of the Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcf836a23-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1599/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority to report to the Secretary of the Interior and the Governor of the Virgin Islands all failures to collect amounts due the government, and expenditures of funds or uses of property which are irregular or not pursuant to law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf836a24-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1599/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of authority transferred","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority granted in paragraph (a) shall extend to all activities of the government of the Virgin Islands, and shall be in addition to the authority conferred upon the Inspector General by chapter 4 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf836a25-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1599/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of personnel, assets, etc., of office of government comptroller for Virgin Islands to Office of Inspector General, Department of the Interior","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to carry out the provisions of this section, the personnel, assets, liabilities, contracts, property, records, and unexpended balances of appropriations, authorizations, allocations, and other funds employed, held, used, arising from, available or to be made available, of the office of the government comptroller for the Virgin Islands related to its audit function are hereby transferred to the Office of Inspector General, Department of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcf836a26-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-22/ch558/s17"},"text":"July 22, 1954, ch. 558, § 17","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/357/tIII/s309/b"},"text":"Pub. L. 97–357, title III, § 309(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-19"},"text":"Oct. 19, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1710"},"text":"96 Stat. 1710","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/92"},"text":"Pub. L. 117–286, § 4(b)(92)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4352"},"text":"136 Stat. 4352","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf836a27-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf836a28-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcf836a29-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1599, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-22/ch558/s17"},"text":"July 22, 1954, ch. 558, § 17","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/505"},"text":"68 Stat. 505","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1958-08-28"},"text":"Aug. 28, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/851"},"text":"Pub. L. 85–851","children":[],"tail":", §§ 4, 5, "},{"tag":"ref","attrib":{"href":"/us/stat/72/1094"},"text":"72 Stat. 1094","children":[],"tail":", 1095; "},{"tag":"date","attrib":{"date":"1962-03-20"},"text":"Mar. 20, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/87/421"},"text":"Pub. L. 87–421","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/43"},"text":"76 Stat. 43","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1968-08-23"},"text":"Aug. 23, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/90/496/s9"},"text":"Pub. L. 90–496, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/840"},"text":"82 Stat. 840","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1977-10-15"},"text":"Oct. 15, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/95/134/tIII/s301/a"},"text":"Pub. L. 95–134, title III, § 301(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1162"},"text":"91 Stat. 1162","children":[],"tail":", related to appointment, status, and duties of the government comptroller for the Virgin Islands, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/97/357/s309/b"},"text":"Pub. L. 97–357, § 309(b)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcf836a2a-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 4 of title 5.” for “the Inspector General Act of 1978 ("},{"tag":"ref","attrib":{"href":"/us/stat/92/1101"},"text":"92 Stat. 1101","children":[],"tail":"), as amended.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
