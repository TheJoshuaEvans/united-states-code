{"tag":"section","attrib":{"id":"idcf7c3e07-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1507"},"text":null,"children":[{"tag":"num","attrib":{"value":"1507"},"text":"§ 1507.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"This chapter shall not in any manner be construed to authorize aliens to acquire title from the United States to any of the public lands of the United States or to in any manner affect or change the laws regulating the disposal of the public lands of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf7c3e08-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1887-03-03/ch340/s7"},"text":"Mar. 3, 1887, ch. 340, § 7","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1897-03-02/ch363"},"text":"Mar. 2, 1897, ch. 363","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/29/619"},"text":"29 Stat. 619","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/act/1905-02-23/ch733/s1"},"text":"Feb. 23, 1905, ch. 733, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/33/733"},"text":"33 Stat. 733","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf7c3e09-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf7c3e0a-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcf7c3e0b-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p"