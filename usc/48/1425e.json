{"tag":"section","attrib":{"id":"idcf77825d-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1425e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1425e"},"text":"§ 1425e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional powers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Powers granted herein shall be in addition to, and not in derogation of, any powers granted by other law to, or for the benefit or assistance of, any public corporate authority.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf77825e-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/171/s5"},"text":"Pub. L. 88–171, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-11-04"},"text":"Nov. 4, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/304"},"text":"77 Stat. 304","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf77825f-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf778260-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcf778261-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Organic Act of Guam which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
