{"tag":"section","attrib":{"id":"idcf940b17-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1822"},"text":null,"children":[{"tag":"num","attrib":{"value":"1822"},"text":"§ 1822.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction of District Court; original jurisdiction; procedural requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcf940b18-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1822/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The District Court for the Northern Mariana Islands shall have the jurisdiction of a District Court of the United States, including, but not limited to, the diversity jurisdiction provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1332"},"text":"section 1332 of title 28","children":[],"tail":" and that of a bankruptcy court of the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf940b19-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1822/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The district court shall have original jurisdiction in all causes in the Northern Mariana Islands not described in subsection (a) jurisdiction over which is not vested by the Constitution or laws of the Northern Mariana Islands in a court or courts of the Northern Mariana Islands. In causes brought in the district court solely on the basis of this subsection, the district court shall be considered a court of the Northern Mariana Islands for the purposes of determining the requirements of indictment by grand jury or trial by jury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcf940b1a-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/157/s2"},"text":"Pub. L. 95–157, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-11-08"},"text":"Nov. 8, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1266"},"text":"91 Stat. 1266","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/454/tIX/s902"},"text":"Pub. L. 98–454, title IX, § 902","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-05"},"text":"Oct. 5, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1744"},"text":"98 Stat. 1744","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf940b1b-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf940b1c-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcf940b1d-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1694a"},"text":"section 1694a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcf940b1e-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/454"},"text":"Pub. L. 98–454","children":[],"tail":" amended subsec. (a) generally, substituting “, including, but not limited to, the diversity jurisdiction provided for in "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1332"},"text":"section 1332 of title 28","children":[],"tail":" and that of a bankruptcy court of the United States” for “, except that in all causes arising under the Constitution, treaties, or laws of the United States, it shall have jurisdiction regardless of the sum or value of the matter in controversy”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcf940b1f-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcf940b20-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/454"},"text":"Pub. L. 98–454","children":[],"tail":" effective on ninetieth day following "},{"tag":"date","attrib":{"date":"1984-10-05"},"text":"Oct. 5, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/454/s1005"},"text":"section 1005 of Pub. L. 98–454","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1424"},"text":"section 1424 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcf940b21-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1825"},"text":"section 1825 of this title","children":[],"tail":" and Effective Date of Constitution note thereunder."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
