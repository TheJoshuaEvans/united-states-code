{"tag":"section","attrib":{"id":"idcf85da9e-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1642a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1642a"},"text":"§ 1642a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of collected customs duties for expenditures as Legislature may provide","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the proceeds of customs duties collected in the Virgin Islands less the cost of collecting all said duties shall, effective for fiscal years beginning after ","children":[{"tag":"date","attrib":{"date":"1979-09-30"},"text":"September 30, 1979","children":[],"tail":", be covered into the Treasury of the Virgin Islands, and shall be available for expenditure as the Legislator "},{"tag":"ref","attrib":{"idref":"fn002012"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002012"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Legislature”."}],"tail":" of the Virgin Islands may provide."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf85da9f-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/304/tI/s100"},"text":"Pub. L. 96–304, title I, § 100","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-07-08"},"text":"July 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/907"},"text":"94 Stat. 907","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf85daa0-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf85daa1-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcf85daa2-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1642a, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/38/tI"},"text":"Pub. L. 96–38, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-25"},"text":"July 25, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/122"},"text":"93 Stat. 122","children":[],"tail":", related to availability of collected customs duties for expenditures as the Virgin Islands Legislature may provide, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/96/205/tIV/s403/b"},"text":"Pub. L. 96–205, title IV, § 403(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-03-12"},"text":"Mar. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/89"},"text":"94 Stat. 89","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
