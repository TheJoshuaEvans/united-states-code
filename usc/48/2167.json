{"tag":"section","attrib":{"id":"idcfc889bf-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2167"},"text":null,"children":[{"tag":"num","attrib":{"value":"2167"},"text":"§ 2167.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Venue","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcfc889c0-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2167/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Venue shall be proper in—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcfc889c1-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2167/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a territory, the district court for the territory or, for any territory that does not have a district court, the United States District Court for the District of Hawaii; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc889c2-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2167/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a covered territorial instrumentality, the district court for the territory in which the covered territorial instrumentality is located or, for any territory that does not have a district court, the United States District Court for the District of Hawaii.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfc889c3-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2167/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative venue","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcfc889c4-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2167/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Oversight Board so determines in its sole discretion, then venue shall be proper in the district court for the jurisdiction in which the Oversight Board maintains an office that is located outside the territory.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc889c5-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2167/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to paragraph (1), the Oversight Board may consider, among other things—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcfc889c6-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2167/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the resources of the district court to adjudicate a case or proceeding; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfc889c7-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2167/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact on witnesses who may be called in such a case or proceeding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcfc889c8-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/187/tIII/s307"},"text":"Pub. L. 114–187, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-30"},"text":"June 30, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/582"},"text":"130 Stat. 582","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
