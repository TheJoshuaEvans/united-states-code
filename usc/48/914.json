{"tag":"section","attrib":{"id":"idcf64701e-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s914"},"text":null,"children":[{"tag":"num","attrib":{"value":"914"},"text":"§ 914.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of bonds and obligations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The legislature may authorize such authorities to issue bonds or other obligations with such security as the legislature may provide and may provide for the disposition of the proceeds of such bonds and all receipts and revenues of such authorities.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf64701f-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch703/s4"},"text":"June 25, 1938, ch. 703, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1203"},"text":"52 Stat. 1203","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf647020-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf647021-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcf647022-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Puerto Rican Federal Relations Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
