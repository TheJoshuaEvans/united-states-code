{"tag":"section","attrib":{"id":"idcf646feb-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s893"},"text":null,"children":[{"tag":"num","attrib":{"value":"893"},"text":"§ 893.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Salary of Commissioner; allowances; franking privilege","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Resident Commissioner shall receive a salary payable monthly by the United States. He shall be allowed the same sum for stationery and for the pay of necessary clerk hire as is allowed Members of the House of Representatives of the United States. He shall be allowed the franking privilege granted Members of Congress.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf646fec-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1917-03-02/ch145/s36"},"text":"Mar. 2, 1917, ch. 145, § 36","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/963"},"text":"39 Stat. 963","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1925-03-04/ch549/s4"},"text":"Mar. 4, 1925, ch. 549, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/1301"},"text":"43 Stat. 1301","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf646fed-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf646fee-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcf646fef-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of parts of third and fourth sentences of section 36 of act ","children":[{"tag":"date","attrib":{"date":"1917-03-02"},"text":"Mar. 2, 1917","children":[],"tail":". For classification of the remainder of section 36, see Codification note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s891"},"text":"section 891 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
