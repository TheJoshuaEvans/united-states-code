{"tag":"section","attrib":{"id":"idcf5fb527-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s731d"},"text":null,"children":[{"tag":"num","attrib":{"value":"731d"},"text":"§ 731d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ratification of constitution by Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Upon adoption of the constitution by the people of Puerto Rico, the President of the United States is authorized to transmit such constitution to the Congress of the United States if he finds that such constitution conforms with the applicable provisions of sections 731b to 731e of this title and of the Constitution of the United States.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Upon approval by the Congress the constitution shall become effective in accordance with its terms.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf5fb528-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-07-03/ch446/s3"},"text":"July 3, 1950, ch. 446, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/319"},"text":"64 Stat. 319","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf5fb529-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf5fb52a-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcf5fb52b-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Puerto Rican Federal Relations Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcf5fb52c-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcf5fb52d-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Constitution of the Commonwealth of Puerto Rico","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Constitution of the Commonwealth of Puerto Rico was approved by the Constitutional Convention of Puerto Rico on ","children":[{"tag":"date","attrib":{"date":"1952-02-06"},"text":"Feb. 6, 1952","children":[],"tail":"; ratified by the people of Puerto Rico on "},{"tag":"date","attrib":{"date":"1952-03-03"},"text":"Mar. 3, 1952","children":[],"tail":"; amended and approved by Congress by Joint Res. "},{"tag":"ref","attrib":{"href":"/us/act/1952-07-03/ch567"},"text":"July 3, 1952, ch. 567","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/327"},"text":"66 Stat. 327","children":[],"tail":"; proclaimed by the Governor of Puerto Rico to be in force and effect on "},{"tag":"date","attrib":{"date":"1952-07-25"},"text":"July 25, 1952","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
