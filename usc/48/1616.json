{"tag":"section","attrib":{"id":"idcf836a6e-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1616"},"text":null,"children":[{"tag":"num","attrib":{"value":"1616"},"text":"§ 1616.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trial by jury","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All criminal cases originating in the district court shall be tried by jury upon demand by the defendant or by the Government. If no jury is demanded the case shall be tried by the judge of the district court without a jury, except that the judge may, on his own motion, order a jury for the trial of any criminal action. The legislature may provide for trial in misdemeanor cases by a jury of six qualified persons.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf836a6f-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-22/ch558/s26"},"text":"July 22, 1954, ch. 558, § 26","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/507"},"text":"68 Stat. 507","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/851/s8"},"text":"Pub. L. 85–851, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-28"},"text":"Aug. 28, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1095"},"text":"72 Stat. 1095","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf836a70-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf836a71-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcf836a72-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1958—","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/851"},"text":"Pub. L. 85–851","children":[],"tail":" substituted requirement of jury trial upon demand by defendant or Government for prohibition against denial to any person on demand of either party."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
