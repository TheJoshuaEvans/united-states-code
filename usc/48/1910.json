{"tag":"section","attrib":{"id":"idcfa263a4-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1910"},"text":null,"children":[{"tag":"num","attrib":{"value":"1910"},"text":"§ 1910.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of audit agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcfa263a5-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1910/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmission of annual financial statement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon receipt of the annual financial statement described in sections 1902(c)(4) and 1903(m)(4) of this title, the President shall promptly transmit a copy of such statement to the Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfa263a6-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1910/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual audits by President","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcfa263a7-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1910/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President shall cause an annual audit to be conducted of the annual financial statements described in sections 1902(c)(4) and 1903(m)(4) of this title. Such audit shall be conducted in accordance with the Generally Accepted Government Auditing Standards promulgated by the Comptroller General of the United States. Such audit shall be submitted to the Congress not later than 180 days after the end of the United States fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfa263a8-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1910/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President shall develop and implement procedures to carry out such audits. Such procedures shall include the matters described in sections 1902(c)(2) and 1903(m)(2) of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfa263a9-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1910/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of GAO","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller General of the United States shall have the authority to conduct the audits referred to in sections 1902(c)(1) and 1903(m)(1) of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcfa263aa-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/239/tI/s110"},"text":"Pub. L. 99–239, title I, § 110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-01-14"},"text":"Jan. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1798"},"text":"99 Stat. 1798","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcfa263ab-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcfa263ac-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcfa263ad-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1681"},"text":"section 1681 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcfa263ae-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcfa263af-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of provisions in subsec. (b) of this section relating to the requirement that the annual audit be submitted to Congress, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance, and the 13th item on page 37 of House Document No. 103–7."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
