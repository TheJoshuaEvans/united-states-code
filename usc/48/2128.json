{"tag":"section","attrib":{"id":"idcfc63f9c-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2128"},"text":null,"children":[{"tag":"num","attrib":{"value":"2128"},"text":"§ 2128.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Autonomy of Oversight Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcfc63f9d-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2128/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Neither the Governor nor the Legislature may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcfc63f9e-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2128/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exercise any control, supervision, oversight, or review over the Oversight Board or its activities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc63f9f-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2128/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enact, implement, or enforce any statute, resolution, policy, or rule that would impair or defeat the purposes of this chapter, as determined by the Oversight Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfc63fa0-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2128/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oversight Board legal representation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any action brought by, on behalf of, or against the Oversight Board, the Oversight Board shall be represented by such counsel as it may hire or retain so long as the representation complies with the applicable professional rules of conduct governing conflicts of interests.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcfc63fa1-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/187/tI/s108"},"text":"Pub. L. 114–187, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-30"},"text":"June 30, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/563"},"text":"130 Stat. 563","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcfc63fa2-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcfc63fa3-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcfc63fa4-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a)(2), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/187"},"text":"Pub. L. 114–187","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-30"},"text":"June 30, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/549"},"text":"130 Stat. 549","children":[],"tail":", known as the Puerto Rico Oversight, Management, and Economic Stability Act and also as PROMESA, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s2101"},"text":"section 2101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
