{"tag":"section","attrib":{"id":"idcfcafac0-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2199"},"text":null,"children":[{"tag":"num","attrib":{"value":"2199"},"text":"§ 2199.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expansion of HUBZones in Puerto Rico","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcfcafac1-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2199/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfcafac2-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2199/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improving oversight","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcfcafac3-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2199/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 270 days after ","children":[{"tag":"date","attrib":{"date":"2016-06-30"},"text":"June 30, 2016","children":[],"tail":", the Administrator of the Small Business Administration shall develop and implement criteria and guidance on using a risk-based approach to requesting and verifying information from entities applying to be designated or recertified as qualified HUBZone small business concerns (as defined in section 632(p)(5) "},{"tag":"ref","attrib":{"idref":"fn002059"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002059"},"text":null,"children":[{"tag":"num","attrib":{},"text":"