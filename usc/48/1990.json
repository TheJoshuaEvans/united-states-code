{"tag":"section","attrib":{"id":"idcfc3ce7a-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1990"},"text":null,"children":[{"tag":"num","attrib":{"value":"1990"},"text":"§ 1990.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compact appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcfc3ce7b-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1990/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding for activities of the Secretary of the Interior","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the period of fiscal years 2024 through 2043, there are appropriated to the Compact of Free Association account of the Department of the Interior, out of any funds in the Treasury not otherwise appropriated, to remain available until expended, the amounts described in and to carry out the purposes of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcfc3ce7c-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1990/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 261, 265, and 266 of the 2023 Amended U.S.-FSM Compact;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc3ce7d-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1990/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 261, 265, and 266 of the 2023 Amended U.S.-RMI Compact; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc3ce7e-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1990/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Articles 1, 2, and 3 of the 2023 U.S.-Palau Compact Review Agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfc3ce7f-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1990/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding for activities of the United States Postal Service","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcfc3ce80-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1990/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is appropriated to the United States Postal Service, out of any funds in the Treasury not otherwise appropriated for each of fiscal years 2024 through 2043, $31,700,000, to remain available until expended, to carry out the costs of the following provisions that are not otherwise funded:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcfc3ce81-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1990/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 221(a)(2) of the 2023 Amended U.S.-FSM Compact.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfc3ce82-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1990/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 221(a)(2) of the 2023 Amended U.S.-RMI Compact.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfc3ce83-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1990/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 221(a)(2) of the U.S.-Palau Compact.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfc3ce84-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1990/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Article 6(a) of the 2023 U.S.-Palau Compact Review Agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc3ce85-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1990/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcfc3ce86-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1990/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amounts appropriated to the United States Postal Service under paragraph (1) shall be deposited into the Postal Service Fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s2003"},"text":"section 2003 of title 39","children":[],"tail":" to carry out the provisions described in that paragraph."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfc3ce87-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1990/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amounts deposited into the Postal Service Fund under subparagraph (A) shall be the fiduciary, fiscal, and audit responsibility of the Postal Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfc3ce88-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1990/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding for Judicial training","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is appropriated to the Secretary of the Interior to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1988/d"},"text":"section 1988(d) of this title","children":[],"tail":" out of any funds in the Treasury not otherwise appropriated, $550,000 for each of fiscal years 2024 through 2043, to remain available until expended."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfc3ce89-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1990/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of previously appropriated amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total amounts made available to the Government of the Federated States of Micronesia and the Government of the Republic of the Marshall Islands under subsection (a) shall be reduced by amounts made available to the Government of the Federated States of Micronesia and the Government of the Republic of the Marshall Islands, as applicable, under section 2101(a) of the Continuing Appropriations Act, 2024 and Other Extensions Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/15"},"text":"Public Law 118–15","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/137/81"},"text":"137 Stat. 81","children":[],"tail":") (as amended by section 101 of division B of the Further Continuing Appropriations and Other Extensions Act, 2024 ("},{"tag":"ref","attrib":{"href":"/us/pl/118/22"},"text":"Public Law 118–22","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/137/114"},"text":"137 Stat. 114","children":[],"tail":") and section 201 of the Further Additional Continuing Appropriations and Other Extensions Act, 2024 ("},{"tag":"ref","attrib":{"href":"/us/pl/118/35"},"text":"Public Law 118–35","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/138/7"},"text":"138 Stat. 7","children":[],"tail":"))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcfc3ce8a-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/42/dG/tII/s211"},"text":"Pub. L. 118–42, div. G, title II, § 211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-03-09"},"text":"Mar. 9, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/450"},"text":"138 Stat. 450","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcfc3ce8b-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcfc3ce8c-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcfc3ce8d-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 2101(a) of the Continuing Appropriations Act, 2024 and Other Extensions Act, referred to in subsec. (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/15/s2101/a"},"text":"section 2101(a) of Pub. L. 118–15","children":[],"tail":", div. B, title I, "},{"tag":"date","attrib":{"date":"2023-09-30"},"text":"Sept. 30, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/81"},"text":"127 Stat. 81","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
