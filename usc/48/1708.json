{"tag":"section","attrib":{"id":"idcf8a95a0-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1708"},"text":null,"children":[{"tag":"num","attrib":{"value":"1708"},"text":"§ 1708.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discrimination prohibited in rights of access to, and benefits from, conveyed lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No person shall be denied access to, or any of the benefits accruing from, the lands conveyed by this Act, or by the amendment made by this Act, on the basis of race, religion, creed, color, sex, national origin, or ancestry: ","children":[{"tag":"i","attrib":{},"text":"Provided, however","children":[],"tail":", That this section shall not be construed in derogation of any of the provisions of the "},{"tag":"date","attrib":{"date":"1900-04-17"},"text":"April 17, 1900","children":[],"tail":" cession of Tutuila and Aunuu or the "},{"tag":"date","attrib":{"date":"1904-07-16"},"text":"July 16, 1904","children":[],"tail":" cession of the Manu’s Islands, as ratified by the Act of "},{"tag":"date","attrib":{"date":"1929-02-20"},"text":"February 20, 1929","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/45/1253"},"text":"45 Stat. 1253","children":[],"tail":") and the Act of "},{"tag":"date","attrib":{"date":"1929-05-22"},"text":"May 22, 1929","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/46/4"},"text":"46 Stat. 4","children":[],"tail":")."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf8a95a1-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/435/s6"},"text":"Pub. L. 93–435, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-05"},"text":"Oct. 5, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1212"},"text":"88 Stat. 1212","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attr