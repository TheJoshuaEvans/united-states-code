{"tag":"section","attrib":{"id":"idcf61ff49-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s821"},"text":null,"children":[{"tag":"num","attrib":{"value":"821"},"text":"§ 821.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Legislative power","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The legislative authority shall extend to all matters of a legislative character not locally inapplicable, including power to create, consolidate, and reorganize the municipalities so far as may be necessary, and to provide and repeal laws and ordinances therefor; also the power to alter, amend, modify, or repeal any or all laws and ordinances of every character in force in Puerto Rico or municipality or district thereof on ","children":[{"tag":"date","attrib":{"date":"1917-03-02"},"text":"March 2, 1917","children":[],"tail":", insofar as such alteration, amendment, modification, or repeal may be consistent with the provisions of this chapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf61ff4a-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1917-03-02/ch145/s37"},"text":"Mar. 2, 1917, ch. 145, § 37","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/964"},"text":"39 Stat. 964","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1932-05-17/ch190"},"text":"May 17, 1932, ch. 190","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/158"},"text":"47 Stat. 158","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf61ff4b-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf61ff4c-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcf61ff4d-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/act/1917-03-02/ch145"},"text":"act Mar. 2, 1917, ch. 145","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/951"},"text":"39 Stat. 951","children":[],"tail":", known as the Puerto Rican Federal Relations Act and also popularly known as the Jones Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s731"},"text":"section 731 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcf61ff4e-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idcf61ff4f-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Puerto Rico” substituted in text for “Porto Rico” pursuant to act ","children":[{"tag":"date","attrib":{"date":"1932-05-17"},"text":"May 17, 1932","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s731a"},"text":"section 731a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
