{"tag":"section","attrib":{"id":"idcf646ff0-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s894"},"text":null,"children":[{"tag":"num","attrib":{"value":"894"},"text":"§ 894.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Salary and traveling expenses; payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The salary and traveling expenses of the Resident Commissioner from Puerto Rico to the United States shall be paid by the Chief Administrative Officer of the House of Representatives in the same manner as the salaries of the members of the House of Representatives are paid.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf646ff1-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1906-06-22/ch3514/s1"},"text":"June 22, 1906, ch. 3514, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/417"},"text":"34 Stat. 417","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1932-05-17/ch190"},"text":"May 17, 1932, ch. 190","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/158"},"text":"47 Stat. 158","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s224/1"},"text":"Pub. L. 104–186, title II, § 224(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1752"},"text":"110 Stat. 1752","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf646ff2-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf646ff3-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcf646ff4-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Puerto Rican Federal Relations Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcf646ff5-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186"},"text":"Pub. L. 104–186","children":[],"tail":" substituted “Chief Administrative Officer” for “Sergeant-at-Arms”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcf646ff6-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idcf646ff7-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Puerto Rico” substituted in text for “Porto Rico” pursuant to act ","children":[{"tag":"date","attrib":{"date":"1932-05-17"},"text":"May 17, 1932","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s731a"},"text":"section 731a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
