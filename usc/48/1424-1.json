{"tag":"section","attrib":{"id":"idcf7511f0-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1424–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1424–1"},"text":"§ 1424–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction and powers of local courts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcf7511f1-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1424–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supreme Court of Guam","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Supreme Court of Guam shall be the highest court of the judicial branch of Guam (excluding the District Court of Guam) and shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcf7511f2-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1424–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have original jurisdiction over proceedings necessary to protect its appellate jurisdiction and supervisory authority and such other original jurisdiction as the laws of Guam may provide;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcf7511f3-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1424–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have jurisdiction to hear appeals over any cause in Guam decided by the Superior Court of Guam or other courts established under the laws of Guam;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcf7511f4-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1424–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have jurisdiction to issue all orders and writs in aid of its appellate, supervisory, and original jurisdiction, including those orders necessary for the supervision of the judicial branch of Guam;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcf7511f5-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1424–1/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have supervisory jurisdiction over the Superior Court of Guam and all other courts of the judicial branch of Guam;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcf7511f6-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1424–1/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hear and determine appeals by a panel of three of the justices of the Supreme Court of Guam and a concurrence of two such justices shall be necessary to a decision of the Supreme Court of Guam on the merits of an appeal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcf7511f7-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1424–1/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make and promulgate rules governing the administration of the judiciary and the practice and procedure in the courts of the judicial branch of Guam, including procedures for the determination of an appeal en banc; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcf7511f8-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1424–1/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" govern attorney and judicial ethics and the practice of law in Guam, including admission to practice law and the conduct and discipline of persons admitted to practice law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf7511f9-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1424–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief Justice of Supreme Court of Guam","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Chief Justice of the Supreme Court of Guam—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcf7511fa-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1424–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall preside over the Supreme Court unless disqualified or unable to act;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcf7511fb-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1424–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be the administrative head of, and have general supervisory power over, all departments, divisions, and other instrumentalities of the judicial branch of Guam; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcf7511fc-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1424–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may issue such administrative orders on behalf of the Supreme Court of Guam as necessary for the efficient administration of the judicial branch of Guam.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf7511fd-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1424–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Orders of Chief Justice with respect to appeals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Chief Justice of the Supreme Court of Guam, or a justice sitting in place of such Chief Justice, may make any appropriate order with respect to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcf7511fe-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1424–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an appeal prior to the hearing and determination of that appeal on the merits; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcf7511ff-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1424–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dismissal of an appeal for lack of jurisdiction or failure to take or prosecute the appeal in accordance with applicable laws or rules of procedure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf751200-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1424–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other local courts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as granted to the Supreme Court of Guam or otherwise provided by this chapter or any other Act of Congress, the Superior Court of Guam and all other local courts established by the laws of Guam shall have such original and appellate jurisdiction over all causes in Guam as the laws of Guam provide, except that such jurisdiction shall be subject to the exclusive or concurrent jurisdiction conferred on the District Court of Guam under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1424"},"text":"section 1424 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf751201-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1424–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications and duties of justices and judges","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The qualifications and duties of the justices and judges of the Supreme Court of Guam, the Superior Court of Guam, and all other local courts established by the laws of Guam shall be governed by the laws of Guam and the rules of such courts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcf751202-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-08-01/ch512/s22A"},"text":"Aug. 1, 1950, ch. 512, § 22A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/454/tVIII/s801"},"text":"Pub. L. 98–454, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-05"},"text":"Oct. 5, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1742"},"text":"98 Stat. 1742","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/378/s1/b"},"text":"Pub. L. 108–378, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2206"},"text":"118 Stat. 2206","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf751203-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf751204-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcf751205-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/378"},"text":"Pub. L. 108–378","children":[],"tail":" amended section generally, substituting provisions relating to Supreme Court of Guam and other courts for provisions consisting of subsecs. (a) to (c) relating to composition of local courts and establishment of appellate court, jurisdiction of courts, and practice and procedure in local courts and qualifications and duties of judges."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcf751206-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcf751207-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on ninetieth day following ","children":[{"tag":"date","attrib":{"date":"1984-10-05"},"text":"Oct. 5, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/454/s1005"},"text":"section 1005 of Pub. L. 98–454","children":[],"tail":", set out as an Effective Date of 1984 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1424"},"text":"section 1424 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
