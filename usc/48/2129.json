{"tag":"section","attrib":{"id":"idcfc63fa5-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2129"},"text":null,"children":[{"tag":"num","attrib":{"value":"2129"},"text":"§ 2129.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ethics","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcfc63fa6-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2129/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflict of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any ethics provision governing employees of the covered territory, all members and staff of the Oversight Board shall be subject to the Federal conflict of interest requirements described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s208"},"text":"section 208 of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfc63fa7-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2129/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial disclosure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any ethics provision governing employees of the covered territory, all members of the Oversight Board and staff designated by the Oversight Board shall be subject to disclosure of their financial interests, the contents of which shall conform to the same requirements set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s13104"},"text":"section 13104 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcfc63fa8-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"r