{"tag":"section","attrib":{"id":"idcfc889eb-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2175"},"text":null,"children":[{"tag":"num","attrib":{"value":"2175"},"text":"§ 2175.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Role and capacity of Oversight Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcfc889ec-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2175/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions of Oversight Board","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this subchapter, the Oversight Board may take any action necessary on behalf of the debtor to prosecute the case of the debtor, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcfc889ed-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2175/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" filing a petition under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s2164"},"text":"section 2164 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc889ee-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2175/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submitting or modifying a plan of adjustment under sections 2172 and 2173 of this title; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc889ef-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2175/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise generally submitting filings in relation to the case with the court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfc889f0-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2175/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Representative of debtor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Oversight Board in a case under this subchapter is the representative of the debtor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcfc889f1-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/187/tIII/s315"},"text":"Pub. L. 114–187, title III, § 315","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-30"},"text":"June 30, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/584"},"text":"130 Stat. 584","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
