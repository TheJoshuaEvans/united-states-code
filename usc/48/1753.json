{"tag":"section","attrib":{"id":"idcf8a95ef-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1753"},"text":null,"children":[{"tag":"num","attrib":{"value":"1753"},"text":"§ 1753.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications for office of Delegate","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"To be eligible for the office of Delegate a candidate shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcf8a95f0-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1753/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be at least 25 years of age on the date of the election;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcf8a95f1-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1753/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have been a citizen of the United States for at least 7 years prior to the date of the election;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcf8a95f2-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1753/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a resident and domiciliary of the Commonwealth of the Northern Mariana Islands for at least 7 years prior to the date of the election;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcf8a95f3-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1753/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be qualified to vote in the Commonwealth of the Northern Mariana Islands on the date of the election; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcf8a95f4-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1753/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not be, on the date of the election, a candidate for any other office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcf8a95f5-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/229/tVII/s713"},"text":"Pub. L. 110–229, title VII, § 713","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-08"},"text":"May 8, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/868"},"text":"122 Stat. 868","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
