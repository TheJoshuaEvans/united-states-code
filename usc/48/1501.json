{"tag":"section","attrib":{"id":"idcf7c3de9-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1501"},"text":null,"children":[{"tag":"num","attrib":{"value":"1501"},"text":"§ 1501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lands in Territories","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No alien or person who is not a citizen of the United States, or who has not declared his intention to become a citizen of the United States in the manner provided by law shall acquire title to or own any land in any of the Territories of the United States except as hereinafter provided. The prohibition of this section shall not apply to cases in which the right to hold or dispose of lands in the United States is secured by existing treaties to citizens or subjects of foreign countries, which rights, so far as they may exist by force of any such treaty, shall continue to exist so long as such treaties are in force, and no longer.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf7c3dea-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1887-03-03/ch340/s1"},"text":"Mar. 3, 1887, ch. 340, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/24/476"},"text":"24 Stat. 476","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1897-03-02/ch363"},"text":"Mar. 2, 1897, ch. 363","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/29/618"},"text":"29 Stat. 618","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf7c3deb-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf7c3dec-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcf7c3ded-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s71"},"text":"section 71 of Title 8","children":[],"tail":", Aliens and Nationality."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
