{"tag":"section","attrib":{"id":"idcf6de647-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1408e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1408e"},"text":"§ 1408e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional powers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Powers granted in this Act shall be in addition to and not in derogation of any powers granted by other law to or for the benefit or assistance of any public corporate authority or municipality.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf6de648-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-07-18/ch466"},"text":"July 18, 1950, ch. 466","children":[],"tail":", title III, § 306, "},{"tag":"ref","attrib":{"href":"/us/stat/64/347"},"text":"64 Stat. 347","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf6de649-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf6de64a-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcf6de64b-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, means ","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-07-18/ch466"},"text":"act July 18, 1950, ch. 466","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/344"},"text":"64 Stat. 344","children":[],"tail":", known as the Territorial Enabling Act of 1950, which enacted this subchapter and sections 480 to 480b, 483a, 483b, 721 to 721b, and 910 to 910b of this title, amended sections 481 to 483 and 722 of this title, and enacted provisions set out as notes under sections 480, 481, and 722 of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
