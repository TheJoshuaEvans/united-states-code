{"tag":"section","attrib":{"id":"idcf7c3d9c-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1494"},"text":null,"children":[{"tag":"num","attrib":{"value":"1494"},"text":"§ 1494.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The purposes of sections 1494 to 1494c of this title are to improve enforcement of drug laws and enhance interdiction of illicit drug shipments in the Caribbean and Pacific territories and commonwealths of the United States and the Trust Territory of the Pacific Islands (or successor governments) and to assist public and private sector drug abuse and other substance prevention and treatment programs in United States associated insular areas.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf7c3d9d-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/tV/s5002"},"text":"Pub. L. 99–570, title V, § 5002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-154"},"text":"100 Stat. 3207–154","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tIX/s9308"},"text":"Pub. L. 100–690, title IX, § 9308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4538"},"text":"102 Stat. 4538","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf7c3d9e-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf7c3d9f-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[]