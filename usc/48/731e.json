{"tag":"section","attrib":{"id":"idcf5fb52e-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s731e"},"text":null,"children":[{"tag":"num","attrib":{"value":"731e"},"text":"§ 731e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chapter continued in force and effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"This chapter is continued in force and effect.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf5fb52f-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-07-03/ch446/s4"},"text":"July 3, 1950, ch. 446, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/319"},"text":"64 Stat. 319","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf5fb530-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf5fb531-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcf5fb532-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “the Act entitled ‘An Act to provide a civil government for Porto Rico, and for other purposes,’ approved ","children":[{"tag":"date","attrib":{"date":"1917-03-02"},"text":"March 2, 1917","children":[],"tail":", as amended”, meaning "},{"tag":"ref","attrib":{"href":"/us/act/1917-03-02/ch145"},"text":"act Mar. 2, 1917, ch. 145","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/951"},"text":"39 Stat. 951","children":[],"tail":", as amended, known as the Puerto Rican Federal Relations Act and also popularly known as the Jones Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s731"},"text":"section 731 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcf5fb533-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Puerto Rican Federal Relations Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
