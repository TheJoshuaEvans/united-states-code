{"tag":"section","attrib":{"id":"idcfcafacf-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2200"},"text":null,"children":[{"tag":"num","attrib":{"value":"2200"},"text":"§ 2200.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination on debt","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Nothing in this chapter shall be interpreted to restrict—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcfcafad0-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2200/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of the Puerto Rico Commission for the Comprehensive Audit of the Public Credit to file its reports; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfcafad1-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2200/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the review and consideration of the Puerto Rico Commission’s findings by Puerto Rico’s government or an Oversight Board for Puerto Rico established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s2121"},"text":"section 2121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcfcafad2-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/187/tIV/s413"},"text":"Pub. L. 114–187, title IV, § 413","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-30"},"text":"June 30, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/596"},"text":"130 Stat. 596","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcfcafad3-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editor