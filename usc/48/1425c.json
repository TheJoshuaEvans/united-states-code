{"tag":"section","attrib":{"id":"idcf778253-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1425c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1425c"},"text":"§ 1425c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of loans, conveyances, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Legislature of Guam may by law assist such authority by furnishing, or authorizing the furnishing of, cash donations, loans, conveyances of real and personal property, facilities, and services, and otherwise, and may by law take other action in aid of urban renewal or housing or related activities.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf778254-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/171/s3"},"text":"Pub. L. 88–171, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-11-04"},"text":"Nov. 4, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/304"},"text":"77 Stat. 304","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf778255-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf778256-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcf778257-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Organic Act of Guam which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
