{"tag":"section","attrib":{"id":"idcfcafab2-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2197"},"text":null,"children":[{"tag":"num","attrib":{"value":"2197"},"text":"§ 2197.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2016-06-30"},"text":"June 30, 2016","children":[],"tail":", the Comptroller General shall submit a report to the Committee on Natural Resources of the House of Representatives and the Committee on Energy and Natural Resources of the Senate describing—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcfcafab3-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2197/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conditions which led to the level of debt, which should be analyzed, per capita and based upon overall economic activity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfcafab4-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2197/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how actions of the territorial government improved or impaired the territory’s financial conditions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfcafab5-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2197/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations on non-fiscal actions, or policies that would not imperil America’s homeland and national security, that could be taken by Congress or the Administration to avert future indebtedness of territories, while respecting sovereignty and constitutional parameters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcfcafab6-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/187/tIV/s410"},"text":"Pub. L. 114–187, title IV, § 410","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-30"},"text":"June 30, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/594"},"text":"130 Stat. 594","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
