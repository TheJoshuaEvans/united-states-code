{"tag":"section","attrib":{"id":"idcf72c83a-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1421n"},"text":null,"children":[{"tag":"num","attrib":{"value":"1421n"},"text":"§ 1421n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of Federal copyright laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The laws of the United States relating to copyrights, and to the enforcement of rights arising thereunder, shall have the same force and effect in Guam as in the continental United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf72c83b-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch852/s24"},"text":"Aug. 1, 1956, ch. 852, § 24","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/911"},"text":"70 Stat. 911","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf72c83c-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf72c83d-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcf72c83e-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The laws of the United States relating to copyrights, referred to in text, are classified generally to Title 17, Copyrights.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcf72c83f-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Organic Act of Guam which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
