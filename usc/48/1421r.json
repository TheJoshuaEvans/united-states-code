{"tag":"section","attrib":{"id":"idcf72c85b-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1421r"},"text":null,"children":[{"tag":"num","attrib":{"value":"1421r"},"text":"§ 1421r.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Port of Guam Improvement Enterprise Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcf72c85c-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1421r/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Transportation, acting through the Administrator of the Maritime Administration (in this section referred to as the “Administrator”), may establish a Port of Guam Improvement Enterprise Program (in this section referred to as the “Program”) to provide for the planning, design, and construction of projects for the Port of Guam to improve facilities, relieve port congestion, and provide greater access to port facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf72c85d-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1421r/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorities of the Administrator","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the Program, the Administrator may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcf72c85e-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1421r/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive funds provided for the Program from Federal and non-Federal entities, including private entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcf72c85f-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1421r/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for coordination among appropriate governmental agencies to expedite the review process under the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.) for projects carried out under the Program;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcf72c860-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1421r/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for coordination among appropriate governmental agencies in connection with other reviews and requirements applicable to projects carried out under the Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcf72c861-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1421r/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance to the Port Authority of Guam (and its agents) as needed for projects carried out under the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf72c862-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1421r/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Port of Guam Improvement Enterprise Fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcf72c863-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1421r/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury of the United States a separate account to be known as the “Port of Guam Improvement Enterprise Fund” (in this section referred to as the “Fund”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcf72c864-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1421r/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There shall be deposited into the Fund—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcf72c865-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1421r/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts received by the Administrator from Federal and non-Federal sources under subsection (b)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcf72c866-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1421r/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts transferred to the Administrator under subsection (d); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcf72c867-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1421r/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts appropriated to carry out this section under subsection (f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcf72c868-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1421r/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts in the Fund shall be available to the Administrator to carry out the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcf72c869-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1421r/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not to exceed 3 percent of the amounts appropriated to the Fund for a fiscal year may be used for administrative expenses of the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcf72c86a-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1421r/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts in the Fund shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf72c86b-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1421r/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers of amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts appropriated or otherwise made available for any fiscal year for an intermodal or marine facility comprising a component of the Program shall be transferred to and administered by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf72c86c-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1421r/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to authorize amounts made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t23/s165"},"text":"section 165 of title 23","children":[],"tail":" or any other amounts made available for the construction of highways or amounts otherwise not eligible for making port improvements to be deposited into the Fund."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf72c86d-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1421r/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Fund such sums as may be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcf72c86e-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417/dC/tXXXV/s3512"},"text":"Pub. L. 110–417, div. C, title XXXV, § 3512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4770"},"text":"122 Stat. 4770","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tX/s1075/e/20"},"text":"Pub. L. 111–383, div. A, title X, § 1075(e)(20)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4375"},"text":"124 Stat. 4375","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dA/tI/s1114/b/2/C"},"text":"Pub. L. 112–141, div. A, title I, § 1114(b)(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/468"},"text":"126 Stat. 468","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf72c86f-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf72c870-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcf72c871-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Environmental Policy Act of 1969, referred to in subsec. (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", which is classified generally to chapter 55 (§ 4321 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcf72c872-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Duncan Hunter National Defense Authorization Act for Fiscal Year 2009 and not as part of the Organic Act of Guam which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcf72c873-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" substituted “section 165” for “section 215”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383"},"text":"Pub. L. 111–383","children":[],"tail":" inserted period at end."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcf72c874-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcf72c875-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s3/a"},"text":"section 3(a) of Pub. L. 112–141","children":[],"tail":", set out as an Effective and Termination Dates of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of Title 23","children":[],"tail":", Highways."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
