{"tag":"section","attrib":{"id":"idcf79f3f2-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1469e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1469e"},"text":"§ 1469e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insular government purchases","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Governments of the Commonwealth of Puerto Rico, Guam, American Samoa, the Commonwealth of the Northern Mariana Islands, and the United States Virgin Islands are authorized to make purchases through the General Services Administration.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf79f3f3-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/247/tIII/s302"},"text":"Pub. L. 102–247, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-02-24"},"text":"Feb. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/38"},"text":"106 Stat. 38","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/187/tIV/s406"},"text":"Pub. L. 114–187, title IV, § 406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-30"},"text":"June 30, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/592"},"text":"130 Stat. 592","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf79f3f4-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf79f3f5-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcf79f3f6-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Similar provisions relating to the Virgin Islands, Guam, American Samoa, and the Trust Territory of the Pacific Islands, were classified to sections 1401f, 1423","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":", 1665, and 1682, respectively, of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcf79f3f7-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/187"},"text":"Pub. L. 114–187","children":[],"tail":" amended text generally. Prior to amendment, text read as follows: “The Governments of American Samoa, Guam, the Northern Mariana Islands, the Trust Territory of the Pacific Islands, and the Virgin Islands are authorized to make purchases through the General Services Administration.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idcf79f3f8-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcf79f3f9-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Termination of Trust Territory of the Pacific Islands","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For termination of Trust Territory of the Pacific Islands, see note set out preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1681"},"text":"section 1681 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
