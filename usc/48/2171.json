{"tag":"section","attrib":{"id":"idcfc889d4-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2171"},"text":null,"children":[{"tag":"num","attrib":{"value":"2171"},"text":"§ 2171.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leases","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A lease to a territory or territorial instrumentality shall not be treated as an executory contract or unexpired lease for the purposes of section 365 or 502(b)(6) of title 11 solely by reason of the lease being subject to termination in the event the debtor fails to appropriate rent.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcfc889d5-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/187/tIII/s311"},"text":"Pub. L. 114–187, title III, § 311","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-30"},"text":"June 30, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/583"},"text":"130 Stat. 583","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
