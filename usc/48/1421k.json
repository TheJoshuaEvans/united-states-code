{"tag":"section","attrib":{"id":"idcf72c829-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1421k"},"text":null,"children":[{"tag":"num","attrib":{"value":"1421k"},"text":"§ 1421k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of naval or military reservations; closed port","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing contained in this chapter shall be construed as limiting the authority of the President to designate parts of Guam as naval or military reservations, nor to restrict his authority to treat Guam as a closed port with respect to the vessels and aircraft of foreign nations.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf72c82a-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-08-01/ch512/s33"},"text":"Aug. 1, 1950, ch. 512, § 33","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/393"},"text":"64 Stat. 393","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf72c82b-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcf72c82c-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcf72c82d-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Submerged Lands, Conveyance to Territory","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Conveyance of submerged lands to the government of Guam, see section 1701 et seq. of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
