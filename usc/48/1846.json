{"tag":"section","attrib":{"id":"idcf967c81-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1846"},"text":null,"children":[{"tag":"num","attrib":{"value":"1846"},"text":"§ 1846.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption from assessment and taxation of real property owned by Commonwealth in United States capital","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Real property owned by the Commonwealth of the Northern Mariana Islands in the capital of the United States and used by the Resident Representative thereof in the discharge of his representative duties under the Covenant shall be exempt from assessment and taxation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf967c82-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/219/tII/s208"},"text":"Pub. L. 101–219, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-12"},"text":"Dec. 12, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1875"},"text":"103 Stat. 1875","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf967c83-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf967c84-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcf967c85-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Covenant, referred to in text, is the Covenant to Establish a Commonwealth of the Northern Mariana Islands in Political Union with the United States of America, which is contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/241/s1"},"text":"section 1 of Pub. L. 94–241","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1801"},"text":"section 1801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcf967c86-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1681"},"text":"section 1681 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
