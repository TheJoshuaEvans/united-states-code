{"tag":"section","attrib":{"id":"idcf8a95d8-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1735"},"text":null,"children":[{"tag":"num","attrib":{"value":"1735"},"text":"§ 1735.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation of Office; compensation, allowances, and benefits; privileges and immunities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Until the Rules of the House of Representatives are amended to provide otherwise, the Delegate from American Samoa shall receive the same compensation, allowances, and benefits as a Member of the House of Representatives, and shall be entitled to whatever privileges and immunities that are, or hereinafter may be, granted to the nonvoting Delegate from the Territory of Guam.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf8a95d9-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/556/s5"},"text":"Pub. L. 95–556, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-31"},"text":"Oct. 31, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2078"},"text":"92 Stat. 2078","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/357/tIV/s401"},"text":"Pub. L. 97–357, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-19"},"text":"Oct. 19, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1711"},"text":"96 Stat. 1711","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf8a95da-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf8a95db-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcf8a95dc-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/357"},"text":"Pub. L. 97–357","children":[],"tail":" struck out proviso limiting clerk hire allowance for Delegate from American Samoa to 50 per centum of clerk hire allowance of a Member of House of Representatives."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcf8a95dd-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcf8a95de-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1982 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/357/tIV/s401"},"text":"Pub. L. 97–357, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-19"},"text":"Oct. 19, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1711"},"text":"96 Stat. 1711","children":[],"tail":", provided that the amendment made by section 401 is effective "},{"tag":"date","attrib":{"date":"1983-01-01"},"text":"Jan. 1, 1983","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
