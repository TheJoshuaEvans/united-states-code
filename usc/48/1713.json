{"tag":"section","attrib":{"id":"idcf8a95b1-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1713"},"text":null,"children":[{"tag":"num","attrib":{"value":"1713"},"text":"§ 1713.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications for Office of Delegate","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"To be eligible for the Office of Delegate a candidate must—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcf8a95b2-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1713/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be at least twenty-five years of age on the date of the election,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf8a95b3-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1713/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have been a citizen of the United States for at least seven years prior to the date of the election,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf8a95b4-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1713/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be an inhabitant of the territory from which he is elected, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf8a95b5-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1713/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not be, on the date of the election, a candidate for any other office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcf8a95b6-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/271/s3"},"text":"Pub. L. 92–271, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-04-10"},"text":"Apr. 10, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/119"},"text":"86 Stat. 119","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
