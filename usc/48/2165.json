{"tag":"section","attrib":{"id":"idcfc889a1-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2165"},"text":null,"children":[{"tag":"num","attrib":{"value":"2165"},"text":"§ 2165.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on jurisdiction and powers of court","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Subject to the limitations set forth in subchapters I and II of this chapter, notwithstanding any power of the court, unless the Oversight Board consents or the plan so provides, the court may not, by any stay, order, or decree, in the case or otherwise, interfere with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcfc889a2-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2165/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any of the political or governmental powers of the debtor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc889a3-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2165/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any of the property or revenues of the debtor; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc889a4-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2165/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use or enjoyment by the debtor of any income-producing property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcfc889a5-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/187/tIII/s305"},"text":"Pub. L. 114–187, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-30"},"text":"June 30, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/580"},"text":"130 Stat. 580","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
