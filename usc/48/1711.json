{"tag":"section","attrib":{"id":"idcf8a95a8-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1711"},"text":null,"children":[{"tag":"num","attrib":{"value":"1711"},"text":"§ 1711.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegate to House of Representatives from Guam and Virgin Islands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The territory of Guam and the territory of the Virgin Islands each shall be represented in the United States Congress by a nonvoting Delegate to the House of Representatives, elected as hereinafter provided.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf8a95a9-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/271/s1"},"text":"Pub. L. 92–271, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-04-10"},"text":"Apr. 10, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/118"},"text":"86 Stat. 118","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
