{"tag":"section","attrib":{"id":"idcf5fb57d-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s739"},"text":null,"children":[{"tag":"num","attrib":{"value":"739"},"text":"§ 739.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties on foreign imports; books and pamphlets in English language","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The same tariffs, customs, and duties shall be levied, collected, and paid upon all articles imported into Puerto Rico from ports other than those of the United States which are required by law to be collected upon articles imported into the United States from foreign countries. All books and pamphlets printed in the English language shall be admitted into Puerto Rico free of duty when imported from the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf5fb57e-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1900-04-12/ch191/s2"},"text":"Apr. 12, 1900, ch. 191, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/31/77"},"text":"31 Stat. 77","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1909-08-05/ch6/s1"},"text":"Aug. 5, 1909, ch. 6, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/71"},"text":"36 Stat. 71","children":[],"tail":", 74; "},{"tag":"ref","attrib":{"href":"/us/act/1932-05-17/ch190"},"text":"May 17, 1932, ch. 190","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/158"},"text":"47 Stat. 158","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf5fb57f-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf5fb580-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcf5fb581-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Puerto Rican Federal Relations Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcf5fb582-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1909—Act ","children":[{"tag":"date","attrib":{"date":"1909-08-05"},"text":"Aug. 5, 1909","children":[],"tail":", placed coffee in the bean or ground, imported into Puerto Rico, formerly subject to a duty of 5 cents, on the duty free list."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcf5fb583-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idcf5fb584-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Puerto Rico” substituted in text for “Porto Rico” pursuant to act ","children":[{"tag":"date","attrib":{"date":"1932-05-17"},"text":"May 17, 1932","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s731a"},"text":"section 731a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
