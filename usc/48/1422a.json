{"tag":"section","attrib":{"id":"idcf72c880-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1422a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1422a"},"text":"§ 1422a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal of Governor, Lieutenant Governor, or member of legislature; referendum election","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcf72c881-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1422a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The people of Guam shall have the right of initiative and referendum, to be exercised under conditions and procedures specified in the laws of Guam.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf72c882-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1422a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any Governor, Lieutenant Governor, or member of the legislature of Guam may be removed from office by a referendum election in which at least two-thirds of the number of persons voting for such official in the last preceding general election at which such official was elected vote in favor of recall and in which those so voting constitute a majority of all those participating in such referendum election. The referendum election shall be initiated by the legislature of Guam following (a) a two-thirds vote of the members of the legislature in favor of a referendum, or (b) petition for such a referendum to the legislature by registered voters equal in number to at least 50 per centum of the whole number of votes cast at the last general election at which such official was elected preceding the filing of the petition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcf72c883-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-08-01/ch512/s7"},"text":"Aug. 1, 1950, ch. 512, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/387"},"text":"64 Stat. 387","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/497/s2"},"text":"Pub. L. 90–497, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-09-11"},"text":"Sept. 11, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/844"},"text":"82 Stat. 844","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/357/tI/s101"},"text":"Pub. L. 97–357, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-19"},"text":"Oct. 19, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1705"},"text":"96 Stat. 1705","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf72c884-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf72c885-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcf72c886-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1982—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/357"},"text":"Pub. L. 97–357","children":[],"tail":" added subsec. (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/357"},"text":"Pub. L. 97–357","children":[],"tail":" redesignated existing provisions as subsec. (b) and inserted provisions relating to the removal of a Lieutenant Governor or member of the legislature of Guam."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/497"},"text":"Pub. L. 90–497","children":[],"tail":" substituted provisions for the removal of the Governor of Guam through a referendum election for provisions for the appointment, tenure, powers, and duties of the Secretary of Guam."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcf72c887-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcf72c888-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1968 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/497"},"text":"Pub. L. 90–497","children":[],"tail":" necessary to authorize the holding of an election for Governor and Lieutenant Governor on "},{"tag":"date","attrib":{"date":"1970-11-03"},"text":"Nov. 3, 1970","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", and all other amendments unless otherwise provided effective "},{"tag":"date","attrib":{"date":"1971-01-04"},"text":"Jan. 4, 1971","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/497/s13"},"text":"section 13 of Pub. L. 90–497","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1422"},"text":"section 1422 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
