{"tag":"section","attrib":{"id":"idcf778266-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1428"},"text":null,"children":[{"tag":"num","attrib":{"value":"1428"},"text":"§ 1428.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcf778267-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1428/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of promoting economic development in the territory of Guam, there is authorized to be appropriated to the Secretary of the Interior to be paid to the government of Guam for the purposes of this subchapter the sum of $5,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf778268-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1428/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to the appropriations authorized in subsection (a), $1,000,000 is authorized to be appropriated to the Secretary of the Interior to be paid to the government of Guam annually for five fiscal years commencing in fiscal year 1978 to carry out the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcf778269-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/601/s2"},"text":"Pub. L. 90–601, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-17"},"text":"Oct. 17, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1172"},"text":"82 Stat. 1172","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/134/tII/s202"},"text":"Pub. L. 95–134, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-10-15"},"text":"Oct. 15, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1161"},"text":"91 Stat. 1161","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf77826a-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf77826b-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcf77826c-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Organic Act of Guam which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcf77826d-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1977—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/134"},"text":"Pub. L. 95–134","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
