{"tag":"section","attrib":{"id":"idcfa26396-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1908"},"text":null,"children":[{"tag":"num","attrib":{"value":"1908"},"text":"§ 1908.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transitional immigration rules","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcfa26397-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1908/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Citizen of Northern Mariana Islands","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who is a citizen of the Northern Mariana Islands, as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/act/1983-12-08/s24/b"},"text":"section 24(b) of the Act of December 8, 1983","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/97/1465"},"text":"97 Stat. 1465","children":[],"tail":"), is considered a citizen of the United States for purposes of entry into, permanent residence, and employment in the United States and its territories and possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfa26398-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1908/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this section shall cease to be effective when section 301 of the Covenant to Establish a Commonwealth of the Northern Mariana Islands in Political Union With the United States (","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/241"},"text":"Public Law 94–241","children":[],"tail":") becomes effective pursuant to section 1003(c) of the Covenant."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcfa26399-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/239/tI/s108"},"text":"Pub. L. 99–239, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-01-14"},"text":"Jan. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1798"},"text":"99 Stat. 1798","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcfa2639a-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcfa2639b-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcfa2639c-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1983-12-08/s24/b"},"text":"Section 24(b) of the Act of December 8, 1983","children":[],"tail":", referred to in subsec. (a), is "},{"tag":"ref","attrib":{"href":"/us/pl/98/213/s24/b"},"text":"Pub. L. 98–213, § 24(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-12-08"},"text":"Dec. 8, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1465"},"text":"97 Stat. 1465","children":[],"tail":", which was formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1801"},"text":"section 1801 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Covenant to Establish a Commonwealth of the Northern Mariana Islands in Political Union With the United States, referred to in subsec. (b), is contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/241/s1"},"text":"section 1 of Pub. L. 94–241","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1801"},"text":"section 1801 of this title","children":[],"tail":". For "},{"tag":"date","attrib":{"date":"1986-11-04"},"text":"November 4, 1986","children":[],"tail":", as the effective date of section 301 of the Covenant, see Proc. No. 5564, "},{"tag":"date","attrib":{"date":"1986-11-03"},"text":"Nov. 3, 1986","children":[],"tail":", 51 F.R. 40399, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1801"},"text":"section 1801 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/241"},"text":"Public Law 94–241","children":[],"tail":", referred to in subsec. (b), is "},{"tag":"ref","attrib":{"href":"/us/pl/94/241"},"text":"Pub. L. 94–241","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-03-24"},"text":"Mar. 24, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/263"},"text":"90 Stat. 263","children":[],"tail":", as amended, which is classified generally to subchapter I (§ 1801 et seq.) of chapter 17 of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcfa2639d-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1681"},"text":"section 1681 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
