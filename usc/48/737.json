{"tag":"section","attrib":{"id":"idcf5fb56f-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s737"},"text":null,"children":[{"tag":"num","attrib":{"value":"737"},"text":"§ 737.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privileges and immunities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The rights, privileges, and immunities of citizens of the United States shall be respected in Puerto Rico to the same extent as though Puerto Rico were a State of the Union and subject to the provisions of paragraph 1 of section 2 of article IV of the Constitution of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf5fb570-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1917-03-02/ch145/s2"},"text":"Mar. 2, 1917, ch. 145, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/951"},"text":"39 Stat. 951","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1921-02-03/ch34/s1"},"text":"Feb. 3, 1921, ch. 34, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/1096"},"text":"41 Stat. 1096","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1934-03-02/ch37/s1"},"text":"Mar. 2, 1934, ch. 37, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/361"},"text":"48 Stat. 361","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1947-08-05/ch490/s7"},"text":"Aug. 5, 1947, ch. 490, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/772"},"text":"61 Stat. 772","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1950-07-03/ch446/s5/1"},"text":"July 3, 1950, ch. 446, § 5(1)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/320"},"text":"64 Stat. 320","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf5fb571-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf5fb572-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcf5fb573-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1950—Act ","children":[{"tag":"date","attrib":{"date":"1950-07-03"},"text":"July 3, 1950","children":[],"tail":", repealed all of section relating to bill of rights and restrictions except last paragraph."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1947—Act ","children":[{"tag":"date","attrib":{"date":"1947-08-05"},"text":"Aug. 5, 1947","children":[],"tail":", inserted privileges and immunities provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1934—Act ","children":[{"tag":"date","attrib":{"date":"1934-03-02"},"text":"Mar. 2, 1934","children":[],"tail":", repealed so much of former provisions of twentieth paragraph of this section making it unlawful to import, manufacture, sell or give away, or to expose for sale or gift any intoxicating liquors. The penalty formerly contained in such paragraph, related only to violation of such provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcf5fb574-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcf5fb575-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1950 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by act ","children":[{"tag":"date","attrib":{"date":"1950-07-03"},"text":"July 3, 1950","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1952-07-25"},"text":"July 25, 1952","children":[],"tail":", the date the Constitution of Puerto Rico became effective, see Effective Date of Repeal note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s732"},"text":"section 732 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
