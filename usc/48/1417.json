{"tag":"section","attrib":{"id":"idcf6de682-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1417"},"text":null,"children":[{"tag":"num","attrib":{"value":"1417"},"text":"§ 1417.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All acts done, and offenses or crimes committed, on any island, rock, or key mentioned in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1411"},"text":"section 1411 of this title","children":[],"tail":", by persons who may land thereon, or in the waters adjacent thereto, shall be deemed committed on the high seas, on board a merchant ship or vessel belonging to the United States; and shall be punished according to the laws of the United States relating to such ships or vessels and offenses on the high seas, which laws for the purpose aforesaid are extended over such islands, rocks, and keys."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf6de683-3a70-11f1-9e44-df1065572ea0"},"text":"(R.S. § 5576.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf6de684-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf6de685-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcf6de686-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 5576 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1856-08-18/ch164/s6"},"text":"act Aug. 18, 1856, ch. 164, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/11/120"},"text":"11 Stat. 120","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
