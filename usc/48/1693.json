{"tag":"section","attrib":{"id":"idcf882458-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1693"},"text":null,"children":[{"tag":"num","attrib":{"value":"1693"},"text":"§ 1693.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit of government; access to books, records, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Comptroller General of the United States, or any of his duly authorized representatives, shall have access, for the purpose of audit and examination, to any relevant books, documents, papers, or records of the government of the Trust Territory of the Pacific Islands.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf882459-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/257/s6"},"text":"Pub. L. 92–257, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-03-21"},"text":"Mar. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/88"},"text":"86 Stat. 88","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
