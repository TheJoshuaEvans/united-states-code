{"tag":"section","attrib":{"id":"idcf72c845-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1421p"},"text":null,"children":[{"tag":"num","attrib":{"value":"1421p"},"text":"§ 1421p.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are hereby authorized to be appropriated such sums as may be necessary to carry out the purposes of section 1421","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title. Sums appropriated in pursuance of sections 1421"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":" and 1421p of this title may be allocated to such agencies of the Department as are concerned with the administration of the program in Guam."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf72c846-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/421/s2"},"text":"Pub. L. 93–421, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-19"},"text":"Sept. 19, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1154"},"text":"88 Stat. 1154","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf72c847-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf72c848-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcf72c849-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Organic Act of Guam which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
