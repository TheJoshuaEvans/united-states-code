{"tag":"section","attrib":{"id":"idcf85daa9-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1644"},"text":null,"children":[{"tag":"num","attrib":{"value":"1644"},"text":"§ 1644.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Import duties on articles entering United States or possessions from Virgin Islands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All articles coming into the United States from the Virgin Islands shall be subject to or exempt from duty as provided for in section 1301a ","children":[{"tag":"ref","attrib":{"idref":"fn002013"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002013"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 19 and subject to internal-revenue taxes as provided for in "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s7652/b"},"text":"section 7652(b) of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf85daaa-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-22/ch558/s28/d"},"text":"July 22, 1954, ch. 558, § 28(d)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/509"},"text":"68 Stat. 509","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1954-09-01/ch1213"},"text":"Sept. 1, 1954, ch. 1213","children":[],"tail":", title IV, § 402(a), "},{"tag":"ref","attrib":{"href":"/us/stat/68/1140"},"text":"68 Stat. 1140","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf85daab-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf85daac-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcf85daad-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1301a"},"text":"Section 1301a of title 19","children":[],"tail":", referred to in text, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/87/456/tIII/s301/a"},"text":"Pub. L. 87–456, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-05-24"},"text":"May 24, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/75"},"text":"76 Stat. 75","children":[],"tail":". See General Headnote 3(a) under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1202"},"text":"section 1202 of Title 19","children":[],"tail":", Customs Duties."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcf85daae-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section constitutes subsec. (d) of section 28 of act ","children":[{"tag":"date","attrib":{"date":"1954-07-22"},"text":"July 22, 1954","children":[],"tail":". Subsecs. (a) and (c) of section 28 are classified to sections 1642 and 1643, respectively, of this title, and subsec. (b) thereof amended section 3350 of former Title 26, Internal Revenue Code, 1939."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcf85daaf-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “Internal Revenue Code of 1986” for “Internal Revenue Code of 1954”, which for purposes of codification was translated as “title 26” thus requiring no change in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1954—Act ","children":[{"tag":"date","attrib":{"date":"1954-09-01"},"text":"Sept. 1, 1954","children":[],"tail":", subjected the Virgin Islands to the general provision for importations from insular possessions contained in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1301a"},"text":"section 1301a of Title 19","children":[],"tail":", Customs Duties."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcf85dab0-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcf85dab1-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1954 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by act ","children":[{"tag":"date","attrib":{"date":"1954-09-01"},"text":"Sept. 1, 1954","children":[],"tail":", effective on and after the thirtieth day following "},{"tag":"date","attrib":{"date":"1954-09-01"},"text":"Sept. 1, 1954","children":[],"tail":", see section 601 of act "},{"tag":"date","attrib":{"date":"1954-09-01"},"text":"Sept. 1, 1954","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1421e"},"text":"section 1421e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}]