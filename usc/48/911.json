{"tag":"section","attrib":{"id":"idcf64700f-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s911"},"text":null,"children":[{"tag":"num","attrib":{"value":"911"},"text":"§ 911.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Legislative authorization to create authorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Legislature of Puerto Rico may create public corporate authorities to undertake slum clearance and projects to provide dwelling accommodations for families of low income.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf647010-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch703/s1"},"text":"June 25, 1938, ch. 703, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1203"},"text":"52 Stat. 1203","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf647011-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf647012-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcf647013-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Puerto Rican Federal Relations Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
