{"tag":"section","attrib":{"id":"idcfc889cd-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2169"},"text":null,"children":[{"tag":"num","attrib":{"value":"2169"},"text":"§ 2169.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Abstention","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter prevents a district court in the interests of justice from abstaining from hearing a particular proceeding arising in or related to a case under this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcfc889ce-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/187/tIII/s309"},"text":"Pub. L. 114–187, title III, § 309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-30"},"text":"June 30, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/583"},"text":"130 Stat. 583","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
