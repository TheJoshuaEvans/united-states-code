{"tag":"section","attrib":{"id":"idcf646fa4-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s868"},"text":null,"children":[{"tag":"num","attrib":{"value":"868"},"text":"§ 868.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees part of United States revenues","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All fees, fines, costs, and forfeitures as would be deposited to the credit of the United States if collected and paid into a district court of the United States shall become revenues of the United States when collected and paid into the United States District Court for the District of Puerto Rico. The sum of $500 a year from such fees, fines, costs, and forfeitures shall be retained by the clerk and expended for law library purposes under the direction of the judge.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf646fa5-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1917-03-02/ch145/s45"},"text":"Mar. 2, 1917, ch. 145, § 45","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/966"},"text":"39 Stat. 966","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1932-05-17/ch190"},"text":"May 17, 1932, ch. 190","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/158"},"text":"47 Stat. 158","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf646fa6-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf646fa7-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcf646fa8-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“United States District Court for the District of Puerto Rico” substituted in text for “District Court of the United States for Puerto Rico” in view of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s132/a"},"text":"section 132(a) of Title 28","children":[],"tail":", Judiciary and Judicial Procedure, which states that “There shall be in each judicial district a district court which shall be a court of record known as the United States District Court for the district” and "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s119"},"text":"section 119 of Title 28","children":[],"tail":", which states that “Puerto Rico constitutes one judicial district”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcf646fa9-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/act/1901-03-02/ch812/s2"},"text":"act Mar. 2, 1901, ch. 812, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/31/953"},"text":"31 Stat. 953","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcf646faa-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idcf646fab-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Puerto Rico” substituted in text for “Porto Rico” pursuant to act ","children":[{"tag":"date","attrib":{"date":"1932-05-17"},"text":"May 17, 1932","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s731a"},"text":"section 731a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
