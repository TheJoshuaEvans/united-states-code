{"tag":"section","attrib":{"id":"idcf6de67d-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1416"},"text":null,"children":[{"tag":"num","attrib":{"value":"1416"},"text":"§ 1416.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulation of trade","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The introduction of guano from such islands, rocks, or keys shall be regulated as in the coasting trade between different parts of the United States, and the same laws shall govern the vessels concerned therein.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf6de67e-3a70-11f1-9e44-df1065572ea0"},"text":"(R.S. § 5575.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf6de67f-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf6de680-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcf6de681-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 5575 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1856-08-18/ch164/s3"},"text":"act Aug. 18, 1856, ch. 164, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/11/120"},"text":"11 Stat. 120","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
