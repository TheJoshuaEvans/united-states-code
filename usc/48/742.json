{"tag":"section","attrib":{"id":"idcf5fb59e-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s742"},"text":null,"children":[{"tag":"num","attrib":{"value":"742"},"text":"§ 742.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acknowledgment of deeds","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Deeds and other instruments affecting land situate in the District of Columbia, or any other territory or possession of the United States, may be acknowledged in Puerto Rico before any notary public appointed therein by proper authority, or any officer therein who has ex officio the powers of a notary public. The certificate by such notary shall be accompanied by the certificate of the executive secretary of Puerto Rico to the effect that the notary taking such acknowledgment is in fact such notarial officer.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf5fb59f-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1917-03-02/ch145/s54"},"text":"Mar. 2, 1917, ch. 145, § 54","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/968"},"text":"39 Stat. 968","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1932-05-17/ch190"},"text":"May 17, 1932, ch. 190","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/158"},"text":"47 Stat. 158","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf5fb5a0-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf5fb5a1-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcf5fb5a2-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/act/1902-03-22/ch273"},"text":"act Mar. 22, 1902, ch. 273","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/88"},"text":"32 Stat. 88","children":[],"tail":", except that that act required the certificate of the attorney general of Puerto Rico, rather than of the executive secretary of Puerto Rico as required by this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcf61fe93-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idcf61fe94-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Puerto Rico” substituted in text for “Porto Rico” pursuant to act ","children":[{"tag":"date","attrib":{"date":"1932-05-17"},"text":"May 17, 1932","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s731a"},"text":"section 731a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
