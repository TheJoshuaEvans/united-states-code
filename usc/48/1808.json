{"tag":"section","attrib":{"id":"idcf940af8-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1808"},"text":null,"children":[{"tag":"num","attrib":{"value":"1808"},"text":"§ 1808.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcf940af9-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1808/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"At any time on and after ","children":[{"tag":"date","attrib":{"date":"2008-05-08"},"text":"May 8, 2008","children":[],"tail":", the Attorney General, Secretary of Homeland Security, and the Secretary of Labor may establish and maintain offices and other operations in the Commonwealth for the purpose of carrying out duties under—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcf940afa-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1808/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Immigration and Nationality Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"8 U.S.C. 1101","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcf940afb-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1808/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transition program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1806"},"text":"section 1806 of this title","children":[],"tail":", as added by subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcf940afc-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1808/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the maximum extent practicable and consistent with the satisfactory performance of assigned duties under applicable law, the Attorney General, Secretary of Homeland Security, and the Secretary of Labor shall recruit and hire personnel from among qualified United States citizens and national applicants residing in the Commonwealth to serve as staff in carrying out operations described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcf940afd-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/229/tVII/s702/f"},"text":"Pub. L. 110–229, title VII, § 702(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-08"},"text":"May 8, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/863"},"text":"122 Stat. 863","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf940afe-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf940aff-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcf940b00-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Immigration and Nationality Act, referred to in par. (1)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"act June 27, 1952, ch. 