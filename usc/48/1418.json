{"tag":"section","attrib":{"id":"idcf6de687-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1418"},"text":null,"children":[{"tag":"num","attrib":{"value":"1418"},"text":"§ 1418.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment of land and naval forces in protection of rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President is authorized, at his discretion, to employ the land and naval forces of the United States to protect the rights of the discoverer or of his widow, heir, executor, administrator, or assigns.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf6de688-3a70-11f1-9e44-df1065572ea0"},"text":"(R.S. § 5577.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf6de689-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf6de68a-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcf6de68b-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 5577 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1856-08-18/ch164/s5"},"text":"act Aug. 18, 1856, ch. 164, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/11/120"},"text":"11 Stat. 120","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
