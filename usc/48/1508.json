{"tag":"section","attrib":{"id":"idcf7c3e0c-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1508"},"text":null,"children":[{"tag":"num","attrib":{"value":"1508"},"text":"§ 1508.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to District of Columbia","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Aliens shall have the same rights and privileges concerning the acquisition, holding, owning, and disposition of real estate in the District of Columbia as are conferred upon aliens in respect of real estate in the Territories of the United States by this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf7c3e0d-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1905-02-23/ch733/s1"},"text":"Feb. 23, 1905, ch. 733, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/33/733"},"text":"33 Stat. 733","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf7c3e0e-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf7c3e0f-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcf7c3e10-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s78"},"text":"section 78 of Title 8","children":[],"tail":", Aliens and Nationality."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1887-03-03/ch340"},"text":"act Mar. 3, 1887, ch. 340","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/24/476"},"text":"24 Stat. 476","children":[],"tail":", which comprises this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcf7c3e11-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"repeals","id":"idcf7c3e12-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeals","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1905-02-23/ch733/s2"},"text":"Act Feb. 23, 1905, ch. 733, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/33/733"},"text":"33 Stat. 733","children":[],"tail":", repealed all laws and parts of laws so far as they conflict with the provisions of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
