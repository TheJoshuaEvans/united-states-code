{"tag":"section","attrib":{"id":"idcf7c3de5-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1494c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1494c"},"text":"§ 1494c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drug Enforcement Agency personnel assignments","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"To assist in the enforcement of the controlled substances laws of the United States in coordination with law enforcement officers in insular areas in the eastern Caribbean and in the central and western Pacific, the Administrator of the Drug Enforcement Administration shall assign appropriate personnel and other resources to the Virgin Islands and Guam.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf7c3de6-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/tV/s5005"},"text":"Pub. L. 99–570, title V, § 5005","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tIX/s9310"},"text":"Pub. L. 100–690, title IX, § 9310","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4539"},"text":"102 Stat. 4539","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
