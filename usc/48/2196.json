{"tag":"section","attrib":{"id":"idcfcafa96-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2196"},"text":null,"children":[{"tag":"num","attrib":{"value":"2196"},"text":"§ 2196.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional Task Force on Economic Growth in Puerto Rico","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcfcafa97-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2196/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the legislative branch a Congressional Task Force on Economic Growth in Puerto Rico (hereinafter referred to as the “Task Force”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfcafa98-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2196/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Task Force shall be composed of eight members as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcfcafa99-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2196/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member of the House of Representatives, who shall be appointed by the Speaker of the House of Representatives, in coordination with the Chairman of the Committee on Natural Resources of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfcafa9a-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2196/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member of the House of Representatives, who shall be appointed by the Speaker of the House of Representatives, in coordination with the Chairman of the Committee on Ways and Means of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfcafa9b-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2196/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member of the House of Representatives, who shall be appointed by the Minority Leader of the House of Representatives, in coordination with the ranking minority member of the Committee on Natural Resources of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfcafa9c-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2196/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member of the House of Representatives, who shall be appointed by the Minority Leader of the House of Representatives, in coordination with the ranking minority member of the Committee on Ways and Means of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfcafa9d-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2196/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member of the Senate, who shall be appointed by the Majority Leader of the Senate, in coordination with the Chairman of the Committee on Energy and Natural Resources of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfcafa9e-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2196/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member of the Senate, who shall be appointed by the Majority Leader of the Senate, in coordination with the Chairman of the Committee on Finance of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfcafa9f-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2196/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member of the Senate, who shall be appointed by the Minority Leader of the Senate, in coordination with the ranking minority member of the Committee on Energy and Natural Resources of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfcafaa0-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2196/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member of the Senate, who shall be appointed by the Minority Leader of the Senate, in coordination with the ranking minority member of the Committee on Finance of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfcafaa1-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2196/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline for appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All appointments to the Task Force shall be made not later than 15 days after ","children":[{"tag":"date","attrib":{"date":"2016-06-30"},"text":"June 30, 2016","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfcafaa2-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2196/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chair","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Speaker shall designate one Member to serve as chair of the Task Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfcafaa3-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2196/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any vacancy in the Task Force shall be filled in the same manner as the original appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfcafaa4-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2196/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status update","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Between ","children":[{"tag":"date","attrib":{"date":"2016-09-01"},"text":"September 1, 2016","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"2016-09-15"},"text":"September 15, 2016","children":[],"tail":", the Task Force shall provide a status update to the House and Senate that includes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcfcafaa5-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2196/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information the Task Force has collected; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfcafaa6-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2196/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a discussion on matters the chairman of the Task Force deems urgent for consideration by Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfcafaa7-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2196/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2016-12-31"},"text":"December 31, 2016","children":[],"tail":", the Task Force shall issue a report of its findings to the House and Senate regarding—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcfcafaa8-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2196/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impediments in current Federal law and programs to economic growth in Puerto Rico including equitable access to Federal health care programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfcafaa9-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2196/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommended changes to Federal law and programs that, if adopted, would serve to spur sustainable long-term economic growth, job creation, reduce child poverty, and attract investment in Puerto Rico;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfcafaaa-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2196/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the economic effect of Administrative Order No. 346 of the Department of Health of the Commonwealth of Puerto Rico (relating to natural products, natural supplements, and dietary supplements) or any successor or substantially similar order, rule, or guidance of the Commonwealth of Puerto Rico; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfcafaab-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2196/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" additional information the Task Force deems appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfcafaac-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2196/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consensus views","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the greatest extent practicable, the report issued under subsection (f) ","children":[{"tag":"ref","attrib":{"idref":"fn002057"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002057"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “subsection (g)”."}],"tail":" shall reflect the shared views of all eight Members, except that the report may contain dissenting views."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfcafaad-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2196/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearings and sessions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Task Force may, for the purpose of carrying out this section, hold hearings, sit and act at times and places, take testimony, and receive evidence as the Task Force considers appropriate. If the Task Force holds hearings, at least one such hearing must be held in Puerto Rico.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfcafaae-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2196/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stakeholder participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out its duties, the Task Force shall consult with the Puerto Rico Legislative Assembly, the Puerto Rico Department of Economic Development and Commerce, and the private sector of Puerto Rico.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfcafaaf-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2196/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resources","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Task Force shall carry out its duties by utilizing existing facilities, services, and staff of the House of Representatives and Senate, except that no additional funds are authorized to be appropriated to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfcafab0-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2196/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Task Force shall terminate upon issuing the report required under subsection (f) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcfcafab1-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/187/tIV/s409"},"text":"Pub. L. 114–187, title IV, § 409","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-30"},"text":"June 30, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/593"},"text":"130 Stat. 593","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
