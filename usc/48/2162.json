{"tag":"section","attrib":{"id":"idcfc88984-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2162"},"text":null,"children":[{"tag":"num","attrib":{"value":"2162"},"text":"§ 2162.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Who may be a debtor","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"An entity may be a debtor under this subchapter if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcfc88985-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2162/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the entity is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcfc88986-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2162/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a territory that has requested the establishment of an Oversight Board or has had an Oversight Board established for it by the United States Congress in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s2121"},"text":"section 2121 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfc88987-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2162/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a covered territorial instrumentality of a territory described in paragraph (1)(A);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc88988-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2162/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Oversight Board has issued a certification under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s2146/b"},"text":"section 2146(b) of this title","children":[],"tail":" for such entity; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc88989-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2162/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the entity desires to effect a plan to adjust its debts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcfc8898a-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/187/tIII/s302"},"text":"Pub. L. 114–187, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-30"},"text":"June 30, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/579"},"text":"130 Stat. 579","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
