{"tag":"section","attrib":{"id":"idcf7782a5-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1452"},"text":null,"children":[{"tag":"num","attrib":{"value":"1452"},"text":"§ 1452.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulation of Indians","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nor shall anything in title 23 of the Revised Statutes be construed to affect the authority of the United States to make any regulations respecting the Indians of any Territory, their lands, property, or rights, by treaty, law, or otherwise, in the same manner as might be made if no temporary government existed, or is hereafter established, in any such Territory. As used herein, the term “Territory” does not include the Virgin Islands, Puerto Rico, American Samoa, Guam, or the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf7782a6-3a70-11f1-9e44-df1065572ea0"},"text":"(R.S. § 1840; ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/213/s15/b"},"text":"Pub. L. 98–213, § 15(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-12-08"},"text":"Dec. 8, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1462"},"text":"97 Stat. 1462","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf7782a7-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf7782a8-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcf7782a9-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Title 23 of the Revised Statutes, referred to in text, was in the original “this Title”, meaning title 23 of the Revised Statutes, consisting of R.S. §§ 1839 to 1976, and which, insofar as classified to the Code, is classified to sections 1451 to 1455, 1457 to 1460a, 1463, 1463a, 1465, 1467 to 1470, 1480, and 1482 to 1485 of this title and to sections 644 to 647, 649, and 655 to 657 of Title 16, Conservation. For complete classification of R.S. §§ 1839 to 1976 to the Code, see Tables.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcf7782aa-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 1840 derived from N.M., ","children":[{"tag":"ref","attrib":{"href":"/us/act/1850-09-09/ch49/s2"},"text":"act Sept. 9, 1850, ch. 49, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/9/447"},"text":"9 Stat. 447","children":[],"tail":". Utah, "},{"tag":"ref","attrib":{"href":"/us/act/1850-09-09/ch51/s1"},"text":"act Sept. 9, 1850, ch. 51, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/9/453"},"text":"9 Stat. 453","children":[],"tail":". Wash., "},{"tag":"ref","attrib":{"href":"/us/act/1853-03-02/ch90/s1"},"text":"act Mar. 2, 1853, ch. 90, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/10/172"},"text":"10 Stat. 172","children":[],"tail":". Colo., "},{"tag":"ref","attrib":{"href":"/us/act/1861-02-28/ch59/s1"},"text":"act Feb. 28, 1861, ch. 59, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/12/172"},"text":"12 Stat. 172","children":[],"tail":". Dak., "},{"tag":"ref","attrib":{"href":"/us/act/1861-03-02/ch86/s1"},"text":"act Mar. 2, 1861, ch. 86, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/12/239"},"text":"12 Stat. 239","children":[],"tail":". Ariz., "},{"tag":"ref","attrib":{"href":"/us/act/1863-02-24/ch56/s1"},"text":"act Feb. 24, 1863, ch. 56, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/12/664"},"text":"12 Stat. 664","children":[],"tail":". Idaho, "},{"tag":"ref","attrib":{"href":"/us/act/1863-03-03/ch117/s1"},"text":"act Mar. 3, 1863, ch. 117, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/12/808"},"text":"12 Stat. 808","children":[],"tail":". Mont., "},{"tag":"ref","attrib":{"href":"/us/act/1864-05-26/ch95/s1"},"text":"act May 26, 1864, ch. 95, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/13/85"},"text":"13 Stat. 85","children":[],"tail":". Wyo., "},{"tag":"ref","attrib":{"href":"/us/act/1868-07-25/ch235/s1"},"text":"act July 25, 1868, ch. 235, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/15/178"},"text":"15 Stat. 178","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcf7782ab-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/213"},"text":"Pub. L. 98–213","children":[],"tail":" inserted provisions excluding from the term “Territory” the Virgin Islands, Puerto Rico, American Samoa, Guam, or the Northern Mariana Islands."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
