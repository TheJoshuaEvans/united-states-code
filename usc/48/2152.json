{"tag":"section","attrib":{"id":"idcfc8896a-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2152"},"text":null,"children":[{"tag":"num","attrib":{"value":"2152"},"text":"§ 2152.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intervention in litigation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcfc8896b-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2152/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intervention","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Oversight Board may intervene in any litigation filed against the territorial government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfc8896c-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2152/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Injunctive relief","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcfc8896d-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2152/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Oversight Board intervenes in a litigation under subsection (a), the Oversight Board may seek injunctive relief, including a stay of litigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc8896e-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2152/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No independent basis for relief","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section does not create an independent basis on which injunctive relief, including a stay of litigation, may be granted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcfc8896f-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/187/tII/s212"},"text":"Pub. L. 114–187, title II, § 212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-30"},"text":"June 30, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/577"},"text":"130 Stat. 577","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
