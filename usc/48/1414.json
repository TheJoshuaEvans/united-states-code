{"tag":"section","attrib":{"id":"idcf6de673-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1414"},"text":null,"children":[{"tag":"num","attrib":{"value":"1414"},"text":"§ 1414.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusive privileges of discoverer","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The discoverer, or his assigns, being citizens of the United States, may be allowed, at the pleasure of Congress, the exclusive right of occupying such island, rocks, or keys, for the purpose of obtaining guano, and of selling and delivering the same to citizens of the United States, to be used therein, and may be allowed to charge and receive for every ton thereof delivered alongside a vessel, in proper tubs, within reach of ship’s tackle, a sum not exceeding $8 per ton for the best quality, or $4 for every ton taken while in its native place of deposit.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf6de674-3a70-11f1-9e44-df1065572ea0"},"text":"(R.S. § 5573.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf6de675-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf6de676-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcf6de677-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 5573 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1856-08-18/ch164/s2"},"text":"act Aug. 18, 1856, ch. 164, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/11/119"},"text":"11 Stat. 119","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
