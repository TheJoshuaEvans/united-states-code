{"tag":"section","attrib":{"id":"idcfbca1f9-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1932"},"text":null,"children":[{"tag":"num","attrib":{"value":"1932"},"text":"§ 1932.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of Compact of Free Association to Palau","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcfbca1fa-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1932/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The interpretation of and United States Policy Regarding the Compact of Free Association set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1904"},"text":"section 1904 of this title","children":[],"tail":" shall apply to the Compact of Free Association with Palau."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfbca1fb-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1932/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1905"},"text":"section 1905 of this title","children":[],"tail":", except for subsection (i), "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1906"},"text":"section 1906 of this title","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1910"},"text":"section 1910 of this title","children":[],"tail":", and section 1911(a) and (d) of this title shall apply to Palau in the same manner and to the same extent as such sections apply to the Marshall Islands."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcfbca1fc-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/658/tI/s102"},"text":"Pub. L. 99–658, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3675"},"text":"100 Stat. 3675","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcfbca1fd-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcfbca1fe-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcfbca1ff-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Compact of Free Association with Palau, referred to in subsec. (a), is the Compact of Free Association between the United States and the Government of Palau, which is contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/658/s201"},"text":"section 201 of Pub. L. 99–658","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1931"},"text":"section 1931 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcfbca200-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1681"},"text":"section 1681 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
