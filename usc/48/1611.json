{"tag":"section","attrib":{"id":"idcf836a2c-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1611"},"text":null,"children":[{"tag":"num","attrib":{"value":"1611"},"text":"§ 1611.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" District Court of Virgin Islands; local courts; jurisdiction; practice and procedure","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcf836a2d-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1611/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" District Court of Virgin Islands; local courts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The judicial power of the Virgin Islands shall be vested in a court of record designated the “District Court of the Virgin Islands” established by Congress, and in such appellate court and lower local courts as may have been or may hereafter be established by local law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf836a2e-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1611/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The legislature of the Virgin Islands may vest in the courts of the Virgin Islands established by local law jurisdiction over all causes in the Virgin Islands over which any court established by the Constitution and laws of the United States does not have exclusive jurisdiction. Such jurisdiction shall be subject to the concurrent jurisdiction conferred on the District Court of the Virgin Islands by section 1612(a) and (c) of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf836a2f-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1611/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Practice and procedure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rules governing the practice and procedure of the courts established by local law and those prescribing the qualifications and duties of the judges and officers thereof, oaths and bonds, and the times and places of holding court shall be governed by local law or the rules promulgated by those courts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcf836a30-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-22/ch558/s21"},"text":"July 22, 1954, ch. 558, § 21","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/506"},"text":"68 Stat. 506","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/454/tVII/s702"},"text":"Pub. L. 98–454, title VII, § 702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-05"},"text":"Oct. 5, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1737"},"text":"98 Stat. 1737","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf836a31-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf836a32-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcf836a33-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/454"},"text":"Pub. L. 98–454","children":[],"tail":" designated existing provisions as subsec. (a), inserted “established by Congress” before “and in such” and substituted “appellate court and lower local courts as may have been or may hereafter be established by local law” for “court or courts of inferior jurisdiction as have been or may hereafter be established by local law”, and added subsecs. (b) and (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcf836a34-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcf836a35-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/454"},"text":"Pub. L. 98–454","children":[],"tail":" effective on ninetieth day following "},{"tag":"date","attrib":{"date":"1984-10-05"},"text":"Oct. 5, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/454/s1005"},"text":"section 1005 of Pub. L. 98–454","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1424"},"text":"section 1424 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
