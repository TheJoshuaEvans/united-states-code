{"tag":"section","attrib":{"id":"idcfc3ceb6-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2004"},"text":null,"children":[{"tag":"num","attrib":{"value":"2004"},"text":"§ 2004.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative matters","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcfc3ceb7-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2004/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior shall provide all necessary administrative support to accomplish the requirements of sections 2002 and 2003 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfc3ceb8-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2004/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to carry out the provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcfc3ceb9-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/239/tIII/s304"},"text":"Pub. L. 99–239, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-01-14"},"text":"Jan. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1837"},"text":"99 Stat. 1837","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcfc3ceba-3a70-11f1-9e44-df1065572ea0"},"text":"\n",