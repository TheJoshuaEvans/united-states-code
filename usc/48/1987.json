{"tag":"section","attrib":{"id":"idcfc15cb8-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987"},"text":null,"children":[{"tag":"num","attrib":{"value":"1987"},"text":"§ 1987.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oversight provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcfc15cb9-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorities and duties of the Comptroller General of the United States","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcfc15cba-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Comptroller General of the United States (including any duly authorized representative of the Comptroller General of the United States) shall have the authorities necessary to carry out the responsibilities of the Comptroller General of the United States under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcfc15cbb-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 2023 Amended U.S.-FSM Compact and related subsidiary agreements, including the authorities and privileges described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1921a/b"},"text":"section 1921a(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfc15cbc-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 2023 Amended U.S.-RMI Compact and related subsidiary agreements, including the authorities and privileges described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1921b/k"},"text":"section 1921b(k) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfc15cbd-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 2023 U.S.-Palau Compact Review Agreement, related subsidiary agreements, and the authorities described in appendix D of the “Agreement between the Government of the United States of America and the Government of the Republic of Palau Following the Compact of Free Association Section 432 Review” signed by the United States and the Republic of Palau on ","children":[{"tag":"date","attrib":{"date":"2010-09-03"},"text":"September 3, 2010","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc15cbe-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2024-03-09"},"text":"March 9, 2024","children":[],"tail":", and every 4 years thereafter, the Comptroller General of the United States shall submit to the appropriate committees of Congress a report with respect to the Freely Associated States, including addressing—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcfc15cbf-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the topics described in subparagraphs (A) through (E) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1921c/h/1"},"text":"section 1921c(h)(1) of this title","children":[],"tail":", except that for purposes of a report submitted under this paragraph, the report shall address those topics with respect to each of the Freely Associated States; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfc15cc0-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of administrative oversight by the United States of the Freely Associated States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfc15cc1-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary of the Interior oversight authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Interior shall have the authority necessary to fulfill the responsibilities for monitoring and managing the funds appropriated to the Compact of Free Association account of the Department of the Interior by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1990/a"},"text":"section 1990(a) of this title","children":[],"tail":" to carry out—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcfc15cc2-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 2023 Amended U.S.-FSM Compact;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc15cc3-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 2023 Amended U.S.-RMI Compact;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc15cc4-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 2023 U.S.-Palau Compact Review Agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc15cc5-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsidiary agreements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfc15cc6-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Postmaster General oversight authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Postmaster General shall have the authority necessary to fulfill the responsibilities for monitoring and managing the funds appropriated to the United States Postal Service under paragraph (1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1990/b"},"text":"section 1990(b) of this title","children":[],"tail":" and deposited in the Postal Service Fund under paragraph (2)(A) of that section to carry out—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcfc15cc7-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 221(a)(2) of the 2023 Amended U.S.-FSM Compact;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc15cc8-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 221(a)(2) of the 2023 Amended U.S.-RMI Compact;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc15cc9-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 221(a)(2) of the U.S.-Palau Compact; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc15cca-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Article 6(a) of the 2023 U.S.-Palau Compact Review Agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfc15ccb-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency Group on Freely Associated States","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcfc15ccc-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President, in consultation with the Secretary of State, the Secretary of the Interior, and the Secretary of Defense, shall establish an Interagency Group on Freely Associated States (referred to in this subsection as the “Interagency Group”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc15ccd-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the Interagency Group are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcfc15cce-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to coordinate development and implementation of executive branch policies, programs, services, and other activities in or relating to the Freely Associated States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfc15ccf-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to provide policy guidance, recommendations, and oversight to Federal agencies, departments, and instrumentalities with respect to the implementation of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcfc15cd0-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 2023 Amended U.S.-FSM Compact;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcfc15cd1-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 2023 Amended U.S.-RMI Compact; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcfc15cd2-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/d/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 2023 U.S.-Palau Compact Review Agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc15cd3-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Interagency Group shall consist of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcfc15cd4-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of State, who shall serve as co-chair of the Interagency Group;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfc15cd5-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Interior, who shall serve as co-chair of the Interagency Group;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfc15cd6-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfc15cd7-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Treasury;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfc15cd8-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/d/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the heads of relevant Federal agencies, departments, and instrumentalities carrying out obligations under—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcfc15cd9-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/d/3/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 131 and 132 of the 2003 Amended U.S.-FSM Compact and subsections (a) and (b) of section 221 and section 261 of the 2023 Amended U.S.-FSM Compact;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcfc15cda-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/d/3/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 131 and 132 of the 2003 Amended U.S.-RMI Compact and subsections (a) and (b) of section 221 and section 261 of the 2023 Amended U.S.-RMI Compact;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcfc15cdb-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/d/3/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 131 and 132 and subsections (a) and (b) of section 221 of the U.S.-Palau Compact;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcfc15cdc-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/d/3/E/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Article 6 of the 2023 U.S.-Palau Compact Review Agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcfc15cdd-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/d/3/E/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any applicable subsidiary agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcfc15cde-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/d/3/E/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1988"},"text":"section 1988 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfc15cdf-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/d/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the head of any other Federal agency, department, or instrumentality that the Secretary of State or the Secretary of the Interior may designate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc15ce0-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Secretary of State and Secretary of the Interior","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State (or a senior official designee of the Secretary of State) and the Secretary of the Interior (or a senior official designee of the Secretary of the Interior) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcfc15ce1-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" co-lead and preside at a meeting of the Interagency Group not less frequently than annually;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfc15ce2-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine, in consultation with the Secretary of Defense, the agenda for meetings of the Interagency Group; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfc15ce3-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate and coordinate the work of the Interagency Group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc15ce4-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of the Interagency Group","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Interagency Group shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcfc15ce5-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide advice on the establishment or implementation of policies relating to the Freely Associated States to the President, acting through the Office of Intergovernmental Affairs, in the form of a written report not less frequently than annually;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfc15ce6-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtain information and advice relating to the Freely Associated States from the Presidents, other elected officials, and members of civil society of the Freely Associated States, including through the members of the Interagency Group (including senior official designees of the members) meeting not less frequently than annually with any Presidents of the Freely Associated States who elect to participate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfc15ce7-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/d/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the request of the head of any Federal agency (or a senior official designee of the head of a Federal agency) who is a member of the Interagency Group, promptly review and provide advice on a policy or policy implementation action affecting 1 or more of the Freely Associated States proposed by the Federal agency, department, or instrumentality; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfc15ce8-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/d/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate coordination of relevant policies, programs, initiatives, and activities involving 1 or more of the Freely Associated States, including ensuring coherence and avoiding duplication between programs, initiatives, and activities conducted pursuant to a Compact with a Freely Associated State and non-Compact programs, initiatives, and activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc15ce9-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2024-03-09"},"text":"March 9, 2024","children":[],"tail":", and each year thereafter in which a Compact of Free Association with a Freely Associated State is in effect, the President shall submit to the majority leader and minority leader of the Senate, the Speaker and minority leader of the House of Representatives, and the appropriate committees of Congress a report that describes the activities and recommendations of the Interagency Group during the applicable year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfc15cea-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal agency coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The head of any Federal agency providing programs and services to the Federated States of Micronesia, the Republic of the Marshall Islands, or the Republic of Palau shall coordinate with the Secretary of the Interior and the Secretary of State regarding the provision of the programs and services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfc15ceb-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign loans or debt","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress reaffirms that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcfc15cec-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the foreign loans or debt of the Government of the Federated States of Micronesia, the Government of the Republic of the Marshall Islands, or the Government of the Republic of Palau shall not constitute an obligation of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc15ced-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the full faith and credit of the United States Government shall not be pledged for the payment and performance of any foreign loan or debt referred to in paragraph (1) without specific further authorization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfc15cee-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compact compilation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2024-03-09"},"text":"March 9, 2024","children":[],"tail":", the Secretary of the Interior shall submit a report to the appropriate committees of Congress that includes a compilation of the Compact of Free Association with the Federated State of Micronesia, the Compact of Free Association with the Republic of Palau, and the Compact of Free Association with Republic of the Marshall Islands."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfc15cef-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication; Revision by Office of the Law Revision Counsel","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcfc15cf0-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In publishing this title ","children":[{"tag":"ref","attrib":{"idref":"fn002047"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002047"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" in slip form and in the United States Statutes at Large pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t1/s112"},"text":"section 112 of title 1","children":[],"tail":", the Archivist of the United States shall include after the date of approval at the end an appendix setting forth the text of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcfc15cf1-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 2023 Agreement to Amend the U.S.-FSM Compact; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfc15cf2-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 2023 Agreement to Amend the U.S.-RMI Compact.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc15cf3-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revision by Office of the Law Revision Counsel","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Office of the Law Revision Counsel is directed to revise—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcfc15cf4-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 2003 Amended U.S.-FSM Compact set forth in the note following ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1921"},"text":"section 1921 of title 48","children":[],"tail":" to reflect the amendments to the 2003 Amended U.S.-FSM Compact made by the 2023 Agreement to Amend the U.S.-FSM Compact; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfc15cf5-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1987/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 2003 Amended U.S.-RMI Compact set forth in the note following ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1921"},"text":"section 1921 of title 48","children":[],"tail":" to reflect the amendments to the 2003 Amended U.S.-RMI Compact made by the 2023 Agreement to Amend the U.S.-RMI Compact."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcfc15cf6-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/42/dG/tII/s208"},"text":"Pub. L. 118–42, div. G, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-03-09"},"text":"Mar. 9, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/434"},"text":"138 Stat. 434","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcfc15cf7-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcfc15cf8-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcfc15cf9-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1988"},"text":"Section 1988 of this title","children":[],"tail":", referred to in subsec. (d)(3)(E)(vi), was in the original “section 209”, meaning "},{"tag":"ref","attrib":{"href":"/us/pl/118/42/dG/tII/s209"},"text":"section 209 of title II of div. G of Pub. L. 118–42","children":[],"tail":", which is classified principally to "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1988"},"text":"section 1988 of this title","children":[],"tail":". For complete classification of section 209 to the Code, see Codification note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1988"},"text":"section 1988 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This title, referred to in subsec. (h)(1), is title II of div. G of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/42"},"text":"Pub. L. 118–42","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-03-09"},"text":"Mar. 9, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/419"},"text":"138 Stat. 419","children":[],"tail":", known as the Compact of Free Association Amendments Act of 2024, which is classified principally to this subchapter. For complete classification of title II to the Code, see Short Title of 2024 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1901"},"text":"section 1901 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
