{"tag":"section","attrib":{"id":"idcf7511c5-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1423h"},"text":null,"children":[{"tag":"num","attrib":{"value":"1423h"},"text":"§ 1423h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regular and special sessions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Regular sessions of the legislature shall be held annually, commencing on the second Monday in January (unless the legislature shall by law fix a different date), and shall continue for such term as the legislature may provide. The Governor may call special sessions of the legislature at any time when, in his opinion, the public interest may require it. No legislation shall be considered at any special session other than that specified in the call therefor or in any special message by the Governor to the legislature while in such session. All sessions of the legislature shall be open to the public.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf7511c6-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-08-01/ch512/s18"},"text":"Aug. 1, 1950, ch. 512, § 18","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/388"},"text":"64 Stat. 388","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/497/s6/a"},"text":"Pub. L. 90–497, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-09-11"},"text":"Sept. 11, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/846"},"text":"82 Stat. 846","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf7511c7-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf7511c8-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcf7511c9-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1968—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/497"},"text":"Pub. L. 90–497","children":[],"tail":" removed 60-day limitation on the length of regular sessions and 14-day limitation on the length of special sessions of the legislature."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcf7511ca-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcf7511cb-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1968 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/497/s6/a"},"text":"Pub. L. 90–497, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-09-11"},"text":"Sept. 11, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/846"},"text":"82 Stat. 846","children":[],"tail":", provided that the amendment made by that section is effective on date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/90/497"},"text":"Pub. L. 90–497","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1968-09-11"},"text":"Sept. 11, 1968","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
