{"tag":"section","attrib":{"id":"idcfcafab7-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2198"},"text":null,"children":[{"tag":"num","attrib":{"value":"2198"},"text":"§ 2198.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on territorial debt","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcfcafab8-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2198/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than one year after ","children":[{"tag":"date","attrib":{"date":"2016-06-30"},"text":"June 30, 2016","children":[],"tail":", and thereafter not less than once every two years, the Comptroller General of the United States shall submit to Congress a report on the public debt of each territory, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcfcafab9-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2198/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the historical levels of each territory’s public debt, current amount and composition of each territory’s public debt, and future projections of each territory’s public debt;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfcafaba-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2198/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the historical levels of each territory’s revenue, current amount and composition of each territory’s revenue, and future projections of each territory’s revenue;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfcafabb-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2198/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the drivers and composition of each territory’s public debt;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfcafabc-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2198/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effect of Federal laws, mandates, rules, and regulations on each territory’s public debt; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfcafabd-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2198/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of each territory to repay it’s ","children":[{"tag":"ref","attrib":{"idref":"fn002058"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002058"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “its”."}],"tail":" public debt."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfcafabe-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2198/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Materials","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The government of each territory shall make available to the Comptroller General of the United States all materials necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcfcafabf-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/187/tIV/s411"},"text":"Pub. L. 114–187, title IV, § 411","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-30"},"text":"June 30, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/594"},"text":"130 Stat. 594","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
