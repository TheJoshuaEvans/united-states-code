{"tag":"section","attrib":{"id":"idcf6de68c-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1419"},"text":null,"children":[{"tag":"num","attrib":{"value":"1419"},"text":"§ 1419.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right to abandon islands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter contained shall be construed as obliging the United States to retain possession of the islands, rocks, or keys, after the guano shall have been removed from the same.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf6de68d-3a70-11f1-9e44-df1065572ea0"},"text":"(R.S. § 5578.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf6de68e-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf6de68f-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcf6de690-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 5578 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1856-08-18/ch164/s4"},"text":"act Aug. 18, 1856, ch. 164, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/11/120"},"text":"11 Stat. 120","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
