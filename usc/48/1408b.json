{"tag":"section","attrib":{"id":"idcf6de637-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1408b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1408b"},"text":"§ 1408b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of loans, conveyances, etc., by government and municipalities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The government of the Virgin Islands, through its legislative assembly, may assist such authority with cash donations, loans, conveyances of real and personal property, facilities, and services, and otherwise, and may authorize municipalities and other subdivisions to make cash donations, loans, conveyances of real and personal property to such authority, and to take other action, including but not limited to, the making available or the furnishing of facilities and services, in aid of slum clearance, urban redevelopment, urban renewal, or low-rent housing projects.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf6de638-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-07-18/ch466"},"text":"July 18, 1950, ch. 466","children":[],"tail":", title III, § 303, "},{"tag":"ref","attrib":{"href":"/us/stat/64/347"},"text":"64 Stat. 347","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1955-08-11/ch783"},"text":"Aug. 11, 1955, ch. 783","children":[],"tail":", title I, § 107(5), "},{"tag":"ref","attrib":{"href":"/us/stat/69/638"},"text":"69 Stat. 638","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf6de639-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf6de63a-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcf6de63b-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1955—Act ","children":[{"tag":"date","attrib":{"date":"1955-08-11"},"text":"Aug. 11, 1955","children":[],"tail":", included urban renewal proj­ects."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
