{"tag":"section","attrib":{"id":"idcf940b3b-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1825"},"text":null,"children":[{"tag":"num","attrib":{"value":"1825"},"text":"§ 1825.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"This subchapter shall come into force upon its approval or at the time proclaimed by the President for the Constitution of the Northern Mariana Islands to become effective, whichever is the later date.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf940b3c-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/157/s5"},"text":"Pub. L. 95–157, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-11-08"},"text":"Nov. 8, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1267"},"text":"91 Stat. 1267","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf940b3d-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf940b3e-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcf940b3f-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1694d"},"text":"section 1694d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idcf940b40-3a70-11f1-9e44-df1065572ea0"},"text":null,"childre