{"tag":"section","attrib":{"id":"idcf7056d1-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1421d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1421d"},"text":"§ 1421d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Salaries and allowances of officers and employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The salaries and travel allowances of the Governor, Lieutenant Governor, the heads of the executive departments, other officers and employees of the government of Guam, and the members of the legislature, shall be paid by the government of Guam at rates prescribed by the laws of Guam.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf7056d2-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-08-01/ch512/s26"},"text":"Aug. 1, 1950, ch. 512, § 26","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/391"},"text":"64 Stat. 391","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch852/s21"},"text":"Aug. 1, 1956, ch. 852, § 21","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/911"},"text":"70 Stat. 911","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/100"},"text":"Pub. L. 89–100","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-07-30"},"text":"July 30, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/424"},"text":"79 Stat. 424","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/497/s9"},"text":"Pub. L. 90–497, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-09-11"},"text":"Sept. 11, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/847"},"text":"82 Stat. 847","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf7056d3-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf7056d4-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcf7056d5-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1968—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/497/s9/a"},"text":"Pub. L. 90–497, § 9(a)","children":[],"tail":", repealed subsec. (c) which provided for the payment of transportation expenses by the United States of all officers and employees of the government of Guam if their homes were outside Guam."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/497/s9/b"},"text":"Pub. L. 90–497, § 9(b)","children":[],"tail":", removed subsection designations and substituted provisions that the government of Guam pay the salaries and travel expenses of the Governor, Lieutenant Governor, heads of executive departments, members of the legislature, and government officers and employees at rates prescribed by the laws of Guam for provisions setting the salary for the Governor and Secretary of Guam and allowing for the payment of transportation expenses and salaries of certain officers and employees by the United States."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/100"},"text":"Pub. L. 89–100","children":[],"tail":" substituted provisions empowering the government of Guam to fix and pay legislative salaries and expenses for provisions which specifically fixed a sum of $15 per day to be paid each member for every day the legislature is in session payable out of Congressional appropriations and which required all other expenses to be paid by the government of Guam."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1956—Subsec. (a). Act ","children":[{"tag":"date","attrib":{"date":"1956-08-01"},"text":"Aug. 1, 1956","children":[],"tail":", substituted “the Governor of the Virgin Islands in the Executive Pay Act of 1949, as heretofore or hereafter amended,” for “Governors of Territories and possessions in the Executive Pay Act of 1949, but not to exceed $13,125,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcf7056d6-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcf7056d7-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1968 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/497/s9/a"},"text":"Pub. L. 90–497, § 9(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-09-11"},"text":"Sept. 11, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/847"},"text":"82 Stat. 847","children":[],"tail":", provided that the amendment made by that section is effective on date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/90/497"},"text":"Pub. L. 90–497","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1968-09-11"},"text":"Sept. 11, 1968","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/497/s9/b"},"text":"Pub. L. 90–497, § 9(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-09-11"},"text":"Sept. 11, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/847"},"text":"82 Stat. 847","children":[],"tail":", provided that the amendment made by that section is effective "},{"tag":"date","attrib":{"date":"1971-01-04"},"text":"Jan. 4, 1971","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
