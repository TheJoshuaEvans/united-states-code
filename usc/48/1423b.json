{"tag":"section","attrib":{"id":"idcf7511b2-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1423b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1423b"},"text":"§ 1423b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection and qualification of members; officers; rules and regulations; quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The legislature shall be the judge of the selection and qualification of its own members. It shall choose from its members its own officers, determine its rules and procedure, not inconsistent with this chapter, and keep a journal. The quorum of the legislature shall consist of a simple majority of its members. No bill shall become a law unless it shall have been passed at a meeting, at which a quorum was present, by the affirmative vote of a majority of the members present and voting, which vote shall be by yeas and nays.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf7511b3-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-08-01/ch512/s12"},"text":"Aug. 1, 1950, ch. 512, § 12","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/388"},"text":"64 Stat. 388","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/497/s6/b"},"text":"Pub. L. 90–497, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-09-11"},"text":"Sept. 11, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/846"},"text":"82 Stat. 846","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/291/s3"},"text":"Pub. L. 105–291, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-27"},"text":"Oct. 27, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2785"},"text":"112 Stat. 2785","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf7511b4-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf7511b5-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcf7511b6-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/291"},"text":"Pub. L. 105–291","children":[],"tail":" substituted “a simple majority” for “eleven”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/497"},"text":"Pub. L. 90–497","children":[],"tail":" inserted a quorum requirement, provided that a quorum of the legislature consist of eleven of its members, and made presence of a quorum requisite to passage of a law."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcf7511b7-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcf7511b8-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1968 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/497/s6/b"},"text":"Pub. L. 90–497, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-09-11"},"text":"Sept. 11, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/846"},"text":"82 Stat. 846","children":[],"tail":", provided that the amendment made by that section is effective on date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/90/497"},"text":"Pub. L. 90–497","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1968-09-11"},"text":"Sept. 11, 1968","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
