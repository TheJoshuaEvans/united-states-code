{"tag":"section","attrib":{"id":"idcfc889dc-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2174"},"text":null,"children":[{"tag":"num","attrib":{"value":"2174"},"text":"§ 2174.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confirmation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcfc889dd-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2174/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Objection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A special tax payer may object to confirmation of a plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfc889de-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2174/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confirmation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The court shall confirm the plan if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcfc889df-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2174/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan complies with the provisions of title 11, made applicable to a case under this subchapter by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s2161"},"text":"section 2161 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc889e0-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2174/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan complies with the provisions of this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc889e1-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2174/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the debtor is not prohibited by law from taking any action necessary to carry out the plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc889e2-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2174/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except to the extent that the holder of a particular claim has agreed to a different treatment of such claim, the plan provides that on the effective date of the plan each holder of a claim of a kind specified in 507(a)(2) ","children":[{"tag":"ref","attrib":{"idref":"fn002054"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002054"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be preceded by “section”."}],"tail":" of title 11 will receive on account of such claim cash equal to the allowed amount of such claim;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc889e3-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2174/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any legislative, regulatory, or electoral approval necessary under applicable law in order to carry out any provision of the plan has been obtained, or such provision is expressly conditioned on such approval;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc889e4-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2174/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan is feasible and in the best interests of creditors, which shall require the court to consider whether available remedies under the non-bankruptcy laws and constitution of the territory would result in a greater recovery for the creditors than is provided by such plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc889e5-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2174/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan is consistent with the applicable Fiscal Plan certified by the Oversight Board under subchapter II.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfc889e6-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2174/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confirmation for debtors with a single class of claims","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If all of the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s2174/b"},"text":"section 2174(b) of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s1129/a"},"text":"section 1129(a) of title 11","children":[],"tail":", incorporated into this subchapter by "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s2161"},"text":"section 2161 of this title","children":[],"tail":" other than sections 1129(a)(8) and 1129(a)(10) are met with respect to a plan—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcfc889e7-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2174/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to which all claims are substantially similar under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s2161/e"},"text":"section 2161(e) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc889e8-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2174/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that includes only one class of claims, which claims are impaired claims; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc889e9-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2174/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that was not accepted by such impaired class,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the court shall confirm the plan notwithstanding the requirements of such sections 1129(a)(8) and 1129(a)(10) of title 11 if the plan is fair and equitable and does not discriminate unfairly with respect to such impaired class.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcfc889ea-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/187/tIII/s314"},"text":"Pub. L. 114–187, title III, § 314","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-30"},"text":"June 30, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/583"},"text":"130 Stat. 583","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
