{"tag":"section","attrib":{"id":"idcf8a95cd-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1733"},"text":null,"children":[{"tag":"num","attrib":{"value":"1733"},"text":"§ 1733.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications for Office of Delegate","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"To be eligible for the office of Delegate a candidate shall—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcf8a95ce-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1733/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be at least twenty-five years of age on the date of the election;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf8a95cf-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1733/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owe allegiance to the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf8a95d0-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1733/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be an inhabitant of the Territory of American Samoa; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf8a95d1-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1733/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not be, on the date of the election, a candidate for any other office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcf8a95d2-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/556/s3"},"text":"Pub. L. 95–556, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-31"},"text":"Oct. 31, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2078"},"text":"92 Stat. 2078","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/584/s3"},"text":"Pub. L. 95–584, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-02"},"text":"Nov. 2, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2483"},"text":"92 Stat. 2483","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf8a95d3-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf8a95d4-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcf8a95d5-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/584"},"text":"Pub. L. 95–584","children":[],"tail":" substituted allegiance requirement for provision requiring United States citizenship for at least seven years prior to the date of the election."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
