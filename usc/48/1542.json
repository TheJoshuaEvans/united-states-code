{"tag":"section","attrib":{"id":"idcf7eae30-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1542"},"text":null,"children":[{"tag":"num","attrib":{"value":"1542"},"text":"§ 1542.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voting franchise; discrimination prohibited","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcf7eae31-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1542/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The franchise shall be vested in residents of the Virgin Islands who are citizens of the United States, twenty-one years of age or over. Additional qualifications may be prescribed by the legislature: ","children":[{"tag":"i","attrib":{},"text":"Provided, however","children":[],"tail":", That no property, language, or income qualification shall ever be imposed upon or required of any voter, nor shall any discrimination in qualification be made or based upon difference in race, color, sex, or religious belief."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf7eae32-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1542/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The legislature shall have authority to enact legislation establishing the voting age for residents of the Virgin Islands at an age not lower than eighteen years of age, if a majority of the qualified voters in the Virgin Islands approve in a referendum election held for that purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcf7eae33-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-22/ch558/s4"},"text":"July 22, 1954, ch. 558, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/498"},"text":"68 Stat. 498","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/460"},"text":"Pub. L. 91–460","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-16"},"text":"Oct. 16, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/978"},"text":"84 Stat. 978","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf7eae34-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf7eae35-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcf7eae36-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/460"},"text":"Pub. L. 91–460","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
