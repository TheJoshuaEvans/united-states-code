{"tag":"section","attrib":{"id":"idcf646fe5-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s892"},"text":null,"children":[{"tag":"num","attrib":{"value":"892"},"text":"§ 892.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications of Commissioner; appointment to fill vacancy","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No person shall be eligible to election as Resident Commissioner who is not a bona fide citizen of the United States and who is not more than twenty-five years of age, and who does not read and write the English language. In case of a vacancy in the office of Resident Commissioner by death, resignation, or otherwise, the governor, by and with the advice and consent of the senate, shall appoint a Resident Commissioner to fill the vacancy, who shall serve until the next general election and until his successor is elected and qualified.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf646fe6-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1917-03-02/ch145/s36"},"text":"Mar. 2, 1917, ch. 145, § 36","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/963"},"text":"39 Stat. 963","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf646fe7-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf646fe8-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcf646fe9-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of fifth and sixth sentences of section 36 of act ","children":[{"tag":"date","attrib":{"date":"1917-03-02"},"text":"Mar. 2, 1917","children":[],"tail":". For classification of the remainder of section 36, see Codification note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s891"},"text":"section 891 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcf646fea-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/act/1900-04-12/ch191/s39"},"text":"act Apr. 12, 1900, ch. 191, § 39","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/31/86"},"text":"31 Stat. 86","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
