{"tag":"section","attrib":{"id":"idcf79f488-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1492a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1492a"},"text":"§ 1492a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study of electric rates in the insular areas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcf79f489-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1492a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcf79f48a-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1492a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comprehensive energy plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “comprehensive energy plan” means a comprehensive energy plan prepared and updated under subsections (c) and (e) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1492"},"text":"section 1492 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcf79f48b-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1492a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy action plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “energy action plan” means the plan required by subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcf79f48c-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1492a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Freely Associated States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Freely Associated States” means the Federated States of Micronesia, the Republic of the Marshall Islands, and the Republic of Palau.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcf79f48d-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1492a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insular areas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “insular areas” means American Samoa, the Commonwealth of the Northern Mariana Islands, Puerto Rico, Guam, and the Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcf79f48e-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1492a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior, except that, with respect to Puerto Rico, the term means, the Secretary of Energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcf79f48f-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1492a/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Team","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “team” means the team established by the Secretary under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf79f490-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1492a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2014-12-16"},"text":"December 16, 2014","children":[],"tail":" (except in the case of Puerto Rico, in which case not later than 270 days after "},{"tag":"date","attrib":{"date":"2016-06-30"},"text":"June 30, 2016","children":[],"tail":"), the Secretary shall, within the Empowering Insular Communities activity (except in the case of Puerto Rico), establish a team of technical, policy, and financial experts—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcf79f491-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1492a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop an energy action plan addressing the energy needs of each of the insular areas and Freely Associated States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcf79f492-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1492a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist each of the insular areas and Freely Associated States in implementing such plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf79f493-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1492a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation of regional utility organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In establishing the team, the Secretary shall consider including regional utility organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf7c3d84-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1492a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy action plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In accordance with subsection (b), the energy action plan shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcf7c3d85-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1492a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" recommendations, based on the comprehensive energy plan where applicable, to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcf7c3d86-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1492a/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce reliance and expenditures on fuel shipped to the insular areas and Freely Associated States from ports outside the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcf7c3d87-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1492a/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and utilize domestic fuel energy sources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcf7c3d88-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1492a/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve performance of energy infrastructure and overall energy efficiency;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcf7c3d89-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1492a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a schedule for implementation of such recommendations and identification and prioritization of specific projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcf7c3d8a-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1492a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a financial and engineering plan for implementing and sustaining projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcf7c3d8b-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1492a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" benchmarks for measuring progress toward implementation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf7c3d8c-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1492a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after the date on which the Secretary establishes the team and annually thereafter, the team shall submit to the Secretary a report detailing progress made in fulfilling its charge and in implementing the energy action plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf7c3d8d-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1492a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after the date on which the Secretary receives a report submitted by the team under subsection (e), the Secretary shall submit to the appropriate committees of Congress a summary of the report of the team.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcf7c3d8e-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1492a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of Secretary required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The energy action plan shall not be implemented until the Secretary approves the energy action plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcf7c3d8f-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s9"},"text":"Pub. L. 113–235, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2133"},"text":"128 Stat. 2133","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/187/tV/s505/d"},"text":"Pub. L. 114–187, title V, § 505(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-30"},"text":"June 30, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/602"},"text":"130 Stat. 602","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf7c3d90-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf7c3d91-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcf7c3d92-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Consolidated and Further Continuing Appropriations Act, 2015.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcf7c3d93-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/187/s505/d/1"},"text":"Pub. L. 114–187, § 505(d)(1)","children":[],"tail":", inserted “, except that, with respect to Puerto Rico, the term means, the Secretary of Energy” after “Secretary of the Interior”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/187/s505/d/2"},"text":"Pub. L. 114–187, § 505(d)(2)","children":[],"tail":", in introductory provisions, inserted “(except in the case of Puerto Rico, in which case not later than 270 days after "},{"tag":"date","attrib":{"date":"2016-06-30"},"text":"June 30, 2016","children":[],"tail":")” after “"},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"December 16, 2014","children":[],"tail":"” and “(except in the case of Puerto Rico)” after “Empowering Insular Communities activity”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
