{"tag":"section","attrib":{"id":"idcfc88953-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2149"},"text":null,"children":[{"tag":"num","attrib":{"value":"2149"},"text":"§ 2149.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of Oversight Board","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"An Oversight Board shall terminate upon certification by the Oversight Board that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcfc88954-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2149/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicable territorial government has adequate access to short-term and long-term credit markets at reasonable interest rates to meet the borrowing needs of the territorial government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc88955-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2149/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for at least 4 consecutive fiscal years—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcfc88956-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2149/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the territorial government has developed its Budgets in accordance with modified accrual accounting standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfc88957-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2149/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expenditures made by the territorial government during each fiscal year did not exceed the revenues of the territorial government during that year, as determined in accordance with modified accrual accounting standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcfc88958-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/187/tII/s209"},"text":"Pub. L. 114–187, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-30"},"text":"June 30, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/576"},"text":"130 Stat. 576","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
