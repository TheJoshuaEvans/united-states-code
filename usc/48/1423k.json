{"tag":"section","attrib":{"id":"idcf7511d8-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1423k"},"text":null,"children":[{"tag":"num","attrib":{"value":"1423k"},"text":"§ 1423k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right of petition","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The legislature or any person or group of persons in Guam shall have the unrestricted right of petition. It shall be the duty of all officers of the government to receive and without delay to act upon or forward, as the case may require, any such petition.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf7511d9-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-08-01/ch512/s21"},"text":"Aug. 1, 1950, ch. 512, § 21","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/389"},"text":"64 Stat. 389","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
