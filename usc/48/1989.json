{"tag":"section","attrib":{"id":"idcfc3ce51-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1989"},"text":null,"children":[{"tag":"num","attrib":{"value":"1989"},"text":"§ 1989.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional authorities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcfc3ce52-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1989/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agencies, departments, and instrumentalities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcfc3ce53-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1989/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Appropriations to carry out the obligations, services, and programs described in paragraph (2) shall be made directly to the Federal agencies, departments, and instrumentalities carrying out the obligations, services and programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc3ce54-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1989/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obligations, services, and programs described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The obligations, services, and programs referred to in paragraphs (1) and (3) are the obligations, services, and programs under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcfc3ce55-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1989/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 131 and 132, paragraphs (1) and (3) through (6) of section 221(a), and section 221(b) of the 2023 Amended U.S.-FSM Compact;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfc3ce56-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1989/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 131 and 132, paragraphs (1) and (3) through (6) of section 221(a), and section 221(b) of the 2023 Amended U.S.-RMI Compact;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfc3ce57-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1989/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 131 and 132 and paragraphs (1), (3), and (4) of section 221(a) of the U.S.-Palau Compact;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfc3ce58-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1989/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Article 6 of the 2023 U.S.-Palau Compact Review Agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfc3ce59-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1989/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the Federal Deposit Insurance Corporation, any applicable Federal programs and services agreement between the United States and the Republic of Palau; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfc3ce5a-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1989/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1988"},"text":"section 1988 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfc3ce5b-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1989/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The heads of the Federal agencies, departments, and instrumentalities to which appropriations are made available under paragraph (1) as well as the Federal Deposit Insurance Corporation shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcfc3ce5c-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1989/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have the authority to carry out any activities that are necessary to fulfill the obligations, services, and programs described in paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcfc3ce5d-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1989/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use available funds to carry out the activities under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcfc3ce5e-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1989/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional assistance","children":[],"tail