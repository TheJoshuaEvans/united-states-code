{"tag":"section","attrib":{"id":"idcf7511c3-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1423g"},"text":null,"children":[{"tag":"num","attrib":{"value":"1423g"},"text":"§ 1423g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Vacancies occurring in the legislature shall be filled as the legislature shall provide, except that no person filling a vacancy shall hold office longer than for the remainder of the term for which his predecessor was elected.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf7511c4-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-08-01/ch512/s17"},"text":"Aug. 1, 1950, ch. 512, § 17","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/388"},"text":"64 Stat. 388","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
