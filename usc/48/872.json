{"tag":"section","attrib":{"id":"idcf646fbc-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s872"},"text":null,"children":[{"tag":"num","attrib":{"value":"872"},"text":"§ 872.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Habeas corpus; mandamus; suit to restrain assessment or collection of taxes","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The supreme and district courts of Puerto Rico and the respective judges thereof may grant writs of habeas corpus in all cases in which the same are grantable by the judges of the district courts of the United States, and the district courts may grant writs of mandamus in all proper cases.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"No suit for the purpose of restraining the assessment or collection of any tax imposed by the laws of Puerto Rico shall be maintained in the United States District Court for the District of Puerto Rico.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf646fbd-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1917-03-02/ch145/s48"},"text":"Mar. 2, 1917, ch. 145, § 48","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/967"},"text":"39 Stat. 967","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1927-03-04/ch503/s7"},"text":"Mar. 4, 1927, ch. 503, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/1421"},"text":"44 Stat. 1421","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1932-05-17/ch190"},"text":"May 17, 1932, ch. 190","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/158"},"text":"47 Stat. 158","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf646fbe-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf646fbf-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcf646fc0-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“United States District Court for the District of Puerto Rico” substituted in text for “District Court of the United States for Puerto Rico” in view of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s132/a"},"text":"section 132(a) of Title 28","children":[],"tail":", Judiciary and Judicial Procedure, which states that “There shall be in each judicial district a district court which shall be a court of record known as the United States District Court for the district” and "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s119"},"text":"section 119 of Title 28","children":[],"tail":" which states that “Puerto Rico constitutes one judicial district”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcf646fc1-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1927—Act ","children":[{"tag":"date","attrib":{"date":"1927-03-04"},"text":"Mar. 4, 1927","children":[],"tail":", added second paragraph."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcf646fc2-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idcf646fc3-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Puerto Rico” substituted in text for “Porto Rico” pursuant to act ","children":[{"tag":"date","attrib":{"date":"1932-05-17"},"text":"May 17, 1932","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s731a"},"text":"section 731a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
