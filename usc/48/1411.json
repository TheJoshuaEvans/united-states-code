{"tag":"section","attrib":{"id":"idcf6de664-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s1411"},"text":null,"children":[{"tag":"num","attrib":{"value":"1411"},"text":"§ 1411.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guano districts; claim by United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever any citizen of the United States discovers a deposit of guano on any island, rock, or key, not within the lawful jurisdiction of any other government, and not occupied by the citizens of any other government, and takes peaceable possession thereof, and occupies the same, such island, rock, or key may, at the discretion of the President, be considered as appertaining to the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf6de665-3a70-11f1-9e44-df1065572ea0"},"text":"(R.S. § 5570.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf6de666-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf6de667-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcf6de668-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 5570 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1856-08-18/ch164/s1"},"text":"act Aug. 18, 1856, ch. 164, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/11/119"},"text":"11 Stat. 119","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
