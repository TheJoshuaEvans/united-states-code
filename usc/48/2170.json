{"tag":"section","attrib":{"id":"idcfc889cf-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2170"},"text":null,"children":[{"tag":"num","attrib":{"value":"2170"},"text":"§ 2170.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable rules of procedure","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Federal Rules of Bankruptcy Procedure shall apply to a case under this subchapter and to all civil proceedings arising in or related to cases under this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcfc889d0-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/187/tIII/s310"},"text":"Pub. L. 114–187, title III, § 310","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-30"},"text":"June 30, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/583"},"text":"130 Stat. 583","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcfc889d1-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcfc889d2-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcfc889d3-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Rules of Bankruptcy Procedure, referred to in text, are set out in the Appendix to Title 11, Bankruptcy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
