{"tag":"section","attrib":{"id":"idcf61fe9a-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s744"},"text":null,"children":[{"tag":"num","attrib":{"value":"744"},"text":"§ 744.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coasting trade laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The coasting trade between Puerto Rico and the United States shall be regulated in accordance with the provisions of law applicable to such trade between any two great coasting districts of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcf61fe9b-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1900-04-12/ch191/s9"},"text":"Apr. 12, 1900, ch. 191, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/31/79"},"text":"31 Stat. 79","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1932-05-17/ch190"},"text":"May 17, 1932, ch. 190","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/158"},"text":"47 Stat. 158","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcf61fe9c-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcf61fe9d-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcf61fe9e-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Additional provisions of section 9 of act ","children":[{"tag":"date","attrib":{"date":"1900-04-12"},"text":"Apr. 12, 1900","children":[],"tail":", authorizing the making of regulations for the nationalization of all vessels owned by inhabitants of Puerto Rico on "},{"tag":"date","attrib":{"date":"1889-04-11"},"text":"April 11, 1889","children":[],"tail":", and which continued to be so owned up to the date of that nationalization and for the admission of the same to all the benefits of the coasting trade of the United States, have been omitted."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Puerto Rican Federal Relations Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcf61fe9f-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idcf61fea0-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Puerto Rico” substituted in text for “Porto Rico” pursuant to act ","children":[{"tag":"date","attrib":{"date":"1932-05-17"},"text":"May 17, 1932","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s731a"},"text":"section 731a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
