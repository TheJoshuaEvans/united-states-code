{"tag":"section","attrib":{"id":"idcfcafa30-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2191"},"text":null,"children":[{"tag":"num","attrib":{"value":"2191"},"text":"§ 2191.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules of construction","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Nothing in this chapter is intended, or may be construed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcfcafa31-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2191/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to limit the authority of Congress to exercise legislative authority over the territories pursuant to Article IV, section 3 of the Constitution of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfcafa32-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2191/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to authorize the application of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s2124/f"},"text":"section 2124(f) of this title","children":[],"tail":" (relating to issuance of subpoenas) to judicial officers or employees of territory courts;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfcafa33-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2191/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to alter, amend, or abrogate any provision of the Covenant To Establish a Commonwealth of the Northern Mariana Islands in Political Union With the United States of America (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1801"},"text":"48 U.S.C. 1801","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcfcafa34-3a70-11f1-9e44-df1065572ea0","identifier":"/us/usc/t48/s2191/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to alter, amend, or abrogate the treaties of cession regarding certain islands of American Samoa (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1661"},"text":"48 U.S.C. 1661","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcfcafa35-3a70-11f1-9e44-df1065572ea0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/187/tIV/s401"},"text":"Pub. L. 114–187, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-30"},"text":"June 30, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/585"},"text":"130 Stat. 585","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcfcafa36-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcfcafa37-3a70-11f1-9e44-df1065572ea0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcfcafa38-3a70-11f1-9e44-df1065572ea0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/187"},"text":"Pub. L. 114–187","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-30"},"text":"June 30, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/549"},"text":"130 Stat. 549","children":[],"tail":", known as the Puerto Rico Oversight, Management, and E