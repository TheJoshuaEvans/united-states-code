:[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" inserted “or the Space Force” after “member of the Ready Reserve”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92"},"text":"Pub. L. 114–92","children":[],"tail":" redesignated subsec. (e) as (d) and struck out former subsec. (d) which related to agency contributions for retention in critical specialties and first-time enlistees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s605/b"},"text":"Pub. L. 109–163, § 605(b)","children":[],"tail":", inserted “and First-Time Enlistees” after “Specialties” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s605/a/1"},"text":"Pub. L. 109–163, § 605(a)(1)","children":[],"tail":", designated existing provisions of subpar. (A) as cl. (i), redesignated former subpar. (B) as cl. (ii) of subpar. (A) and substituted “; or” for period at end, and added a new subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s605/a/2"},"text":"Pub. L. 109–163, § 605(a)(2)","children":[],"tail":"–(4), substituted “member under paragraph (1)(A)” for “member under paragraph (1)” in first sentence of par. (2), added par. (3), designated second sentence of par. (2) as (4), and in par. (4) substituted “this subsection” for “this paragraph”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s662"},"text":"Pub. L. 106–65, § 662","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb0636a33-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb0636a34-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment; Implementation","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92"},"text":"Pub. L. 114–92","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2018-01-01"},"text":"Jan. 1, 2018","children":[],"tail":", with certain implementation requirements, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/s635"},"text":"section 635 of Pub. L. 114–92","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8432"},"text":"section 8432 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb0636a35-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section and amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", unless postponed, see "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/s663"},"text":"section 663 of Pub. L. 106–65","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8440e"},"text":"section 8440e of Title 5","children":[],"tail":", Governmen