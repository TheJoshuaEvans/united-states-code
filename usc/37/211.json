{"tag":"section","attrib":{"id":"idb0636a24-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s211"},"text":null,"children":[{"tag":"num","attrib":{"value":"211"},"text":"§ 211.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation in Thrift Savings Plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb0636a25-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s211/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “member” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0636a26-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s211/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the uniformed services serving on active duty; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0636a27-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s211/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the Ready Reserve or the Space Force in any pay status.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0636a28-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s211/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any member may participate in the Thrift Savings Plan in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8440e"},"text":"section 8440e of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0636a29-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s211/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction Regarding Separation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subchapters III and VII of chapter 84 of title 5, each of the following actions shall, in the case of a member participating in the Thrift Savings Plan in accordance with section 8440e of such title, be considered a separation from Government employment:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0636a2a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s211/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Release of the member from active duty, not followed, before the end of the 31-day period beginning on the day following the effective date of the release, by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0636a2b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s211/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a resumption of active duty; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0636a2c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s211/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an appointment to a position covered by chapter 83 or 84 of title 5 or an equivalent retirement system, as identified by the Executive Director (appointed by the Federal Retirement Thrift Investment Board) in regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0636a2d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s211/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transfer of the member to inactive status, or to a retired list pursuant to any provision of title 10.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0636a2e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s211/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment of Amounts Borrowed From Member Account","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a loan is issued to a member under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8433/g"},"text":"section 8433(g) of title 5","children":[],"tail":" from funds in the member’s account in the Thrift Savings Plan, repayment of the loan may be required on the same semi-monthly basis as authorized for contributions to the Thrift Savings Fund on behalf of the member under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s1014/c"},"text":"section 1014(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb0636a2f-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tVI"},"text":"Pub. L. 106–65, div. A, title VI","children":[],"tail":", §§ 661(a)(1)(A), 662, "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/670"},"text":"113 Stat. 670","children":[],"tail":", 672; "},{"tag":"ref","attrib":{"href":"