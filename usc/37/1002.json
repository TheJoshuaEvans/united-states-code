ren":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/86/559/s8"},"text":"Pub. L. 86–559, § 8","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/74/282"},"text":"74 Stat. 282","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Aug. 25, 1961","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/87/164"},"text":"Pub. L. 87–164","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/75/401"},"text":"75 Stat. 401","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “A member of the National Guard, or of a reserve component” are substituted for the enumeration of those reserve categories to conform to other sections of this revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “section 404(a)–(d), and (f), of this title” are substituted for the words “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s253/a"},"text":"section 253(a) of this title","children":[],"tail":"” to reflect the section of this revised title which restates that section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (d) is substituted for section 301(e) of existing title 37.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb0be0cba-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb0be0cbb-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s601/h/1"},"text":"Pub. L. 119–60, § 601(h)(1)","children":[],"tail":", substituted “; members of the National Guard; members of the Space Force” for “and members of National Guard” in section catchline. Catchline text was editorially conformed to the style used in this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s601/h/2"},"text":"Pub. L. 119–60, § 601(h)(2)","children":[],"tail":", substituted “of a reserve component of a uniformed service, or of the Space Force” for “of the National Guard, or of a reserve component of a uniformed service,” and “the consent of the member” for “his consent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s601/h/3"},"text":"Pub. L. 119–60, § 601(h)(3)","children":[],"tail":", inserted “or the Space Force” after “of a reserve component”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" substituted “section 452” for “section 474(a)–(d), and (f),”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s1076/a/9"},"text":"Pub. L. 112–239, § 1076(a)(9)","children":[],"tail":", made technical amendment to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/s631/f/4/A"},"text":"Pub. L. 112–81, § 631(f)(4)(A)","children":[],"tail":". See 2011 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s631/f/4/A"},"text":"Pub. L. 112–81, § 631(f)(4)(A)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/s1076/a/9"},"text":"Pub. L. 112–239, § 1076(a)(9)","children":[],"tail":", substituted “474” for “404”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/25"},"text":"Pub. L. 102–25","children":[],"tail":" struck out “of this section” after “subsection (a)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb0be0cbc-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb0be0cbd-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2013 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1076/a"},"text":"Pub. L. 112–239, div. A, title X, § 1076(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1947"},"text":"126 Stat. 1947","children":[],"tail":", provided that the amendment made by section 1076(a)(9) is effective "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", and as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":" as enacted."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb0be0cbe-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1999 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tVI/s672/c"},"text":"Pub. L. 106–65, div. A