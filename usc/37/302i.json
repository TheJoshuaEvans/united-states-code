{"tag":"section","attrib":{"id":"idb07b3710-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302i"},"text":null,"children":[{"tag":"num","attrib":{"value":"302i"},"text":"§ 302i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special pay: pharmacy officers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb07b3711-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Army, Navy, and Air Force Pharmacy Officers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under regulations prescribed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s303a"},"text":"section 303a of this title","children":[],"tail":", the Secretary of the military department concerned may, subject to subsection (c), pay retention special pay under this section to an officer who—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb07b3712-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302i/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a pharmacy officer in the Medical Service Corps of the Army or Navy or the Biomedical Sciences Corps of the Air Force; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb07b3713-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302i/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is on active duty under a call or order to active duty for a period of not less than one year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb07b3714-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public Health Service Corps","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (c), the Secretary of Health and Human Services may pay retention special pay under this section to an officer who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb07b3715-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302i/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an officer in the Regular or Reserve Corps ","children":[{"tag":"ref","attrib":{"idref":"fn002005"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002005"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Change of Name note below."}],"tail":" of the Public Health Service and is designated as a pharmacy officer; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb07b3716-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302i/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is on active duty under a call or order to active duty for a period of not less than one year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb07b3717-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302i/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Eligibility for Special Pay","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Special pay may not be paid under this section to an officer serving in a pay grade above pay grade O–6.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb07b3718-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302i/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Amount of Special Pay","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of retention special pay paid to an officer under this section may not exceed $15,000 for any 12-month period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb07b3719-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title VI, § 628(a)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–154; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tVI/s615/g"},"text":"Pub. L. 107–314, div. A, title VI, § 615(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2569"},"text":"116 Stat. 2569","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb07b371a-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb07b371b-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb07b371c-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/s615/g/1"},"text":"Pub. L. 107–314, § 615(g)(1)","children":[],"tail":", substituted “retention special pay under this section” for “special pay at the rates specified in subsection (d)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/s615/g/2"},"text":"Pub. L. 107–314, § 615(g)(2)","children":[],"tail":", inserted “"},{"tag":"inline","attrib":{},"text":"on Eligibility for Special Pay","children":[],"tail":"” after “"},{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":"” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/s615/g/3"},"text":"Pub. L. 107–314, § 615(g)(3)","children":[],"tail":", added subsec. (d) and struck out heading and text of former subsec. (d). Text read as follows: “The rate of special pay paid to an officer under subsection (a) or (b) is as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) $3,000 per year, if the officer is undergoing pharmacy internship training or has less than 3 years of creditable service.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) $7,000 per year, if the officer has at least 3 but less than 6 years of creditable service and is not undergoing pharmacy internship training.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) $7,000 per year, if the officer has at least 6 but less than 8 years of creditable service.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) $12,000 per year, if the officer has at least 8 but less than 12 years of creditable service.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(5) $10,000 per year, if the officer has at least 12 but less than 14 years of creditable service.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(6) $9,000 per year, if the officer has at least 14 but less than 18 years of creditable service.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(7) $8,000 per year, if the officer has 18 or more years of creditable service.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb07b371d-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb07b371e-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to Reserve Corps of the Public Health Service deemed to be a reference to the Ready Reserve Corps, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s204/c/3"},"text":"section 204(c)(3) of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb07b371f-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Application of Increase","children":[],"tail":null},{"tag":"p","attrib":{},"text":"In case of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/s615"},"text":"section 615 of Pub. L. 107–314","children":[],"tail":" to increase maximum amount of special pay or bonus that may be paid during any 12-month period, the amended limitation is applicable to 12-month periods beginning after "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"Sept. 30, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/s615/i"},"text":"section 615(i) of Pub. L. 107–314","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s301d"},"text":"section 301d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
