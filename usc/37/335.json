{"tag":"section","attrib":{"id":"idb09575c2-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s335"},"text":null,"children":[{"tag":"num","attrib":{"value":"335"},"text":"§ 335.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special bonus and incentive pay authorities for officers in health professions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb09575c3-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s335/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Health Professions Bonus","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned may pay a health professions bonus under this section to a person, including an officer in the uniformed services, who is a graduate of an accredited school in a health profession and who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb09575c4-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s335/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accepts a commission or appointment as an officer in a regular or reserve component of a uniformed service, or affiliates with a reserve component of a uniformed service, and agrees to serve on active duty in a regular component or in an active status in a reserve component in a health profession;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09575c5-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s335/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accepts a commission or appointment as an officer and whose health profession specialty is designated by the Secretary of Defense as a critically short wartime specialty; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09575c6-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s335/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agrees to remain on active duty or continue serving in an active status in a reserve component in a health profession.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09575c7-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s335/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Health Professions Incentive Pay","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned may pay incentive pay under this section to an officer in a regular or reserve component of a uniformed service who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb09575c8-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s335/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is entitled to basic pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s204"},"text":"section 204 of this title","children":[],"tail":" or compensation under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s206"},"text":"section 206 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09575c9-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s335/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is serving on active duty or in an active status in a designated health profession specialty or skill.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09575ca-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s335/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Board Certification Incentive Pay","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned may pay board certification incentive pay under this section to an officer in a regular or reserve component of a uniformed service who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb09575cb-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s335/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is entitled to basic pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s204"},"text":"section 204 of this title","children":[],"tail":" or compensation under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s206"},"text":"section 206 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09575cc-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s335/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is board certified in a designated health profession specialty or skill; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09575cd-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s335/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is serving on active duty or in an active status in such designated health profession specialty or skill.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09575ce-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s335/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Eligibility Criteria","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned may impose such additional criteria for the receipt of a bonus or incentive pay under this section as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09575cf-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s335/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum Amount and Method of Payment.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb09575d0-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s335/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum amount","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned shall determine the amounts of a bonus or incentive pay to be paid under this section, except that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb09575d1-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s335/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a health professions bonus paid under paragraph (1) of subsection (a) may not exceed $100,000 for each 12-month period of obligated service agreed to under subsection (f);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb09575d2-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s335/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a health professions bonus paid under paragraph (2) of subsection (a) may not exceed $200,000 for each 12-month period of obligated service agreed to under subsection (f);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb09575d3-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s335/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a health professions bonus paid under paragraph (3) of subsection (a) may not exceed $150,000 for each 12-month period of obligated service agreed to under subsection (f);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb09575d4-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s335/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" health professions incentive pay under subsection (b) may be paid monthly and may not exceed, in any 12-month period—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb09575d5-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s335/e/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $200,000 for medical officers and dental officers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb09575d6-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s335/e/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $50,000 for officers in other health professions; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb09575d7-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s335/e/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" board certification incentive pay under subsection (c) may not exceed $15,000 for each 12-month period an officer remains certified in the designated health profession specialty or skill.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09575d8-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s335/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lump sum or installments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A health professions bonus under subsection (a) may be paid in a lump sum or in periodic installments, as determined by the Secretary concerned. Board certification incentive pay under subsection (c) may be paid monthly, in a lump sum at the beginning of the certification period, or in periodic installments during the certification period, as determined by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09575d9-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s335/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fixing bonus amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon acceptance by the Secretary concerned of the written agreement required by subsection (f), the total amount of the health professions bonus to be paid under the agreement shall be fixed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09575da-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s335/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Written Agreement for Bonus","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To receive a bonus under this section, an officer determined to be eligible for the bonus shall enter into a written agreement with the Secretary concerned that specifies—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb09575db-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s335/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the bonus;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09575dc-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s335/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the method of payment of the bonus under subsection (e)(2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09575dd-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s335/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period of obligated service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09575de-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s335/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the service will be performed on active duty or in an active status in a reserve component; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09575df-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s335/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type or conditions of the service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09575e0-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s335/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reserve Component Officers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer in a reserve component authorized incentive pay under subsection (b) or (c) who is not serving on continuous active duty and is entitled to compensation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s204"},"text":"section 204 of this title","children":[],"tail":" or compensation under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s206"},"text":"section 206 of this title","children":[],"tail":" may be paid a monthly amount of incentive pay that is proportionate to the basic pay or compensation received under this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09575e1-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s335/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Other Pay and Allowances.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb09575e2-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s335/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Health professions bonus","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A bonus paid to a person or officer under subsection (a) shall be in addition to any other pay and allowance to which the person or officer is entitled, except that a person or officer may not receive a payment under such subsection and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s332"},"text":"section 332 of this title","children":[],"tail":" for the same period of obligated service."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09575e3-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s335/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Health professions incentive pay","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Incentive pay paid to an officer under subsection (b) shall be in addition to any other pay and allowance to which an officer is entitled, except that an officer may not receive a payment under such subsection and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s353"},"text":"section 353 of this title","children":[],"tail":" for the same skill and period of service."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09575e4-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s335/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Board certification incentive pay","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Incentive pay paid to an officer under subsection (c) shall be in addition to any other pay and allowance to which an officer is entitled, except that an officer may not receive a payment under such subsection and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s353/b"},"text":"section 353(b) of this title","children":[],"tail":" for the same skill and period of service covered by the certification."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09575e5-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s335/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer who receives a bonus or incentive pay under this section and who fails to fulfill the eligibility requirements for the receipt of the bonus or incentive pay or complete the period of service for which the bonus or incentive pay is paid, as specified in the written agreement under subsection (f) in the case of a bonus, shall be subject to the repayment provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s373"},"text":"section 373 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09575e6-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s335/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Health Profession Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “health profession” means the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb09575e7-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s335/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any health profession performed by officers in the Medical Corps of a uniformed service or by officers designated as a medical officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09575e8-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s335/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any health profession performed by officers in the Dental Corps of a uniformed service or by officers designated as a dental officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09575e9-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s335/j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any health profession performed by officers in the Medical Service Corps of a uniformed service or by officers designated as a medical service officer or biomedical sciences officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09575ea-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s335/j/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any health profession performed by officers in the Medical Specialist Corps of a uniformed service or by officers designated as a medical specialist.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09575eb-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s335/j/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any health profession performed by officers of the Nurse Corps of a uniformed service or by officers designated as a nurse.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09575ec-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s335/j/6"},"text":nul