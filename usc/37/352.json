{"tag":"section","attrib":{"id":"idb0957628-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s352"},"text":null,"children":[{"tag":"num","attrib":{"value":"352"},"text":"§ 352.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assignment pay or special duty pay","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb0957629-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s352/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assignment or Special Duty Pay Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned may pay assignment or special duty pay under this section to a member of the uniformed services who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb095762a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s352/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is entitled to basic pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s204"},"text":"section 204 of this title","children":[],"tail":" or compensation under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s206"},"text":"section 206 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb095762b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s352/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performs duties in an assignment, location (including a cold weather location), or unit designated by, and under the conditions of service specified by, the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb095762c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s352/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum Amount and Method of Payment.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb095762d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s352/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lump sum or installments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Assignment or special duty pay under subsection (a) may be paid monthly, in a lump sum, or in periodic installments other than monthly, as determined by the Secretary concerned. If paid monthly, the Secretary concerned may prorate the monthly amount of the assignment or special duty pay for a member who does not satisfy the eligibility requirement for an entire month to reflect the duration of the member’s actual qualifying service during the month.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb095762e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s352/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum monthly amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The maximum monthly amount of assignment or special duty pay may not exceed $5,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb095762f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s352/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum lump sum amount","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of a lump sum payment of assignment or special duty pay payable to a member may not exceed the amount equal to the product of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0957630-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s352/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maximum monthly rate authorized under paragraph (2) at the time the member enters into a written agreement under subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0957631-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s352/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of continuous months in the period for which assignment or special duty pay will be paid pursuant to the agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0957632-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s352/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum installment amount","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of each installment payment of assignment or special duty pay payable to a member on an installment basis may not exceed the amount equal to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0957633-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s352/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the product of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb0957634-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s352/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a monthly rate specified in the written agreement entered into under subsection (c), which monthly rate may not exceed the maximum monthly rate authorized under paragraph (2) at the time the member enters into the agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb0957635-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s352/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of continuous months in the period for which the assignment or special duty pay will be paid; divided by","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0957636-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s352/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of installments over such period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0957637-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s352/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of extension","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a member extends an assignment or performance of duty specified in an agreement with the Secretary concerned under subsection (c), assignment or special duty pay for the period of the extension may be paid on a monthly basis, in a lump sum, or in installments, consistent with this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0957638-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s352/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Written Agreement.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0957639-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s352/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Discretionary for monthly payments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned may require a member to enter into a written agreement with the Secretary in order to qualify for the payment of assignment or special duty pay on a monthly basis. The written agreement shall specify the period for which the assignment or special duty pay will be paid to the member and the monthly rate of the assignment or special duty pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb095763a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s352/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required for lump sum or installment payments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned shall require a member to enter into a written agreement with the Secretary in order to qualify for payment of assignment or special duty pay on a lump sum or installment basis. The written agreement shall specify the period for which the assignment or special duty pay will be paid to the member and the amount of the lump sum or each periodic installment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb095763b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s352/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reserve Component Members Performing Inactive Duty Training","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member of a reserve component entitled to compensation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s206"},"text":"section 206 of this title","children":[],"tail":" who is authorized assignment or special duty pay under this section may be paid an amount of assignment or special duty pay that is proportionate to the compensation received by the member under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s206"},"text":"section 206 of this title","children":[],"tail":" for inactive-duty training."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb097e73c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s352/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Other Pay and Allowances","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Assignment or special duty pay paid to a member under this section is in addition to any other pay and allowances to which the member is entitled.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb097e73d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s352/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member who receives assignment or special duty pay under this section and who fails to fulfill the eligibility requirements under subsection (a) for receipt of such pay shall be subject to the repayment provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s373"},"text":"section 373 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb097e73e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s352/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No agreement may be entered into under this section after ","children":[{"tag":"date","attrib":{"date":"2026-12-31"},"text":"December 31, 2026","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb097e73f-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tVI/s661/a/2"},"text":"Pub. L. 110–181, div. A, title VI, § 661(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/173"},"text":"122 Stat. 173","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tVI"},"text":"Pub. L. 111–84, div. A, title VI","children":[],"tail":", §§ 614(7), 618(c), "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2354"},"text":"123 Stat. 2354","children":[],"tail":", 2356; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tVI/s614/7"},"