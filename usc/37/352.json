/328/dA/tVI/s614/8"},"text":"Pub. L. 114–328, div. A, title VI, § 614(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2159"},"text":"130 Stat. 2159","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tVI/s614/8"},"text":"Pub. L. 115–91, div. A, title VI, § 614(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1422"},"text":"131 Stat. 1422","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVI/s611/d/7"},"text":"Pub. L. 115–232, div. A, title VI, § 611(d)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1797"},"text":"132 Stat. 1797","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tVI/s611/d/7"},"text":"Pub. L. 116–92, div. A, title VI, § 611(d)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1426"},"text":"133 Stat. 1426","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tVI/s611/d/7"},"text":"Pub. L. 116–283, div. A, title VI, § 611(d)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3673"},"text":"134 Stat. 3673","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tVI/s611/d/7"},"text":"Pub. L. 117–81, div. A, title VI, § 611(d)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1769"},"text":"135 Stat. 1769","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tVI"},"text":"Pub. L. 117–263, div. A, title VI","children":[],"tail":", §§ 601(d)(7), 603(a), "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2620"},"text":"136 Stat. 2620","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tVI/s613/d/7"},"text":"Pub. L. 118–31, div. A, title VI, § 613(d)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/292"},"text":"137 Stat. 292","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tVI/s611/d/7"},"text":"Pub. L. 118–159, div. A, title VI, § 611(d)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1932"},"text":"138 Stat. 1932","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tVI"},"text":"Pub. L. 119–60, div. A, title VI","children":[],"tail":", §§ 601(c)(4), 611(d)(7), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/903"},"text":"139 Stat. 903","children":[],"tail":", 906.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb097e740-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb097e741-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb097e742-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s601/c/4"},"text":"Pub. L. 119–60, § 601(c)(4)","children":[],"tail":", struck out “of a regular or reserve component” after “to a member” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s611/d/7"},"text":"Pub. L. 119–60, § 611(d)(7)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2026-12-31"},"text":"December 31, 2026","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2025-12-31"},"text":"December 31, 2025","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2024—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2025-12-31"},"text":"December 31, 2025","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2024-12-31"},"text":"December 31, 2024","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2023—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2024-12-31"},"text":"December 31, 2024","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2023-12-31"},"text":"December 31, 2023","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s603/a"},"text":"Pub. L. 117–263, § 603(a)","children":[],"tail":", inserted “(including a cold weather location)” after “location”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s601/d/7"},"text":"Pub. L. 117–263, § 601(d)(7)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2023-12-31"},"text":"December 31, 