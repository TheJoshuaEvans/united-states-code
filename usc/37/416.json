{"tag":"section","attrib":{"id":"idb0a61824-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s416"},"text":null,"children":[{"tag":"num","attrib":{"value":"416"},"text":"§ 416.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uniform allowance: officers; additional allowances","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb0a61825-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s416/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to the allowance provided by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s415"},"text":"section 415 of this title","children":[],"tail":", a reserve officer of an armed force, an officer of the Army or the Air Force without specification of component, an officer of the Space Force not on sustained duty, or a regular officer of an armed force appointed under section 2106 or 2107 of title 10 is entitled to not more than $200 as reimbursement for additional uniforms and equipment required on that duty, for each time that the officer enters on active duty for a period of more than 90 days."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0a61826-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s416/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subsection (a) does not apply to a tour of active duty if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0a61827-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s416/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the officer, during that tour or within a period of two years before entering on that tour, received, under any law, an initial uniform reimbursement or allowance of more than $400; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0a61828-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s416/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the officer enters on that tour within two years after completing a period of active duty of more than 90 days’ duration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb0a61829-2930-11f1-a69d-9cbca84c43f0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/649"},"text":"Pub. L. 87–649","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/477"},"text":"76 Stat. 477","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/624/s1"},"text":"Pub. L. 88–624, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-10-03"},"text":"Oct. 3, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/1002"},"text":"78 Stat. 1002","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/647/tII/s202/3"},"text":"Pub. L. 88–647, title II, § 202(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-10-13"},"text":"Oct. 13, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/1070"},"text":"78 Stat. 1070","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/718/s63"},"text":"Pub. L. 89–718, § 63","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1123"},"text":"80 Stat. 1123","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s516/13"},"text":"Pub. L. 96–513, title V, § 516(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tai