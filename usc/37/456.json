{"tag":"section","attrib":{"id":"idb0ad442b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s456"},"text":null,"children":[{"tag":"num","attrib":{"value":"456"},"text":"§ 456.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Managed travel program refunds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb0ad442c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s456/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Credit of Refunds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may credit refunds attributable to Department of Defense managed travel programs as a direct result of official travel to such operation and maintenance or research, development, test, and evaluation accounts of the Department as designated by the Secretary that are available for obligation for the fiscal year in which the refund or amount is collected.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0ad442d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s456/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Refunds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Refunds credited under subsection (a) may only be used for official travel or operations and efficiency improvements for improved financial management of official travel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0ad442e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s456/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0ad442f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s456/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Managed travel program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “managed travel program” includes air, rental car, train, bus, dining, lodging, and travel management, but does not include rebates or refunds attributable to the use of the Government travel card, the Government Purchase Card, or Government travel arranged by Government Contracted Travel Management Centers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0ad4430-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s456/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Refund","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “refund” includes miscellaneous receipts credited to the Department identified as a refund, rebate, repayment, or other similar amounts collected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb0ad4431-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tVI/s606/a"},"text":"Pub. L. 116–92, div. A, title VI, § 606(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1424"},"text":"133 Stat. 1424","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
