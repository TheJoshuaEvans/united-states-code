[{"tag":"heading","attrib":{},"text":"Relation to Temporary Increase in Authorized Amount of Hostile Fire and Imminent Danger Special Pay","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tVI/s618/d/1"},"text":"Pub. L. 108–136, div. A, title VI, § 618(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1504"},"text":"117 Stat. 1504","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/136/dA/tVI/s618/d/1"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The amendment made by subsection (a)(2) [amending this section] does not affect the authority to pay an increased amount of hostile fire and imminent danger special pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s310"},"text":"section 310 of title 37","children":[],"tail":", United States Code, pursuant to—"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amendment made by subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/11/s1316"},"text":"section 1316 of Public Law 108–11","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/117/570"},"text":"117 Stat. 570","children":[],"tail":") [amending this section] during the period specified in subsection (c)(1) of such section, as modified by "},{"tag":"ref","attrib":{"href":"/us/pl/108/84/s113"},"text":"section 113 of Public Law 108–84","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/117/1044"},"text":"117 Stat. 1044","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amendment made by section 619 of this Act [amending this section] during the period specified in such amendment.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb0898f72-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Retroactive Payment of Hostile Fire or Imminent Danger Pay for Service in Eastern Mediterranean Sea in Operation Iraqi Freedom","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tVI/s620"},"text":"Pub. L. 108–136, div. A, title VI, § 620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1504"},"text":"117 Stat. 1504","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/136/dA/tVI/s620"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may authorize the payment of hostile fire or imminent danger pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s310/a"},"text":"section 310(a) of title 37","children":[],"tail":", United States Code, to members of the Armed Forces who were assigned to duty, during the period beginning on "},{"tag":"date","attrib":{"date":"2003-03-19"},"text":"March 19, 2003","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2003-04-11"},"text":"April 11, 2003","children":[],"tail":", in the area specified in subsection (b) in connection with Operation Iraqi Freedom at any time during that period."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Specified Area","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The area referred to in subsection (a) is the Mediterranean Sea east of 30 degrees East Longitude (sea area only).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb0898f73-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rates of Pay for Fiscal Year 2004","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/106/tI/s1104"},"text":"Pub. L. 108–106, title I, § 1104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-06"},"text":"Nov. 6, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1214"},"text":"117 Stat. 1214","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/106/tI/s1104"},"text":"“From ","children":[{"tag":"date","attrib":{"date":"2003-10-01"},"text":"October 1, 2003","children":[],"tail":", through "},{"tag":"date","attrib":{"date":"2004-09-30"},"text":"September 30, 2004","children":[],"tail":", (a) the rates of pay authorized by "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s310/a"},"text":"section 310(a) of title 37","children":[],"tail":", United States Code, shall be $225; and (b) the rates of pay authorized by "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s427/a/1"},"text":"section 427(a)(1) of title 37","children":[],"tail":", United States Code, shall be $250.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb0898f74-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Retroactive Authorization for Imminent Danger Pay for Service in Connection With Operation Enduring Freedom","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tVI/s624"},"text":"Pub. L. 107–107, div. A, title VI, § 624","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1143"},"text":"115 Stat. 1143","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/107/dA/tVI/s624"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retroactive Authorization","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may provide for the payment of imminent danger pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s310"},"text":"section 310 of title 37","children":[],"tail":", United States Code, to members of the Armed Forces assigned to duty in the areas specified in subsection (b) in connection with the contingency operation known as Operation Enduring Freedom with respect to periods of duty served in those areas during the period beginning on "},{"tag":"date","attrib":{"date":"2001-09-19"},"text":"September 19, 2001","children":[],"tail":", and ending "},{"tag":"date","attrib":{"date":"2001-10-31"},"text":"October 31, 2001","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Specified Areas","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The areas referred to in subsection (a) are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The land areas of Kyrgyzstan, Oman, the United Arab Emirates, and Uzbekistan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Red Sea, the Gulf of Aden, the Gulf of Oman, and the Arabian Sea (that portion north of 10° north latitude and west of 68° east longitude).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb0898f75-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Temporary Increase in Special Pay in Connection With Persian Gulf Conflict","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/25/tIII/s301"},"text":"Pub. L. 102–25, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-04-06"},"text":"Apr. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/80"},"text":"105 Stat. 80","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/25/tIII/s301"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Increased Rate","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In lieu of the rate of special pay specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s310/a"},"text":"section 310(a) of title 37","children":[],"tail":", United States Code, the rate of special pay payable under that section shall be $150 for each month during the period described in subsection (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Period of Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) shall apply during the period beginning on ","children":[{"tag":"date","attrib":{"date":"1990-08-01"},"text":"August 1, 1990","children":[],"tail":", and ending on the first day of the first month beginning on or after the date 180 days after the end of the Persian Gulf conflict.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb0898f76-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Imminent Danger Pay in Connection With Operation Desert Shield","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXI/s1111/a"},"text":"Pub. L. 101–510, div. A, title XI, § 1111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1635"},"text":"104 Stat. 1635","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/510/dA/tXI/s1111/a"},"text":"“The Secretary of Defense may provide for the payment of imminent danger pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s310"},"text":"section 310 of title 37","children":[],"tail":", United States Code, to members of the Armed Forces assigned to duty in the Persian Gulf area in connection with Operation Desert Shield with respect to periods of duty served after "},{"tag":"date","attrib":{"date":"1990-08-01"},"text":"August 1, 1990","children":[],"tail":", and before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
