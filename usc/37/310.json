{"tag":"section","attrib":{"id":"idb0898f51-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s310"},"text":null,"children":[{"tag":"num","attrib":{"value":"310"},"text":"§ 310.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special pay: duty subject to hostile fire or imminent danger","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb0898f52-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s310/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under regulations prescribed by the Secretary of Defense, a member of a uniformed service may be paid special pay under subsection (b) for any day or portion of a day in which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0898f53-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s310/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the member was entitled to basic pay or compensation under section 204 or 206 of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0898f54-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s310/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the member—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0898f55-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s310/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was subject to hostile fire or explosion of hostile mines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0898f56-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s310/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was on duty in an area in which the member was in imminent danger of being exposed to hostile fire or explosion of hostile mines and in which, during the period the member was on duty in the area, other members of the uniformed services were subject to hostile fire or explosion of hostile mines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0898f57-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s310/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was killed, injured, or wounded by hostile fire, explosion of a hostile mine, or any other hostile action; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0898f58-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s310/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was on duty in a foreign area in which the member was subject to the threat of physical harm or imminent danger on the basis of civil insurrection, civil war, terrorism, or wartime conditions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0898f59-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s310/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Pay Amount","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0898f5a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s310/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), the amount of special pay authorized by subsection (a) for qualifying service during a day or portion of a day shall be the amount equal to 1/30th of the maximum monthly amount of special pay payable to a member as specified in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0898f5b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s310/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a member who is exposed to hostile fire or a hostile mine explosion event in or for a day or portion of a day, the Secretary concerned may, at the election of the Secretary, pay the member special pay under subsection (a) for such service in an amount not to exceed the maximum monthly amount of special pay payable to a member as specified in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0898f5c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s310/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The maximum monthly amount of special pay payable to a member under this subsection for any month is $225.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0898f5d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s310/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continuation During Hospitalization","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0898f5e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s310/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member described in paragraph (2) may be paid special pay under this section for any day (or portion of a day) of not more than three additional months during which the member is hospitalized as described in such paragraph.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0898f5f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s310/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Paragraph (1) applies with respect to a member who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0898f60-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s310/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is injured or wounded under the circumstances described in subsection (a)(2)(C) and is hospitalized for the treatment of the injury or wound; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0898f61-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s310/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while in the line of duty, incurs a wound, injury, or illness in a combat operation or combat zone designated by the Secretary of Defense and is hospitalized outside of the theater of the combat operation or the combat zone for the treatment of the wound, injury, or illness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0898f62-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s310/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations and Administration","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0898f63-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s310/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of an area described in subparagraph (B) or (D) of subsection (a)(2), the Secretary of Defense shall be responsible for designating the period during which duty in the area will qualify members for special pay under this section. The effective date designated for the commencement of such a period may be a date occurring before, on, or after the actual date on which the Secretary makes the designation. If the commencement date for such a period is a date occurring before the date on which the Secretary makes the designation, the payment of special pay under this section for the period between the commencement date and the date on which the Secretary makes the designation shall be subject to the availability of appropriated funds for that purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0898f64-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s310/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member may not be paid more than one special pay under this section for any day. A member may be paid special pay under this section in addition to any other pay and allowances to which he may be entitled.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0898f65-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s310/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determinations of Fact","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any determination of fact that is made in administering this section is conclusive. Such a determination may not be reviewed by any other officer or agency of the United States unless there has been fraud or gross negligence. However, the determination may be changed on the basis of new evidence or for other good cause.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb0898f66-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/132/s9/a/1"},"text":"Pub. L. 88–132, § 9(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-10-02"},"text":"Oct. 2, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/216"},"text":"77 Stat. 216","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/89/132/s4"},"text":"Pub. L. 89–132, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-08-21"},"text":"Aug. 21, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/547"},"text":"79 Stat. 547","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/94/tIX/s905/a"},"text":"Pub. L. 98–94, title IX, § 905(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"1983-09-24"},"text":"Sept. 24, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/636"},"text":"97 Stat. 636","children":[],"tail":", 637; "},{"tag":"ref","attrib":{"href":"/us/pl/99/145/tVI/s638/a"},"text":"Pub. L. 99–145, title VI, § 638(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/649"},"text":"99 Stat. 649","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXIII/s1322/c/6"},"text":"Pub. L. 101–510, div. A, title XIII, § 1322(c)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1672"},"text":"104 Stat. 1672","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tVI"},"text":"Pub. L. 102–190, div. A, title VI","children":[],"tail":", §§ 611(a), 613, "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1376"},"text":"105 Stat. 1376","children":[],"tail":", 1377; "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tVI/s621"},"text":"Pub. L. 105–261, div. A, title VI, § 621","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2042"},"text":"112 Stat. 2042","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/11/tI/s1316/a"},"text":"Pub. L. 108–11, title I, § 1316(a)","children":[],"tail":", (c)(2), "},{"tag":"date","attrib":{"date":"2003-04-16"},"text":"Apr. 16, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/570"},"text":"117 Stat. 570","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tVI"},"text":"Pub. L. 108–136, div. A, title VI","children":[],"tail":", §§ 618(a), (b), (d)(2), 619, "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1503"},"text":"117 Stat. 1503","children":[],"tail":", 1504; "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tVI/s623/a"},"text":"Pub. L. 108–375, div. A, title VI, § 623(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1955"},"text":"118 Stat. 1955","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tVI"},"text":"Pub. L. 109–163, div. A, title VI","children":[],"tail":", §§ 636, 642(b), "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3300"},"text":"119 Stat. 3300","children":[],"tail":", 3306; "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tVI/s618/a"},"text":"Pub. L. 111–84, div. A, title VI, § 618(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2355"},"text":"123 Stat. 2355","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVI/s616/a"},"text":"Pub. L. 112–81, div. A, title VI, § 616(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1451"},"text":"125 Stat. 1451","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1076/h/1"},"text":"Pub. L. 112–239, div. A, title X, § 1076(h)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1955"},"text":"126 Stat. 1955","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb0898f67-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb0898f68-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb0898f69-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":" substituted “section for” for “section for for”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s616/a/1"},"text":"Pub. L. 112–81, § 616(a)(1)","children":[],"tail":", substituted “for any day or portion of a day” for “for any month or portion of a month” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s616/a/2"},"text":"Pub. L. 112–81, § 616(a)(2)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b). Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) The special pay authorized by subsection (a) may not exceed $225 a month.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) Except as provided in subsection (c), if a member does not satisfy the eligibility requirements specified in paragraphs (1) and (2) of subsection (a) for an entire month for receipt of special pay under subsection (a), the Secretary concerned may prorate the payment amount to reflect the duration of the member’s actual qualifying service during the month.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s616/a/3"},"text":"Pub. L. 112–81, § 616(a)(3)","children":[],"tail":", inserted “for any day (or portion of a day) of” before “not more than three additional months”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s616/a/4"},"text":"Pub. L. 112–81, § 616(a)(4)","children":[],"tail":", substituted “any day” for “any month”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s618/a/1"},"text":"Pub. L. 111–84, § 618(a)(1)","children":[],"tail":", struck out “and Special Pay Amount” after “Eligibility” in heading and substituted “under subsection (b) for any month or portion of a month” for “at the rate of $225 for any month” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s618/a/3"},"text":"Pub. L. 111–84, § 618(a)(3)","children":[],"tail":", (4), added subsec. (b) and redesignated former subsec. (b) as (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s618/a/2"},"text":"Pub. L. 111–84, § 618(a)(2)","children":[],"tail":", struck out par. (3) which read as follows: “A member of a reserve component who is eligible for special pay under this section for a month shall receive the full amount authorized in subsection (a) for that month regardless of the number of days during that month on which the member satisfies the eligibility criteria specified in such subsection.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s618/a/3"},"text":"Pub. L. 111–84, § 618(a)(3)","children":[],"tail":", redesignated subsecs. (c) and (d) as (d) and (e), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s642/b"},"text":"Pub. L. 109–163, § 642(b)","children":[],"tail":", designated existing text as par. (1), substituted “A member described in paragraph (2)” for “A member covered by subsection (a)(2)(C) who is hospitalized for the treatment of the injury or wound” and “hospitalized as described in such paragraph” for “so hospitalized”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s636"},"text":"Pub. L. 109–163, § 636","children":[],"tail":", added par. (1) and redesignated former pars. (1) and (2) as (2) and (3), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s623/a/2/A"},"text":"Pub. L. 108–375, § 623(a)(2)(A)","children":[],"tail":", substituted “$225” for “$150”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s623/a/2/B"},"text":"Pub. L. 108–375, § 623(a)(2)(B)","children":[],"tail":", struck out heading and text of subsec. (e). Text read as follows: “For the period beginning on "},{"tag":"date","attrib":{"date":"2003-10-01"},"text":"October 1, 2003","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2005-12-31"},"text":"December 31, 2005","children":[],"tail":", the rate of pay authorized by subsection (a) shall be increased to $225.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s623/a/1"},"text":"Pub. L. 108–375, § 623(a)(1)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2005-12-31"},"text":"December 31, 2005","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2004-12-31"},"text":"December 31, 2004","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s618/a/2"},"text":"Pub. L. 108–136, § 618(a)(2)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a) which read as follows: “Under regulations prescribed by the Secretary of Defense, a member of a uniformed service may be paid special pay at the rate of $150 for any month in which he was entitled to basic pay and in which he—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) was subject to hostile fire or explosion of hostile mines;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) was on duty in an area in which he was in imminent danger of being exposed to hostile fire or explosion of hostile mines and in which, during the period he was on duty in that area, other members of the uniformed services were subject to hostile fire or explosion of hostile mines;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) was killed, injured, or wounded by hostile fire, explosion of a hostile mine, or any other hostile action; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) was on duty in a foreign area in which he was subject to the threat of physical harm or imminent danger on the basis of civil insurrection, civil war, terrorism, or wartime conditions.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"A member covered by clause (3) who is hospitalized for the treatment of his injury or wound may be paid special pay under this section for not more than three additional months during which he is so hospitalized.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/11/s1316/a"},"text":"Pub. L. 108–11, § 1316(a)","children":[],"tail":", (c), as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/s618/d/2"},"text":"Pub. L. 108–136, § 618(d)(2)","children":[],"tail":", temporarily substituted “$225” for “$150” in introductory provisions. See Effective and Termination Dates of 2003 Amendments note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s618/a/2"},"text":"Pub. L. 108–136, § 618(a)(2)","children":[],"tail":", added subsec. (b). Former subsec. (b) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s618/b/1"},"text":"Pub. L. 108–136, § 618(b)(1)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s618/a/1"},"text":"Pub. L. 108–136, § 618(a)(1)","children":[],"tail":", redesignated subsec. (b) as (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s618/b/2"},"text":"Pub. L. 108–136, § 618(b)(2)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s618/a/1"},"text":"Pub. L. 108–136, § 618(a)(1)","children":[],"tail":", redesignated subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s619"},"text":"Pub. L. 108–136, § 619","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261"},"text":"Pub. L. 105–261","children":[],"tail":" designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190"},"text":"Pub. L. 102–190","children":[],"tail":" substituted “Under” for “Except in time of war declared by Congress, and under” and “rate of $150” for “lowest rate for hazardous duty incentive pay specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s301/c/1"},"text":"section 301(c)(1) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510"},"text":"Pub. L. 101–510","children":[],"tail":" struck out subsec. (d) which read as follows: “The Secretary of Defense shall report to Congress by March 1 of each year on the administration of this section during the preceding calendar year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145"},"text":"Pub. L. 99–145","children":[],"tail":" substituted “at the lowest rate for hazardous duty incentive pay spe