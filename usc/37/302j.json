{"tag":"section","attrib":{"id":"idb07b3720-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302j"},"text":null,"children":[{"tag":"num","attrib":{"value":"302j"},"text":"§ 302j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special pay: accession bonus for pharmacy officers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb07b3721-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Accession Bonus Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person who is a graduate of an accredited pharmacy school and who, during the period beginning on ","children":[{"tag":"date","attrib":{"date":"2000-10-30"},"text":"October 30, 2000","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":", executes a written agreement described in subsection (d) to accept a commission as an officer of a uniformed service and remain on active duty for a period of not less than 4 years may, upon acceptance of the agreement by the Secretary concerned, be paid an accession bonus in an amount determined by the Secretary concerned."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb07b3722-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Amount of Bonus.","children":[],"tail":"—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of an accession bonus under subsection (a) may not exceed $30,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb07b3723-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302j/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Eligibility for Bonus","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person may not be paid a bonus under subsection (a) if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb07b3724-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302j/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person, in exchange for an agreement to accept an appointment as a warrant or commissioned officer, received financial assistance from the Department of Defense or the Department of Health and Human Services to pursue a course of study in pharmacy; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb07b3725-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302j/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary concerned determines that the person is not qualified to become and remain licensed as a pharmacist.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb07b3726-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302j/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The agreement referred to in subsection (a) shall provide that, consistent with the needs of the uniformed service concerned, the person executing the agreement shall be assigned to duty, for the period of obligated service covered by the agreement, as a pharmacy officer in the Medical Service Corps of the Army or Navy, a biomedical sciences officer in the Air Force designated as a pharmacy officer, or a pharmacy officer of the Public Health Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb07b3727-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302j/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person who, after signing an agreement under subsection (a), is not commissioned as an officer of the armed forces, does not become and remain certified or licensed as a pharmacist, or does not complete the period of active duty specified in the agreement shall be subject to the repayment provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s303a/e"},"text":"section 303a(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb07b3728-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title VI, § 628(a)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–154; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tX/s1062/c/1"},"text":"Pub. L. 107–314, div. A, title X, § 1062(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2650"},"text":"116 Stat. 2650","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us