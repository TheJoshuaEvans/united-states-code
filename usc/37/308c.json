{"tag":"section","attrib":{"id":"idb084d499-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308c"},"text":null,"children":[{"tag":"num","attrib":{"value":"308c"},"text":"§ 308c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special pay: bonus for affiliation or enlistment in the Selected Reserve","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb084d49a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Affiliation Bonus Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned may pay an affiliation bonus to an enlisted member of an armed force who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb084d49b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has completed fewer than 20 years of military service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb084d49c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" executes a written agreement to serve in the Selected Reserve of the Ready Reserve of an armed force for a period of not less than three years in a skill, unit, or pay grade designated under subsection (b) after being discharged or released from active duty under honorable conditions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb084d49d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation of Skills, Units, and Pay Grades","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned shall designate the skills, units, and pay grades for which an affiliation bonus may be paid under subsection (a). Any skill, unit, or pay grade so designated shall be a skill, unit, or pay grade for which there is a critical need for personnel in the Selected Reserve of the Ready Reserve of an armed force, as determined by the Secretary concerned. The Secretary concerned shall establish other requirements to ensure that members accepted for affiliation meet required performance and discipline standards.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb084d49e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Accession Bonus Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned may pay an accession bonus to a person who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb084d49f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not previously served in the armed forces or has served in the armed forces, but was released from such service before completing the basic training requirements of the armed force of which the person was a member and the service was characterized as either honorable or uncharacterized; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb084d4a0-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" executes a written agreement to serve as an enlisted member in the Selected Reserve of the Ready Reserve of an armed force for a period of not less than three years upon acceptance of the agreement by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb084d4a1-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Amount of Bonus","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of a bonus under subsection (a) or (c) may not exceed $20,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb084d4a2-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment Method","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon acceptance of a written agreement by the Secretary concerned, the total amount of the bonus payable under the agreement becomes fixed. The agreement shall specify whether the bonus shall be paid by the Secretary concerned in a lump sum or in installments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb084d4a3-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308c/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continued Entitlement to Bonus Payments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member entitled to a bonus under this section who is called or ordered to active duty shall be paid, during that period of active duty, any amount of the bonus that becomes payable to the member during that period of active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb084d4a4-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308c/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person who enters into an agreement under subsection (a) or (c) and receives all or part of the bonus under the agreement, but who does not commence to serve in the Selected Reserve or does not satisfactorily participate in the Selected Reserve for the total period of service specified in the agreement, shall be subject to the repayment provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s303a/e"},"text":"section 303a(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb084d4a5-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308c/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall be administered under regulations prescribed by the Secretary of Defense for the armed forces under the jurisdiction of the Secretary of Defense and by the Secretary of Homeland Security for the Coast Guard when it is not operating as a service in the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb084d4a6-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308c/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of Bonus Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No bonus may be paid under this section with respect to any agreement entered into under subsection (a) or (c) after ","children":[{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb084d4a7-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/485/tIV/s404/a"},"text":"Pub. L. 95–485, title IV, § 404(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-20"},"text":"Oct. 20, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1614"},"text":"92 Stat. 1614","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/342/tVIII/s805/b"},"text":"Pub. L. 96–342, title VIII, § 805(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-08"},"text":"Sept. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1095"},"text":"94 Stat. 1095","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/22/s11/b/1"},"text":"Pub. L. 97–22, § 11(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-07-10"},"text":"July 10, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/138"},"text":"95 Stat. 138","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/145/tVI/s642"},"text":"Pub. L. 99–145, title VI, § 642","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/652"},"tex