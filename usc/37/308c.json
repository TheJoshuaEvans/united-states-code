ren":[{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2010-12-31"},"text":"December 31, 2010","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2009-12-31"},"text":"December 31, 2009","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s620"},"text":"Pub. L. 110–181, § 620","children":[],"tail":", inserted before semicolon “or has served in the armed forces, but was released from such service before completing the basic training requirements of the armed force of which the person was a member and the service was characterized as either honorable or uncharacterized”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2009-12-31"},"text":"December 31, 2009","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2008-12-31"},"text":"December 31, 2008","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s611/b"},"text":"Pub. L. 110–181, § 611(b)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2008-12-31"},"text":"December 31, 2008","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2007-12-31"},"text":"December 31, 2007","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s631/a"},"text":"Pub. L. 109–163, § 631(a)","children":[],"tail":", amended section generally. Prior to amendment, section consisted of subsecs. (a) to (f) relating to payment of bonuses of up to $10,000 for enlistment in the Selected Reserve."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s687/b/16"},"text":"Pub. L. 109–163, § 687(b)(16)","children":[],"tail":", added subsec. (g) and struck out heading and text of former subsec. (g). Text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) A person who enters into an agreement under subsection (a) or (c) and receives all or part of the bonus under the agreement, but who does not commence to serve in the Selected Reserve or does not satisfactorily participate in the Selected Reserve for the total period of service specified in the agreement, shall repay to the United States the amount of the bonus so paid, except as otherwise prescribed under paragraph (2).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) The Secretary concerned shall prescribe in regulations whether repayment of an amount otherwise required under paragraph (1) shall be made in whole or in part, the method for computing the amount of such repayment, and any conditions under which an exception to required repayment would apply.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) An obligation to repay the United States imposed under paragraph (1) is for all purposes a debt owed to the United States. A discharge in bankruptcy under title 11 that is entered less than five years after the termination of an agreement entered into under subsection (a) or (c) does not discharge the individual signing the agreement from a debt arising under such agreement or under paragraph (1).”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2007-12-31"},"text":"December 31, 2007","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2006-12-31"},"text":"December 31, 2006","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s618/c/1"},"text":"Pub. L. 108–375, § 618(c)(1)","children":[],"tail":", substituted “$10,000” for “$8,000” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s611/b"},"text":"Pub. L. 108–375, § 611(b)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2005-12-31"},"text":"December 31, 2005","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2004-12-31"},"text":"December 31, 2004","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s618/c/2"},"text":"Pub. L. 108–375, § 618(c)(2)","children":[],"tail":", amended subsec. (f) generally. Prior to amendment, subsec. (f) read as follows: “The total amount of expenditures under this section may not exceed $37,024,000 during fiscal year 1994.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Pub. L. 108–136","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2004-12-31"},"text":"December 31, 2004","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2003-12-31"},"text":"December 31, 2003","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" substituted “of Homeland Security” for “of Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314"},"text":"Pub. L. 107–314","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2003-12-31"},"text":"December 31, 2003","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2002-12-31"},"text":"December 31, 2002","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attr