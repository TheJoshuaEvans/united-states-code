{"tag":"section","attrib":{"id":"idb0ad443a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s463"},"text":null,"children":[{"tag":"num","attrib":{"value":"463"},"text":"§ 463.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs of compliance; electronic processing of travel claims","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb0ad443b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s463/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Programs of Compliance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The administering Secretaries shall provide for compliance with the requirements of this chapter through programs of compliance established and maintained for that purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0ad443c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s463/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The programs of compliance under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0ad443d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s463/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize the provision of benefits under this chapter based on inaccurate claims, unauthorized claims, overstated or inflated claims, and multiple claims for the same benefits through the electronic verification of travel claims on a near-time basis and such other means as the administering Secretaries may establish for purposes of the programs of compliance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0ad443e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s463/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that benefits provided under this chapter do not exceed reasonable or actual and necessary expenses of travel claimed or reasonable allowances based on commercial travel rates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0ad443f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s463/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Electronic Processing of Travel Claims","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0ad4440-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s463/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" By not later than the date that is five years after the date of the enactment of the National Defense Authorization Act for Fiscal Year 2012, any travel claim under this chapter shall be processed electronically.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0ad4441-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s463/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The administering Secretary, or the Secretary’s designee, may waive the requirement in paragraph (1) with respect to a particular claim in the interests of the department concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0ad4442-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s463/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The electronic processing of claims under this subsection shall be subject to the regulations prescribed by the Secretary of Defense under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s464"},"text":"section 464 of this title","children":[],"tail":" which shall apply uniformly to all members of the uniformed services and, to the extent practicable, to all other authorized travelers."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb0ad4443-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVI/s631/b"},"text":"Pub. L. 112–81, div. A, title VI, § 631(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1459"},"text":"125 Stat. 1459","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb0ad4444-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb0ad4445-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb0ad4446-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the National Defense Authorization Act for Fiscal Year 2012, referred to in subsec. (c)(1), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
