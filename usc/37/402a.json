 L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb09ca28a-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (b)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" inserted “or 351” after “section 310”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/s602/1"},"text":"Pub. L. 114–92, § 602(1)","children":[],"tail":", inserted “and paragraph (4)” after “subsection (d)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/s602/2"},"text":"Pub. L. 114–92, § 602(2)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsecs. (f) to (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":" redesignated subsecs. (g) and (h) as (f) and (g), respectively, and struck out former subsec. (f). Prior to amendment, text of subsec. (f) read as follows: “Not later than March 1 of each year after 2001, the Secretary of Defense shall submit to Congress a report specifying the number of members of the armed forces who received, at any time during the preceding year, the supplemental subsistence allowance. In preparing the report, the Secretary of Defense shall consult with the Secretary of Homeland Security, with respect to the Coast Guard.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (a)(2), (3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":" substituted “$1,100” for “$500”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(1), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4002/b/1/A"},"text":"Pub. L. 110–246, § 4002(b)(1)(A)","children":[],"tail":", (2)(T), substituted “supplemental nutrition assistance program” for “food stamp program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4002/b/1/A"},"text":"Pub. L. 110–246, § 4002(b)(1)(A)","children":[],"tail":", (B), (2)(T), substituted “Food and Nutrition Act of 2008” for “Food Stamp Act of 1977” and “supplemental nutrition assistance program” for “food stamp program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4002/b/1/B"},"text":"Pub. L. 110–246, § 4002(b)(1)(B)","children":[],"tail":", (2)(T), substituted “Food and Nutrition Act of 2008” for “Food Stamp Act of 1977”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4002/b/1/A"},"text":"Pub. L. 110–246, § 4002(b)(1)(A)","children":[],"tail":", (B), (2)(T), substituted “supplemental nutrition assistance program” for “food stamp program” and “Food and Nutrition Act of 2008” for “Food Stamp Act of 1977”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s1071/c/6"},"text":"Pub. L. 109–364, § 1071(c)(6)","children":[],"tail":", substituted “title” for “section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s608/b"},"text":"Pub. L. 109–163, § 608(b)","children":[],"t