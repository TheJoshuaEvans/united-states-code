3/2347"},"text":"123 Stat. 2347","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tX/s1063/a"},"text":"Pub. L. 112–81, div. A, title X, § 1063(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1586"},"text":"125 Stat. 1586","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tVI/s602"},"text":"Pub. L. 114–92, div. A, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/836"},"text":"129 Stat. 836","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVI/s618/h/2"},"text":"Pub. L. 114–328, div. A, title VI, § 618(h)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2160"},"text":"130 Stat. 2160","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb09ca286-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb09ca287-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb09ca288-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Richard B. Russell National School Lunch Act, referred to in subsec. (f)(2)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-06-04/ch281"},"text":"act June 4, 1946, ch. 281","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/230