{"tag":"section","attrib":{"id":"idb0767cd3-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302e"},"text":null,"children":[{"tag":"num","attrib":{"value":"302e"},"text":"§ 302e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special pay: nurse anesthetists","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb0767cd4-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Pay Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0767cd5-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer described in subsection (b)(1) who, during the period beginning on ","children":[{"tag":"date","attrib":{"date":"1989-11-29"},"text":"November 29, 1989","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":", executes a written agreement to remain on active duty for a period of one year or more may, upon the acceptance of the agreement by the Secretary concerned, be paid incentive special pay in an amount not to exceed $50,000 for any 12-month period."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0767cd6-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned shall determine the amount of incentive special pay to be paid to an officer under paragraph (1). In determining that amount, the Secretary concerned shall consider the period of obligated service provided for in the agreement under that paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0767cd7-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Officers","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0767cd8-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An officer referred to in subsection (a) is an officer of a uniformed service who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0767cd9-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302e/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an officer of the Nurse Corps of the Army or Navy, an officer of the Air Force designated as a nurse, or an officer designated as a nurse in the commissioned corps of the Public Health Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0767cda-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302e/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a qualified certified registered nurse anesthetist; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0767cdb-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302e/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is on active duty under a call or order to active duty for a period of not less than one year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0767cdc-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense may extend the special pay authorized under subsection (a) to officers of the armed forces who serve in a nursing specialty (other than as nurse anesthetists) that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0767cdd-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302e/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is designated by the Secretary of the military department concerned as critical to meet requirements (whether such specialty is designated as critical to meet wartime or peacetime requirements); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0767cde-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302e/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires postbaccalaureate education and training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0767cdf-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of Agreement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under regulations prescribed by the Secretary of Defense, with respect to the Army, Navy, and Air Force, and the Secretary of Health and Human Services, with respect to the Public Health Service, the Secretary concerned may terminate an agreement entered into under subsection (a). Upon termination of an agreement, the entitlement of the officer to special pay under this section and the agreed upon commitment to active duty of the officer shall end. If such entitlement is terminated, the officer concerned shall be subject to the repayment provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s303a/e"},"text":"section 303a(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0767ce0-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Special pay payable to an officer under subsection (a) shall be paid annually at the beginning of the 12-month period for which the officer is to receive that payment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0767ce1-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302e/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer who does not complete the period of active duty specified in the agreement entered into under subsection (a) shall be subject to the repayment provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s303a/e"},"text":"section 303a(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb0767ce2-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/d