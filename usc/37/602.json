{"tag":"section","attrib":{"id":"idb0b4708a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s602"},"text":null,"children":[{"tag":"num","attrib":{"value":"602"},"text":"§ 602.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments: designation of person to receive amounts due","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb0b4708b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s602/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Active duty pay and allowances, amounts due for accrued or accumulated leave, or retired or retainer pay, that are otherwise payable to a member to whom this chapter applies and who is mentally incapable of managing his affairs, may be paid for that member’s use or benefit to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0b4708c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s602/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a legal committee, guardian, or other representative that has been appointed by a court of competent jurisdiction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0b4708d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s602/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual to whom the member has granted authority to manage such funds pursuant to a valid and legally executed durable power of attorney; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0b4708e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s602/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person designated by the Secretary concerned, or by any officer to whom he delegates his authority under this section, without the appointment in judicial proceedings of a committee, guardian, or other legal representative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0b4708f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s602/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An individual may not be designated under subsection (a)(3) to receive payments unless a board consisting of at least three qualified medical officers or physicians, one of whom is specially qualified in the treatment of mental disorders, determines that the member is mentally incapable of managing the member’s affairs. Any such board shall be appointed from available medical officers or physicians under his jurisdiction by the head of whichever of the following is providing medical treatment for the member, or by a person designated by that head—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0b47090-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s602/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Department of the Army;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0b47091-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s602/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Department of the Navy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0b47092-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s602/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Department of the Air Force;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0b47093-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s602/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Department of Health and Human Services; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0b47094-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s602/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Department of Veterans Affairs.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"If the hospitalization or medical care of the member is not provided by the United States, the board shall be appointed by the Secretary of the department having jurisdiction of the member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0b47095-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s602/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A payment made to a person who is authorized to receive payments under this section discharges the obligation of the United States as to the amount paid.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0b6e096-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s602/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person serving in a legal, medical, fiduciary, or other capacity, may not demand or accept a fee, commission, or other charge for any service performed under this chapter, unless a court of competent jurisdiction orders payment of such fee, commission, or other charge.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0b6e097-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s602/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person who is designated under subsection (a)(3) to receive payments under this section shall furnish satisfactory assurance that the amounts received by him will be applied to the use and benefit of the incompetent member, and, where the payments may reasonably be expected to be more than $25,000, shall provide a suitable bond to be paid for out of amounts due the incompetent member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb0b6e098-2930-11f1-a69d-9cbca84c43f0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/649"},"text":"Pub. L. 87–649","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/483"},"text":"76 Stat. 483","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s516/17"},"text":"Pub. L. 96–513, title V, § 516(17)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2939"},"text":"94 Stat. 2939","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tXVI/s1621/b/1"},"text":"Pub. L. 101–189, div. A, title XVI, § 1621(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1604"},"text":"103 Stat. 1604","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVI/s645"},"text":"Pub. L. 114–328, div. A, title VI, § 645","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2167"},"text":"130 Stat. 2167","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb0b6e099-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb0b6e09a-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb0b6e09b-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"602(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"602(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"37:352 (1st sentence, less 31 words before provisos and less provisos).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"37:352 (last proviso of 1st sentence, 2d sentence, and last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-06-21/ch342"},"text":"June 21, 1950, ch. 342","children":[],"tail":", §§ 2, 3 (less 1st 28 words), "},{"tag":"html:a","attrib":{"href":"/us/stat/64/249"},"text":"64 Stat. 249","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Aug. 7, 1959","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/86/145/s1"},"text":"Pub. L. 86–145, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/73/297"},"text":"73 Stat. 297","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"602(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"37:352 (31 words before provisos of 1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"602(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"37:352 (1st proviso of 1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"602(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"37:352 (2d proviso of 1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"602(f)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"37:353 (less 1st 28 words).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “or persons” and “or officers” are omitted, since, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t1/s1"},"text":"section 1 of title 1","children":[],"tail":", “words importing the singular include and apply to several persons, parties, or things”. The words “to whom he delegates his authority under this section” are substituted for the words “as the respective Secretaries may designate for such purposes” to obviate confusion between persons “designated to receive payments and those who perform the Secretary’s functions under the section. The words “the necessity of” are omitted as surplusage."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “or persons” are omitted for the reasons given in the preceding paragraph. The words “discharges the obligation” are substituted for the words “shall constitute a complete discharge”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “under the authority of” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “have been” and “including a requirement” are omitted as surplusage. The words “or persons” are omitted for the reason stated in the explanation under subsection (a), above.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb0b6e09c-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb0b6e09d-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s645/1"},"text":"Pub. L. 114–328, § 645(1)","children":[],"tail":", struck out “, in the opinion of a board of medical officers or physicians,” after “and who” and substituted “use or benefit to—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) a legal committee, guardian, or other representative that has been appointed by a court of competent jurisdiction;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) an individual to whom the member has granted authority to manage such funds pursuant to a valid and legally executed durable power of attorney; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) any person designated”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"for “use or benefit to any person designated”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s645/2"},"text":"Pub. L. 114–328, § 645(2)","children":[],"tail":", in introductory provisions, substituted “An individual may not be designated under subsection (a)(3) to receive payments unless a board consisting” for “The board shall consist” and inserted “determines that the member is mentally incapable of managing the member’s affairs. Any such board shall be” after “treatment of mental disorders,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s645/3"},"text":"Pub. L. 114–328, § 645(3)","children":[],"tail":", substituted “authorized to receive payments” for “designated”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s645/4"},"text":"Pub. L. 114–328, § 645(4)","children":[],"tail":", inserted “, unless a court of competent jurisdiction orders payment of such fee, commission, or other charge” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s645/5"},"text":"Pub. L. 114–328, § 645(5)","children":[],"tail":"–(7), redesignated subsec. (f) as (e), inserted “under subsection (a)(3)” after “who is designated” and substituted “$25,000” for “$1,000”, and struck out former subsec. (e) which read as follows: “This section does not apply in any case in which a legal committee, guardian, or other representative has been appointed by a court of competent jurisdiction, except as to payments made before the paying agency of the department concerned receives notice of that appointment.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189"},"text":"Pub. L. 101–189","children":[],"tail":" substituted “Department of Veterans Affairs” for “Veterans’ Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" substituted “Department of Health and Human Services” for “Department of Health, Education, and Welfare”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb0b6e09e-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb0b6e09f-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701/b/3"},"text":"section 701(b)(3) of Pub. L. 96–513","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
