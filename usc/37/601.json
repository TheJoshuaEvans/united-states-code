{"tag":"section","attrib":{"id":"idb0b47083-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s601"},"text":null,"children":[{"tag":"num","attrib":{"value":"601"},"text":"§ 601.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"This chapter applies to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0b47084-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s601/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members of a uniformed service who are on active duty (other than for training) or who are on a retired list of that service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0b47085-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s601/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members of the Fleet Reserve or Fleet Marine Corps Reserve.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb0b47086-2930-11f1-a69d-9cbca84c43f0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/649"},"text":"Pub. L. 87–649","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/483"},"text":"76 Stat. 483","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb0b47087-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb0b47088-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb0b47089-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"601","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"37:351.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-06-21/ch342/s1"},"text":"June 21, 1950, ch. 342, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/249"},"text":"64 Stat. 249","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “on active duty (other than for training)” are substituted for the words “on the active . . . list” to conform to longstanding administrative construction, and because there is no “active list” in the case of many of the uniformed services named, but only for certain regular component of those services, e.g., the “Regular Army” and the “Regular Air Force”. The words “a retired list of that service” are substituted for the words “retired list”, since there is more than one retired list for many of the services named. (See sections 1376, 3966, and 8966 of title 10, for example.) The words “members of the Reserve components of the respective services entitled to Federal pay either on the active or any retired list of said services” are omitted as covered by clause (1), since members of the reserve components are members of the uniformed services concerned. The word “transferred” is omitted as surplusage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
