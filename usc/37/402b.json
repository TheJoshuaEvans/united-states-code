{"tag":"section","attrib":{"id":"idb09ca292-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b"},"text":null,"children":[{"tag":"num","attrib":{"value":"402b"},"text":"§ 402b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basic needs allowance for members on active service in the Armed Forces","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb09ca293-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allowance Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned shall pay to each member who is eligible under subsection (b) a basic needs allowance in the amount determined for such member under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09ca294-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Members","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A member on active service in the armed forces is eligible for the allowance under subsection (a) if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb09ca295-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the member has completed initial entry training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09eeb86-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the gross household income of the member during the most recent calendar year did not exceed an amount equal to 200 percent of the Federal poverty guidelines of the Department of Health and Human Services for the location of the member and the number of individuals in the household of the member for such year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09eeb87-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the member—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb09eeb88-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not ineligible for the allowance under subsection (d); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb09eeb89-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not elect under subsection (g) not to receive the allowance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09eeb8a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount of Allowance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of the monthly allowance payable to a member under subsection (a) shall be the amount equal to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb09eeb8b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb09eeb8c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 200 percent of the Federal poverty guidelines of the Department of Health and Human Services for the calendar year during which the allowance is paid based on the location of the member and the number of individuals in the household of the member during the month for which the allowance is paid; minus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb09eeb8d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the gross household income of the member during the preceding calendar year; divided by","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09eeb8e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 12.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09eeb8f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Bases of Ineligibility.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb09eeb90-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following members are ineligible for the allowance under subsection (a):","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb09eeb91-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member who does not have any dependents.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb09eeb92-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A cadet at the United States Military Academy, the United States Air Force Academy, or the Coast Guard Academy, a midshipman at the United States Naval Academy, or a cadet or midshipman serving elsewhere in the armed forces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09eeb93-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Household with more than one eligible member","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the event a household contains two or more members determined under subsection (f) to be eligible to receive the allowance under subsection (a), only one allowance may be paid to a member among such members as such members shall jointly elect.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09eeb94-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Automatic ineligibility of members receiving certain pay increases","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member determined to be eligible under subsection (f) for the allowance under subsection (a) whose monthly gross household income increases as a result of a promotion or other permanent increase to pay or allowances under this title to an amount that, on an annualized basis, would exceed the amount described in subsection (b)(2) is ineligible for the allowance. If such member is receiving the allowance, payment of the allowance shall automatically terminate within a reasonable time, as determined by the Secretary of Defense in regulations prescribed under subsection (j).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09eeb95-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Ineligibility of certain changes in income","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member whose gross household income for the preceding year decreases because of a fine, forfeiture, or reduction in rank imposed as a part of disciplinary action or an action under chapter 47 of title 10 (the Uniform Code of Military Justice) is not eligible for the allowance under subsection (a) solely as a result of the fine, forfeiture, or reduction in rank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09eeb96-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application by Members Seeking Allowance.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb09eeb97-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member who seeks to receive the allowance under subsection (a) shall submit to the Secretary concerned an application for the allowance that includes such information as the Secretary may require in order to determine whether or not the member is eligible to receive the allowance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09eeb98-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timing of submission","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member who receives the allowance under subsection (a) and seeks to continue to receive the allowance shall submit to the Secretary concerned an updated application under paragraph (1) at such times as the Secretary may require, but not less frequently than annually.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09eeb99-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Voluntary submission","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The submission of an application under paragraph (1) is voluntary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09eeb9a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Screening of members for eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb09eeb9b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that all members of the armed forces are screened during initial entry training and regularly thereafter for eligibility for the allowance under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb09eeb9c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify any member so screened who may be eligible that the member may apply for the allowance by submitting an application under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09eeb9d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determinations of Eligibility.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb09eeb9e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb09eeb9f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine which members of the armed forces are eligible under subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb09eeba0-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify each such member, in writing, of that determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09eeba1-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information included in notice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The notice under paragraph (1) shall include information regarding financial management and assistance programs for which the member may be eligible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09eeba2-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Election Not to Receive Allowance.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb09eeba3-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member determined under subsection (f) to be eligible for the allowance under subsection (a) may elect, in writing, not to receive the allowance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09eeba4-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deemed ineligible","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member who does not submit an application under subsection (e) within a reasonable time (as determined by the Secretary concerned) shall be deemed ineligible for the allowance under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09eeba5-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Rule for Members Stationed Outside United States","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of a member assigned to a duty location outside the United States, the Secretary concerned shall make the calculations described in subsections (b)(2) and (c)(1) using the Federal poverty guidelines of the Department of Health and Human Services for the continental United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09eeba6-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than one year after the date of the enactment of the National Defense Authorization Act for Fiscal Year 2022, the Secretary of Defense shall prescribe regulations for the administration of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09eeba7-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Period.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb09eeba8-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation period","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The allowance under subsection (a) is payable for months beginning on or after the date that is one year after the date of the enactment of the National Defense Authorization Act for Fiscal Year 2022.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09eeba9-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The allowance under subsection (a) may not be paid for any month beginning after ","children":[{"tag":"date","attrib":{"date":"2027-12-31"},"text":"December 31, 2027","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09eebaa-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb09eebab-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Gross household income","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “gross household income”, with respect to a member of the armed forces, includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb09eebac-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/k/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all household income, derived from any source; minus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb09eebad-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/k/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a member whom the Secretary concerned determines resides in an area with a high cost of living or that otherwise has a demonstrated need, any portion of the basic allowance for housing under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s403"},"text":"section 403 of this title","children":[],"tail":" that the Secretary concerned elects to exclude."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09eebae-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s402b/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Household","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “household” means a member of the armed forces and any dependents of the member enrolled in the Defense Enrollment Eligibility Reporting System, regardless of the location of those dependents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb09eebaf-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tVI/s601/a"},"text":"Pub. L. 117–81, div. A, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1761"},"text":"135 Stat. 1761","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tVI/s611/a"},"text":"Pub. L. 117–263, div. A, title VI, § 611(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2622"},"text":"136 Stat. 2622","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dO/tII/s201/a"},"text":"Pub. L. 117–328, div. O, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5226"},"text":"136 Stat. 5226","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tVI/s621/a"},"text":"Pub. L. 118–31, div. A, title VI, § 621(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/293"},"text":"137 Stat. 293","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tVI/s621"},"text":"Pub. L. 118–159, div. A, title VI, § 621","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1933"},"text":"138 Stat. 1933","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb09eebb0-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb09eebb1-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb09eebb2-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the National Defense Authorization Act for Fiscal Year 2022, referred to in subsecs. (i) and (j)(1), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb09eebb3-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s621/a"},"text":"Pub. L. 118–159, § 621(a)","children":[],"tail":", struck out subpar. (A) designation before “the gross household income”, substituted “200 percent” for “150 percent” and “; and” for “; or”, and struck out subpar. (B) which read as follows: “if the Secretary concerned determines it appropriate (based on location, household need, or special circumstance), the gross household income of the member during the most recent calendar year did not exceed an amount equal to 200 percent of the Federal poverty guidelines of the Department of Health and Human Services for the location of the member and the number of individuals in the household of the member for such year; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s621/b"},"text":"Pub. L. 118–159, § 621(b)","children":[],"tail":", substituted “200 percent” for “150 percent (or, in the case of a member described in subsection (b)(2)(B), 200 percent)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2023—Subsec. (k)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" inserted “or that otherwise has a demonstrated need” after “high cost of living”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s201/a/1"},"text":"Pub. L. 117–328, § 201(a)(1)","children":[],"tail":", made technical amendment to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/s611/a"},"text":"Pub. L. 117–263, § 611(a)","children":[],"tail":". See Amendment notes below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s611/a/1"},"text":"Pub. L. 117–263, § 611(a)(1)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/s201/a/2"},"text":"Pub. L. 117–328, § 201(a)(2)","children":[],"tail":", designated existing provisions as subpar. (A), substituted “150 percent” for “130 percent” and “; or” for “; and”, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s611/a/2"},"text":"Pub. L. 117–263, § 611(a)(2)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/s201/a/3"},"text":"Pub. L. 117–328, § 201(a)(3)","children":[],"tail":", substituted “150 percent (or, in the case of a member described in subsection (b)(2)(B), 200 percent)” for “130 percent”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb09eebb4-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb09eebb5-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of ","children":[{"tag":"i","attrib":{},"text":"2022","children":[],"tail":" Amendment"}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dO/tII/s201/b"},"text":"Pub. L. 117–328, div. O, title II, § 201(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5227"},"text":"136 Stat. 5227","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dO/tII/s201/b"},"text":"“The amendments made by this section [amending ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s611/a"},"text":"section 611(a) of Pub. L. 117–263","children":[],"tail":", which amended this section] shall take effect as if included in the enactment of such Act [meaning "},{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":", approved "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb09eebb6-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Implementation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tVI/s621/b"},"text":"Pub. L. 118–31, div. A, title VI, § 621(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/293"},"text":"137 Stat. 293","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/31/dA/tVI/s621/b"},"text":"“The Secretary of Defense shall revise the guidance issued with respect to implementation of the basic needs allowance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s402b"},"text":"section 402b of title 37","children":[],"tail":", United States Code, to reflect the amendment made by subsection (a) [amending this section].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tVI/s611/b"},"text":"Pub. L. 117–263, div. A, title VI, § 611(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2622"},"text":"136 Stat. 2622","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dA/tVI/s611/b"},"text":"“Not later than ","children":[{"tag":"date","attrib":{"date":"2024-01-01"},"text":"January 1, 2024","children":[],"tail":", the Secretary concerned (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s101"},"text":"section 101 of title 37","children":[],"tail":", United States Code) shall modify the calculation of the basic needs allowance under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s402b"},"text":"section 402b of title 37","children":[],"tail":", United States Code, to implement the amendments made by subsection (a) [amending this section].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
