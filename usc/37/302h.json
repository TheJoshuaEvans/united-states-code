{"tag":"section","attrib":{"id":"idb078c5ff-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302h"},"text":null,"children":[{"tag":"num","attrib":{"value":"302h"},"text":"§ 302h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special pay: accession bonus for dental officers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb078c600-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Accession Bonus Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb078c601-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302h/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person who is a graduate of an accredited dental school and who, during the period beginning on ","children":[{"tag":"date","attrib":{"date":"1996-09-23"},"text":"September 23, 1996","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":", executes a written agreement described in subsection (c) to accept a commission as an officer of the armed forces and remain on active duty for a period of not less than four years may, upon the acceptance of the agreement by the Secretary concerned, be paid an accession bonus in an amount determined by the Secretary concerned."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb078c602-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302h/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of an accession bonus under paragraph (1) may not exceed $200,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb078c603-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Eligibility for Bonus","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person may not be paid a bonus under subsection (a) if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb078c604-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302h/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person, in exchange for an agreement to accept an appointment as an officer, received financial assistance from the Department of Defense to pursue a course of study in dentistry; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb078c605-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302h/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary concerned determines that the person is not qualified to become and remain certified and licensed as a dentist.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb078c606-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302h/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The agreement referred to in subsection (a) shall provide that, consistent with the needs of the armed service concerned, the person executing the agreement will be assigned to duty, for the period of obligated service covered by the agreement, as an officer of the Dental Corps of the Army or the Navy or an officer of the Air Force designated as a dental officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb078c607-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302h/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person who, after signing an agreement under subsection (a), is not commissioned as an officer of the armed forces, does not become licensed as a dentist, or does not complete the period of active duty specified in the agreement shall be subject to the repayment provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s303a/e"},"text":"section 303a(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb078c608-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tVI/s615/c/1"},"text":"Pub. L. 104–201, div. A, title VI, § 615(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2545"},"text":"110 Stat. 2545","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tVI/s618"},"text":"Pub. L. 107–107, div. A, title VI, § 618","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1137"},"text":"115 Stat. 1137","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tVI/s612/f"},"text":"Pub. L. 107–314, div. A, title VI, § 612(f)","children":[],"tail":", "},{"tag":"