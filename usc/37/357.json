{"tag":"section","attrib":{"id":"idb09a30c0-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s357"},"text":null,"children":[{"tag":"num","attrib":{"value":"357"},"text":"§ 357.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special and incentive pay authorities for members of the reserve components of the armed forces","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s1004"},"text":"section 1004 of this title","children":[],"tail":", the Secretary concerned shall pay a member of the reserve component of an armed force special or incentive pay in the same monthly amount as that paid to a member in the regular component of such armed force performing comparable work requiring comparable skills if the Secretary concerned is paying the member of the reserve component the special or incentive pay for the purpose of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb09a30c1-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s357/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintaining a skill certification or proficiency identical to a skill certification or proficiency required of the member in the regular component; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09a30c2-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s357/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compensating the member of the reserve component for exposure to hazards or risks identical to hazards or risks to which the member in the regular component was exposed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb09a30c3-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tVI/s602/a"},"text":"Pub. L. 117–81, div. A, title VI, § 602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1765"},"text":"135 Stat. 1765","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tVI/s612/a"},"text":"Pub. L. 118–31, div. A, title VI, § 612(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/290"},"text":"137 Stat. 290","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb09a30c4-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb09a30c5-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb09a30c6-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":", in section catchline, substituted “Special and incentive” for “Incentive” and, in text, substituted “special or incentive pay” for “incentive pay” and “if the Secretary concerned is paying the member of the reserve component the special or incentive pay for the purpose of—” for period, and added pars. (1) and (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb09a30c7-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb09a30c8-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Implementation of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tVI/s602/c"},"text":"Pub. L. 117–81, div. A, title VI, § 602(c)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1765"},"text":"135 Stat. 1765","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tVI/s612/c"},"text":"Pub. L. 118–31, div. A, title VI, § 612(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/291"},"text":"137 Stat. 291","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tVI/s613"},"text":"Pub. L. 119–60, div. A, title VI, § 613","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/907"},"text":"139 Stat. 907","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dA/tVI/s613"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2022-09-30"},"text":"September 30, 2022","children":[],"tail":", the Secretary of Defense shall submit to the Committees on Armed Services of the Senate and House of Representatives a report containing—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan of the Secretary to implement section 357 of such title [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s357"},"text":"37 U.S.C. 357","children":[],"tail":"], as added by subsection (a);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the costs of such implementation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of members described in such section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other matter the Secretary determines relevant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation Date","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall not implement section 357 of such title, as added by subsection (a) until after—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submission of the report under subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines and certifies in writing to the Committees on Armed Services of the Senate and House of Representatives that such implementation shall not have a detrimental effect on the force structure of an Armed Force concerned, including with regard to recruiting or retention of members in the regular component of such Armed Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Evaluation of types of special and incentive pay","children":[],"tail":".—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In making the determination and certification described in paragraph (1)(B), the Secretary shall evaluate each type or category of special and incentive pay separately and may make the determination and certification based on the effect on an Armed Force concerned of a particular type or category of special or incentive pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Aviation incentive pay evaluation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2026-06-01"},"text":"June 1, 2026","children":[],"tail":", the Secretary shall complete the evaluation required by subparagraph (A) with respect to aviation incentive pay under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s334"},"text":"section 334 of title 37","children":[],"tail":", United States Code. In conducting that evaluation, the Secretary shall make a specific determination with respect to the percentage of such aviation incentive pay, if any, that is paid specifically to maintain skill certification or proficiency under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s357"},"text":"section 357 of title 37","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special and incentive pay framework","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2026-06-01"},"text":"June 1, 2026","children":[],"tail":", the Secretary shall submit to the Committees on Armed Services of the Senate and the House of Representatives a detailed report on the special and incentive pay assessment framework, required by the Senate report accompanying the National Defense Authorization Act for Fiscal Year 2024 ("},{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Public Law 118–31","children":[],"tail":") [see Tables for classification], that includes the Secretary’s plan and timeline for implementing such framework."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Initiation of payments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2027-01-01"},"text":"January 1, 2027","children":[],"tail":", the Secretary concerned shall begin making aviation incentive payments under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s357"},"text":"section 357 of title 37","children":[],"tail":", United States Code, pursuant to the determination made under paragraph (2)(B).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
