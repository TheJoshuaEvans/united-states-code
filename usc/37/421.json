{"tag":"section","attrib":{"id":"idb0a88876-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s421"},"text":null,"children":[{"tag":"num","attrib":{"value":"421"},"text":"§ 421.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowances: no increase while dependent is entitled to basic pay","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A member of a uniformed service may not be paid an increased allowance under this chapter, on account of a dependent, for any period during which that dependent is entitled to basic pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s204"},"text":"section 204 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb0a88877-2930-11f1-a69d-9cbca84c43f0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/649"},"text":"Pub. L. 87–649","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/479"},"text":"76 Stat. 479","children":[],"tail":", § 420; renumbered § 421, "},{"tag":"ref","attrib":{"href":"/us/pl/100/180/dA/tVI/s611/a/1/A"},"text":"Pub. L. 100–180, div. A, title VI, § 611(a)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1093"},"text":"101 Stat. 1093","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb0a88878-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb0a88879-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb0a8887a-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text