{"tag":"section","attrib":{"id":"idb06cdfdb-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s301d"},"text":null,"children":[{"tag":"num","attrib":{"value":"301d"},"text":"§ 301d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiyear retention bonus: medical officers of the armed forces","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb06cdfdc-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s301d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Bonus Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb06cdfdd-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s301d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A medical officer described in subsection (b) who executes a written agreement to remain on active duty for two, three, or four years after completion of any other active-duty service commitment may, upon acceptance of the written agreement by the Secretary of the military department concerned, be paid a retention bonus as provided in this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb06cdfde-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s301d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of a retention bonus under paragraph (1) may not exceed $75,000 for each year covered by a four-year agreement. The maximum yearly retention bonus for two-year and three-year agreements shall be reduced to reflect the shorter service commitment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb06cdfdf-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s301d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Officers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section applies to an officer of the armed forces who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb06cdfe0-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s301d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an officer of the Medical Corps of the Army or the Navy or an officer of the Air Force designated as a medical officer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb06cdfe1-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s301d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in a pay grade below pay grade O–7;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb06cdfe2-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s301d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has at least eight years of creditable service (computed as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s302/g"},"text":"section 302(g) of this title","children":[],"tail":") or has completed any active-duty service commitment incurred for medical education and training; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb06cdfe3-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s301d/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has completed initial residency training (or will complete such training before September 30 of the fiscal year in which the officer enters into an agreement under subsection (a)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb06cdfe4-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s301d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer who does not complete the period of active duty specified in the agreement entered into under subsection (a) shall be subject to the repayment provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s303a/e"},"text":"section 303a(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb06cdfe5-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tVI/s611/a/1"},"text":"Pub. L. 101–510, div. A, title VI, § 611(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1576"},"text":"104 Stat. 1576","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tX/s1054/a/2"},"text":"Pub. L. 102–484, div. A, title X, § 1054(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2502"},"text":"106 Stat. 2502","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tVI/s615/a"},"text":"Pub. L. 107–314, div. A, title VI, § 615(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2568"},"text":"116 Stat. 2568","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tVI/s687/b/2"},"text":"Pub. L. 109–163, div. A, title VI, § 687(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3327"},"text":"119 Stat. 3327","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tVI/s615/b"},"text":"Pub. L. 110–181, div. A, title VI, § 615(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/150"},"text":"122 Stat. 150","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb06cdfe6-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb06cdfe7-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb06cdfe8-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" substituted “$75,000” for “$50,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" amended heading and text of subsec. (c) generally, substituting provisions referring to repayment provisions of section 303a(e) for specific provisions relating to refunds required when officer fails to complete total period of active duty."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314"},"text":"Pub. L. 107–314","children":[],"tail":" substituted “$50,000” for “$14,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/s1054/a/2/A"},"text":"Pub. L. 102–484, § 1054(a)(2)(A)","children":[],"tail":", substituted “owed” for “owned”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/s1054/a/2/B"},"text":"Pub. L. 102–484, § 1054(a)(2)(B)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"November 5, 1990","children":[],"tail":"” for “the date of the enactment of the National Defense Authorization Act for Fiscal Year 1991”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb06cdfe9-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb06cdfea-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tVI/s615/c"},"text":"Pub. L. 110–181, div. A, title VI, § 615(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/150"},"text":"122 Stat. 150","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/181/dA/tVI/s615/c"},"text":"“The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s302"},"text":"section 302 of this title","children":[],"tail":"] shall apply with respect to agreements entered into under section 301d(a) or 302b(c) of title 37, United States Code, on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"idb06cdfeb-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For savings provision relating to payment or repayment of any bonus, incentive pay, special pay, or similar pay obligated to be paid before ","children":[{"tag":"date","attrib":{"date":"2006-04-01"},"text":"Apr. 1, 2006","children":[],"tail":", under a provision of this section amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s687/b"},"text":"section 687(b) of Pub. L. 109–163","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s687/f"},"text":"section 687(f) of Pub. L. 109–163","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s510"},"text":"section 510 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb06cdfec-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Application of Increase","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tVI/s615/i"},"text":"Pub. L. 107–314, div. A, title VI, § 615(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2569"},"text":"116 Stat. 2569","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/314/dA/tVI/s615/i"},"text":"“In the case of an amendment made by this section [amending sections 301d, 301e, 302, 302a, 302d, 302e, and 302i of this title and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2130a"},"text":"section 2130a of Title 10","children":[],"tail":", Armed Forces] to increase the maximum amount of a special pay or bonus that may be paid during any 12-month period, the amended limitation shall apply to 12-month periods beginning after "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"September 30, 2002","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb06cdfed-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Eligibility of Flag and General Officers for Multiyear Retention Bonus for Medical Officers","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tVI/s615"},"text":"Pub. L. 102–190, div. A, title VI, § 615","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1377"},"text":"105 Stat. 1377","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/190/dA/tVI/s615"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reiterating Ineligibility","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The restriction contained in subsection (b)(2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s301d"},"text":"section 301d of title 37","children":[],"tail":", United States Code, on the eligibility of flag and general officers serving as full-time physicians to receive a multiyear retention bonus under that section shall not be construed as being limited, modified, or superseded by any provision of law, whether enacted before, on, or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":"], unless that provision of law—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifically refers to that section and this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies the flag and general officers affected by that provision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Savings Provision","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A medical officer of the Armed Forces who is a flag or general officer and has received any payment of a bonus under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s301d"},"text":"section 301d of title 37","children":[],"tail":", United States Code, before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":"] may not be required to reimburse the United States for such payment by reason of the enactment of subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A written agreement referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s301d"},"text":"section 301d of title 37","children":[],"tail":", United States Code, that was entered into on or after "},{"tag":"date","attrib":{"date":"1991-04-10"},"text":"April 10, 1991","children":[],"tail":", and before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":"] by a medical officer of the Armed Forces referred to in paragraph (1) in exchange for a payment (or a promise of payment) of a bonus under that section shall be terminated as of the later of—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the end of the month following the month in which this Act is enacted; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the end of the period covered by the bonus payment or payments received by that officer as described in that paragraph.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/172/tVIII/s8084"},"text":"Pub. L. 102–172, title VIII, § 8084","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-11-26"},"text":"Nov. 26, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1192"},"text":"105 Stat. 1192","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/172/tVIII/s8084"},"text":"“Restrictions provided under subsection (b)(2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s301d"},"text":"section 301d of title 37","children":[],"tail":", United States Code, as authorized by the National Defense Authorization Act for Fiscal Year 1991 ("},{"tag":"ref","attrib":{"href":"/us/pl/101/510"},"text":"Public Law 101–510","children":[],"tail":"), and hereafter, shall not apply in the case of flag or general officers serving as full-time practicing physicians.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb06cdfee-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Existing Retention Bonus Agreement","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tVI/s611/b"},"text":"Pub. L. 101–510, div. A, title VI, § 611(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1576"},"text":"104 Stat. 1576","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/510/dA/tVI/s611/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to the approval of the Secretary of the military department concerned, a medical officer who is eligible to enter into a retention bonus agreement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s301d"},"text":"section 301d of title 37","children":[],"tail":", United States Code (as added by subsection (a)) may terminate any existing retention bonus agreement entered into by that officer under [section] 612 of the National Defense Authorization Act, Fiscal Year 1989 ["},{"tag":"ref","attrib":{"href":"/us/pl/100/456"},"text":"Pub. L. 100–456","children":[],"tail":"] ("},{"tag":"ref","attrib":{"href":"/us/usc/t37/s302"},"text":"37 U.S.C. 302","children":[],"tail":" note), in order to enter into an agreement under section 301d of such title containing an active-duty service obligation that is not less than the active-duty service obligation remaining under the existing agreement on the date of its termination."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (e) of section 612 of the National Defense Authorization Act, Fiscal Year 1989 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s302"},"text":"37 U.S.C. 302","children":[],"tail":" note), shall not apply to the termination, pursuant to paragraph (1), of a retention bonus agreement under that section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
