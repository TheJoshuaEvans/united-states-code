{"tag":"section","attrib":{"id":"idb0aafa35-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s438"},"text":null,"children":[{"tag":"num","attrib":{"value":"438"},"text":"§ 438.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preventive health services allowance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb0aafa36-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s438/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Demonstration Project","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"During the period beginning on ","children":[{"tag":"date","attrib":{"date":"2009-01-01"},"text":"January 1, 2009","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"December 31, 2011","children":[],"tail":", the Secretary of Defense shall conduct a demonstration project designed to evaluate the efficacy of providing an annual allowance (to be known as a “preventive health services allowance”) to members of the armed forces described in subsection (b) to increase the use of preventive health services by such members and their dependents."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0aafa37-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s438/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Members","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0aafa38-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s438/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to the numerical limitations specified in paragraph (2), a member of the armed forces who is serving on active duty for a period of more than 30 days and meets the medical and dental readiness requirements for the armed force of the member may receive a preventive health services allowance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0aafa39-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s438/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than 1,500 members of each of the Army, Navy, Air Force, and Marine Corps may receive a preventive health services allowance during any year, of which half in each armed force shall be members without dependents and half shall be members with dependents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0aafa3a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s438/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount of Allowance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the military department concerned shall pay a preventive health services allowance to a member selected to receive the allowance in an amount equal to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0aafa3b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s438/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $500 per year, in the case of a member without dependents; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0aafa3c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s438/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000 per year, in the case of a member with dependents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0aafa3d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s438/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorized Preventive Health Services","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0aafa3e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s438/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall specify the types of preventive health services that may be procured using a preventive health services allowance and the frequency at which such services may be procured.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0aafa3f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s438/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" At a minimum, authorized preventive health services shall include, taking into consideration the age and gender of the member and dependents of the member:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0aafa40-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s438/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Colorectal screening.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0aafa41-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s438/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Breast screening.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0aafa42-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s438/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cervical screening.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0aafa43-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s438/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Prostate screening.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0aafa44-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s438/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Annual physical exam.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0aafa45-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s438/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Annual dental exam.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0aafa46-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s438/d/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Weight and body mass screening.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0aafa47-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s438/d/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Vaccinations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0aafa48-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s438/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall ensure that members selected to receive the preventive health services allowance and their dependents are provided a reasonable opportunity to receive the services authorized under this subsection in their local area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0aafa49-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s438/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Data Collection","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"At a minimum, the Secretary of Defense shall monitor and record the health of members receiving a preventive health services allowance and their dependents and the results of the testing required to qualify for payment of the allowance, if conducted. The Secretary shall assess the medical utility of the testing required to qualify for payment of a preventive health allowance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0aafa4a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s438/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reporting Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2010-03-31"},"text":"March 31, 2010","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"2012-03-31"},"text":"March 31, 2012","children":[],"tail":", the Secretary of Defense shall submit to Congress a report on the status of the demonstration project, including findings regarding the medical status of participants, recommendations to modify the policies and procedures of the program, and recommendations concerning the future utility of the project."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0aafa4b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s438/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall prescribe regulations to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb0aafa4c-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title VII, § 714(a), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4504"},"text":"122 Stat. 4504","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
