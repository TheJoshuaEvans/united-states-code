{"tag":"section","attrib":{"id":"idb0898f41-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s309"},"text":null,"children":[{"tag":"num","attrib":{"value":"309"},"text":"§ 309.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special pay: enlistment bonus","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb0898f42-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s309/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Bonus Authorized; Bonus Amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person who enlists in an armed force for a period of at least 2 years may be paid a bonus in an amount not to exceed $40,000. The bonus may be paid in a single lump sum or in periodic installments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0898f43-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s309/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member who does not complete the term of enlistment for which a bonus was paid to the member under this section, or a member who is not technically qualified in the skill for which a bonus was paid to the member under this section, shall be subject to the repayment provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s303a/e"},"text":"section 303a(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0898f44-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s309/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relation to Prohibition on Bounties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The enlistment bonus authorized by this section is not a bounty for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s514/a"},"text":"section 514(a) of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0898f45-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s309/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall be administered under regulations prescribed by the Secretary of Defense for the armed forces under the jurisdiction of the Secretary of Defense and by the Secretary of Homeland Security for the Coast Guard when the Coast Guard is not operating as a service in the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0898f46-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s309/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duration of Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No bonus shall be paid under this section with respect to any enlistment in the armed forces made after ","children":[{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb0898f47-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div