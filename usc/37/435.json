{"tag":"section","attrib":{"id":"idb0aafa00-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s435"},"text":null,"children":[{"tag":"num","attrib":{"value":"435"},"text":"§ 435.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funeral honors duty: allowance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb0aafa01-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s435/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allowance Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0aafa02-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s435/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned may authorize payment of an allowance to a member of the Ready Reserve for any day on which the member performs at least two hours of funeral honors duty pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12503"},"text":"section 12503 of title 10","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t32/s115"},"text":"section 115 of title 32","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0aafa03-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s435/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned may also authorize payment of that allowance to a member of the armed forces in a retired status for any day on which the member serves in a funeral honors detail under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1491"},"text":"section 1491 of title 10","children":[],"tail":", if the time required for service in such detail (including time for preparation) is not less than two hours. The amount of an allowance paid to a member under this paragraph shall be in addition to any other compensation to which the member may be entitled under this title or title 10 or 38."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0aafa04-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s435/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The daily rate of an allowance under this section is $50.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb0aafa05-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tV/s578/j"},"text":"Pub. L. 106–65, div. A, title V, § 578(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/630"},"text":"113 Stat. 630","children":[],"tail":", § 435; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title V, § 575(b), title X, § 1087(c)(1)(A)(i)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–138, 1654A–292; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tV/s561/b"},"text":"Pub. L. 107–107, div. A, title V, § 561(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1119"},"text":"115 Stat. 1119","children":[],"tail":"; renumbered § 495 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVI/s631/d/2"},"text":"Pub. L. 112–81, div. A, title VI, § 631(d)(2)","children":[],"tail":", (e)(32), "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1460"},"text":"125 Stat. 1460","children":[],"tail":", 1464; renumbered § 435 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tVI/s604/b"},"text":"Pub. L. 116–283, div. A, title VI, § 604(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3672"},"text":"134 Stat. 3672","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb0aafa06-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb0aafa07-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb0aafa08-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 435 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s495"},"text":"section 495 of this title","children":[],"tail":" prior to being renumbered again as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb0aafa09-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s604/b/1"},"text":"Pub. L. 116–283, § 604(b)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s495"},"text":"section 495 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s604/b/2"},"text":"Pub. L. 116–283, § 604(b)(2)","children":[],"tail":", struck out subsec. (c). Text read as follows: “No allowance may be paid under this section for any day after the travel authorities transition expiration date.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s631/d/2"},"text":"Pub. L. 112–81, § 631(d)(2)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s435"},"text":"section 435 of this title","children":[],"tail":" as section 495."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s631/e/32"},"text":"Pub. L. 112–81, § 631(e)(32)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title X, § 1087(c)(1)(A)(i)], made technical amendment to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/s578/j"},"text":"Pub. L. 106–65, § 578(j)","children":[],"tail":", which enacted this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title V, § 575(b)], struck out heading and text of subsec. (c). Text read as follows: “Except for expenses reimbursed under subsection (c) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12503"},"text":"section 12503 of title 10","children":[],"tail":" or subsection (c) of "},{"tag":"ref","attrib":{"href":"/us/usc/t32/s115"},"text":"section 115 of title 32","children":[],"tail":", the allowance paid under this section is the only monetary compensation authorized to be paid a member for the performance of funeral honors duty pursuant to such section, regardless of the grade in which the member is serving, and shall constitute payment in full to the member.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb0aafa0a-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb0aafa0b-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by section 1 [[div. A], title V, § 575(b)] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":", applicable with respect to funeral honors duty performed on or after "},{"tag":"date","attrib":{"date":"2000-10-01"},"text":"Oct. 1, 2000","children":[],"tail":", see section 1 [[div. A], title V, § 575(c)] of "},{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12503"},"text":"section 12503 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title X, § 1087(c)(1)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–292, provided that the amendment made by that section is effective as of "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", and as if included in the National Defense Authorization Act for Fiscal Year 2000, "},{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":", as enacted."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
