{"tag":"section","attrib":{"id":"idb09a30ff-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s374"},"text":null,"children":[{"tag":"num","attrib":{"value":"374"},"text":"§ 374.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"This subchapter and subchapter II shall be administered under regulations prescribed by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb09a3100-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s374/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Defense, with respect to the armed forces under the jurisdiction of the Secretary of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09a3101-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s374/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Homeland Security, with respect to the Coast Guard when it is not operating as a service in the Navy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09a3102-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s374/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Health and Human Services, with respect to the commissioned corps of the Public Health Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09a3103-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s374/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Commerce, with respect to the National Oceanic and Atmospheric Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb09a3104-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tVI/s661/a/2"},"text":"Pub. L. 110–181, div. A, title VI, § 661(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/178"},"text":"122 Stat. 178","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
