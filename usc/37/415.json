13","children":[],"tail":"; restated "},{"tag":"html:a","attrib":{"href":"/us/act/1956-04-27/ch211/s2/a"},"text":"Apr. 27, 1956, ch. 211, § 2(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/70/116"},"text":"70 Stat. 116","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"415(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"37:256.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-10-12/ch681/s306"},"text":"Oct. 12, 1949, ch. 681, § 306","children":[],"tail":"; added "},{"tag":"html:a","attrib":{"href":"/us/act/1956-08-10/ch1041/s20/d"},"text":"Aug. 10, 1956, ch. 1041, § 20(d)","children":[],"tail":" (last par.), "},{"tag":"html:a","attrib":{"href":"/us/stat/70A/629"},"text":"70A Stat. 629","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"[Uncodified.]","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1947-08-07/ch512/s302/f"},"text":"Aug. 7, 1947, ch. 512, § 302(f)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/61/830"},"text":"61 Stat. 830","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “Subject to subsections (b) and (c) of this section,” are inserted for clarity. The words “of an armed force” are inserted, since the source section, as originally enacted, did not apply to the Public Health Service or the Coast and Geodetic Survey. (See section 243 of the Armed Forces Reserve Act of 1952 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/66/492"},"text":"66 Stat. 492","children":[],"tail":").) The words “of the Army, or the Air Force, without specification of component” are inserted to reflect the definition of “reserve component” in section 102(k) of the source statute. That definition is executed throughout this revised title. For that reason, the words “but not as a member of the Army without specification of component or the Air Force without specification of component, in section 255(a)(2) of existing title 37”, are omitted, and since those categories are excluded by the words “member of a reserve component”. The words “of a reserve component”, in section 255(a)(3) of existing title 37, are omitted, since the Ready Reserve cannot be in anything other than a reserve component."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “heretofore or hereafter” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “An officer” are substituted for the words “any individual”, since the revised section applies only to officers.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “who is in pay grade O–1, O–2, or O–3” are substituted for the words “is receiving the pay of the junior assistant, assistant, or senior assistant grade” to reflect current terminology. (See chapter 3 of this revised title.) The last sentence is substituted for section 214 (words following semicolon) of title 14.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “as a temporary officer” are inserted for clarity. The words “5596 or” are substituted for ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-08-07/s302/f"},"text":"section 302(f) of the Act of August 7, 1947","children":[],"tail":", cited above."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb0a6181b-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb0a6181c-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":" substituted “$400” for “$200” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/25"},"text":"Pub. L. 102–25","children":[],"tail":" struck out “of this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/22"},"text":"Pub. L. 97–22","children":[],"tail":" substituted “subsection (b) of this section” for “subsections (b) and (c) of this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/60"},"text":"Pub. L. 97–60","children":[],"tail":" added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/s412/1"},"text":"Pub. L. 96–513, § 412(1)","children":[],"tail":", (2), substituted “an officer of an armed force is entitled” for “a reserve officer of an armed force, an officer of the Army or the Air Force without specification of component, or a regular officer of an armed force appointed under section 2106 or 2107 of title 10 is entitled”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/s412/3"},"text":"Pub. L. 96–513, § 412(3)","children":[],"tail":", (4), redesignated subsec. (d) as (c). Former subsec. (c), relating to limitations on qualifications for initial allowances by certain officers, was struck out."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/s412/3"},"text":"Pub. L. 96–513, § 412(3)","children":[],"tail":", struck out subsec. (e) relating to uniform allowances for temporary officers or warrant officers."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/76"},"text":"Pub. L. 96–76","children":[],"tail":" in cl. (1) inserted provisions for applicability to officers on inactive duty training status, and struck out cl. (3) setting forth applicability to officers entitled to basic pay of pay grade O–1, O–2, or O–3."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/278"},"text":"Pub. L. 91–278","children":[],"tail":" provided for entitlement to uniform allowance of enlisted member appointed a warrant officer under "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s213"},"text":"section 213 of title 14","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/83"},"text":"Pub. L. 90–83","children":[],"tail":" substituted “entitled to the basic pay” for “is entitled to the basic pay”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/718"},"text":"Pub. L. 89–718","children":[],"tail":" struck out “, United States Code,” after “title 10”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/444"},"text":"Pub. L. 89–444","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t14/s214"},"text":"section 214 of title 14","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t14/s435"},"text":"section 435 of title 14","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1964—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/647"},"text":"Pub. L. 88–647","children":[],"tail":" included a regular officer of an armed force appointed under section 2106 or 2107 of title 10."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb0a6181d-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb0a6181e-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title VI, § 610(c)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–150, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/398/s1/dA"},"text":"“The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s416"},"text":"section 416 of this title","children":[],"tail":"] shall take effect on "},{"tag":"date","attrib":{"date":"2000-10-01"},"text":"Octobe