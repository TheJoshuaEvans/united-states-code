{"tag":"section","attrib":{"id":"idb0a6180d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s415"},"text":null,"children":[{"tag":"num","attrib":{"value":"415"},"text":"§ 415.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uniform allowance: officers; initial allowance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb0a6180e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s415/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to subsection (b), an officer of an armed force is entitled to an initial allowance of not more than $400 as reimbursement for the purchase of required uniforms and equipment—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0a6180f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s415/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon first reporting for active duty (other than for training) for a period of more than 90 days;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0a61810-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s415/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon completing at least 14 days of active duty as a member of a reserve component;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0a61811-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s415/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon completing 14 periods, each of which was of at least two hours’ duration, of inactive-duty training as a member of the Ready Reserve; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0a61812-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s415/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon reporting for the first period of active duty required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2121/c"},"text":"section 2121(c) of title 10","children":[],"tail":" as a member of the Armed Forces Health Professions Scholarship program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0a61813-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s415/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer who has received an initial uniform reimbursement or allowance under any other law is not entitled to an initial allowance under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0a61814-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s415/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An allowance of $250 for uniforms and equipment may be paid to each commissioned officer of the Public Health Service who is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0a61815-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s415/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on active duty or on inactive duty training status; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0a61816-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s415/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" required by directive of the Surgeon General to wear a uniform.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"An officer is not entitled to more than one allowance under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb0a61817-2930-11f1-a69d-9cbca84c43f0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/649"},"text":"Pub. L. 87–649","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/477"},"text":"76 Stat. 477","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/647/tII/s202/3"},"text":"Pub. L. 88–647, title II, § 202(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-10-13"},"text":"Oct. 13, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/1070"},"text":"78 Stat. 1070","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/444/s2/1"},"text":"Pub. L. 89–444, § 2(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-06-09"},"text":"June 9, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/198"},"text":"80 Stat. 198","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/718/s63"},"text":"Pub. L. 89–718, § 63","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1123"},"text":"80 Stat. 1123","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/83/s5/1"},"text":"Pub. L. 90–83, § 5(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-09-11"},"text":"Sept. 11, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/221"},"text":"81 Stat. 221","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/278/s3/3"},"text":"Pub. L. 91–278, § 3(3)","children":[],"tail":", "},{"tag"