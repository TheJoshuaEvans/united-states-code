ref":"/us/pl/118/159/s624/1"},"text":"Pub. L. 118–159, § 624(1)","children":[],"tail":", struck out “(but not to exceed one privately owned vehicle per member household)” after “privately owned vehicles”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s624/2"},"text":"Pub. L. 118–159, § 624(2)","children":[],"tail":", substituted “privately owned vehicles” for “a privately owned vehicle”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2023—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s635/1"},"text":"Pub. L. 118–31, § 635(1)","children":[],"tail":", substituted “"},{"tag":"inline","attrib":{},"text":"Reimbursement of Qualifying Spouse Relicensing Costs and Business Costs","children":[],"tail":"” for “"},{"tag":"inline","attrib":{},"text":"Reimbursement of Qualifying Spouse Relicensing Costs or Business Costs Incident to a Member’s Permanent Change of Station or Assignment","children":[],"tail":"” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s635/2/A"},"text":"Pub. L. 118–31, § 635(2)(A)","children":[],"tail":", substituted “and qualified business costs” for “or qualified business costs” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s635/2/B"},"text":"Pub. L. 118–31, § 635(2)(B)","children":[],"tail":", amended subpar. (A) generally. Prior to amendment, subpar. (A) read as follows: “the member is reassigned, either as a permanent change of station or permanent change of assignment, between duty stations located in separate jurisdictions with unique licensing or certification requirements and authorities; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s635/2/C"},"text":"Pub. L. 118–31, § 635(2)(C)","children":[],"tail":", substituted “relocation” for “reassignment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s635/3"},"text":"Pub. L. 118–31, § 635(3)","children":[],"tail":", substituted “relocation” for “reassignment” in subpars. (A) and (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s635/4/A"},"text":"Pub. L. 118–31, § 635(4)(A)","children":[],"tail":", substituted “the member’s relocation described in paragraph (1);” for “movement described in paragraph (1)(B) in connection with the member’s change in duty location pursuant to reassignment described in paragraph (1)(A);”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s635/4/B"},"text":"Pub. L. 118–31, § 635(4)(B)","children":[],"tail":", substituted “relocation” for “reassignment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(5)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s635/5/A"},"text":"Pub. L. 118–31, § 635(5)(A)","children":[],"tail":", substituted “the member’s relocation described in paragraph (1);” for “movement described in paragraph (1)(B) in connection with the member’s change in duty location pursuant to reassignment described in paragraph (1)(A);”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(5)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s635/5/B"},"text":"Pub. L. 118–31, § 635(5)(B)","children":[],"tail":", substituted “relocation” for “reassignment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s622/a/1"},"text":"Pub. L. 117–263, § 622(a)(1)","children":[],"tail":", inserted “or Business Costs” after “Relicensing Costs” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s622/a/2"},"text":"Pub. L. 117–263, § 622(a)(2)","children":[],"tail":", inserted “or qualified business costs” after “qualified relicensing costs” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s622/a/3"},"text":"Pub. L. 117–263, § 622(a)(3)","children":[],"tail":", designated existing provisions as subpar. (A), inserted “for qualified relicensing costs” after “subsection”, substituted “$1,000” for “$1000”, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":", §§ 622(a)(4), 623, inserted “or qualified business costs” after “qualified relicensing costs” and substituted “"},{"tag":"date","attrib":{"date":"2029-12-31"},"text":"December 31, 2029","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2024-12-31"},"text":"December 31, 2024","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s622/a/5/A"},"text":"Pub. L. 117–263, § 622(a)(5)(A)","children":[],"tail":", inserted “business license, permit,” after “courses,” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s622/a/5/B"},"text":"Pub. L. 117–263, § 622(a)(5)(B)","children":[],"tail":", inserted “, or owned a business,” before “during”, “professional” before “license”, and “, or business license or permit,” after “certification”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s622/a/5/C"},"text":"Pub. L. 117–263, § 622(a)(5)(C)","children":[],"tail":", inserted “professional” before “license” and “, or business license or permit,” after “certification”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s622/a/6"},"text":"Pub. L. 117–263, § 622(a)(6)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s624"},"text":"Pub. L. 117–263, § 624","children":[],"tail":", added subsec. (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s625"},"text":"Pub. L. 117–263, § 625","children":[],"tail":", added subsec. (i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" struck out subsec. (g). Text read as follows: “A member may be reimbursed as specified in regulations prescribed under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s464"},"text":"section 464 of this title","children":[],"tail":" for travel and related expenses incurred by the member as a result of the cancellation of previously approved leave when the leave is cancelled in conjunction with the member’s participation in a contingency operation and the cancellation occurs within 48 hours of the time the leave would have commenced. The settlement for reimbursement under this subsection is final and conclusive.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s621/h"},"text":"Pub. L. 113–66, § 621(h)","children":[],"tail":", substituted “(including household goods in temporary storage, but excluding packing and crating)” for “(including packing, crating, and household goods in temporary storage)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s621/c/1"},"text":"Pub. L. 113–66, § 621(c)(1)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb0ad440b-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb0ad440c-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Storage of Household Effects","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tV/s503/c"},"text":"Pub. L. 101–510, div. A, title V, § 503(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1558"},"text":"104 Stat. 1558","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tV/s561"},"text":"Pub. L. 103–160, div. A, title V, § 561","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2), "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1668"},"text":"107 Stat. 1668","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tV/s561/f"},"text":"Pub. L. 105–261, div. A, title V, § 561(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2025"},"text":"112 Stat. 2025","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title V, § 571(f)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–134; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVI/s631/f/4/B"},"text":"Pub. L. 112–81, div. A, title VI, § 631(f)(4)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1465"},"text":"125 Stat. 1465","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1076/a/9"},"text":"Pub. L. 112–239, div. A, title X, § 1076(a)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1948"},"text":"126 Stat. 1948","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/239/dA/tX/s1076/a/9"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of a military department shall exercise the authority provided by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s476"},"text":"section 476 of title 37","children":[],"tail":", United States Code, to provide nontemporary storage of baggage and household effects for a period not longer than one year in the case of individuals who are involuntarily separated during the period beginning on "},{"tag":"date","attrib":{"date":"1990-10-01"},"text":"October 1, 1990","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2001-12-31"},"text":"December 31, 2001","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this subsection, the term ‘involuntarily separated’ has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1141"},"text":"section 1141 of title 10","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
