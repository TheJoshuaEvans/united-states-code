{"tag":"section","attrib":{"id":"idb0ad43d4-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453"},"text":null,"children":[{"tag":"num","attrib":{"value":"453"},"text":"§ 453.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowable travel and transportation: specific authorities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb0ad43d5-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In addition to any other authority for the provision of travel and transportation allowances, the administering Secretaries may provide travel and transportation allowances under this subchapter in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0ad43d6-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorized Absence From Temporary Duty Location","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An authorized traveler may be paid travel and transportation allowances, or reimbursed for actual and necessary expenses of travel, incurred at a temporary duty location during an authorized absence from that location.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0ad43d7-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Movement of Personal Property","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0ad43d8-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of a uniformed service may be allowed moving expenses and transportation allowances for self and dependents associated with the movement of personal property and household goods, including such expenses when associated with a self-move.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0ad43d9-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority in paragraph (1) includes the movement and temporary and non-temporary storage of personal property, household goods, and privately owned vehicles in connection with the temporary or permanent move between authorized locations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0ad43da-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For movement of household goods, the administering Secretaries shall prescribe weight allowances in regulations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s464"},"text":"section 464 of this title","children":[],"tail":". The prescribed weight allowances may not exceed 18,000 pounds (including household goods in temporary storage, but excluding packing and crating), except that the administering Secretary may, on a case-by-case basis, authorize additional weight allowances as necessary."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0ad43db-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The administering Secretary may prescribe the terms, rates, and conditions that authorize a member of the uniformed services to ship or store privately owned vehicles.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0ad43dc-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No carrier, port agent, warehouseman, freight forwarder, or other person involved in the transportation of property may have any lien on, or hold, impound, or otherwise interfere with, the movement of baggage and household goods being transported under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0ad43dd-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Unusual or Emergency Circumstances","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An authorized traveler may be provided travel and transportation allowances under this section for unusual, extraordinary, hardship, or emergency circumstances, including circumstances warranting evacuation from a permanent duty assignment location.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0ad43de-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Particular Separation Provisions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The administering Secretary may provide travel-in-kind and transportation-in-kind for the following persons in accordance with regulations prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s464"},"text":"section 464 of this title","children":[],"tail":":"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0ad43df-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member who is retired, or is placed on the temporary disability retired list, under chapter 61 of title 10.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0ad43e0-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member who is retired with pay under any other law or who, immediately following at least eight years of continuous active duty with no single break therein of more than 90 days, is discharged with separation pay or is involuntarily released from active duty with separation pay or readjustment pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0ad43e1-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member who is discharged under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1173"},"text":"section 1173 of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0ad43e2-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Attendance at Memorial Ceremonies and Services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A family member or member of the uniformed services who attends a deceased member’s repatriation, burial, or memorial ceremony or service may be provided travel and transportation allowances to the extent provided in regulations prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s464"},"text":"section 464 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0ad43e3-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement of Qualifying Spouse Relicensing Costs and Business Costs","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0ad43e4-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" From amounts otherwise made available for a fiscal year to provide travel and transportation allowances under this chapter, the Secretary concerned may reimburse a member of the uniformed services for qualified relicensing costs and qualified business costs of the spouse of the member when—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0ad43e5-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the member relocates to a new jurisdiction or geographic area as the result of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb0ad43e6-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/g/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assignment to a duty station;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb0ad43e7-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/g/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a reassignment, either as a result of a permanent change of station or permanent change of assignment, between duty stations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb0ad43e8-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/g/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a transfer from a regular component of a uniformed service into the Selected Reserve of the Ready Reserve of a uniformed service, if the member is authorized a final move from the last duty station to the new jurisdiction or geographic area; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb0ad43e9-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/g/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" placement on the temporary disability retired list under chapter 61 of title 10; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0ad43ea-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the movement of the member’s dependents is authorized at the expense of the United States under this section as part of the relocation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0ad43eb-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0ad43ec-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reimbursement provided to a member under this subsection for qualified relicensing costs may not exceed $1,000 in connection with each relocation described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0ad43ed-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reimbursement provided to a member under this subsection for qualified business costs may not exceed $1,000 in connection with each relocation described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0ad43ee-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No reimbursement may be provided under this subsection for qualified relicensing costs or qualified business costs paid or incurred after ","children":[{"tag":"date","attrib":{"date":"2029-12-31"},"text":"December 31, 2029","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0ad43ef-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this subsection, the term “qualified relicensing costs” means costs, including exam, continuing education courses, business license, permit, and registration fees, incurred by the spouse of a member if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0ad43f0-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/g/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the spouse was licensed or certified in a profession, or owned a business, during the member’s previous duty assignment and requires a new professional license or certification, or business license or permit, to engage in that profession in a new jurisdiction because of the member’s relocation described in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0ad43f1-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/g/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs were incurred or paid to secure or maintain the professional license or certification, or business license or permit, from the new jurisdiction in connection with such relocation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0ad43f2-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this subsection, the term “qualified business costs” means costs, including moving services for equipment, equipment removal, new equipment purchases, information technology expenses, and inspection fees, incurred by the spouse of a member if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0ad43f3-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/g/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the spouse owned a business during the member’s previous duty assignment and the costs result from a the ","children":[{"tag":"ref","attrib":{"idref":"fn002017"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002017"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" member’s relocation described in paragraph (1); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0ad43f4-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/g/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs were incurred or paid to move such business to a new location in connection with such relocation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0ad43f5-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement for Transportation of Pets Arising From Certain Permanent Changes of Stations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0ad43f6-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned may reimburse a member for any cost related to the relocation of a pet that arises from a permanent change of station of such member within the continental United States. Such reimbursement may not exceed $550 for each such permanent change of station.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0ad43f7-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned may reimburse a member for any cost related to the relocation of a pet that arises from a permanent change of station of such member to or from a duty station located outside the continental United States. Such reimbursement may not exceed $4,000 for each such permanent change of station.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0ad43f8-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Attendance at Professional Military Education Institution or Training Classes.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0ad43f9-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of the military department concerned may authorize temporary duty status, and travel and transportation allowances payable to a member in such status, for a member under the jurisdiction of such Secretary who is reassigned—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0ad43fa-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/i/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" between duty stations located within the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0ad43fb-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/i/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a period of not more than one year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0ad43fc-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/i/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the purpose of participating in professional military education or training classes,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0ad43fd-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/i/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with orders to return to the duty station where the member maintains primary residence and the dependents of such member reside.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0ad43fe-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the Secretary of the military department concerned assigns permanent duty status to a member described in paragraph (1), such member shall be eligible for travel and transportation allowances including the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0ad43ff-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transportation, including mileage at the same rate paid for a permanent change of station.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0ad4400-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Per diem while traveling between the permanent duty station and professional military education institution or training site.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0ad4401-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/i/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Per diem paid in the same manner and amount as temporary lodging expenses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0ad4402-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/i/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Per diem equal to the amount of the basic allowance for housing under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s403"},"text":"section 403 of this title","children":[],"tail":" paid to a member—"}],"tail":null},{"tag":"clause","attrib":{"id":"idb0ad4403-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/i/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the grade of such member;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb0ad4404-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/i/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without dependents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb0ad4405-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/i/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who resides in the military housing area in which the professional military education institution or training site is located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0ad4406-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s453/i/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Movement of household goods in an amount determined under applicable regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb0ad4407-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVI/s631/b"},"text":"Pub. L. 112–81, div. A, title VI, § 631(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1457"},"text":"125 Stat. 1457","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tVI/s621/c/1"},"text":"Pub. L. 113–66, div. A, title VI, § 621(c)(1)","children":[],"tail":", (h), "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/783"},"text":"127 Stat. 783","children":[],"tail":", 784; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tV/s522/c"},"text":"Pub. L. 114–328, div. A, title V, § 522(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2116"},"text":"130 Stat. 2116","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tVI/s622/a"},