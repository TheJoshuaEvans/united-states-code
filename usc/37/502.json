:"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"37:32(f) (last 8 words).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1946-08-09/ch931/s2/f"},"text":"Aug. 9, 1946, ch. 931, § 2(f)","children":[],"tail":" (last 8 words), "},{"tag":"html:a","attrib":{"href":"/us/stat/60/963"},"text":"60 Stat. 963","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “After ","children":[{"tag":"date","attrib":{"date":"1946-08-31"},"text":"August 31, 1946","children":[],"tail":"”, in section 33(b) of existing title 37, are omitted as executed. The words “allowance or”, in section 33(b) of existing title 37, are omitted as surplusage. The last sentence of section 33(b) of existing title 37 is omitted as executed, since the Act of "},{"tag":"date","attrib":{"date":"1945-12-28"},"text":"December 28, 1945","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/59/663"},"text":"59 Stat. 663","children":[],"tail":") was repealed by section 506(g) of the Officer Personnel Act of 1947 ("},{"tag":"ref","attrib":{"href":"/us/stat/61/892"},"text":"61 Stat. 892","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a) and (b), the words “, or his designated representative,” are substituted for the last 8 words of section 32(f) of existing title 37.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “Except as provided in subsection (a) of this section” are inserted for clarity. The words “the part of his absence that is more than the number of days’ leave authorized by that section” are substituted for the words “such absence”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb0b1feae-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb0b1feaf-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" inserted at end “Nothing in this subsection may be construed to deprive a member, detailed or assigned by the Secretary concerned as a full-time student at a civilian institution to pursue a program of education that is substantially the same as a program of education offered to civilians, of pay or allowances to which such member is entitled.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" substituted “section 701(g)” for “section 701(h)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s925/g/3/B/i"},"text":"Pub. L. 116–283, § 925(g)(3)(B)(i)","children":[],"tail":", (ii), substituted “the Secretary’s designated representative” for “his designated representative” and substituted “the member” for “he” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s925/g/1/B"},"text":"Pub. L. 116–283, § 925(g)(1)(B)","children":[],"tail":", which directed insertion of “Space Force,” after “Marines Corps,”, was executed by making the insertion after “Marine Corps,” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s925/g/3/B/i"},"text":"Pub. L. 116–283, § 925(g)(3)(B)(i)","children":[],"tail":", (iii), substituted “the Secretary’s designated representative” for “his designated representative” and “the member’s” for “his”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/25"},"text":"Pub. L. 102–25","children":[],"tail":" struck out “of this section” after “subsection (a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661"},"text":"Pub. L. 99–661","children":[],"tail":" inserted “and "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s701/h"},"text":"section 701(h) of title 10","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" substituted “National Oceanic and Atmospheric Administration” for “Environmental Science Services Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/718"},"text":"Pub. L. 89–718","children":[],"tail":" substituted “Environmental Science Services Administration” for “Coast and Geodetic Survey”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb0b1feb0-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb0b1feb1-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/232"},"text":"Pub. L. 117–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2023-01-01"},"text":"Jan. 1, 2023","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/s631/d"},"text":"section 631(d) of Pub. L. 117–263","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s701"},"text":"section 701 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb0b1feb2-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701/b/3"},"text":"section 701(b)(3) of Pub. L. 96–513","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idb0b1feb3-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of authorities, functions, personnel, and assets of the Coast Guard, including the authorities and functions of the Secretary of Transportation relating thereto, to the Department of Homeland Security, and for treatment of related references, see sections 468(b), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
