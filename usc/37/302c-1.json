{"tag":"section","attrib":{"id":"idb0767ca3-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"302c–1"},"text":"§ 302c–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special pay: accession and retention bonuses for psychologists","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb0767ca4-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Accession Bonus.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0767ca5-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Accession bonus authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person described in paragraph (2) who executes a written agreement described in subsection (d) to accept a commission as an officer of the armed forces and remain on active duty for a period of not less than four consecutive years may, upon acceptance of the agreement by the Secretary concerned, be paid an accession bonus in an amount, subject to subsection (c)(1), determined by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0767ca6-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible persons","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person described in paragraph (1) is any person who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0767ca7-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c–1/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a graduate of an accredited school of psychology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0767ca8-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c–1/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" holds a valid State license to practice as a doctoral level psychologist.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0767ca9-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person may not be paid a bonus under this subsection if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0767caa-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c–1/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person, in exchange for an agreement to accept an appointment as an officer, received financial assistance from the Department of Defense to pursue a course of study in psychology; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0767cab-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c–1/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary concerned determines that the person is not qualified to become and remain certified as a psychologist.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0767cac-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Multiyear Retention Bonus.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0767cad-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retention bonus authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer described in paragraph (2) who executes a written agreement described in subsection (d) to remain on active duty for up to four years after completion of any other active-duty service commitment may, upon acceptance of the agreement by the Secretary concerned, be paid a retention bonus as provided in this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0767cae-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible officers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An officer described in paragraph (1) is an officer of the armed forces who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0767caf-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c–1/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a psychologist of the armed forces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0767cb0-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c–1/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in a pay grade below pay grade O–7;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0767cb1-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c–1/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has at least eight years of creditable service (computed as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s302b/f"},"text":"section 302b(f) of this title","children":[],"tail":") or has completed any active-duty service commitment incurred for psychology education and training;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0767cb2-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c–1/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has completed initial residency training (or will complete such training before September 30 of the fiscal year in which the officer enters into the agreement under this subsection); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0767cb3-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c–1/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" holds a valid State license to practice as a doctoral level psychologist.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0767cb4-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum Amount of Bonus.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0767cb5-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Accession bonus","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of an accession bonus under subsection (a) may not exceed $400,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0767cb6-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retention bonus","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of a retention bonus under subsection (b) may not exceed $25,000 for each year of the agreement of the officer concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0767cb7-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The agreement referred to in subsections (a) and (b) shall provide that, consistent with the needs of the armed force concerned, the person or officer executing the agreement will be assigned to duty, for the period of obligated service covered by the agreement, as an officer of such armed force as a psychologist.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0767cb8-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0767cb9-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c–1/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Accession bonus","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person who, after signing an agreement under subsection (a), is not commissioned as an officer of the armed forces, does not become licensed as a psychologist, or does not complete the period of active duty specified in the agreement shall be subject to the repayment provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s303a/e"},"text":"section 303a(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0767cba-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c–1/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retention bonus","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer who does not complete the period of active duty specified in the agreement entered into under subsection (b) shall be subject to the repayment provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s303a/e"},"text":"section 303a(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0767cbb-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c–1/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No agreement under subsection (a) or (b) may be entered into after ","children":[{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb0767cbc-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title VI, § 620(b)(1), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4490"},"text":"122 Stat. 4490","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tVI/s612/b/1"},"text":"Pub. L. 111–84, div. A, title VI, § 612(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2353"},"text":"123 Stat. 2353","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tVI/s612/b/1"},"text":"Pub. L. 111–383, div. A, title VI, § 612(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4236"},"text":"124 Stat. 4236","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVI/s612/b/1"},"text":"Pub. L. 112–81, div. A, title VI, § 612(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1449"},"text":"125 Stat. 1449","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tVI/s612/b/1"},"text":"Pub. L. 112–239, div. A, title VI, § 612(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1776"},"text":"126 Stat. 1776","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tVI/s612/b/1"},"text":"Pub. L. 113–66, div. A, title VI, § 612(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/780"},"text":"127 Stat. 780","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tVI/s612/b/1"},"text":"Pub. L. 113–291, div. A, title VI, § 612(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3400"},"text":"128 Stat. 3400","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tVI/s612/b/1"},"text":"Pub. L. 114–92, div. A, title VI, § 612(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/838"},"text":"129 Stat. 838","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVI/s612/b/1"},"text":"Pub. L. 114–328, div. A, title VI, § 612(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2158"},"text":"130 Stat. 2158","children":[],"tail":"; "},