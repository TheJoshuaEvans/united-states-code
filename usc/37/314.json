{"tag":"section","attrib":{"id":"idb08e49d2-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s314"},"text":null,"children":[{"tag":"num","attrib":{"value":"314"},"text":"§ 314.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special pay or bonus: qualified members extending duty at designated locations overseas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb08e49d3-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s314/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Members","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section applies with respect to a member of an armed force who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb08e49d4-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s314/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is entitled to basic pay;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb08e49d5-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s314/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a specialty that is designated by the Secretary concerned for the purposes of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb08e49d6-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s314/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has completed a tour of duty (as defined in accordance with regulations prescribed by the Secretary concerned) at a location outside the continental United States that is designated by the Secretary concerned for the purposes of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb08e49d7-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s314/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the end of that tour of duty executes an agreement to extend that tour for a period of not less than one year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb08e49d8-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s314/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Pay or Bonus Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon the acceptance by the Secretary concerned of the agreement providing for an extension of the tour of duty of a member described in subsection (a), the member is entitled, at the election of the Secretary concerned, to either—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb08e49d9-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s314/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" special pay in monthly installments in an amount prescribed by the Secretary, but not to exceed $80 per month; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb08e49da-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s314/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an annual bonus in an amount prescribed by the Secretary, but not to exceed $2,000 per year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb08e49db-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s314/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection and Payment of Special Pay or Bonus","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than the date on which the Secretary concerned accepts an agreement described in subsection (a)(4) providing for the extension of a member’s tour of duty, the Secretary concerned shall notify the member regarding whether the member will receive special pay or a bonus under this section. The payment rate for the special pay or bonus shall be fixed at the time of the agreement and may not be changed during the period of the extended tour of duty. The Secretary concerned may pay a bonus under this section either in a lump sum or installments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb08e49dc-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s314/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member who, having entered into a written agreement to extend a tour of duty for a period under subsection (a), receives a bonus payment under subsection (b)(2) for a 12-month period covered by the agreement and ceases during that 12-month period to perform the agreed tour of duty shall be subject to the repayment provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s303a/e"},"text":"section 303a(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb08e49dd-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s314/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of Rest and Recuperative Absence","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member who elects to receive one of the benefits specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s705/b"},"text":"section 705(b) of title 10","children":[],"tail":" as part of the extension of a tour of duty is not entitled to the special pay authorized by subsection (b)(1) for the period of the extension of duty for which the benefit under such section is provided."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb08e49de-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/579/s5/a/1"},"text":"Pub. L. 96–579, § 5(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-23"},"text":"Dec. 23, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3366"},"text":"94 Stat. 3366","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/145/tVI/s641/a"},"text":"Pub. L. 99–145, title VI, § 641(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/652"},"text":"99 Stat. 652","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tVI/s625/a/1"},"text":"Pub. L. 105–85, div. A, title VI, § 625(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1794"},"text":"111 Stat. 1794","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tVI/s654/b/1"},"text":"Pub. L. 107–314, div. A, title VI, § 654(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2582"},"text":"116 Stat. 2582","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tVI/s621/a/1"},"text":"Pub. L. 108–136, div. A, title VI, § 621(a)(1)","children":[],"tail":", (2)(A), "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1505"},"text":"117 Stat. 1505","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tVI/s687/b/23"},"text":"Pub. L. 109–163, div. A, title VI, § 687(b)(23)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3331"},"text":"119 Stat. 3331","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb08e49df-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb08e49e0-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb08e49e1-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the National Defense Authorization Act for Fiscal Year 1998, referred to in subsec. (d)(4), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb08e49e2-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" amended heading and text of subsec. (d) generally, substituting provisions referring to repayment provisions of section 303a(e) for specific provisions relating to refunds required when member receives bonus payment but fails to complete agreed upon extended tour of duty."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s621/a/2/A"},"text":"Pub. L. 108–136, § 621(a)(2)(A)","children":[],"tail":", substituted “qualified members” for “qualified enlisted members” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s621/a/1"},"text":"Pub. L. 108–136, § 621(a)(1)","children":[],"tail":", substituted “a member” for “an enlisted member” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314"},"text":"Pub. L. 107–314","children":[],"tail":" substituted “the continental United States” for “the 48 contiguous States and the District of Columbia”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" amended section catchline and text generally. Prior to amendment, section consisted of subsecs. (a) and (b) relating to special pay for qualified enlisted members extending duty at designated locations overseas."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145"},"text":"Pub. L. 99–145","children":[],"tail":" substituted “$80” for “$50” in provision following par. (4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb08e49e3-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb08e49e4-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tVI/s625/b"},"text":"Pub. L. 105–85, div. A, title VI, § 625(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1795"},"text":"111 Stat. 1795","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/85/dA/tVI/s625/b"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s314"},"text":"Section 314 of title 37","children":[],"tail":", United States Code, as amended by subsection (a), shall apply with respect to an agreement to extend a tour of duty as provided in such section executed on or after "},{"tag":"date","attrib":{"date":"1997-10-01"},"text":"October 1, 1997","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb08e49e5-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145/tVI/s641/b"},"text":"Pub. L. 99–145, title VI, § 641(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/652"},"text":"99 Stat. 652","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/145/tVI/s641/b"},"text":"“The amendment made by subsection (a) [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1985-10-01"},"text":"October 1, 1985","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb08e49e6-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/579/s5/c/1"},"text":"Pub. L. 96–579, § 5(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-23"},"text":"Dec. 23, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3367"},"text":"94 Stat. 3367","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/579/s5/c/1"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s314"},"text":"Section 314 of title 37","children":[],"tail":", United States Code, as added by subsection (a), shall take effect on the first day of the first month following the month in which this section is enacted [Dec. 1980] and shall apply to periods of extended duty overseas beginning before, on, or after such date, but no payment may be made under such section for any month before the first day of the first month following the month in which this section is enacted.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"idb08e49e7-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For savings provision relating to payment or repayment of any bonus, incentive pay, special pay, or similar pay obligated to be paid before ","children":[{"tag":"date","attrib":{"date":"2006-04-01"},"text":"Apr. 1, 2006","children":[],"tail":", under a provision of this section amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s687/b"},"text":"section 687(b) of Pub. L. 109–163","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s687/f"},"text":"section 687(f) of Pub. L. 109–163","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s510"},"text":"section 510 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
