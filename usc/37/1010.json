{"tag":"section","attrib":{"id":"idb0c0564a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s1010"},"text":null,"children":[{"tag":"num","attrib":{"value":"1010"},"text":"§ 1010.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commissioned officers: promotions; effective date for pay and allowances","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"An officer of a uniformed service who is promoted to a grade above second lieutenant or ensign is entitled to the pay and allowances of the grade to which promoted on the effective date of the promotion.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb0c0564b-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/tIV/s403/c"},"text":"Pub. L. 96–513, title IV, § 403(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2905"},"text":"94 Stat. 2905","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tX/s1071/c/8"},"text":"Pub. L. 109–364, div. A, title X, § 1071(c)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2401"},"text":"120 Stat. 2401","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb0c0564c-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb0c0564d-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb0c0564e-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":" substituted “promotions” for “promotion” in section catchline."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb0c0564f-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb0c05650-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1981-09-15"},"text":"Sept. 15, 1981","children":[],"tail":", but the authority to prescribe regulations under this section effective on "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701"},"text":"section 701 of Pub. L. 96–513","children":[],"tail":", set out as an Effective Date of 1980 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
