ub. L. 111–383","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"December 31, 2011","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2010-12-31"},"text":"December 31, 2010","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsecs. (c) to (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s618/b"},"text":"Pub. L. 111–84, § 618(b)","children":[],"tail":", added subsec. (c), redesignated former subsecs. (e) to (i) as (d) to (h), respectively, and struck out former subsecs. (c) and (d), which related to method of payment and reserve component members performing inactive duty training."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s618/b/1"},"text":"Pub. L. 111–84, § 618(b)(1)","children":[],"tail":", redesignated subsec. (i) as (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s614/6"},"text":"Pub. L. 111–84, § 614(6)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2010-12-31"},"text":"December 31, 2010","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2009-12-31"},"text":"December 31, 2009","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417/s618/d"},"text":"Pub. L. 110–417, § 618(d)","children":[],"tail":", substituted “paragraph (1) or (3) of subsection (a)” for “subsection (a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417/s618/e"},"text":"Pub. L. 110–417, § 618(e)","children":[],"tail":", substituted “in connection with determining whether a triggering event has occurred for the provision of hazardous duty pay under subsection (a)(1)” for “in administering subsection (a)” and struck out at end “The regulations prescribed to administer this section shall define the activities that are considered hazardous for purposes of subsection (a)(2).”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb0957626-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb0957627-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reviews of Designations of Imminent Danger Pay Areas","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tVI/s614"},"text":"Pub. L. 119–60, div. A, title VI, § 614","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/907"},"text":"139 Stat. 907","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dA/tVI/s614"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Initial Review","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2026-03-01"},"text":"March 1, 2026","children":[],"tail":", the Secretary of Defense, in coordination with the Secretaries of the military departments, shall—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commence a review of each area designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s351/a/3"},"text":"section 351(a)(3) of title 37","children":[],"tail":", United States Code, to determine whether the area is one in which a member of the uniformed services is subject to imminent danger of physical injury due to threat conditions; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Committees on Armed Services of the Senate and the House of Representatives a report on the review, including any changes to designations under that section that result from the review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subsequent Reviews.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2031-03-01"},"text":"March 1, 2031","children":[],"tail":", and every 5 years thereafter, the Secretary of Defense, in coordination with the Secretaries of the military departments, shall conduct a review described in subsection (a)(1)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 60 days after completing a review under paragraph (1), the Secretary of Defense shall submit to the Committees on Armed Services of the Senate and the House of Representatives a report on the review, including any changes to designations under that section that result from the review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports on Designation Changes Between Reports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If, at any time between the submission of reports required by subsections (a)(2) and (b)(2), the Secretary of Defense or the Secretary of a military department conducts a review of areas designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s351/a/3"},"text":"section 351(a)(3) of title 37","children":[],"tail":", United States Code, and makes a change to any such designation, that Secretary shall submit to the Committees on Armed Services of the Senate and the House of Representatives a report on the review and the change not later than 60 days after the change is made.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
