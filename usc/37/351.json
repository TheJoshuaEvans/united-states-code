{"tag":"section","attrib":{"id":"idb0957608-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s351"},"text":null,"children":[{"tag":"num","attrib":{"value":"351"},"text":"§ 351.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hazardous duty pay","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb0957609-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s351/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Hazardous Duty Pay","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned may pay hazardous duty pay under this section to a member of the uniformed services entitled to basic pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s204"},"text":"section 204 of this title","children":[],"tail":" or compensation under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s206"},"text":"section 206 of this title","children":[],"tail":" who—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb095760a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s351/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performs duty in a hostile fire area designated by the Secretary concerned, is exposed to a hostile fire event, explosion of a hostile explosive device, or any other hostile action, or is on duty during a month in an area in which a hostile event occurred which placed the member in grave danger of physical injury;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb095760b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s351/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performs duty designated by the Secretary concerned as hazardous duty based upon the inherent dangers of that duty and risks of physical injury; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb095760c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s351/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performs duty in a foreign area designated by the Secretary concerned as an area in which the member is subject to imminent danger of physical injury due to threat conditions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb095760d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s351/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum Amount","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of hazardous duty pay paid to a member under subsection (a) shall be based on the type of duty and the area in which the duty is performed, as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb095760e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s351/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a member who performs duty in a designated hostile fire area, as described in subsection (a)(1), hazardous duty pay may not exceed $450 per month.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb095760f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s351/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a member who performs a designated hazardous duty, as described in subsection (a)(2), hazardous duty pay may not exceed $275 per month.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0957610-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s351/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a member who performs duty in a foreign area designated as an imminent danger area, as described in subsection (a)(3), hazardous duty pay may not exceed $275 per month.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0957611-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s351/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Method of Payment; Proration.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0957612-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s351/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Monthly payment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to paragraph (2), hazardous duty pay shall be paid on a monthly basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0957613-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s351/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Proration","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a member does not satisfy the eligibility requirements specified in paragraph (1), (2), or (3) of subsection (a) for an entire month for receipt of hazardous duty pay—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0957614-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s351/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of hazardous duty pay payable under paragraph (1) of subsection (a), the Secretary concerned—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb0957615-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s351/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may prorate the payment amount to reflect the duration of the member’s actual qualifying service during the month; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb0957616-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s351/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a member who is exposed to hostile fire or an explosion of a hostile explosive device in or for a day or portion of a day, may, at the election of the Secretary, pay the member hazardous duty pay in an amount not to exceed the entire amount of hazardous duty pay that would be payable to the member under such paragraph (1) for the month in which the duty concerned occurs (with the total amount of hazardous duty pay paid the member under this clause in any given month not to exceed such entire amount); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0957617-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s351/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of hazardous duty pay payable under paragraph (2) of subsection (a), the Secretary concerned—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb0957618-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s351/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may prorate the payment amount to reflect the duration of the member’s actual qualifying service during the month; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb0957619-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s351/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of member ","children":[{"tag":"ref","attrib":{"idref":"fn002011"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002011"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be preceded by “a”."}],"tail":" who performs hazardous duty specifically designated by the Secretary concerned, shall pay the member hazardous duty pay in an amount not to exceed the maximum amount of hazardous duty pay that would be payable to the member under subsection (b)(2) for the entire month, regardless of the duration of the qualifying service."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb095761a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s351/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of hazardous duty pay payable under paragraph (3) of subsection (a), the Secretary concerned may prorate the payment amount to reflect the duration of the member’s actual qualifying service during the month.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb095761b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s351/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administration and Retroactive Payments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The effective date for the designation of a hostile fire area, as described in paragraph (1) of subsection (a), and for the designation of a foreign area as an imminent danger area, as described in paragraph (3) of such subsection, may be a date that occurs before, on, or after the actual date of the designation by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb095761c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s351/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination of Fact","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any determination of fact that is made in connection with determining whether a triggering event has occurred for the provision of hazardous duty pay under subsection (a)(1) is conclusive. The determination may not be reviewed by any other officer or agency of the United States unless there has been fraud or gross negligence. However, the Secretary concerned may change the determination on the basis of new evidence or for other good cause.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb095761d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s351/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Other Pay and Allowances.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb095761e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s351/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In addition to other pay and allowances","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member may be paid hazardous duty pay under this section in addition to any other pay and allowances to which the member is entitled. The regulations prescribed to administer this section shall address dual compensation under this section for multiple circumstances involving performance of a designated hazardous duty, as described in paragraph (2) of subsection (a), or for duty in certain designated areas, as described in paragraph (1) or (3) of such subsection, that is performed by a member during a single month of service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb095761f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s351/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member may not receive hazardous duty pay under this section for a month for more than three qualifying instances described in subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0957620-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s351/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on Variable Rates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The regulations prescribed to administer this section may not include varied criteria or rates for payment of hazardous duty for officers and enlisted members.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0957621-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s351/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No hazardous duty pay under this section may be paid after ","children":[{"tag":"date","attrib":{"date":"2026-12-31"},"text":"December 31, 2026","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb0957622-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tVI/s661/a/2"},"text":"Pub. L. 110–181, div. A, title VI, § 661(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/172"},"text":"122 Stat. 172","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title VI, § 618(d), (e), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4486"},"text":"122 Stat. 4486","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tVI"},"text":"Pub. L. 111–84, div. A, title VI","children":[],"tail":", §§ 614(6), 618(b), "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2354"},"text":"123 Stat. 2354","children":[],"tail":", 2356; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tVI/s614/6"},"text":"Pub. L. 111–383, div. A, title VI, § 614(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4237"},"text":"124 Stat. 4237","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVI"},"text":"Pub. L. 112–81, div. A, title VI","children":[],"tail":", §§ 614(6), 616(b), "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1450"},"text":"125 Stat. 1450","children":[],"tail":", 1451; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tVI/s614/6"},"text":"Pub. L. 112–239, div. A, title VI, § 614(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1777"},"text":"126 Stat. 1777","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tVI/s614/6"},"text":"Pub. L. 113–66, div. A, title VI, § 614(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/781"},"text":"127 Stat. 781","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tVI/s614/7"},"text":"Pub. L. 113–291, div. A, title VI, § 614(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3401"},"text":"128 Stat. 3401","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tVI/s614/7"},"text":"Pub. L. 114–92, div. A, title VI, § 614(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/839"},"text":"129 Stat. 839","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVI/s614/7"},"text":"Pub. L. 114–328, div. A, title VI, § 614(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2158"},"text":"130 Stat. 2158","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tVI/s614/7"},"text":"Pub. L. 115–91, div. A, title VI, § 614(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1422"},"text":"131 Stat. 1422","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVI/s611/d/6"},"text":"Pub. L. 115–232, div. A, title VI, § 611(d)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1797"},"text":"132 Stat. 1797","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tVI/s611/d/6"},"text":"Pub. L. 116–92, div. A, title VI, § 611(d)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1426"},"text":"133 Stat. 1426","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tVI"},"text":"Pub. L. 116–283, div. A, title VI","children":[],"tail":", §§ 611(d)(6), 613, 614, "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3673"},"text":"134 Stat. 3673","children":[],"tail":", 3674; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tVI/s611/d/6"},"text":"Pub. L. 117–81, div. A, title VI, § 611(d)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"