{"tag":"section","attrib":{"id":"idb093054c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s333"},"text":null,"children":[{"tag":"num","attrib":{"value":"333"},"text":"§ 333.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special bonus and incentive pay authorities for nuclear officers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb093054d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s333/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nuclear Officer Bonus","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Navy may pay a nuclear officer bonus under this section to a person, including an officer in the Navy, who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb093054e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s333/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is selected for the officer naval nuclear power training program in connection with the supervision, operation, and maintenance of naval nuclear propulsion plants and agrees to serve, upon completion of such training, on active duty in connection with the supervision, operation, and maintenance of naval nuclear propulsion plants; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb093054f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s333/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the current technical qualification for duty in connection with the supervision, operation, and maintenance of naval nuclear propulsion plants and agrees to remain on active duty in connection with the supervision, operation, and maintenance of naval nuclear propulsion plants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0930550-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s333/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nuclear Officer Incentive Pay","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Navy may pay nuclear officer incentive pay under this section to an officer in the Navy who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0930551-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s333/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is entitled to basic pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s204"},"text":"section 204 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0930552-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s333/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remains on active duty for a specified period while maintaining current technical qualifications, as approved by the Secretary, for duty in connection with the supervision, operation, and maintenance of naval nuclear propulsion plants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0930553-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s333/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Eligibility Criteria","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Navy may impose such additional criteria for the receipt of a nuclear officer bonus or nuclear officer incentive pay under this section as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0930554-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s333/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum Amount and Method of Payment.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0930555-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s333/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum amount","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Navy shall determine the amounts of a nuclear officer bonus or nuclear officer incentive pay to be paid under this section, except that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0930556-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s333/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nuclear officer bonus paid under subsection (a) may not exceed $75,000 for each 12-month period of the agreement under subsection (e); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0930557-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s333/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of nuclear officer incentive paid under subsection (b) may not exceed $25,000 for each 12-month period of qualifying service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0930558-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s333/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lump sum or installments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A nuclear officer bonus or nuclear officer incentive pay under this section may be paid in a lump sum or in periodic installments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0930559-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s333/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fixing bonus amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon acceptance by the Secretary concerned of the written agreement required by subsection (e), the total amount of the nuclear officer bonus to be paid under the agreement shall be fixed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb093055a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s333/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Written Agreement for Bonus.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb093055b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s333/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreement required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To receive a nuclear officer bonus under subsection (a), a person or officer determined to be eligible for the bonus shall enter into a written agreement with the Secretary of the Navy that specifies—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb093055c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s333/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the bonus;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb093055d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s333/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the method of payment of the bonus under subsection (d)(2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb093055e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s333/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period of obligated service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb093055f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s333/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type or conditions of the service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0930560-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s333/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Replacement agreement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer who is performing obligated service under an agreement for a nuclear officer bonus may execute a new agreement to replace the existing agreement if the amount to be paid under the new agreement will be higher than the amount to be paid under the existing agreement. The period of the new agreement shall be equal to or exceed the remaining term of the period of the officer’s existing agreement. If a new agreement is executed under this paragraph, the existing agreement shall be cancelled, effective on the day before an anniversary date of the existing agreement occurring after the date on which the amount to be paid under this paragraph is increased.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0930561-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s333/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Other Pay and Allowances","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A nuclear officer bonus or nuclear officer incentive pay paid to a person or officer under this section is in addition to any other pay and allowance to which the person or officer is entitled, except that a person or officer may not receive a payment under this section and section 332 or 353 of this title for the same skill and period of service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0930562-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s333/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person or officer who receives a nuclear officer bonus or nuclear officer incentive pay under this section and who fails to complete the officer naval nuclear power training program, maintain required technical and operational qualifications, complete the period of service, or meet the types or conditions of service for which the bonus or incentive pay is paid, as specified in the written agreement under subsection (e) in the case of a nuclear officer bonus, shall be subject to the repayment provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s373"},"text":"section 373 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0930563-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s333/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall be administered under regulations prescribed by the Secretary of the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0930564-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s333/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No agreement may be entered into under this section after ","children":[{"tag":"date","attrib":{"date":"2026-12-31"},"text":"December 31, 2026","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb0930565-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/d