{"tag":"section","attrib":{"id":"idb0c05679-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s1015"},"text":null,"children":[{"tag":"num","attrib":{"value":"1015"},"text":"§ 1015.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recordation of installment payment obligations for incentive pays and similar benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb0c0567a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s1015/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of any pay, allowance, bonus, or other benefit described in subsection (b) that is paid to a member of the uniformed services on an installment basis, each installment payment shall be charged to appropriations that are available for obligation at the time such payment is payable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0c0567b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s1015/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Pay and Benefits","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) applies to any incentive pay, special pay, or bonus, or similar periodic payment of pay or allowances, or of educational benefits or stipends, that is paid to a member of the uniformed services under this title or title 10.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb0c0567c-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tVI/s662/a"},"text":"Pub. L. 114–92, div. A, title VI, § 662(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/859"},"text":"129 Stat. 859","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb0c0567d-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb0c0567e-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb0c0567f-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1015, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tVI/s673/a/1"},"text":"Pub. L. 106–65, div. A, title VI, § 673(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/674"},"text":"113 Stat. 674","children":[],"tail":", related to annual report on effects of recruitment and retention initiatives, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tX/s1046/b/1"},"text":"Pub. L. 109–364, div. A, title X, § 1046(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2393"},"text":"120 Stat. 2393","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
