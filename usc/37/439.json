{"tag":"section","attrib":{"id":"idb0aafa4d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s439"},"text":null,"children":[{"tag":"num","attrib":{"value":"439"},"text":"§ 439.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special compensation: members of the uniformed services with catastrophic injuries or illnesses requiring assistance in everyday living","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb0aafa4e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s439/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Monthly Compensation Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned may pay to any member of the uniformed services described in subsection (b) monthly special compensation in an amount determined under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0aafa4f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s439/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Members","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A member eligible for monthly special compensation authorized by subsection (a) is a member who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0aafa50-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s439/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a catastrophic injury or illness that was incurred or aggravated in the line of duty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0aafa51-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s439/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been certified by a licensed physician to be in need of assistance from another person to perform the personal functions required in everyday living;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0aafa52-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s439/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the absence of the provision of such assistance, would require hospitalization, nursing home care, or other residential institutional care; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0aafa53-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s439/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets such other criteria, if any, as the Secretary of Defense (or the Secretary of Homeland Security, with respect to the Coast Guard) prescribes for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0aafa54-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s439/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of monthly special compensation payable to a member under subsection (a) shall be the amount as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0aafa55-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s439/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The monthly amount of aid and attendance payable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1114/r/2"},"text":"section 1114(r)(2) of title 38","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0aafa56-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s439/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon the establishment by the Secretary of Veterans Affairs pursuant to subparagraph (C) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1720G/a/3"},"text":"section 1720G(a)(3) of title 38","children":[],"tail":" of the schedule of monthly personal caregiver stipends under the Department of Veterans Affairs program of comprehensive assistance for family caregivers under subparagraph (A)(ii)(V) of such section, the monthly personal caregiver stipend payable with respect to similarly circumstanced veterans under such schedule, rather than the amount specified in paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0aafa57-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s439/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duration","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The eligibility of a member to receive special monthly compensation under subsection (a) expires on the earlier of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0aafa58-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s439/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The last day of the month during which a 90-day period ends that begins on the date of the separation or retirement of the member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0aafa59-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s439/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The last day of the month during which the member dies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0aafa5a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s439/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The last day of the month during which the member is determined to be no longer afflicted with the catastrophic injury or illness referred to in subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0aafa5b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s439/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The last day of the month preceding the month during which the member begins receiving compensation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1114/r/2"},"text":"section 1114(r)(2) of title 38","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0aafa5c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s439/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction With Other Pay and Allowances","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Monthly special compensation payable to a member under this section is in addition to any other pay and allowances payable to the member by law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0aafa5d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s439/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Benefit Information","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0aafa5e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s439/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense, in collaboration with the Secretary of Veterans Affairs, shall ensure that members of the uniformed services who may be eligible for compensation under this section are made aware of the availability of such compensation by including information about such compensation in written and online materials for such members and their families.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0aafa5f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s439/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall ensure that a member eligible to receive special monthly compensation under this section is aware that the member’s eligibility for such compensation will expire pursuant to subsection (d)(1) after the end of the 90-day period that begins on the date of the separation or retirement of the member even though the member has not begun to receive compensation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1114/r/2"},"text":"section 1114(r)(2) of title 38","children":[],"tail":" before the end of such period."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0aafa60-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s439/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Catastrophic Injury or Illness Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “catastrophic injury or illness” means a permanent, severely disabling injury, disorder, or illness that the Secretary concerned determines compromises the ability of the afflicted person to carry out the activities of daily living to such a degree that the person requires—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0aafa61-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s439/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personal or mechanical assistance to leave home or bed; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0aafa62-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s439/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" constant supervision to avoid physical harm to self or others.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0aafa63-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s439/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense (or the Secretary of Homeland Security, with respect to the Coast Guard) shall prescribe regulations to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb0aafa64-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tVI/s603/a"},"text":"Pub. L. 111–84, div. A, title VI, § 603(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2348"},"text":"123 Stat. 2348","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tVI/s634"},"text":"Pub. L. 111–383, div. A, title VI, § 634","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4241"},"text":"124 Stat. 4241","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb0aafa65-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb0aafa66-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb0aafa67-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383"},"text":"Pub. L. 111–383","children":[],"tail":" amended subsec. (c) generally. Prior to amendment, subsec. (c) related to the amount of monthly special compensation payable to a member under subsec. (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
