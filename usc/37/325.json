{"tag":"section","attrib":{"id":"idb090bba5-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s325"},"text":null,"children":[{"tag":"num","attrib":{"value":"325"},"text":"§ 325.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incentive bonus: savings plan for education expenses and other contingencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb090bba6-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s325/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Benefit and Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned may purchase United States savings bonds under this section for a member of the armed forces who is eligible as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb090bba7-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s325/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member who, before completing three years of service on active duty, enters into a commitment to perform qualifying service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb090bba8-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s325/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member who, after completing three years of service on active duty, but not more than nine years of service on active duty, enters into a commitment to perform qualifying service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb090bba9-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s325/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member who, after completing nine years of service on active duty, enters into a commitment to perform qualifying service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb090bbaa-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s325/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualifying Service","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this section, qualifying service is service on active duty in a specialty designated by the Secretary concerned as critical to meet requirements (whether or not such specialty is designated as critical to meet wartime or peacetime requirements) for a period that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb090bbab-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s325/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not less than six years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb090bbac-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s325/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include any part of a period for which the member is obligated to serve on active duty under an enlistment or other agreement for which a benefit has previously been paid under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb090bbad-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s325/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Forms of Commitment to Additional Service","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this section, a commitment means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb090bbae-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s325/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an enlisted member, a reenlistment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb090bbaf-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s325/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a commissioned officer, an agreement entered into with the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb090bbb0-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s325/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amounts of Bonds","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The total of the face amounts of the United States savings bonds authorized to be purchased for a member under this section for a commitment shall be as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb090bbb1-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s325/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a purchase for a member under paragraph (1) of subsection (a), $5,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb090bbb2-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s325/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a purchase for a member under paragraph (2) of subsection (a), the amount equal to the excess of $15,000 over the total of the face amounts of any United States savings bonds previously purchased for the member under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb090bbb3-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s325/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a purchase for a member under paragraph (3) of subsection (a), the amount equal to the excess of $30,000 over the total of the face amounts of any United States savings bonds previously purchased for the member under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb090bbb4-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s325/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Total Amount of Benefit","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The total amount of the benefit authorized for a member when United States savings bonds are purchased for the member under this section by reason of a commitment by that member shall be the sum of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb090bbb5-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s325/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchase price of the United States savings bonds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb090bbb6-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s325/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amounts that would be deducted and withheld for the payment of individual income taxes if the total amount computed under this subsection for that commitment were paid to the member as a bonus.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb090bbb7-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s325/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount Withheld for Taxes","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The total amount payable for a member under subsection (e)(2) for a commitment by that member shall be withheld, credited, and otherwise treated in the same manner as amounts deducted and withheld from the basic pay of the member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb090bbb8-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s325/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a person does not complete the qualifying service for which the person is obligated under a commitment for which a benefit has been paid under this section, the person shall be subject to the repayment provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s303a/e"},"text":"section 303a(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb090bbb9-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s325/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Other Special Pays","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The benefit authorized under this section is in addition to any other bonus or incentive or special pay that is paid or payable to a member under any other provision of this chapter for any portion of the same qualifying service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb090bbba-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s325/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall be administered under regulations prescribed by the Secretary of Defense for the armed forces under his jurisdiction and by the Secretary of Homeland Security for the Coast Guard when the Coast Guard is not operating as a service in the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb090bbbb-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tVI/s622/a/1"},"text":"Pub. L. 107–107, div. A, title VI, § 622(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1140"},"text":"115 Stat. 1140","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVII/s1704/c"},"text":"Pub. L. 107–296, title XVII, § 1704(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2314"},"text":"116 Stat. 2314","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tVI/s687/b/33"},"text":"Pub. L. 109–163, div. A, title VI, § 687(b)(33)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3332"},"text":"119 Stat. 3332","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb090bbbc-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb090bbbd-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb090bbbe-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":", amended heading and text of subsec. (g) generally, substituting provisions referring to repayment provisions of section 303a(e) for specific provisions relating to refunds required when person fails to complete qualifying service for which person is obligated under commitment for which benefit was paid."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" substituted “of Homeland Security” for “of Transportation”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb090bbbf-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb090bbc0-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" effective on the date of transfer of the Coast Guard to the Department of Homeland Security, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1704/g"},"text":"section 1704(g) of Pub. L. 107–296","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb090bbc1-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tVI/s622/b"},"text":"Pub. L. 107–107, div. A, title VI, § 622(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1142"},"text":"115 Stat. 1142","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/107/dA/tVI/s622/b"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s325"},"text":"Section 325 of title 37","children":[],"tail":", United States Code, as added by subsection (a), shall apply with respect to reenlistments and other agreements for qualifying service, as described in that section, that are entered into on or after "},{"tag":"date","attrib":{"date":"2001-10-01"},"text":"October 1, 2001","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"idb090bbc2-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For savings provision relating to payment or repayment of any bonus, incentive pay, special pay, or similar pay obligated to be paid before ","children":[{"tag":"date","attrib":{"date":"2006-04-01"},"text":"Apr. 1, 2006","children":[],"tail":", under a provision of this section amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s687/b"},"text":"section 687(b) of Pub. L. 109–163","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s687/f"},"text":"section 687(f) of Pub. L. 109–163","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s510"},"text":"section 510 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
