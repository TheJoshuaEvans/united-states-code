{"tag":"section","attrib":{"id":"idb0c0566d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s1014"},"text":null,"children":[{"tag":"num","attrib":{"value":"1014"},"text":"§ 1014.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment date for pay and allowances","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb0c0566e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s1014/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts of basic pay, basic allowance for housing, basic allowance for subsistence, and other payments of military compensation (other than travel and transportation allowances and separation allowances) shall be paid on the first day of the month beginning after the month during which the right to such compensation accrues.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0c0566f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s1014/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (a) does not preclude one payment in midmonth for any element of compensation and does not affect any authority to make advance payments of pay and allowances.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0c05670-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s1014/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to a member of the uniformed services who has elected to participate in the Thrift Savings Plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s211"},"text":"section 211 of this title","children":[],"tail":", subsection (a) does not preclude the payment of an amount equal to one-half of the monthly deposit to the Thrift Savings Fund otherwise to be made by the member in participating in the Plan, which amount may be deposited in the Thrift Savings Fund at midmonth."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb0c05671-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500/s101/c/tIX/s9103/1"},"text":"Pub. L. 99–500, § 101(c) [title IX, § 9103(1)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1783-82"},"text":"100 Stat. 1783–82","children":[],"tail":", 1783–118, and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/s101/c/tIX/s9103/1"},"text":"Pub. L. 99–591, § 101(c) [title IX, § 9103(1)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-30"},"text":"Oct. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3341-82"},"text":"100 Stat. 3341–82","children":[],"tail":", 3341–118, § 1013; renumbered § 1014, "},{"tag":"ref","attrib":{"href":"/us/pl/100/26/s8/b/2"},"text":"Pub. L. 100–26, § 8(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-04-21"},"text":"Apr. 21, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/285"},"text":"101 Stat. 285","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tVI/s603/d/1/E"},"text":"Pub. L. 105–85, div. A, title VI, § 603(d)(1)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1782"},"text":"111 Stat. 1782","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tVI/s605/a"},"text":"Pub. L. 110–181, div. A, title VI, § 605(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/146"},"text":