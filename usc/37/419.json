{"tag":"section","attrib":{"id":"idb0a88860-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s419"},"text":null,"children":[{"tag":"num","attrib":{"value":"419"},"text":"§ 419.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civilian clothing allowance","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Under regulations prescribed by the Secretary of Defense, an officer of an armed force who is assigned to a permanent duty station at a location outside the United States may be paid a civilian clothing allowance in such amount as the Secretary shall determine under regulations if such officer is required to wear civilian clothing all or a substantial portion of the time in the performance of the officer’s official duties. A clothing allowance under this section is in addition to any uniform allowance to which an officer is otherwise entitled under this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb0a88861-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180/dA/tVI/s611/a/1/B"},"text":"Pub. L. 100–180, div. A, title VI, § 611(a)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1093"},"text":"101 Stat. 1093","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/456/dA/tVI/s625"},"text":"Pub. L. 100–456, div. A, title VI, § 625","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1984"},"text":"102 Stat. 1984","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tVI/s653/c/2"},"text":"Pub. L. 101–189, div. A, title VI, § 653(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1462"},"text":"103 Stat. 1462","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb0a88862-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb0a88863-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb0a88864-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 419 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s420"},"text":"section 420 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb0a88865-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189"},"text":"Pub. L. 101–189","children":[],"tail":" substituted “an officer” for “a officer” in two places and struck out “to” after “may be paid”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456"},"text":"Pub. L. 100–456","children":[],"tail":" substituted “officer” for “member” in three places, “may be paid” for “is entitled”, and “officer’s” for “member’s”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb0a88866-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb0a88867-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180/dA/tVI/s611/b"},"text":"Pub. L. 100–180, div. A, title VI, § 611(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1093"},"text":"101 Stat. 1093","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/180/dA/tVI/s611/b"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s419"},"text":"Section 419 of title 37","children":[],"tail":", United States Code, as added by subsection (a), shall take effect on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":"]. No member may be paid a clothing allowance under such section for any period before such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
