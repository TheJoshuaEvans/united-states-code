{"tag":"section","attrib":{"id":"idb09575f8-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s336"},"text":null,"children":[{"tag":"num","attrib":{"value":"336"},"text":"§ 336.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracting bonus for cadets and midshipmen enrolled in the Senior Reserve Officers’ Training Corps","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb09575f9-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s336/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contracting Bonus Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned may pay a bonus under this section to a cadet or midshipman enrolled in the Senior Reserve Officers’ Training Corps who executes a written agreement described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09575fa-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s336/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount of Bonus","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of a bonus under subsection (a) may not exceed $5,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09575fb-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s336/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A written agreement referred to in subsection (a) is a written agreement by the cadet or midshipman—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb09575fc-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s336/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to complete field training or a practice cruise under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2104/b/6/A/ii"},"text":"section 2104(b)(6)(A)(ii) of title 10","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09575fd-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s336/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to complete advanced training under chapter 103 of title 10;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09575fe-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s336/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to accept a commission or appointment as an officer of the armed forces; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09575ff-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s336/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to serve on active duty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0957600-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s336/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment Method","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon acceptance of a written agreement under subsection (a) by the Secretary concerned, the total amount of the bonus payable under the agreement becomes fixed. The agreement shall specify when the bonus will be paid and whether the bonus will be paid in a lump sum or in installments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0957601-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s336/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person who, having received all or part of a bonus under subsection (a), fails to fulfill the terms of the written agreement required by such subsection for receipt of the bonus shall be subject to the repayment provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s373"},"text":"section 373 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0957602-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s336/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned shall issue such regulations as may be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0957603-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s336/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No agreement under this section may be entered into after ","children":[{"tag":"date","attrib":{"date":"2026-12-31"},"text":"December 31, 2026","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb0957604-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tVI/s617/a"},"text":"Pub. L. 113–66, div. A, title VI, § 617(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/781"},"text":"127 Stat. 781","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tVI/s614/6"},"text":"Pub. L. 113–291, div. A, title VI, § 614(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3401"},"text":"128 Stat. 3401","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tVI/s614/6"},"text":"Pub. L. 114–92, div. A, title VI, § 614(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/839"},"text":"129 Stat. 839","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVI/s614/6"},"text":"Pub. L. 114–328, div. A, title VI, § 614(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2158"},"text":"130 Stat. 2158","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tVI/s614/6"},"text":"Pub. L. 115–91, div. A, title VI, § 614(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1422"},"text":"131 Stat. 1422","children":[],"tail":"; 