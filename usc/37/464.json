{"tag":"section","attrib":{"id":"idb0ad4447-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s464"},"text":null,"children":[{"tag":"num","attrib":{"value":"464"},"text":"§ 464.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"This subchapter and subchapter I shall be administered under terms, rates, conditions, and regulations prescribed by the Secretary of Defense in consultation with the other administering Secretaries for members of the uniformed services. Such regulations shall be uniform for the Department of Defense and shall apply as uniformly as practicable to the uniformed services under the jurisdiction of the other administering Secretaries.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb0ad4448-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVI/s631/b"},"text":"Pub. L. 112–81, div. A, title VI, § 631(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1460"},"text":"125 Stat. 1460","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb0ad4449-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb0ad444a-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb0ad444b-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Travel and Transportation Allowances: Prohibition of Requirement of Zero-Emission Vehicle","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tVI/s626"},"text":"Pub. L. 118–159, div. A, title VI, § 626","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1935"},"text":"138 Stat. 1935","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/159/dA/tVI/s626"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Joint Travel Regulations for the Uniformed Services may not require that travel or transportation be in a zero-emission vehicle in order to be eligible a travel or transportation allowance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section shall not be construed to prohibit the payment of such an allowance in the case of a member of the uniformed services who uses a zero-emission vehicle for travel or transportation that—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the member owns; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is provided to such member by a rental company.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
