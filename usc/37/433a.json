{"tag":"section","attrib":{"id":"idb0aaf9f6-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s433a"},"text":null,"children":[{"tag":"num","attrib":{"value":"433a"},"text":"§ 433a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowance for participation in Ready Reserve screening","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb0aaf9f7-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s433a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allowance Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0aaf9f8-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s433a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under regulations prescribed by the Secretaries concerned, a member of the Individual Ready Reserve may be paid a stipend for participation in the screening performed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s10149"},"text":"section 10149 of title 10","children":[],"tail":", in lieu of muster duty performed under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12319"},"text":"section 12319 of title 10","children":[],"tail":", if such participation is conducted through electronic means."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0aaf9f9-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s433a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The stipend paid a member under this section shall constitute the sole monetary allowance authorized for participation in the screening described in paragraph (1), and shall constitute payment in full to the member for participation in such screening, regardless of the grade or rank in which the member is serving.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0aaf9fa-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s433a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum Payment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The aggregate amount of the stipend paid a member of the Individual Ready Reserve under this section in any calendar year may not exceed $50.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0aaf9fb-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s433a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0aaf9fc-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s433a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The stipend authorized by this section may not be disbursed in kind.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0aaf9fd-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s433a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payment of a stipend to a member of the Individual Ready Reserve under this section for participation in screening shall be made on or after the date of participation in such screening, but not later than 30 days after such date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb0aaf9fe-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tVI/s633/a/1"},"text":"Pub. L. 110–181, div. A, title VI, § 633(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/154"},"text":"122 Stat. 154","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
