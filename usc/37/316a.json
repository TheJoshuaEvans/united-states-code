{"tag":"section","attrib":{"id":"idb08e4a17-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s316a"},"text":null,"children":[{"tag":"num","attrib":{"value":"316a"},"text":"§ 316a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special pay: incentive pay for members of precommissioning programs pursuing foreign language proficiency","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb08e4a18-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s316a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Incentive Pay","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense may pay incentive pay under this section to an individual who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb08e4a19-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s316a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is enrolled as a member of the Senior Reserve Officers’ Training Corps or the Marine Corps Platoon Leaders Class, as determined in accordance with regulations prescribed by the Secretary of Defense under subsection (e); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb08e4a1a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s316a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participates in a language immersion program approved for purposes of the Senior Reserve Officers’ Training Corps, or in study abroad, or is enrolled in an academic course that involves instruction in a foreign language of strategic interest to the Department of Defense as designated by the Secretary of Defense for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb08e4a1b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s316a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Period of Payment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Incentive pay is payable under this section to an individual described in subsection (a) for the period of the individual’s participation in the language program or study described in paragraph (2) of that subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb08e4a1c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s316a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of incentive pay payable to an individual under this section may not exceed $3,000 per year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb08e4a1d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s316a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual who is paid incentive pay under this section but who does not satisfactorily complete participation in the individual’s language program or study as described in subsection (a)(2), or who does not complete the requirements of the Senior Reserve Officers’ Training Corps or the Marine Corps Platoon Leaders Class, as applicable, shall be subject to the repayment provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s303a/e"},"text":"section 303a(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb08e4a1e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s316a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall be administered under regulations prescribed by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb08e4a1f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s316a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No incentive pay may be paid under this section after ","children":[{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb08e4a20-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title VI, § 619(b)(1), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4488"},"text":"122 Stat. 4488","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tX/s1065/b"},"text":"Pub. L. 112–81, div. A, title X, § 1065(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag