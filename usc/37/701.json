Notes","id":"idb0b6e0bd-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb0b6e0be-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s925/h/1"},"text":"Pub. L. 116–283, § 925(h)(1)","children":[],"tail":", (2)(A), substituted “Marine Corps, or Space Force” for “or Marine Corps” and “the officer’s” for “his”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s925/h/2/B"},"text":"Pub. L. 116–283, § 925(h)(2)(B)","children":[],"tail":", substituted “the person’s” for “his”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s925/h/1"},"text":"Pub. L. 116–283, § 925(h)(1)","children":[],"tail":", (2)(C), substituted “Marine Corps, or Space Force” for “or Marine Corps” and “the member’s pay, and if the member does so” for “his pay, and if he does so”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s925/h/1"},"text":"Pub. L. 116–283, § 925(h)(1)","children":[],"tail":", substituted “Marine Corps, or Space Force” for “or Marine Corps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" added subsecs. (d) and (e) and struck out former subsec. (d) which read as follows: “The Secretary of the military department concerned, may allow a—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) member of the Army, Navy, Air Force, or Marine Corps; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) contract surgeon of the Army, Navy, or Air Force;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"to make allotments from his pay for the support of his relatives, or for any other purpose that the Secretary concerned considers proper. If an allotment made under this subsection is paid to the allottee before the disbursing officer receives a notice of discontinuance from the officer required by regulation to furnish the notice, the amount of the allotment shall be credited to the disbursing officer. If an allotment is erroneously paid because the officer required by regulation to so report failed to report the death of the allotter or any other fact that makes the allotment not payable, the amount of the payment not recovered from the allottee shall, if practicable, be collected by the Secretary concerned, from the officer who failed to make the report.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/25"},"text":"Pub. L. 102–25","children":[],"tail":" struck out “of this section” after “subsection (a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145/s683/a/2"},"text":"Pub. L. 99–145, § 683(a)(2)","children":[],"tail":", inserted reference to Navy and Marine Corps in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145/s683/a/1/A"},"text":"Pub. L. 99–145, § 683(a)(1)(A)","children":[],"tail":", (C), substituted “Secretary of the military department concerned” for “Secretary of the Army or the Secretary of the Air Force, as the case may be” and “commissioned officer of the Army, Navy, Air Force, or Marine Corps” for “commissioned officer of the Army or the Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145/s683/a/1/B"},"text":"Pub. L. 99–145, § 683(a)(1)(B)","children":[],"tail":", inserted reference to Navy."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145/s683/a/1/A"},"text":"Pub. L. 99–145, § 683(a)(1)(A)","children":[],"tail":", inserted reference to Navy and Marine Corps."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145/s683/a/1/C"},"text":"Pub. L. 99–145, § 683(a)(1)(C)","children":[],"tail":", substituted “Secretary of the military department concerned” for “Secretary of the Army or the Secretary of the Air Force, as the case may be”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145/s683/a/1/A"},"text":"Pub. L. 99–145, § 683(a)(1)(A)","children":[],"tail":", inserted reference to Navy and Marine Corps."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145/s683/a/1/B"},"text":"Pub. L. 99–145, § 683(a)(1)(B)","children":[],"tail":", inserted reference to Navy."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/718"},"text":"Pub. L. 89–718","children":[],"tail":" substituted “Secretary concerned” for “Chief of Finance (in cases involving the Army) or by the Secretary of the Air Force” in provision for collection erroneously paid allotments."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb0b6e0bf-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb0b6e0c0-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tVI/s651/b"},"text":"Pub. L. 104–201, div. A, title VI, § 651(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2582"},"text":"110 Stat. 2582","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/201/dA/tVI/s651/b"},"text":"“The Secretaries of the military departments shall prescribe regulations under subsection (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s701"},"text":"section 701 of title 37","children":[],"tail":", United States Code, as added by subsection (a), not later than "},{"tag":"date","attrib":{"date":"1997-10-01"},"text":"October 1, 1997","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
