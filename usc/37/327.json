{"tag":"section","attrib":{"id":"idb090bbd6-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s327"},"text":null,"children":[{"tag":"num","attrib":{"value":"327"},"text":"§ 327.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incentive bonus: transfer between armed forces","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb090bbd7-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s327/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Incentive Bonus Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A bonus under this section may be paid to an eligible member of a regular component or reserve component of an armed force who executes a written agreement—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb090bbd8-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s327/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to transfer from such regular component or reserve component to a regular component or reserve component of another armed force; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb090bbd9-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s327/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to serve pursuant to such agreement for a period of not less than three years in the component to which transferred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb090bbda-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s327/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Members","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A member is eligible to enter into an agreement under subsection (a) if, as of the date of the agreement, the member—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb090bbdb-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s327/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not failed to satisfactorily complete any term of enlistment in the armed forces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb090bbdc-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s327/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is eligible for reenlistment in the armed forces or, in the case of an officer, is eligible to continue in service in a regular or reserve component of the armed forces; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb090bbdd-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s327/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has fulfilled such requirements for transfer to the component of the armed force to which the member will transfer as the Secretary having jurisdiction over such armed force shall establish.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb090bbde-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s327/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member may enter into an agreement under subsection (a) to transfer to a regular component or reserve component of another armed force only if the Secretary having jurisdiction over such armed force determines that there is shortage of trained and qualified personnel in such component.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb090bbdf-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s327/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount and Payment of Bonus","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb090bbe0-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s327/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A bonus under this section may not exceed $10,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb090bbe1-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s327/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A bonus under this section shall be paid by the Secretary having jurisdiction of the armed force to which the member to be paid the bonus is transferring.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb090bbe2-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s327/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A bonus under this section shall, at the election of the Secretary paying the bonus—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb090bbe3-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s327/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be disbursed to the member in one lump sum when the transfer for which the bonus is paid is approved by the chief personnel officer of the armed force to which the member is transferring; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb090bbe4-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s327/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be paid to the member in annual installments in such amounts as may be determined by the Secretary paying the bonus.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb090bbe5-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s327/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Other Pay and Allowances","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A bonus paid to a member under this section is in addition to any other pay and allowances to which the member is entitled.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb090bbe6-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s327/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member who is paid a bonus under an agreement under this section and who, voluntarily or because of misconduct, fails to serve for the period covered by such agreement shall be subject to the repayment provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s303a/e"},"text":"section 303a(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb090bbe7-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s327/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretaries concerned shall prescribe regulations to carry out this section. Regulations prescribed by the Secretary of a military department under this subsection shall be subject to the approval of the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb090bbe8-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s327/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No agreement under this section may be entered into after ","children":[{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb090bbe9-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tVI"},"text":"Pub. L. 109–163, div. A, title VI","children":[],"tail":", §§ 641(a), 687(b)(35), "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3304"},"text":"119 Stat. 3304","children":[],"tail":", 3333; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tVI"},"text":"Pub. L. 109–364, div. A, title VI","children":[],"tail":", §§ 614(h), 620(a), "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2249"},"text":"120 Stat. 2249","children":[],"tail":", 2252; "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tVI/s615/7"},"text":"Pub. L. 111–84, div. A, title VI, § 615(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2354"},"text":"123 Stat. 2354","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tVI/s615/7"},"text":"Pub. L. 111–383, div. A, title VI, § 615(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4237"},"text":"124 Stat. 4237","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVI/s615/7"},"text":"Pub. L. 112–81, div. A, title VI, § 615(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1451"},"text":"125 Stat. 1451","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tVI/s615/7"},"text":"Pub. L. 112–239, div. A, title VI, § 615(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1777"},"text":"126 Stat. 1777","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tVI/s615/7"},"text":"Pub. L. 113–66, div. A, title VI, § 615(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/781"},"text":"127 Stat. 781","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tVI/s615/8"},"text":"Pub. L. 113–291, div. A, title VI, § 615(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3401"},"text":"128 Stat. 3401","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tVI/s615/8"},"text":"Pub. L. 114–92, div. A, title VI, § 615(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/839"},"text":"129 Stat. 839","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVI/s615/8"},"text":"Pub. L. 114–328, div. A, title VI, § 615(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2159"},"text":"130 Stat. 2159","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tVI/s615/8"},"text":"Pub. L. 115–91, div. A, title VI, § 615(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1423"},"text":"131 Stat. 1423","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb090bbea-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb090bbeb-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb090bbec-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2017-12-31"},"text":"December 31, 2017","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2017-12-31"},"text":"December 31, 2017","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2016-12-31"},"text":"December 31, 2016","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92"},"text":"Pub. L. 114–92","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2016-12-31"},"text":"December 31, 2016","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2015-12-31"},"text":"December 31, 2015","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291"},"text":"Pub. L. 113–291","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2015-12-31"},"text":"December 31, 2015","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2014-12-31"},"text":"December 31, 2014","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66"},"text":"Pub. L. 113–66","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2014-12-31"},"text":"December 31, 2014","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2013-12-31"},"text":"December 31, 2013","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2013-12-31"},"text":"December 31, 2013","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2012-12-31"},"text":"December 31, 2012","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2012-12-31"},"text":"December 31, 2012","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"December 31, 2011","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383"},"text":"Pub. L. 111–383","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"December 31, 2011","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2010-12-31"},"text":"December 31, 2010","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2010-12-31"},"text":"December 31, 2010","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2009-12-31"},"text":"December 31, 2009","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s620/a"},"text":"Pub. L. 109–364, § 620(a)","children":[],"tail":", substituted “$10,000” for “$2,500”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s687/b/35"},"text":"Pub. L. 109–163, § 687(b)(35)","children":[],"tail":", amended heading and text of subsec. (f) generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) A member who is paid a bonus under an agreement under this section and who, voluntarily or because of misconduct, fails to serve for the period covered by such agreement shall refund to the United States an amount which bears the same ratio to the amount of the bonus paid such member as the period which such member failed to serve bears to the total period for which the bonus was paid.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) An obligation to reimburse the United States imposed under paragraph (1) is for all purposes a debt owed to the United States.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) A discharge in bankruptcy under title 11 that is entered less than 5 years after the termination of an agreement under this section does not discharge the person signing such agreement from a debt arising under paragraph (1).”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s614/h"},"text":"Pub. L. 109–364, § 614(h)","children":[],"tail":", substituted “2009” for “2006”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb090bbed-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb090bbee-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tVI/s620/b"},"text":"Pub. L. 109–364, div. A, title VI, § 620(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2252"},"text":"120 Stat. 2252","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/364/dA/tVI/s620/b"},"text":"“The amendment made by subsection (a) [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"2006-10-01"},"text":"October 1, 2006","children":[],"tail":", and shall apply to agreements entered into or revised under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s327"},"text":"section 327 of title 37","children":[],"tail":", United States Code, on or after that date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"idb09304df-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For savings provision relating to payment or repayment of any bonus, incentive pay, special pay, or similar pay obligated to be paid before ","children":[{"tag":"date","attrib":{"date":"2006-04-01"},"text":"Apr. 1, 2006","children":[],"tail":", under a provision of this section amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s687/b"},"text":"section 687(b) of Pub. L. 109–163","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s687/f"},"text":"section 687(f) of Pub. L. 109–163","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s510"},"text":"section 510 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
