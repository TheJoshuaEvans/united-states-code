{"tag":"section","attrib":{"id":"idb0740b84-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c"},"text":null,"children":[{"tag":"num","attrib":{"value":"302c"},"text":"§ 302c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special pay: psychologists and nonphysician health care providers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb0740b85-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public Health Service Corps","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A member who is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0740b86-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an officer in the Regular or Reserve Corps ","children":[{"tag":"ref","attrib":{"idref":"fn002004"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002004"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Change of Name note below."}],"tail":" of the Public Health Service and is designated as a psychologist; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0740b87-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been awarded a diploma as a Diplomate in Psychology by the American Board of Professional Psychology,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is entitled to special pay, as provided in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0740b88-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rate of Special Pay","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The rate of special pay to which an officer is entitled pursuant to subsection (a) shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0740b89-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,000 per year, if the officer has less than 10 years of creditable service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0740b8a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,500 per year, if the officer has at least 10 but less than 12 years of creditable service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0767c8b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $3,000 per year, if the officer has at least 12 but less than 14 years of creditable service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0767c8c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $4,000 per year, if the officer has at least 14 but less than 18 years of creditable service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0767c8d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000 per year, if the officer has 18 or more years of creditable service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0767c8e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Army, Navy, and Air Force Psychologists","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense may provide special pay at the rates specified in subsection (b) to an officer who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0767c8f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an officer in the Medical Service Corps of the Army or Navy or a biomedical sciences officer in the Air Force;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0767c90-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is designated as a psychologist; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0767c91-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been awarded a diploma as a Diplomate in Psychology by the American Board of Professional Psychology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0767c92-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonphysician Health Care Providers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned may authorize the payment of special pay at the rates specified in subsection (b) to an officer who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0767c93-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an officer in the Medical Service Corps of the Army or Navy, a biomedical sciences officer in the Air Force, an officer in the Army Medical Specialist Corps, an officer of the Nurse Corps of the Army or Navy, an officer of the Air Force designated as a nurse, an officer of the Coast Guard or Coast Guard Reserve designated as a physician assistant, or an officer in the Regular or Reserve Corps ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of the Public Health Service;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0767c94-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a health care provider (other than a psychologist);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0767c95-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a postbaccalaureate degree; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0767c96-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302c/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is certified by a professional board in the officer’s specialty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb0767c97-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/140/s2/a"},"text":"Pub. L. 100–140, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-10-26"},"text":"Oct. 26, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/830"},"text":"101 Stat. 830","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tVII/s704/a"},"text":"Pub. L. 101–189, div. A, title VII, § 704(a)","children":[],"tail":", (b)(1), (c), "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1471"},"text":"103 Stat. 1471","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tVI/s618/a"},"text":"Pub. L. 101–510, div. A, title VI, § 618(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1579"},"text":"104 Stat. 1579","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/25/tVII/s702/a/2/A"},"text":"Pub. L. 102–25, title VII, § 702(a)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-04-06"},"text":"Apr. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/117"},"text":"105 Stat. 117","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tVI/s611"},"text":"Pub. L. 102–484, div. A, title VI, § 611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2420"},"text":"106 Stat. 2420","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tVI/s617"},"text":"Pub. L. 104–106, div. A, title VI, § 617","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/362"},"text":"110 Stat. 362","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tVI/s614/b"},"text":"Pub. L. 104–201, div. A, title VI, § 614(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2544"},"text":"110 Stat. 2544","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tX/s1073/c/5"},"text":"Pub. L. 105–85, div. A, title X, § 1073(c)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1904"},"text":"111 Stat. 1904","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title VI, § 627], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–153; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tX/s1063/b"},"text":"Pub. L. 110–181, div. A, title X, § 1063(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/322"},"text":"122 Stat. 322","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb0767c98-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb0767c99-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb0767c9a-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 302c, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/284/s3/a/1"},"text":"Pub. L. 96–284, § 3(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-28"},"text":"June 28, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/589"},"text":"94 Stat. 589","children":[],"tail":", related to special pay for medical officers of the Public Health Service, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tIV/s414/a"},"text":"Pub. L. 96–513, title IV, § 414(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2906"},"text":"94 Stat. 2906","children":[],"tail":", eff. "},{"tag":"date","attrib":{"date":"1981-09-15"},"text":"Sept. 15, 1981","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb0767c9b-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" substituted “Service Corps” for “Services Corps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":" inserted “an officer of the Coast Guard or Coast Guard Reserve designated as a physician assistant,” after “nurse,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" made technical correction to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/s614/b/2/B"},"text":"Pub. L. 104–201, § 614(b)(2)(B)","children":[],"tail":". See 1996 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s614/b/1"},"text":"Pub. L. 104–201, § 614(b)(1)","children":[],"tail":", substituted “Secretary concerned” for “Secretary of Defense” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s614/b/2/B"},"text":"Pub. L. 104–201, § 614(b)(2)(B)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":", inserted before semicolon at end “, or an officer in the Regular or Reserve Corps of the Public Health Service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s614/b/2/A"},"text":"Pub. L. 104–201, § 614(b)(2)(A)","children":[],"tail":", struck out “or” after “Nurse Corps of the Army or Navy,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" struck out “or” after “Air Force,” and inserted “, an officer of the Nurse Corps of the Army or Navy, or an officer of the Air Force designated as a nurse” before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484"},"text":"Pub. L. 102–484","children":[],"tail":" substituted “Navy,” for “Navy or” and inserted before semicolon at end “, or an officer in the Army Medical Specialist Corps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/25"},"text":"Pub. L. 102–25","children":[],"tail":" amended section catchline generally."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510"},"text":"Pub. L. 101–510","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s704/b/1"},"text":"Pub. L. 101–189, § 704(b)(1)","children":[],"tail":", struck out “in the Public Health Service Corps” after “psychologists” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s704/c"},"text":"Pub. L. 101–189, § 704(c)","children":[],"tail":", inserted headings."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s704/a"},"text":"Pub. L. 101–189, § 704(a)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb0767c9c-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb0767c9d-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to Reserve Corps of the Public Health Service deemed to be a reference to the Ready Reserve Corps, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s204/c/3"},"text":"section 204(c)(3) of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb0767c9e-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tX/s1073/c"},"text":"Pub. L. 105–85, div. A, title X, § 1073(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1904"},"text":"111 Stat. 1904","children":[],"tail":", provided that the amendment made by that section is effective as of "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", and as if included in the National Defense Authorization Act for Fiscal Year 1997, "},{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":", as enacted."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb0767c9f-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/140/s2/c"},"text":"Pub. L. 100–140, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-10-26"},"text":"Oct. 26, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/831"},"text":"101 Stat. 831","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/140/s2/c"},"text":"“The amendments made by this section [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s303a"},"text":"section 303a of this title","children":[],"tail":"] shall take effect on "},{"tag":"date","attrib":{"date":"1987-10-01"},"text":"October 1, 1987","children":[],"tail":" or on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1987-10-26"},"text":"Oct. 26, 1987","children":[],"tail":"], whichever is later, and shall apply with respect to pay periods beginning on or after that effective date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idb0767ca0-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of authorities, functions, personnel, and assets of the Coast Guard, including the authorities and functions of the Secretary of Transportation relating thereto, to the Department of Homeland Security, and for treatment of related references, see sections 468(b), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb0767ca1-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Implementation of Subsection (d)","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tVI/s618/b"},"text":"Pub. L. 101–510, div. A, title VI, § 618(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1579"},"text":"104 Stat. 1