{"tag":"section","attrib":{"id":"idb0b1fed4-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s551"},"text":null,"children":[{"tag":"num","attrib":{"value":"551"},"text":"§ 551.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0b1fed5-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s551/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “dependent”, with respect to a member of a uniformed service, means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0b1fed6-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s551/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" his spouse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0b1fed7-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s551/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" his unmarried child (including an unmarried dependent stepchild or adopted child) under 21 years of age;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0b1fed8-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s551/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" his dependent mother or father;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0b1fed9-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s551/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a dependent designated in official records; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0b1feda-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s551/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person determined to be dependent by the Secretary concerned, or his designee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0b1fedb-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s551/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “missing status” means the status of a member of a uniformed service who is officially carried or determined to be absent in a status of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0b1fedc-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s551/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" missing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0b1fedd-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s551/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" missing in action;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0b1fede-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s551/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interned in a foreign country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0b1fedf-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s551/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" captured, beleaguered, or besieged by a hostile force; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0b1fee0-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s551/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" detained in a foreign country against his will.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0b1fee1-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s551/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “pay and allowances” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0b1fee2-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s551/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" basic pay;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0b1fee3-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s551/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" special pay;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0b1fee4-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s551/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incentive pay;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0b1fee5-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s551/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" basic allowance for housing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0b1fee6-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s551/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" basic allowance for subsistence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0b1fee7-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s551/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" station per diem allowances for not more than 90 days.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb0b1fee8-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554/s5/b"},"text":"Pub. L. 89–554, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/625"},"text":"80 Stat. 625","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/145/tXIII/s1301/g"},"text":"Pub. L. 99–145, title XIII, § 1301(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/737"},"text":"99 Stat. 737","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/26/s8/e/10"},"text":"Pub. L. 100–26, § 8(e)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-04-21"},"text":"Apr. 21, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/287"},"text":"101 Stat. 287","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tVI/s603/d/1/D"},"text":"Pub. L. 105–85, div. A, title VI, § 603(d