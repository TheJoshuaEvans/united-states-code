{"tag":"section","attrib":{"id":"idb0b92afe-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s901"},"text":null,"children":[{"tag":"num","attrib":{"value":"901"},"text":"§ 901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wartime pay of officer of armed force exercising command higher than his grade","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In time of war, an officer of an armed force who is serving with troops operating against an enemy and who exercises, under assignment in orders issued by competent authority, a command above that pertaining to his grade, is entitled to the pay and allowances (not above that of pay grade O–7) appropriate to the command so exercised.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb0b92aff-2930-11f1-a69d-9cbca84c43f0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/649"},"text":"Pub. L. 87–649","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/486"},"text":"76 Stat. 486","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb0b92b00-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb0b92b01-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb0b92b02-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"901","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"37:235a.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1898-04-26/ch191/s7"},"text":"Apr. 26, 1898, ch. 191, § 7","children":[],"tail":" (less last proviso), "},{"tag":"html:a","attrib":{"href":"/us/stat/30/365"},"text":"30 Stat. 365","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Applicability of the source law to the Air Force is based on Transfer Order No. 25(zzz), of the Secretary of Defense, dated ","children":[{"tag":"date","attrib":{"date":"1948-10-14"},"text":"October 14, 1948","children":[],"tail":". Its applicability, other than to the Army and the Air Force, is based upon an opinion of the Judge Advocate General of the Navy, JAG 135: DDC; dmt.; 4229, dated "},{"tag":"date","attrib":{"date":"1960-07-29"},"text":"July 29, 1960","children":[],"tail":". The words “(but not above that of pay grade O–7)” are substituted for section 235a (proviso) of existing title 37."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
