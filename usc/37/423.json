],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “or which hereafter may be” are omitted as surplusage. The words “a person designated by him to investigate the matter” are substituted for the words “such person as he may designate for the purpose”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb0a88892-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb0a88893-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Career Compensation Act of 1949, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-10-12/ch681"},"text":"act Oct. 12, 1949, ch. 681","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/802"},"text":"63 Stat. 802","children":[],"tail":", which was classified principally to chapter 4 (§ 231 et seq.) of former Title 37, Pay and Allowances, prior to the revision and reenactment of Title 37 by "},{"tag":"ref","attrib":{"href":"/us/pl/87/649"},"text":"Pub. L. 87–649","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/451"},"text":"76 Stat. 451","children":[],"tail":". For distribution of sections of chapter 4 of former Title 37, see Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Pay Readjustment Act of 1942, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1942-06-16/ch413"},"text":"act June 16, 1942, ch. 413","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/56/359"},"text":"56 Stat. 359","children":[],"tail":", which was classified principally to chapter 2 (§ 101 et seq.) of former Title 37, Pay and Allowances, prior to the revision and reenactment of title 37 by "},{"tag":"ref","attrib":{"href":"/us/pl/87/649"},"text":"Pub. L. 87–649","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/451"},"text":"76 Stat. 451","children":[],"tail":". For distribution of sections of chapter 2 of former title 37, see Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
