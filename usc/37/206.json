ildren":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tVI/s607"},"text":"Pub. L. 109–364, div. A, title VI, § 607","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2247"},"text":"120 Stat. 2247","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tVI/s633/b"},"text":"Pub. L. 110–181, div. A, title VI, § 633(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/155"},"text":"122 Stat. 155","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tVI/s602/a"},"text":"Pub. L. 116–283, div. A, title VI, § 602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3670"},"text":"134 Stat. 3670","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tVI/s601/b"},"text":"Pub. L. 118–31, div. A, title VI, § 601(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/288"},"text":"137 Stat. 288","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tVI/s601/b/4"},"text":"Pub. L. 119–60, div. A, title VI, § 601(b)(4)","children":[],"tail":", div. G, title LXXII, § 7225(c), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/902"},"text":"139 Stat. 902","children":[],"tail":", 1705.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb060f8d8-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb060f8d9-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb060f8da-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"206(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"37:301(a) (less 45 words before proviso and proviso).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":" 37:301(e) (as applicable to basic pay).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-10-12/ch681/s501/a"},"text":"Oct. 12, 1949, ch. 681, § 501(a)","children":[],"tail":" (less 45 words before proviso), (b) (less 1st sentence), (e) (as applicable to basic pay), "},{"tag":"html:a","attrib":{"href":"/us/stat/63/825"},"text":"63 Stat. 825","children":[],"tail":", 827; "},{"tag":"html:a","attrib":{"href":"/us/act/1956-08-10/ch1041/s20/e"},"text":"Aug. 10, 1956, ch. 1041, § 20(e)","children":[],"tail":", (f), "},{"tag":"html:a","attrib":{"href":"/us/stat/70A/629"},"text":"70A Stat. 629","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"June 30, 1960","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/86/559/s8"},"text":"Pub. L. 86–559, § 8","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/74/282"},"text":"74 Stat. 282","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"206(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"37:301(a) (proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"206(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"32:303(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"[None.]","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"206(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"37:301(b) (less 1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “National Guard” are substituted for the words “National Guard, Air National Guard”, in section 301(a) of existing title 37, to conform to the definition of “National Guard” in section 101(6) of this revised title. The words “member of a reserve component of a uniformed service” are substituted for the words “National Guard of the United States, Air National Guard of the United States, Organized Reserve Corps, Naval Reserve, Air Force Reserve, Marine Corps Reserve, Coast Guard Reserve, and the Reserve Corps of the Public Health Service,” since all of those organizations, or their successors, are the reserve components of the uniformed services. The words “who is not entitled to basic pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s204"},"text":"section 204 of this title","children":[],"tail":"” are substituted for section 301(e) as (applicable to basic pay) of existing title 37. The words “of a corresponding grade” are inserted for clarity."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “National Guard or reserve components” are substituted for the listing of organizations for the reasons set forth above. Reference to “classes of organization,” so far as they relate to the Na