{"tag":"section","attrib":{"id":"idb09304e3-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s329"},"text":null,"children":[{"tag":"num","attrib":{"value":"329"},"text":"§ 329.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incentive bonus: retired members and reserve component members volunteering for high-demand, low-density assignments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb09304e4-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s329/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Incentive Bonus Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may pay a bonus under this section to a retired member or former member of the Army, Navy, Air Force, or Marine Corps or to a member of a reserve component of the Army, Navy, Air Force, or Marine Corps (who is not otherwise serving on active duty) who executes a written agreement to serve on active duty for a period specified in the agreement in an assignment intended to alleviate the need for members in a high-demand, low-density military capability or in any other specialty designated by the Secretary as critical to meet wartime or peacetime requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09304e5-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s329/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum Amount of Bonus","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A bonus under subsection (a) and any incentive developed under subsection (d) may not exceed $50,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09304e6-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s329/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Methods of Payment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"At the election of the Secretary of Defense, a bonus under subsection (a) and any incentive developed under subsection (d) shall be paid or provided—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb09304e7-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s329/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when the member commences service on active duty; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09304e8-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s329/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in annual installments in such amounts as may be determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09304e9-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s329/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Development of Additional Incentives","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb09304ea-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s329/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may develop and provide to members referred to in subsection (a) additional incentives to encourage such members to return to active duty in assignments intended to alleviate the need for members in a high-demand, low-density military capability or in other specialties designated by the Secretary as critical to meet wartime or peacetime requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09304eb-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s329/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provision of any incentive developed under this subsection shall be subject to an agreement, as required for bonuses under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09304ec-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s329/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 30 days before first offering any incentive developed under this subsection, the Secretary shall submit to the congressional defense committees a report that contains a description of that incentive and an explanation why a bonus under subsection (a) or other pay and allowances are not sufficient to alleviate the high-demand, low-density military capability or otherwise fill critical military specialties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09304ed-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s329/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this subsection, the term “congressional defense committees” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/a/16"},"text":"section 101(a)(16) of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09304ee-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s329/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Other Pay and Allowances","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A bonus or other incentive paid or provided to a member under this section is in addition to any other pay and allowances to which the member is entitled.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09304ef-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s329/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on Promotions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The written agreement required by subsections (a) and (d) shall specify that a member who is paid or receives a bonus or other incentive under this section is not eligible for promotion while serving in the assignment for which the bonus or other incentive is provided.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09304f0-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s329/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member who does not complete the period of active duty specified in the agreement executed under subsection (a) or (d) shall be subject to the repayment provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s303a/e"},"text":"section 303a(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09304f1-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s329/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"High-Demand, Low-Density Military Capability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “high-demand, low-density military capability” means a combat, combat support or service support capability, unit, system, or occupational specialty that the Secretary of Defense determines has funding, equipment, or personnel levels that are substantially below the levels required to fully meet or sustain actual or expected operational requirements set by regional commanders.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09304f2-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s329/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may prescribe such regulations as the Secretary considers necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09304f3-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s329/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No agreement under subsection (a) or (d) may be entered into after ","children":[{"tag":"date","attrib":{"date":"2010-12-31"},"text":"December 31, 2010","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb09304f4-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tVI/s621/a"},"text":"Pub. L. 109–364, div. A, title VI, § 621(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2253"},"text":"120 Stat. 2253","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb09304f5-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb09304f6-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb09304f7-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tVI/s621/e"},"text":"Pub. L. 109–364, div. A, title VI, § 621(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2255"},"text":"120 Stat. 2255","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/364/dA/tVI/s621/e"},"text":"“No agreement may be entered into under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s329"},"text":"section 329 of title 37","children":[],"tail":", United States Code, as added by subsection (a), before "},{"tag":"date","attrib":{"date":"2006-10-01"},"text":"October 1, 2006","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
