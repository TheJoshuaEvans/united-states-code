{"tag":"section","attrib":{"id":"idb071c141-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302a"},"text":null,"children":[{"tag":"num","attrib":{"value":"302a"},"text":"§ 302a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special pay: optometrists","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb071c142-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regular Special Pay","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each of the following officers is entitled to special pay at the rate of $100 a month for each month of active duty:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb071c143-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A commissioned officer—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb071c144-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the Regular Army, Regular Navy, or Regular Air Force who is designated as an optometry officer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb071c145-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is an optometry officer of the Regular Corps of the Public Health Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb071c146-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A commissioned officer—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb071c147-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of a Reserve component of the Army, Navy, or Air Force who is designated as an optometry officer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb071c148-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is an optometry officer of the Reserve Corps ","children":[{"tag":"ref","attrib":{"idref":"fn002003"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002003"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Change of Name note below."}],"tail":" of the Public Health Service,"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"who is on active duty as a result of a call or order to active duty for a period of at least one year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb071c149-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A general officer of the Army or the Air Force appointed, from any of the categories named in clause (1) or (2), in the Army, Air Force, or the National Guard, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb071c14a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retention Special Pay","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb071c14b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under regulations prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s303a/a"},"text":"section 303a(a) of this title","children":[],"tail":", the Secretary concerned may pay an officer described in paragraph (2) a retention special pay of not more than $15,000 for any twelve-month period during which the officer is not undergoing an internship or initial residency training."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb071c14c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An officer referred to in paragraph (1) is an officer of a uniformed service who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb071c14d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is entitled to special pay under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb071c14e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has completed any initial active-duty service commitment incurred for education and training; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb071c14f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302a/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is determined by the Secretary concerned to be qualified as an optometrist.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb071c150-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer may not be paid retention special pay under paragraph (1) for any twelve-month period unless the officer first executes a written agreement under which the officer agrees to remain on active duty for a period of not less than one year beginning on the date the officer accepts the award of such special pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb071c151-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned may terminate at any time the eligibility of an officer to receive retention special pay under paragraph (1). An officer who does not complete the period for which the payment was made under paragraph (1) shall be subject to the repayment provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s303a/e"},"text":"section 303a(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb071c152-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/129/tII/s202/a"},"text":"Pub. L. 92–129, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-09-28"},"text":"Sept. 28, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/357"},"text":"85 Stat. 357","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/93/64/tII/s202"},"text":"Pub. L. 93–64, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-07-09"},"text":"July 9, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/149"},"text":"87 Stat. 149","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/114/s2"},"text":"Pub. L. 95–114, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-09-30"},"text":"Sept. 30, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1046"},"text":"91 Stat. 1046","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/485/tVIII/s801/b"},"text":"Pub. L. 95–485, title VIII, § 801(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-20"},"text":"Oct. 20, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1619"},"text":"92 Stat. 1619","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/284/s4/a"},"text":"Pub. L. 96–284, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-28"},"text":"June 28, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/591"},"text":"94 Stat. 591","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/26/s8/d/2"},"text":"Pub. L. 100–26, § 8(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-04-21"},"text":"Apr. 21, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/285"},"text":"101 Stat. 285","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tVI/s617/a"},"text":"Pub. L. 101–510, div. A, title VI, § 617(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1578"},"text":"104 Stat. 1578","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tVI/s614/a"},"text":"Pub. L. 104–201, div. A, title VI, § 614(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2544"},"text":"110 Stat. 2544","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title VI, § 626(a)(1)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–153; "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tVI/s615/d"},"text":"Pub. L. 107–314, div. A, title VI, § 615(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2568"},"text":"116 Stat. 2568","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tVI/s687/b/5"},"text":"Pub. L. 109–163, div. A, title VI, § 687(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3328"},"text":"119 Stat. 3328","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb071c153-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb071c154-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb071c155-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" amended par. (4) generally. Prior to amendment, par. (4) read as follows: “The Secretary concerned may terminate at any time the eligibility of an officer to receive retention special pay under paragraph (1). If such eligibility is terminated, the officer concerned shall receive such special pay only for the part of the period of active duty that the officer served and may be required to refund any amount in excess of that amount.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314"},"text":"Pub. L. 107–314","children":[],"tail":" substituted “$15,000” for “$6,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":" substituted “the Secretary concerned may pay an officer described in paragraph (2) a” for “an officer described in paragraph (2) may be paid”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s614/a/1/A"},"text":"Pub. L. 104–201, § 614(a)(1)(A)","children":[],"tail":", substituted “a uniformed service” for “an armed force” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s614/a/1/B"},"text":"Pub. L. 104–201, § 614(a)(1)(B)","children":[],"tail":", struck out “of the military department” before “concerned to be”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s614/a/2"},"text":"Pub. L. 104–201, § 614(a)(2)","children":[],"tail":", struck out “of the military department” before “concerned may terminate”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510"},"text":"Pub. L. 101–510","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/26"},"text":"Pub. L. 100–26","children":[],"tail":" substituted “A” for “a” at beginning of pars. (1) to (3), “; or” for “, or” at end of par. (1)(A), period for semicolon at end of par. (1)(B), and period for “; and” at end of par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/284"},"text":"Pub. L. 96–284","children":[],"tail":" substituted “Each” for “(a) In addition to any other basic pay, special pay, incentive pay or allowance to which he is entitled, each”, struck out “beginning on or after "},{"tag":"date","attrib":{"date":"1977-10-01"},"text":"October 1, 1977","children":[],"tail":"” after “active duty”, struck out subsec. (b) which prohibited inclusion of active duty monthly special pay in computation of amount of increase in pay authorized in any other provision of this title or in computation of retired pay or severance pay, and struck out subsec. (c) which provided that no special pay be paid for any month after September 1980."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/485"},"text":"Pub. L. 95–485","children":[],"tail":" substituted “September 1980” for “September 1978”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/114"},"text":"Pub. L. 95–114","children":[],"tail":" amended subsec. (a) to provide for the reinstatement of special pay provisions for optometrists for each month on active duty beginning on or after "},{"tag":"date","attrib":{"date":"1977-10-01"},"text":"Oct. 1, 1977","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/114"},"text":"Pub. L. 95–114","children":[],"tail":" reenacted subsec. (b) without change and added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/64"},"text":"Pub. L. 93–64","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1975-07-01"},"text":"July 1, 1975","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1973-07-01"},"text":"July 1, 1973","children":[],"tail":"” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb071c156-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb071c157-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to Reserve Corps of the Public Health Service deemed to be a reference to the Ready Reserve Corps, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s204/c/3"},"text":"section 204(c)(3) of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb071c158-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1977 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/114/s4"},"text":"Pub. L. 95–114, § 4","chi