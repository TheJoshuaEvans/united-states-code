{"tag":"section","attrib":{"id":"idb090bbc3-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s326"},"text":null,"children":[{"tag":"num","attrib":{"value":"326"},"text":"§ 326.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incentive bonus: conversion to military occupational specialty to ease personnel shortage","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb090bbc4-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s326/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Incentive Bonus Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned may pay a bonus under this section to an eligible member of a regular or reserve component of the armed forces who executes a written agreement to convert to, and serve for a period of not less than three years in, a military occupational specialty for which there is a shortage of trained and qualified personnel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb090bbc5-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s326/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Members","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A member is eligible to enter into an agreement under subsection (a) if, at the time the agreement is executed, the member is serving in—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb090bbc6-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s326/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay grade E–6, with not more than 10 years of service computed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s205"},"text":"section 205 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb090bbc7-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s326/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay grade E–5 or below, regardless of years of service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb090bbc8-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s326/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount and Payment of Bonus","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb090bbc9-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s326/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A bonus under this section may not exceed $4,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb090bbca-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s326/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A bonus payable under this section shall be disbursed in one lump sum when the member’s conversion to the military occupational specialty is approved by the chief personnel officer of the regular or reserve component of the member’s armed force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb090bbcb-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s326/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Other Pay and Allowances","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A bonus paid to a member under this section is in addition to any other pay and allowances to which the member is entitled.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb090bbcc-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s326/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member who does not convert to and complete the period of service in the military occupational specialty specified in the agreement executed under subsection (a) shall be subject to the repayment provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s303a/e"},"text":"section 303a(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb090bbcd-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s326/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretaries concerned shall prescribe regulations to carry out this section. Regulations prescribed by the Secretary of a military department shall be subject to the approval of the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb090bbce-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s326/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No agreement under this section may be entered into after ","children":[{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb090bbcf-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tVI/s625/a"},"text":"Pub. L. 108–136, div. A, title VI, § 625(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1506"},"text":"117 Stat. 1506","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tVI/s622"},"text":"Pub. L. 108–375, div. A, title VI, § 622","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1955"},"text":"118 Stat. 1955","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tVI/s687/b/34"},"text":"Pub. L. 109–163, div. A, title VI, § 687(b)(34)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3333"},"text":"119 Stat. 3333","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tVI/s614/g"},"text":"Pub. L. 109–364, div. A, title VI, § 614(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2249"},"text":"120 Stat. 2249","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tVI/s614/f"},"text":"Pub. L. 110–181, div. A, title VI, § 614(f)","children":[