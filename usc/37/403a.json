{"tag":"section","attrib":{"id":"idb0a3cd78-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s403a"},"text":null,"children":[{"tag":"num","attrib":{"value":"403a"},"text":"§ 403a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Housing treatment for certain members of the armed forces, and their spouses and other dependents, undergoing a permanent change of station within the United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb0a3cd79-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s403a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Housing Treatment for Certain Members Who Have a Spouse or Other Dependents.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0a3cd7a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s403a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Housing treatment regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall prescribe regulations that permit a member of the armed forces described in paragraph (2) who is undergoing a permanent change of station within the United States to request the housing treatment described in subsection (b) during the covered relocation period of the member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0a3cd7b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s403a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible members","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A member described in this paragraph is any member who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0a3cd7c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s403a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a spouse who is gainfully employed or enrolled in a degree, certificate or license granting program at the beginning of the covered relocation period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0a3cd7d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s403a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has one or more dependents attending an elementary or secondary school at the beginning of the covered relocation period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0a3cd7e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s403a/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has one or more dependents enrolled in the Exceptional Family Member Program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0a3cd7f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s403a/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is caring for an immediate family member with a chronic or long-term illness at the beginning of the covered relocation period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0a3cd80-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s403a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Housing Treatment.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0a3cd81-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s403a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continuation of housing for the spouse and other dependents","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a spouse or other dependent of a member whose request under subsection (a) is approved resides in Government-owned or Government-leased housing at the beginning of the covered relocation period, the spouse or other dependent may continue to reside in such housing during a period determined in accordance with the regulations prescribed pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0a3cd82-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s403a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Early housing eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a spouse or other dependent of a member whose request under subsection (a) is approved is eligible to reside in Government-owned or Government-leased housing following the member’s permanent change of station within the United States, the spouse or other dependent may commence residing in such housing at any time during the covered relocation period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0a3cd83-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s403a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Temporary use of government-owned or government-leased housing intended for members without a spouse or dependent","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a spouse or other dependent of a member relocates at a time different from the member in accordance with a request approved under subsection (a), the member may be assigned to Government-owned or Government-leased housing intended for the permanent housing of members without a spouse or dependent until the member’s detachment date or the spouse or other dependent’s arrival date, but only if such Government-owned or Government-leased housing is available without displacing a member without a spouse or dependent at such housing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0a3cd84-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s403a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Equitable basic allowance for housing","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a spouse or other dependent of a member relocates at a time different from the member in accordance with a request approved under subsection (a), the amount of basic allowance for housing payable may be based on whichever of the following areas the Secretary concerned determines to be the most equitable:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0a3cd85-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s403a/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The area of the duty station to which the member is reassigned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0a3cd86-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s403a/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The area in which the spouse or other dependent resides, but only if the spouse or other dependent resides in that area when the member departs for the duty station to which the member is reassigned, and only for the period during which the spouse or other dependent resides in that area.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0a3cd87-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s403a/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The area of the former duty station of the member, but only if that area is different from the area in which the spouse or other dependent resides.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0a3cd88-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s403a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction Related to Certain Basic Allowance for Housing Payments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to limit the payment or the amount of basic allowance for housing payable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s403/d/3/A"},"text":"section 403(d)(3)(A) of this title","children":[],"tail":" to a member whose request under subsection (a) is approved."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0a3cd89-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s403a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Housing Treatment Education","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The regulations prescribed pursuant to this section shall ensure the relocation assistance programs under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1056"},"text":"section 1056 of title 10","children":[],"tail":" include, as part of the assistance normally provided under such section, education about the housing treatment available under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0a3cd8a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s403a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0a3cd8b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s403a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered relocation period","children":[],"tail":".—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0a3cd8c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s403a/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to subparagraph (B), the term “covered relocation period”, when used with respect to a permanent change of station of a member of the armed forces, means the period that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb0a3cd8d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s403a/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" begins 180 days before the date of the permanent change of station; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb0a3cd8e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s403a/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ends 180 days after the date of the permanent change of station.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0a3cd8f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s403a/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The regulations prescribed pursuant to this section may provide for a shortening or lengthening of the covered relocation period of a member for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0a3cd90-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s403a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Dependent","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “dependent” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s401"},"text":"section 401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0a3cd91-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s403a/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Permanent change of station","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “permanent change of station” means a permanent change of station described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s452/b/2"},"text":"section 452(b)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb0a3cd92-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tVI/s604/a/1"},"text":"Pub. L. 115–91, div. A, title VI, § 604(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1419"},"text":"131 Stat. 1419","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb0a3cd93-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb0a3cd94-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb0a3cd95-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 403a, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/tVI/s602/d/1"},"text":"Pub. L. 98–525, title VI, § 602(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2534"},"text":"98 Stat. 2534","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/145/tVI"},"text":"Pub. L. 99–145, title VI","children":[],"tail":", §§ 602(a)–(d), 604(b), "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/636-638"},"text":"99 Stat. 636–638","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/26/s8/e/8"},"text":"Pub. L. 100–26, § 8(e)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-04-21"},"text":"Apr. 21, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/286"},"text":"101 Stat. 286","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tVI/s602/a"},"text":"Pub. L. 101–189, div. A, title VI, § 602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1445"},"text":"103 Stat. 1445","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tVI/s602"},"text":"Pub. L. 101–510, div. A, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1575"},"text":"104 Stat. 1575","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/25/tVII/s702/b/1"},"text":"Pub. L. 102–25, title VII, § 702(b)(1)","children":[],"tail":", (2), (c), "},{"tag":"date","attrib":{"date":"1991-04-06"},"text":"Apr. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/117"},"text":"105 Stat. 117","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tVI"},"text":"Pub. L. 102–190, div. A, title VI","children":[],"tail":", §§ 603, 604(b), 633, "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1373"},"text":"105 Stat. 1373","children":[],"tail":", 1374, 1381; "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tVI/s604"},"text":"Pub. L. 103–160, div. A, title VI, § 604","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1679"},"text":"107 Stat. 1679","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tVI/s605/a/1"},"text":"Pub. L. 104–106, div. A, title VI, § 605(a)(1)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/358"},"text":"110 Stat. 358","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tVI"},"text":"Pub. L. 104–201, div. A, title VI","children":[],"tail":", §§ 604(d), 606(a)–(d), "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2541"},"text":"110 Stat. 2541","children":[],"tail":", 2542, related to variable housing allowances, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tVI/s603/c/1"},"text":"Pub. L. 105–85, div. A, title VI, § 603(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1781"},"text":"111 Stat. 1781","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb0a3cd96-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb0a3cd97-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tVI/s604/b"},"text":"Pub. L. 115–91, div. A, title VI, § 604(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1420"},"text":"131 Stat. 1420","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/91/dA/tVI/s604/b"},"text":"“The amendments made by this section [enacting this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"2018-10-01"},"text":"October 1, 2018","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
