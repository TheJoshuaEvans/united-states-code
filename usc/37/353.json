{"tag":"section","attrib":{"id":"idb097e747-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s353"},"text":null,"children":[{"tag":"num","attrib":{"value":"353"},"text":"§ 353.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Skill incentive pay or proficiency bonus","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb097e748-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s353/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Skill Incentive Pay","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned may pay a monthly skill incentive pay to a member of the uniformed services who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb097e749-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s353/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is entitled to basic pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s204"},"text":"section 204 of this title","children":[],"tail":" or compensation under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s206"},"text":"section 206 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb097e74a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s353/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serves in a career field or skill designated as critical by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb097e74b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s353/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Skill Proficiency Bonus.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb097e74c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s353/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability; eligible persons","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned may pay a proficiency bonus to a member of the uniformed services who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb097e74d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s353/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is entitled to basic pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s204"},"text":"section 204 of this title","children":[],"tail":" or compensation under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s206"},"text":"section 206 of this title","children":[],"tail":" or is enrolled in an officer training program; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb097e74e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s353/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is determined to have, and maintains, certified proficiency under subsection (d) in a skill designated as critical by the Secretary concerned or is in training to acquire proficiency in a critical foreign language or expertise in foreign cultural studies or a related skill designated as critical by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb097e74f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s353/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inclusion of certain senior rotc members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A proficiency bonus may be paid under this subsection to a student who is enrolled in the Senior Reserve Officers’ Training Corps program even though the student is in the first year of the four-year course under the program. During the period covered by the proficiency bonus, the student shall also be entitled to a monthly subsistence allowance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s209/c"},"text":"section 209(c) of this title","children":[],"tail":" even though the student has not entered into an agreement under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2103a"},"text":"section 2103a of title 10","children":[],"tail":". However, if the student receives incentive pay under subsection (g)(2) "},{"tag":"ref","attrib":{"idref":"fn002012"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002012"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" for the same period, the student may receive only a single monthly subsistence allowance under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s209/c"},"text":"section 209(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb097e750-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s353/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum Amounts and Methods of Payment.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb097e751-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s353/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Skill incentive pay","children":[],"tail":".—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb097e752-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s353/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Skill incentive pay under subsection (a) may not exceed $1,750 a month.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb097e753-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s353/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a member does not satisfy the eligibility requirements specified in paragraphs (1) and (2) of subsection (a) for an entire month for receipt of skill incentive pay, the Secretary concerned may prorate the payment amount to reflect the duration of the member’s actual qualifying service during the month. A member of a reserve component entitled to compensation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s206"},"text":"section 206 of this title","children":[],"tail":" who is authorized skill incentive pay under subsection (a) may be paid an amount of such pay that is proportionate to the compensation received by the member under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s206"},"text":"section 206 of this title","children":[],"tail":" for inactive-duty training."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb097e754-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s353/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Proficiency bonus","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A proficiency bonus under subsection (b) may be paid in a lump sum at the beginning of the proficiency certification period or in periodic installments during the proficiency certification period. The amount of the bonus may not exceed $55,000 for each 12-month period of certification. The Secretary concerned may not vary the criteria or rates for the proficiency bonus paid for officers and enlisted members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb097e755-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s353/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certified Proficiency for Proficiency Bonus.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb097e756-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s353/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Proficiency in a designated critical skill for purposes of subsection (b) shall be subject to annual certification by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb097e757-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s353/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duration of certification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A certification period for purposes of subsection (c)(2) shall expire at the end of the one-year period beginning on the first day of the first month beginning on or after the certification date.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb097e758-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s353/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding paragraphs (1) and (2), the regulations prescribed to administer this section shall address the circumstances under which the Secretary concerned may waive the certification requirement under paragraph (1) or extend a certification period under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb097e759-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s353/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Written Agreement.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb097e75a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s353/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Discretionary for skill incentive pay","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned may require a member to enter into a written agreement with the Secretary in order to qualify for the payment of skill incentive pay under subsection (a). The written agreement shall specify the period for which the skill incentive pay will be paid to the member and the monthly rate of the pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb097e75b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s353/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required for proficiency bonus","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned shall require a member to enter into a written agreement with the Secretary in order to qualify for payment of a proficiency bonus under subsection (b). The written agreement shall specify the amount of the proficiency bonus, the period for which the bonus will be paid, and the initial certification or recertification necessary for payment of the proficiency bonus.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb097e75c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s353/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Foreign Language Studies in Officer Training Programs.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb097e75d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s353/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of incentive pay","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned may pay incentive pay to a person enrolled in an officer training program to also participate in an education or training program to acquire proficiency in a critical foreign language or expertise in foreign cultural studies or a related skill designated as critical by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb097e75e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s353/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inclusion of certain senior rotc members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Incentive pay may be paid under this subsection to a student who is enrolled in the Senior Reserve Officers’ Training Corps program even though the student is in the first year of the four-year course under the program. While the student receives the incentive pay, the student shall also be entitled to a monthly subsistence allowance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s209/c"},"text":"section 209(c) of this title","children":[],"tail":" even though the student has not entered into an agreement under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2103a"},"text":"section 2103a of title 10","children":[],"tail":". However, if the student receives a proficiency bonus under subsection (b)(2) covering the same month, the student may receive only a single monthly subsistence allowance under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s209/c"},"text":"section 209(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb097e75f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s353/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Critical foreign language defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “critical foreign language” includes Arabic, Korean, Japanese, Chinese, Pashto, Persian-Farsi, Serbian-Croatian, Russian, Portuguese, or other language designated as critical by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb097e760-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s353/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member who receives skill incentive pay or a proficiency bonus under this section and who fails to fulfill the eligibility requirement for receipt of the pay or bonus shall be subject to the repayment provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s373"},"text":"section 373 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb097e761-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s353/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Other Pays and Allowances","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member may not be paid more than one pay under this section in any month for the same period of service and skill. A member may be paid skill incentive pay or the proficiency bonus under this section in addition to any other pay and allowances to which the member is entitled, except that a member may not be paid skill incentive pay or a proficiency bonus under this section and hazardous duty pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s351"},"text":"section 351 of this title","children":[],"tail":" for the same period of service in the same career field or skill."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb097e762-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s353/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No agreement may be entered into under this section after ","children":[{"tag":"date","attrib":{"date":"2026-12-31"},"text":"December 31, 2026","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb097e763-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tVI/s661/a/2"},"text":"Pub. L. 110–181, div. A, title VI, § 661(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/175"},"text":"122 Stat. 175","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title VI, § 619(a), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4487"},"text":"122 Stat. 4487","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tVI"},"text":"Pub. L. 111–84, div. A, title VI","children":[],"tail":", §§ 614(8), 618(d), "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2354"},"text":"123 Stat. 2354","children":[],"tail":", 2356; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tVI/s614/8"},"text":"Pub. L. 111–383, div. A, title VI, § 614(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4237"},"text":"124 Stat. 4237","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVI/s614/8"},"text":"Pub. L. 112–81, div. A, title VI, § 614(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1450"},"text":"125 Stat. 1450","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tVI/s614/8"},"text":"Pub. L. 112–239, div. A, title VI, § 614(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1777"},"text":"126 Stat. 1777","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tVI/s614/8"},"text":"Pub. L. 113–66, div. A, title VI, § 614(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/781"},"text":"127 Stat. 781","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tVI/s614/9"},"text":"Pub. L. 113–291, div. A, title VI, § 614(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3401"},"text":"128 Stat. 3401","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tVI/s614/9"},"text":"Pub. L. 114–92, div. A, title VI, § 614(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/839"},"text":"129 Stat. 839","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVI/s614/9"},"text":"Pub. L. 114–328, div. A, title VI, § 614(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2159"},"text":"130 Stat. 2159","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tVI/s614/9"},"text":"Pub. L. 115–91, div. A, title VI, § 614(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1422"},"text":"131 Stat. 1422","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVI/s611/d/8"},"text":"Pub. L. 115–232, div. A, title VI, § 611(d)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1797"},"text":"132 Stat. 1797","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tVI/s611/d/8"},"text":"Pub. L. 116–92, div. A, title VI, § 611(d)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1426"},"text":"133 Stat. 1426","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tVI/s611/d/8"},"text":"Pub. L. 116–283, div. A, title VI, § 611(d)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3673"},"text":"134 Stat. 3673","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tVI/s611/d/8"},"text":"Pub. L. 117–81, div. A, title VI, § 611(d)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1769"},"text":"135 Stat. 1769","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tVI"},"text":"Pub. L. 117–263, div. A, t