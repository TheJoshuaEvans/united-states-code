 (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s618/d/1"},"text":"Pub. L. 111–84, § 618(d)(1)","children":[],"tail":", redesignated subsecs. (g) to (j) as (f) to (i), respectively, and struck out former subsec. (f) which related to reserve component members performing inactive duty training."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s618/d/1"},"text":"Pub. L. 111–84, § 618(d)(1)","children":[],"tail":", redesignated subsec. (j) as (i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s614/8"},"text":"Pub. L. 111–84, § 614(8)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2010-12-31"},"text":"December 31, 2010","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2009-12-31"},"text":"December 31, 2009","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417/s619/a/1"},"text":"Pub. L. 110–417, § 619(a)(1)","children":[],"tail":", amended subsec. (b) generally. Prior to amendment, text read as follows: “The Secretary concerned may pay a proficiency bonus to a member of a regular or reserve component of the uniformed services who—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) is entitled to basic pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s204"},"text":"section 204 of this title","children":[],"tail":" or compensation under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s206"},"text":"section 206 of this title","children":[],"tail":"; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) is determined to have, and maintains, certified proficiency under subsection (d) in a skill designated as critical by the Secretary concerned.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (g) to (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417/s619/a/2"},"text":"Pub. L. 110–417, § 619(a)(2)","children":[],"tail":", added subsec. (g) and redesignated former subsecs. (g) to (i) as (h) to (j), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb097e768-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb097e769-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Pilot Program for Foreign Language Proficiency Training for Reserve Members","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title VI, § 619(c), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4489"},"text":"122 Stat. 4489","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/417"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pilot program required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall conduct a pilot program to provide a skill proficiency bonus under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s353/b"},"text":"section 353(b) of title 37","children":[],"tail":", United States Code, to a member of a reserve component of the uniformed services who is entitled to compensation under section 206 of such title while the member participates in an education or training program to acquire proficiency in a critical foreign language or expertise in foreign cultural studies or a related skill designated as critical under such section 353."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duration of pilot program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall conduct the pilot program during the period beginning on ","children":[{"tag":"date","attrib":{"date":"2008-10-01"},"text":"October 1, 2008","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2013-12-31"},"text":"December 31, 2013","children":[],"tail":". Incentive pay may not be provided under the pilot program after "},{"tag":"date","attrib":{"date":"2013-12-31"},"text":"December 31, 2013","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reporting requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2012-03-31"},"text":"March 31, 2012","children":[],"tail":", the Secretary shall submit to Congress a report containing the results of the pilot program and the recommendations of the Secretary regarding whether to continue or expand the pilot program.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb097e76a-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Expedited Implementation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title VI, § 619(d), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4489"},"text":"122 Stat. 4489","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tX/s1075/e/10"},"text":"Pub. L. 111–383, div. A, title X, § 1075(e)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4375"},"text":"124 Stat. 4375","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/383/dA/tX/s1075/e/10"},"text":"“Notwithstanding section 662 of the National Defense Authorization Act for Fiscal Year 2008 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Public Law 110–181","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/122/180"},"text":"122 Stat. 180","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s301"},"text":"37 U.S.C. 301","children":[],"tail":" note), the Secretary of a military department may immediately implement the amendments made by subsection (a) [amending this section] in order to ensure the prompt availability of proficiency bonuses and incentive pay under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s353"},"text":"section 353 of title 37","children":[],"tail":", United States Code, as amended by such subsection, for persons enrolled in officer training programs.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
