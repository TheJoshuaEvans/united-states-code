{"tag":"section","attrib":{"id":"idb08e4a25-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s317"},"text":null,"children":[{"tag":"num","attrib":{"value":"317"},"text":"§ 317.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special pay: officers in critical acquisition positions extending period of active duty","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb08e4a26-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s317/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Bonus Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer described in subsection (b) who executes a written agreement to remain on active duty in a critical acquisition position for at least one year may, upon the acceptance of the agreement by the Secretary concerned, be paid a retention bonus as provided in this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb08e4a27-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s317/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Officers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An officer referred to in subsection (a) is an officer of the Army, Navy, Air Force, or Marine Corps who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb08e4a28-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s317/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a member of the acquisition workforce selected to serve in, or serving in, a critical acquisition position designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1731"},"text":"section 1731 of title 10","children":[],"tail":"."},{"tag":"ref","attrib":{"idref":"fn002008"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002008"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The period probably should be “; and”."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb08e4a29-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s317/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is eligible to retire, or is assigned to such position for a period that will extend beyond the date on which the officer will be eligible to retire, under any provision of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb08e4a2a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s317/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount of Bonus","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of a bonus paid under this section for each year a member agrees to remain on active duty may not be more than 15 percent of the annual rate of basic pay paid to the member at the time the member executes a written agreement under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb08e4a2b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s317/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment of Bonus","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon the acceptance of a written agreement under subsection (a) by the Secretary concerned, the total amount payable pursuant to the agreement becomes fixed and may be paid by the Secretary in either a lump sum or installments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb08e4a2c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s317/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Pay","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A bonus paid under this section is in addition to other pay and allowances to which an officer is entitled.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb08e4a2d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s317/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer who, having entered into a written agreement under subsection (a) and having received all or part of a bonus under this section, does not complete the period of active duty as specified in the agreement shall be subject to the repayment provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s303a/e"},"text":"section 303a(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb08e4a2e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s317/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Period of Commitment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The period of active duty agreed upon by an officer in a written agreement under this section is in addition to any other service commitment of the officer, except that any period of active duty agreed upon in a written agreement under subsection (a)(2) or (b)(2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1734"},"text":"section 1734 of title 10","children":[],"tail":" by the officer may be counted concurrently with the commitment under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb08e4a2f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s317/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretaries concerned shall prescribe regulations to carry out this section. Regulations prescribed by the Secretary of a military department shall be subject to the approval of the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb08e4a30-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXII/s1203/a/1"},"text":"Pub. L. 101–510, div. A, title XII, § 1203(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1656"},"text":"104 Stat. 1656","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tVI/s687/b/26"},"text":"Pub. L. 109–163, div. A, title VI, § 687(b)(26)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3331"},"text":"119 Stat. 3331","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tVIII/s861/j/17"},"text":"Pub. L. 116–92, div. A, title VIII, § 861(j)(17)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1520"},"text":"133 Stat. 1520","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb08e4a31-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb08e4a32-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb08e4a33-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":", which directed the general amendment of par. (1) of "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s317"},"text":"section 317 of this title","children":[],"tail":", was executed by making the amendment to par. (1) of subsec. (b) of this section to reflect the probable intent of Congress. Prior to amendment, subsec. (b)(1) read as follows: “is a member of an Acquisition Corps selected to serve in, or serving in, a critical acquisition position designated under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1733"},"text":"section 1733 of title 10","children":[],"tail":"; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" amended heading and text of subsec. (f) generally, substituting provisions referring to repayment provisions of section 303a(e) for specific provisions relating to repayment of bonus required when officer fails to complete total period of agreed upon active duty."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb08e4a34-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb08e4a35-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXII/s1203/b"},"text":"Pub. L. 101–510, div. A, title XII, § 1203(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1658"},"text":"104 Stat. 1658","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/510/dA/tXII/s1203/b"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s317"},"text":"Section 317 of title 37","children":[],"tail":", United States Code, as added by subsection (a), shall take effect as of "},{"tag":"date","attrib":{"date":"1991-10-01"},"text":"October 1, 1991","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"idb08e4a36-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For savings provision relating to payment or repayment of any bonus, incentive pay, special pay, or similar pay obligated to be paid before ","children":[{"tag":"date","attrib":{"date":"2006-04-01"},"text":"Apr. 1, 2006","children":[],"tail":", under a provision of this section amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s687/b"},"text":"section 687(b) of Pub. L. 109–163","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s687/f"},"text":"section 687(f) of Pub. L. 109–163","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s510"},"text":"section 510 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
