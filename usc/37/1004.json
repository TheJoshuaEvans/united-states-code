{"tag":"section","attrib":{"id":"idb0be0cc8-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s1004"},"text":null,"children":[{"tag":"num","attrib":{"value":"1004"},"text":"§ 1004.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation of pay and allowances for month or part of month","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A member of a uniformed service who is entitled to pay and allowances under this title for a continuous period of less than one month is entitled to his pay and allowances for each day of that period at the rate of ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":"⁄"},{"tag":"sub","attrib":{},"text":"30","children":[],"tail":" of the monthly amount of his pay and allowances. The thirty-first day of a calendar month may not be excluded from a computation under this section."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb0be0cc9-2930-11f1-a69d-9cbca84c43f0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/649"},"text":"Pub. L. 87–649","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/490"},"text":"76 Stat. 490","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb0be0cca-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb0be0ccb-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb0be0ccc-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"t