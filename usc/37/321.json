{"tag":"section","attrib":{"id":"idb090bb7e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s321"},"text":null,"children":[{"tag":"num","attrib":{"value":"321"},"text":"§ 321.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special pay: judge advocate continuation pay","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb090bb7f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s321/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Judge Advocate Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “eligible judge advocate” means an officer of the armed forces on full-time active duty who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb090bb80-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s321/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is qualified and serving as a judge advocate, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of title 10","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb090bb81-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s321/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has completed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb090bb82-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s321/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the active duty service obligation incurred through the officer’s original commissioning program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb090bb83-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s321/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an officer detailed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2004"},"text":"section 2004 of title 10","children":[],"tail":" or section 470 "},{"tag":"ref","attrib":{"idref":"fn002009"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002009"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 14, the active duty service obligation incurred as part of that detail."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb090bb84-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s321/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Pay Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An eligible judge advocate who executes a written agreement to remain on active duty for a period of obligated service specified in the agreement may, upon the acceptance of the agreement by the Secretary concerned, be paid continuation pay under this section. The total amount paid to an officer under one or more agreements under this section may not exceed $60,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb090bb85-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s321/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Proration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term of an agreement under subsection (b) and the amount payable under the agreement may be prorated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb090bb86-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s321/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment Methods","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon acceptance of an agreement under subsection (b) by the Secretary concerned, the total amount payable pursuant to the agreement becomes fixed. The Secretary shall prepare an implementation plan specifying the amount of each installment payment under the agreement and the times for payment of the installments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb090bb87-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s321/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Pay","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any amount paid to an officer under this section is in addition to any other pay and allowances to which the officer is entitled.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb090bb88-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s321/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer who has entered into a written agreement under subsection (b) and has received all or part of the amount payable under the agreement but who does not complete the total period of active duty specified in the agreement, shall be subject to the repayment provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s303a/e"},"text":"section 303a(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb090bb89-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s321/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned shall prescribe regulations to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb090bb8a-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tVI/s629/a/1"},"text":"Pub. L. 106–65, div. A, title VI, § 629(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/659"},"text":"113 Stat. 659","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tVI/s687/b/29"},"text":"Pub. L. 109–163, div. A, title VI, § 687(b)(29)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3332"},"text":"119 Stat. 3332","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb090bb8b-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb090bb8c-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb090bb8d-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s470"},"text":"Section 470 of title 14","children":[],"tail":", referred to in subsec. (a)(2)(B), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s2770"},"text":"section 2770 of title 14","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s116/b/2"},"text":"Pub. L. 115–282, title I, § 116(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4226"},"text":"132 Stat. 4226","children":[],"tail":", and references to "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s470"},"text":"section 470 of title 14","children":[],"tail":" deemed to refer to such redesignated section, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/b/1"},"text":"section 123(b)(1) of Pub. L. 115–282","children":[],"tail":", set out as a References to Sections of Title 14 as Redesignated by "},{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s101"},"text":"section 101 of Title 14","children":[],"tail":", Coast Guard."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb090bb8e-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" amended heading and text of subsec. (f) generally, substituting provisions referring to repayment provisions of section 303a(e) for specific provisions relating to repayment required when officer fails to complete total period of agreed upon active duty."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb090bb8f-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb090bb90-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tVI/s629/c"},"text":"Pub. L. 106–65, div. A, title VI, § 629(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/661"},"text":"113 Stat. 661","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/65/dA/tVI/s629/c"},"text":"“The amendments made by subsection (a) [enacting this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1999-10-01"},"text":"October 1, 1999","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"idb090bb91-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For savings provision relating to payment or repayment of any bonus, incentive pay, special pay, or similar pay obligated to be paid before ","children":[{"tag":"date","attrib":{"date":"2006-04-01"},"text":"Apr. 1, 2006","children":[],"tail":", under a provision of this section amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s687/b"},"text":"section 687(b) of Pub. L. 109–163","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s687/f"},"text":"section 687(f) of Pub. L. 109–163","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s510"},"text":"section 510 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
