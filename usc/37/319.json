{"tag":"section","attrib":{"id":"idb090bb51-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s319"},"text":null,"children":[{"tag":"num","attrib":{"value":"319"},"text":"§ 319.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special pay: surface warfare officer continuation pay","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb090bb52-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s319/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Surface Warfare Officer Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “eligible surface warfare officer” means an officer of the Regular Navy or Navy Reserve on active duty who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb090bb53-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s319/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is qualified and serving as a surface warfare officer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb090bb54-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s319/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been selected for assignment as a department head on a surface vessel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb090bb55-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s319/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has completed any service commitment incurred through the officer’s original commissioning program or is within one year of completing such commitment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb090bb56-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s319/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Pay Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An eligible surface warfare officer who executes a written agreement to remain on active duty to complete one or more tours of duty to which the officer may be ordered as a department head on a surface vessel may, upon the acceptance of the agreement by the Secretary of the Navy, be paid an amount not to exceed $50,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb090bb57-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s319/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Proration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term of the written agreement under subsection (b) and the amount payable under the agreement may be prorated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb090bb58-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s319/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment Methods","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon acceptance of the written agreement under subsection (b) by the Secretary of the Navy, the total amount payable pursuant to the agreement becomes fixed. The Secretary shall prepare an implementation plan specifying the amount of each installment payment under the agreement and the times for payment of the installments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb090bb59-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s319/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Pay","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any amount paid under this section is in addition to any other pay and allowances to which an officer is entitled.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb090bb5a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s319/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer who, having entered into a written agreement under subsection (b) and having received all or part of a bonus under this section, does not complete the period of active duty as a department head on a surface vessel as specified in the agreement, shall be subject to the repayment provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s303a/e"},"text":"section 303a(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb090bb5b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s319/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Navy shall prescribe regulations to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb090bb5c-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tVI/s627/a/1"},"text":"Pub. L. 106–65, div. A, title VI, § 627(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/656"},"text":"113 Stat. 656","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tVI/s616/b"},"text":"Pub. L. 107–107, div. A, title VI, § 616(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1137"},"text":"115 Stat. 1137","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tV/s515/d/1/E"},"text":"Pub. L. 109–163, div. A, title V, § 515(d)(1)(E)","children":[],"tail":", title VI, § 687(b)(28), "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3236"},"text":"119 Stat. 3236","children":[],"tail":", 3332.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb090bb5d-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb090bb5e-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb090bb5f-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s515/d/1/E"},"text":"Pub. L. 109–163, § 515(d)(1)(E)","children":[],"tail":", substituted “Navy Reserve” for “Naval Reserve” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s687/b/28"},"text":"Pub. L. 109–163, § 687(b)(28)","children":[],"tail":", amended heading and text of subsec. (f) generally, substituting provisions referring to repayment provisions of section 303a(e) for specific provisions relating to repayment required when officer receives bonus but fails to complete total period of agreed upon active duty as department head on surface vessel."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" inserted “or is within one year of completing such commitment” before period at end."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb090bb60-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb090bb61-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tVI/s627/b"},"text":"Pub. L. 106–65, div. A, title VI, § 627(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/657"},"text":"113 Stat. 657","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/65/dA/tVI/s627/b"},"text":"“The amendments made by subsection (a) [enacting this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1999-10-01"},"text":"October 1, 1999","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"idb090bb62-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For savings provision relating to payment or repayment of any bonus, incentive pay, special pay, or similar pay obligated to be paid before ","children":[{"tag":"date","attrib":{"date":"2006-04-01"},"text":"Apr. 1, 2006","children":[],"tail":", under a provision of this section amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s687/b"},"text":"section 687(b) of Pub. L. 109–163","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s687/f"},"text":"section 687(f) of Pub. L. 109–163","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s510"},"text":"section 510 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
