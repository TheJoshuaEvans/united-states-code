{"tag":"section","attrib":{"id":"idb0aafa6e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451"},"text":null,"children":[{"tag":"num","attrib":{"value":"451"},"text":"§ 451.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb0aafa6f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions Relating to Persons","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subchapter and subchapter II:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0aafa70-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “administering Secretary” or “administering Secretaries” means the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0aafa71-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense, with respect to the armed forces (including the Coast Guard when it is operating as a service in the Navy).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0aafa72-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Homeland Security, with respect to the Coast Guard when it is not operating as a service in the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0aafa73-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Commerce, with respect to the National Oceanic and Atmospheric Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0aafa74-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Health and Human Services, with respect to the Public Health Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0aafa75-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “authorized traveler” means a person who is authorized travel and transportation allowances when performing official travel ordered or authorized by the administering Secretary. Such term includes the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0aafa76-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the uniformed services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0aafa77-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A family member of a member of the uniformed services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0aafa78-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person acting as an escort or attendant for a member or family member who is traveling on official travel or is traveling with the remains of a deceased member or as an escort or attendant for dependents of a member for necessary travel performed not later than one year after the member is unable to accompany the dependents who are incapable of traveling alone.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0aafa79-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person who participates in a military funeral honors detail.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0aafa7a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Senior Reserve Officers’ Training Corps cadet or midshipman.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0aafa7b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An applicant or rejected applicant for enlistment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0aafa7c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person whose employment or service is considered directly related to a Government official activity or function under regulations prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s464"},"text":"section 464 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0aafa7d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any other person not covered by subparagraphs (A) through (G) who is determined by the administering Secretary pursuant to regulations prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s464"},"text":"section 464 of this title","children":[],"tail":" as warranting the provision of travel benefits for purposes of the following:"}],"tail":null},{"tag":"clause","attrib":{"id":"idb0aafa7e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/a/2/H/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transportation of survivors to attend burial services or transfer of deceased members after death overseas as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s453/f"},"text":"section 453(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb0aafa7f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/a/2/H/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transportation of designated individuals incident to the hospitalization of members as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s452/b/12"},"text":"section 452(b)(12) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb0aafa80-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/a/2/H/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transportation of designated individuals incident to the repatriation of members as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s452/b/13"},"text":"section 452(b)(13) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb0aafa81-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/a/2/H/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transportation of non-medical attendants as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s452/b/14"},"text":"section 452(b)(14) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb0aafa82-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/a/2/H/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transportation of designated individuals to attend Yellow Ribbon Reintegration Program events as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s452/b/15"},"text":"section 452(b)(15) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb0aafa83-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/a/2/H/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transportation of a person with regard to a single event when the administering Secretary determines that the travel is necessary to ensure fairness and equity, respond to emergency or humanitarian circumstances, or serve the best interests of the Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb0aafa84-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/a/2/H/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transportation of a dependent child of a member of the uniformed services to the United States to obtain formal secondary, undergraduate, graduate, or vocational education, if the permanent duty assignment location of the member is outside the continental United States (other than in Alaska or Hawaii).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb0aafa85-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/a/2/H/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transportation of a dependent child of a member of the uniformed services within the United States to obtain formal secondary, undergraduate, graduate, or vocational education, if the permanent duty assignment location of the member is in Alaska or Hawaii and the school is located in a State outside of the permanent duty assignment location.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb0aafa86-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/a/2/H/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transportation of a dependent to a location where a member of the uniformed services is on permanent duty aboard a ship that is overhauling, inactivating, or under construction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0aafa87-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “family member”, with respect to a member of the uniformed services, means the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0aafa88-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A dependent, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s401/a"},"text":"section 401(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0aafa89-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A child, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s401/b/1"},"text":"section 401(b)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0aafa8a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A parent, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s401/b/2"},"text":"section 401(b)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0aafa8b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A sibling of the member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0aafa8c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A former spouse of the member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0aafa8d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions Relating to Travel and Transportation Allowances","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subchapter and subchapter II:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0aafa8e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “official travel” means the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0aafa8f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Military duty or official business performed by an authorized traveler away from a duty assignment location or other authorized location.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0aafa90-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Travel performed by an authorized traveler ordered to relocate from a permanent duty station to another permanent duty station.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0aafa91-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Travel performed by an authorized traveler ordered to the first permanent duty station, or separated or retired from uniformed service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0aafa92-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Local travel in or around the temporary duty or permanent duty station.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0aafa93-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other travel as authorized or ordered by the administering Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0aafa94-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “actual and necessary expenses” means expenses incurred in fact by an authorized traveler as a reasonable consequence of official travel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0aafa95-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “travel allowances” means the daily lodging, meals, and other related expenses, including relocation expenses, incurred by an authorized traveler while on official travel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0aafa96-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “transportation allowances” means the costs of temporarily or permanently moving an authorized traveler, the personal property of an authorized traveler, or a combination thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0aafa97-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “transportation-, lodging-, or meals-in-kind” means transportation, lodging, or meals provided by the Government without cost to an authorized traveler.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0aafa98-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “miscellaneous expenses” means authorized expenses incurred in addition to authorized allowances during the performance of official travel by an authorized traveler.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0aafa99-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “personal property”, with respect to transportation allowances, includes baggage, furniture, and other household items, clothing, privately owned vehicles, house trailers, mobile homes, and any other personal items that would not otherwise be prohibited by any other provision of law or regulation prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s464"},"text":"section 464 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0aafa9a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “relocation allowances” means the costs associated with relocating a member of the uniformed services and the member’s dependents between an old and new temporary or permanent duty assignment location or other authorized location. Such costs include pet quarantine expenses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0aafa9b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “dislocation allowances” means the costs associated with relocation of the household of a member of the uniformed services and the member’s dependents in relation to a change in the member’s permanent duty assignment location ordered for the convenience of the Government or incident to an evacuation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0ad438c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0ad438d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/b/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “permanent duty assignment location” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb0ad438e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/b/10/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the official station of a member of the uniformed services; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb0ad438f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/b/10/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the residence of a dependent of a member of the uniformed services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0ad4390-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s451/b/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As used in subparagraph (A)(ii), the residence of a dependent who is a student not living with the member while at school is the permanent duty assignment location of the dependent student.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb0ad4391-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVI/s631/b"},"text":"Pub. L. 112–81, div. A, title VI, § 631(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1453"},"text":"125 Stat. 1453","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tVI/s621/a/1"},"text":"Pub. L. 113–66, div. A, title VI, § 621(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/783"},"text":"127 Stat. 783","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tVI/s603/b"},"text":"Pub. L. 117–81, div. A, title VI, § 603(b)","children":[],"tail":", (c)(2), (d)(2), "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1766"},"text":"135 Stat. 1766","children":[],"tail":", 1767; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tVI/s626/h/6"},"text":"Pub. L. 117–263, div. A, title VI, § 626(h)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2629"},"text":"136 Stat. 2629","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb0ad4392-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb0ad4393-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb0ad4394-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(2)(H)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s626/h/6/A"},"text":"Pub. L. 117–263, § 626(h)(6)(A)","children":[],"tail":", substituted “section 453(f)” for “section 481f”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(H)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s626/h/6/B"},"text":"Pub. L. 117–263, § 626(h)(6)(B)","children":[],"tail":", substituted “section 452(b)(12)” for “section 481h”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(H)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s626/h/6/C"},"text":"Pub. L. 117–263, § 626(h)(6)(C)","children":[],"tail":", substituted “section 452(b)(13)” for “section 481j”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(H)(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s626/h/6/D"},"text":"Pub. L. 117–263, § 626(h)(6)(D)","children":[],"tail":", substituted “section 452(b)(14)” for “section 481k”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(H)(v). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s626/h/6/E"},"text":"Pub. L. 117–263, § 626(h)(6)(E)","children":[],"tail":", substituted “section 452(b)(15)” for “section 481"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(2)(H)(vii), (viii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s603/c/2/A"},"text":"Pub. L. 117–81, § 603(c)(2)(A)","children":[],"tail":", added cls. (vii) and (viii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(H)(ix). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s603/d/2"},"text":"Pub. L. 117–81, § 603(d)(2)","children":[],"tail":", added cl. (ix)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s603/b"},"text":"Pub. L. 117–81, § 603(b)","children":[],"tail":", inserted at end “Such costs include pet quarantine expenses.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s603/c/2/B"},"text":"Pub. L. 117–81, § 603(c)(2)(B)","children":[],"tail":", added par. (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (a)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66"},"text":"Pub. L. 113–66","children":[],"tail":" inserted “or as an escort or attendant for dependents of a member for necessary travel performed not later than one year after the member is unable to accompany the dependents who are incapable of traveling alone” before period at end."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb0ad4395-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb0ad4396-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Purpose of Consolidation and Reform of Travel and Transportation Authorities of the Uniformed Services","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVI/s631/a"},"text":"Pub. L. 112–81, div. A, title VI, § 631(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1452"},"text":"125 Stat. 1452","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/81/dA/tVI/s631/a"},"text":"“This section [see Tables for classification] establishes general travel and transportation provisions for members of the uniformed services and other travelers authorized to travel under official conditions. Recognizing the complexities and the changing nature of travel, the amendments made by this section [see Tables for classification] provide the Secretary of Defense and the other administering Secretaries with the authority to prescribe and implement travel and transportation policy that is simple, clear, efficient, and flexible, and that meets mission and servicemember needs, while realizing cost savings that should come with a more efficient and less cumbersome system for travel and transportation.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb0ad4397-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transition Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVI/s632"},"text":"Pub. L. 112–81, div. A, title VI, § 632","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1465"},"text":"125 Stat. 1465","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/81/dA/tVI/s632"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation Plan","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall develop a plan to implement subchapters I and II of chapter 8 of title 37, United States Code (as added by section 631(b) of this Act), and to transition all of the travel and transportation programs for members of the uniformed services under chapter 7 of title 37, United States Code, solely to provisions of those subchapters by the end of the transition period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority for Modifications to Old-Law Authorities During Transition Period","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"During the transition period, the Secretary of Defense and the Secretaries concerned, in using the authorities under subchapter III of chapter 8 of title 37, United States Code (as so added), may apply those authorities subject to the terms of such provisions and such modifications as the Secretary of Defense may include in the implementation plan required under subsection (a) or in any subsequent modification to that implementation plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall prepare the implementation plan under subsection (a) and any modification to that plan under subsection (b) in coordination with—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Homeland Security, with respect to the Coast Guard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Health and Human Services, with respect to the commissioned corps of the Public Health Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Commerce, with respect to the National Oceanic and Atmospheric Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program of Compliance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense and the other administering Secretaries shall commence the operation of the programs of compliance required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s463"},"text":"section 463 of title 37","children":[],"tail":", United States Code (as so added), by not later than one year after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transition Period","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term ‘transition period’ means the 10-year period beginning on the first day of the first month beginning after the date of the enactment of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
