{"tag":"section","attrib":{"id":"idb09304f8-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s330"},"text":null,"children":[{"tag":"num","attrib":{"value":"330"},"text":"§ 330.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special pay: accession bonus for officer candidates","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb09304f9-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s330/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Accession Bonus Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under regulations prescribed by the Secretary concerned, a person who executes a written agreement described in subsection (c) may be paid an accession bonus under this section upon acceptance of the agreement by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09304fa-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s330/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount of Bonus","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of an accession bonus under subsection (a) may not exceed $8,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09304fb-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s330/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A written agreement referred to in subsection (a) is a written agreement by a person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb09304fc-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s330/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to complete officer candidate school;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09304fd-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s330/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to accept a commission or appointment as an officer of the armed forces; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09304fe-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s330/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to serve on active duty as a commissioned officer for a period specified in the agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09304ff-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s330/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment Method","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon acceptance of a written agreement under subsection (a) by the Secretary concerned, the total amount of the accession bonus payable under the agreement becomes fixed. The agreement shall specify whether the accession bonus will be paid in a lump sum or installments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0930500-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s330/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person who, having received all or part of the bonus under a written agreement under subsection (a), does not complete the total period of active duty as a commissioned officer as specified in such agreement shall be subject to the repayment provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s303a/e"},"text":"section 303a(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0930501-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s330/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No agreement under this section may be entered into after ","children":[{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb0930502-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tVI/s622/a/1"},"text":"Pub. L. 109–364, div. A, title VI, § 622(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2255"},"text":"120 Stat. 2255","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tVI/s614/g"},"text":"Pub. L. 110–181, div. A, title VI, § 614(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/149"},"text":"122 Sta