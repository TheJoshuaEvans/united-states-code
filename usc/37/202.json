{"tag":"section","attrib":{"id":"idb0578329-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s202"},"text":null,"children":[{"tag":"num","attrib":{"value":"202"},"text":"§ 202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pay grades: retired Coast Guard rear admirals (lower half)","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"An officer of the Coast Guard holding a permanent appointment in the grade of rear admiral (lower half) on the retired list, and who in time of war or national emergency has served satisfactorily on active duty for two years in that grade or in a higher grade, is entitled when on active duty to the basic pay of a rear admiral.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb057832a-2930-11f1-a69d-9cbca84c43f0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/649"},"text":"Pub. L. 87–649","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/454"},"text":"76 Stat. 454","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/718/s50"},"text":"Pub. L. 89–718, § 50","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1121"},"text":"80 Stat. 1121","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/130/s3/1"},"text":"Pub. L. 90–130, § 3(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-11-08"},"text":"Nov. 8, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/383"},"text":"81 Stat. 383","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/179/s7"},"text":"Pub. L. 90–179, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-08"},"text":"Dec. 8, 1967","children":[],"tail":", "},{"tag":"ref