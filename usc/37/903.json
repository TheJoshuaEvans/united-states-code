{"tag":"section","attrib":{"id":"idb0b92b0d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s903"},"text":null,"children":[{"tag":"num","attrib":{"value":"903"},"text":"§ 903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retired members recalled to active duty; former members","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A retired member or former member of a uniformed service, or a member of the Fleet Reserve or Fleet Marine Corps Reserve, who is serving on active duty is entitled to the pay and allowances to which he is entitled, under this title, for the grade, rank, or rating in which he is serving. In addition, while on active duty, he is entitled to the pay and allowances, while on leave of absence or while sick, of a member of a uniformed service of similar grade, rank, or rating who is entitled to basic pay.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb0b92b0e-2930-11f1-a69d-9cbca84c43f0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/649"},"text":"Pub. L. 87–649","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/487"},"text":"76 Stat. 487","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb0b92b0f-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb0b92b10-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb0b92b11-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"903","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"37:314.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-10-12/ch681/s514"},"text":"Oct. 12, 1949, ch. 681, § 514","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/63/831"},"text":"63 Stat. 831","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “rating” is inserted for clarity. The words “is entitled to” are substituted for the words “shall . . . be entitled to receive and have the same . . . rights”. The last 41 words of section 314 of existing title 37 are omitted, since the sections mentioned therein were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041/s53/b"},"text":"section 53(b) of the Act of August 10, 1956, ch. 1041","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/70A/646"},"text":"70A Stat. 646","children":[],"tail":"). The subject of death benefits and entitlement thereto is now covered by chapter 75 of title 10."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
