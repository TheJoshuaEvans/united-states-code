il":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s618/h/1/E"},"text":"Pub. L. 115–91, § 618(h)(1)(E)","children":[],"tail":", inserted “or 352” after “section 305a”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s618/h/1/F"},"text":"Pub. L. 115–91, § 618(h)(1)(F)","children":[],"tail":", inserted “or 352” after “section 305b”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s618/h/1/G"},"text":"Pub. L. 115–91, § 618(h)(1)(G)","children":[],"tail":", inserted “or 352” after “section 307a”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s618/h/1/H"},"text":"Pub. L. 115–91, § 618(h)(1)(H)","children":[],"tail":", inserted “or 352” after “section 314”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(J). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s618/h/1/I"},"text":"Pub. L. 115–91, § 618(h)(1)(I)","children":[],"tail":", substituted “353(b)” for “316”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(K). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s618/h/1/J"},"text":"Pub. L. 115–91, § 618(h)(1)(J)","children":[],"tail":", substituted “section 355” for “323”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s618/h/2/A"},"text":"Pub. L. 115–91, § 618(h)(2)(A)","children":[],"tail":", inserted “or 352” after “section 307”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s618/h/2/B"},"text":"Pub. L. 115–91, § 618(h)(2)(B)","children":[],"tail":", substituted “331” for “308”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s618/h/2/C"},"text":"Pub. L. 115–91, § 618(h)(2)(C)","children":[],"tail":", substituted “331” for “309”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s618/h/2/D"},"text":"Pub. L. 115–91, § 618(h)(2)(D)","children":[],"tail":", inserted “or 353” after “section 320”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (d)(1)(H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" inserted “or 351” after “section 310”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s686/b/1"},"text":"Pub. L. 109–163, § 686(b)(1)","children":[],"tail":", substituted “the officer” for “he” wherever appearing and “the appointment” for “his appointment” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s686/b/2"},"text":"Pub. L. 109–163, § 686(b)(2)","children":[],"tail":", substituted “the officer remained” for “he remained”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s686/a"},"text":"Pub. L. 109–163, § 686(a)","children":[],"tail":", amended subsec. (d) generally. Prior to amendment, subsec. (d) read as follows: “In determining the amount of the pay and allowances of a grade formerly held by an officer, incentive pay for hazardous duty under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s301"},"text":"section 301 of this title","children":[],"tail":", special pay for diving duty under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s304"},"text":"section 304 of this title","children":[],"tail":", for hardship duty under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s305"},"text":"section 305 of this title","children":[],"tail":", and for sea duty under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s305a"},"text":"section 305a of this title","children":[],"tail":", and proficiency pay under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s307"},"text":"section 307 of this title","children":[],"tail":" may be considered only so long as the officer continues to perform the duty creating the entitlement to or eligibility for that pay and would otherwise be eligible to receive that pay in his former grade.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261"},"text":"Pub. L. 105–261","children":[],"tail":" substituted “hardship duty” for “duty at a hardship duty location”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" substituted “duty at a hardship duty location” for “duty at certain places”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/25"},"text":"Pub. L. 102–25","children":[],"tail":" struck out “of this section” after “subsection (d)” in subpar. (A) and after “subsection (e)” in subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/343"},"text":"Pub. L. 96–343","children":[],"tail":" substituted “and warrant officers appointed as officers:” for “appointed as officers;” in section catchline, and, in generally revising section, struck out provision for temporary appointment of enlisted members as officers, provided for pay and allowances for warrant officers who accept appointment as commissioned officers, and specified what pay and allowances include and what rates and allowances of a grade which an officer formerly held are for purposes of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb0b92b51-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb0b92b52-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tVI/s686/c"},"text":"Pub. L. 109–163, div. A, title VI, § 686(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3326"},"text":"119 Stat. 3326","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/163/dA/tVI/s686/c"},"text":"“Subsection (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s907"},"text":"section 907 of title 37","children":[],"tail":", United States Code, as amended by subsection (a), shall apply with respect to any acceptance by an enlisted member of the Armed Forces of an appointment as an officer made on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb0b92b53-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/343/s6/c"},"text":"Pub. L. 96–343, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-08"},"text":"Sept. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1127"},"text":"94 Stat. 1127","children":[],"tai