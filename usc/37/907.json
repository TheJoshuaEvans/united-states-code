{"tag":"section","attrib":{"id":"idb0b92b2d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s907"},"text":null,"children":[{"tag":"num","attrib":{"value":"907"},"text":"§ 907.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enlisted members and warrant officers appointed as officers: pay and allowances stabilized","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb0b92b2e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s907/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An enlisted member who accepts an appointment as an officer shall, for service as an officer, be paid the greater of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0b92b2f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s907/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the pay and allowances to which the officer is entitled as an officer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0b92b30-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s907/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the pay and allowances to which the officer would be entitled if the officer were in the last enlisted grade the officer held before the appointment as an officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0b92b31-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s907/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A warrant officer who accepts an appointment as a commissioned officer in a pay grade above W–4 shall, for service as such a commissioned officer, be paid the greater of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0b92b32-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s907/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the pay and allowances to which the officer is entitled as such a commissioned officer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0b92b33-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s907/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the pay and allowances to which the officer would be entitled if the officer were in the last warrant officer grade the officer held before the appointment as such a commissioned officer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0b92b34-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s907/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an officer who was formerly an enlisted member, the pay and allowances to which the officer would be entitled if the officer were in the last enlisted grade the officer held before the appointment as an officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0b92b35-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s907/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0b92b36-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s907/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the pay and allowances of a grade formerly held by an officer include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0b92b37-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s907/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to subsection (d), special and incentive pays under chapter 5 of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0b92b38-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s907/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to subsection (e), allowances under chapter 7 of this title; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0b92b39-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s907/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rates of pay and allowances of a grade which an officer formerly held are those to which the officer would have been entitled had the officer remained in that grade and continued to receive the increases in pay and allowances authorized for that grade, as otherwise provided in this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0b92b3a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s907/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0b92b3b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s907/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In determining the amount of the pay and allowances of a grade formerly held by an officer, the following special and incentive pays may be considered only so long as the officer continues to perform the duty that creates the entitlement to, or eligibility for, that pay and would otherwise be eligible to receive that pay in the former grade:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0b92b3c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s907/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Incentive pay for hazardous duty under section 301 or 351 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0b92b3d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s907/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Submarine duty incentive pay under section 301c or 352 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0b92b3e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s907/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Special pay for diving duty under section 304 or 353(a) of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0b92b3f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s907/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hardship duty pay under section 305 or 352 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0b92b40-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s907/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Career sea pay under section 305a or 352 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0b92b41-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s907/d/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Special pay for service as a member of a Weapons of Mass Destruction Civil Support Team under section 305b or 352 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0b92b42-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s907/d/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assignment incentive pay under section 307a or 352 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0b92b43-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s907/d/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Special pay for duty subject to hostile fire or imminent danger under section 310 or 351 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0b92b44-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s907/d/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Special pay or bonus for an extension of duty at a designated overseas location under section 314 or 352 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0b92b45-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s907/d/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Foreign language proficiency pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s353/b"},"text":"section 353(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0b92b46-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s907/d/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Critical skill retention bonus under section section ","children":[{"tag":"ref","attrib":{"idref":"fn002020"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002020"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" 355 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0b92b47-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s907/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The following special and incentive pays are dependent on a member being in an enlisted status and may not be considered in determining the amount of the pay and allowances of a grade formerly held by an officer:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0b92b48-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s907/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Special duty assignment pay under section 307 or 352 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0b92b49-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s907/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reenlistment bonus under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s331"},"text":"section 331 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0b92b4a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s907/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Enlistment bonus under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s331"},"text":"section 331 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0b92b4b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s907/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Career enlisted flyer incentive pay under section 320 or 353 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0b92b4c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s907/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The clothing allowance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s418"},"text":"section 418 of this title","children":[],"tail":" may not be considered in determining the amount of the pay and allowances of a grade formerly held by an officer if the officer is entitled to a uniform allowance under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s415"},"text":"section 415 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb0b92b4d-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/484/s1/1"},"text":"Pub. L. 91–484, § 1(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-21"},"text":"Oct. 21, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1083"},"text":"84 Stat. 1083","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/343/s6/a/1"},"text":"Pub. L. 96–343, § 6(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-08"},"text":"Sept. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1126"},"text":"94 Stat. 1126","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/25/tVII/s702/b/1"},"text":"Pub. L. 102–25, title VII, § 702(b)(1)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1991-04-06"},"text":"Apr. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/117"},"text":"105 Stat. 117","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tVI/s619/d"},"text":"Pub. L. 105–85, div. A, title VI, § 619(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1790"},"text":"111 Stat. 1790","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tVI/s617/b"},"text":"Pub. L. 105–261, div. A, title VI, § 617(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2041"},"text":"112 Stat. 2041","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tVI/s686/a"},"text":"Pub. L. 109–163, div. A, title VI, § 686(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3325"},"text":"119 Stat. 3325","children":[],"tail":", 3326; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVI/s618/h/4"},"text":"Pub. L. 114–328, div. A, title VI, § 618(h)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attri