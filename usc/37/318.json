{"tag":"section","attrib":{"id":"idb08e4a37-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s318"},"text":null,"children":[{"tag":"num","attrib":{"value":"318"},"text":"§ 318.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special pay: special warfare officers extending period of active duty","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb08e4a38-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s318/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Warfare Officer Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “special warfare officer” means an officer of a uniformed service who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb08e4a39-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s318/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is qualified for a military occupational specialty or designator identified by the Secretary concerned as a special warfare military occupational specialty or designator; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb08e4a3a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s318/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is serving in a position for which that specialty or designator is authorized.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb08e4a3b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s318/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retention Bonus Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A special warfare officer who meets the eligibility requirements specified in subsection (c) and who executes a written agreement to remain on active duty in special warfare service for at least one year may, upon the acceptance of the agreement by the Secretary concerned, be paid a retention bonus as provided in this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb08e4a3c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s318/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A special warfare officer may apply to enter into an agreement referred to in subsection (b) if the officer—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb08e4a3d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s318/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in pay grade O–3, or is in pay grade O–4 and is not on a list of officers recommended for promotion, at the time the officer applies to enter into the agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb090bb3e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s318/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has completed at least 6, but not more than 14, years of active commissioned service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb090bb3f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s318/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has completed any service commitment incurred to be commissioned as an officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb090bb40-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s318/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount of Bonus","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of a retention bonus paid under this section may not be more than $15,000 for each year covered by the agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb090bb41-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s318/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Proration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term of an agreement under subsection (b) and the amount of the retention bonus payable under subsection (d) may be prorated as long as the agreement does not extend beyond the date on which the officer executing the agreement would complete 14 years of active commissioned service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb090bb42-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s318/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment Methods","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb090bb43-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s318/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon acceptance of an agreement under subsection (b) by the Secretary concerned, the total amount payable pursuant to the agreement becomes fixed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb090bb44-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s318/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The amount of the retention bonus may be paid as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb090bb45-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s318/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At the time the agreement is accepted by the Secretary concerned, the Secretary may make a lump sum payment equal to half the total amount payable under the agreement. The balance of the bonus amount shall be paid in equal annual installments on the anniversary of the acceptance of the agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb090bb46-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s318/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned may make graduated annual payments under regulations prescribed by the Secretary, with the first payment being payable at the time the agreement is accepted by the Secretary and subsequent payments being payable on the anniversary of the acceptance of the agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb090bb47-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s318/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Pay","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A retention bonus paid under this section is in addition to any other pay and allowances to which an officer is entitled.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb090bb48-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s318/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer who, having entered into a written agreement under subsection (b) and having received all or part of a bonus under this section, does not complete the period of active duty in special warfare service as specified in the agreement shall be subject to the repayment provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s303a/e"},"text":"section 303a(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb090bb49-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s318/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretaries concerned shall prescribe regulations to carry out this section, including the definition of the term “special warfare service” for purposes of this section. Regulations prescribed by the Secretary of a military department under this section shall be subject to the approval of the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb090bb4a-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tVI/s626/a/1"},"text":"Pub. L. 106–65, div. A, title VI, § 626(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/655"},"text":"113 Stat. 655","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tX/s1048/i/7"},"text":"Pub. L. 107–107, div. A, title X, § 1048(i)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1229"},"text":"115 Stat. 1229","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tVI/s687/b/27"},"text":"Pub. L. 109–163, div. A, title VI, § 687(b)(27)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3331"},"text":"119 Stat. 3331","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb090bb4b-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb090bb4c-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb090bb4d-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" amended heading and text of subsec. (h) generally, substituting provisions referring to repayment provisions of section 303a(e) for specific provisions relating to repayment required when officer receives bonus but fails to complete total period of agreed upon active duty in special warfare."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (h)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" substituted “subsection (b)” for “subsection (a)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb090bb4e-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb090bb4f-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tVI/s626/b"},"text":"Pub. L. 106–65, div. A, title VI, § 626(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/656"},"text":"113 Stat. 656","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/65/dA/tVI/s626/b"},"text":"“The amendments made by subsection (a) [enacting this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1999-10-01"},"text":"October 1, 1999","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"idb090bb50-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For savings provision relating to payment or repayment of any bonus, incentive pay, special pay, or similar pay obligated to be paid before ","children":[{"tag":"date","attrib":{"date":"2006-04-01"},"text":"Apr. 1, 2006","children":[],"tail":", under a provision of this section amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s687/b"},"text":"section 687(b) of Pub. L. 109–163","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s687/f"},"text":"section 687(f) of Pub. L. 109–163","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s510"},"text":"section 510 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
