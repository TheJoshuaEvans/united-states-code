{"tag":"section","attrib":{"id":"idb0c05680-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s1016"},"text":null,"children":[{"tag":"num","attrib":{"value":"1016"},"text":"§ 1016.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pay statements: descriptions of types of pay","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb0c05681-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s1016/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall make available contemporaneously with each pay statement provided to a member of the Armed Forces, for each type of pay, allowance, and deduction listed on the statement, a brief and plain-language description of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0c05682-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s1016/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the statutory or regulatory authority under which a pay, allowance, or deduction is made;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0c05683-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s1016/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purpose of a pay, allowance, or deduction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0c05684-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s1016/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the criteria for determining eligibility of members for a pay, allowance, or deduction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0c05685-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s1016/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" possible changes in the eligibility of the member for a pay, allowance, or deduction, including the circumstances under which a pay, allowance, or deduction may be suspended or modified or may expire.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0c05686-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s1016/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The descriptions required to be made available with a pay statement under paragraph (1) shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0c05687-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s1016/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" published on a website accessible by a member and printable with the pay statement of the member; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0c05688-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s1016/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" presented in language easily understood by individuals without specialized knowledge of military finance, accounting, or law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb0c05689-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tVI/s661/a"},"text":"Pub. L. 119–60, div. A, title VI, § 661(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/913"},"text":"139 Stat. 913","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb0c0568a-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb0c0568b-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb0c0568c-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tVI/s661/b"},"text":"Pub. L. 119–60, div. A, title VI, § 661(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/914"},"text":"139 Stat. 914","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dA/tVI/s661/b"},"text":"“The requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s1016"},"text":"section 1016 of title 37","children":[],"tail":", United States Code, as added by subsection (a), shall apply with respect to pay statements issued on or after the date that is 180 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
