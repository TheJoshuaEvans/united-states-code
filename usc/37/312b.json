{"tag":"section","attrib":{"id":"idb08bd98e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s312b"},"text":null,"children":[{"tag":"num","attrib":{"value":"312b"},"text":"§ 312b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special pay: nuclear career accession bonus","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb08bd98f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s312b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb08bd990-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s312b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under regulations prescribed by the Secretary of the Navy, an individual who is selected for officer naval nuclear power training and who executes a written agreement to participate in a program of training for duty in connection with the supervision, operation, and maintenance of naval nuclear propulsion plants may be paid a bonus not to exceed $30,000 upon acceptance by the Secretary of the written agreement. Upon acceptance of the agreement by the Secretary, the amounts payable upon selection for training and upon completion of training, respectively, as determined under subsection (b), shall become fixed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb08bd991-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s312b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer who does not commence or complete satisfactorily the nuclear power training specified in the agreement under paragraph (1) shall be subject to the repayment provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s303a/e"},"text":"section 303a(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb08bd992-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s312b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of the Navy shall determine annually the total amount of the bonus to be paid under this section and of that amount the portions that are to be paid—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb08bd993-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s312b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon selection for officer naval nuclear power training; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb08bd994-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s312b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon successful completion, as a commissioned officer, of training for duty in connection with the supervision, operation, and maintenance of naval nuclear propulsion plants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb08bd995-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s312b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of this section shall be effective only in the case of officers who, on or before ","children":[{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":", have been accepted for training for duty in connection with the supervision, operation, and maintenance of naval nuclear propulsion plants."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb0