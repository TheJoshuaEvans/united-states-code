{"tag":"section","attrib":{"id":"idb0a88894-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s424"},"text":null,"children":[{"tag":"num","attrib":{"value":"424"},"text":"§ 424.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Band leaders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb0a88895-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s424/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The leader of the Army Band is entitled to the allowances of a captain in the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0a88896-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s424/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The leader of the United States Navy Band is entitled to the allowances of a lieutenant of the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0a88897-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s424/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the Marine Corps who is appointed as director or assistant director of the United States Marine Corps Band under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8287"},"text":"section 8287 of title 10","children":[],"tail":", is entitled, while serving thereunder, only to the allowances of an officer in the grade in which he is serving. However, his allowances may not be less than those to which he was entitled at the time of his appointment under that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0a88898-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s424/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The leader of the Naval Academy Band is entitled to the allowances of the pay grade prescribed for him by the Secretary of Navy under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s207/e"},"text":"section 207(e) of this title","children":[],"tail":". The second leader is entitled to the allowances of a warrant officer, W–1."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0a88899-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s424/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The director of the Coast Guard Band is entitled to the allowances of an officer in the grade in which he is serving. However, his allowances may not be less than those to which he was entitled at the time of his appointment as director.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb0a8889a-2930-11f1-a69d-9cbca84c43f0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/649"},"text":"Pub. L. 87–649","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/480"},"text":"76 Stat. 480","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/189/s3"},"text":"Pub. L. 89–189, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-09-17"},"text":"Sept. 17, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/820"},"text":"79 Stat. 820","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/551/s3/b/2"},"text":"Pub. L. 95–551, § 3(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-30"},"text":"Oct. 30, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2069"},"text":"92 Stat. 2069","children":[],"tail":"; "},{"tag":"ref","attrib":{"hre