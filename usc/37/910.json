"id":"idb0bb9b94-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb0bb9b95-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s601/g/2/A"},"text":"Pub. L. 119–60, § 601(g)(2)(A)","children":[],"tail":", inserted “and members of the Space Force” after “reserve component members” in section catchline. Catchline text was editorially conformed to the style used in this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s601/g/2/B"},"text":"Pub. L. 119–60, § 601(g)(2)(B)","children":[],"tail":", inserted “or of the Space Force” after “of the armed forces”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1) to (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s601/g/2/C"},"text":"Pub. L. 119–60, § 601(g)(2)(C)","children":[],"tail":", inserted “or the Space Force” after “a reserve component” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s601/g/2/C"},"text":"Pub. L. 119–60, § 601(g)(2)(C)","children":[],"tail":", inserted “or the Space Force” after “a reserve component”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s611/a"},"text":"Pub. L. 119–60, § 611(a)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2026-12-31"},"text":"December 31, 2026","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2025-12-31"},"text":"December 31, 2025","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p"