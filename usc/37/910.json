{"tag":"section","attrib":{"id":"idb0bb9b78-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s910"},"text":null,"children":[{"tag":"num","attrib":{"value":"910"},"text":"§ 910.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Replacement of lost income: involuntarily mobilized reserve component members and members of the Space Force subject to extended and frequent active duty service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb0bb9b79-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s910/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned shall pay to an eligible member of a reserve component of the armed forces or of the Space Force an amount equal to the monthly active-duty income differential of the member, as determined by the Secretary, when the total monthly military compensation of the member is less than the average monthly civilian income of the member. The payments shall be made on a monthly basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0bb9b7a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s910/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0bb9b7b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s910/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A member of a reserve component or the Space Force is entitled to a payment under this section for any full month of active duty of the member, when the total monthly military compensation of the member is less than the average monthly civilian income of the member, while the member is on active duty under an involuntary mobilization order, following the date on which the member—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0bb9b7c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s910/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" completes 547 continuous days of service on active duty under an involuntary mobilization order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0bb9b7d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s910/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" completes 730 cumulative days on active duty under an involuntary mobilization order during the previous 1,826 days; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0bb9b7e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s910/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is involuntarily mobilized for service on active duty for a period of 180 days or more within 180 days after the date of the member’s separation from a previous period of active duty for a period of 180 days or more.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0bb9b7f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s910/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The entitlement of a member of a reserve component or the Space Force to a payment under this section also shall commence or, if previously commenced under paragraph (1), shall continue if the member—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0bb9b80-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s910/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" satisfies the required number of days on active duty specified in subparagraph (A) or (B) of paragraph (1) or was involuntarily mobilized as provided in subparagraph (C) of such paragraph; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0bb9b81-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s910/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is retained on active duty under subparagraph (A) or (B) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12301/h/1"},"text":"section 12301(h)(1) of title 10","children":[],"tail":" because of an injury or illness incurred or aggravated while the member was assigned to duty in an area for which special pay under section 310, or paragraph (1) or (3) of section 351(a), of this title is available."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0bb9b82-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s910/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A civilian employee of the Federal Government who is also a member of a reserve component or the Space Force is not entitled to a payment under this section for any period for which the employee is entitled to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0bb9b83-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s910/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a differential payment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5538"},"text":"section 5538 of title 5","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0bb9b84-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s910/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a comparable benefit under an administratively established program for civilian employees absent from a position of employment with the Federal Government in order to perform active duty in the uniformed services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0bb9b85-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s910/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimum and Maximum Payment Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0bb9b86-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s910/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A payment under this section shall be made to a member for a month only if the amount of the monthly active-duty income differential for the month is greater than $50.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0bb9b87-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s910/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding the amount determined under subsection (d) for a member for a month, the monthly payment to a member under this section may not exceed $3,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0bb9b88-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s910/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Monthly Active-Duty Income Differential","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the monthly active-duty income differential of a member is the difference between—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0bb9b89-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s910/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average monthly civilian income of the member; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0bb9b8a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s910/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the member’s total monthly military compensation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0bb9b8b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s910/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0bb9b8c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s910/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “average monthly civilian income”, with respect to a member of a reserve component or the Space Force, means the amount, determined by the Secretary concerned, of the earned income of the member for either the 12 months preceding the member’s mobilization or the 12 months covered by the member’s most recent Federal income tax filing, divided by 12.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0bb9b8d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s910/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “total monthly military compensation” means the amount, computed on a monthly basis, of the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0bb9b8e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s910/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the regular military compensation (RMC) of the member; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0bb9b8f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s910/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amount of special pay or incentive pay and any allowance (other than an allowance included in regular military compensation) that is paid to the member on a monthly basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0bb9b90-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s910/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall be administered under regulations to be prescribed by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0bb9b91-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s910/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No payment shall be made to a member under this section for months beginning after ","children":[{"tag":"date","attrib":{"date":"2026-12-31"},"text":"December 31, 2026","children":[],"tail":", unless the entitlement of the member to payments under this section commenced on or before that date."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb0bb9b92-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tVI/s614/a"},"text":"Pub. L. 109–163, div. A, title VI, § 614(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3292"},"text":"119 Stat. 3292","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tVI/s604"},"text":"Pub. L. 110–181, div. A, title VI, § 604","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/145"},"text":"122 Stat. 145","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title VI, § 605, "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4483"},"text":"122 Stat. 4483","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tVI/s611/7"},"text":"Pub. L. 111–84, div. A, title VI, § 611(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2352"},"text":"123 Stat. 2352","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tVI"},"text":"Pub. L. 111–383, div. A, title VI","children":[],"tail":", §§ 601(a), 611(7), "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4235"},"text":"124 Stat. 4235","children":[],"tail":", 4236; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVI/s611/7"},"text":"Pub. L. 112–81, div. A, title VI, § 611(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1449"},"text":"125 Stat. 1449","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tVI/s611/8"},"text":"Pub. L. 112–239, div. A, title VI, § 611(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1776"},"text":"126 Stat. 1776","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tVI/s611/8"},"text":"Pub. L. 113–66, div. A, title VI, § 611(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/780"},"text":"127 Stat. 780","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tVI/s611/8"},"text":"Pub. L. 113–291, div. A, title VI, § 611(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3399"},"text":"128 Stat. 3399","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tVI/s611/8"},"text":"Pub. L. 114–92, div. A, title VI, § 611(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/838"},"text":"129 Stat. 838","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVI"},"text":"Pub. L. 114–328, div. A, title VI","children":[],"tail":", §§ 611(8), 618(h)(5), "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2157"},"text":"130 Stat. 2157","children":[],"tail":", 2161; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tVI/s611/8"},"text":"Pub. L. 115–91, div. A, title VI, § 611(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1421"},"text":"131 Stat. 1421","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVI/s611/a"},"text":"Pub. L. 115–232, div. A, title VI, § 611(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1796"},"text":"132 Stat. 1796","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tVI/s611/a"},"text":"Pub. L. 116–92, div. A, title VI, § 611(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1425"},"text":"133 Stat. 1425","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tVI/s611/a"},"text":"Pub. L. 116–283, div. A, title VI, § 611(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":"