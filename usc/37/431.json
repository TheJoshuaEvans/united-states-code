{"tag":"section","attrib":{"id":"idb0a888d6-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s431"},"text":null,"children":[{"tag":"num","attrib":{"value":"431"},"text":"§ 431.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefits for certain members assigned to the Defense Intelligence Agency","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb0a888d7-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s431/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may provide to members of the armed forces described in subsection (e) allowances and benefits comparable to those provided by the Secretary of State to officers and employees of the Foreign Service under paragraphs (2), (3), (4), (6), (7), (8), and (13) of section 901 and sections 705 and 903 of the Foreign Service Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4081/2"},"text":"22 U.S.C. 4081(2)","children":[],"tail":", (3), (4), (6), (7), (8), and (13), 4025, 4083) and under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5924/4"},"text":"section 5924(4) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0a888d8-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s431/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority of the Secretary of Defense to make payments under subsection (a) is effective for any fiscal year only to the extent that appropriated funds are available for such purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0a888d9-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s431/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the armed forces may not receive benefits under both subsection (a) and any other provision of this title for the same purpose. The Secretary of Defense shall prescribe such regulations as may be necessary to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0a888da-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s431/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Regulations prescribed under subsection (a) may not take effect until the Secretary of Defense has submitted such regulations to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0a888db-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s431/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Armed Services and the Select Committee on Intelligence of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0a888dc-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s431/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Armed Services and the Permanent Select Committee on Intelligence of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0a888dd-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s431/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subsection (a) applies to members of the armed forces who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0a888de-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s431/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" are assigned—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0a888df-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s431/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to Defense Attaché Offices or Defense Intelligence Agency Liaison Offices outside the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0a888e0-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s431/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Defense Intelligence Agency and engaged in intelligence-related duties outside the United States; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0a888e1-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s431/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are designated by the Secretary of Defense for the purposes of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb0a888e2-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145/tXIII/s1302/b/1"},"text":"Pub. L. 99–145, title XIII, § 1302(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/738"},"text":"99 Stat. 738","children":[],"tail":", § 431; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/25/tVII/s702/b/1"},"text":"Pub. L. 102–25, title VII, § 702(b)(1)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1991-04-06"},"text":"Apr. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/117"},"text":"105 Stat. 117","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/93/tV/s502/b"},"text":"Pub. L. 104–93, title V, § 502(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-01-06"},"text":"Jan. 6, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/973"},"text":"109 Stat. 973","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tX/s1067/2"},"text":"Pub. L. 106–65, div. A, title X, § 1067(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/774"},"text":"113 Stat. 774","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVI/s631/d/2"},"text":"Pub. L. 112–81, div. A, title VI, § 631(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1460"},"text":"125 Stat. 1460","children":[],"tail":"; renumbered § 491, "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1076/h/2"},"text":"Pub. L. 112–239, div. A, title X, § 1076(h)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1955"},"text":"126 Stat. 1955","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tVI/s604/a"},"text":"Pub. L. 117–81, div. A, title VI, § 604(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1767"},"text":"135 Stat. 1767","children":[],"tail":"; renumbered § 431, "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tVI/s615/a"},"text":"Pub. L. 117–263, div. A, title VI, § 615(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2624"},"text":"136 Stat. 2624","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb0a888e3-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb0a888e4-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb0a888e5-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" revived "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s491"},"text":"section 491 of this title","children":[],"tail":" to read as it did immediately before its repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":", and renumbered it as this section. The section was transferred to its original location in Chapter 7 of this title to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" repealed this section. However, this section was revived to read as it did immediately before repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":". See note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s431"},"text":"section 431 of this title","children":[],"tail":" as "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s491"},"text":"section 491 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":" transferred this section to this chapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" substituted “Committee on Armed Services” for “Committee on National Security”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/93/s502/b/1"},"text":"Pub. L. 104–93, § 502(b)(1)","children":[],"tail":", substituted “described in subsection (e)” for “who are assigned to Defense Attache Offices and Defense Intelligence Agency Liaison Offices outside the United States and who are designated by the Secretary of Defense for the purposes of this subsection”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/93/s502/b/2"},"text":"Pub. L. 104–93, § 502(b)(2)","children":[],"tail":", (3), added subsecs. (d) and (e) and struck out former subsec. (d) which read as follows: “Regulations prescribed pursuant to subsection (a) shall be submitted to the Committee on Armed Services and the Permanent Select Committee on Intelligence of the House of Representatives and the Committee on Armed Services and the Select Committee on Intelligence of the Senate before such regulations take effect.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsecs. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/25"},"text":"Pub. L. 102–25","children":[],"tail":" struck out “of this section” after “subsection (a)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb0a888e6-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb0a888e7-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Delegation of Authority of Secretary of Defense","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145/tXIII/s1302/b/3"},"text":"Pub. L. 99–145, title XIII, § 1302(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/738"},"text":"99 Stat. 738","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/180/dA/tXIII/s1314/d/4"},"text":"Pub. L. 100–180, div. A, title XIII, § 1314(d)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1176"},"text":"101 Stat. 1176","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/180/dA/tXIII/s1314/d/4"},"text":"“The authority of the Secretary of Defense under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s431"},"text":"section 431 of title 37","children":[],"tail":", United States Code, as added by paragraph (1), may be delegated in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s113/d"},"text":"section 113(d) of title 10","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[Amendment to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145/s1302/b/3"},"text":"section 1302(b)(3) of Pub. L. 99–145","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/100/180"},"text":"Pub. L. 100–180","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/180/s1314/e/2"},"text":"section 1314(e)(2) of Pub. L. 100–180","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s413"},"text":"section 413 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
