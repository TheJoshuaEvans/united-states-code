{"tag":"section","attrib":{"id":"idb06cdfef-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s301e"},"text":null,"children":[{"tag":"num","attrib":{"value":"301e"},"text":"§ 301e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiyear retention bonus: dental officers of the armed forces","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb06cdff0-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s301e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Bonus Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb06cdff1-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s301e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A dental officer described in subsection (b) who executes a written agreement to remain on active duty for two, three, or four years after completion of any other active-duty service commitment may, upon acceptance of the written agreement by the Secretary of the military department concerned, be paid a retention bonus as provided in this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb06cdff2-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s301e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of a retention bonus under paragraph (1) may not exceed $50,000 for each year covered by a four-year agreement. The maximum yearly retention bonus for two-year and three-year agreements shall be reduced to reflect the shorter service commitment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb06cdff3-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s301e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Officers Automatically Eligible","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) applies to an officer of the armed forces who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb06cdff4-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s301e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an officer of the Dental Corps of the Army or the Navy or an officer of the Air Force designated as a dental officer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb06cdff5-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s301e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a dental specialty in oral and maxillofacial surgery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb06cdff6-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s301e/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in a pay grade below pay grade O–7;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb06cdff7-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s301e/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has at least eight years of creditable service (computed as described in section 302b(g) ","children":[{"tag":"ref","attrib":{"idref":"fn002002"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002002"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title) or has completed any active-duty service commitment incurred for dental education and training; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb06cdff8-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s301e/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has completed initial residency training (or will complete such training before September 30 of the fiscal year in which the officer enters into an agreement under subsection (a)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb06cdff9-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s301e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Extension of Bonus to Other Dental Officers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"At the discretion of the Secretary of the military department concerned, the Secretary may enter into a written agreement described in subsection (a)(1) with a dental officer who does not have the dental specialty specified in subsection (b)(2), and pay a retention bonus to such an officer as provided in this section, if the officer otherwise satisfies the eligibility requirements specified in subsection (b). The Secretaries shall exercise the authority provided in this section in a manner consistent with regulations prescribed by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb06cdffa-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s301e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer who does not complete the period of active duty specified in the agreement entered into under subsection (a) shall be subject to the repayment provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s303a/e"},"text":"section 303a(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb06cdffb-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tVI/s617/a"},"text":"Pub. L. 105–85, div. A, title VI, § 617(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1788"},"text":"111 Stat. 1788","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tVI/s615/b"},"text":"Pub. L. 107–314, div. A, title VI, § 615(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2568"},"text":"116 Stat. 2568","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tVI/s687/b/3"},"text":"Pub. L. 109–163, div. A, title VI, § 687(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3328"},"text":"119 Stat. 3328","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb06cdffc-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb06cdffd-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb06cdffe-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s302b/g"},"text":"Section 302b(g) of this title","children":[],"tail":", referred to in subsec. (b)(4), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s302b/f"},"text":"section 302b(f) of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tVI/s687/b/6/D"},"text":"Pub. L. 109–163, div. A, title VI, § 687(b)(6)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3328"},"text":"119 Stat. 3328","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb06cdfff-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" amended heading and text of subsec. (d) generally, substituting provisions referring to repayment provisions of section 303a(e) for specific provisions relating to refunds required when officer fails to complete total period of active duty."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314"},"text":"Pub. L. 107–314","children":[],"tail":" substituted “$50,000” for “$14,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb06ce000-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"idb06ce001-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For savings provision relating to payment or repayment of any bonus, incentive pay, special pay, or similar pay obligated to be paid before ","children":[{"tag":"date","attrib":{"date":"2006-04-01"},"text":"Apr. 1, 2006","children":[],"tail":", under a provision of this section amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s687/b"},"text":"section 687(b) of Pub. L. 109–163","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s687/f"},"text":"section 687(f) of Pub. L. 109–163","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s510"},"text":"section 510 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb06f5002-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Application of Increase","children":[],"tail":null},{"tag":"p","attrib":{},"text":"In case of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/s615"},"text":"section 615 of Pub. L. 107–314","children":[],"tail":" to increase maximum amount of special pay or bonus that may be paid during any 12-month period, the amended limitation is applicable to 12-month periods beginning after "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"Sept. 30, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/s615/i"},"text":"section 615(i) of Pub. L. 107–314","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s301d"},"text":"section 301d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
