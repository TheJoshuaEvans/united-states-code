{"tag":"section","attrib":{"id":"idb0a88868-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s420"},"text":null,"children":[{"tag":"num","attrib":{"value":"420"},"text":"§ 420.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowances while participating in international sports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb0a88869-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s420/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s717"},"text":"Section 717 of title 10","children":[],"tail":" does not authorize the payment of allowances at higher rates than those provided for participation in military activities not covered by that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0a8886a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s420/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other law, a member of a uniformed service is not entitled to travel and transportation allowances under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s452"},"text":"section 452 of this title","children":[],"tail":" for any period during which his expenses for travel or transportation are being paid by the agency sponsoring his participation in a competition covered by "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s717"},"text":"section 717 of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0a8886b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s420/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other law, a member of a uniformed service who has no dep