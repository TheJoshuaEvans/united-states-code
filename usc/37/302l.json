{"tag":"section","attrib":{"id":"idb07b373f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302l"},"text":null,"children":[{"tag":"num","attrib":{"value":"302l"},"text":"§ 302l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special pay: accession bonus for dental specialist officers in critically short wartime specialties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb07b3740-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302l/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Accession Bonus Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person who is a graduate of an accredited dental school in a specialty designated by regulations as a critically short wartime specialty and who executes a written agreement described in subsection (d) to accept a commission as an officer of the armed forces and remain on active duty for a period of not less than four consecutive years may, upon the acceptance of the agreement by the Secretary concerned, be paid an accession bonus in the amount determined by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb07b3741-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302l/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount of Bonus","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of an accession bonus under subsection (a) may not exceed $400,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb07b3742-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302l/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Eligibility for Bonus","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person may not be paid a bonus under subsection (a) if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb07b3743-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302l/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person, in exchange for an agreement to accept an appointment as an officer, received financial assistance from the Department of Defense to pursue a course of study in dentistry; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb07b3744-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302l/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary concerned determines that the person is not qualified to become and remain certified as a dentist in a specialty designated by regulations as a critically short wartime specialty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb07b3745-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302l/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The agreement referred to in subsection (a) shall provide that, consistent with the needs of the armed force concerned, the person executing the agreement will be assigned to duty, for the period of obligated service covered by the agreement, as an officer of the Dental Corps of the Army or the Navy or as an officer of the Air Force designated as a dental officer in a specialty designated by regulations as a critically short wartime specialty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb07b3746-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302l/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person who, after executing an agreement under subsection (a) is not commissioned as an officer of the armed forces, does not become licensed as a dentist, or does not complete the period of active duty in a specialty specified in the agreement, shall be subject to the repayment provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s303a/e"},"text":"section 303a(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb07b3747-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302l/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination With Other Accession Bonus Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person eligible to execute an agreement under both subsection (a) and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s302h"},"text":"section 302h of this title","children":[],"tail":" shall elect which authority to execute the agreement under. A person may not execute an agreement under both subsection (a) and such section 302h."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb07b3748-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302l/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No agreement under this section may be entered into after ","children":[{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb07b3749-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tVI/s617/c"},"text":"Pub. L. 109–364, div. A, title VI, § 617(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2250"},"text":"120 Stat. 2250","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tVI/s612/i"},"text":"Pub. L. 110–181, div. A, title VI, § 612(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/149"},"text":"122 Stat. 149","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title VI, § 612(i), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4485"},"text":"122 Stat. 4485","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tVI/s612/b/8"},"text":"Pub. L. 111–84, div. A, title VI, § 612(b)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2353"},"text":"123 Stat. 2353","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tVI/s612/b/8"},"text":"Pub. L. 111–383, div. A