{"tag":"section","attrib":{"id":"idb078c5f0-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302g"},"text":null,"children":[{"tag":"num","attrib":{"value":"302g"},"text":"§ 302g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special pay: Selected Reserve health care professionals in critically short wartime specialties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb078c5f1-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Pay Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer of a reserve component of the armed forces described in subsection (b) who executes a written agreement under which the officer agrees to serve in the Selected Reserve of an armed force for a period of not less than one year nor more than three years, beginning on the date the officer accepts the award of special pay under this section, may be paid special pay at an annual rate not to exceed $25,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb078c5f2-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Officers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer referred to in subsection (a) is an officer in a health care profession who is qualified in a specialty designated by regulations as a critically short wartime specialty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb078c5f3-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Time for Payment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Special pay under this section shall be paid annually at the beginning of each twelve-month period for which the officer has agreed to serve.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb078c5f4-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302g/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer who does not complete the period of service in the Selected Reserve specified in the agreement entered into under subsection (a) shall be subject to the repayment provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s303a/e"},"text":"section 303a(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb078c5f5-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302g/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of Agreement Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No agreement under this section may be entered into after ","children":[{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb078c5f6-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tVI/s614/a/1"},"text":"Pub. L. 104–106, div. A, title VI, 