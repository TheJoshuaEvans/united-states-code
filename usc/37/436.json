{"tag":"section","attrib":{"id":"idb0aafa0c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s436"},"text":null,"children":[{"tag":"num","attrib":{"value":"436"},"text":"§ 436.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High-deployment allowance: lengthy or numerous deployments; frequent mobilizations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb0aafa0d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s436/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Monthly Allowance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the military department concerned may pay a high-deployment allowance to a member of the armed forces under the Secretary’s jurisdiction for each month during which the member—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0aafa0e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s436/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is deployed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0aafa0f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s436/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" at any time during that month—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0aafa10-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s436/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been deployed for 191 or more consecutive days (or a lower number of consecutive days prescribed by the Secretary of Defense, acting through the Under Secretary of Defense for Personnel and Readiness);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0aafa11-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s436/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been deployed, out of the preceding 730 days, for a total of 401 or more days (or a lower number of days prescribed by the Secretary of Defense, acting through the Under Secretary of Defense for Personnel and Readiness); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0aafa12-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s436/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a member of a reserve component, is on active duty—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb0aafa13-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s436/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under a call or order to active duty for a period of more than 30 days that is the second (or later) such call or order to active duty (whether voluntary or involuntary) for that member in support of the same contingency operation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb0aafa14-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s436/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a period of more than 30 days under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12304b"},"text":"section 12304b of title 10","children":[],"tail":" or a provision of law referred to in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/a/13/B"},"text":"section 101(a)(13)(B) of title 10","children":[],"tail":", if such period begins within one year after the date on which the member was released from previous service on active duty for a period of more than 30 days under a call or order issued under such a provision of law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0aafa15-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s436/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition of Deployed","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “deployed”, with respect to a member, means that the member is deployed or in a deployment within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s991/b"},"text":"section 991(b) of title 10","children":[],"tail":" (including any definition of “deployment” prescribed under paragraph (4) of that section)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0aafa16-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s436/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rate","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The monthly rate of the allowance payable to a member under this section shall be determined by the Secretary concerned, not to exceed $1,000 per month.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0aafa17-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s436/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment of Claims","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A claim of a member for payment of the high-deployment allowance that is not fully substantiated by the recordkeeping system applicable to the member under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s991/c"},"text":"section 991(c) of title 10","children":[],"tail":" shall be paid if the member furnishes the Secretary concerned with other evidence determined by the Secretary as being sufficient to substantiate the claim."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0aafa18-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s436/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Other Allowances","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A high-deployment allowance payable to a member under this section is in addition to any other pay or allowance payable to the member under any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0aafa19-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s436/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National Security Waiver","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No allowance may be paid under this section to a member for any month during which the applicability of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s991"},"text":"section 991 of title 10","children":[],"tail":" to the member is suspended under subsection (d) of that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0aafa1a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s436/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to Exclude Certain Duty Assignments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned may exclude members serving in specified duty assignments from eligibility for the high-deployment allowance while serving in those assignments. Any such specification of duty assignments may only be made with the approval of the Secretary of Defense, acting through the Under Secretary of Defense for Personnel and Readiness. Specification of a particular duty assignment for purposes of this subsection may not be implemented so as to apply to the member serving in that position at the time of such specification.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0aafa1b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s436/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment From Operation and Maintenance Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The monthly allowance payable to a member under this section shall be paid from appropriations available for operation and maintenance for the armed force in which the member serves.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb0aafa1c-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tV/s586/b"},"text":"Pub. L. 106–65, div. A, title V, § 586(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/638"},"text":"113 Stat. 638","children":[],"tail":", § 435; renumbered § 436 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title V, § 574(c), title X, § 1087(b)(4)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–137, 1654A–292; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tV/s592/a"},"text":"Pub. L. 107–107, div. A, title V, § 592(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1125"},"text":"115 Stat. 1125","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tV/s541/b/1"},"text":"Pub. L. 108–136, div. A, title V, § 541(b)(1)","children":[],"tail":"–(5)(A), "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1476"},"text":"117 Stat. 1476","children":[],"tail":", 1477; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tV/s530/a"},"text":"Pub. L. 112–81, div. A, title V, § 530(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1403"},"text":"125 Stat. 1403","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVI/s602"},"text":"Pub. L. 115–232, div. A, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1794"},"text":"132 Stat. 1794","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb0aafa1d-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb0aafa1e-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb0aafa1f-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(2)(C)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" inserted “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12304b"},"text":"section 12304b of title 10","children":[],"tail":" or” before “a provision of law referred to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":" substituted “may pay” for “shall pay” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s541/b/5/A"},"text":"Pub. L. 108–136, § 541(b)(5)(A)","children":[],"tail":", substituted “High-deployment allowance: lengthy or numerous deployments; frequent mobilizations” for “Per diem allowance for lengthy or numerous deployments” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s541/b/1"},"text":"Pub. L. 108–136, § 541(b)(1)","children":[],"tail":", amended heading and text of subsec. (a) generally. Prior to amendment, text read as follows: “The Secretary of the military department concerned shall pay a high-deployment per diem allowance to a member of the armed forces under the Secretary’s jurisdiction for each day on which the member (1) is deployed, and (2) has, as of that day, been deployed 401 or more days out of the preceding 730 days. The Secretary shall pay the allowance from appropriations available for operation and maintenance for the armed force in which the member serves.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s541/b/2"},"text":"Pub. L. 108–136, § 541(b)(2)","children":[],"tail":", amended heading and text of subsec. (c) generally. Prior to amendment, text read as follows: “The amount of the high-deployment per diem payable to a member under this section is $100.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s541/b/4/A"},"text":"Pub. L. 108–136, § 541(b)(4)(A)","children":[],"tail":", struck out “per diem” before “allowance”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s541/b/4/B"},"text":"Pub. L. 108–136, § 541(b)(4)(B)","children":[],"tail":", substituted “allowance” for “per diem” after “high-deployment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s541/b/4/C"},"text":"Pub. L. 108–136, § 541(b)(4)(C)","children":[],"tail":", substituted “allowance” for “per diem” and “month during which” for “day on which”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (g), (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s541/b/3"},"text":"Pub. L. 108–136, § 541(b)(3)","children":[],"tail":", added subsecs. (g) and (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" inserted at end “The Secretary shall pay the allowance from appropriations available for operation and maintenance for the armed force in which the member serves.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title X, § 1087(b)(4)], renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s435"},"text":"section 435 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title V, § 574(c)(1)], substituted “401 or more days out of the preceding 730 days” for “251 days or more out of the preceding 365 days”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title V, § 574(c)(2)], substituted “prescribed under paragraph (4)” for “prescribed under paragraph (3)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb0aafa20-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb0aafa21-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2011 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tV/s530/b"},"text":"Pub. L. 112–81, div. A, title V, § 530(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1403"},"text":"125 Stat. 1403","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/81/dA/tV/s530/b"},"text":"“The amendment made by subsection (a) [amending this section] shall take effect on the first day of the first month beginning on or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb0aafa22-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tV/s586/d/2"},"text":"Pub. L. 106–65, div. A, title V, § 586(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/639"},"text":"113 Stat. 639","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/65/dA/tV/s586/d/2"},"text":"“Section 435 [now 436] of title 37, United States Code (as added by subsection (b)) [this section], shall take effect on ","children":[{"tag":"date","attrib":{"date":"2001-10-01"},"text":"October 1, 2001","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
