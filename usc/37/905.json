{"tag":"section","attrib":{"id":"idb0b92b17-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s905"},"text":null,"children":[{"tag":"num","attrib":{"value":"905"},"text":"§ 905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reserve officers of the Navy or Marine Corps not on the active-duty list: effective date of pay and allowances","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb0b92b18-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s905/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A reserve officer who is promoted under chapter 1405 of title 10 to a grade above lieutenant (junior grade) in the Navy Reserve or above first lieutenant in the Marine Corps Reserve is entitled to the pay and allowances of the grade to which promoted for duty performed from the date on which he becomes eligible for promotion to that grade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0b92b19-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s905/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A reserve officer who is promoted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14308/b"},"text":"section 14308(b) of title 10","children":[],"tail":" to the grade of lieutenant (junior grade) in the Navy Reserve or first lieutenant in the Marine Corps Reserve is entitled to the pay and allowances of the higher grade for duty performed from the date given him as his date of rank."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb0b92b1a-2930-11f1-a69d-9cbca84c43f0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/649"},"text":"Pub. L. 87–649","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"ta