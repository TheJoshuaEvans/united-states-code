{"tag":"section","attrib":{"id":"idb097e76b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s354"},"text":null,"children":[{"tag":"num","attrib":{"value":"354"},"text":"§ 354.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special pay: 15-year career status bonus for members entering service on or after ","children":[{"tag":"date","attrib":{"date":"1986-08-01"},"text":"August 1, 1986","children":[],"tail":null}],"tail":null},{"tag":"subsection","attrib":{"id":"idb097e76c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s354/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Bonus","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned shall pay a bonus under this section to an eligible career bonus member if the member—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb097e76d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s354/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" elects to receive the bonus under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb097e76e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s354/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" executes a written agreement (prescribed by the Secretary concerned) to remain continuously on active duty until the member has completed 20 years of active-duty service creditable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1405"},"text":"section 1405 of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb097e76f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s354/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Career Bonus Member Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “eligible career bonus member” means a member of a uniformed service serving on active duty who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb097e770-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s354/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" first became a member on or after ","children":[{"tag":"date","attrib":{"date":"1986-08-01"},"text":"August 1, 1986","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb097e771-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s354/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has completed 15 years of active duty in the uniformed services (or has received notification under subsection (e) that the member is about to complete that duty).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb097e772-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s354/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Election Method","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An election under subsection (a)(1) shall be made in such form and within such period as the Secretary concerned may prescribe. An election under that subsection is irrevocable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb097e773-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s354/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount of Bonus; Payment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb097e774-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s354/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A bonus under this section shall be equal to $30,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb097e775-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s354/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A member electing to receive the bonus under this section shall elect one of the following payment options:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb097e776-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s354/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A single lump sum of $30,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb097e777-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s354/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two installments of $15,000 each.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb097e778-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s354/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Three installments of $10,000 each.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb097e779-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s354/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Four installments of $7,500 each.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb097e77a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s354/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Five installments of $6,000 each.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb097e77b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s354/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If a member elects installment payments under paragraph (2), the second installment (and subsequent installments, as applicable) shall be paid on the earlier of the following dates:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb097e77c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s354/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The annual anniversary date of the payment of the first installment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb097e77d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s354/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" January 15 of each succeeding calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb097e77e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s354/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The lump sum payment of the bonus, and the first installment payment in the case of members who elect to receive the bonus in installments, shall be paid to an eligible career bonus member not later than the first month that begins on or after the date that is 60 days after the date on which the Secretary concerned receives from the member the election required under subsection (a)(1) and the written agreement required under subsection (a)(2), if applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb097e77f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s354/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification of Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb097e780-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s354/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned shall transmit to each member who meets the definition of eligible career bonus member a written notification of the opportunity of the member to elect to receive a bonus under this section. The Secretary shall provide the notification not later than 180 days before the date on which the member will complete 15 years of active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb097e781-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s354/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The notification shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb097e782-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s354/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The procedures for electing to receive the bonus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb097e783-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s354/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An explanation of the effects under sections 1401a, 1409, and 1410 of title 10 that such an election has on the computation of any retired or retainer pay that the member may become eligible to receive.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb097e784-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s354/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb097e785-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s354/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a person paid a bonus under this section does not complete a period of active duty beginning on the date on which the election of the person under paragraph (1) of subsection (a) is received and ending on the date on which the person completes 20 years of active duty service as described in paragraph (2) of such subsection, the person shall be subject to the repayment provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s373"},"text":"section 373 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb097e786-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s354/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a person who is paid a bonus under this section subsequently makes an election described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1409/b/4/B"},"text":"section 1409(b)(4)(B) of title 10","children":[],"tail":", the person shall repay any bonus payments received under this section in the same manner as repayments are made under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s373"},"text":"section 373 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb097e787-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s354/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sunset and Continuation of Payments","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb097e788-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s354/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Secretary concerned may not pay a new bonus under this section after ","children":[{"tag":"date","attrib":{"date":"2017-12-31"},"text":"December 31, 2017","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb097e789-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s354/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subsection (f)(2), the Secretary concerned may continue to make payments for bonuses that were awarded under this section on or before the date specified in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb097e78a-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tVI/s642/a"},"text":"Pub. L. 106–65, div. A, title VI, § 642(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/662"},"text":"113 Stat. 662","children":[],"tail":", § 322; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tVI/s620/a"},"text":"Pub. L. 107–107, div. A, title VI, § 620(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1138"},"text":"115 Stat. 1138","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tVI/s687/b/30"},"text":"Pub. L. 109–163, div. A, title VI, § 687(b)(30)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3332"},"text":"119 Stat. 3332","children":[],"tail":"; renumbered § 354 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tVI/s661/b/1"},"text":"Pub. L. 110–181, div. A, title VI, § 661(b)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/178"},"text":"122 Stat. 178","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tVI/s631/c/2"},"text":"Pub. L. 114–92, div. A, title VI, § 631(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/844"},"text":"129 Stat. 844","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb097e78b-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb097e78c-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb097e78d-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/s631/c/2/A"},"text":"Pub. L. 114–92, § 631(c)(2)(A)","children":[],"tail":", designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/s631/c/2/B"},"text":"Pub. L. 114–92, § 631(c)(2)(B)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s661/b/1"},"text":"Pub. L. 110–181, § 661(b)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s322"},"text":"section 322 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s661/b/2"},"text":"Pub. L. 110–181, § 661(b)(2)","children":[],"tail":", substituted “section 373” for “section 303a(e)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":", amended heading and text of subsec. (f) generally, substituting provisions referring to repayment provisions of section 303a(e) for specific provisions relating to repayment required when person elects to receive bonus to remain continuously on active duty until completion of 20 years but fails to complete total period."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s620/a/1"},"text":"Pub. L. 107–107, § 620(a)(1)","children":[],"tail":", substituted “equal to $30,000” for “paid in a single lump sum of $30,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s620/a/2"},"text":"Pub. L. 107–107, § 620(a)(2)","children":[],"tail":", (3), added pars. (2) and (3), redesignated former par. (2) as (4), and substituted therein “The lump sum payment of the bonus, and the first installment payment in the case of members who elect to receive the bonus in installments,” for “The bonus”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb097e78e-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb097e78f-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment; Implementation","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92"},"text":"Pub. L. 114–92","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2018-01-01"},"text":"Jan. 1, 2018","children":[],"tail":", with certain implementation requirements, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/s635"},"text":"section 635 of Pub. L. 114–92","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8432"},"text":"section 8432 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb097e790-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1999-10-01"},"text":"Oct. 1, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/s644"},"text":"section 644 of Pub. L. 106–65","children":[],"tail":", set out as an Effective Date of 1999 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1401a"},"text":"section 1401a of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"idb097e791-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For savings provision relating to payment or repayment of any bonus, incentive pay, special pay, or similar pay obligated to be paid before ","children":[{"tag":"date","attrib":{"date":"2006-04-01"},"text":"Apr. 1, 2006","children":[],"tail":", under a provision of this section amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s687/b"},"text":"section 687(b) of Pub. L. 109–163","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s687/f"},"text":"section 687(f) of Pub. L. 109–163","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s510"},"text":"section 510 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb097e792-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Application to Existing Agreements","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tVI/s620/b"},"text":"Pub. L. 107–107, div. A, title VI, § 620(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1139"},"text":"115 Stat. 1139","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/107/dA/tVI/s620/b"},"text":"“The Secretary concerned (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s101/5"},"text":"section 101(5) of title 37","children":[],"tail":", United States Code) shall extend to each member of the uniformed services who has executed the written agreement required by subsection (a)(2) of section 322 [now 354] of such title before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":"], but who has not received the lump sum payment by that date, an opportunity to make the election authorized by subsection (d) of such section, as amended by this section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
