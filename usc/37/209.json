l":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb0636a03-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb0636a04-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb0636a05-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"209(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:6904(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"[None.]","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"209(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:6905(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"[None.]","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"209(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:6906(c) (1st sentence, as applicable to pay).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"[None.]","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb0636a06-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb0636a07-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":", which directed substitution of “("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3806/d/1"},"text":"50 U.S.C. 3806(d)(1)","children":[],"tail":")” for “(50 U.S.C. App. 456(d)(1))” in par. (1), was executed by making the substitution in par. (3) to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Pub. L. 108–136","children":[],"tail":" added subsec. (c) and redesignated former subsecs. (c) and (d) as (d) and (e), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314"},"text":"Pub. L. 107–314","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title VI, § 612(c)(4)(B)]. See 2000 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" inserted before period at end “, except that the rate for a cadet or midshipman who is a member of the regular component of an armed force shall be the rate of basic pay applicable to the member under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s203"},"text":"section 203 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title VI, § 612(b), (c)(1)], inserted heading, designated first sentence as par. (1), substituted “monthly subsistence allowance at a rate prescribed under paragraph (2)” for “subsistence allowance of $200 a month”, added par. (2), designated last sentence as par. (3), and substituted “A subsistence” for “Subsistence”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title VI, § 612(c)(2)], inserted heading and substituted “at a rate prescribed under subsection (a)” for “in the amount provided in subsection (a)” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title VI, § 612(c)(3)], inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title VI, § 612(c)(4)(B)], as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/107/314"},"text":"Pub. L. 107–314","children":[],"tail":", substituted “a monthly rate prescribed under subsection (a)” for “the same rate as that prescribed by subsection (a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title VI, § 612(c)(4)(A)], inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" substituted “$200 a month” for “$150 a month”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" substituted “$150 a month” for “$100 a month”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsecs. (b) and (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/25"},"text":"Pub. L.