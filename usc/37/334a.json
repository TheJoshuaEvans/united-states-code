{"tag":"section","attrib":{"id":"idb095759a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334a"},"text":null,"children":[{"tag":"num","attrib":{"value":"334a"},"text":"§ 334a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special aviation incentive pay and bonus authorities: enlisted members who operate remotely piloted aircraft","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb095759b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Aviation Incentive Pay.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb095759c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Incentive pay authorized","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned may pay aviation incentive pay under this section to an enlisted member in a regular or reserve component of a uniformed service who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb095759d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is entitled to basic pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s204"},"text":"section 204 of this title","children":[],"tail":" or compensation under 206 of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb095759e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is designated as a remotely piloted aircraft pilot, or is in training leading to such a designation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb095759f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334a/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engages in, or is in training leading to, frequent and regular performance of operational flying duty or proficiency flying duty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb09575a0-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334a/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engages in or remains in aviation service for a specified period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb09575a1-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334a/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets such other criteria as the Secretary concerned determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09575a2-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enlisted members not currently engaged in flying duty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned may pay aviation incentive pay under this section to an enlisted member who is otherwise qualified for such pay but who is not currently engaged in the performance of operational flying duty or proficiency flying duty if the Secretary determines, under regulations prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s374"},"text":"section 374 of this title","children":[],"tail":", that payment of aviation pay to that enlisted member is in the best interests of the service."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09575a3-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Aviation Bonus","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned may pay an aviation bonus under this section to an enlisted member in a regular or reserve component of a uniformed service who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb09575a4-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is entitled to aviation incentive pay under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09575a5-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is within one year of completing the enlistment of the member;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09575a6-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" reenlists or voluntarily extends the enlistment of the member—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb09575a7-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334a/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a period of at least one year; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb09575a8-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334a/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of an enlisted member serving pursuant to an indefinite reenlistment, executes a written agreement—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb09575a9-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334a/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to remain on active duty for a period of at least one year; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb09575aa-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334a/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to remain in an active status in a reserve component for a period of at least one year; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09575ab-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets such other criteria as the Secretary concerned determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09575ac-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum Amount and Method of Payment.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb09575ad-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum amount","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned shall determine the amount of a bonus or incentive pay to be paid under this section, except that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb09575ae-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aviation incentive pay under subsection (a) shall be paid at a monthly rate not to exceed $1,000 per month; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb09575af-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an aviation bonus under subsection (b) may not exceed $35,000 for each 12-month period of obligated service agreed to under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09575b0-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lump sum or installments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A bonus under this section may be paid in a lump sum or in periodic installments, as determined by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09575b1-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fixing bonus amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon acceptance by the Secretary concerned of the written agreement required by subsection (d), the total amount of the bonus to be paid under the agreement shall be fixed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09575b2-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Written Agreement for Bonus","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To receive an aviation bonus under this section, an enlisted member determined to be eligible for the bonus shall enter into a written agreement with the Secretary concerned that specifies—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb09575b3-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the bonus;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09575b4-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the method of payment of the bonus under subsection (c)(2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09575b5-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period of obligated service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09575b6-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type or conditions of the service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09575b7-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reserve Component Enlisted Members Performing Inactive Duty Training","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An enlisted member of reserve component who is entitled to compensation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s206"},"text":"section 206 of this title","children":[],"tail":" and who is authorized aviation incentive pay under this section may be paid an amount of incentive pay that is proportionate to the compensation received under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s206"},"text":"section 206 of this title","children":[],"tail":" for inactive-duty training."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09575b8-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Other Pay and Allowances.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb09575b9-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Aviation incentive pay","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Aviation incentive pay paid to an enlisted member under subsection (a) shall be in addition to any other pay and allowance to which the enlisted member is entitled, except that an enlisted member may not receive a payment under such subsection and section 351(a)(2) or 353(a) of this title for the same skill and period of service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09575ba-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Aviation bonus","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An aviation bonus paid to an enlisted member under subsection (b) shall be in addition to any other pay and allowance to which the enlisted member is entitled, except that an enlisted member may not receive a bonus payment under such subsection and section 331 or 353(b) of this title for the same skill and period of service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09575bb-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An enlisted member who receives aviation incentive pay or an aviation bonus under this section and who fails to fulfill the eligibility requirements for the receipt of the incentive pay or bonus or complete the period of service for which the incentive pay or bonus is paid, as specified in the written agreement under subsection (d) in the case of a bonus, shall be subject to the repayment provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s373"},"text":"section 373 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09575bc-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb09575bd-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334a/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Aviation service","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “aviation service” means participation in aerial flight performed, under regulations prescribed by the Secretary concerned, by an eligible enlisted member who is a remotely piloted aircraft pilot.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09575be-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334a/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operational flying duty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “operational flying duty” means flying performed under competent orders by enlisted members of the regular or reserve components while serving in assignments in which basic flying skills are normally maintained in the performance of assigned duties as determined by the Secretary concerned, and flying duty performed by members in training that leads to designation as a remotely piloted aircraft pilot by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09575bf-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334a/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Proficiency flying duty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “proficiency flying duty” means flying performed under competent orders by enlisted members of the regular or reserve components while serving in assignments in which such skills would normally not be maintained in the performance of assigned duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09575c0-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334a/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No agreement may be entered into under this section after ","children":[{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb09575c1-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tVI/s617/a"},"text":"Pub. L. 115–91, div. A, title VI, § 617(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1424"},"text":"131 Stat. 1424","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
