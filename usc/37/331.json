{"tag":"section","attrib":{"id":"idb093050a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s331"},"text":null,"children":[{"tag":"num","attrib":{"value":"331"},"text":"§ 331.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General bonus authority for enlisted members","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb093050b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s331/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to Provide Bonus","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned may pay a bonus under this section to a person, including a member of the armed forces, who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb093050c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s331/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enlists in an armed force;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb093050d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s331/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enlists in or affiliates with a reserve component of an armed force;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb093050e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s331/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" reenlists, voluntarily extends an enlistment, or otherwise agrees to serve—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb093050f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s331/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a specified period in a designated career field, skill, or unit of an armed force; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0930510-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s331/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under other conditions of service in an armed force;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0930511-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s331/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfers from a regular component of an armed force to a reserve component of that same armed force or from a reserve component of an armed force to the regular component of that same armed force;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0930512-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s331/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfers from a regular component or reserve component of an armed force to a regular component or reserve component of another armed force, subject to the approval of the Secretary with jurisdiction over the armed force to which the member is transferring; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0930513-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s331/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfers from a regular component or reserve component of an armed force to the Space Force or from the Space Force to a regular component or reserve component of another armed force, subject to the approval of the Secretary with jurisdiction over the armed force to which the member is transferring.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0930514-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s331/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Service Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A bonus authorized by subsection (a) may be paid to a person or member only if the person or member agrees under subsection (d)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0930515-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s331/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to serve for a specified period in a designated career field, skill, unit, or grade; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0930516-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s331/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to meet some other condition or conditions of service imposed by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0930517-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s331/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum Amount and Method of Payment.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0930518-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s331/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum amount","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned shall determine the amount of a bonus to be paid under this section, except that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0930519-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s331/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a bonus paid under paragraph (1) or (2) of subsection (a) may not exceed $75,000 for a minimum two-year period of obligated service agreed to under subsection (d);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb093051a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s331/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a bonus paid under paragraph (3) of subsection (a) may not exceed $50,000 for each year of obligated service in a regular component, or in the Space Force on sustained duty under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s20105"},"text":"section 20105 of title 10","children":[],"tail":", agreed to under subsection (d);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb093051b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s331/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a bonus paid under paragraph (3) of subsection (a) may not exceed $15,000 for each year of obligated service in a reserve component, or in the Space Force in space force active status not on sustained duty under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s20105"},"text":"section 20105 of title 10","children":[],"tail":", agreed to under subsection (d); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb093051c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s331/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a bonus paid under paragraph (4), (5), or (6) of subsection (a) may not exceed $10,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb093051d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s331/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lump sum or installments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A bonus under this section may be paid in a lump sum or in periodic installments, as determined by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb093051e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s331/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fixing bonus amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon acceptance by the Secretary concerned of the written agreement required by subsection (d), the total amount of the bonus to be paid under the agreement shall be fixed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb093051f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s331/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Written Agreement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To receive a bonus under this section, a person or member determined to be eligible for the bonus shall enter into a written agreement with the Secretary concerned that specifies—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0930520-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s331/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the bonus;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0930521-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s331/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the method of payment of the bonus under subsection (c)(2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0930522-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s331/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period of obligated service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0930523-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s331/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type or conditions of the service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0930524-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s331/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Other Pay and Allowances","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A bonus paid to a person or member under this section is in addition to any other pay and allowance to which the person or member is entitled.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0930525-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s331/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Prohibition on Bounties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A bonus authorized under this section is not a bounty for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s514/a"},"text":"section 514(a) of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0930526-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s331/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person or member who receives a bonus under this section and who fails to complete the period of service, or meet the conditions of service, for which the bonus is paid, as specified in the written agreement under subsection (d), shall be subject to the repayment provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s373"},"text":"section 373 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0930527-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s331/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No agreement may be entered into under this section after ","children":[{"tag":"date","attrib":{"date":"2026-12-31"},"text":"December 31, 2026","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb0930528-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tVI/s661/a/2"},"text":"Pub. L. 110–181, div. A, title VI, § 661(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/163"},"text":"122 Stat. 163","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tVI/s614/1"},"text":"Pub. L. 111–84, div. A, title VI, § 614(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2353"},"text":"123 Stat. 2353","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tVI/s614/1"},"text":"Pub. L. 111–383, div. A, title VI, § 614(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4237"},"text":"124 Stat. 4237","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVI/s614/1"},"text":"Pub. L. 112–81, div. A, title VI, § 614(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1450"},"text":"125 Stat. 1450","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tVI/s614/1"},"text":"Pub. L. 112–239, div. A, title VI, § 614(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1777"},"text":"126 Stat. 1777","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tVI/s614/1"},"text":"Pub. L. 113–66, div. A, title VI, § 614(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/780"},"text":"127 Stat. 780","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tVI/s614/1"},"text":"Pub. L. 113–291, div. A, title VI, § 614(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3400"},"text":"128 Stat. 3400","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tVI/s614/1"},"text":"Pub. L. 114–92, div. A, title VI, § 614(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/838"},"text":"129 Stat. 838","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVI/s614/1"},"text":"Pub. L. 114–328, div. A, title VI, § 614(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2158"},"text":"130 Stat. 2158","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tVI/s614/1"},"text":"Pub. L. 115–91, div. A, title VI, § 614(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1422"},"text":"131 Stat. 1422","children":[],"tail":"; "},{"tag