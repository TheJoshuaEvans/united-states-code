 App. 1003 (2d proviso of 2d sentence)","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"553(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50 App. 1004.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1942-03-07/ch166/s4"},"text":"Mar. 7, 1942, ch. 166, § 4","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/56/144"},"text":"56 Stat. 144","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1942-12-24/ch828/s1"},"text":"Dec. 24, 1942, ch. 828, § 1","children":[],"tail":" (2d par.), "},{"tag":"html:a","attrib":{"href":"/us/stat/56/1093"},"text":"56 Stat. 1093","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1944-07-01/ch371/s4"},"text":"July 1, 1944, ch. 371, § 4","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/58/680"},"text":"58 Stat. 680","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"553(f)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"553(g)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50 App. 1006 (1st sentence).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"50 App. 1014 (as applicable to § 1006 (1st sentence)).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"50 App. 1006 (2d sentence, as applicable to allotments).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1942-03-07/ch166/s6"},"text":"Mar. 7, 1942, ch. 166, § 6","children":[],"tail":" (1st sentence and 2d sentence, as applicable to allotments); added "},{"tag":"html:a","attrib":{"href":"/us/act/1942-12-24/ch828/s1"},"text":"Dec. 24, 1942, ch. 828, § 1","children":[],"tail":" (4th par.), "},{"tag":"html:a","attrib":{"href":"/us/stat/56/1093"},"text":"56 Stat. 1093","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1953-04-04/ch17/s1/b"},"text":"Apr. 4, 1953, ch. 17, § 1(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/67/21"},"text":"67 Stat. 21","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Aug. 14, 1964","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/88/428/s1/5"},"text":"Pub. L. 88–428, § 1(5)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/78/437"},"text":"78 Stat. 437","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"553(h)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50 App. 1007.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1942-03-07/ch166/s7"},"text":"Mar. 7, 1942, ch. 166, § 7","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/56/145"},"text":"56 Stat. 145","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Aug. 14, 1964","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/88/428/s1/6"},"text":"Pub. L. 88–428, § 1(6)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/78/437"},"text":"78 Stat. 437","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1942-03-07/ch166/s14"},"text":"Mar. 7, 1942, ch. 166, § 14","children":[],"tail":" (as applicable to § 6 (1st sentence)), "},{"tag":"html:a","attrib":{"href":"/us/stat/56/147"},"text":"56 Stat. 147","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1953-04-04/ch17/s1/e"},"text":"Apr. 4, 1953, ch. 17, § 1(e)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/67/21"},"text":"67 Stat. 21","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Only that portion of the source law which is applicable to members of the uniformed services and their dependents is codified in this section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “a member of a uniformed service . . . in a missing status . . . he . . . under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s552"},"text":"section 552 of this title","children":[],"tail":"” are substituted for “any person . . . under section 2 of this Act . . . his absence”, for clarity and to conform to the definition in revised section 551(2) of this chapter. The words “except as otherwise herein provided” are omitted as unnecessary."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “Secretary concerned, he, or his designee,” are substituted for “head of the department concerned . . . head of the department concerned, or such subordinate as he may designate” to conform to the definition in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s101/5"},"text":"37 U.S.C. 101(5)","children":[],"tail":". The word “member” is substituted for “person” to conform to the definition in "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s101/23"},"text":"37 U.S.C. 101(23)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “in effect” are omitted as unnecessary. The words “member in a missing status” are substituted for “absent person” to conform to the definition in revised section 551(2) of this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “United States” are substituted for “Government” to conform to the style of title 37. The word “member” is substituted for “person” to conform to the definition in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s101/23"},"text":"37 U.S.C. 101(23)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “Secretary concerned, or his designee,” are substituted for “head of the department concerned, or such subordinates as he may designate,” to conform to the definition in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s101/5"},"text":"37 U.S.C. 101(5)","children":[],"tail":". The words “United States” are substituted for “Government” to conform to the style of title 37. The words “when he considers it” are substituted for “When circumstances are deemed to justify such action”. The word “member” is substituted for “person”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f), the words “When the Secretary concerned officially reports that a member in a missing status” are substituted for “When it is officially reported by the head of the department concerned that a person missing under the conditions specified in section 2 of this Act”. The words “the payments of allotments authorized by subsections (a)–(d) of this section may, subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s552"},"text":"section 552 of this title","children":[],"tail":" . . . until the date the Secretary concerned” are substituted for “the payments authorized by section 3 of this Act are, subject to the provisions of section 2 of this Act, authorized to be made for a period not to extend beyond the date of the receipt by the head of the department concerned”. The words “the member” are substituted for “the missing person”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (g), the words “A member in a missing status” are substituted for “a person missing under the conditions specified in section 2 of this Act”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (h), the words “Secretary concerned” are substituted for “head of the department concerned.” The words “a member on active duty” are substituted for “of persons in active service” to conform to the definitions in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s101/20"},"text":"37 U.S.C. 101(20)","children":[],"tail":" and (23). In clause (2), the words “heretofore or hereafter” are omitted as unnecessary."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb0b47013-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb0b47014-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s569/c/3/A"},"text":"Pub. L. 104–106, § 569(c)(3)(A)","children":[],"tail":", substituted “the date on which, in a case covered by "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s555"},"text":"section 555 of this title","children":[],"tail":", the Secretary concerned receives evidence, or, in a case covered by chapter 76 of title 10, the Secretary concerned determines pursuant to that chapter, that” for “the date the Secretary concerned receives evidence that”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s569/c/3/B"},"text":"Pub. L. 104–106, § 569(c)(3)(B)","children":[],"tail":", inserted “or under chapter 76 of title 10” after “"},{"tag":"ref","attrib":{"href":"/us/usc/t37/s555"},"text":"section 555 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsecs. (e) to (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/25"},"text":"Pub. L. 102–25","children":[],"tail":" struck out “of this section” after “subsections (f) and (g)” in subsec. (e) and after “subsections (a)–(d)” in subsecs. (f) and (g)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
