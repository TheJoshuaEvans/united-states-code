html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"37:241(a) (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"306(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"37:241(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"306(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"37:241(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"306(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"37:241(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"306(f)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"37:241(e).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “an armed force under his jurisdiction” are substituted for the words “the service concerned” in the first sentence of section 241(a) of existing title 37 to conform to the last sentence of that subsection.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “(other than for training)” are inserted for clarity, since members on duty for training only are not included in computing strength authorizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb07ff205-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb07ff206-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s616/a/1"},"text":"Pub. L. 108–136, § 616(a)(1)","children":[],"tail":", designated existing provisions as par. (1), substituted “described in paragraph (2)” for “who is entitled to the basic pay of pay grade O–6 or below and”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s616/a/3"},"text":"Pub. L. 108–136, § 616(a)(3)","children":[],"tail":", added subsec. (b). Former subsec. (b) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s616/a/2"},"text":"Pub. L. 108–136, § 616(a)(2)","children":[],"tail":", redesignated subsec. (b) as (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s616/b"},"text":"Pub. L. 108–136, § 616(b)","children":[],"tail":", designated existing provisions as par. (1), inserted “or mobilization in support of a contingency operation” after “training”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s616/a/2"},"text":"Pub. L. 108–136, § 616(a)(2)","children":[],"tail":", redesignated subsec. (c) as (d). Former subsec. (d) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s616/a/2"},"text":"Pub. L. 108–136, § 616(a)(2)","children":[],"tail":", redesignated subsecs. (d) and (e) as (e) and (f), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" substituted “of Homeland Security” for “of Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/587/s5205/a"},"text":"Pub. L. 102–587, § 5205(a)","children":[],"tail":", substituted “of pay grade O–6 or below” for “of pay grade O–3, O–4, O–5, or O–6” in text and amended table by substituting “O–4 and below” for “O–4” and striking out line providing monthly rate of $50 for pay grade O–3."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/587/s5205/b"},"text":"Pub. L. 102–587, § 5205(b)","children":[],"tail":", substituted “in each of the pay grades O–3 and below,” for “in pay grade O–3,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510"},"text":"Pub. L. 101–510","children":[],"tail":" struck out subsec. (f) which read as follows: “The Secretary of Defense shall report to Congress by March 1 of each year following a calendar year in which special pay is disbursed under this section. Negative reports need not be submitted.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/322"},"text":"Pub. L. 97–322","children":[],"tail":" struck out last sentence providing that the Secretary of Transportation shall make a similar report for the Coast Guard when the Coast Guard is not operating as a service in the Navy."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/284"},"text":"Pub. L. 96–284","children":[],"tail":" made section inapplicable to a person entitled to special pay under section 302a or 302b of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/470"},"text":"Pub. L. 96–470","children":[],"tail":" substituted provision requiring the Secretary of Defense to report by Mar. 1 of each year following a calendar year in which special pay is disbursed under this section and providing that negative reports need not be submitted for provision requiring the Secretary of Defense to report by Mar. 1 of each year on the administration of this section within each military department during the preceding calendar year."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—Subsecs. (d), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/623"},"text":"Pub. L. 90–623","children":[],"tail":" substituted “Secretary of Transportation” for “Secretary of the Treasury”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb07ff207-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attr