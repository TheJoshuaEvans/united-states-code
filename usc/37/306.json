{"tag":"section","attrib":{"id":"idb07ff1f5-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s306"},"text":null,"children":[{"tag":"num","attrib":{"value":"306"},"text":"§ 306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special pay: officers holding positions of unusual responsibility and of critical nature","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb07ff1f6-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s306/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb07ff1f7-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s306/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned may designate positions of unusual responsibility which are of a critical nature to an armed force under his jurisdiction and may pay special pay, in addition to other pay prescribed by law, to an officer of an armed force described in paragraph (2) who is performing the duties of such a position, at the following monthly rates:","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb07ff1f8-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Pay Grade","children":[],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Monthly Rate","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"O–6","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"$150","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"O–5","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"100","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"O–4 and below","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb07ff1f9-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s306/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer of the armed forces referred to in paragraph (1) is an officer who is entitled to the basic pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s204"},"text":"section 204 of this title","children":[],"tail":", or the compensation under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s206"},"text":"section 206 of this title","children":[],"tail":", of pay grade O–6 or below."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb07ff1fa-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s306/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If an officer entitled to compensation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s206"},"text":"section 206 of this title","children":[],"tail":" is paid special pay under subsection (a) for the performance of duties in a position designated under such subsection, the special pay shall be paid at the rate of "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":"⁄"},{"tag":"sub","attrib":{},"text":"30","children":[],"tail":" of the monthly rate authorized by such subsection for each day of the performance of duties in the designated position."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb07ff1fb-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s306/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned shall prescribe the criteria and circumstances under which officers of an armed force under his jurisdiction are eligible for special pay under this section and, when he considers it necessary, may abolish that special pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb07ff1fc-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s306/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb07ff1fd-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s306/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than 5 percent of the number of officers on active duty (other than for training or mobilization in support of a contingency operation) in an armed force in each of the pay grades O–3 and below, and not more than 10 percent of the number of officers on active duty in an armed force in pay grade O–4, O–5, or O–6, may be paid special pay under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb07ff1fe-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s306/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Of the number of officers in the Selected Reserve of the Ready Reserve of an armed force who are not on active duty (other than for training or mobilization in support of a contingency operation), not more than 5 percent of the number of such officers in each of the pay grades O–3 and below, and not more than 10 percent of the number of such officers in pay grade O–4, O–5, or O–6, may be paid special pay under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb07ff1ff-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s306/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section shall be administered under regulations prescribed by the Secretary of Defense for the armed forces under his jurisdiction, and by the Secretary of Homeland Security for the Coast Guard when the Coast Guard is not operating as a service in the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb07ff200-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s306/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section does not apply to a person who is entitled to special pay under section 302, 302a, 302b, or 303 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb07ff201-2930-11f1-a69d-9cbca84c43f0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/649"},"text":"Pub. L. 87–649","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/466"},"text":"76 Stat. 466","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/623/s3/1"},"text":"Pub. L. 90–623, § 3(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1314"},"text":"82 Stat. 1314","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/284/s6"},"text":"Pub. L. 96–284, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-28"},"text":"June 28, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/593"},"text":"94 Stat. 593","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/470/tII/s202/b"},"text":"Pub. L. 96–470, title II, § 202(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-19"},"text":"Oct. 19, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2242"},"text":"94 Stat. 2242","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/322/tI/s116"},"text":"Pub. L. 97–322, title I, § 116","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-15"},"text":"Oct. 15, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1586"},"text":"96 Stat. 1586","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXIII/s1322/c/3"},"text":"Pub. L. 101–510, div. A, title XIII, § 1322(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1672"},"text":"104 Stat. 1672","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/587/tV/s5205"},"text":"