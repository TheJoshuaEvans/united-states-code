ail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “disability retirement pay” are omitted as covered by the words “retired pay”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb07b3762-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb07b3763-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title VI, § 629(1)], substituted “who is an officer in the Biomedical Sciences Corps and holds a degree in veterinary medicine” for “who is designated as a veterinary officer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title VI, § 629(2)], added subpar. (B) and struck out former subpar. (B) which read as follows: “of a Reserve component of the Air Force, of the Army or the Air Force without specification of component, or of the National Guard, who is designated as a veterinary officer of the Army or the Air Force, as the case may be; or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" designated existing provisions as subsec. (a), inserted subsec. heading, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/25"},"text":"Pub. L. 102–25","children":[],"tail":" struck out “of this subsection” after “clause (1) or (2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180"},"text":"Pub. L. 100–180","children":[],"tail":" substituted semicolon for comma at end of par. (2)(A) and “; or” for “, or” at end of par. (2)(B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/26"},"text":"Pub. L. 100–26","children":[],"tail":" substituted “A” for “a” at beginning of pars. (1) to (3), semicolon for comma at end of par. (1)(A), “; or” for “, or” at end of par. (1)(B), period for semicolon at end of par. (1)(C), and period for “; and” at end of par. (2); and directed substitution of semicolon for comma at end of par. (1)(B) which could not be executed because no comma appeared at end of par. (1)(B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/284"},"text":"Pub. L. 96–284","children":[],"tail":" substituted “Each” for “(a) In addition to any other basic pay, special pay, incentive pay or allowance to which he is entitled, each”, struck out “beginning on or after "},{"tag":"date","attrib":{"date":"1977-10-01"},"text":"October 1, 1977","children":[],"tail":"” after “active duty”, struck out subsec. (b) which prohibited inclusion of active duty monthly special pay in computation of amount of increase in pay authorized in any other provision of this title or in computation of retired pay or severance pay, and struck out subsec. (c) which provided that no special pay be paid for any month after September 1980."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/485"},"text":"Pub. L. 95–485","children":[],"tail":" substituted “September 1980” for “September 1978”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/114"},"text":"Pub. L. 95