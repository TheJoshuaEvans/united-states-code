{"tag":"section","attrib":{"id":"idb07b3750-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s303"},"text":null,"children":[{"tag":"num","attrib":{"value":"303"},"text":"§ 303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special pay: veterinarians","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb07b3751-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Monthly Special Pay","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each of the following officers is entitled to special pay at the rate of $100 a month for each month of active duty:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb07b3752-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s303/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A commissioned officer—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb07b3753-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s303/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the Regular Army who is in the Veterinary Corps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb07b3754-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s303/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the Regular Air Force who is an officer in the Biomedical Sciences Corps and holds a degree in veterinary medicine; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb07b3755-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s303/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is a veterinary officer of the Regular Corps of the Public Health Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb07b3756-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s303/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A commissioned officer—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb07b3757-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s303/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of a Reserve component of the Army who is in the Veterinary Corps of the Army;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb07b3758-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s303/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" of a reserve component of the Air Force, of the Army or the Air Force without specification of component, or of the National Guard, who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb07b3759-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s303/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is designated as a veterinary officer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb07b375a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s303/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an officer in the Biomedical Sciences Corps of the Air Force and holds a degree in veterinary medicine; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb07b375b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s303/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is a veterinary officer of the Reserve Corps ","children":[{"tag":"ref","attrib":{"idref":"fn002006"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002006"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Change of Name note below."}],"tail":" of the Public Health Service,"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"who is on active duty as a result of a call or order to active duty for a period of at least one year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb07b375c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s303/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A general officer of the Army or the Air Force appointed, from any of the categories named in clause (1) or (2), in the Army, the Air Force, or the National Guard, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb07b375d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Special Pay for Board Certification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A commissioned officer entitled to special pay under subsection (a) who has been certified as a Diplomate in a specialty recognized by the American Veterinarian Medical Association is entitled to special pay (in addition to the special pay under subsection (a)) at the same rate as is provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s302c/b"},"text":"section 302c(b) of this title","children":[],"tail":" for an officer referred to in that section who has the same number of years of creditable service as the commissioned officer."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb07b375e-2930-11f1-a69d-9cbca84c43f0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/649"},"text":"Pub. L. 87–649","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/465"},"text":"76 Stat. 465","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/2/s5"},"text":"Pub. L. 88–2, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-03-28"},"text":"Mar. 28, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/4"},"text":"77 Stat. 4","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/40/s5"},"text":"Pub. L. 90–40, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-06-30"},"text":"June 30, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/105"},"text":"81 Stat. 105","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/129/tI/s104"},"text":"Pub. L. 92–129, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-09-28"},"text":"Sept. 28, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/355"},"text":"85 Stat. 355","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/64/tII/s203"},"text":"Pub. L. 93–64, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-07-09"},"text":"July 9, 1973","children":[],"tail"