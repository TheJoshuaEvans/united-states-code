{"tag":"section","attrib":{"id":"idb0930569-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334"},"text":null,"children":[{"tag":"num","attrib":{"value":"334"},"text":"§ 334.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special aviation incentive pay and bonus authorities for officers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb093056a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Aviation Incentive Pay.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb093056b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Incentive pay authorized","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned may pay aviation incentive pay under this section to an officer of a uniformed service who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb093056c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is entitled to basic pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s204"},"text":"section 204 of this title","children":[],"tail":" or compensation under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s206"},"text":"section 206 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb093056d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintains, or is in training leading to, an aeronautical rating or designation that qualifies the officer to engage in operational flying duty or proficiency flying duty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb093056e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engages in, or is in training leading to, frequent and regular performance of operational flying duty or proficiency flying duty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb093056f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engages in or remains in aviation service for a specified period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0930570-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets such other criteria as the Secretary concerned determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0930571-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Officers not currently engaged in flying duty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned may pay aviation incentive pay under this section to an officer who is otherwise qualified for such pay but who is not currently engaged in the performance of operational flying duty or proficiency flying duty if the Secretary determines, under regulations prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s374"},"text":"section 374 of this title","children":[],"tail":", that payment of aviation incentive pay to that officer is in the best interests of the service."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0930572-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Aviation Bonus","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned may pay an aviation bonus under this section to an officer of a uniformed service who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0930573-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is entitled to aviation incentive pay under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0930574-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has completed any active duty service commitment incurred for undergraduate aviator training or is within one year of completing such commitment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0930575-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" executes a written agreement to remain on active duty in a regular component or to serve in an active status in a reserve component, or, in the case of an officer of the Space Force, to remain in space force active status in aviation service for at least one year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0930576-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets such other criteria as the Secretary concerned determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0930577-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum Amount and Method of Payment.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0930578-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum amount","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned shall determine the amount of a bonus or incentive pay to be paid under this section, except that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0930579-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aviation incentive pay under subsection (a) shall be paid at a monthly rate not to exceed $1,500 per month; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb093057a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an aviation bonus under subsection (b) may not exceed $50,000 for each 12-month period of obligated service agreed to under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb093057b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual business case for payment of aviation bonus amounts.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb093057c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned shall determine the amount of the aviation bonus payable under paragraph (1)(B) under agreements entered into under subsection (d) during a fiscal year solely through a business case analysis of the amount required to be paid under such agreements in order to address anticipated manning shortfalls for such fiscal year by aircraft type category.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb093057d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Budget justification documents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The budget justification documents in support of the budget of the President for a fiscal year (as submitted to Congress pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":") shall set forth for each uniformed service the following:"}],"tail":null},{"tag":"clause","attrib":{"id":"idb093057e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount requested for the payment of aviation bonuses under subsection (b) using amounts authorized to be appropriated for the fiscal year concerned by aircraft type category.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb093057f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The business case analysis supporting the amount so requested by aircraft type category.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb0930580-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For each aircraft type category, whether or not the amount requested will permit the payment during the fiscal year concerned of the maximum amount of the aviation bonus authorized by paragraph (1)(B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb0930581-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334/c/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If any amount requested is to address manning shortfalls, a description of any plans of the Secretary concerned to address such shortfalls by nonmonetary means.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0930582-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lump sum or installments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A bonus under this section may be paid in a lump sum or in periodic installments, as determined by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0930583-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fixing bonus amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon acceptance by the Secretary concerned of the written agreement required by subsection (d), the total amount of the bonus to be paid under the agreement shall be fixed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0930584-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Written Agreement for Bonus","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To receive an aviation officer bonus under this section, an officer determined to be eligible for the bonus shall enter into a written agreement with the Secretary concerned that specifies—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0930585-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the bonus;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0930586-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the method of payment of the bonus under subsection (c)(2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0930587-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period of obligated service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0930588-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type or conditions of the service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0930589-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Officers Performing Inactive Duty Training","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer who is entitled to compensation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s206"},"text":"section 206 of this title","children":[],"tail":" and who is authorized aviation incentive pay under this section may be paid an amount of incentive pay that is proportionate to the compensation received under section 206 for inactive-duty training."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb093058a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Other Pay and Allowances.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb093058b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Aviation incentive pay","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Aviation incentive pay paid to an officer under subsection (a) shall be in addition to any other pay and allowance to which the officer is entitled, except that an officer may not receive a payment under such subsection and section 351(a)(2) or 353(a) of this title for the same skill and period of service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb093058c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Aviation bonus","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An aviation bonus paid to an officer under subsection (b) shall be in addition to any other pay and allowance to which the officer is entitled, except that an officer may not receive a bonus payment under such subsection and section 332 or 353(b) of this title for the same skill and period of service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb093058d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer who receives aviation incentive pay or an aviation bonus under this section and who fails to fulfill the eligibility requirements for the receipt of the incentive pay or bonus or complete the period of service for which the incentive pay or bonus is paid, as specified in the written agreement under subsection (d) in the case of a bonus, shall be subject to the repayment provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s373"},"text":"section 373 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb093058e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb093058f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “aviation service” means service performed by an officer while holding an aeronautical rating or designation or while in training to receive an aeronautical rating or designation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0930590-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “operational flying duty” means flying performed under competent orders by rated or designated officers while serving in assignments in which basic flying skills normally are maintained in the performance of assigned duties as determined by the Secretary concerned, and flying performed by members in training that leads to the award of an aeronautical rating or designation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0930591-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “proficiency flying duty” means flying performed under competent orders by rated or designated officers while serving in assignments in which such skills would normally not be maintained in the performance of assigned duties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0930592-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “officer” includes an individual enlisted and designated as an aviation cadet under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8411"},"text":"section 8411 of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0930593-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s334/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No agreement may be entered into under this section after ","children":[{"tag":"date","attrib":{"date":"2026-12-31"},"text":"December 31, 2026","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb0930594-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tVI/s661/a/2"},"text":"Pub. L. 110–181, div. A, title VI, § 661(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/167"},"text":"122 Stat. 167","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title VI, § 618(b), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4486"},"text":"122 Stat. 4486","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tVI/s614/4"},"text":"Pub. L. 111–84, div. A, title VI, § 614(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2353"},"text":"123 Stat. 2353","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tVI/s614/4"},"text":"Pub. L. 111–383, div. A, title VI, § 614(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4237"},"text":"124 Stat. 4237","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVI/s614/4"},"text":"Pub. L. 112–81, div. A, title VI, § 614(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12