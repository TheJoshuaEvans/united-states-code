{"tag":"section","attrib":{"id":"idb0a617f8-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s414"},"text":null,"children":[{"tag":"num","attrib":{"value":"414"},"text":"§ 414.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personal money allowance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb0a617f9-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s414/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allowance for Officers Serving in Certain Ranks or Positions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to other pay or allowances authorized by this title, an officer who is entitled to basic pay is entitled to a personal money allowance of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0a617fa-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s414/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $500 a year, while serving in the grade of lieutenant general or vice admiral, or in an equivalent grade or rank;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0a617fb-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s414/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,200 a year, in place of any other personal money allowance authorized by this section while serving as Surgeon General of the Public Health Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0a617fc-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s414/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,200 a year, in addition to the personal money allowance authorized by clause (1), while serving as a senior member of the Military Staff Committee of the United Nations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0a617fd-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s414/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,200 a year, while serving in the grade of general or admiral, or in an equivalent grade or rank; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0a617fe-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s414/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $4,000 a year, in place of any other personal money allowance authorized by this section, while serving as Chief of Staff of the Army, Chief of Naval Operations, Chief of Staff of the Air Force, Commandant of the Marine Corps, Chief of Space Operations, Commandant of the Coast Guard, or Chief of the National Guard Bureau.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0a617ff-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s414/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allowance for Senior Enlisted Members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In addition to other pay or allowances authorized by this title, a noncommissioned officer is entitled to a personal money allowance of $2,000 a year while serving as the Sergeant Major of the Army, the Master Chief Petty Officer of the Navy, the Chief Master Sergeant of the Air Force, the Sergeant Major of the Marine Corps, the Chief Master Sergeant of the Space Force, the Master Chief Petty Officer of the Coast Guard, the Senior Enlisted Advisor to the Chairman of the Joint Chiefs of Staff, or the Senior Enlisted Advisor to the Chief of the National Guard Bureau.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb0a61800-2930-11f1-a69d-9cbca84c43f0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/649"},"text":"Pub. L. 87–649","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/476"},"text":"76 Stat. 476","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/718/s49/a/2"},"text":"Pub. L. 89–718, § 49(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1121"},"text":"80 Stat. 1121","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/25/tVII/s702/b/2"},"text":"Pub. L. 102–25, title VII, § 702(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-04-06"},"text":"Apr. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/117"},"text":"105 Stat. 117","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title VI, § 609(a), (b)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–149; "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tV/s557/a/2"},"text":"Pub. L. 108–375, div. A, title V, § 557(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1915"},"text":"118 Stat. 1915","chil