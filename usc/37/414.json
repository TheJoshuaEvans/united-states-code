,"attrib":{},"text":"414(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"37:257.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1946-08-02/ch756/s3"},"text":"Aug. 2, 1946, ch. 756, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/60/853"},"text":"60 Stat. 853","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “pay or” are inserted to conform to subsection (a). The word “position” is substituted for the words “capacities” and “officers”, respectively. In clause (1), the words “Superintendent of the Naval Postgraduate School” are substituted for the words “Head of the Postgraduate school at the Naval Academy” to reflect present terminology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb0a61804-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb0a61805-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" substituted “the Chief Master Sergeant of the Space Force” for “the senior enlisted advisor of the Space Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s925/e/1/A"},"text":"Pub. L. 116–283, § 925(e)(1)(A)","children":[],"tail":", inserted “Chief of Space Operations,” after “Commandant of the Marine Corps,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s925/e/1/B"},"text":"Pub. L. 116–283, § 925(e)(1)(B)","children":[],"tail":", inserted “the senior enlisted advisor of the Space Force,” after “Sergeant Major of the Marine Corps,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" redesignated subsec. (c) as (b) and struck out former subsec. (b) which related to allowance for certain naval officers."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s603/c/1"},"text":"Pub. L. 113–291, § 603(c)(1)","children":[],"tail":", substituted “Commandant of the Coast Guard, or Chief of the National Guard Bureau” for “or Commandant of the Coast Guard”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s603/c/2"},"text":"Pub. L. 113–291, § 603(c)(2)","children":[],"tail":", substituted “the Senior Enlisted Advisor to the Chairman of the Joint Chiefs of Staff, or the Senior Enlisted Advisor to the Chief of the National Guard Bureau” for “or the Senior Enlisted Advisor to the Chairman of the Joint Chiefs of Staff”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":" struck out before period at end “, or the Senior Enlisted Advisor for the Chairman of the Joint Chiefs of Staff”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s685/c/2"},"text":"Pub. L. 109–163, § 685(c)(2)","children":[],"tail":" inserted before period at end “, or the Senior Enlisted Advisor for the Chairman of the Joint Chiefs of Staff”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s685/c/1"},"text":"Pub. L. 109–163, § 685(c)(1)","children":[],"tail":", which directed that subsec. (c) be amended by striking “or” after “Sergeant Major of the Marine Corps,” could not be executed because of prior amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/109/148"},"text":"Pub. L. 109–148","children":[],"tail":". See below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005–Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/148"},"text":"Pub. L. 109–148","children":[],"tail":" substituted “the Master Chief Petty Officer of the Coast Guard, or the Senior Enlisted Advisor to the Chairman of the Joint Chiefs of Staff” for “or the Master Chief Petty Officer of the Coast Guard”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" substituted “President of the Naval Postgraduate School” for “Superintendent of the Naval Postgraduate School”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title VI, § 609(b)(1)], inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title VI, § 609(b)(2)], inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title VI, § 609(a)], added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102