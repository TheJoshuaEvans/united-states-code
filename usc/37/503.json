{"tag":"section","attrib":{"id":"idb0b1feb4-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s503"},"text":null,"children":[{"tag":"num","attrib":{"value":"503"},"text":"§ 503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Absence without leave or over leave","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb0b1feb5-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0b1feb6-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s503/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (2), a member of the Army, Navy, Air Force, Marine Corps, Space Force, Coast Guard, or National Oceanic and Atmospheric Administration, who is absent without leave or over leave, forfeits all pay and allowances for the period of that absence, unless it is excused as unavoidable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0b1feb7-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s503/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0b1feb8-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s503/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a member of the Army, Navy, Air Force, Marine Corps, Space Force, or Coast Guard when it is operating as service in the Department of the Navy, the Secretary of Defense may determine to pay the pay and allowances described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0b1feb9-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s503/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may not delegate the authority to make a determination under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0b1feba-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s503/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 30 days after determining to pay any pay or allowance under subparagraph (A), the Secretary shall submit to the Committees on Armed Services of the Senate and House of Representatives a report regarding such determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0b1febb-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A commissioned officer of the Regular Corps of the Public Health Service, or an officer of the Reserve Corps ","children":[{"tag":"ref","attrib":{"idref":"fn002019"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002019"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Change of Name note below."}],"tail":" of the Public Health Service on active duty, who is absent without leave, forfeits all pay and allowances for the period of that absence, unless it is excused as unavoidable."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb0b1febc-2930-11f1-a69d-9cbca84c43f0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/649"},"text":"Pub. L. 87–649","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"hre