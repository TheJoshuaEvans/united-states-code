ttrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"552(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50 App. 1002(a) (1st sentence, less last 46 words).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1942-03-07/ch166/s2/a"},"text":"Mar. 7, 1942, ch. 166, § 2(a)","children":[],"tail":"; added "},{"tag":"html:a","attrib":{"href":"/us/act/1944-07-01/ch371/s2"},"text":"July 1, 1944, ch. 371, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/58/679"},"text":"58 Stat. 679","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1953-04-04/ch17/s1/a"},"text":"Apr. 4, 1953, ch. 17, § 1(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/67/21"},"text":"67 Stat. 21","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Aug. 29, 1957","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/217/s1/b"},"text":"Pub. L. 85–217, § 1(b)","children":[],"tail":" (1st par.), "},{"tag":"html:a","attrib":{"href":"/us/stat/71/491"},"text":"71 Stat. 491","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Aug. 14, 1964","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/88/428/s1/3"},"text":"Pub. L. 88–428, § 1(3)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/78/437"},"text":"78 Stat. 437","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50 App. 1014 (as applicable to § 1002(a) (1st sentence)).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1942-03-07/ch166/s14"},"text":"Mar. 7, 1942, ch. 166, § 14","children":[],"tail":" (as applicable to § 2(a) (1st and last sentences)), "},{"tag":"html:a","attrib":{"href":"/us/stat/56/147"},"text":"56 Stat. 147","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1953-04-04/ch17/s1/e"},"text":"Apr. 4, 1953, ch. 17, § 1(e)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/67/21"},"text":"67 Stat. 21","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"552(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50 App. 1002(a) (last 46 words of 1st sentence, and 2d sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"552(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50 App. 1002(a) (3d sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"552(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50 App. 1002(a) (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50 App. 1014 (as applicable to § 1002(a) (last sentence)).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"552(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50 App. 1006 (2d sentence as applicable to pay and allowances).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1942-03-07/ch166/s6"},"text":"Mar. 7, 1942, ch. 166, § 6","children":[],"tail":" (2d sentence, as applicable to pay and allowances); added "},{"tag":"html:a","attrib":{"href":"/us/act/1942-12-24/ch828/s1"},"text":"Dec. 24, 1942, ch. 828, § 1","children":[],"tail":" (4th par.), "},{"tag":"html:a","attrib":{"href":"/us/stat/56/1093"},"text":"56 Stat. 1093","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Aug. 14, 1964","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/88/428/s1/5/B"},"text":"Pub. L. 88–428, § 1(5)(B)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/78/437"},"text":"78 Stat. 437","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Only that portion of the source law which is applicable to members of the uniformed services and their dependents is codified in this section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the first 22 words are substituted for 50 App. U.S.C. 1002(a) (1st 66 words) to conform to the definitions in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s101/3"},"text":"37 U.S.C. 101(3)","children":[],"tail":", (18), (20), (22), and (23) and revised section 551(2) of this chapter. The words “pay and allowances, as defined in this chapter,” are substituted for the enumeration of pay and allowances in 50 App. U.S.C. 1002(a) (1st sentence) to conform to the definition in revised section 551(3) of this chapter. The words “on active duty” are substituted for “performing full-time active duty” to conform to the definition in "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s101/18"},"text":"37 U.S.C. 101(18)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the first sentence is substituted for 50 App. U.S.C. 1002(a) (1st 21 words of 2d sentence). The words “or employment” are omitted as inapplicable to members of the uniformed services. The words “entitlement to pay and allowances under subsection (a) of this section” are substituted for “Such entitlement to pay and allowances” for clarity. The words “Notwithstanding the death of a member while in a missing status” are substituted for 50 App. U.S.C. 1002(a) (2d sentence, less 1st 21 words). The word “member” is substituted for “person” and the word “Secretary” is substituted for “department” to conform to the definitions in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s101/5"},"text":"37 U.S.C. 101(5)","children":[],"tail":" and (23)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “A member” are substituted for “such person”. The words “under subsection (a) of this section” are inserted for clarity. The words “United States” are substituted for “Government” to conform to the style of title 37.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “A member . . . he . . . in a missing status” are substituted for “Persons”, “such persons”, and the enumerated absent stata to conform to the definitions in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s101/23"},"text":"37 U.S.C. 101(23)","children":[],"tail":" and revised section 551(2) of this chapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “A member in a missing status” are substituted for “a person missing under the conditions specified in section 2 of this Act” to conform to the definition in revised section 551(2) of this chapter. The words “under subsection (a) of this section” are substituted for “as provided in section 2 of this Act”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb0b1fefe-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb0b1feff-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" inserted “or section 351(a)(2)” after “section 301”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s569/c/2/A"},"text":"Pub. L. 104–106, § 569(c)(2)(A)","children":[],"tail":", substituted “for all purposes” for “for all purposes, even though the Secretary concerned determines under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s556/b"},"text":"section 556(b) of this title","children":[],"tail":" that the member died before the promotion was made”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s569/c/2/B"},"text":"Pub. L. 104–106, § 569(c)(2)(B)","children":[],"tail":", inserted “or under chapter 76 of title 10” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s569/c/2/C"},"text":"Pub. L. 104–106, § 569(c)(2)(C)","children":[],"tail":", inserted “or under chapter 76 of title 10” after “"},{"tag":"ref","attrib":{"href":"/us/usc/t37/s555"},"text":"section 555 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsecs. (b), (c), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/25"},"text":"Pub. L. 102–25","children":[],"tail":" struck out “of this section” after “subsection (a)” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/26"},"text":"Pub. L. 93–26","children":[],"tail":" provided for full effectiveness for all purposes of promotion of a member while he is in a missing status notwithstanding a determination of the Secretary of death of the member before the making of the promotion."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/482"},"text":"Pub. L. 92–482","children":[],"tail":" designated existing provisions as cl. (1), added cl. (2), and struck out provisions relating to effectiveness of the promotion of a member of the uniformed services while he is in a missing status and the Secretary concerned determines under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s556/b"},"text":"section 556(b) of this title","children":[],"tail":" that the member