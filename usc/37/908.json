{"tag":"section","attrib":{"id":"idb0b92b54-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s908"},"text":null,"children":[{"tag":"num","attrib":{"value":"908"},"text":"§ 908.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reserves and retired members: acceptance of employment, payments, and awards from foreign governments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb0b92b55-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s908/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Congressional Consent","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsections (b) and (c), Congress consents to the following persons accepting civil employment (and compensation for that employment), accepting payment for speeches, travel, meals, lodging, or registration fees, or accepting a non-cash award, for which the consent of Congress is required by the last paragraph of section 9 of article I of the Constitution, related to acceptance of emoluments, offices, or titles from a foreign government:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0b92b56-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s908/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Retired members of the uniformed services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0b92b57-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s908/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of a reserve component of the armed forces and members of the Space Force in space force active status not on sustained duty, except members serving on active duty under a call or order to active duty for a period in excess of 30 days.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0b92b58-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s908/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the Commissioned Reserve Corps ","children":[{"tag":"ref","attrib":{"idref":"fn002021"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002021"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Change of Name note below."}],"tail":" of the Public Health Service."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0b92b59-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s908/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Approval Required for Employment and Compensation","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0b92b5a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s908/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person described in subsection (a) may accept employment or compensation described in that subsection only if the Secretary concerned and the Secretary of State approve the employment after determining that such approval is not contrary to the national interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0b92b5b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s908/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of a military department may delegate the determination of the Secretary required by paragraph (1) only to an official of the military department at or above the level of an Assistant Secretary or, in the event of a vacancy in the position of such an official, a civilian official performing the duties of that position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0b92b5c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s908/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Approval Required for Certain Payments and Awards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person described in subsection (a) may accept payment for speeches, travel, meals, lodging, or registration fees described in that subsection, or accept a non-cash award described in that subsection, only if the Secretary concerned approves the payment or award.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0b92b5d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s908/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Reports on Approvals for Retired General and Flag Officers","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0b92b5e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s908/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than January 31 each year, the Secretaries of the military departments, after consulting with the Secretary of State, shall jointly submit to the Committees on Armed Services of the Senate and House of Representatives a report on each approval under subsection (b) for employment or compensation described in subsection (a), and each approval under subsection (c) for a payment or award described in subsection (a), for a retired member of the armed forces in general or flag officer grade that was issued during the preceding year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0bb9b5f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s908/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The report under paragraph (1) on an approval described in that paragraph with respect to a person shall set forth the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0bb9b60-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s908/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The foreign government providing the employment or compensation or payment or award.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0bb9b61-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s908/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the duties, if any, the person is to perform and the compensation the person is to receive for such duties, as reflected in the person’s application for approval of the employment or compensation or payment or award.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0bb9b62-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s908/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The position the person held or holds in the armed forces, including the rank of the person and the armed force in which the person served.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0bb9b63-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s908/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other information the Secretaries of the military departments consider relevant, except that such information may not include the person’s date of birth, Social Security number, home address, phone number, or any other personal identifier other than the name and rank of the person and the armed force in which the person served.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0bb9b64-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s908/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 60 days after the date on which a report required by paragraph (1) is submitted, the Secretaries of the military departments shall make the report, and all contents of the report, available on a publicly accessible internet website.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0bb9b65-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s908/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Military Service in Foreign Armed Forces","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For a provision of law providing the consent of Congress to service in the military forces of certain foreign nations, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1060"},"text":"section 1060 of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0bb9b66-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s908/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on Former Members of Armed Forces Accepting Employment With Certain Foreign Governments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For a provision of law prohibiting former members of the armed forces from accepting post-service employment with certain foreign governments, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s989"},"text":"section 989 of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb0bb9b67-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/295/s3/6/A"},"text":"Pub. L. 97–295, § 3(6)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1304"},"text":"96 Stat. 1304","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/25/tVII/s702/b/1"},"text":"Pub. L. 102–25, title VII, § 702(b)(1)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1991-04-06"},"text":"Apr. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/117"},"text":"105 Stat. 117","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tXIV/s1433/c"},"text":"Pub. L. 103–160, div. A, title XIV, § 1433(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1834"},"text":"107 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tX/s1070/d/6"},"text":"Pub. L. 103–337, div. A, title X, § 1070(d)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2858"},"text":"108 Stat. 2858","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tVI/s651/a"},"text":"Pub. L. 116–92, div. A, title VI, § 651(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1431"},"text":"133 Stat. 1431","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tVI/s641/a"},"text":"Pub. L. 116–283, div. A, title VI, § 641(a)","children":[],"tail":"–(c)(1), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3683"},"text":"134 Stat. 3683","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tV"},"text":"Pub. L. 118–31, div. A, title V","children":[],"tail":", §§ 523(c), 525, "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/252"},"text":"137 Stat. 252","children":[],"tail":", 254; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tVI/s601/g/1"},"text":"Pub. L. 119–60, div. A, title VI, § 601(g)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/905"},"text":"139 Stat. 905","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb0bb9b68-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb0bb9b69-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb0bb9b6a-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"908","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"37:801 (note).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 17, 1977","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/105/s509/a"},"text":"Pub. L. 95–105, § 509(a)","children":[],"tail":"–(c), "},{"tag":"html:a","attrib":{"href":"/us/stat/91/859"},"text":"91 Stat. 859","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “for which” are substituted for “with respect to which” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1977-08-17/s509/c"},"text":"section 509(c) of the Act of August 17, 1977","children":[],"tail":", is omitted as unnecessary because of the definitions in 37:101."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb0bb9b6b-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb0bb9b6c-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" inserted “and members of the Space Force in space force active status not on sustained duty” after “of the armed forces”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2023—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s525/1"},"text":"Pub. L. 118–31, § 525(1)","children":[],"tail":", designated existing provisions as par. (1), inserted “after determining that such approval is not contrary to the national interests of the United States” after “approve the employment”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s525/2/A/i"},"text":"Pub. L. 118–31, § 525(2)(A)(i)","children":[],"tail":", substituted “a person” for “an officer” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(B) to (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s525/2/A/ii"},"text":"Pub. L. 118–31, § 525(2)(A)(ii)","children":[],"tail":", added subpars. (B) to (D) and struck out former subpars. (B) and (C) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) The duties, if any, to be performed in connection with the employment or compensation or payment or award.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) The total amount of compensation, if any, or payment to be provided.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s525/2/B"},"text":"Pub. L. 118–31, § 525(2)(B)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s523/c"},"text":"Pub. L. 118–31, § 523(c)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s641/c/1"},"text":"Pub. L. 116–283, § 641(c)(1)","children":[],"tail":", amended section catchline generally, substituting “Reserves and retired members: acceptance of employment, payments, and awards from foreign governments” for “Employment of reserves and retired members by foreign governments”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s641/a/1/A"},"text":"Pub. L. 116–283, § 641(a)(1)(A)","children":[],"tail":", in introductory provisions, substituted “subsections (b) and (c)” for “subsection (b)” and inserted “, accepting payment for speeches, travel, meals, lodging, or registration fees, or accepting a non-cash award,” after “that employment)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s641/a/1/B"},"text":"Pub. L. 116–283, § 641(a)(1)(B)","children":[],"tail":", substituted “armed forces, except members serving on active duty under a call or order to active duty for a period in excess of 30 days” for “armed forces”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s641/a/2"},"text":"Pub. L. 116–283, § 641(a)(2)","children":[],"tail":", inserted “for Employment and Compensation” after “Approval Required” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s641/a/4"},"text":"Pub. L. 116–283, § 641(a)(4)","children":[],"tail":", added subsec. (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s641/a/3"},"text":"Pub. L. 116–283, § 641(a)(3)","children":[],"tail":", (b), redesignated subsec. (c) as (d), designated existing provisions as par. (1), inserted “, and each approval under subsection (c) for a payment or award described in subsection (a),” after “in subsection (a)”, and added par. (2). Former subsec. (d) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s641/a/3"},"text":"Pub. L. 116–283, § 641(a)(3)","children":[],"tail":", redesignated subsec. (d) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s651/a"},"text":"Pub. L. 116–92, § 651(a)","children":[],"tail":", added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"tex