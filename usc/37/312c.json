{"tag":"section","attrib":{"id":"idb08bd9a3-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s312c"},"text":null,"children":[{"tag":"num","attrib":{"value":"312c"},"text":"§ 312c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special pay: nuclear career annual incentive bonus","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb08bd9a4-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s312c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb08bd9a5-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s312c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under regulations prescribed by the Secretary of the Navy, an officer of the naval service who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb08bd9a6-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s312c/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is entitled to basic pay;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb08bd9a7-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s312c/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not above the pay grade O–6;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb08bd9a8-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s312c/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has completed his initial obligated active service as an officer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb08bd9a9-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s312c/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has, as a commissioned officer, successfully completed training for duty in connection with the supervision, operation, and maintenance of naval nuclear propulsion plants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb08bd9aa-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s312c/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the current technical qualifications for duty in connection with the supervision, operation, and maintenance of naval nuclear propulsion plants;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"may, in addition to all other compensation to which he is entitled, be paid an annual bonus in an amount not to exceed $22,000 for each nuclear service year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb08bd9ab-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s312c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to be eligible for an annual bonus for any nuclear service year in accordance with this subsection, an otherwise technically qualified officer must have been on active duty on the last day of that nuclear service year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb08bd9ac-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s312c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The amount of the annual bonus to which an officer would otherwise be entitled for a nuclear service year in accordance with this subsection shall be reduced on a pro rata basis for each day of that nuclear service year on which he—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb08bd9ad-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s312c/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was not on active duty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb08bd9ae-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s312c/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was not technically qualified for duty in connection with the supervision, operation, and maintenance of naval nuclear propulsion plants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb08bd9af-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s312c/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was performing obligated service as the result of an active-service agreement executed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s312"},"text":"section 312 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb08bd9b0-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s312c/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" was entitled to receive aviation career incentive pay in accordance with section 301a while serving in a billet other than a billet that required the officer—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb08bd9b1-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s312c/a/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be technically qualified for duty in connection with the supervision, operation, and maintenance of naval nuclear propulsion plants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb08bd9b2-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s312c/a/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be qualified for the performance of operational flying duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb08bd9b3-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s312c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb08bd9b4-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s312c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under regulations prescribed by the Secretary of the Navy, an officer of the naval service who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb08bd9b5-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s312c/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is entitled to basic pay;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb08bd9b6-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s312c/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not above the pay grade O–6;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb08bd9b7-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s312c/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has, as an enlisted member, received training for duty in connection with the supervision, operation, and maintenance of naval nuclear propulsion plants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb08bd9b8-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s312c/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the current technical qualifications for duty in connection with the supervision, operation, and maintenance of naval nuclear propulsion plants;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"may, in addition to all other compensation to which he is entitled, be paid an annual bonus in an amount not to exceed $14,000 for each nuclear service year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb08bd9b9-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s312c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to be eligible for an annual bonus for any nuclear service year in accordance with this subsection, an otherwise technically qualified officer must have been on active duty on the last day of that nuclear service year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb08bd9ba-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s312c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The amount of the annual bonus to which an officer would otherwise be entitled in accordance with this subsection shall be reduced on a pro rata basis for each day of that nuclear service year on which he—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb08bd9bb-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s312c/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was not in an assignment involving the direct supervision, operation, or maintenance of naval nuclear propulsion plants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb08bd9bc-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s312c/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was performing obligated service as the result of an active-service agreement executed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s312"},"text":"section 312 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb08bd9bd-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s312c/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" was entitled to receive aviation career incentive pay in accordance with section 301a while serving in a billet other than a billet—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb08bd9be-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s312c/b/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involving the direct supervision, operation, or maintenance of naval nuclear propulsion plants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb08bd9bf-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s312c/b/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that required the officer be qualified for the performance of operational flying duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb08bd9c0-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s312c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under regulations prescribed by the Secretary of the Navy, an officer of the naval service who is not on active duty on the last day of a nuclear service year or who, on or before the last day of a nuclear service year, loses his technical qualifications or advances from the pay grade of O–6 to a higher pay grade may be paid a bonus in accordance with subsection (a) or (b) on a pro rata basis, if otherwise qualified, unless termination of active duty or loss of technical qualifications was voluntary or was the result of his own misconduct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb08bd9c1-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s312c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of this section, a “nuclear service year” is any fiscal year beginning before ","children":[{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb08bd9c2-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/356/s3"},"text":"Pub. L. 94–356, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-07-12"},"text":"July 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/901"},"text":"90 Stat. 901","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/