{"tag":"section","attrib":{"id":"idb09a310a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s401"},"text":null,"children":[{"tag":"num","attrib":{"value":"401"},"text":"§ 401.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb09a310b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s401/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Dependent Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this chapter, the term “dependent”, with respect to a member of a uniformed service, means the following persons:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb09a310c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s401/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The spouse of the member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09a310d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s401/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An unmarried child of the member who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb09a310e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s401/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is under 21 years of age;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb09a310f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s401/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is incapable of self-support because of mental or physical incapacity and is in fact dependent on the member for more than one-half of the child’s support; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb09a3110-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s401/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is under 23 years of age, is enrolled in a full-time course of study in an institution of higher education approved by the Secretary concerned for purposes of this subparagraph, and is in fact dependent on the member for more than one-half of the child’s support.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09a3111-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s401/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A parent of the member if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb09a3112-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s401/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the parent is in fact dependent on the member for more than one-half of the parent’s support;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb09a3113-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s401/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the parent has been so dependent for a period prescribed by the Secretary concerned or became so dependent due to a change of circumstances arising after the member entered on active duty; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb09a3114-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s401/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the dependency of the parent on the member is determined on the basis of an affidavit submitted by the parent and any other evidence required under regulations prescribed by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09a3115-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s401/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An unmarried person who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb09a3116-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s401/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is placed in the legal custody of the member as a result of an order of a court of competent jurisdiction in the United States (or Puerto Rico or a possession of the United States) for a period of at least 12 consecutive months;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb09a3117-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s401/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" either—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb09a3118-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s401/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not attained the age of 21;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb09a3119-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s401/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not attained the age of 23 years and is enrolled in a full time course of study at an institution of higher learning approved by the Secretary concerned; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb09a311a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s401/a/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is incapable of self support because of a mental or physical incapacity that occurred while the person was considered a dependent of the member or former member under this paragraph pursuant to clause (i) or (ii);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb09a311b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s401/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is dependent on the member for over one-half of the person’s support;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb09a311c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s401/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resides with the member unless separated by the necessity of military service or to receive institutional care as a result of disability or incapacitation or under such other circumstances as the Secretary concerned may by regulation prescribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb09a311d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s401/a/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not a dependent of a member under any other paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09a311e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s401/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb09a311f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s401/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “child” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb09a3120-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s401/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a stepchild of the member (except that such term does not include a stepchild after the divorce of the member from the stepchild’s parent by blood);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb09ca221-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s401/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an adopted child of the member, including a child placed in the home of the member by a placement agency (recognized by the Secretary of Defense) in anticipation of the legal adoption of the child by the member; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb09ca222-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s401/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an illegitimate child of the member if the member’s parentage of the child is established in accordance with criteria prescribed in regulations by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09ca223-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s401/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “parent” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb09ca224-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s401/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a natural parent of the member;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb09ca225-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s401/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a stepparent of the member;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb09ca226-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s401/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a parent of the member by adoption;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb09ca227-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s401/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a parent, stepparent, or adopted parent of the spouse of the member; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb09ca228-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s401/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other person, including a former stepparent, who has stood in loco parentis to the member at any time for a continuous period of at least five years before the member became 21 years of age.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb09ca229-2930-11f1-a69d-9cbca84c43f0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/649"},"text":"Pub. L. 87–649","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/469"},"text":"76 Stat. 469","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/64/tI"},"text":"Pub. L. 93–64, title I","children":[],"tail":", §§ 103, 104, "},{"tag":"date","attrib":{"date":"1973-07-09"},"text":"July 9, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/148"},"text":"87 Stat. 148","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/26/s8/e/7"},"text":"Pub. L. 100–26, § 8(e)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-04-21"},"text":"Apr. 21, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/286"},"text":"101 Stat. 286","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tVI/s621"},"text":"Pub. L. 102–190, div. A, title VI, § 621","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1377"},"text":"105 Stat. 1377","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tVI/s631/a"},"text":"Pub. L. 103–160, div. A, title VI, § 631(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1683"},"text":"107 Stat. 1683","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tVII/s701/b"},"text":"Pub. L. 103–337, div. A, title VII, § 701(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2797"},"text":"108 Stat. 2797","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb09ca22a-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb09ca22b-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb09ca22c-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"401","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"37:231(g) (less last proviso of last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-10-12/ch681/s102/g"},"text":"Oct. 12, 1949, ch. 681, § 102(g)","children":[],"tail":" (less last proviso of last sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/63/804"},"text":"63 Stat. 804","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1950-09-08/ch922/s1"},"text":"Sept. 8, 1950, ch. 922, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/794"},"text":"64 Stat. 794","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1953-03-23/ch8"},"text":"Mar. 23, 1953, ch. 8","children":[],"tail":" (as applicable to § 102(g)), "},{"tag":"html:a","attrib":{"href":"/us/stat/67/6"},"text":"67 Stat. 6","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1955-06-30/ch250/s103"},"text":"June 30, 1955, ch. 250, § 103","children":[],"tail":" (as applicable to § 102(g)), "},{"tag":"html:a","attrib":{"href":"/us/stat/69/224"},"text":"69 Stat. 224","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Mar. 23, 1959","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/86/4/s3"},"text":"Pub. L. 86–4, § 3","children":[],"tail":" (as applicable to § 102(g)), "},{"tag":"html:a","attrib":{"href":"/us/stat/73/13"},"text":"73 Stat. 13","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “lawful”, “at all times and in all places”, “except as hereinafter limited in this subsection”, and “in addition to those persons otherwise defined as dependents in this subsection” are omitted as surplusage. In clause (1), the word “spouse” is substituted for words “wife” and “husband”. Clause (2) is substituted for the 16th through 24th words of the first sentence of section 231(g) of existing title 37 and the third sentence (less last proviso) of section 231(g) of existing title 37. Clause (3) is substituted for the second sentence of section 231(g) of existing title 37 and the last sentence (less provisos) of section 231(g) of existing title 37. The second sentence is substituted for the last proviso of the third sentence of section 231(g) of existing title 37. The last sentence is substituted for the first proviso of the last sentence of section 231(g) of existing title 37.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb09ca22d-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb09ca22e-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" substituted “placement agency (recognized by the Secretary of Defense) in anticipation of the legal adoption of the child by the member” for “placement agency for the purpose of adoption”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160"},"text":"Pub. L. 103–160","children":[],"tail":" added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190"},"text":"Pub. L. 102–190","children":[],"tail":" amended text generally. Prior to amendment, text read as follows: “In this chapter, the term ‘dependent’, with respect to a member of a uniformed service, means—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) his spouse;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) his unmarried child (including any of the following categories of children if such child is in fact dependent on the member: a stepchild; an adopted child; or an illegitimate child whose alleged member-father has been judicially decreed to be the father of the child or judicially ordered to contribute to the child’s support, or whose parentage has been admitted in writing by the member) who either—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) is under 21 years of age; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) is incapable of self-support because of a mental or physical incapacity, and in fact dependent on the member for over one-half of his support; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) his parent (including a stepparent or parent by adoption, and any person, including a former stepparent, who has stood in loco parentis to the member at any time for a continuous period of at least five years before the member became 21 years of age) who is in fact dependent on the member for over one-half of his support; however, the dependency of such a parent is determined on the basis of an affidavit submitted by the parent, and any other evidence required under regulations prescribed by the Secretary concerned, and he is not considered a dependent of the member claiming the dependence unless—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the member has provided over one-half of his support for the period prescribed by the Secretary concerned; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) due to changed circumstances arising after the member enters on active duty, he becomes in fact dependent on the member for over one-half of his support.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For the purposes of this section, the relationship between a stepparent and his stepchild is terminated by the stepparent’s divorce from the parent by blood.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/26"},"text":"Pub. L. 100–26","children":[],"tail":" inserted “the term” after “In this chapter,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—Cl. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/64/s103/1"},"text":"Pub. L. 93–64, § 103(1)","children":[],"tail":", in revising cl. (1) of first sentence, substituted “unmarried child” for “unmarried legitimate child” and defined dependent to include an illegitimate child whose alleged member-father has been judicially decreed to be the father of the child or judicially ordered to contribute to the child’s support, or whose parentage has been admitted in writing by the member."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Cl. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/64/s104"},"text":"Pub. L. 93–64, § 104","children":[],"tail":", in revising cl. (3) of first sentence, substituted “five years before the member became 21 years” for “five years before he became 21 years”, struck out requirement of actual residence of parent in the member’s household, and inserted provision respecting determination of dependency of parent, including items (A) and (B), formerly contained in former section 2201 of Appendix to Title 50, War and National Defense."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Closing text. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/64/s103/2"},"text":"Pub. L. 93–64, § 103(2)","children":[],"tail":", struck out second sentence, following cl. (3) of first sentence, stating that a person is not a dependent of a female member unless he is in fact dependent on her for over one-half of his support."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb09ca22f-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb09ca230-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tVI/s631/b"},"text":"Pub. L. 103–160, div. A, title VI, § 631(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1684"},"text":"107 Stat. 1684","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/160/dA/tVI/s631/b"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s401/a/4"},"text":"Section 401(a)(4) of title 37","children":[],"tail":", United States Code, as added by subsection (a), shall apply with respect to determinations of dependency made on or after "},{"tag":"date","attrib":{"date":"1994-07-01"},"text":"July 1, 1994","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb09ca231-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1973 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/64/tII/s206"},"text":"Pub. L. 93–64, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-07-09"},"text":"July 9, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/149"},"text":"87 Stat. 149","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/93/64/tII/s206"},"text":"“This Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1173"},"text":"section 1173 of Title 10","children":[],"tail":", Armed Forces, amending this section and sections 302, 302a, 303, 308a, and 403 of this title, and repealing sections 2210 to 2212 of the former Appendix to Title 50, War and National Defense] shall become effective "},{"tag":"date","attrib":{"date":"1973-07-01"},"text":"July 1, 1973","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
