{"tag":"section","attrib":{"id":"idb08e49e8-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s315"},"text":null,"children":[{"tag":"num","attrib":{"value":"315"},"text":"§ 315.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special pay: engineering and scientific career continuation pay","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb08e49e9-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s315/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this section, the term “engineering or scientific duty” means service performed by an officer—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb08e49ea-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s315/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that requires an engineering or science degree; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb08e49eb-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s315/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that requires a skill designated (under regulations prescribed by the Secretary of Defense for the armed forces, by the Secretary of Commerce for the National Oceanic and Atmospheric Administration, or by the Secretary of Health and Human Services for the Public Health Service) as critical and as a skill in which there is a critical shortage of officers in the uniformed service concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb08e49ec-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s315/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under regulations prescribed by the Secretary concerned, an officer of a uniformed service who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb08e49ed-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s315/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is entitled to basic pay;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb08e49ee-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s315/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is below the pay grade of O–7;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb08e49ef-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s315/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" holds a degree in engineering or science from an accredited college or university;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb08e49f0-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s315/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been certified by the Secretary concerned as having the technical qualifications for detail to engineering or scientific duty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb08e49f1-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s315/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has completed at least three but less than nineteen years of engineering or scientific duty as an officer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb08e49f2-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s315/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" executes a written agreement to remain on active duty for detail to engineering or scientific duty for at least one year, but not more than four years;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"may, upon acceptance of the written agreement by the Secretary concerned, be paid, in addition to all other compensation to which the officer is entitled, an amount not to exceed $3,000 multiplied by the number of years, or monthly fraction thereof, of obligated service to which the officer agrees under the agreement. The total amount payable may be paid in a lump sum or in equal periodic installments, as determined by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb08e49f3-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s315/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer who, having entered into a written agreement under subsection (b) and having received all or part of a bonus under this section, does not complete the period of active duty as specified in the agreement shall be subject to the repayment provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s303a/e"},"text":"section 303a(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb08e49f4-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/60/tI/s120/a"},"text":"Pub. L. 97–60, title I, § 120(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-10-14"},"text":"Oct. 14, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/998"},"text":"95 Stat. 998","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/145/tVI/s637/a"},"text":"Pub. L. 99–145, title VI, § 637(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/648"},"text":"99 Stat. 648","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/26/s8/e/6"},"text":"Pub. L. 100–26, § 8(e)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-04-21"},"text":"Apr. 21, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/286"},"text":"101 Stat. 286","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/25/tVII/s702/b/1"},"text":"Pub. L. 102–25, title VII, § 702(b)(1)","children":[],"tail":", (2), (c), "},{"tag":"date","attrib":{"date":"1991-04-06"},"text":"Apr. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/117"},"text":"105 Stat. 117","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tVI/s687/b/24"},"text":"Pub. L. 109–163, div. A, title VI, § 687(b)(24)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3331"},"text":"119 Stat. 3331","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb08e49f5-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb08e49f6-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb08e49f7-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" amended subsec. (c) generally, substituting provisions referring to repayment provisions of section 303a(e) for specific provisions relating to refunds required when officer receives bonus but fails to complete agreed upon period of active duty."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/25"},"text":"Pub. L. 102–25","children":[],"tail":" struck out “of this section” after “subsection (b)” in two places in par. (1) and struck out “of this subsection” after “paragraph (1)” in pars. (2) to (4) and after “paragraph (3)” in par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/26"},"text":"Pub. L. 100–26","children":[],"tail":" inserted “the term” after “In this section,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145/s637/a/1"},"text":"Pub. L. 99–145, § 637(a)(1)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows: “In this section, the term ‘engineering or scientific duty’ means service performed by an officer that requires an engineering or science degree and that requires a skill designated under regulations prescribed by the Secretary of Defense as critical and as a skill in which there is a critical shortage of officers in the armed force concerned.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145/s637/a/2"},"text":"Pub. L. 99–145, § 637(a)(2)","children":[],"tail":", in provision preceding par. (1), substituted “prescribed by the Secretary concerned” for “prescribed by the Secretary of Defense” and “officer of a uniformed service” for “officer of an armed force”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb08e49f8-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb08e49f9-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145/tVI/s637/b"},"text":"Pub. L. 99–145, title VI, § 637(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/649"},"text":"99 Stat. 649","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/145/tVI/s637/b"},"text":"“The amendments made by subsection (a) [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1985-10-01"},"text":"October 1, 1985","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"idb08e49fa-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For savings provision relating to payment or repayment of any bonus, incentive pay, special pay, or similar pay obligated to be paid before ","children":[{"tag":"date","attrib":{"date":"2006-04-01"},"text":"Apr. 1, 2006","children":[],"tail":", under a provision of this section amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s687/b"},"text":"section 687(b) of Pub. L. 109–163","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s687/f"},"text":"section 687(f) of Pub. L. 109–163","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s510"},"text":"section 510 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
