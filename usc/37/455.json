{"tag":"section","attrib":{"id":"idb0ad4423-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s455"},"text":null,"children":[{"tag":"num","attrib":{"value":"455"},"text":"§ 455.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations for travel: may not be used for attendance at certain meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Appropriations of the Department of Defense that are available for travel may not, without the approval of the Secretary concerned or his designee, be used for expenses incident to attendance of a member of an armed force under that department at a meeting of a technical, scientific, professional, or similar organization.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb0ad4424-2930-11f1-a69d-9cbca84c43f0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/649"},"text":"Pub. L. 87–649","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/476"},"text":"76 Stat. 476","children":[],"tail":", § 412; renumbered § 455, "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVI/s631/d/1"},"text":"Pub. L. 112–81, div. A, title VI, § 631(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1460"},"text":"125 Stat. 1460","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb0ad4425-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb0ad4426-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb0ad4427-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":