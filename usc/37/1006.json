:[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"37:310d.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1006(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"37:310c (less (a) and (b)).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1006(f)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"14:465.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"[None.]","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a) and (b), the words “a member of an armed force” are substituted for the words “commissioned and warrant officers, and enlisted men of the armed services.” The words “Secretary concerned” are substituted for the words “heads of the departments concerned” to conform to the definition in section 101(5) of this revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “may be paid in advance” are substituted for the words “may have their pay and emoluments advanced”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “Secretary concerned” are substituted for the words “heads of the departments concerned” to conform to the definition in section 101(5) of this revised title. The words “member of an armed force” are substituted for the words “members of the armed services”. The words “who are” are substituted for the words “in the event such dependents are”. The words “under subsection (a) or (b) of this section” are substituted for the words “in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s310c"},"text":"section 310c of this title","children":[],"tail":"” to reflect the section of this revised title which restates that section. The words “dependents of members of the armed forces” are substituted for the words “military dependents.” The words “at a place” are omitted as surplusage."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “If a” are substituted for the words “In the event the”. The words “credited to the account” are substituted for the words “passed to credit in the account”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb0be0ce9-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb0be0cea-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" substituted “section 452(c)(2)” for “section 477” and “section 452(b)(11)” for “section 475a(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s1076/a/9"},"text":"Pub. L. 112–239, § 1076(a)(9)","children":[],"tail":", made technical amendment to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/s631/f/4/A"},"text":"Pub. L. 112–81, § 631(f)(4)(A)","children":[],"tail":". See 2011 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s631/f/4/A"},"text":"Pub. L. 112–81, § 631(f)(4)(A)","children":[],"tail":" as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/s1076/a/9"},"text":"Pub. L. 112–239, § 1076(a)(9)","children":[],"tail":", substituted “477” for “407” and “475a” for “405a”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" substituted “Secretary of Homeland Security” for “Secretary of Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261"},"text":"Pub. L. 105–261","children":[],"tail":" designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160"},"text":"Pub. L. 103–160","children":[],"tail":" substituted “the Secretary of Defense” for “the President” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484"},"text":"Pub. L. 102–484","children":[],"tail":" inserted first four sentences and struck out former first and second sentences which read as follows: “Under regulations prescribed by the Secretary concerned, an advance of pay to a member of a uniformed service who is on duty outside the United States, or other place designated by the President, of not more than two months’ basic pay may be made directly to his previously designated dependents who are ordered evacuated by competent authority. An advance of pay under this subsection is not subject to the conditions under which advances of pay may be made under subsection (a) or (b), and may be made only if all dependents of members of the uniformed services are ordered evacuated from the place where the member’s dependents are located.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/25"},"text":"Pub. L. 102–25","children":[],"tail":" struck out “of this section” after “subsection (a) or (b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/25"},"text":"Pub. L. 102–25","children":[],"tail":" struck out “of this section” after “subsection (a), (b), or (c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/25"},"text":"Pub. L. 102–25","children":[],"tail":" struck out “of this section” after “subsections (a)–(d)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661"},"text":"Pub. L. 99–661","children":[],"tail":" added subsec. (j)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145"},"text":"Pub. L. 99–145","children":[],"tail":" substituted “subsections (a) and (b) of section 3324” for “section 3324(a) and (b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":" substituted “section 3324(a) and (b) of title 31” for “section 3648 of the Revised Statutes ("},{"tag":"ref","attrib":{"href":"/us/usc/t31/s529"},"text":"31 U.S.C. 529","children":[],"tail":")” after “Notwithstanding”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/60"},"text":"Pub. L. 97–60","children":[],"tail":" added subsec. (i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/343"},"text":"Pub. L. 96–343","children":[],"tail":" inserted provision authorizing an advance payment of the amount of an allotment made from the pay of a member of the uniformed services to a dependent if the member is scheduled for duty with a unit deployed outside the United States and the allotment is made not more than 60 days before the scheduled date of the assignment."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/215/s3/1"},"text":"Pub. L. 96–215, § 3(1)","children":[],"tail":", substituted “a uniformed service” for “an armed force or of the Public Health Service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/215/s3/1"},"text":"Pub. L. 96–215, § 3(1)","children":[],"tail":", substituted “a uniformed service” for “an armed force or of the Public Health Service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/215/s3/1"},"text":"Pub. L. 96–215, § 3(1)","children":[],"tail":", (2), substituted “a uniformed service” for “an armed force or of the Public Health Service” and “members of the uniformed services” for “members of the armed forces or of the Public Health Service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/215/s3/3"},"text":"Pub. L. 96–215, § 3(3)","children":[],"tail":", substituted “from his uniformed service” for “from his armed force or from the Public Health Service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/215/s3/4"},"text":"Pub. L. 96–215, § 3(4)","children":[],"tail":", substituted “uniformed services” for “armed forces and the Public Health Service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" substituted “3648 of the Revised Statutes ("},{"tag":"ref","attrib":{"href":"/us/usc/t31/s529"},"text":"31 U.S.C. 529","children":[],"tail":")” for “529 of title 31”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/215/s3/5"},"text":"Pub. L. 96–215, § 3(5)","children":[],"tail":", substituted “a uniformed service” for “an armed force or of the Public Health Service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsecs. (a) to (d) and (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/76"},"text":"Pub. L. 96–76","children":[],"tail":" inserted reference to the Public Health Service."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/623/s3/9"},"text":"Pub. L. 90–623, § 3(9)","children":[],"tail":", substituted “change of permanent station” for “permanent change of station”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/623/s3/1"},"text":"Pub. L. 90–623, § 3(1)","children":[],"tail":", substituted “Secretary of Transportation” for “Secretary of the Treasury”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/718"},"text":"Pub. L. 89–718","children":[],"tail":" redesignated as subsec. (h) the subsection relating to advance payment of pay and allowances when the last day of the pay period falls on a Saturday, Sunday, or legal holiday, formerly designated as subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/26/s1/6/A"},"text":"Pub. L. 89–26, § 1(6)(A)","children":[],"tail":", empowered the Secretary concerned or his designee to waive any right of recovery of not more than one month’s basic pay advanced if he finds that recovery of the advance would be against equity and good conscience or against the public interest."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/193"},"text":"Pub. L. 89–193","children":[],"tail":" added subsec. (g) relating to the payment of pay and allowances when the last day of the pay period falls on a Saturday, Sunday, or legal holiday."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/26/s1/6/B"},"text":"Pub. L. 89–26, § 1(6)(B)","children":[],"tail":", added subsec. (g) relating to advance payment of the dislocation allowance."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb0be0ceb-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb0be0cec-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2013 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1076/a"},"text":"Pub. L. 112–239, div. A, title X, § 1076(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1947"},"text":"126 Stat. 1947","children":[],"tail":", provided that the amendment made by section 1076(a)(9) is effective "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", and as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":" as enacted."}],"tail":"\n"}],"tail":"\n"},{"tag":"note