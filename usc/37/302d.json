{"tag":"section","attrib":{"id":"idb0767cc0-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302d"},"text":null,"children":[{"tag":"num","attrib":{"value":"302d"},"text":"§ 302d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special pay: accession bonus for registered nurses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb0767cc1-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Accession Bonus Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0767cc2-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person who is a registered nurse and who, during the period beginning on ","children":[{"tag":"date","attrib":{"date":"1989-11-29"},"text":"November 29, 1989","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":", executes a written agreement described in subsection (c) to accept a commission as an officer and remain on active duty for a period of not less than three years may, upon the acceptance of the agreement by the Secretary concerned, be paid an accession bonus in an amount determined by the Secretary concerned."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0767cc3-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of an accession bonus under paragraph (1) may not exceed $30,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0767cc4-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Eligibility for Bonus","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person may not be paid a bonus under subsection (a) if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0767cc5-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person, in exchange for an agreement to accept an appointment as an officer, received financial assistance from the Department of Defense to pursue a baccalaureate degree; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0767cc6-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary concerned determines that the person is not qualified to become and remain licensed as a registered nurse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0767cc7-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The agreement referred to in subsection (a) shall provide that, consistent with the needs of the uniformed service concerned, the person executing the agreement will be assigned to duty, for the period of obligated service covered by the agreement, as an officer of the Nurse Corps of the Army or Navy, an officer of the Air Force designated as a nurse, or an officer designated as a nurse in the commissioned corps of the Public Health Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0767cc8-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s302d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer who does not become and remain licensed as a registered nurse during the period for which the payment is made, or who does not complete the period of active duty specified in the agreement entered into under subsection (a), shall be subject to the repayment provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s303a/e"},"text":"section 303a(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb0767cc9-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tVII/s705/a/1"},"text":"Pub. L. 101–189, div. A, title VII, § 705(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1471"},"text":"103 Stat. 1471","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tVI/s613/a"},"text":"Pub. L. 101–510, div. A, title VI, § 613(a)","children":[],"tail":", title XIV, § 1484(d)(2), "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1577"},"text":"104 Stat. 1577","children":[],"tail":", 1716; "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tVI/s612/g"},"text":"Pub. L. 102–484