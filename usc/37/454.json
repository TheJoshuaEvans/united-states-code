{"tag":"section","attrib":{"id":"idb0ad440d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s454"},"text":null,"children":[{"tag":"num","attrib":{"value":"454"},"text":"§ 454.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel and transportation: pilot programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb0ad440e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s454/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pilot Programs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise prohibited by law, the Secretary of Defense may conduct pilot programs to evaluate alternative travel and transportation programs, policies, and processes for Department of Defense authorized travelers. Any such pilot program shall be designed to enhance cost savings or other efficiencies that accrue to the Government and be conducted so as to evaluate one or more of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0ad440f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s454/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Alternative methods for performing and reimbursing travel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0ad4410-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s454/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Means for limiting the need for travel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0ad4411-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s454/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Means for reducing the environmental impact of travel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0ad4412-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s454/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0ad4413-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s454/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than three pilot programs may be carried out under subsection (a) at any one time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0ad4414-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s454/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The duration of a pilot program may not exceed four years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0ad4415-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s454/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority to carry out a pilot program is subject to the availability of appropriated funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0ad4416-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s454/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0ad4417-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s454/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than 30 days before the commencement of a pilot program under subsection (a), the Secretary shall submit to the congressional defense committees a report on the pilot program. The report on a pilot program under this paragraph shall set forth a description of the pilot program, including the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0ad4418-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s454/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The purpose of the pilot program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0ad4419-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s454/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The duration of the pilot program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0ad441a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s454/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The cost savings or other efficiencies anticipated to accrue to the Government under the pilot program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0ad441b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s454/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than 60 days after the completion of a pilot program, the Secretary shall submit to the congressional defense committees a report on the pilot program. The report on a pilot program under this paragraph shall set forth the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0ad441c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s454/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of results of the pilot program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0ad441d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s454/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such recommendations for legislative or administrative action as the Secretary considers appropriate in light of the pilot program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0ad441e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s454/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Congressional Defense Committees Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “congressional defense committees” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/a/16"},"text":"section 101(a)(16) of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb0ad441f-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVI/s631/b"},"text":"Pub. L. 112–81, div. A, title VI, § 631(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1458"},"text":"125 Stat. 1458","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb0ad4420-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb0ad4421-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb0ad4422-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Pilot Program To Reimburse Members of the Armed Forces for Certain Child Care Costs Incident to a Permanent Change of Station or Assignment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tVI/s627"},"text":"Pub. L. 117–263, div. A, title VI, § 627","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2630"},"text":"136 Stat. 2630","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dA/tVI/s627"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall carry out a pilot program to reimburse members of the Armed Forces for certain child care costs incident to a permanent change of station or assignment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Travel and Transportation Allowances","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under the pilot program, the Secretary of Defense shall treat a designated child care provider as an authorized traveler if child care is not available to a member of the Armed Forces at a military child development center at the permanent duty location of such member not later than 30 days after the member arrives at such location.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement of Certain Child Care Costs.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under the pilot program, the Secretary of Defense may reimburse a member of the Armed Forces for travel expenses for a designated child care provider when—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the member is reassigned, either as a permanent change of station or permanent change of assignment, to a new duty station;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the movement of the member’s dependents is authorized at the expense of the United States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s451"},"text":"section 451 of title 37","children":[],"tail":", United States Code, as part of the reassignment;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" child care is not available at a military child development center at such duty station not later than 30 days after the member arrives at such duty station; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the dependent child is on the wait list for child care at such military child development center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum amounts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Reimbursement provided to a member under this subsection may not exceed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $500 for a reassignment between duty stations within the continental United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,500 for a reassignment involving a duty station outside of the continental United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deadline","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member may not apply for reimbursement under this subsection later than one year after a reassignment described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Concurrent receipt prohibited","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the event a household contains more than one member eligible for reimbursement under this subsection, reimbursement may be paid to one member among such members as such members shall jointly elect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2027-01-01"},"text":"January 1, 2027","children":[],"tail":", the Secretary shall submit to the Committees on Armed Services of the Senate and House of Representatives a report on the pilot program, including the recommendation of the Secretary whether to make the pilot program permanent."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The pilot program shall terminate on ","children":[{"tag":"date","attrib":{"date":"2028-09-30"},"text":"September 30, 2028","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘authorized traveler’ has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s451"},"text":"section 451 of title 37","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘designated child care provider’ means an adult selected by a member of the armed forces to provide child care to a dependent child of such member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘military child development center’ has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1800"},"text":"section 1800 of title 10","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
