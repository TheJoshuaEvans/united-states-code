{"tag":"section","attrib":{"id":"idb09a30ca-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s371"},"text":null,"children":[{"tag":"num","attrib":{"value":"371"},"text":"§ 371.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to other incentives and pays","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb09a30cb-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s371/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A bonus or incentive pay paid to a member of the uniformed services under subchapter II is in addition to any other pay and allowance to which a member is entitled, unless otherwise provided under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09a30cc-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s371/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member may not receive a bonus or incentive pay under both subchapter I and subchapter II for the same activity, skill, or period of service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb09a30cd-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s371/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Other Computations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of a bonus or incentive pay to which a member is entitled under subchapter II may not be included in computing the amount of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb09a30ce-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s371/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any increase in pay authorized by any other provision of this title; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb09a30cf-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s371/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any retired pay, retainer pay, separation pay, or disability severance pay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb09a30d0-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tVI/s661/a/2"},"text":"Pub. L. 110–181, div. A, title VI, § 661(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/176"},"text":"122 Stat. 176","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
