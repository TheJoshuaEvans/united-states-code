{"tag":"section","attrib":{"id":"idb0898f1e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308j"},"text":null,"children":[{"tag":"num","attrib":{"value":"308j"},"text":"§ 308j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special pay: affiliation bonus for officers in the Selected Reserve","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb0898f1f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Affiliation Bonus","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0898f20-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308j/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary concerned may pay an affiliation bonus under this section to an eligible officer in any of the armed forces who enters into an agreement with the Secretary to serve, for the period specified in the agreement, in the Selected Reserve of the Ready Reserve of an armed force under the Secretary’s jurisdiction—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0898f21-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308j/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a critical officer skill designated under paragraph (3); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0898f22-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308j/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to meet a manpower shortage in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb0898f23-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308j/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a unit of that Selected Reserve; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb0898f24-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308j/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a particular pay grade in that armed force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0898f25-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308j/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An officer is eligible for an affiliation bonus under this section if the officer—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0898f26-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308j/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" either—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb0898f27-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308j/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is serving on active duty for a period of more than 30 days; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb0898f28-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308j/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a member of a reserve component not on active duty and, if the member formerly served on active duty, was released from active duty under honorable conditions; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0898f29-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308j/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not entitled to receive retired or retainer pay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0898f2a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308j/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0898f2b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308j/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned shall designate for an armed force under the Secretary’s jurisdiction the critical officer skills to which the bonus authority under this subsection is to be applied.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0898f2c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308j/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A skill may be designated as a critical officer skill for an armed force under subparagraph (A) if, to meet requirements of that armed force, it is critical for that armed force to have a sufficient number of officers who are qualified in that skill.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0898f2d-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308j/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An affiliation bonus payable pursuant to an agreement under this section to an eligible officer accrues on the date on which the person is assigned to a unit or position in the Selected Reserve pursuant to such agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0898f2e-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Accession Bonus","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0898f2f-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308j/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary concerned may pay an accession bonus under this section to an eligible person who enters into an agreement with the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0898f30-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308j/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to accept an appointment as an officer in the armed forces; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0898f31-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308j/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to serve in the Selected Reserve of the Ready Reserve in a skill designated under paragraph (2) for a period specified in the agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0898f32-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308j/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb0898f33-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308j/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned shall designate for an armed force under the Secretary’s jurisdiction the officer skills to which the authority under this subsection is to be applied.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb0898f34-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308j/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A skill may be designated for an armed force under subparagraph (A) if, to mitigate a current or projected significant shortage of personnel in that armed force who are qualified in that skill, it is critical to increase the number of persons accessed into that armed force who are qualified in that skill or are to be trained in that skill.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0898f35-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308j/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An accession bonus payable to a person pursuant to an agreement under this section accrues on the date on which that agreement is accepted by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0898f36-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308j/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Period of Obligated Service","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An agreement entered into with the Secretary concerned under this section shall require the person entering into that agreement to serve in the Selected Reserve for a specified period. The period specified in the agreement shall be any period not less than three years that the Secretary concerned determines appropriate to meet the needs of the reserve component in which the service is to be performed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0898f37-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308j/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of a bonus under this section may be any amount not in excess of $20,000 that the Secretary concerned determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0898f38-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308j/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb0898f39-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308j/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon acceptance of a written agreement by the Secretary concerned under this section, the total amount of the bonus payable under the agreement becomes fixed. The agreement shall specify whether the bonus is to be paid in one lump sum or in installments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb0898f3a-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308j/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person entitled to a bonus under this section who is called or ordered to active duty shall be paid, during that period of active duty, any amount of the bonus that becomes payable to the member during that period of active duty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0898f3b-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308j/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relation to Other Accession Bonus Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person may not receive an affiliation bonus or accession bonus under this section and financial assistance under chapter 1608, 1609, or 1611 of title 10, or under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s302g"},"text":"section 302g of this title","children":[],"tail":", for the same period of service."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb0898f3c-2930-11f1-a69d-9cbca84c43f0","identifier":"/us/usc/t37/s308j/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person who enters into an agreement under this section and receives all or part of the bonus under the agreement, but who does not accept a commission or an appointment as an officer or does not commence to participate or does not satisfactorily participate in the Selected Reserve for the total period of service specified in the agreement, shall be subject to the repayment provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s303a/e"},"text":"section 303a(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb0898f3d-2930-11f1-a69d-9cbca84c43f0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tVI/s619/a"},"text":"Pub. L. 108–375, div. A, title VI, § 619(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1950"},"text":"118 Stat. 1950","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tVI/s634/a"},"text":"Pub. L. 109–163, div. A, title VI, § 634(a)","children":[],"tail":"–(c)(1), "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3300"},"text":"119 Stat. 3300","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tX/s1071/c/4"},"text":"Pub. L. 109–364, div. A, title X, § 1071(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2401"},"text":"120 Stat. 2401","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tVI/s616"},"text":"Pub. L. 112–239, div. A, title VI, § 616","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1777"},"text":"126 Stat. 1777","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb0898f3e-2930-11f1-a69d-9cbca84c43f0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb0898f3f-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb0898f40-2930-11f1-a69d-9cbca84c43f0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":" substituted “$20,000” for “$10,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s634/c/1"},"text":"Pub. L. 109–163, § 634(c)(1)","children":[],"tail":", substituted “Special pay: affiliation bonus for officers in the Selected Reserve” for “Special pay: bonus for certain initial service of officers in the Selected Reserve”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s634/a"},"text":"Pub. L. 109–163, § 634(a)","children":[],"tail":", redesignated subpar. (C) as (B) and struck out former subpar. (B) which read as follows: “has not previously served in the Selected Reserve of the Ready Reserve; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s634/b"},"text":"Pub. L. 109–163, § 634(b)","children":[],"tail":", substituted “$10,000” for “$6,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":" added subsec. (g) and struck out former subsec. (g) which related to requirement to repay bonus upon failure to commence or complete obligated service, inclusion of repayment requirements in each agreement, and characterization of obligation to repay as a debt owed to the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
