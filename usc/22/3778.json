{"tag":"section","attrib":{"id":"id904891ef-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3778"},"text":null,"children":[{"tag":"num","attrib":{"value":"3778"},"text":"§ 3778.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of local inspectors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id904891f0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3778/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The President shall provide for the establishment of a Board of Local Inspectors of the Panama Canal Commission which shall perform, in accordance with regulations prescribed by the President—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id904891f1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3778/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the investigations required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3777"},"text":"section 3777 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904891f2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3778/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other duties with respect to marine matters as may be assigned by the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id904891f3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3778/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In conducting any investigation pursuant to subsection (a) of this section, the Board of Local Inspectors established pursuant to such subsection may summon witnesses, administer oaths, and require the production of books and papers necessary for such investigation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id904891f4-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70/tI/s1418"},"text":"Pub. L. 96–70, title I, § 1418","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-27"},"text":"Sept. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/487"},"text":"93 Stat. 487","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id904891f5-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id904891f6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id904891f7-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions vested in President by this section delegated to Secretary of Defense, see section 1–303 of Ex. Ord. No. 12215, ","children":[{"tag":"date","attrib":{"date":"1980-05-27"},"text":"May 27, 1980","children":[],"tail":", 45 F.R. 36044, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3601"},"text":"section 3601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
