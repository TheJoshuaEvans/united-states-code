{"tag":"section","attrib":{"id":"id90c22fe0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6724"},"text":null,"children":[{"tag":"num","attrib":{"value":"6724"},"text":"§ 6724.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures for inspections","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90c22fe1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6724/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Types of inspections","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each inspection of a plant, plant site, or other facility or location in the United States under the Convention shall be conducted in accordance with this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6725"},"text":"section 6725 of this title","children":[],"tail":", except where other procedures are provided in a facility agreement entered into under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6722"},"text":"section 6722 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90c22fe2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6724/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90c22fe3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6724/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An inspection referred to in subsection (a) may be made only upon issuance of an actual written notice by the United States National Authority to the owner and to the operator, occupant, or agent in charge of the premises to be inspected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90c22fe4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6724/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time of notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The notice for a routine inspection shall be submitted to the owner and to the operator, occupant, or agent in charge within six hours of receiving the notification of the inspection from the Technical Secretariat or as soon as possible thereafter. Notice for a challenge inspection shall be provided at any appropriate time determined by the United States National Authority. Notices may be posted prominently at the plant, plant site, or other facility or location if the United States is unable to provide actual written notice to the owner, operator, or agent in charge of the premises.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90c22fe5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6724/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content of notice","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90c22fe6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6724/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The notice under paragraph (1) shall include all appropriate information supplied by the Technical Secretariat to the United States National Authority concerning—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90c22fe7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6724/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type of inspection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90c22fe8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6724/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the basis for the selection of the plant, plant site, or other facility or location for the type of inspection sought;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90c22fe9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6724/b/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the time and date that the inspection will begin and the period covered by the inspection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90c22fea-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6724/b/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the names and titles of the inspectors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90c22feb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6724/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for challenge inspections","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a challenge inspection pursuant to Article IX of the Convention, the notice shall also include all appropriate evidence or reasons provided by the requesting state party to the Convention for seeking the inspection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90c22fec-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6724/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separate notices required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A separate notice shall be provided for each inspection, except that a notice shall not be required for each entry made during the period covered by the inspection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90c22fed-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6724/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credentials","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The head of the inspection team of the Technical Secretariat and the accompanying employees of the Federal Government (and, in the case of an inspection of a United States Government facility, any accompanying contractor personnel) shall display appropriate identifying credentials to the owner, operator, occupant, or agent in charge of the premises before the inspection is commenced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90c22fee-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6724/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timeframe for inspections","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Consistent with the provisions of the Convention, each inspection shall be commenced and completed with reasonable promptness and shall be conducted at reasonable times, within reasonable limits, and in a reasonable manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90c22fef-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6724/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90c22ff0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6724/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in a warrant issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6725"},"text":"section 6725 of this title","children":[],"tail":" or a facility agreement entered into under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6722"},"text":"section 6722 of this title","children":[],"tail":", an inspection conducted under this subchapter may extend to all things within the premises inspected (including records, files, papers, processes, controls, structures and vehicles) related to whether the requirements of the Convention applicable to such premises have been complied with."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90c22ff1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6724/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Unless required by the Convention, no inspection under this subchapter shall extend to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90c22ff2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6724/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financial data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90c22ff3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6724/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sales and marketing data (other than shipment data);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90c22ff4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6724/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pricing data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90c22ff5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6724/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personnel data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90c22ff6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6724/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90c22ff7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6724/e/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" patent data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90c22ff8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6724/e/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data maintained for compliance with environmental or occupational health and safety regulations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90c22ff9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6724/e/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personnel and vehicles entering and personnel and personal passenger vehicles exiting the facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90c22ffa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6724/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sampling and safety","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90c22ffb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6724/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the United States National Authority is authorized to require the provision of samples to a member of the inspection team of the Technical Secretariat in accordance with the provisions of the Convention. The owner or the operator, occupant or agent in charge of the premises to be inspected shall determine whether the sample shall be taken by representatives of the premises or the inspection team or other individuals present. No sample collected in the United States pursuant to an inspection permitted by this chapter may be transferred for analysis to any laboratory outside the territory of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90c22ffc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6724/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out their activities, members of the inspection team of the Technical Secretariat and representatives of agencies or departments accompanying the inspection team shall observe safety regulations established at the premises to be inspected, including those for protection of controlled environments within a facility and for personal safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90c22ffd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6724/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The appropriate representatives of the United States, as designated, if present, shall assist the owner and the operator, occupant or agent in charge of the premises to be inspected in interacting with the members of the inspection team of the Technical Secretariat.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90c22ffe-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dI/tIII/s304"},"text":"Pub. L. 105–277, div. I, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-874"},"text":"112 Stat. 2681–874","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tXII/s1204/b"},"text":"Pub. L. 107–107, div. A, title XII, § 1204(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1247"},"text":"115 Stat. 1247","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90c22fff-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90c23000-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90c23001-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (f)(1), was in the original “this Act” and was translated as reading “this division”, meaning div. I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-856"},"text":"112 Stat. 2681–856","children":[],"tail":", known as the Chemical Weapons Convention Implementation Act of 1998, to reflect the probable intent of Congress. For complete classification of division I to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6701"},"text":"section 6701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90c23002-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" substituted “Federal Government (and, in the case of an inspection of a United States Government facility, any accompanying contractor personnel)” for “Federal government”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
