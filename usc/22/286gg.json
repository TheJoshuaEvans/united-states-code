{"tag":"section","attrib":{"id":"id8ec8a8d3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286gg"},"text":null,"children":[{"tag":"num","attrib":{"value":"286gg"},"text":"§ 286gg.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elimination of trade restrictions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ec8a8d4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286gg/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotion of fair trade as financial assistance policy","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ec8a8d5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286gg/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of the Treasury shall instruct the United States Executive Director of each of the multilateral development banks (in this section referred to as the “banks”) and of the Fund to initiate a wide consultation with the Managing Director of each of the banks and of the Fund and the other directors of the banks and of the Fund with regard to the development of financial assistance policies which, to the maximum feasible extent—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ec8a8d6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286gg/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce obstacles to and restrictions upon international trade and investment in goods and services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ec8a8d7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286gg/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eliminate unfair trade and investment practices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ec8a8d8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286gg/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote mutually advantageous economic relations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ec8a8d9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286gg/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Treasury shall work closely in this effort with the Trade Policy Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ec8a8da-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286gg/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As part of this effort, the Secretary of the Treasury shall also instruct the United States Executive Director of each of the banks and of the Fund to encourage close cooperation between their staff and the Secretariat of the World Trade Organization (as the term “World Trade Organization” is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3501/8"},"text":"section 3501(8) of title 19","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ec8a8db-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286gg/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement to eliminate unfair trade practices as condition of financial assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ec8a8dc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286gg/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Treasury shall instruct the United States Executive Director of each of the banks and of the Fund, prior to the extension to any country of financial assistance by the banks and by the Fund, to work to have the banks and the Fund obtain the agreement of such country to eliminate, in a manner consistent with its balance of payments adjustment program, unfair trade and investment practices with respect to goods and services which the United States Trade Representative, after consultation with the Trade Policy Committee, has determined to have a significant deleterious effect on the international trading system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ec8a8dd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286gg/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Such practices include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ec8a8de-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286gg/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of predatory export subsidies, employed in connection with the exporting of agricultural commodities and products thereof to foreign countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ec8a8df-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286gg/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of other export subsidies, such as government subsidized below-market interest rate financing for commodities or manufactured goods;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ec8a8e0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286gg/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unreasonable import restrictions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ec8a8e1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286gg/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the imposition of trade-related performance requirements on foreign investment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ec8a8e2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286gg/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" practices which are inconsistent with international agreements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ec8a8e3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286gg/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States position on requests for loans or drawing under bank and Fund programs; progress made in eliminating unfair trade practices","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ec8a8e4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286gg/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In determining the United States position on requests for loans or periodic drawing under bank and Fund programs, the Secretary of the Treasury shall take full account of the progress countries have made in achieving targets for eliminating or phasing out the practices referred to in subsection (b) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ec8a8e5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286gg/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the event that the United States supports a request for loans or drawing by a country that has not achieved the bank and Fund targets relating to such practices specified in its program, the Secretary of the Treasury shall report to the appropriate committees of the Congress the reasons for the United States position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ec8a8e6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286gg/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Multilateral development banks” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “multilateral development banks” means the International Bank for Reconstruction and Development, the Inter-American Development Bank, the African Development Bank, and the Asian Development Bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ec8a8e7-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-07-31/ch339/s49"},"text":"July 31, 1945, ch. 339, § 49","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/181/tI"},"text":"Pub. L. 98–181, title I","children":[],"tail":" [title VIII, § 812], "},{"tag":"date","attrib":{"date":"1983-11-30"},"text":"Nov. 30, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1275"},"text":"97 Stat. 1275","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/500/s101/f/tV/s555"},"text":"Pub. L. 99–500, § 101(f) [title V, § 555]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1783-213"},"text":"100 Stat. 1783–213","children":[],"tail":", 1783–240, and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/s101/f/tV/s555"},"text":"Pub. L. 99–591, § 101(f) [title V, § 555]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-30"},"text":"Oct. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3341-214"},"text":"100 Stat. 3341–214","children":[],"tail":", 3341–240; "},{"tag":"ref","attrib":{"href":"/us/pl/106/36/tI/s1002/c"},"text":"Pub. L. 106–36, title I, § 1002(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-06-25"},"text":"June 25, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/133"},"text":"113 Stat. 133","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ec8a8e8-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ec8a8e9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8ec8a8ea-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/591"},"text":"Pub. L. 99–591","children":[],"tail":" is a corrected version of "},{"tag":"ref","attrib":{"href":"/us/pl/99/500"},"text":"Pub. L. 99–500","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8ec8a8eb-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/36"},"text":"Pub. L. 106–36","children":[],"tail":" substituted “Secretariat of the World Trade Organization (as the term ‘World Trade Organization’ is defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3501/8"},"text":"section 3501(8) of title 19","children":[],"tail":")” for “GATT Secretariat”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500"},"text":"Pub. L. 99–500","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/s101/f/tV/s555/b"},"text":"Pub. L. 99–591, § 101(f) [title V, § 555(b)]","children":[],"tail":", inserted “each of the multilateral development banks (in this section referred to as the ‘banks’) and of”, “each of the banks and of”, and “banks and of the”, and substituted “development of financial” for “development of Fund financial”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500"},"text":"Pub. L. 99–500","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/s101/f/tV/s555/c"},"text":"Pub. L. 99–591, § 101(f) [title V, § 555(c)]","children":[],"tail":", inserted “each of the banks and of” and substituted “their staff” for “Fund staff”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500"},"text":"Pub. L. 99–500","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/s101/f/tV/s555/d"},"text":"Pub. L. 99–591, § 101(f) [title V, § 555(d)]","children":[],"tail":", inserted “each of the banks and of”, “the banks and by”, and “the banks and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500"},"text":"Pub. L. 99–500","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/s101/f/tV/s555/e"},"text":"Pub. L. 99–591, § 101(f) [title V, § 555(e), (f)]","children":[],"tail":", inserted “bank and” and “loans or” in pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500"},"text":"Pub. L. 99–500","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/s101/f/tV/s555/a"},"text":"Pub. L. 99–591, § 101(f) [title V, § 555(a)]","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
