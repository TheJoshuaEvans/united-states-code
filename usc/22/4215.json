{"tag":"section","attrib":{"id":"id9073730f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4215"},"text":null,"children":[{"tag":"num","attrib":{"value":"4215"},"text":"§ 4215.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notarial acts, oaths, affirmations, affidavits, and depositions; fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Every consular officer of the United States is required, whenever application is made to him therefor, within the limits of his consulate, to administer to or take from any person any oath, affirmation, affidavit, or deposition, and to perform any other notarial act which any notary public is required or authorized by law to do within the United States; and for every such notarial act performed he shall charge in each instance the appropriate fee prescribed by the President under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4219"},"text":"section 4219 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id90737310-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1906-04-05/ch1366/s7"},"text":"Apr. 5, 1906, ch. 1366, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/101"},"text":"34 Stat. 101","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s127/b"},"text":"Pub. L. 103–236, title I, § 127(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/394"},"text":"108 Stat. 394","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/415/s1/mm/1"},"text":"Pub. L. 103–415, § 1(mm)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4303"},"text":"108 Stat. 4303","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90737311-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90737312-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id90737313-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Foreign Service Act of 1980 which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s1195"},"text":"section 1195 of this title","children":[],"tail":", and prior thereto to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s98"},"text":"section 98 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90737314-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/415"},"text":"Pub. L. 103–415","children":[],"tail":" struck out sentence inserted at end by "},{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":". See below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":" inserted at end “Pursuant to such regulations as the Secretary of State may prescribe, the Secretary may designate any other employee of the Department of State who is a citizen of the United States to perform any notarial function authorized to be performed by a consular officer of the United States under this Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
