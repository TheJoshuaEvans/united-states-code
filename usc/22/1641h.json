{"tag":"section","attrib":{"id":"id8f12a9ef-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1641h"},"text":null,"children":[{"tag":"num","attrib":{"value":"1641h"},"text":"§ 1641h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds for payment of claims","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All payments authorized under this subchapter shall be disbursed exclusively from the claims fund attributable to the country with respect to which the claims are allowed pursuant to this subchapter. All amounts covered into the Treasury to the credit of the claims funds created by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s1641a"},"text":"section 1641a of this title","children":[],"tail":" are hereby permanently appropriated for the making of the payments authorized under this subchapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f12a9f0-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-03-10/ch54"},"text":"Mar. 10, 1950, ch. 54","children":[],"tail":", title III, § 309, as added "},{"tag":"ref","attrib":{"href":"/us/act/1955-08-09/ch645/s3"},"text":"Aug. 9, 1955, ch. 645, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/573"},"text":"69 Stat. 573","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
