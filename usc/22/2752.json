{"tag":"section","attrib":{"id":"id900a9e2e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2752"},"text":null,"children":[{"tag":"num","attrib":{"value":"2752"},"text":"§ 2752.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with foreign policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id900a9e2f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2752/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noninfringement of powers or functions of Secretary of State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing contained in this chapter shall be construed to infringe upon the powers or functions of the Secretary of State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id900a9e30-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2752/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibility for supervision and direction of sales, leases, financing, cooperative projects, and exports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under the direction of the President, the Secretary of State (taking into account other United States activities abroad, such as military assistance, economic assistance, and the food for peace program) shall be responsible for the continuous supervision and general direction of sales, leases, financing, cooperative projects, and exports under this chapter, including, but not limited to, determining—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id900a9e31-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2752/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether there will be a sale to or financing for a country and the amount thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id900a9e32-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2752/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether there will be a lease to a country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id900a9e33-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2752/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether there will be a cooperative project and the scope thereof; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id900a9e34-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2752/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether there will be delivery or other performance under such sale, lease, cooperative project, or export,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"to the end that sales, financing, leases, cooperative projects, and exports will be integrated with other United States activities and to the end that the foreign policy of the United States would be best served thereby.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id900a9e35-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2752/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination among representatives of United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall prescribe appropriate procedures to assure coordination among representatives of the United States Government in each country, under the leadership of the Chief of the United States Diplomatic Mission. The Chief of the diplomatic mission shall make sure that recommendations of such representatives pertaining to sales are coordinated with political and economic considerations, and his comments shall accompany such recommendations if he so desires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id900a9e36-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/629"},"text":"Pub. L. 90–629","children":[],"tail":", ch. 1, § 2, "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1322"},"text":"82 Stat. 1322","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/329/tII/s212/a/2"},"text":"Pub. L. 94–329, title II, § 212(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-06-30"},"text":"June 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/745"},"text":"90 Stat. 745","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/113/tI/s109/b/1"},"text":"Pub. L. 97–113, title I, § 109(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1526"},"text":"95 Stat. 1526","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/83/tI/s115/b/1"},"text":"Pub. L. 99–83, title I, § 115(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-08"},"text":"Aug. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/201"},"text":"99 Stat. 201","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/145/tXI/s1102/a/2"},"text":"Pub. L. 99–145, title XI, § 1102(a)(2)","children":[],"tail":", (5), "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/710"},"text":"99 Stat. 710","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tXIII/s1342/e"},"text":"Pub. L. 99–661, div. A, title XIII, § 1342(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3991"},"text":"100 Stat. 3991","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id900a9e37-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id900a9e38-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id900a9e39-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a) and (b), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/629"},"text":"Pub. L. 90–629","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1321"},"text":"82 Stat. 1321","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2751"},"text":"section 2751 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id900a9e3a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661"},"text":"Pub. L. 99–661","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/pl/99/145/s1102/a/2"},"text":"section 1102(a)(2) of Pub. L. 99–145","children":[],"tail":" and the amendments made by that section, and provided that this section shall apply as if that section had never been enacted. See 1985 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/83"},"text":"Pub. L. 99–83","children":[],"tail":" amended subsec. (b) generally, substituting reference to the food for peace program for reference to food for freedom and adding financing and cooperative projects under this chapter to the list of responsibilities of the Secretary of State."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145/s1102/a/2"},"text":"Pub. L. 99–145, § 1102(a)(2)","children":[],"tail":", which enacted amendments similar to those provided in "},{"tag":"ref","attrib":{"href":"/us/pl/99/83"},"text":"Pub. L. 99–83","children":[],"tail":", was repealed. See 1986 Amendment note above and Repeals; Effective Date note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/113"},"text":"Pub. L. 97–113","children":[],"tail":" substituted “sales, leases,” for “sales” in two places and “such sale, lease,” for “such sale” and inserted “whether there shall be a lease to a country,” after “whether there shall be a sale to a country and the amount thereof,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/329"},"text":"Pub. L. 94–329","children":[],"tail":" inserted “and exports” after “sales” wherever appearing and “and whether there shall be delivery or other performance under such sale or export,” after “thereof,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id900a9e3b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id900a9e3c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/83"},"text":"Pub. L. 99–83","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1985-10-01"},"text":"Oct. 1, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/83/s1301"},"text":"section 1301 of Pub. L. 99–83","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151–1"},"text":"section 2151–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id900a9e3d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1968-07-01"},"text":"July 1, 1968","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/629/s41"},"text":"section 41 of Pub. L. 90–629","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2751"},"text":"section 2751 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"repeals","id":"id900a9e3e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[