{"tag":"section","attrib":{"id":"id911cd17f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111"},"text":null,"children":[{"tag":"num","attrib":{"value":"9111"},"text":"§ 9111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual Report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id911cd180-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than April 30 of each year, the Secretary of State shall submit to the appropriate congressional committees an Annual Report on International Child Abduction. The Secretary shall post the Annual Report to the publicly accessible website of the Department of State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id911cd181-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Annual Report shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id911cd182-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a list of all countries in which there were 1 or more abduction cases, during the preceding calendar year, relating to a child whose habitual residence is the United States, including a description of whether each such country—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911cd183-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a Convention country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911cd184-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a bilateral procedures country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911cd185-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has other procedures for resolving such abductions; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911cd186-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adheres to no protocols with respect to child abduction;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911cd187-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for each country with respect to which there were 5 or more pending abduction cases, during the preceding year, relating to a child whose habitual residence is the United States—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911cd188-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of such new abduction and access cases, respectively, reported during the preceding year and the number of children involved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911cd189-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for Convention and bilateral procedures countries—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id911cd18a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of abduction and access cases that the Central Authority of the United States transmitted to the Central Authority of such country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id911cd18b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of abduction and access cases that were not submitted by the Central Authority to the judicial or administrative authority, as applicable, of such country;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911cd18c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reason for the delay in submission of each case identified in subparagraph (B)(ii) by the Central Authority of such country to the judicial or administrative authority of that country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911cd18d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of unresolved abduction and access cases, respectively, the number of children involved, and the length of time each case has been pending;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911cd18e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the number and percentage of unresolved abduction cases in which law enforcement authorities have—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id911cd18f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/b/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not located the abducted child;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id911cd190-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/b/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" failed to undertake serious efforts to locate the abducted child; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id911cd191-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/b/2/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" failed to enforce a return order rendered by the judicial or administrative authorities of such country;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911cd192-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number and the percentage of the total number of abduction and access cases, respectively, resolved during the preceding year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911cd193-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations to improve the resolution of abduction and access cases; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911cd194-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average time it takes to locate a child;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911cd195-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the number of abducted children whose habitual residence is in the United States and who were returned to the United States from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911cd196-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Convention countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911cd197-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bilateral procedures countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911cd198-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" countries having other procedures for resolving such abductions; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911cd199-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" countries adhering to no protocols with respect to child abduction;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911cd19a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of Convention countries and bilateral procedures countries that have failed to comply with any of their obligations under the Hague Abduction Convention or bilateral procedures, as applicable, with respect to the resolution of abduction and access cases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911cd19b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of countries demonstrating a pattern of noncompliance and a description of the criteria on which the determination of a pattern of noncompliance for each country is based;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911cd19c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" information on efforts by the Secretary of State to encourage non-Convention countries—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911cd19d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ratify or accede to the Hague Abduction Convention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911cd19e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enter into or implement other bilateral procedures, including memoranda of understanding, with the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911cd19f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/b/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to address pending abduction and access cases;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911cd1a0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of cases resolved without abducted children being returned to the United States from Convention countries, bilateral procedures countries, or other non-Convention countries, and number of children involved in such cases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911cd1a1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of countries that became Convention countries with respect to the United States during the preceding year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911cd1a2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information about efforts to seek resolution of abduction cases of children whose habitual residence is in the United States and whose abduction occurred before the Hague Abduction Convention entered into force with respect to the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911cd1a3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of pending cases the Department of State has assigned to case officers and number of children involved for each country and as a total for all countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id911cd1a4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Unless a left-behind parent provides written permission to the Central Authority of the United States to include personally identifiable information about the parent or the child in the Annual Report, the Annual Report may not include any personally identifiable information about any such parent, child, or party to an abduction or access case involving such parent or child.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id911cd1a5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional sections","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Annual Report shall also include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id911cd1a6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on the number of unresolved abduction cases affecting military parents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911cd1a7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the assistance offered to such military parents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911cd1a8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on the use of airlines in abductions, voluntary airline practices to prevent abductions, and recommendations for best airline practices to prevent abductions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911cd1a9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on actions taken by the Central Authority of the United States to train domestic judges in the application of the Hague Abduction Convention; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911cd1aa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" information on actions taken by the Central Authority of the United States to train United States Armed Forces legal assistance personnel, military chaplains, and military family support center personnel about—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911cd1ab-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" abductions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911cd1ac-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the risk of loss of contact with children; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911cd1ad-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/d/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the legal means available to resolve such cases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id911cd1ae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id911cd1af-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification to Congress on countries in noncompliance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id911cd1b0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall include, in a separate section of the Annual Report, the Secretary’s determination, pursuant to the provisions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9122/b"},"text":"section 9122(b) of this title","children":[],"tail":", of whether each country listed in the report has engaged in a pattern of noncompliance in cases of child abduction during the preceding 12 months."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911cd1b1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The section described in paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911cd1b2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall identify any action or actions described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9122/d"},"text":"section 9122(d) of this title","children":[],"tail":" (or commensurate action as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s9122/e"},"text":"section 9122(e) of this title","children":[],"tail":") that have been taken by the Secretary with respect to each country;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911cd1b3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall describe the basis for the Secretary’s determination of the pattern of noncompliance by each country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911cd1b4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9111/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall indicate whether noneconomic policy options designed to resolve the pattern of noncompliance have reasonably been exhausted, including the consultations required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9123"},"text":"section 9123 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id911cd1b5-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/150/tI/s101"},"text":"Pub. L. 113–150, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-08-08"},"text":"Aug. 8, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1813"},"text":"128 Stat. 1813","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dE/tLVII/s5702"},"text":"Pub. L. 117–81, div. E, title LVII, § 5702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attr