{"tag":"section","attrib":{"id":"id8e884463-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s254d"},"text":null,"children":[{"tag":"num","attrib":{"value":"254d"},"text":"§ 254d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dismissal on motion of action against individual entitled to immunity","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any action or proceeding brought against an individual who is entitled to immunity with respect to such action or proceeding under the Vienna Convention on Diplomatic Relations, under section 254b or 254c of this title, or under any other laws extending diplomatic privileges and immunities, shall be dismissed. Such immunity may be established upon motion or suggestion by or on behalf of the individual, or as otherwise permitted by law or applicable rules of procedure.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8e884464-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/393/s5"},"text":"Pub. L. 95–393, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-09-30"},"text":"Sept. 30, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/809"},"text":"92 Stat. 809","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8e884465-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8e884466-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id8e884467-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective at end of ninety-day period beginning on ","children":[{"tag":"date","attrib":{"date":"1978-09-30"},"text":"Sept. 30, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/393/s9"},"text":"section 9 of Pub. L. 95–393","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s254a"},"text":"section 254a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
