children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1535"},"text":"95 Stat. 1535","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tI/s101/1"},"text":"Pub. L. 98–473, title I, § 101(1)","children":[],"tail":" [title V, § 541(a)], "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1884"},"text":"98 Stat. 1884","children":[],"tail":", 1903; "},{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/e/tII/s201"},"text":"Pub. L. 100–202, § 101(e) [title II, § 201]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-131"},"text":"101 Stat. 1329–131","children":[],"tail":", 1329–142; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/d/tII"},"text":"Pub. L. 105–277, div. A, § 101(d) [title II]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-150"},"text":"112 Stat. 2681–150","children":[],"tail":", 2681–157.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f63b08c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f63b08d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8f63b08e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Foreign Assistance Act of 1969, referred to in subsecs. (b), (c), (d), and (g), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/175"},"text":"Pub. L. 91–175","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/805"},"text":"83 Stat. 805","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":" and Tables. The guaranty authorities repealed by the 1969 Act were the guaranty authorities contained in sections 2181 to 2184 prior to the general reorganization of this subpart by the 1969 Act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2200"},"text":"Section 2200 of this title","children":[],"tail":", referred to in subsec. (d), was in the original a reference to section 240 of this Act, meaning "},{"tag":"ref","attrib":{"href":"/us/pl/87/195/s240"},"text":"section 240 of Pub. L. 87–195","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/91/175/s105"},"text":"section 105 of Pub. L. 91–175","children":[],"tail":", which was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/93/559/s8/b"},"text":"section 8(b) of Pub. L. 93–559","children":[],"tail":", and was replaced by "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2182a"},"text":"section 2182a of this title","children":[],"tail":". Another "},{"tag":"ref","attrib":{"href":"/us/pl/87/195/s240"},"text":"section 240 of Pub. L. 87–195","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/95/268/s9"},"text":"section 9 of Pub. L. 95–268","children":[],"tail":", was enacted "},{"tag":"date","attrib":{"date":"1978-04-24"},"text":"Apr. 24, 1978","children":[],"tail":", and was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2200"},"text":"section 2200 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dF/