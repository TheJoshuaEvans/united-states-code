{"tag":"section","attrib":{"id":"id90357f0b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3312"},"text":null,"children":[{"tag":"num","attrib":{"value":"3312"},"text":"§ 3312.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President is authorized to prescribe such rules and regulations as he may deem appropriate to carry out the purposes of this chapter. During the three-year period beginning on ","children":[{"tag":"date","attrib":{"date":"1979-01-01"},"text":"January 1, 1979","children":[],"tail":", such rules and regulations shall be transmitted promptly to the Speaker of the House of Representatives and to the Committee on Foreign Relations of the Senate. Such action shall not, however, relieve the Institute of the responsibilities placed upon it by this chapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id90357f0c-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/8/s13"},"text":"Pub. L. 96–8, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-04-10"},"text":"Apr. 10, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/20"},"text":"93 Stat. 20","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90357f0d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90357f0e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id90357f0f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective as of ","children":[{"tag":"date","attrib":{"date":"1979-01-01"},"text":"January 1, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/8/s18"},"text":"section 18 of Pub. L. 96–8","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3301"},"text":"section 3301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
