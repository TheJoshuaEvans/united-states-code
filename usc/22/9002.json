{"tag":"section","attrib":{"id":"id911a61bd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9002"},"text":null,"children":[{"tag":"num","attrib":{"value":"9002"},"text":"§ 9002.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id911a61be-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9002/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “applicant” means any person who, pursuant to the Convention, files an application with the United States Central Authority or a Central Authority of any other party to the Convention for the return of a child alleged to have been wrongfully removed or retained or for arrangements for organizing or securing the effective exercise of rights of access pursuant to the Convention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a61bf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9002/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Convention” means the Convention on the Civil Aspects of International Child Abduction, done at The Hague on ","children":[{"tag":"date","attrib":{"date":"1980-10-25"},"text":"October 25, 1980","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a61c0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9002/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Parent Locator Service” means the service established by the Secretary of Health and Human Services under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s653"},"text":"section 653 of title 42","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a61c1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9002/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “petitioner” means any person who, in accordance with this chapter, files a petition in court seeking relief under the Convention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a61c2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9002/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “person” includes any individual, institution, or other legal entity or body;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a61c3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9002/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “respondent” means any person against whose interests a petition is filed in court, in accordance with this chapter, which seeks relief under the Convention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a61c4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9002/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “rights of access” means visitation rights;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a61c5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9002/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State” means any of the several States, the District of Columbia, and any commonwealth, territory, or possession of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a61c6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9002/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “United States Central Authority” means the agency of the Federal Government designated by the President under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9006/a"},"text":"section 9006(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id911a61c7-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/300/s3"},"text":"Pub. L. 100–300, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-29"},"text":"Apr. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/437"},"text":"102 Stat. 437","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id911a61c8-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id911a61c9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id911a61ca-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act” meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/300"},"text":"Pub. L. 100–300","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-29"},"text":"Apr. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/437"},"text":"102 Stat. 437","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s9001"},"text":"section 9001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id911a61cb-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11602"},"text":"section 11602 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
