{"tag":"section","attrib":{"id":"id90eac686-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7702"},"text":null,"children":[{"tag":"num","attrib":{"value":"7702"},"text":"§ 7702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90eac687-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7702/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90eac688-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7702/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on International Relations and the Committee on Appropriations of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90eac689-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7702/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations and the Committee on Appropriations of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90eac68a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7702/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Board” means the Board of Directors of the Corporation established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7703/c"},"text":"section 7703(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90eac68b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7702/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Candidate country","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “candidate country” means a country that meets the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7705"},"text":"section 7705 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90eac68c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7702/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief Executive Officer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Chief Executive Officer” means the chief executive officer of the Corporation appointed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7703/b"},"text":"section 7703(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90eac68d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7702/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compact","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Compact” means a Millennium Challenge Compact described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7708"},"text":"section 7708 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90eac68e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7702/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Corporation” means the Millennium Challenge Corporation established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7703/a"},"text":"section 7703(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90eac68f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7702/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible country","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible country” means a candidate country that is determined, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7706"},"text":"section 7706 of this title","children":[],"tail":", to be an eligible country to receive assistance under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7704"},"text":"section 7704 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90eac690-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7702/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investments in the people","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “investments in the people” means gov