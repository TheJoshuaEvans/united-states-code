{"tag":"section","attrib":{"id":"id8f851bac-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2296c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2296c"},"text":"§ 2296c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Border control assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f851bad-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2296c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose of assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of assistance under this section includes the assistance of the countries of the South Caucasus and Central Asia to secure their borders and implement effective controls necessary to prevent the trafficking of illegal narcotics and the proliferation of technology and materials related to weapons of mass destruction (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2332a/c/2"},"text":"section 2332a(c)(2) of title 18","children":[],"tail":"), and to contain and inhibit transnational organized criminal activities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f851bae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2296c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization for assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out the purpose of subsection (a), the President is authorized to provide assistance to the countries of the South Caucasus and Central Asia to support the activities described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f851baf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2296c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities supported","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Activities that may be supported by assistance under subsection (b) include assisting those countries of the South Caucasus and Central Asia in developing capabilities to maintain national border guards, coast guard, and customs controls.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f851bb0-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. I, § 499C, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/2/tV/s596/b"},"text":"Pub. L. 106–113, div. B, § 1000(a)(2) [title V, § 596(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1535"},"text":"113 Stat. 1535","children":[],"tail":", 1501A–124.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f851bb1-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id8f851bb2-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id8f851bb3-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions of President under this section, see Ex. Ord. No. 12163, ","children":[{"tag":"date","attrib":{"date":"1979-09-29"},"text":"Sept. 29, 1979","children":[],"tail":", 44 F.R. 56673, as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2381"},"text":"section 2381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
