{"tag":"section","attrib":{"id":"id8ee558c8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290m–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"290m–3"},"text":"§ 290m–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Border Environment Cooperation Agreement” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For purposes of this subchapter, the term “Border Environment Cooperation Agreement” (referred to in this subchapter as the “Cooperation Agreement”) means the November 1993 Agreement Between the Government of the United States of America and the Government of the United Mexican States Concerning the Establishment of a Border Environment Cooperation Commission and a North American Development Bank.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ee558c9-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/182/tV/s544"},"text":"Pub. L. 103–182, title V, § 544","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-08"},"text":"Dec. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2170"},"text":"107 Stat. 2170","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/113/tVI/s601"},"text":"Pub. L. 116–113, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/78"},"text":"134 Stat. 78","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dO/tVI/s601/a/1"},"text":"Pub. L. 116–260, div. O, title VI, § 601(a)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2149"},"text":"134 Stat. 2149","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":