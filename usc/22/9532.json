{"tag":"section","attrib":{"id":"id9132564a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9532"},"text":null,"children":[{"tag":"num","attrib":{"value":"9532"},"text":"§ 9532.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Nothing in this part or the amendments made by this part shall be construed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9132564b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9532/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to supersede the limitations or exceptions on the use of rocket engines for national security purposes under section 1608 of the Carl Levin and Howard P. “Buck” McKeon National Defense Authorization Act for Fiscal Year 2015 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291"},"text":"Public Law 113–291","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/128/3626"},"text":"128 Stat. 3626","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2271"},"text":"10 U.S.C. 2271","children":[],"tail":" note), as amended by section 1607 of the National Defense Authorization Act for Fiscal Year 2016 ("},{"tag":"ref","attrib":{"href":"/us/pl/114/92"},"text":"Public Law 114–92","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/129/1100"},"text":"129 Stat. 1100","children":[],"tail":") and section 1602 of the National Defense Authorization Act for Fiscal Year 2017 ("},{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Public Law 114–328","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/130/2582"},"text":"130 Stat. 2582","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9132564c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9532/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prohibit a contractor or subcontractor of the Department of Defense from acquiring components referred to in such section 1608.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9132564d-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/44/tII/s238"},"text":"Pub. L. 115–44, title II, § 238","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-02"},"text":"Aug. 2, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/922"},"text":"131 Stat. 922","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9132564e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9132564f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id91325650-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This part, referred to in text, is part 2 (§§ 221–238) of subtitle A of title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/44"},"text":"Pub. L. 115–44","children":[],"tail":", which enacted this part and sections 8909 and 8910 of this title and amended sections 8901, 8907, 8908, 8923, 8924 of this title. For complete classification of part 2 to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
