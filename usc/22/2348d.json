{"tag":"section","attrib":{"id":"id8f95bc7d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2348d"},"text":null,"children":[{"tag":"num","attrib":{"value":"2348d"},"text":"§ 2348d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data on costs incurred in support of United Nations peacekeeping operations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f95bc7e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2348d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall annually provide to the Secretary General of the United Nations data regarding all costs incurred by the United States Department of Defense during the preceding year in support of all United Nations Security Council resolutions as reported to the Congress pursuant to section 8079 of the Department of Defense Appropriations Act, 1998.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f95bc7f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2348d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United Nations member costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall request that the United Nations compile and publish information concerning costs incurred by United Nations members in support of such resolutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f95bc80-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. II, § 554, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/7/dA/tVII/s722"},"text":"Pub. L. 106–113, div. B, § 1000(a)(7) [div. A, title VII, § 722]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–462.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f95bc81-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f95bc82-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8f95bc83-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 8079 of the Department of Defense Appropriations Act, 1998, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/56/s8079"},"text":"section 8079 of Pub. L. 105–56","children":[],"tail":", title VIII, "},{"tag":"date","attrib":{"date":"1997-10-08"},"text":"Oct. 8, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1236"},"text":"111 Stat. 1236","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id8f95bc84-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195/s554"},"text":"section 554 of Pub. L. 87–195","children":[],"tail":" was renumbered section 553 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2348c"},"text":"section 2348c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id8f95bc85-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id8f95bc86-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions of President under this section, see Ex. Ord. No. 12163, ","children":[{"tag":"date","attrib":{"date":"1979-09-29"},"text":"Sept. 29, 1979","children":[],"tail":", 44 F.R. 56673, as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2381"},"text":"section 2381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
