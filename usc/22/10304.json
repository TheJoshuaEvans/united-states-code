{"tag":"section","attrib":{"id":"id915399fb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10304"},"text":null,"children":[{"tag":"num","attrib":{"value":"10304"},"text":"§ 10304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short course on emerging technologies for senior officials","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id915399fc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", the Secretary shall develop and begin providing, for senior officials of the Department, a course addressing how the most recent and relevant technologies affect the activities of the Department."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id915399fd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Throughput objectives","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary should ensure that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id915399fe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10304/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the first year that the course developed pursuant to subsection (a) is offered, not fewer than 20 percent of senior officials are certified as having passed such course; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id915399ff-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10304/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in each subsequent year, until the date on which 80 percent of senior officials are certified as having passed such course, an additional 10 percent of senior officials are certified as having passed such course.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id91539a00-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dI/tXCV/s9507"},"text":"Pub. L. 117–263, div. I, title XCV, § 9507","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3906"},"text":"136 Stat. 3906","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id91539a01-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id91539a02-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id91539a03-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary” and “Department” as used in this section mean the Secretary and Department of State, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s9002"},"text":"section 9002 of Pub. L. 117–263","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
