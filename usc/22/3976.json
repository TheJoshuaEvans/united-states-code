{"tag":"section","attrib":{"id":"id9054795c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3976"},"text":null,"children":[{"tag":"num","attrib":{"value":"3976"},"text":"§ 3976.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Survivors’ and dependents’ educational assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9054795d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3976/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign Service employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, pursuant to guidance issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3973/c"},"text":"section 3973(c) of this title","children":[],"tail":", provide educational assistance to a beneficiary of any United States national Foreign Service employee who dies while on duty abroad as a result of an act of terrorism, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2656f/d"},"text":"section 2656f(d) of this title","children":[],"tail":", to meet, in whole or in part, the expenses incurred by the beneficiary in pursuing a program of education at an educational institution, including subsistence, tuition, fees, supplies, books, equipment, and other educational costs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9054795e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3976/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other executive agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The head of an executive agency shall, pursuant to guidance issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3973/c"},"text":"section 3973(c) of this title","children":[],"tail":" provide educational assistance authorized by this section to a beneficiary of any employee of that agency who dies as a result of an act of terrorism or terrorism, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2656f/d"},"text":"section 2656f(d) of this title","children":[],"tail":", while on duty abroad and subject to the authority of the chief of mission pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3927"},"text":"section 3927 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9054795f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3976/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Educational assistance under this section may be made available up to the amounts provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3532"},"text":"section 3532 of title 38","children":[],"tail":", as adjusted by "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3564"},"text":"section 3564 of title 38","children":[],"tail":", and for an aggregate period not in excess of 48 months."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90547960-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3976/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program of education and educational institution defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the terms “program of education” and “educational institution” have the meanings given the terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3501"},"text":"section 3501 of title 38","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90547961-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s416"},"text":"Pub. L. 96–465, title I, § 416","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/76/dK/tVII/s7082/b/1"},"text":"Pub. L. 113–76, div. K, title VII, § 7082(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-01-17"},"text":"Jan. 17, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/566"},"text":"128 Stat. 566","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90547962-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90547963-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90547964-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2656f/d"},"text":"Section 2656f(d) of this title","children":[],"tail":", referred to in subsecs. (a) and (b), was in the original “section 140(d) of the Foreign Relations Authorization Act, Fiscal Years 1998 and 1999”, and was translated as meaning “section 140(d) of the Foreign Relations Authorization Act, Fiscal Years 1988 and 1989”, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90547965-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id90547966-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable in the case of a Foreign Service or executive branch employee subject to the authority of the chief of mission pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3927"},"text":"section 3927 of this title","children":[],"tail":", serving at a United States diplomatic or consular mission abroad, who died on or after "},{"tag":"date","attrib":{"date":"1983-04-18"},"text":"April 18, 1983","children":[],"tail":", as a result of injuries from an act of terrorism, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2656f/d"},"text":"section 2656f(d) of this title","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/113/76/s7082/c"},"text":"section 7082(c) of Pub. L. 113–76","children":[],"tail":", set out as an Effective Date of 2014 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3973"},"text":"section 3973 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
