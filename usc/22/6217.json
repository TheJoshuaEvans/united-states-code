{"tag":"section","attrib":{"id":"id90b18e03-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217"},"text":null,"children":[{"tag":"num","attrib":{"value":"6217"},"text":"§ 6217.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Global internet freedom","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90b18e04-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of policy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the policy of the United States to promote internet freedom through programs of the Department and USAID that preserve and expand the internet as an open, global space for freedom of expression and association, which shall be prioritized for countries—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90b18e05-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose governments restrict freedom of expression on the internet; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b18e06-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that are important to the national interest of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90b18e07-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose and coordination with other programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Global internet freedom programming under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90b18e08-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall be coordinated with other United States foreign assistance programs that promote democracy and support the efforts of civil society—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90b18e09-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to counter the development of repressive internet-related laws and regulations, including countering threats to internet freedom at international organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b18e0a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to combat violence against bloggers and other civil society activists who utilize the internet; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b18e0b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enhance digital security training and capacity building for democracy activists;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b18e0c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall seek to assist efforts—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90b18e0d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to research key threats to internet freedom;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b18e0e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to continue the development of technologies that provide or enhance access to the internet, including circumvention tools that bypass internet blocking, filtering, and other censorship techniques used by authoritarian governments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b18e0f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain the technological advantage of the Federal Government over the censorship techniques described in subparagraph (B); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b18e10-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be incorporated into country assistance and democracy promotion strategies, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90b18e11-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated for fiscal year 2023—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90b18e12-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $75,000,000 to the Department and USAID, to continue efforts to promote internet freedom globally, and shall be matched, to the maximum extent practicable, by sources other than the Federal Government, including the private sector; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b18e13-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" $49,000,000 to the United States Agency for Global Media (referred to in this section as the “USAGM”) and its grantees, for internet freedom and circumvention technologies that are designed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90b18e14-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for open-source tools and techniques to securely develop and distribute digital content produced by the USAGM and its grantees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b18e15-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate audience access to such digital content on websites that are censored;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b18e16-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to coordinate the distribution of such digital content to targeted regional audiences; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b18e17-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote and distribute such tools and techniques, including digital security techniques.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90b18e18-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States Agency for Global Media activities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90b18e19-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual certification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For any new tools or techniques authorized under subsection (c)(2), the Chief Executive Officer of the USAGM, in consultation with the President of the Open Technology Fund (referred to in this subsection as the “OTF”) and relevant Federal departments and agencies, shall submit an annual certification to the appropriate congressional committees that verifies they—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90b18e1a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have evaluated the risks and benefits of such new tools or techniques; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b18e1b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have established safeguards to minimize the use of such new tools or techniques for illicit purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b18e1c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information sharing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not direct programs or policy of the USAGM or the OTF, but may share any research and development with relevant Federal departments and agencies for the exclusive purposes of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90b18e1d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sharing information, technologies, and best practices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b18e1e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing the effectiveness of such technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b18e1f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States Agency for Global Media","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Chief Executive Officer of the USAGM, in consultation with the President of the OTF, shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90b3d710-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate international broadcasting programs and incorporate such programs into country broadcasting strategies, as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b3d711-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solicit project proposals through an open, transparent, and competitive application process, including by seeking input from technical and subject matter experts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b3d712-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support internet circumvention tools and techniques for audiences in countries that are strategic priorities for the OTF, in accordance with USAGM’s annual language service prioritization review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90b3d713-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" USAGM report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", the Chief Executive Office of the USAGM shall submit a report to the appropriate congressional committees that describes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90b3d714-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" as of the date of the report—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90b3d715-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the full scope of internet freedom programs within the USAGM, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90b3d716-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the efforts of the Office of Internet Freedom; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90b3d717-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the efforts of the Open Technology Fund;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b3d718-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the capacity of internet censorship circumvention tools supported by the Office of Internet Freedom and grantees of the Open Technology Fund that are available for use by individuals in foreign countries seeking to counteract censors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b3d719-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any barriers to the provision of the efforts described in clauses (i) and (ii) of subparagraph (A), including access to surge funding; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b3d71a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" successful examples from the Office of Internet Freedom and Open Technology Fund involving—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90b3d71b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" responding rapidly to internet shutdowns in closed societies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b3d71c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring uninterrupted circumvention services for USAGM entities to promote internet freedom within repressive regimes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90b3d71d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", the Secretary and the Administrator of USAID shall jointly submit a report, which may include a classified annex, to the appropriate congressional committees that describes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90b3d71e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" as of the date of the report—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90b3d71f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the full scope of internet freedom programs within the Department and USAID, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90b3d720-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/f/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Department circumvention efforts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90b3d721-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/f/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" USAID efforts to support internet infrastructure;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b3d722-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the capacity of internet censorship circumvention tools supported by the Federal Government that are available for use by individuals in foreign countries seeking to counteract censors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b3d723-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any barriers to provision of the efforts enumerated in clauses (i) and (ii) of subsection (e)(1)(A), including access to surge funding; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b3d724-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any new resources needed to provide the Federal Government with greater capacity to provide and boost internet access—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90b3d725-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to respond rapidly to internet shutdowns in closed societies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b3d726-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide internet connectivity to foreign locations where the provision of additional internet access service would promote freedom from repressive regimes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90b3d727-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security audits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before providing any support for open source technologies under this section, such technologies must undergo comprehensive security audits to ensure that such technologies are secure and have not been compromised in a manner that is detrimental to the interest of the United States or to the interests of individuals and organizations benefitting from programs supported by such funding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90b3d728-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surge","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90b3d729-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), there is authorized to be appropriated, in addition to amounts otherwise made available for such purposes, up to $2,500,000 to support internet freedom programs in closed societies, including programs that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90b3d72a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are carried out in crisis situations by vetted entities that are already engaged in internet freedom programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b3d72b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involve circumvention tools; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b3d72c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/h/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the overseas bandwidth for companies that received Federal funding during the previous fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b3d72d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts authorized to be appropriated pursuant to paragraph (1) may not be expended until the Secretary has certified to the appropriate congressional committees, the Committee on Appropriations of the Senate, and the Committee on Appropriations of the House of Representatives that the use of such funds is in the national interest of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90b3d72e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6217/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Defined term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “internet censorship circumvention tool” means a software application or other tool that an individual can use to evade foreign government restrictions on internet access.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90b3d72f-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dI/tXCVII/s9707"},"text":"Pub. L. 117–263, div. I, title XCVII, § 9707","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3915"},"text":"136 Stat. 3915","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90b3d730-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90b3d731-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id90b3d732-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Department of State Authorization Act of 2022, and also as part of the James M. Inhofe National Defense Authorization Act for Fiscal Year 2023, and not as part of the United States International Broadcasting Act of 1994 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90b3d733-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id90b3d734-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of terms used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s9002"},"text":"section 9002 of Pub. L. 117–263","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
