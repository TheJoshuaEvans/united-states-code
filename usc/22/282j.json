{"tag":"section","attrib":{"id":"id8eb80753-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s282j"},"text":null,"children":[{"tag":"num","attrib":{"value":"282j"},"text":"§ 282j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increase in capital stock of Corporation; subscription to additional shares","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8eb80754-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s282j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The United States Governor of the Corporation is authorized—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8eb80755-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s282j/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to vote for an increase of 650,000 shares in the authorized capital stock of the Corporation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8eb80756-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s282j/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to subscribe on behalf of the United States to 175,162 additional shares of the capital stock of the Corporation, except that any subscription to additional shares shall be effective only to such extent or in such amounts as are provided in advance in appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8eb80757-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s282j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to pay for the increase in the United States subscription to the Corporation provided for in this section, there are authorized to be appropriated, without fiscal year limitation, § 175,162,000 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8eb80758-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-08-11/ch788/s12"},"text":"Aug. 11, 1955, ch. 788, § 12","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/190/s101/i/tI"},"text":"Pub. L. 99–190, § 101(i) [title I, (a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-19"},"text":"Dec. 19, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1291"},"text":"99 Stat. 1291","children":[],"tail":", 1294.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8eb80759-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8eb8075a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8eb8075b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 12 of act ","children":[{"tag":"date","attrib":{"date":"1955-08-11"},"text":"Aug. 11, 1955","children":[],"tail":", is based on section 3 of H.R. 1948, Ninety-ninth Congress, as introduced "},{"tag":"date","attrib":{"date":"1985-04-03"},"text":"Apr. 3, 1985","children":[],"tail":", and enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/99/190"},"text":"Pub. L. 99–190","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
