{"tag":"section","attrib":{"id":"id9005e3fe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2741"},"text":null,"children":[{"tag":"num","attrib":{"value":"2741"},"text":"§ 2741.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to pay for or reimburse for certain security services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9005e3ff-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2741/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and the Administrator are authorized to pay for or reimburse for appropriate security services to mitigate risks to certain employees or members of their households resulting from or related to the employee’s official duties or affiliation with the Department or USAID. These security equipment or services may include security cameras and services to de-prioritize or remove internet search results revealing personally identifiable information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9005e400-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2741/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required policy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Prior to paying for or reimbursing services pursuant to subsection (a), the Department shall establish a policy that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9005e401-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2741/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outlines the requirements for qualifying for the payment of or reimbursement of services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9005e402-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2741/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies the office responsible for vetting requests for paying for or reimbursing of services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9005e403-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2741/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mandates expeditious consideration of such requests.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9005e404-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dG/tLXXI/s7115"},"text":"Pub. L. 118–159, div. G, title LXXI, § 7115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2527"},"text":"138 Stat. 2527","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9005e405-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9005e406-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id9005e407-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “Secretary”, “Administrator”, “Department”, and “USAID” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s7002"},"text":"section 7002 of Pub. L. 118–159","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
