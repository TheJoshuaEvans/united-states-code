{"tag":"section","attrib":{"id":"id8f0dc7d3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1622e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1622e"},"text":"§ 1622e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vesting of all non-adjudicatory functions, powers, and duties in Chairman of Foreign Claims Settlement Commission of the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All functions, powers, and duties not directly related to adjudicating claims are hereby vested in the Chairman, including the functions set forth in section 3 of Reorganization Plan Numbered 1 of 1954 and the authority to issue rules and regulations.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f0dc7d4-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/209/tI/s105"},"text":"Pub. L. 96–209, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-03-14"},"text":"Mar. 14, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/97"},"text":"94 Stat. 97","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f0dc7d5-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f0dc7d6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8f0dc7d7-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Reorganization Plan Numbered 1 of 1954, referred to in text, is Reorg. Plan. No. 1 of 1954, ","children":[{"tag":"date","attrib":{"date":"1954-07-01"},"text":"July 1, 1954","children":[],"tail":", 19 F.R. 3985, "},{"tag":"ref","attrib":{"href":"/us/stat/68/1279"},"text":"68 Stat. 1279","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s1622"},"text":"section 1622 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8f0dc7d8-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the International Claims Settlement Act of 1949 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f0dc7d9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id8f0dc7da-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1980-03-14"},"text":"Mar. 14, 1980","children":[],"tail":", see title VI of "},{"tag":"ref","attrib":{"href":"/us/pl/96/209"},"text":"Pub. L. 96–209","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s1622a"},"text":"section 1622a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
