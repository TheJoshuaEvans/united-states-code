{"tag":"section","attrib":{"id":"id8fa68613-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2378"},"text":null,"children":[{"tag":"num","attrib":{"value":"2378"},"text":"§ 2378.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on assistance to countries that provide military equipment to terrorist states","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fa68614-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2378/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fa68615-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2378/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall withhold assistance under this chapter to the government of any country that provides lethal military equipment to a country the government of which the Secretary of State has determined is a terrorist government for the purposes of section 4605(j) ","children":[{"tag":"ref","attrib":{"idref":"fn002146"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002146"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 50, or 2371 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fa68616-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2378/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The prohibition under this section with respect to a foreign government shall terminate 1 year after that government ceases to provide lethal military equipment. This section applies with respect to lethal military equipment provided under a contract entered into after ","children":[{"tag":"date","attrib":{"date":"1996-04-24"},"text":"April 24, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fa68617-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2378/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, assistance may be furnished to a foreign government described in subsection (a) if the President determines that furnishing such assistance is important to the national interests of the United States and, not later than 15 days before obligating such assistance, furnishes a report to the appropriate committees of Congress including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fa68618-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2378/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of the determination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fa68619-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2378/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed explanation of the assistance to be provided;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fa6861a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2378/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated dollar amount of the assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fa6861b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2378/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation of how the assistance furthers United States national interests.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fa6861c-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. III, § 620H, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/132/tIII/s326"},"text":"Pub. L. 104–132, title III, § 326","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1256"},"text":"110 Stat. 1256","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fa6861d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8fa6861e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8fa6861f-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a)(1), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195",