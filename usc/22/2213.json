{"tag":"section","attrib":{"id":"id8f686b9e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2213"},"text":null,"children":[{"tag":"num","attrib":{"value":"2213"},"text":"§ 2213.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States Microfinance Loan Facility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f686b9f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2213/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President is authorized to establish a United States Microfinance Loan Facility (in this section referred to as the “Facility”) to pool and manage the risk from natural disasters, war or civil conflict, national financial crisis, or short-term financial movements that threaten the long-term development of United States-supported financial intermediaries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f686ba0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2213/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disbursements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f686ba1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2213/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall make disbursements from the Facility to United States-supported financial intermediaries to prevent the bankruptcy of such institutions caused by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8f686ba2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2213/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" natural disasters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f686ba3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2213/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" national wars or civil conflict; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f686ba4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2213/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" national financial crisis or other short-term financial movements that threaten the long-term development of United States-supported financial intermediaries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f686ba5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2213/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Assistance under this section shall be in the form of loans or loan guarantees for financial intermediaries that demonstrate the capacity to resume self-sustained operations within a reasonable time period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f686ba6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2213/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional notification procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During each of the fiscal years 2005 through 2009, funds may not be made available from the Facility until 15 days after notification of the proposed availability of the funds has been provided to the congressional committees specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2394–1"},"text":"section 2394–1 of this title","children":[],"tail":" in accordance with the procedures applicable to reprogramming notifications under that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f686ba7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2213/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General provisions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f686ba8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2213/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In providing the credit assistance authorized by this section, the Administrator should apply, as appropriate, the policy provisions in subchapter I of this chapter that are applicable to development assistance activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f686ba9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2213/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Default and procurement provisions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8f686baa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2213/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Default provision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2370/q"},"text":"section 2370(q) of this title","children":[],"tail":", or any comparable provision of law, shall not be construed to prohibit assistance to a country in the event that a private sector recipient of assistance furnished under this section is in default in its payment to the United States for the period specified in such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f686bab-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2213/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procurement provision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Assistance may be provided under this section without regard to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2354/a"},"text":"section 2354(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f686bac-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2213/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions of credit assistance","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8f686bad-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2213/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Credit assistance provided under this section shall be offered on such terms and conditions, including fees charged, as the Administrator may determine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f686bae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2213/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on principal amount of financing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The principal amount of loans made or guaranteed under this section in any fiscal year, with respect to any single event, may not exceed $30,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f686baf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2213/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No payment may be made under any guarantee issued under this section for any loss arising out of fraud or misrepresentation for which the party seeking payment is responsible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f686bb0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2213/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full faith and credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All guarantees issued under this section shall constitute obligations, in accordance with the terms of such guarantees, of the United States of America, and the full faith and credit of the United States of America is hereby pledged for the full payment and performance of such obligations to the extent of the guarantee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f686bb1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2213/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f686bb2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2213/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the amounts made available to carry out subchapter I of this chapter for each of the fiscal years 2005 through 2009, such sums as may be necessary may be made available for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8f686bb3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2213/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the subsidy cost, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s661a/5"},"text":"section 661a(5) of title 2","children":[],"tail":", to carry out this section; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f686bb4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2213/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the administrative costs to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f686bb5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2213/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to other funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts made available under paragraph (1) are in addition to amounts available under any other provision of law to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f686bb6-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. I, § 257, formerly § 132, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/309/tI/s107/a"},"text":"Pub. L. 106–309, title I, § 107(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1086"},"text":"114 Stat. 1086","children":[],"tail":"; renumbered § 257 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/484/s5/a"},"text":"Pub. L. 108–484, § 5(a)","children":[],"tail":", (b), (c)(2), "},{"tag":"date","attrib":{"date":"2004-12-23"},"text":"Dec. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3927"},"text":"118 Stat. 3927","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/428/s4/g"},"text":"Pub. L. 115–428, § 4(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-09"},"text":"Jan. 9, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5515"},"text":"132 Stat. 5515","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f686bb7-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f686bb8-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8f686bb9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2152b"},"text":"section 2152b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id8f686bba-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2213, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. I, § 253, as added "},{"tag":"ref","attrib":{"href":"/us/pl/87/565"},"text":"Pub. L. 87–565","children":[],"tail":", pt. I, § 106, "},{"tag":"date","attrib":{"date":"1962-08-01"},"text":"Aug. 1, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/258"},"text":"76 Stat. 258","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/88/205"},"text":"Pub. L. 88–205","children":[],"tail":", pt. I, § 106(c), "},{"tag":"date","attrib":{"date":"1963-12-16"},"text":"Dec. 16, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/383"},"text":"77 Stat. 383","children":[],"tail":", related to availability of receipts from loans for Alliance for Progress, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/95/424/tI/s102/g/1/A"},"text":"Pub. L. 95–424, title I, § 102(g)(1)(A)","children":[],"tail":", title VI, § 605, "},{"tag":"date","attrib":{"date":"1978-10-06"},"text":"Oct. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/942"},"text":"92 Stat. 942","children":[],"tail":", 961, effective "},{"tag":"date","attrib":{"date":"1978-10-01"},"text":"Oct. 1, 1978","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f686bbb-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/428/s4/g/1"},"text":"Pub. L. 115–428, § 4(g)(1)","children":[],"tail":", substituted “President” for “Administrator” and “United States-supported financial intermediaries” for “United States-supported microfinance institutions”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/428/s4/g/2/A"},"text":"Pub. L. 115–428, § 4(g)(2)(A)","children":[],"tail":", substituted “United States-supported financial intermediaries” for “United States-supported microfinance institutions” in introductory provisions and in subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/428/s4/g/2/B"},"text":"Pub. L. 115–428, § 4(g)(2)(B)","children":[],"tail":", substituted “financial intermediaries” for “microfinance institutions”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (b)(3). Pub. L. 108—484, § 5(c)(2)(A), substituted “2005 through 2009” for “2001 and 2002”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec.(d)(1). Pub. L. 108—484, § 5(c)(2)(B), substituted “for each of the fiscal years 2005 through 2009, such sums as may be necessary” for “for the fiscal year 2001, up to $5,000,000”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/484/s5/c/2/C"},"text":"Pub. L. 108–484, § 5(c)(2)(C)","children":[],"tail":", struck out heading and text of subsec. (e) which defined “Administrator”, “appropriate congressional committees”, and “United States-supported microfinance institution” for purposes of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f686bbc-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8f686bbd-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References to Subchapter I Deemed To Include Certain Parts of Subchapter II","children":[],"tail":null},{"tag":"p","attrib":{},"text":"References to subchapter I of this chapter are deemed to include parts IV (§ 2346 et seq.), VI (§ 2348 et seq.), and VIII (§ 2349aa et seq.) of subchapter II of this chapter, and references to subchapter II are deemed to exclude such parts. See ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/226/s202/b"},"text":"section 202(b) of Pub. L. 92–226","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2346"},"text":"section 2346 of this title","children":[],"tail":", and sections 2348c and 2349aa–5 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
