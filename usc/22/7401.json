{"tag":"section","attrib":{"id":"id90dc6e28-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7401"},"text":null,"children":[{"tag":"num","attrib":{"value":"7401"},"text":"§ 7401.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction relating to United States accession to the International Criminal Court","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90dc6e29-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7401/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States shall not become a party to the International Criminal Court except pursuant to a treaty made under Article II, section 2, clause 2 of the Constitution of the United States on or after ","children":[{"tag":"date","attrib":{"date":"1999-11-29"},"text":"November 29, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90dc6e2a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7401/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"None of the funds authorized to be appropriated by this or any other Act may be obligated for use by, or for support of, the International Criminal Court unless the United States has become a party to the Court pursuant to a treaty made under Article II, section 2, clause 2 of the Constitution of the United States on or after ","children":[{"tag":"date","attrib":{"date":"1999-11-29"},"text":"November 29, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90dc6e2b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7401/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International Criminal Court defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “International Criminal Court” means the court established by the Rome Statute of the International Criminal Court, adopted by the United Nations Diplomatic Conference of Plenipotentiaries on the Establishment of an International Criminal Court on ","children":[{"tag":"date","attrib":{"date":"1998-07-17"},"text":"July 17, 1998","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90dc6e2c-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/7/dA/tVII/s705"},"text":"Pub. L. 106–113, div. B, § 1000(a)(7) [div. A, title VII, § 705]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–460.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90dc6e2d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90dc6e2e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id90dc6e2f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s262–1"},"text":"section 262–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90dc6e30-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id90dc6e31-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/206/tII/s2001"},"text":"Pub. L. 107–206, title II, § 2001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-02"},"text":"Aug. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/899"},"text":"116 Stat. 899","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/206/tII/s2001"},"text":"“This title [enacting subchapter II of this chapter] may be cited as the ‘American Servicemembers’ Protection Act of 2002’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
