{"tag":"section","attrib":{"id":"id90f6ad10-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8151"},"text":null,"children":[{"tag":"num","attrib":{"value":"8151"},"text":"§ 8151.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification to Congress of IAEA Board approval of wide-area environmental sampling","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90f6ad11-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8151/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after the date on which the Board of Governors of the IAEA approves wide-area environmental sampling for use as a safeguards verification tool, the President shall notify the appropriate congressional committees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90f6ad12-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8151/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The notification under subsection (a) shall contain—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90f6ad13-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8151/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the specific methods and sampling techniques approved by the Board of Governors that are to be employed for purposes of wide-area sampling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f6ad14-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8151/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement as to whether or not such sampling may be conducted in the United States under the Additional Protocol; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f6ad15-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8151/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the ability of the approved methods and sampling techniques to detect, identify, and determine the conduct, type, and nature of nuclear activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90f6ad16-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/401/tII/s251"},"text":"Pub. L. 109–401, title II, § 251","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-18"},"text":"Dec. 18, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2749"},"text":"120 Stat. 2749","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
