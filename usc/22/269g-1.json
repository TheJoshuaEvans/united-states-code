{"tag":"section","attrib":{"id":"id8ea73e15-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s269g–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"269g–1"},"text":"§ 269g–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary for the payment by the United States of its proportionate share of the expenses of the Hague Conference on Private International Law and of the International (Rome) Institute for the Unification of Private Law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ea73e16-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/244/s2"},"text":"Pub. L. 88–244, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-12-30"},"text":"Dec. 30, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/775"},"text":"77 Stat. 775","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/497"},"text":"Pub. L. 92–497","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-17"},"text":"Oct. 17, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/814"},"text":"86 Stat. 814","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/241/tI/s114"},"text":"Pub. L. 97–241, title I, § 114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-08-24"},"text":"Aug. 24, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/278"},"text":"96 Stat. 278","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ea73e17-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ea73e18-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8ea73e19-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/241"},"text":"Pub. L. 97–241","children":[],"tail":" struck out provision that no payment of the United States for any year exceed 7 per centum of all expenses apportioned among members for that year."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/497"},"text":"Pub. L. 92–497","children":[],"tail":" substituted provisions authorizing to be appropriated such sums as may be necessary for the payment of the United States of its proportionate share, except that no payment of the United States for any year shall exceed 7 per centum of all expenses apportioned among members for that year, for provisions authorizing to be appropriated such sums as may be necessary, not to exceed $25,000 annually, for the payment by the United States of its proportionate share."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ea73e1a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"appropriations","id":"id8ea73e1b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Annual Appropriations","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Annual appropriations to meet the obligations of membership in various international organizations were contained in acts listed in a note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s269a"},"text":"section 269a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
