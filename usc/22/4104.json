{"tag":"section","attrib":{"id":"id906c6e58-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4104"},"text":null,"children":[{"tag":"num","attrib":{"value":"4104"},"text":"§ 4104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee rights","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id906c6e59-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Every employee has the right to form, join, or assist any labor organization, or to refrain from any such activity, freely and without fear of penalty or reprisal. Each employee shall be protected in the exercise of such right.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id906c6e5a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as otherwise provided under this subchapter, such right includes the right—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id906c6e5b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4104/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to act for a labor organization in the capacity of a representative and, in that capacity, to present the views of the labor organization to the Secretary and other officials of the Government, including the Congress, or other appropriate authorities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6e5c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4104/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to engage in collective bargaining with respect to conditions of employment through representatives chosen by employees under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id906c6e5d-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s1004"},"text":"Pub. L. 96–465, title I, § 1004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2130"},"text":"94 Stat. 2130","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
