{"tag":"section","attrib":{"id":"id903cab43-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3509"},"text":null,"children":[{"tag":"num","attrib":{"value":"3509"},"text":"§ 3509.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflict of interest; personnel and activities covered","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Members of the Council and Institute Fellows shall avoid any action, in their activities with respect to the Institute, which might result in, or create the appearance of, a conflict of interest, including but not limited to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id903cab44-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3509/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using their office or position for private gain;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903cab45-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3509/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" giving preferential treatment to any person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903cab46-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3509/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making recommendations or decisions relating to any activity authorized by this chapter in other than an impartial and independent manner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903cab47-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3509/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" misusing Government property or official information obtained through their office or position which has not been made available to the general public; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903cab48-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3509/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affecting adversely the confidence of the public in the integrity of the Institute.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id903cab49-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/53/tIV/s409"},"text":"Pub. L. 96–53, title IV, § 409","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-08-14"},"text":"Aug. 14, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/376"},"text":"93 Stat. 376","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id903cab4a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id903cab4b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id903cab4c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in par. (3), was in the original “this title”, meaning title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/53"},"text":"Pub. L. 96–53","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-08-14"},"text":"Aug. 14, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/371"},"text":"93 Stat. 371","children":[],"tail":", which is classified principally to this chapter. For complete classification of title IV to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id903cab4d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id903cab4e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1979-10-01"},"text":"Oct. 1, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/53/s512/a"},"text":"section 512(a) of Pub. L. 96–53","children":[],"tail":", set out as an Effective Date of 1979 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
