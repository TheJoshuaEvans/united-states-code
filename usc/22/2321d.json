{"tag":"section","attrib":{"id":"id8f8c46f7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2321d"},"text":null,"children":[{"tag":"num","attrib":{"value":"2321d"},"text":"§ 2321d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations in furnishing military assistance","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Decisions to furnish military assistance made under subchapter II of this chapter shall take into account whether such assistance will—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f8c46f8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2321d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contribute to an arms race;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f8c46f9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2321d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the possibility of outbreak or escalation of conflict; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f8c46fa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2321d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prejudice the development of bilateral or multilateral arms control arrangements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f8c46fb-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. II, § 511, as added "},{"tag":"ref","attrib":{"href":"/us/pl/92/226"},"text":"Pub. L. 92–226","children":[],"tail":", pt. II, § 201(f), "},{"tag":"date","attrib":{"date":"1972-02-07"},"text":"Feb. 7, 1972","childr