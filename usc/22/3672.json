{"tag":"section","attrib":{"id":"id90416748-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3672"},"text":null,"children":[{"tag":"num","attrib":{"value":"3672"},"text":"§ 3672.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Placement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90416749-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3672/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Citizens separated from employment with Panama Canal Company or Canal Zone Government","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any citizen of the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9041674a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3672/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who, on ","children":[{"tag":"date","attrib":{"date":"1979-03-31"},"text":"March 31, 1979","children":[],"tail":", was an employee of the Panama Canal Company or the Canal Zone Government;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9041674b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3672/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who separates or is scheduled to separate on or after such date for any reason other than misconduct or delinquency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9041674c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3672/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is not placed in another appropriate position in the Government of the United States in the Republic of Panama;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall, upon the employee’s request, be accorded appropriate assistance for placement in vacant positions in the Government of the United States in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9041674d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3672/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Citizens eliminated from employment with Executive agency or Canal Zone Government as a result of implementation of Panama Canal Treaty of 1977","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any citizen of the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9041674e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3672/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who, on ","children":[{"tag":"date","attrib":{"date":"1979-03-31"},"text":"March 31, 1979","children":[],"tail":", was employed in the Canal Zone as an employee of an Executive agency (other than the Panama Canal Company or the Canal Zone Government) or the Smithsonian Institution;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9041674f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3672/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose position is eliminated as the result of the implementation of any provision of the Panama Canal Treaty of 1977 and related agreements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90416750-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3672/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is not appointed to another appropriate position in the Government of the United States in the Republic of Panama;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall, upon the employee’s request, be accorded appropriate assistance for placement in vacant positions in the Government of the United States in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9043d751-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3672/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and administration of program by Office of Personnel Management","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office of Personnel Management shall establish and administer a Government-wide placement program for all eligible employees who request appointment to positions under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9043d752-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3672/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this section shall take effect on ","children":[{"tag":"date","attrib":{"date":"1979-09-27"},"text":"September 27, 1979","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9043d753-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70/tI/s1232"},"text":"Pub. L. 96–70, title I, § 1232","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-27"},"text":"Sept. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/470"},"text":"93 Stat. 470","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
