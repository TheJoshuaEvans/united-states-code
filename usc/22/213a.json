{"tag":"section","attrib":{"id":"id8e8389a6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s213a"},"text":null,"children":[{"tag":"num","attrib":{"value":"213a"},"text":"§ 213a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to designate additional passport acceptance agents","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8e8389a7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s213a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to designate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may designate any person described in subsection (b) that meets such other requirements as the Secretary may prescribe pursuant to regulations to serve as a passport acceptance agent, unless the Secretary withdraws such authorization on a case-by-case basis with respect to a given person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8e8389a8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s213a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized persons","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person described in this subsection is any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8e8389a9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s213a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee of the clerk of any Federal court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e8389aa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s213a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee of the clerk of any State court of record.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e8389ab-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s213a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A postal employee at a United States post office that has been selected to accept passport applications.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e8389ac-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s213a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee of the Department of Defense at a military installation that has been authorized to accept passport applications.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e8389ad-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s213a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee of a Federal department or agency that has been selected to accept passport applications.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e8389ae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s213a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A United States citizen who, as determined by the Secretary, is employed by and provides services through a reputable, established company or institution and is commissioned or appointed as a notary or notary public or otherwise authorized to perform a notarization under the laws of a State, district, or territorial government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e8389af-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s213a/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other person specifically designated by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8e8389b0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s213a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe or revise such regulations as may be necessary to carry out this division.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8e8389b1-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dF/tLXI/s6109"},"text":"Pub. L. 118–31, div. F, title LXI, § 6109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/967"},"text":"137 Stat. 967","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dG/tLXXV/s7507/a"},"text":"Pub. L. 118–159, div. G, title LXXV, § 7507(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2547"},"text":"138 Stat. 2547","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8e8389b2-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8e8389b3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8e8389b4-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This division, referred to in subsec. (c), is div. F of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/963"},"text":"137 Stat. 963","children":[],"tail":", known as the Department of State Authorization Act of 2023. For complete classification of div. F to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8e8389b5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (b)(6), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" added par. (6) and redesignated former par. (6) as (7)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8e8389b6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id8e8389b7-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “Secretary” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s6002"},"text":"section 6002 of Pub. L. 118–31","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
