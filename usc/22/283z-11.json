{"tag":"section","attrib":{"id":"id8eba5153-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–11"},"text":null,"children":[{"tag":"num","attrib":{"value":"283z–11"},"text":"§ 283z–11.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First replenishment of the resources of the Enterprise for the Americas Multilateral Investment Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8eba5154-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–11/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contribution authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8eba5155-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–11/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury may contribute on behalf of the United States $150,000,000 to the first replenishment of the resources of the Enterprise for the Americas Multilateral Investment Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8eba5156-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–11/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subject to appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority provided by paragraph (1) may be exercised only to the extent and in the amounts provided for in advance in appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8eba5157-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–11/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the United States contribution authorized by subsection (a), there are authorized to be appropriated not more than $150,000,000, without fiscal year limitation, for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8eba5158-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/147/s39"},"text":"Pub. L. 86–147, § 39","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/289/dB/tII/s20410"},"text":"Pub. L. 109–289, div. B, title II, § 20410","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/5/s2"},"text":"Pub. L. 110–5, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-02-15"},"text":"Feb. 15, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/25"},"text":"121 Stat. 25","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
