{"tag":"section","attrib":{"id":"id90c6ea44-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6842"},"text":null,"children":[{"tag":"num","attrib":{"value":"6842"},"text":"§ 6842.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification requirement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90c6ea45-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6842/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Prior to the initial obligation or expenditure of funds appropriated pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6841"},"text":"section 6841 of this title","children":[],"tail":", the Secretary of the Treasury shall certify that adequate procedures and standards have been established to ensure accountability for and monitoring of the use of funds contributed to the Trust Fund, including the cost of administering the Trust Fund."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90c6ea46-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6842/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmittal of certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The certification required by subsection (a), and the bases for that certification, shall be submitted by the Secretary of the Treasury to Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90c6ea47-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/264/tI/s142"},"text":"Pub. L. 106–264, title I, § 142","children":[],"tail":", 