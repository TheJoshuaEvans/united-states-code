{"tag":"section","attrib":{"id":"id904166e7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3660"},"text":null,"children":[{"tag":"num","attrib":{"value":"3660"},"text":"§ 3660.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review and adjustment of classifications, grades, and pay level","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"An employee may request at any time that the employee’s agency—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id904166e8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3660/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the classification of the employee’s position or the grade or pay level for the employee’s position, or both; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904166e9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3660/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" revise or adjust that classification, grade or pay level, or both, as the case may be.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The request for review and revision or adjustment shall be submitted and adjudicated in accordance with the regularly established appeals procedures of the agency.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id904166ea-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70/tI/s1220"},"text":"Pub. L. 96–70, title I, § 1220","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-27"},"text":"Sept. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/466"},"text":"93 Stat. 466","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
