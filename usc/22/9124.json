{"tag":"section","attrib":{"id":"id911cd234-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9124"},"text":null,"children":[{"tag":"num","attrib":{"value":"9124"},"text":"§ 9124.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver by the Secretary of State","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id911cd235-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9124/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (b), the Secretary of State may waive the application of any of the actions described in subsections (d) and (e) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9122"},"text":"section 9122 of this title","children":[],"tail":" with respect to a country if the Secretary determines and notifies the appropriate congressional committees that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id911cd236-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9124/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the government of such country—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911cd237-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9124/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has satisfactorily resolved the abduction cases giving rise to the application of any of such actions; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911cd238-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9124/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has ended such country’s pattern of noncompliance; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911cd239-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9124/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the national security interest of the United States requires the exercise of such waiver authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id911cd23a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9124/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional notification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than the date on which the Secretary of State exercises the waiver authority under subsection (a), the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id911cd23b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9124/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the appropriate congressional committees of such waiver; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911cd23c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9124/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide such committees with a detailed justification for such waiver, including an explanation of the steps the noncompliant government has taken—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911cd23d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9124/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to resolve abductions cases; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911cd23e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9124/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to end its pattern of noncompliance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id911cd23f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9124/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication in Federal Register","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (d), the Secretary of State shall ensure that each waiver determination under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id911cd240-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9124/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is published in the Federal Register; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911cd241-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9124/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is posted on the Department of State website.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id911cd242-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9124/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited disclosure of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State may limit the publication of information under subsection (c) in the same manner and to the same extent as the President may limit the publication of findings and determinations described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2414/c"},"text":"section 2414(c) of this title","children":[],"tail":", if the Secretary determines that the publication of such information would be harmful to the national security of the United States and would not further the purposes of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id911cd243-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/150/tII/s204"},"text":"Pub. L. 113–150, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-08-08"},"text":"Aug. 8, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1821"},"text":"128 Stat. 1821","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id911cd244-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id911cd245-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id911cd246-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (d), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/150"},"text":"Pub. L. 113–150","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-08-08"},"text":"Aug. 8, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1807"},"text":"126 Stat. 1807","children":[],"tail":", known as the Sean and David Goldman International Child Abduction Prevention and Return Act of 2014, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s9101"},"text":"section 9101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
