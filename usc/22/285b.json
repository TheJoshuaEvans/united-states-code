{"tag":"section","attrib":{"id":"id8ebcc25c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285b"},"text":null,"children":[{"tag":"num","attrib":{"value":"285b"},"text":"§ 285b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of policies and operations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The policies and operations of the representatives of the United States on the Bank shall be coordinated with other United States policies in such manner as the President shall direct.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ebcc25d-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/369/s4"},"text":"Pub. L. 89–369, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-03-16"},"text":"Mar. 16, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/71"},"text":"80 Stat. 71","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/240/tV/s541/d/2"},"text":"Pub. L. 101–240, title V, § 541(d)(2)","children":[],"tail":", (f)(3), "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2518"},"text":"103 Stat. 2518","children":[],"tail":", 2519.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ebcc25e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ebcc25f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8ebcc260-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/240"},"text":"Pub. L. 101–240","children":[],"tail":" struck out subsec. (a) designation and struck out subsec. (b) which read as follows: “An annual report with respect to United States participation in the Bank shall be submitted to the Congress by such agency or officer as the President shall designate.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
