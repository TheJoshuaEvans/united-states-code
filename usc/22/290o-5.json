{"tag":"section","attrib":{"id":"id8ee55953-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290o–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"290o–5"},"text":"§ 290o–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction and venue of civil actions by or against Bank","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ee55954-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290o–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States district courts shall have original and exclusive jurisdiction of any civil action brought in the United States by or against the Bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ee55955-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290o–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Venue","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1391/b"},"text":"section 1391(b) of title 28","children":[],"tail":", the Bank shall be deemed to be a resident of the judicial district in which the principal office of the Bank in the United States, or its agent appointed for the purpose of accepting service or notice of service, is located."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ee55956-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/c/tVII/s707"},"text":"Pub. L. 104–208, div. A, title I, § 101(c) [title VII, § 707]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-121"},"text":"110 Stat. 3009–121","children":[],"tail":", 3009–180.)"}],"tail":"\n"}],"tail":null}
