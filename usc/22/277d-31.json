{"tag":"section","attrib":{"id":"id8eb0dae5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s277d–31"},"text":null,"children":[{"tag":"num","attrib":{"value":"277d–31"},"text":"§ 277d–31.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"To defray costs that accrue to the United States under the agreement or agreements referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s277d–30"},"text":"section 277d–30 of this title","children":[],"tail":" for the construction, operation, and maintenance of drainage conveyance canal projects, there are authorized to be appropriated to the Department of State for use of the United States Section, International Boundary and Water Commission, United States and Mexico, the following amounts:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8eb0dae6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s277d–31/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not to exceed $690,000 for costs of construction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8eb0dae7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s277d–31/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon completion of construction, not to exceed $25,000 based on estimated calendar year 1976 costs, plus or minus such amounts as may be justified by reason of ordinary fluctuations in operation and maintenance costs involved therein, annually for costs of operation and maintenance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8eb0dae8-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/584/s2"},"text":"Pub. L. 89–584, § 2","childre