{"tag":"section","attrib":{"id":"id90acab4d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6106"},"text":null,"children":[{"tag":"num","attrib":{"value":"6106"},"text":"§ 6106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90acab4e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6106/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “agency of the United States Government” includes any agency of the legislative branch and any court of the judicial branch as well as any agency of the executive branch;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90acab4f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6106/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “agency head” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90acab50-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6106/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the executive branch of Government or an agency of the legislative branch other than the House of Representatives or the Senate, the head of the respective agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90acab51-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6106/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the judicial branch of Government, the chief judge of the respective court;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90acab52-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6106/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the Senate, the President pro tempore, in consultation with the Majority Leader and Minority Leader of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90acab53-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6106/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the House of Representatives, the Speaker of the House, in consultation with the Majority Leader and Minority Leader of the House;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90acab54-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6106/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Center” means the Mansfield Center for Pacific Affairs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90acab55-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6106/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “detailee” means an employee of an agency of the United States Government on assignment or loan to the Mansfield Center for Pacific Affairs without a change of position from the agency by which he or she is employed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90acab56-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tII/s257"},"text":"Pub. L. 103–236, title II, § 257","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/432"},"text":"108 Stat. 432","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
