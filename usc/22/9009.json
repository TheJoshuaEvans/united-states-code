{"tag":"section","attrib":{"id":"id911a621a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9009"},"text":null,"children":[{"tag":"num","attrib":{"value":"9009"},"text":"§ 9009.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Children’s Issues","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id911a621b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9009/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall fill the position of Director of the Office of Children’s Issues of the Department of State (in this section referred to as the “Office”) with an individual of senior rank who can ensure long-term continuity in the management and policy matters of the Office and has a strong background in consular affairs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id911a621c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9009/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Case officer staffing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Effective ","children":[{"tag":"date","attrib":{"date":"2000-04-01"},"text":"April 1, 2000","children":[],"tail":", there shall be assigned to the Office of Children’s Issues of the Department of State a sufficient number of case officers to ensure that the average caseload for each officer does not exceed 75."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id911a621d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9009/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Embassy contact","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall designate in each United States diplomatic mission an employee who shall serve as the point of contact for matters relating to international abductions of children by parents. The Director of the Office shall regularly inform the designated employee of children of United States citizens abducted by parents to that country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id911a621e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9009/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to parents","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id911a621f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9009/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), beginning 6 months after ","children":[{"tag":"date","attrib":{"date":"1999-11-29"},"text":"November 29, 1999","children":[],"tail":", and at least once every 6 months thereafter, the Secretary of State shall report to each parent who has requested assistance regarding an abducted child overseas. Each such report shall include information on the current status of the abducted child’s case and the efforts by the Department of State to resolve the case."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a6220-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9009/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirement in paragraph (1) shall not apply in a case of an abducted child if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911a6221-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9009/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the case has been closed and the Secretary of State has reported the reason the case was closed to the parent who requested assistance; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911a6222-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9009/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the parent seeking assistance requests that such reports not be provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id911a6223-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/7/dA/tII/s201"},"text":"Pub. L. 106–113, div. B, § 1000(a)(7) [div. A, title II, § 201]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–419)."}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id911a6224-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id911a6225-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id911a6226-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Admiral James W. Nance and Meg Donovan Foreign Relations Authorization Act, Fiscal Years 2000 and 2001, and not as part of the International Child Abduction Remedies Act which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11608a"},"text":"section 11608a of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
