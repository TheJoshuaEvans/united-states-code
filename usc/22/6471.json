{"tag":"section","attrib":{"id":"id90bb042d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6471"},"text":null,"children":[{"tag":"num","attrib":{"value":"6471"},"text":"§ 6471.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of Annual Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Annual Report, together with other relevant documentation, shall serve as a resource for immigration judges and consular, refugee, and asylum officers in cases involving claims of persecution on the grounds of religion. Absence of reference by the Annual Report to conditions described by the alien shall not constitute the sole grounds for a denial of the alien’s claim.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id90bb042e-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/292/tVI/s601"},"text":"Pub. L. 105–292, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-27"},"text":"Oct. 27, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2812"},"text":"112 Stat. 2812","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90bb042f-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90bb0430-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id90bb0431-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Immigration and Naturalization Service and Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For abolition of Immigration and Naturalization Service, transfer of functions, and treatment of related references, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1551"},"text":"section 1551 of Title 8","children":[],"tail":", Aliens and Nationality."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
