{"tag":"section","attrib":{"id":"id8f982e7b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"2349cc–1"},"text":"§ 2349cc–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of assistance and funding for cyberspace, digital connectivity, and related technologies (CDT) capacity building activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f982e7c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State is authorized to provide assistance to foreign governments and organizations, including national, regional, and international institutions, on such terms and conditions as the Secretary may determine, in order to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f982e7d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advance a secure and stable cyberspace;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f982e7e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect and expand trusted digital ecosystems and connectivity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f982e7f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" build the cybersecurity capacity of partner countries and organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f982e80-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc–1/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the development of standards and the deployment and use of technology supports and reinforces human rights and democratic values, including through the Digital Connectivity and Cybersecurity Partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f982e81-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Assistance under this section may include programs to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f982e82-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advance the adoption and deployment of secure and trustworthy information and communications technology (ICT) infrastructure and services, including efforts to grow global markets for secure ICT goods and services and promote a more diverse and resilient ICT supply chain;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f982e83-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide technical and capacity building assistance to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8f982e84-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc–1/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote policy and regulatory frameworks that create an enabling environment for digital connectivity and a vibrant digital economy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f982e85-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc–1/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure technologies, including related new and emerging technologies, are developed, deployed, and used in ways that support and reinforce democratic values and human rights;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f982e86-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc–1/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote innovation and competition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f982e87-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc–1/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support digital governance with the development of rights-respecting international norms and standards;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f982e88-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" help countries prepare for, defend against, and respond to malicious cyber activities, including through—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8f982e89-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc–1/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adoption of cybersecurity best practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f982e8a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc–1/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of national strategies to enhance cybersecurity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f982e8b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc–1/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deployment of cybersecurity tools and services to increase the security, strength, and resilience of networks and infrastructure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f982e8c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc–1/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support for the development of cybersecurity watch, warning, response, and recovery capabilities, including through the development of cybersecurity incident response teams;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f982e8d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc–1/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support for collaboration with the Cybersecurity and Infrastructure Security Agency (CISA) and other relevant Federal agencies to enhance cybersecurity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f982e8e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc–1/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs to strengthen allied and partner governments’ capacity to detect, investigate, deter, and prosecute cybercrimes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f982e8f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc–1/b/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs to provide information and resources to diplomats engaging in discussions and negotiations around international law and capacity building measures related to cybersecurity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f982e90-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc–1/b/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" capacity building for cybersecurity partners, including law enforcement and military entities as described in subsection (f);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f982e91-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc–1/b/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs that enhance the ability of relevant stakeholders to act collectively against shared cybersecurity threats;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f982e92-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc–1/b/3/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the advancement of programs in support of the Framework of Responsible State Behavior in Cyberspace; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f982e93-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc–1/b/3/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fortification of deterrence instruments in cyberspace; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f982e94-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc–1/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such ","children":[{"tag":"ref","attrib":{"idref":"fn002140"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002140"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" other purpose and functions as the Secretary of State may designate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f982e95-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibility for policy decisions and justification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State shall be responsible for policy decisions regarding programs under this part, with respect to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f982e96-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether there will be cybersecurity and digital capacity building programs for a foreign country or entity operating in that country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f982e97-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of funds for each foreign country or entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f982e98-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc–1/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the scope and nature of such uses of funding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f982e99-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detailed justification for uses and purposes of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State shall provide, on an annual basis, a detailed justification for the uses and purposes of the amounts provided under this part, including information concerning—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f982e9a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amounts and kinds of grants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f982e9b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amounts and kinds of budgetary support provided, if any; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f982e9c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc–1/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amounts and kinds of project assistance provided for what purpose and with such amounts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f982e9d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance and funding under other authorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority granted under this section to provide assistance or funding for countries and organizations does not preclude the use of funds provided to carry out other authorities also available for such purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f982e9e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc–1/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts appropriated to carry out this part may be used, notwithstanding any other provision of law, to strengthen civilian cybersecurity and information and communications technology capacity, including participation of foreign law enforcement and military personnel in non-military activities, and for contributions to international organizations and international financial institutions of which the United States is a member, provided that such support is essential to enabling civilian and law enforcement of cybersecurity and information and communication technology related activities in their respective countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f982e9f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc–1/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available under this section shall be obligated in accordance with the procedures applicable to reprogramming notifications pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2394–1"},"text":"section 2394–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f982ea0-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. II, § 592, as added "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dF/tLXIII/s6307"},"text":"Pub. L. 118–31, div. F, title LXIII, § 6307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/990"},"text":"137 Stat. 990","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
