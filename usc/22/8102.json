{"tag":"section","attrib":{"id":"id90f6ac8d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8102"},"text":null,"children":[{"tag":"num","attrib":{"value":"8102"},"text":"§ 8102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90f6ac8e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8102/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional protocol","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Additional Protocol”, when used in the singular form, means the Protocol Additional to the Agreement between the United States of America and the International Atomic Energy Agency for the Application of Safeguards in the United States of America, with Annexes, signed at Vienna ","children":[{"tag":"date","attrib":{"date":"1998-06-12"},"text":"June 12, 1998","children":[],"tail":" (T. Doc. 107–7)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f6ac8f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8102/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “appropriate congressional committees” means the Committee on Armed Services, the Committee on Foreign Relations, and the Committee on Appropriations of the Senate and the Committee on Armed Services, the Committee on International Relations, the Committee on Science, and the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f6ac90-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8102/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Complementary access","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “complementary access” means the exercise of the IAEA’s access rights as set forth in Articles 4 to 6 of the Additional Protocol.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f6ac91-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8102/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “executive agency” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s105"},"text":"section 105 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f6ac92-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8102/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “facility” has the meaning set forth in Article 18i. of the Additional Protocol.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f6ac93-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8102/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" IAEA","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “IAEA” means the International Atomic Energy Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f6ac94-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8102/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judge of the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “judge of the United States” means a United States district judge, or a United States magistrate judge appointed under the authority of chapter 43 of title 28.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f6ac95-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8102/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Location","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “location” means any geographic point or area declared or identified by the United States or specified by the International Atomic Energy Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f6ac96-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8102/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nuclear Non-Proliferation Treaty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Nuclear Non-Proliferation Treaty” means the Treaty on the Non-Proliferation of Nuclear Weapons, done at Washington, London, and Moscow ","children":[{"tag":"date","attrib":{"date":"1968-07-01"},"text":"July 1, 1968","children":[],"tail":", and entered into force "},{"tag":"date","attrib":{"date":"1970-03-05"},"text":"March 5, 1970","children":[],"tail":" (21 UST 483)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f6ac97-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8102/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nuclear-weapon State Party and non-nuclear-weapon State Party","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “nuclear-weapon State Party” and “non-nuclear-weapon State Party” have the meanings given such terms in the Nuclear Non-Proliferation Treaty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f6ac98-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8102/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person”, except as otherwise provided, means any individual, corporation, partnership, firm, association, trust, estate, public or private institution, any State or any political subdivision thereof, or any political entity within a State, any foreign government or nation or any agency, instrumentality, or political subdivision of any such government or nation, or other entity located in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f6ac99-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8102/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Site","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “site” has the meaning set forth in Article 18b. of the Additional Protocol.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f6ac9a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8102/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “United States”, when used as a geographic reference, means the several States of the United States, the District of Columbia, and the commonwealths, territories, and possessions of the United States and includes all places under the jurisdiction or control of the United States, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90f6ac9b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8102/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the territorial sea and the overlying airspace;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90f6ac9c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8102/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any civil aircraft of the United States or public aircraft, as such terms are defined in paragraphs (17) and (41), respectively, of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s40102/a"},"text":"section 40102(a) of title 49","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90f6ac9d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8102/13/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any vessel of the United States, as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s70502/b"},"text":"section 70502(b) of title 46","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f6ac9e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8102/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wide-area environmental sampling","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “wide-area environmental sampling” has the meaning set forth in Article 18g. of the Additional Protocol.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90f6ac9f-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/401/tII/s203"},"text":"Pub. L. 109–401, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-18"},"text":"Dec. 18, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2742"},"text":"120 Stat. 2742","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90f6aca0-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90f6aca1-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id90f6aca2-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In par. (13)(C), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s70502/b"},"text":"section 70502(b) of t