{"tag":"section","attrib":{"id":"id8fbbe36e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430f"},"text":null,"children":[{"tag":"num","attrib":{"value":"2430f"},"text":"§ 2430f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enterprise for the Americas Funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fbbe36f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each beneficiary country that enters into an Americas Framework Agreement shall be required to establish an Enterprise for the Americas Fund to receive payments in local currency pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2430e/b/1"},"text":"section 2430e(b)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fbbe370-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Local currencies deposited in an Americas Fund shall not be considered assistance for purposes of any provision of law limiting assistance to a country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fbbe371-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Deposits made in an Americas Fund shall be invested until disbursed. Any return on such investment may be retained by the Americas Fund, without deposit in the Treasury of the United States and without further appropriation by the Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fbbe372-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disbursements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds in an Americas Fund shall be disbursed only pursuant to an Americas Framework Agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fbe5373-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. IV, § 707, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/549/tVI/s602/a"},"text":"Pub. L. 102–549, title VI, § 602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3666"},"text":"106 Stat. 3666","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fbe5374-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8fbe5375-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id8fbe5376-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","