{"tag":"section","attrib":{"id":"id8ebf328d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285n"},"text":null,"children":[{"tag":"num","attrib":{"value":"285n"},"text":"§ 285n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations to provide United States Special Resources","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purpose of providing United States Special Resources to the Bank there is hereby authorized to be appropriated $100,000,000, all of which shall remain available until expended.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ebf328e-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/369/s17"},"text":"Pub. L. 89–369, § 17","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/92/245/s1"},"text":"Pub. L. 92–245, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-03-10"},"text":"Mar. 10, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/58"},"text":"86 Stat. 58","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/93/189/s28"},"text":"Pub. L. 93–189, § 28","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-17"},"text":"Dec. 17, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/732"},"text":"87 Stat. 732","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ebf328f-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ebf3290-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8ebf3291-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1973—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/189"},"text":"Pub. L. 93–189","children":[],"tail":" substituted “$100,000,000” for “$60,000,000 for the fiscal year 1972 and $40,000,000 for the fiscal year 1973”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
