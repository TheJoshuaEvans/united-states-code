rib":{"href":"/us/pl/109/102/tV/s577"},"text":"Pub. L. 109–102, title V, § 577","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-11-14"},"text":"Nov. 14, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2231"},"text":"119 Stat. 2231","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/dD/tV/s588"},"text":"Pub. L. 108–447, div. D, title V, § 588","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3034"},"text":"118 Stat. 3034","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/dD/tV/s525"},"text":"Pub. L. 108–199, div. D, title V, § 525","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/176"},"text":"118 Stat. 176","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/199/dD/tV/s525"},"text":"“Funds appropriated by this and subsequent appropriations Acts to carry out the provisions of part I of the Foreign Assistance Act of 1961 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"22 U.S.C. 2151","children":[],"tail":" et seq.], including funds appropriated under the heading ‘Assistance for Eastern Europe and the Baltic States’, may be made available to employ individuals overseas on a limited appointment basis pursuant to the authority of sections 308 and 309 of the Foreign Service Act of 1980 ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3948"},"text":"22 U.S.C. 3948","children":[],"tail":", 3949]: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That in fiscal years 2004, 2005, and 2006 the authority of this section may be used to hire not more than 85 individuals in each such year.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
