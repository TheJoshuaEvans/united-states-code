{"tag":"section","attrib":{"id":"id904fbe8b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3948"},"text":null,"children":[{"tag":"num","attrib":{"value":"3948"},"text":"§ 3948.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recall and reappointment of career members","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id904fbe8c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3948/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retired career members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever the Secretary determines that the needs of the Service so require, the Secretary may recall any retired career member of the Service for active duty in the same personnel category as that member was serving at the time of retirement. A retired career member may be recalled under this section to any appropriate salary class or rate, except that a retired career member of the Senior Foreign Service may not be recalled to a salary class higher than the one in which the member was serving at the time of retirement unless appointed to such higher class by the President, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id904fbe8d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3948/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Former career members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Former career members of the Service may be reappointed under section 3942(a)(1) or 3943 of this title, without regard to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3946"},"text":"section 3946 of this title","children":[],"tail":", in a salary class which is appropriate in light of the qualifications and experience of the individual being reappointed."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id904fbe8e-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s308"},"text":"Pub. L. 96–465, title I, § 308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2086"},"text":"94 Stat. 2086","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id904fbe8f-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id904fbe90-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id904fbe91-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"USAID Overseas Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/47/dF/tVII/s7065/a"},"text":"Pub. L. 118–47, div. F, title VII, § 7065(a)","children":[],"tail":"–(d), "},{"tag":"date","attrib":{"date":"2024-03-23"},"text":"Mar. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/846"},"text":"138 Stat. 846","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/47/dF/tVII/s7065/a"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Up to $170,000,000 of the funds made available in title III of this Act [title III of div. F of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/47"},"text":"Pub. L. 118–47","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/740"},"text":"138 Stat. 740","children":[],"tail":"] pursuant to or to carry out the provisions of part I of the Foreign Assistance Act of 1961 ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"22 U.S.C. 2151","children":[],"tail":" et seq.], including funds appropriated under the heading ‘Assistance for Europe, Eurasia and Central Asia’, may be used by the United States Agency for International Development to hire and employ individuals in the United States and overseas on a limited appointment basis pursuant to the authority of sections 308 and 309 of the Foreign Service Act of 1980 ("},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3948"},"text":"22 U.S.C. 3948","children":[],"tail":" and 3949)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Restriction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority to hire individuals contained in subsection (a) shall expire on ","children":[{"tag":"date","attrib":{"date":"2025-09-30"},"text":"September 30, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Account Charged","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The account charged for the cost of an individual hired and employed under the authority of this section shall be the account to which the responsibilities of such individual primarily relate: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That funds made available to carry out this section may be transferred to, and merged with, funds appropriated by this Act in title II [title II of div. F of "},{"tag":"ref","attrib":{"href":"/us/pl/118/47"},"text":"Pub. L. 118–47","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/739"},"text":"138 Stat. 739","children":[],"tail":"] under the heading ‘Operating Expenses’."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Foreign Service Limited Extensions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Individuals hired and employed by USAID [United States Agency for International Development], with funds made available in this Act [div. F of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/47"},"text":"Pub. L. 118–47","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/729"},"text":"138 Stat. 729","children":[],"tail":"] or prior Acts making appropriations for the Department of State, foreign operations, and related programs, pursuant to the authority of section 309 of the Foreign Service Act of 1980 ("},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3949"},"text":"22 U.S.C. 3949","children":[],"tail":"), may be extended for a period of up to 4 years notwithstanding the limitation set forth in such section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dK/tVII/s7065/a"},"text":"Pub. L. 117–328, div. K, title VII, § 7065(a)","children":[],"tail":"–(d), "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5086"},"text":"136 Stat. 5086","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dK/tVII/s7065/a"},"text":"Pub. L. 117–103, div. K, title VII, § 7065(a)","children":[],"tail":"–(d), "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/678"},"text":"136 Stat. 678","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dK/tVII/s7064/a"},"text":"Pub. L. 116–260, div. K, title VII, § 7064(a)","children":[],"tail":"–(d), "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1809"},"text":"134 Stat. 1809","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dG/tVII/s7064/a"},"text":"Pub. L. 116–94, div. G, title VII, § 7064(a)","children":[],"tail":"–(d), "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2928"},"text":"133 Stat. 2928","children":[],"tail":", 2929, as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/dB/tXI/s21004"},"text":"Pub. L. 116–136, div. B, title XI, § 21004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/591"},"text":"134 Stat. 591","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/6/dF/tVII/s7057/a"},"tex