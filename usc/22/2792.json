{"tag":"section","attrib":{"id":"id90226ceb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2792"},"text":null,"children":[{"tag":"num","attrib":{"value":"2792"},"text":"§ 2792.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90226cec-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2792/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available under other law for the operations of United States Government agencies carrying out functions under this chapter shall be available for the administrative expenses incurred by such agencies under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90226ced-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2792/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Charges for administrative expenses and official reception and representation expenses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Charges for administrative services calculated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2761/e/1/A"},"text":"section 2761(e)(1)(A) of this title","children":[],"tail":" shall include recovery of administrative expenses and official reception and representation expenses incurred by any department or agency of the United States Government, including any mission or group thereof, in carrying out functions under this chapter when—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90226cee-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2792/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such functions are primarily for the benefit of any foreign country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90226cef-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2792/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such expenses are not directly and fully charged to, and reimbursed from amounts received for, sale of defense services under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2761/a"},"text":"section 2761(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90226cf0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2792/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such expenses are neither salaries of the Armed Forces of the United States nor represent unfunded estimated costs of civilian retirement and other benefits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90226cf1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2792/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on funds used for official reception and representation expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than $86,500 of the funds derived from charges for administrative services pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2761/e/1/A"},"text":"section 2761(e)(1)(A) of this title","children":[],"tail":" may be used each fiscal year for official reception and representation expenses."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90226cf2-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/629"},"text":"Pub. L. 90–629","children":[],"tail":", ch. 4, § 43, "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1327"},"text":"82 Stat. 1327","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/329/tII/s214"},"text":"Pub. L. 94–329, title II, § 214","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-06-30"},"text":"June 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/746"},"text":"90 Stat. 746","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/92/s7/d"},"text":"Pub. L. 95–92, § 7(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-04"},"text":"Aug. 4, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/617"},"text":"91 Stat. 617","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/92/s19/b"},"text":"Pub. L. 96–92, § 19(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-29"},"text":"Oct. 29, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/709"},"text":"93 Stat. 709","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/113/tVII/s734/a/10"},"text":"Pub. L. 97–113, title VII, § 734(a)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1560"},"text":"95 Stat. 1560","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/83/tI/s120"},"text":"Pub. L. 99–83, title I, § 120","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-08"},"text":"Aug. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/204"},"text":"99 Stat. 204","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/165/tIX/s9104/b/1"},"text":"Pub. L. 101–165, title IX, § 9104(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-21"},"text":"Nov. 21, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1152"},"text":"103 Stat. 1152","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/228/dB/tXII/s1203"},"text":"Pub. L. 107–228, div. B, title XII, § 1203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"Sept. 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1427"},"text":"116 Stat. 1427","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90226cf3-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90226cf4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90226cf5-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a) and (b), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/629"},"text":"Pub. L. 90–629","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1321"},"text":"82 Stat. 1321","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2751"},"text":"section 2751 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],