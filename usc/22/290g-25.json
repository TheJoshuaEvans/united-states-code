{"tag":"section","attrib":{"id":"id8ee09ded-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–25"},"text":null,"children":[{"tag":"num","attrib":{"value":"290g–25"},"text":"§ 290g–25.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fifteenth replenishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ee09dee-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–25/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States Governor of the Fund is authorized to contribute on behalf of the United States $513,900,000 to the fifteenth replenishment of the resources of the Fund, subject to obtaining the necessary appropriations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ee09def-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–25/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to pay for the United States contribution provided for in subsection (a), there are authorized to be appropriated, without fiscal year limitation, $513,900,000 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ee09df0-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/302/tII/s226"},"text":"Pub. L. 94–302, title II, § 226","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/dB/tXI/s21012/b/4"},"text":"Pub. L. 116–136, div. B, title XI, § 21012(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/594"},"text":"134 Stat. 594","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
