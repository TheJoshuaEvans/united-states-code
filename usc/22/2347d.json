{"tag":"section","attrib":{"id":"id8f937353-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2347d"},"text":null,"children":[{"tag":"num","attrib":{"value":"2347d"},"text":"§ 2347d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training in maritime skills","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President is encouraged to allocate a portion of the funds made available each fiscal year to carry out this part for use in providing education and training in maritime search and rescue, operation and maintenance of aids to navigation, port security, at-sea law enforcement, international maritime law, and general maritime skills.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f937354-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. II, § 545, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/83/tI/s127/a"},"text":"Pub. L. 99–83, title I, § 127(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-08"},"text":"Aug. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/205"},"text":"99 Stat. 205","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f937355-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f937356-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id8f937357-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sect