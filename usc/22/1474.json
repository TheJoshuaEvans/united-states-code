{"tag":"section","attrib":{"id":"id8f06c36e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1474"},"text":null,"children":[{"tag":"num","attrib":{"value":"1474"},"text":"§ 1474.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional authority of Secretary of State or other Government agency authorized to administer provisions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In carrying out the provisions of this chapter, the Secretary, or any Government agency authorized to administer such provisions, may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f06c36f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1474/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employ, without regard to the civil service and classification laws, aliens within the United States and abroad for service in the United States relating to the translation or narration of colloquial speech in foreign languages or the preparation and production of foreign language programs when suitably qualified United States citizens are not available when job vacancies occur, and aliens so employed abroad may be admitted to the United States, if otherwise qualified, as nonimmigrants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a/15"},"text":"section 1101(a)(15) of title 8","children":[],"tail":" for such time and under such conditions and procedures as may be established by the Director of the United States Information Agency and the Attorney General;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f06c370-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1474/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay travel expenses of aliens employed abroad for service in the United States and their dependents to and from the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f06c371-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1474/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incur expenses for entertainment within the United States within such amounts as may be provided in appropriations Acts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f06c372-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1474/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtain insurance on official motor vehicles operated by the Secretary or such agency in foreign countries, and pay the expenses incident thereto;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f06c373-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1474/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notwithstanding the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2680/k"},"text":"section 2680(k) of title 28","children":[],"tail":", pay tort claims in the manner authorized in the first paragraph of section 2672 of such title, when such claims arise in foreign countries in connection with operations conducted abroad under this chapter;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f06c374-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1474/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employ aliens by contract for services abroad;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f06c375-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1474/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide ice and drinking water abroad;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f06c376-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1474/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay excise taxes on negotiable instruments abroad;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f06c377-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1474/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay to or for individuals, not United States Government employees, participating in activities conducted under this chapter, the costs of emergency medical expenses, preparation and transport to their former homes of the remains of such participants or their dependents who die while away from their homes during such participation, and health and accident insurance premiums for participants or health and accident benefits for participants by means of a program of self-insurance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f06c378-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1474/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rent or lease, for periods not exceeding ten years, offices, buildings, grounds, and living quarters abroad for employees carrying out this chapter, and make payments therefor in advance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f06c379-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1474/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain, improve, and repair properties used for information activities in foreign countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f06c37a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1474/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" furnish fuel and utilities for Government-owned or leased property abroad;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f06c37b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1474/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay travel expenses of employees attending official international conferences, without regard to sections 5701–5708 of title 5, and regulations issued thereunder, but at rates not in excess of comparable allowances approved for such conferences by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f06c37c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1474/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchase uniforms;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f06c37d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1474/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hire passenger motor vehicles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f06c37e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1474/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchase passenger motor vehicles for use abroad, and right-hand drive and security vehicles may be so purchased without regard to any maximum price limitation established by law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f06c37f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1474/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procure services of experts and consultants in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"section 3109 of title 5","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f06c380-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1474/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make advances of funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f06c381-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1474/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5946"},"text":"section 5946 of title 5","children":[],"tail":", pay dues for library membership in organizations which issue publications to members only, or to members at a price lower than to others;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f06c382-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1474/20"},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"(20)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to the availability of appropriated funds, purchase motion picture, radio and television producers’ liability insurance to cover errors and omissions or similar insurance coverage for the protection of interests in intellectual property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f06c383-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1474/21"},"text":null,"children":[{"tag":"num","attrib":{"value":"21"},"text":"(21)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incur expenses authorized by the Foreign Service Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3901"},"text":"22 U.S.C. 3901","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f06c384-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1474/22"},"text":null,"children":[{"tag":"num","attrib":{"value":"22"},"text":"(22)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" furnish living quarters as authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5912"},"text":"section 5912 of title 5","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f06c385-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1474/23"},"text":null,"children":[{"tag":"num","attrib":{"value":"23"},"text":"(23)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide allowances as authorized by sections 5921 through 5928 of title 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f06c386-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-01-27/ch36"},"text":"Jan. 27, 1948, ch. 36","children":[],"tail":", title VIII, § 804, as added "},{"tag":"ref","attrib":{"href":"/us/pl/92/352/tII/s202"},"text":"Pub. L. 92–352, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-07-13"},"text":"July 13, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/493"},"text":"86 Stat. 493","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/350/tII/s203"},"text":"Pub. L. 94–350, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-07-12"},"text":"July 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/830"},"text":"90 Stat. 830","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/60/tII"},"text":"Pub. L. 96–60, title II","children":[],"tail":", §§ 203(b)(2), 204(b), "},{"tag":"date","attrib":{"date":"1979-08-15"},"text":"Aug. 15, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/398"},"text":"93 Stat. 398","children":[],"tail":", 400; "},{"tag":"ref","attrib":{"href":"/us/pl/97/241/tIII"},"text":"Pub. L. 97–241, title III","children":[],"tail":", §§ 303(b), 304(c), (d), "},{"tag":"date","attrib":{"date":"1982-08-24"},"text":"Aug. 24, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/291"},"text":"96 Stat. 291","children":[],"tail":", 293; "},{"tag":"ref","attrib":{"href":"/us/pl/101/246/tII/s207"},"text":"Pub. L. 101–246, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-02-16"},"text":"Feb. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/53"},"text":"104 Stat. 53","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/138/tII"},"text":"Pub. L. 102–138, title II","children":[],"tail":", §§ 204, 205, "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/692"},"text":"105 Stat. 692","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f06c387-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f06c388-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8f06c389-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Foreign Service Act of 1980, referred to in par. (21), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465"},"text":"Pub. L. 96–465","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2071"},"text":"94 Stat. 2071","children":[],"tail":", which is classified principally to chapter 52 (§ 3901 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3901"},"text":"section 3901 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f06c38a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—Par. (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/138/s205"},"text":"Pub. L. 102–138, § 205","children":[],"tail":", amended par. (9) generally. Prior to amendment, par. (9) read as follows: “pay the actual expenses of preparing and transporting to their former homes the remains of persons, not United States Government employees, who may die away from their homes while participating in activities conducted under this chapter;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (21) to (23). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/138/s204"},"text":"Pub. L. 102–138, § 204","children":[],"tail":", added pars. (21) to (23)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/246"},"text":"Pub. L. 101–246","children":[],"tail":" inserted “when job vacancies occur” after “available”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Par. (16). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/241/s304/c"},"text":"Pub. L. 97–241, § 304(c)","children":[],"tail":", inserted “and security” after “right-hand drive”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (20). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/241/s304/d"},"text":"Pub. L. 97–241, § 304(d)","children":[],"tail":", added par. (20)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/60/s203/b/2"},"text":"Pub. L. 96–60, § 203(b)(2)","children":[],"tail":", authorized employment of aliens within the United States, previously covered in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s1471/5"},"text":"section 1471(5) of this title","children":[],"tail":", extended services to include preparation and production of foreign language programs, and eliminated investigation-of-alien-employees requirement."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/60/s204/b/1"},"text":"Pub. L. 96–60, § 204(b)(1)","children":[],"tail":", substituted “ten” for “five” years."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/60/s204/b/3"},"text":"Pub. L. 96–60, § 204(b)(3)","children":[],"tail":", substituted a semicolon for “, when funds are appropriated therefor.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (15) to (19). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/60/s204/b/4"},"text":"Pub. L. 96–60, § 204(b)(4)","children":[],"tail":", added pars. (15) to (19)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Par. (14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/350"},"text":"Pub. L. 94–350","children":[],"tail":" added par. (14)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f06c38b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8f06c38c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1979 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/60"},"text":"Pub. L. 96–60","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1979-10-01"},"text":"Oct. 1, 1979","children":[],"tail":", and applicable only with respect to funds appropriated after "},{"tag":"date","attrib":{"date":"1979-08-15"},"text":"Aug. 15, 1979","children":[],"tail":", where new authorities provide for expenditure of appropriated funds, see "},{"tag":"ref","attrib":{"href":"/us/pl/96/60/s209"},"text":"section 209 of Pub. L. 96–60","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s1471"},"text":"section 1471 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id8f06c38d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Director of the United States Information Agency” substituted for “Director of the International Communication Agency” in par. (1) pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/241/s303/b"},"text":"section 303(b) of Pub. L. 97–241","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s1461"},"text":"section 1461 of this title","children":[],"tail":", which redesignated International Communication Agency, and Director thereof, as United States Information Agency, and Director thereof. United States Information Agency (other than Broadcasting Board of Governors and International Broadcasting Bureau) abolished and functions transferred to Secretary of State, see sections 6531 and 6532 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8f06c38e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authority To Administer Summer Travel and Work Programs","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. B, title XXIV, § 2418, "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-835"},"text":"112 Stat. 2681–835","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/277/dG"},"text":"“The Director of the United States Information Agency is authorized to administer summer travel and work programs without regard to preplacement requirements.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244/tVIII/s846"},"text":"Pub. L. 105–244, title VIII, § 846","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1822"},"text":"112 Stat. 1822","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For abolition of United States Information Agency (other than Broadcasting Board of Governors and International Broadcasting Bureau), transfer of functions, and treatment of references thereto, see sections 6531, 6532, and 6551 of this title.]","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8f06c38f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Employment Authority for Fiscal Years 1994 and 1995","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tII/s223"},"text":"Pub. L. 103–236, title II, § 223","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/422"},"text":"108 Stat. 422","children":[],"tail":", provided that, for fiscal years 1994 and 1995, Director of United States Information Agency could, in carrying out provisions of this chapter, employ individuals or organizations by contract for services to be performed in United States or abroad, who could not, by virtue of such employment, be considered to be employees of United States Government for purposes of any law administered by Office of Personnel Management."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
