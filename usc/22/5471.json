{"tag":"section","attrib":{"id":"id908db24f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5471"},"text":null,"children":[{"tag":"num","attrib":{"value":"5471"},"text":"§ 5471.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on initial steps taken by United States and on Poland’s requirement for agricultural assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id908db250-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5471/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"1989-11-28"},"text":"November 28, 1989","children":[],"tail":", the President shall submit a report to the Congress—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id908db251-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5471/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describing the steps taken by the United States Government pursuant to subchapter I, in particular sections ","children":[{"tag":"ref","attrib":{"idref":"fn002317"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002317"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section”."}],"tail":" 5412(a) and (b) of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908db252-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5471/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing Poland’s requirements for additional agricultural assistance during fiscal year 1990 and its requirements for agricultural assistance during fiscal years 1991 and 1992; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908db253-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5471/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifying how much agricultural assistance the President proposes be provided by the United States to meet those requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id908db254-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5471/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updating assessments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As additional information becomes available, the President shall provide to the Congress revised assessments of Poland’s requirements for agricultural assistance during fiscal years 1991 and 1992, specifying how much agricultural assistance the President proposes be provided by the United States to meet those requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id908db255-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/179/tVII/s701"},"text":"Pub. L. 101–179, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-28"},"text":"Nov. 28, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1320"},"text":"103 Stat. 1320","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id908db256-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id908db257-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[