{"tag":"section","attrib":{"id":"id90f6acae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8121"},"text":null,"children":[{"tag":"num","attrib":{"value":"8121"},"text":"§ 8121.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement for authority to conduct complementary access","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90f6acaf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8121/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No complementary access to any location in the United States shall take place pursuant to the Additional Protocol without the authorization of the United States Government in accordance with the requirements of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90f6acb0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8121/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90f6acb1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8121/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Complementary access to any location in the United States subject to access under the Additional Protocol is authorized in accordance with this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f6acb2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8121/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States representatives","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90f6acb3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8121/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the event of complementary access to a privately owned or operated location, no employee of the Environmental Protection Agency or of the Mine Safety and Health Administration or the Occupational Safety and Health Administration of the Department of Labor may participate in the access.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90f6acb4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8121/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The number of designated United States representatives accompanying IAEA inspectors shall be kept to the minimum necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90f6acb5-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/401/tII/s221"},"text":"Pub. L. 109–401, title II, § 221","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-18"},"text":"Dec. 18, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2744"},"text":"120 Stat. 2744","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
