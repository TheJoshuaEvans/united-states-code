{"tag":"section","attrib":{"id":"id90843b97-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4855"},"text":null,"children":[{"tag":"num","attrib":{"value":"4855"},"text":"§ 4855.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost overruns","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any amount required to complete any capital project described in the Department of State’s Supplemental Diplomatic Security Program, as justified to the Congress for the respective fiscal year, which is in excess of the amount made available for that project pursuant to section 4851(a)(1) or (3) ","children":[{"tag":"ref","attrib":{"idref":"fn002311"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002311"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" shall be treated as a reprogramming of funds under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2706"},"text":"section 2706 of this title","children":[],"tail":" and shall not be available for obligation or expenditure except in compliance with the procedures applicable to such reprogrammings."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id90843b98-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/399/tIV/s405"},"text":"Pub. L. 99–399, title IV, § 405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/865"},"text":"100 Stat. 865","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90843b99-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90843b9a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90843b9b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4851/a/3"},"text":"Section 4851(a)(3) of this title","children":[],"tail":", referred to in text, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s101/c"},"text":"Pub. L. 103–236, title I, § 101(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/388"},"text":"108 Stat. 388","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
