{"tag":"section","attrib":{"id":"id90330ecc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3307"},"text":null,"children":[{"tag":"num","attrib":{"value":"3307"},"text":"§ 3307.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption from taxation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90330ecd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3307/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States, State, or local taxes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Institute, its property, and its income are exempt from all taxation now or hereafter imposed by the United States (except to the extent that ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3310/a/3"},"text":"section 3310(a)(3) of this title","children":[],"tail":" requires the imposition of taxes imposed under chapter 21 of title 26, relating to the Federal Insurance Contributions Act) or by any State or local taxing authority of the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90330ece-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3307/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Charitable contributions; transfers for public, charitable, and religious uses; charitable and similar gifts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of title 26, the Institute shall be treated as an organization described in sections 170(b)(1)(A), 170(c), 2055(a), 2106(a)(2)(A), 2522(a), and 2522(b) of title 26.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90330ecf-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/8/s8"},"text":"Pub. L. 96–8, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-04-10"},"text":"Apr. 10, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/17"},"text":"93 Stat. 17","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90330ed0-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90330ed1-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90330ed2-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Insurance Contributions Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", §§ 3101, 3102, 3111, 3112, 3121 to 3128, "},{"tag":"ref","attrib":{"href":"/us/stat/68A/415"},"text":"68A Stat. 415","children":[],"tail":", which is classified generally to chapter 21 (§ 3101 et seq.) of Title 26, Internal Revenue Code. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s3128"},"text":"section 3128 of Title 26","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90330ed3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted in subsecs. (a) and (b) “Internal Revenue Code of 1986” for “Internal Revenue Code of 1954”, which for purposes of codification was translated as “title 26” thus requiring no change in text."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90330ed4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id90330ed5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective as of ","children":[{"tag":"date","attrib":{"date":"1979-01-01"},"text":"January 1, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/8/s18"},"text":"section 18 of Pub. L. 96–8","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3301"},"text":"section 3301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
