{"tag":"section","attrib":{"id":"id9056e9fb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4006"},"text":null,"children":[{"tag":"num","attrib":{"value":"4006"},"text":"§ 4006.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other bases for promoting or increasing pay","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9056e9fc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4006/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may pursuant to a recommendation of the Foreign Service Grievance Board, an equal employment opportunity appeals examiner, or the Special Counsel of the Merit Systems Protection Board, and shall pursuant to a decision or order of the Merit Systems Protection Board—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9056e9fd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4006/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend to the President a promotion of a member of the Service under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3942/a"},"text":"section 3942(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9056e9fe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4006/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote a member of the Service under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3943"},"text":"section 3943 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9056e9ff-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4006/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grant performance pay to a member of the Senior Foreign Service under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3965/c"},"text":"section 3965(c) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9056ea00-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4006/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grant a within-class salary increase under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3966"},"text":"section 3966 of this title","children":[],"tail":" to a member of the Service who is assigned to a salary class in the Foreign Service Schedule."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9056ea01-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4006/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In implementing subsection (a) of this section and in cases in which the Secretary has exercised the authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4005/b"},"text":"section 4005(b) of this title","children":[],"tail":", the Secretary may, in special circumstances set forth by regulation, make retroactive promotions, grant performance pay, make retroactive within-class salary increases, and recommend retroactive promotions by the President."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9056ea02-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s606"},"text":"Pub. L. 96–465, title I, § 606","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2096"},"text":"94 Stat. 2096","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
