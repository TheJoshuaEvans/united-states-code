{"tag":"section","attrib":{"id":"id8ebf32dc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285y"},"text":null,"children":[{"tag":"num","attrib":{"value":"285y"},"text":"§ 285y.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional contribution to special funds; authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ebf32dd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285y/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ebf32de-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285y/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Governor of the Bank is authorized to contribute on behalf of the United States $520,000,000 to the Asian Development Fund, a special fund of the Bank.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ebf32df-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285y/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any commitment to make the contribution authorized in paragraph (1) shall be made subject to obtaining the necessary appropriations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ebf32e0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285y/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to pay for the United States contribution to the Asian Development Fund provided for in this section, there are authorized to be appropriated, without fiscal year limitation, $520,000,000 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ebf32e1-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/369/s28"},"text":"Pub. L. 89–369, § 28","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/181/tI"},"text":"Pub. L. 98–181, title I","children":[],"tail":" [title X, § 1002], "},{"tag":"date","attrib":{"date":"1983-11-30"},"text":"Nov. 30, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1286"},"text":"97 Stat. 1286","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
