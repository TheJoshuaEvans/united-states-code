{"tag":"section","attrib":{"id":"id9037efe6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3357"},"text":null,"children":[{"tag":"num","attrib":{"value":"3357"},"text":"§ 3357.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and statement of policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9037efe7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3357/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9037efe8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3357/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Advancing peace and stability in the Indo-Pacific has been a central element of United States foreign policy toward the region.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9037efe9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3357/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Government of the People’s Republic of China (PRC), especially since the election of Tsai Ing-Wen in 2016, has conducted a coordinated campaign to weaken Taiwan diplomatically, economically, and militarily in a manner that threatens to erode United States policy and create a fait accompli on questions surrounding Taiwan’s future.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9037efea-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3357/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To secure United States interests and preserve the ability of the people of Taiwan to determine their own future, it is necessary to reinforce Taiwan’s diplomatic, economic, and territorial space.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9037efeb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3357/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of policy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the policy of the United States to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9037efec-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3357/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain the position that peace and stability in the Western Pacific are in the political, security, and economic interests of the United States, and are matters of international concern; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9037efed-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3357/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work with allies and partners to promote peace and stability in the Indo-Pacific and deter military acts or other forms of coercive behavior that would undermine regional stability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9037efee-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLV/s5511"},"text":"Pub. L. 117–263, div. E, title LV, § 5511","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3308"},"text":"136 Stat. 3308","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
