{"tag":"section","attrib":{"id":"id8e9dc863-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–4d"},"text":null,"children":[{"tag":"num","attrib":{"value":"262p–4d"},"text":"§ 262p–4d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initiation of discussions to facilitate financing of human welfare and natural resource programs in sub-Saharan Africa in connection with debt reduction and conversion","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8e9dc864-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–4d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8e9dc865-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–4d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the heavy burden of debt borne by sub-Saharan governments undermines efforts by such governments to finance projects and programs designed to promote charitable, educational, and scientific purposes, including education, human welfare, health, agricultural research and development, and conservation, restoration and enhancement of the natural resource base; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e9dc866-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–4d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the financing of programs to promote such charitable, educational, and scientific purposes should be facilitated in the context of reducing and converting sovereign debt of sub-Saharan governments, as encouraged in the final communique of the June 1988 economic summit conference in Toronto, Canada, through such means as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8e9dc867-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–4d/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" concessional interest rates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8e9dc868-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–4d/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" extended repayment periods; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8e9dc869-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–4d/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" partial or complete write-offs of debt service obligations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8e9dc86a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–4d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initiation of discussions to facilitate financing of human welfare and natural resource programs in sub-Saharan Africa in connection with debt reduction and conversion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall instruct the United States Executive Director of the African Development Bank and the African Development Fund to initiate discussions with the directors of such institutions and propose that such institutions, jointly with the International Bank for Reconstruction and Development, the International Development Association, and the International Finance Corporation, as appropriate, provide advice and assistance to government creditors holding sovereign debt of any sub-Saharan government, and to sub-Saharan governments which desire to finance programs with local currencies obtained through debt reduction and conversion to promote charitable, educational, and scientific (including conservation and restoration of natural resources) purposes, as a condition of reducing or converting such sovereign debt.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8e9dc86b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/118/tXVI/s1609"},"text":"Pub. L. 95–118, title XVI, § 1609","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/461/tV/s555"},"text":"Pub. L. 100–461, title V, § 555","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-01"},"text":"Oct. 1, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2268-36"},"text":"102 Stat. 2268–36","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8e9dc86c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8e9dc86d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8e9dc86e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/118/s1609"},"text":"Section 1609 of Pub. L. 95–118","children":[],"tail":" is based on section 9 of H.R. 4645, One Hundredth Congress, as reported "},{"tag":"date","attrib":{"date":"1988-09-28"},"text":"Sept. 28, 1988","children":[],"tail":", and enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/100/461"},"text":"Pub. L. 100–461","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8e9dc86f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id8e9dc870-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The definitions in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s262p–5"},"text":"section 262p–5 of this title","children":[],"tail":" apply to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
