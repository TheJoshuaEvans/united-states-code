{"tag":"section","attrib":{"id":"id90dc6de9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7301"},"text":null,"children":[{"tag":"num","attrib":{"value":"7301"},"text":"§ 7301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reorganization; duties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90dc6dea-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reorganization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Diplomatic Telecommunications Service Program Office established pursuant to title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/140"},"text":"Public Law 102–140","children":[],"tail":" shall be reorganized in accordance with this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90dc6deb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The duties of the DTS–PO include implementing a program for the establishment and maintenance of a DTS Network capable of providing multiple levels of service to meet the wide-ranging needs of all United States Government departments and agencies operating from diplomatic and consular facilities outside of the United States, including national security needs for secure, reliable, and robust communications capabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90dc6dec-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/567/tIII/s321"},"text":"P