{"tag":"section","attrib":{"id":"id8f1764df-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1644m"},"text":null,"children":[{"tag":"num","attrib":{"value":"1644m"},"text":"§ 1644m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of administrative provisions of subchapter I","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"To the extent they are not inconsistent with the provisions of this subchapter, the following provisions of subchapter I of this chapter shall be applicable to this subchapter: subsections (b), (c), (d), (e), (h), and (j) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s1623"},"text":"section 1623 of this title","children":[],"tail":"; subsections (c), (d), (e), and (f) of "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s1626"},"text":"section 1626 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f1764e0-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-03-10/ch54"},"text":"Mar. 10, 1950, ch. 54","children":[],"tail":", title VI, § 613, as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/542"},"text":"Pub. L. 94–542","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-18"},"text":"Oct. 18, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2512"},"text":"90 Stat. 2512","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
