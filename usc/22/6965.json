{"tag":"section","attrib":{"id":"id90cbcc24-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6965"},"text":null,"children":[{"tag":"num","attrib":{"value":"6965"},"text":"§ 6965.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90cbcc25-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6965/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Frequency of reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than the date that is 1 year after ","children":[{"tag":"date","attrib":{"date":"2000-10-10"},"text":"October 10, 2000","children":[],"tail":", and not later than the end of each 1-year period thereafter, the Task Force shall submit to the Congress a report on the work of the Task Force during the preceding 1-year period."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90cbcc26-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6965/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report under subsection (a) shall set forth, at a minimum—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90cbcc27-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6965/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of allegations of violations of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1307"},"text":"section 1307 of title 19","children":[],"tail":" with respect to products of the Peoples’ "},{"tag":"ref","attrib":{"idref":"fn002358"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002358"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “People’s”."}],"tail":" Republic of China that were investigated during the preceding 1-year period;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90cbcc28-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6965/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of actual violations of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1307"},"text":"section 1307 of title 19","children":[],"tail":" with respect to the products of the People’s Republic of China that were discovered during the preceding 1-year period;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90cbcc29-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6965/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of each attempted entry of products of the People’s Republic of China in violation of such ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1307"},"text":"section 1307 of title 19","children":[],"tail":" discovered during the preceding 1-year period—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90cbcc2a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6965/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identity of the exporter of the goods;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90cbcc2b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6965/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identity of the person or persons who attempted to sell the goods for export; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90cbcc2c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6965/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identity of all parties involved in transshipment of the goods; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90cbcc2d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6965/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Task Force considers useful in monitoring and enforcing compliance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1307"},"text":"section 1307 of title 19","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90cbcc2e-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/286/dB/tV/s505"},"text":"Pub. L. 106–286, div. B, title V, § 505","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-10"},"text":"Oct. 10, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/904"},"text":"114 Stat. 904","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
