{"tag":"section","attrib":{"id":"id8eac1fde-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276e"},"text":null,"children":[{"tag":"num","attrib":{"value":"276e"},"text":"§ 276e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations; disbursements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"An appropriation of $150,000 annually is authorized, $75,000 of which shall be for the House delegation and $75,000 for the Senate delegation, or so much thereof as may be necessary, to assist in meeting the expenses of the United States group of the Canada-United States Interparliamentary group for each fiscal year for which an appropriation is made, the House and Senate portions of such appropriation to be disbursed on vouchers to be approved by the Chairman of the House delegation and the Chairman of the Senate delegation, respectively.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8eac1fdf-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/42/s2"},"text":"Pub. L. 86–42, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-06-11"},"text":"June 11, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/72"},"text":"73 Stat. 72","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/350/tI/s118/a"},"text":"Pub. L. 94–350, title I, § 118(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-07-12"},"text":"July 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/827"},"text":"90 Stat. 827","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tV/s502/a/2"},"text":"Pub. L. 103–236, title V, § 502(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/462"},"text":"108 Stat. 462","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/77/tIV/s408/b/3"},"text":"Pub. L. 107–77, title IV, § 408(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-28"},"text":"Nov. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/791"},"text":"115 Stat. 791","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8eac1fe0-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8eac1fe1-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8eac1fe2-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/77"},"text":"Pub. L. 107–77","children":[],"tail":" substituted “$150,000” for “$70,000” and substituted “$75,000” for “$35,000” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":" substituted “$70,000” for “$50,000” and substituted “$35,000” for “$25,000” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/350"},"text":"Pub. L. 94–350","children":[],"tail":" increased annual appropriations authorization to $50,000 from $30,000 and amount for the House and Senate delegations to $25,000 from $15,000."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8eac1fe3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"chi