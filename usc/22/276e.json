81-837"},"text":"112 Stat. 2681–837","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/77/tIV/s408/a"},"text":"Pub. L. 107–77, title IV, § 408(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-28"},"text":"Nov. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/790"},"text":"115 Stat. 790","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/77/tIV/s408/a"},"text":"“There is hereby appropriated, out of any money in the Treasury not otherwise appropriated, a total of $620,000 for each fiscal year to carry out (in accordance with the respective authorization amounts) ","children":[{"tag":"ref","attrib":{"href":"/us/pl/84/689/s2/2"},"text":"section 2(2) of Public Law 84–689","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s1928b/2"},"text":"22 U.S.C. 1928b(2)","children":[],"tail":"], "},{"tag":"ref","attrib":{"href":"/us/pl/86/42/s2"},"text":"section 2 of Public Law 86–42","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s276e"},"text":"22 U.S.C. 276e","children":[],"tail":"], "},{"tag":"ref","attrib":{"href":"/us/pl/86/420/s2"},"text":"section 2 of Public Law 86–420","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s276i"},"text":"22 U.S.C. 276i","children":[],"tail":"], and section 109(b) and (c) of the Department of State Authorization Act, Fiscal Years 1984 and 1985 [§ 109(b), (c) of "},{"tag":"ref","attrib":{"href":"/us/pl/98/164/tI"},"text":"Pub. L. 98–164, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-11-22"},"text":"Nov. 22, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1019"},"text":"97 Stat. 1019","children":[],"tail":", set out as a note under section 276"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title].. [sic] These funds may be disbursed to each delegation, pursuant to vouchers in accordance with the applicable provisions of law, at any time requested by the Chairman of the delegation after that fiscal year begins.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/77/tIV/s408/a"},"text":"Pub. L. 107–77, title IV, § 408(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-28"},"text":"Nov. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/790"},"text":"115 Stat. 790","children":[],"tail":", which directed the amendment of section 101(a) [title III, § 303] of "},{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":", set out above, by substituting “$620,000” for “$440,000”, was executed by making the substitution for “$350,000” to reflect the probable intent of Congress and the amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s2503/c/1"},"text":"Pub. L. 105–277, § 2503(c)(1)","children":[],"tail":".]"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/459/tIII/s303/c"},"text":"Pub. L. 100–459, title III, § 303(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-01"},"text":"Oct. 1, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2207"},"text":"102 Stat. 2207","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/459/tIII/s303/c"},"text":"“The amendments made by this section [amending section 101(a) [title III, § 303] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":", set out above] shall take effect on "},{"tag":"date","attrib":{"date":"1988-10-01"},"text":"October 1, 1988","children":[],"tail":".”"}],"tail":"\n]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
