{"tag":"section","attrib":{"id":"id90f91d9e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8221"},"text":null,"children":[{"tag":"num","attrib":{"value":"8221"},"text":"§ 8221.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategies, priorities, and annual report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90f91d9f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8221/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expansion of country-specific strategies to promote democracy","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90f91da0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8221/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commendation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Congress commends the Secretary for the ongoing work by the Department to develop country-specific strategies for promoting democracy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f91da1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8221/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expansion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall expand the development of such strategies to all nondemocratic countries and democratic transition countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f91da2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8221/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Briefings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall keep the appropriate congressional committees fully and currently informed as such strategies are developed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90f91da3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8221/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" to (d) Omitted or repealed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90f91da4-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/tXXI/s2121"},"text":"Pub. L. 110–53, title XXI, § 2121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/531"},"text":"121 Stat. 531","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dF/tLXVII/s6707/b/3"},"text":"Pub. L. 118–31, div. F, title LXVII, § 6707(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/1018"},"text":"137 Stat. 1018","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90f91da5-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90f91da6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id90f91da7-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/s2121"},"text":"section 2121 of Pub. L. 110–53","children":[],"tail":". Subsecs. (b) and (d) of "},{"tag":"ref","attrib":{"href":"/us/pl/110/53/s2121"},"text":"section 2121 of Pub. L. 110–53","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/228/s665/c"},"text":"section 665(c) of Pub. L. 107–228","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151n"},"text":"section 2151n of this title","children":[],"tail":". Subsec. (c) of "},{"tag":"ref","attrib":{"href":"/us/pl/110/53/s2121"},"text":"section 2121 of Pub. L. 110–53","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":", see 2023 Amendment note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90f91da8-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" struck out subsec. (c). Text read as follows: “The Annual Report on Advancing Freedom and Democracy shall include, as appropriate—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) United States priorities for the promotion of democracy and the protection of human rights for each nondemocratic country and democratic transition country, developed in consultation with relevant parties in such countries; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) specific actions and activities of chiefs of missions and other United States officials to promote democracy and protect human rights in each such country.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
