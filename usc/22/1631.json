{"tag":"section","attrib":{"id":"id8f103952-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1631"},"text":null,"children":[{"tag":"num","attrib":{"value":"1631"},"text":"§ 1631.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f103953-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1631/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Person” means a natural person, partnership, association, other unincorporated body, corporation, or body politic.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f103954-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1631/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Property” means any property, right, or interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f103955-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1631/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Treaty of peace”, with respect to a country, means the treaty of peace with that country signed at Paris, France, ","children":[{"tag":"date","attrib":{"date":"1947-02-10"},"text":"February 10, 1947","children":[],"tail":", which came into force between that country and the United States on "},{"tag":"date","attrib":{"date":"1947-09-15"},"text":"September 15, 1947","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f103956-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-03-10/ch54"},"text":"Mar. 10, 1950, ch. 54","children":[],"tail":", title II, § 201, as added "},{"tag":"ref","attrib":{"href":"/us/act/1955-08-09/ch645/s3"},"text":"Aug. 9, 1955, ch. 645, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/562"},"text":"69 Stat. 562","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
