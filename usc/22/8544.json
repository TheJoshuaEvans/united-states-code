{"tag":"section","attrib":{"id":"id9105049d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8544"},"text":null,"children":[{"tag":"num","attrib":{"value":"8544"},"text":"§ 8544.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement authority","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of Commerce may designate any employee of the Office of Export Enforcement of the Department of Commerce to conduct activities specified in clauses (i), (ii), and (iii) of section 12(a)(3)(B) of the Export Administration Act of 1979 (50 U.S.C. App. 2411(a)(3)(B)) ","children":[{"tag":"ref","attrib":{"idref":"fn002409"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002409"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" when the employee is carrying out activities to enforce—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id9105049e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8544/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provisions of the Export Administration Act of 1979 (50 U.S.C. App. 2401 et seq.) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" (as in effect pursuant to the International Emergency Economic Powers Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":" et seq.));"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9105049f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8544/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provisions of this subchapter, or any other provision of law relating to export controls, with respect to which the Secretary of Commerce has enforc