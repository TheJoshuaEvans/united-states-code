{"tag":"section","attrib":{"id":"id90c4a117-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6822"},"text":null,"children":[{"tag":"num","attrib":{"value":"6822"},"text":"§ 6822.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant authorities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90c4a118-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6822/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program objectives","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90c4a119-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6822/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the purpose of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6821/b"},"text":"section 6821(b) of this title","children":[],"tail":", the Trust Fund, acting through the Board of Trustees, should provide only grants, including grants for technical assistance to support measures to build local capacity in national and local government, civil society, and the private sector to lead and implement effective and affordable HIV/AIDS prevention, education, treatment and care services, and research and development activities, including access to affordable drugs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90c4a11a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6822/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities supported","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Among the activities the Trust Fund should provide grants for should be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90c4a11b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6822/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs to promote the best practices in prevention, including health education messages that emphasize risk avoidance such as abstinence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90c4a11c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6822/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measures to ensure a safe blood supply;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90c4a11d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6822/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" voluntary HIV/AIDS testing and counseling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90c4a11e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6822/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measures to stop mother-to-child transmission of HIV/AIDS, including through diagnosis of pregnant women, access to cost-effective treatment and counseling, and access to infant formula or other alternatives for infant feeding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90c4a11f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6822/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs to provide for the support and education of AIDS orphans and the families, communities, and institutions most affected by the HIV/AIDS epidemic;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90c4a120-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6822/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measures for the deterrence of gender-based violence and the provision of post-exposure prophylaxis to victims of rape and sexual assault; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90c4a121-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6822/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incentives to promote affordable access to treatments against AIDS and related infections.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90c4a122-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6822/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of program objectives","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the objectives of paragraph (1), the Trust Fund should coordinate its activities with governments, civil society, nongovernmental organizations, the Joint United Nations Program on HIV/AIDS (UNAIDS), the International Partnership Against AIDS in Africa, other international organizations, the private sector, and donor agencies working to combat the HIV/AIDS crisis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90c4a123-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6822/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In providing grants under this section, the Trust Fund should give priority to countries that have the highest HIV/AIDS prevalence rate or are at risk of having a high HIV/AIDS prevalence rate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90c4a124-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6822/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible grant recipients","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Governments and nongovernmental organizations should be eligible to receive grants under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90c4a125-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6822/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Trust Fund should not make grants for the purpose of project development associated with bilateral or multilateral bank loans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90c4a126-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/264/tI/s122"},"text":"Pub. L. 106–264, title I, § 122","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-08-19"},"text":"Aug. 19, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/755"},"text":"114 Stat. 755","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
