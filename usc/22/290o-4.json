{"tag":"section","attrib":{"id":"id8ee55947-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290o–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"290o–4"},"text":"§ 290o–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subscription of stock","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ee55948-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290o–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subscription authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ee55949-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290o–4/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury may subscribe on behalf of the United States to not more than 7,011,270 shares of the capital stock of the Bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ee5594a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290o–4/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effectiveness of subscription commitment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any commitment to make such subscription shall be effective only to such extent or in such amounts as are provided for in advance by appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ee5594b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290o–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For payment by the Secretary of the Treasury of the subscription of the United States for shares described in subsection (a), there are authorized to be appropriated $1,050,007,800 without fiscal year limitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ee5594c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290o–4/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on obligation of appropriated amounts for shares of capital stock","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ee5594d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290o–4/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Paid-in capital stock","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ee5594e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290o–4/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than $105,000,000 of the amounts appropriated pursuant to subsection (b) may be obligated for subscription to shares of paid-in capital stock.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ee5594f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290o–4/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal year 1997","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than $52,500,000 of the amounts appropriated pursuant to subsection (b) for fiscal year 1997 may be obligated for subscription to shares of paid-in capital stock.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ee55950-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290o–4/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Callable capital stock","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than $787,505,852 of the amounts appropriated pursuant to subsection (b) may be obligated for subscription to shares of callable capital stock.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ee55951-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290o–4/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of net income distributions by Bank","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any payment made to the United States by the Bank as a distribution of net income shall be covered into the Treasury as a miscellaneous receipt.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ee55952-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/c/tVII/s706"},"text":"Pub. L. 104–208, div. A, title I, § 101(c) [title VII, § 706]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-121"},"text":"110 Stat. 3009–121","children":[],"tail":", 3009–179.)"}],"tail":"\n"}],"tail":null}
