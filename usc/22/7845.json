{"tag":"section","attrib":{"id":"id90f1f1d9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7845"},"text":null,"children":[{"tag":"num","attrib":{"value":"7845"},"text":"§ 7845.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90f1f1da-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7845/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Immigration and refugee information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2004-10-18"},"text":"October 18, 2004","children":[],"tail":", and every 12 months thereafter through 2022, the Secretary of State and the Secretary of Homeland Security shall submit a joint report to the appropriate congressional committees and the Committees on the Judiciary of the House of Representatives and the Senate on the operation of this subchapter during the previous year, which shall include the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90f1f1db-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7845/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of aliens who are nationals or citizens of North Korea who applied for political asylum and the number who were granted political asylum.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f1f1dc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7845/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of aliens who are nationals or citizens of North Korea who applied for refugee status and the number who were granted refugee status.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f1f1dd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7845/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A detailed description of the measures undertaken by the Secretary of State to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7843"},"text":"section 7843 of this title","children":[],"tail":", including country-specific information with respect to United States efforts to secure the cooperation and permission of the governments of countries in East and Southeast Asia to facilitate United States processing of North Koreans seeking protection as refugees. The information required under this paragraph shall be provided in unclassified form, with a classified annex, if necessary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90f1f1de-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7845/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Countries of particular concern","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall include in each annual report on proposed refugee admission pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1157/d"},"text":"section 1157(d) of title 8","children":[],"tail":", information about specific measures taken to facilitate access to the United States refugee program for individuals who have fled countries of particular concern for violations of religious freedom, identified pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6442/b"},"text":"section 6442(b) of this title","children":[],"tail":". The report shall include, for each country of particular concern, a description of access of the nationals or former habitual residents of that country to a refugee determination on the basis of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90f1f1df-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7845/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" referrals by external agencies to a refugee adjudication;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f1f1e0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7845/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" groups deemed to be of special humanitarian concern to the United States for purposes of refugee resettlement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f1f1e1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7845/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" family links to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90f1f1e2-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/333/tIII/s305"},"text":"Pub. L. 108–333, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-18"},"text":"Oct. 18, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1297"},"text":"118 Stat. 1297","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/346/s11"},"text":"Pub. L. 110–346, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-07"},"text":"Oct. 7, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3942"},"text":"122 Stat. 3942","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/172/s10"},"text":"Pub. L. 112–172, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-16"},"text":"Aug. 16, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1309"},"text":"126 Stat. 1309","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/198/s7/f"},"text":"Pub. L. 115–198, § 7(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-07-20"},"text":"July 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1524"},"text":"132 Stat. 1524","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90f1f1e3-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90f1f1e4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90f1f1e5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/198"},"text":"Pub. L. 115–198","children":[],"tail":" substituted “2022” for “2017” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/172"},"text":"Pub. L. 112–172","children":[],"tail":" substituted “2017” for “2012” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/346/s11/1"},"text":"Pub. L. 110–346, § 11(1)","children":[],"tail":", (2), inserted “and refugee” before “information” in heading, and, in introductory provisions, substituted “through 2012” for “for each of the following 5 years” and “which shall include the following:” for “which shall include—”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/346/s11/3"},"text":"Pub. L. 110–346, § 11(3)","children":[],"tail":"–(5), substituted “The number of aliens” for “the number of aliens” in pars. (1) and (2) and a period for “; and” in par. (1) and added par. (3)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
