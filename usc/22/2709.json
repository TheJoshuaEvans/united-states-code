{"tag":"section","attrib":{"id":"id8ffc46c2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2709"},"text":null,"children":[{"tag":"num","attrib":{"value":"2709"},"text":"§ 2709.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special agents","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ffc46c3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2709/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under such regulations as the Secretary of State, in consultation with Under Secretary of Management, may prescribe, special agents of the Department of State and the Foreign Service may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ffc46c4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2709/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conduct investigations concerning—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ffc46c5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2709/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" illegal passport or visa issuance or use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ffc46c6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2709/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identity theft or document fraud affecting or relating to the programs, functions, or authorities of the Department of State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ffc46c7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2709/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transnational violations of chapter 77 of title 18 in which any part of the offense conduct occurred outside the United States or involved one or more foreign nationals; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ffc46c8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2709/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal offenses committed within the special maritime and territorial jurisdiction of the United States (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s7/9"},"text":"section 7(9) of title 18","children":[],"tail":"), except as such jurisdiction relates to the premises of United States military missions and related residences;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffc46c9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2709/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtain and execute search and arrest warrants, as well as obtain and serve subpoenas and summonses issued under the authority of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffc46ca-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2709/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" protect and perform protective functions directly related to maintaining the security and safety of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ffc46cb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2709/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" heads of a foreign state, official representatives of a foreign government, and other distinguished visitors to the United States, while in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ffc46cc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2709/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of State, Deputy Secretary of State, and official representatives of the United States Government, in the United States or abroad;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ffc46cd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2709/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members of the immediate family of persons described in subparagraph (A) or (B);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ffc46ce-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2709/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign missions (as defined in section 4302(a)(4) ","children":[{"tag":"ref","attrib":{"idref":"fn002201"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002201"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title) and international organizations (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4309/b"},"text":"section 4309(b) of this title","children":[],"tail":"), within the United States;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ffc46cf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2709/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a departing Secretary of State for a period of up to 180 days after the date of termination of that individual’s incumbency as Secretary of State, on the basis of a threat assessment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ffc46d0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2709/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual who has been designated by the President or President-elect to serve as Secretary of State, prior to that individual’s appointment.","children":[{"tag":"ref","attrib":{"idref":"fn002202"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002202"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. The period probably should be a semicolon."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffc46d1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2709/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if designated by the Secretary and qualified, under regulations approved by the Attorney General, for the use of firearms, carry firearms for the purpose of performing the duties authorized by this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffc46d2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2709/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make arrests without warrant for any offense against the United States committed in their presence, or for any felony cognizable under the laws of the United States if they have reasonable grounds to believe that the person to be arrested has committed or is committing such felony.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ffc46d3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2709/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements with Attorney General and Secretary of the Treasury and firearms regulations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ffc46d4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2709/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement with Attorney General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority conferred by paragraphs (1) and (4) of subsection (a) shall be exercised subject to an agreement between the Secretary and the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffc46d5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2709/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement with Attorney General and Secretary of the Treasury","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority conferred by paragraphs (2) and (5) of subsection (a) shall be exercised subject to an agreement among the Secretary, the Attorney General, and the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffc46d6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2709/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Firearms regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall prescribe regulations, which shall be approved by the Attorney General, with respect to the carrying and use of firearms by special agents under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ffc46d7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2709/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secret Service not affected","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in subsection (a)(3) shall be construed to preclude or limit in any way the authority of the United States Secret Service to provide protective services pursuant to section 3056 or 3056A of title 18 at a level commensurate with protective requirements as determined by the United States Secret Service. The Secretary of State, the Attorney General, and the Secretary of the Treasury shall enter into an interagency agreement with respect to their law enforcement functions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ffc46d8-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch841"},"text":"Aug. 1, 1956, ch. 841","children":[],"tail":", title I, § 37, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/93/tI/s125/a"},"text":"Pub. L. 99–93, title I, § 125(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-16"},"text":"Aug. 16, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/415"},"text":"99 Stat. 415","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/246/tI/s113"},"text":"Pub. L. 101–246, title I, § 113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-02-16"},"text":"Feb. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/22"},"text":"104 Stat. 22","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s139/1"},"text":"Pub. L. 103–236, title I, § 139(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/397"},"text":"108 Stat. 397","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/553/s1/a/2/tIV/s406"},"text":"Pub. L. 106–553, § 1(a)(2) [title IV, § 406, formerly § 407]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2762"},"text":"114 Stat. 2762","children":[],"tail":", 2762A–97, renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/4/dA/s213/a/5"},"text":"Pub. L. 106–554, § 1(a)(4) [div. A, § 213(a)(5)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–180; "},{"tag":"ref","attrib":{"href":"/us/pl/107/228/dA/tII/s202/a"},"text":"Pub. L. 107–228, div. A, title II, § 202(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"Sept. 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1362"},"text":"116 Stat. 1362","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/177/tVI/s605/e/2/A"},"text":"Pub. L. 109–177, title VI, § 605(e)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/255"},"text":"120 Stat. 255","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/323/tIV/s408/a"},"text":"Pub. L. 114–323, title IV, § 408(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1930"},"text":"130 Stat. 1930","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dG/tLXXV/s7501/b"},"text":"Pub. L. 118–159, div. G, title LXXV, § 7501(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2544"},"text":"138 Stat. 2544","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dE/tV/s5502"},"text":"Pub. L. 119–60, div. E, title V, § 5502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1600"},"text":"139 Stat. 1600","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ffc46d9-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id8ffc46da-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendment of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s7501/d"},"text":"section 7501(d) of Pub. L. 118–159","children":[],"tail":" and revival of prior provisions, see Termination Date of 2024 Amendment note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ffc46db-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8ffc46dc-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4302"},"text":"Section 4302 of this title","children":[],"tail":", referred to in subsec. (a)(3)(D), was subsequently amended, and section 4302(a)(4) no longer defines the term “foreign mission”. However, such term is defined elsewhere in that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id8ffc46dd-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 37 of act ","children":[{"tag":"date","attrib":{"date":"1956-08-01"},"text":"Aug. 1, 1956","children":[],"tail":", was renumbered section 38 by "},{"tag":"ref","attrib":{"href":"/us/pl/99/93/s125/a"},"text":"section 125(a) of Pub. L. 99–93","children":[],"tail":", and subsequently renumbered, and was set out as a Short Title of 1956 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/138/tI/s111/1"},"text":"Pub. L. 102–138, title I, § 111(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/654"},"text":"105 Stat. 654","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8ffc46de-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" inserted “, in consultation with Under Secretary of Management,” after “Secretary of State”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2024—Subsec. (a)(1)(C), (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s7501/b"},"text":"Pub. L. 118–159, § 7501(b)","children":[],"tail":", (d), temporarily added subpar. (C) and redesignated former subpar. (C) as (D). See Termination Date of 2024 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/323"},"text":"Pub. L. 114–323","children":[],"tail":" amended par. (1) generally. Prior to amendment, par. (1) read as follows: “conduct investigations concerning illegal passport or visa issuance or use;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177"},"text":"Pub. L. 109–177","children":[],"tail":" substituted “section 3056 or 3056A of title 18” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t3/s202"},"text":"section 202 of title 3","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3056"},"text":"section 3056 of title 18","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/228/s202/a/1"},"text":"Pub. L. 107–228, § 202(a)(1)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “for the purpose of conducting such investigations—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) obtain and execute search and arrest warrants,","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) make arrests without warrant for any offense concerning passport or visa issuance or use if the special agent has reasonable grounds to believe that the person has committed or is committing such offense, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) obtain and serve subpoenas and summonses issued under the authority of the United States;”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/228/s202/a/2"},"text":"Pub. L. 107–228, § 202(a)(2)","children":[],"tail":", inserted “or President-elect” after “President”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/228/s202/a/3"},"text":"Pub. L. 107–228, § 202(a)(3)","children":[],"tail":", amended par. (5) generally. Prior to amendment, par. (5) read as follows: “arrest without warrant any person for a violation of section 111, 112, 351, 970, or 1028 of title 18—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) in the case of a felony violation, if the special agent has reasonable grounds to believe that such person—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) has committed or is committing such violation; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) is in or is fleeing from the immediate area of such violation; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) in the case of a felony or misdemeanor violation, if the violation is committed in the presence of the special agent.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/228/s202/b"},"text":"Pub. L. 107–228, § 202(b)","children":[],"tail":", substituted “Agreements with Attorney General and Secretary of the Treasury and firearms regulations” for “Agreement with Attorney General and firearms regulations” in heading, added pars. (1) and (2), struck out former par. (1), which related to agreement with the Attorney General, and redesignated former par. (2) as (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(3)(E), (F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/553"},"text":"Pub. L. 106–553","children":[],"tail":", as renumbered by "},{"tag":"ref","attrib":{"href":"/us/pl/106/554"},"text":"Pub. L. 106–554","children":[],"tail":", added subpars. (E) and (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":" struck out subsec. (d) which read as follows: “The Secretary of State shall transmit the regulations prescribed under this section to the Committee on Foreign Affairs and the Committee on the Judiciary of the House of Representatives and the Committee on Foreign Relations of the Senate not less than 20 days before the date on which such regulations take effect.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/246/s113/1"},"text":"Pub. L. 101–246, § 113(1)","children":[],"tail":", added subpar. (B) and redesignated former subpar. (B) as (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/246/s113/2"},"text":"Pub. L. 101–246, § 113(2)","children":[],"tail":", amended introductory provisions generally, substituting “970, or 1028” for “911, 970, 1001, 1028, 1541, 1542, 1543, 1544, 1545, or 1546”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ffc46df-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"terminationDate","id":"id8ffc46e0-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination Date of 2024 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" to terminate three years after "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", and provisions of law amended by "},{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" to be restored as if such amendment had not been enacted, see "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/s7501/d"},"text":"section 7501(d) of Pub. L. 118–159","children":[],"tail":", set out in a Human Trafficking Authority note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8ffc46e1-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/323/tIV/s408/b"},"text":"Pub. L. 114–323, title IV, § 408(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1930"},"text":"130 Stat. 1930","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/323/tIV/s408/b"},"text":"“Nothing in the amendment made by subsection (a) [amending this section] may be construed to limit the investigative authority of any Federal department or agency other than the Department [of State].”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id8ffc46e2-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of the functions, personnel, assets, and obligations of the United States Secret Service, including the functions of the Secretary of the Treasury relating thereto, to the Secretary of Homeland Security, and for treatment of related references, see sections 381, 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8ffc46e3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Human Trafficking Authority","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dG/tLXXV/s7501"},"text":"Pub. L. 118–159, div. G, title LXXV, § 7501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2544"},"text":"138 Stat. 2544","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/159/dG/tLXXV/s7501"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary [of State] is authorized to investigate transnational violations of chapter 77 of title 18, United States Code, in which part of the offense conduct occurred outside the United States or involved one or more foreign nationals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorities","children":[],"tail":".—"}],"tail":null},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8ffc46e4-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"p","attrib":{},"text":"[Amended this section.]","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than one year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":"], and annually thereafter for 3 years, the Secretary shall submit to the appropriate committees of Congress a report that includes each of the following:"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of relevant cases opened and investigated by the Diplomatic Security Service as a result of the additional authorities granted by the amendments made by this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The percentage of the cases opened and investigated by the Diplomatic Security Service as a result of the additional authorities granted by the amendments made by this section that were referred for further action, including prosecution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of the efficacy of the authorities granted by the amendments made by this section and whether such authorities are sufficient to meaningfully contribute to Department and broader United States Government efforts to prosecute and prevent, where applicable, human trafficking and transnational violations of chapter 77 of title 18, United States Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of whether the resources of the Diplomatic Security Service are sufficient to effectively carry out the objectives of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sunset","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section and the amendments made by subsection (b) shall terminate on the date that is three years after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":"], and the provisions of law amended by such amendments shall be restored as if such amendments had not been enacted."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriate Committees of Congress Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term ‘appropriate committees of Congress’ means—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations, the Committee on Judiciary, and the Committee on Appropriations of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs, the Committee on Judiciary, and the Committee on Appropriations of the House of Representatives.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8ffc46e5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Implementation of Search, Seizure, Service, and Arrest Authority","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/228/dA/tII/s202/c"},"text":"Pub. L. 107–228, div. A, title II, § 202(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"Sept. 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1362"},"text":"116 Stat. 1362","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/228/dA/tII/s202/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The authority conferred by paragraphs (2) and (5) of section 37(a) of the State Department Basic Authorities Act of 1956 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2709/a/2"},"text":"22 U.S.C. 2709(a)(2)","children":[],"tail":", (5)], as amended by subsection (a), may not be exercised until the date on which the Secretary—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submits the agreement required by subsection (b)(2) of section 37 of such Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2709/b/2"},"text":"22 U.S.C. 2709(b)(2)","children":[],"tail":"] to the appropriate congressional committees; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publishes in the Federal Register a notice that the agreement has been submitted in accordance with the requirements of subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority conferred by paragraphs (2) and (5) of subsection (a) of section 37 of the State Department Basic Authorities Act of 1956, as in effect on the day before the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2002-09-30"},"text":"Sept. 30, 2002","children":[],"tail":"], may continue to be exercised until the date on which the notice described in paragraph (1)(B) is published in the Federal Register.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definitions of “Secretary” and “appropriate congressional committees” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/228/s202/c"},"text":"section 202(c) of Pub. L. 107–228","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/228/s3"},"text":"section 3 of Pub. L. 107–228","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
