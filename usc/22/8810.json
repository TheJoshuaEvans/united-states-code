{"tag":"section","attrib":{"id":"id911335a0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8810"},"text":null,"children":[{"tag":"num","attrib":{"value":"8810"},"text":"§ 8810.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability to certain natural gas projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this subtitle or the amendments made by this subtitle shall apply with respect to any activity relating to a project described in subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8783"},"text":"section 8783 of this title","children":[],"tail":" to which the exception under that section applies at the time of the activity."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id911335a1-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tXII/s1254"},"text":"Pub. L. 112–239, div. A, title XII, § 1254","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2018"},"text":"126 Stat. 2018","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id911335a2-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id911335a3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id911335a4-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subtitle, referred to in text, is subtitle D (§§ 1241–1255) of title XII of div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2004"},"text":"126 Stat. 2004","children":[],"tail":", known as the Iran Freedom and Counter-Proliferation Act of 2012, which is classified principally to this chapter. For complete classification of subtitle D to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s8801"},"text":"section 8801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
