{"tag":"section","attrib":{"id":"id90c22fb8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6721"},"text":null,"children":[{"tag":"num","attrib":{"value":"6721"},"text":"§ 6721.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90c22fb9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6721/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subchapter, the terms “challenge inspection”, “plant site”, “plant”, “facility agreement”, “inspection team”, and “requesting state party” have the meanings given those terms in Part I of the Annex on Implementation and Verification of the Chemical Weapons Convention. The term “routine inspection” means an inspection, other than an “initial inspection”, undertaken pursuant to Article VI of the Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90c22fba-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6721/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Judge of the United States” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subchapter, the term “judge of the United States” means a judge or magistrate judge of a district court of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90c22fbb-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dI/tIII/s301"},"text":"Pub. L. 105–277, div. I, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"