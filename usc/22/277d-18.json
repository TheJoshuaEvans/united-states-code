{"tag":"section","attrib":{"id":"id8eb0dab3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s277d–18"},"text":null,"children":[{"tag":"num","attrib":{"value":"277d–18"},"text":"§ 277d–18.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction, operation, and maintenance of works; Bridge of the Americas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8eb0dab4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s277d–18/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States Commissioner is authorized to construct, operate, and maintain all works provided for in said convention and sections 277d–17 to 277d–25 of this title, and to turn over the operation and maintenance of any such works to any Federal agency, or any State, county, municipality, district, or other political subdivision within which such project or works may be in whole or in part situated, upon such terms, conditions, and requirements as the Commissioner may deem appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8eb0dab5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s277d–18/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bridge of the Americas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States Commissioner is authorized to receive payments of money from public or private sources in the United States or Mexico made for the purpose of sharing in the cost of operations, maintenance, and replacement of the Bridge of the Americas which crosses the Rio Grande between El Paso, Texas, and Cd. Juarez, Chihuahua. Notwithstanding any other provision of law, such payments of money shall be credited to any appropriation to the Commission which is currently available. Funds received under this subsection shall be available only for the replacement of such bridge.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8eb0dab6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s277d–18/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advance appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority of subsection (b) may be exercised only to the extent or in such amounts as are provided in advance in appropriation Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8eb0dab7-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/300/s2"},"text":"Pub. L. 88–300, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-04-29"},"text":"Apr. 29, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/184"},"text":"78 Stat. 184","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tIV/s423/a"},"text":"Pub. L. 103–236, title IV, § 423(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/457"},"text":"108 Stat. 457","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/7/dA/tVII/s703"},"text":"Pub. L. 106–113, div. B, § 1000(a)(7) [div. A, title VII, § 703]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–460.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8eb0dab8-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8eb0dab9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8eb0daba-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":" inserted “operations, maintenance, and” after “cost of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":" designated existing provisions as subsec. (a) and added subsecs. (b) and (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
