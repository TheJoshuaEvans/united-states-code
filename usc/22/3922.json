{"tag":"section","attrib":{"id":"id904d4d3a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3922"},"text":null,"children":[{"tag":"num","attrib":{"value":"3922"},"text":"§ 3922.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utilization of Foreign Service personnel system by other agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id904d4d3b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3922/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id904d4d3c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3922/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Broadcasting Board of Governors and the Administrator of the Agency for International Development may utilize the Foreign Service personnel system with respect to their respective agencies in accordance with this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904d4d3d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3922/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Agriculture may utilize the Foreign Service personnel system in accordance with this chapter—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id904d4d3e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3922/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to personnel of the Foreign Agricultural Service, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id904d4d3f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3922/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to other personnel of the Department of Agriculture to the extent the President determines to be necessary in order to enable the Department of Agriculture to carry out functions which require service abroad.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904d4d40-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3922/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Commerce may utilize the Foreign Service personnel system in accordance with this chapter—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id904d4d41-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3922/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the personnel performing functions transferred to the Department of Commerce from the Department of State by Reorganization Plan Numbered 3 of 1979, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id904d4d42-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3922/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to other personnel of the Department of Commerce to the extent the President determines to be necessary in order to enable the Department of Commerce to carry out functions which require service abroad.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904d4d43-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3922/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id904d4d44-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3922/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whenever (and to the extent) the Secretary of State considers it in the best interests of the United States Government, the Secretary of State may authorize the head of any agency or other Government establishment (including any establishment in the legislative or judicial branch) to appoint under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3943"},"text":"section 3943 of this title","children":[],"tail":" individuals described in subparagraph (B) as members of the Service and to utilize the Foreign Service personnel system with respect to such individuals under such regulations as the Secretary of State may prescribe."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id904d4d45-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3922/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The individuals referred to in subparagraph (A) are individuals eligible for employment abroad under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3951/a"},"text":"section 3951(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id904d4d46-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3922/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3921/b"},"text":"section 3921(b) of this title","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id904d4d47-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3922/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agency heads referred to in subsection (a), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904d4d48-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3922/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the head of any other agency (to the extent authority to utilize the Foreign Service personnel system is granted to such agency head under any other chapter),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall in the case of their respective agencies exercise the functions vested in the Secretary by this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id904d4d49-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s202"},"text":"Pub. L. 96–465, title I, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2078"},"text":"94 Stat. 2078","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/241/tIII/s303/b"},"text":"Pub. L. 97–241, title III, § 303(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-08-24"},"text":"Aug. 24, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/291"},"text":"96 Stat. 291","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. A, title XIII, § 1335(k)(1), title XIV, § 1422(b)(4)(A), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-789"},"text":"112 Stat. 2681–789","children":[],"tail":", 2681–793; "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/7/dA/tIII/s332"},"text":"Pub. L. 106–113, div. B, § 1000(a)(7) [div. A, title III, § 332]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–439.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id904d4d4a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id904d4d4b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id904d4d4c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Reorganization Plan Numbered 3 of 1979, referred to in subsec. (a)(3)(A), is Reorg. Plan No. 3 of 1979, 44 F.R. 69273, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/93/1381"},"text":"93 Stat. 1381","children":[],"tail":", which is set out in the Appendix to Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id904d4d4d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":" added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1422/b/4/A"},"text":"Pub. L. 105–277, § 1422(b)(4)(A)","children":[],"tail":", substituted “Administrator of the Agency for International Development” for “Director of the United States International Development Cooperation Agency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1335/k/1"},"text":"Pub. L. 105–277, § 1335(k)(1)","children":[],"tail":", substituted “Broadcasting Board of Governors” for “Director of the United States Information Agency”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id904d4d4e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id904d4d4f-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Broadcasting Board of Governors renamed United States Agency for Global Media pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6204/a/21"},"text":"section 6204(a)(21) of this title","children":[],"tail":". The renaming was effectuated by notice to congressional appropriations committees dated "},{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":", and became effective "},{"tag":"date","attrib":{"date":"2018-08-22"},"text":"Aug. 22, 2018","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Director of the United States Information Agency” substituted for “Director of the International Communication Agency” in subsec. (a)(1), pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/241/s303/b"},"text":"section 303(b) of Pub. L. 97–241","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s1461"},"text":"section 1461 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id904d4d50-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1335/k/1"},"text":"section 1335(k)(1) of Pub. L. 105–277","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1999-10-01"},"text":"Oct. 1, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1301"},"text":"section 1301 of Pub. L. 105–277","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6531"},"text":"section 6531 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1422/b/4"},"text":"section 1422(b)(4) of Pub. L. 105–277","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1999-04-01"},"text":"Apr. 1, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1401"},"text":"section 1401 of Pub. L. 105–277","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6561"},"text":"section 6561 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id904d4d51-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id904d4d52-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Exercise of Certain Functions by Board of the Foreign Service and Board of Examiners for the Foreign Service","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Board of the Foreign Service and the Board of Examiners for the Foreign Service were authorized to exercise with respect to Foreign Service personnel of the Department of Commerce, functions delegated to them by Ex. Ord. No. 11264, set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3930"},"text":"section 3930 of this title","children":[],"tail":", respecting Foreign Service personnel of the Department of State, see section 1–104(c) of Ex. Ord. No. 12188, "},{"tag":"date","attrib":{"date":"1980-01-02"},"text":"Jan. 2, 1980","children":[],"tail":", 45 F.R. 991, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2171"},"text":"section 2171 of Title 19","children":[],"tail":", Customs Duties."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"executiveOrder","id":"id904d4d53-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Ex. Ord. No. 10522. Authority of the Director of the United States Information Agency","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 10522, ","children":[{"tag":"date","attrib":{"date":"1954-03-26"},"text":"Mar. 26, 1954","children":[],"tail":", 19 F.R. 1689, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Section","children":[],"tail":" 1. The Director of the United States Information Agency is hereby authorized to carry out the functions of the Board of the Foreign Service, provided for by the Foreign Service Act of 1946 ("},{"tag":"ref","attrib":{"href":"/us/stat/60/999"},"text":"60 Stat. 999","children":[],"tail":") [this chapter], with respect to personnel appointed or assigned for service in the United States Information Agency under the provisions of such Act, as amended [this chapter]: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That nothing herein contained shall be construed as transferring to the said Director any function of the said Board relating to any Foreign Service Officer."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 2. The Director of the United States Information Agency is hereby authorized to prescribe such regulations and issue such orders and instructions, not inconsistent with law, as may be necessary or desirable for carrying out his functions under section 1 of this order."}],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"Dwight D. Eisenhower.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For abolition of United States Information Agency (other than Broadcasting Board of Governors and International Broadcasting Bureau), transfer of functions, and treatment of references thereto, see sections 6531, 6532, and 6551 of this title.]","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
