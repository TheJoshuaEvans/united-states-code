{"tag":"section","attrib":{"id":"id90489235-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3793"},"text":null,"children":[{"tag":"num","attrib":{"value":"3793"},"text":"§ 3793.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest on investments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90489236-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3793/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Calculation of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of sections 3721 and 3792 of this title, interest shall be computed, at a rate determined by the Secretary of the Treasury, on the investment of the United States in the Panama Canal as shown in the accounts of the Panama Canal Company at the close of business on the day preceding ","children":[{"tag":"date","attrib":{"date":"1979-10-01"},"text":"October 1, 1979","children":[],"tail":", and as adjusted in accordance with subsections (b) and (c) of this section. Capital investment for interest purposes shall not include any interest during construction."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90489237-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3793/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increases and decreases in investment of United States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The investment of the United States described in subsection (a) of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90489238-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3793/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall be increased by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90489239-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3793/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of expenditures from the Panama Canal Revolving Fund,,","children":[{"tag":"ref","attrib":{"idref":"fn002270"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002270"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9048923a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3793/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value of property transferred to the Commission by any other department or agency of the United States, as determined in accordance with subsection (c) of this section; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9048923b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3793/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall be decreased by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9048923c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3793/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the funds deposited in the Panama Canal Revolving Fund,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9048923d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3793/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value of property transferred to the Republic of Panama pursuant to this chapter or any other Act on or after ","children":[{"tag":"date","attrib":{"date":"1979-10-01"},"text":"October 1, 1979","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9048923e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3793/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value of property transferred by the Commission to any other department or agency of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9048923f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3793/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Value of property transferred to Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The value of property transferred to the Commission by any other department or agency of the United States shall be determined by the Director of the Office of Management and Budget. In computing such value, such Director shall give due consideration to the cost and probable earning power of the transferred property, or the usable value to the Commission if clearly less than cost, and shall make adequate provisions for depreciation, obsolescence, and other determinable decreases in value. Insofar as practicable, the value of such transferred property shall exclude any portion of such value properly allocable to national defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90489240-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3793/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment and deposit of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Panama Canal Commission shall pay to the Treasury of the United States interest on the investment of the United States, as determined under this section. Such interest shall be deposited in the general fund of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90489241-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70/tI/s1603"},"text":"Pub. L. 96–70, title I, § 1603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-27"},"text":"Sept. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/490"},"text":"93 Stat. 490","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/195/s1/b"},"text":"Pub. L. 99–195, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1349"},"text":"99 Stat. 1349","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tV/s5425/a"},"text":"Pub. L. 100–203, title V, § 5425(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-274"},"text":"101 Stat. 1330–274","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90489242-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90489243-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90489244-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b)(2)(B), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70"},"text":"Pub. L. 96–70","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-27"},"text":"Sept. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/452"},"text":"93 Stat. 452","children":[],"tail":", known as the Panama Canal Act of 1979, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3601"},"text":"section 3601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90489245-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1987—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/s5425/a/1"},"text":"Pub. L. 100–203, § 5425(a)(1)","children":[],"tail":", substituted “the Panama Canal Revolving Fund,” for “appropriations to the Commission made on or after "},{"tag":"date","attrib":{"date":"1979-10-01"},"text":"October 1, 1979","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/s5425/a/2"},"text":"Pub. L. 100–203, § 5425(a)(2)","children":[],"tail":", substituted “deposited in the Panama Canal Revolving Fund” for “covered into the Panama Canal Commission Fund pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3712"},"text":"section 3712 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/s5425/a/3"},"text":"Pub. L. 100–203, § 5425(a)(3)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/195"},"text":"Pub. L. 99–195","children":[],"tail":" substituted “Panama Canal Commission Fund” for “Treasury”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90489246-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id90489247-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1987 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1988-01-01"},"text":"Jan. 1, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/s5429"},"text":"section 5429 of Pub. L. 100–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3712"},"text":"section 3712 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id90489248-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/195"},"text":"Pub. L. 99–195","children":[],"tail":" applicable only to tolls and other receipts of the Commission deposited in the Treasury on or after "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/195/s2"},"text":"section 2 of Pub. L. 99–195","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3712"},"text":"section 3712 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
