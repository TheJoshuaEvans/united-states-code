{"tag":"section","attrib":{"id":"id8ed97186-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s288c"},"text":null,"children":[{"tag":"num","attrib":{"value":"288c"},"text":"§ 288c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption from property taxes","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"International organizations shall be exempt from all property taxes imposed by, or under the authority of, any Act of Congress, including such Acts as are applicable solely to the District of Columbia or the Territories.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ed97187-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-12-29/ch652"},"text":"Dec. 29, 1945, ch. 652","children":[],"tail":", title I, § 6, "},{"tag":"ref","attrib":{"href":"/us/stat/59/671"},"text":"59 Stat. 671","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
