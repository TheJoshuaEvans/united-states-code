{"tag":"section","attrib":{"id":"id9043d7f2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3714"},"text":null,"children":[{"tag":"num","attrib":{"value":"3714"},"text":"§ 3714.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Borrowing authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9043d7f3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3714/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on amount; issuance of notes and other obligations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Panama Canal Commission may borrow from the Treasury, for any of the purposes of the Commission, not more than $100,000,000 outstanding at any time. For this purpose, the Commission may issue to the Secretary of the Treasury its notes or other obligations—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9043d7f4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3714/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which shall have maturities (of not later than ","children":[{"tag":"date","attrib":{"date":"1999-12-31"},"text":"December 31, 1999","children":[],"tail":") agreed upon by the Commission and the Secretary of the Treasury, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9043d7f5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3714/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which may be redeemable at the option of the Commission before maturity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9043d7f6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3714/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions on use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts borrowed under this section shall not be available for payments to Panama under Article XIII of the Panama Canal Treaty of 1977.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9043d7f7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3714/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on investment interest in Panama Canal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts borrowed under this section shall increase the investment of the United States in the Panama Canal, and repayment of such amounts shall decrease such investment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9043d7f8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3714/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall report to the Congress and to the Office of Management and Budget on each exercise of borrowing authority under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9043d7f9-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70/tI/s1304"},"text":"Pub. L. 96–70, title I, § 1304","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tV/s5424/a"},"text":"Pub. L. 100–203, title V, § 5424(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-273"},"text":"101 Stat. 1330–273","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9043d7fa-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9043d7fb-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id9043d7fc-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1988-01-01"},"text":"Jan. 1, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/s5429"},"text":"section 5429 of Pub. L. 100–203","children":[],"tail":", set out as an Effective Date of 1987 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3712"},"text":"section 3712 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
