{"tag":"section","attrib":{"id":"id8fbe5409-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431d"},"text":null,"children":[{"tag":"num","attrib":{"value":"2431d"},"text":"§ 2431d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction of debt owed to United States as result of concessional loans under this chapter","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fbe540a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to reduce debt","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fbe540b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may reduce the amount owed to the United States (or any agency of the United States) that is outstanding as of ","children":[{"tag":"date","attrib":{"date":"1998-01-01"},"text":"January 1, 1998","children":[],"tail":", as a result of concessional loans made to an eligible country by the United States under subchapter I of this chapter, part IV of subchapter II of this chapter, or predecessor foreign economic assistance legislation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe540c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the cost (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s661a/5"},"text":"section 661a(5) of title 2","children":[],"tail":") for the reduction of any debt pursuant to this section, there are authorized to be appropriated to the President—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fbe540d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431d/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $25,000,000 for fiscal year 1999;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fbe540e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431d/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $75,000,000 for fiscal year 2000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fbe540f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431d/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000,000 for fiscal year 2001.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe5410-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431d/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain prohibitions inapplicable","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fbe5411-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431d/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A reduction of debt pursuant to this section shall not be considered assistance for purposes of any provision of law limiting assistance to a country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fbe5412-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431d/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority of this section may be exercised notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2370/r"},"text":"section 2370(r) of this title","children":[],"tail":" or section 321 of the International Development and Food Assistance Act of 1975."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fbe5413-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of debt reduction","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fbe5414-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any debt reduction pursuant to subsection (a) shall be accomplished at the direction of the Facility by the exchange of a new obligation for obligations of the type referred to in subsection (a) outstanding as of the date specified in subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe5415-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exchange of obligations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fbe5416-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431d/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Facility shall notify the agency primarily responsible for administering subchapter I of this chapter of an agreement entered into under paragraph (1) with an eligible country to exchange a new obligation for outstanding obligations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fbe5417-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431d/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the direction of the Facility, the old obligations that are the subject of the agreement shall be canceled and a new debt obligation for the country shall be established relating to the agreement, and the agency primarily responsible for administering subchapter I of this chapter shall make an adjustment in its accounts to reflect the debt reduction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fbe5418-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional terms and conditions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fbe5419-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The following additional terms and conditions shall apply to the reduction of debt under subsection (a)(1) in the same manner as such terms and conditions apply to the reduction of debt under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2430c/a/1"},"text":"section 2430c(a)(1) of this title","children":[],"tail":":"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fbe541a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431d/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions relating to repayment of principal under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2430d"},"text":"section 2430d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fbe541b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431d/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions relating to interest on new obligations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2430e"},"text":"section 2430e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe541c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to the application of the provisions relating to repayment of principal under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2430d"},"text":"section 2430d of this title","children":[],"tail":" to the reduction of debt under subsection (a)(1) (in accordance with paragraph (1)(A) of this subsection), repayment of principal on a new obligation established under subsection (b) may be made in the local currency of the beneficiary country and deposited in the Conservation Fund of the country in the same manner as the provisions relating to payment of interest on new obligations under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2430e"},"text":"section 2430e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fbe541d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations for fiscal years after fiscal year 2001","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the cost (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s661a/5"},"text":"section 661a(5) of title 2","children":[],"tail":") for the reduction of any debt pursuant to this section or "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2431e"},"text":"section 2431e of this title","children":[],"tail":", there are authorized to be appropriated to the President the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fbe541e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431d/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $50,000,000 for fiscal year 2002.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe541f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431d/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $75,000,000 for fiscal year 2003.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe5420-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431d/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000,000 for fiscal year 2004.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe5421-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431d/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 for fiscal year 2005.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe5422-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431d/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $25,000,000 for fiscal year 2006.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe5423-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431d/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $30,000,000 for fiscal year 2007.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe5424-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431d/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 for fiscal year 2019.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe5425-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431d/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 for fiscal year 2020.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe5426-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431d/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 for fiscal year 2023.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe5427-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431d/d/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 for fiscal year 2024.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe5428-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431d/d/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 for fiscal year 2025.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe5429-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431d/d/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 for fiscal year 2026.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe542a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431d/d/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 for fiscal year 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fbe542b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds to conduct program audits, evaluations, monitoring, and administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts made available to carry out this subchapter for a fiscal year, $300,000 is authorized to be made available to carry out audits, evaluations, monitoring, and administration of programs under this subchapter, including personnel costs associated with such audits, evaluations, monitoring and administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fbe542c-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. V, § 806, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/214/s1"},"text":"Pub. L. 105–214, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-29"},"text":"July 29, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/887"},"text":"112 Stat. 887","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/26/s2/a"},"text":"Pub. L. 107–26, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-08-17"},"text":"Aug. 17, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/206"},"text":"115 Stat. 206","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/323"},"text":"Pub. L. 108–323","children":[],"tail":", §§ 1–3(a), "},{"tag":"date","attrib":{"date":"2004-10-06"},"text":"Oct. 6, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1218"},"text":"118 Stat. 1218","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/440"},"text":"Pub. L. 115–440","children":[],"tail":", §§ 9(b)(2), 11, "},{"tag":"date","attrib":{"date":"2019-01-14"},"text":"Jan. 14, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5584"},"text":"132 Stat. 5584","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLV/s5587"},"text":"Pub. L. 117–263, div. E