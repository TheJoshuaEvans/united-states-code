{"tag":"section","attrib":{"id":"id90c4a0ac-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6762"},"text":null,"children":[{"tag":"num","attrib":{"value":"6762"},"text":"§ 6762.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90c4a0ad-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6762/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The district courts of the United States shall have jurisdiction over civil actions to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90c4a0ae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6762/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restrain any violation of section 6726 or 6745 of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90c4a0af-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6762/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compel the taking of any action required by or under this chapter or the Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90c4a0b0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6762/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil actions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90c4a0b1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6762/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A civil action described in subsection (a) may be brought—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90c4a0b2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6762/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a civil action described in subsection (a)(1), in the United States district court for the judicial district in which any act, omission, or transaction constituting a violation of section 6726 or 6745 of this title occurred or in which the defendant is found or transacts business; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90c4a0b3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6762/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a civil action described in subsection (a)(2), in the United States district court for the judicial district in which the defendant is found or transacts business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90c4a0b4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6762/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service of process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any such civil action process may be served on a defendant wherever the defendant may reside or may be found, whether the defendant resides or may be found within the United States or elsewhere.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90c4a0b5-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dI/tV/s502"},"text":"Pub. L. 105–277, div. I, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-885"},"text":"112 Stat. 2681–885","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90c4a0b6-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90c4a0b7-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90c4a0b8-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a)(2), was in the original “this Act” and was translated as reading “this division”, meaning div. I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-856"},"text":"112 Stat. 2681–856","children":[],"tail":", known as the Chemical Weapons Convention Implementation Act of 1998, to reflect the probable intent of Congress. For complete classification of division I to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6701"},"text":"section 6701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
