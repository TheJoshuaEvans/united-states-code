{"tag":"section","attrib":{"id":"id9043d7c2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3712"},"text":null,"children":[{"tag":"num","attrib":{"value":"3712"},"text":"§ 3712.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Panama Canal Revolving Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9043d7c3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3712/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established in the Treasury of the United States a revolving fund to be known as “Panama Canal Revolving Fund”. The Panama Canal Revolving Fund shall, subject to subsection (b), be available to the Commission to carry out the purposes, functions, and powers authorized by this chapter, including for the following purposes:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9043d7c4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3712/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The hire of passenger motor vehicles and aircraft.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9043d7c5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3712/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Uniforms or allowances therefor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9043d7c6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3712/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Official receptions and representation expenses of the Board, the Secretary of the Commission, and the Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9043d7c7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3712/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The operation of guide services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9043d7c8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3712/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A residence for the Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9043d7c9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3712/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Disbursements by the Administrator for employee and community projects.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9043d7ca-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3712/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The procurement of expert and consultant services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9043d7cb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3712/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Promotional activities, including the preparation, distribution, or use of any kit, pamphlet, booklet, publication, radio, television, film, or other media presentation designed to promote the Panama Canal as a resource of the world shipping industry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9043d7cc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3712/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The purchase and transportation to the Republic of Panama of passenger motor vehicles, including large, heavy-duty vehicles.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9043d7cd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3712/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payment to the Panama Canal Authority, not later than the Canal Transfer Date, of such amount as is computed by the Commission to be the future amount of severance pay to be paid by the Panama Canal Authority to employees whose employment with the Authority is terminated, to the extent that such severance pay is attributable to periods of service performed with the Commission before the Canal Transfer Date (and assuming for purposes of such computation that the Panama Canal Authority, in paying severance pay to terminated employees, will provide for crediting of periods of service with the Commission).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9043d7ce-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3712/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tolls and other receipts into Panama Canal Revolving Fund; restriction on use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9043d7cf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3712/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There shall be deposited in the Panama Canal Revolving Fund, on a continuing basis, toll receipts (other than amounts of toll receipts deposited into the Panama Canal Commission Dissolution Fund under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3714a"},"text":"section 3714a of this title","children":[],"tail":") and all other receipts of the Commission. Except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3713"},"text":"section 3713 of this title","children":[],"tail":", no funds may be obligated or expended by the Commission in any fiscal year unless such obligation or expenditure has been specifically authorized by law."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9043d7d0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3712/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" No funds may be authorized for the use of the Commission, or obligated or expended by the Commission in any fiscal year; in excess of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9043d7d1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3712/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of revenues deposited in the Panama Canal Revolving Fund and the Panama Canal Commission Dissolution Fund during such fiscal year; plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9043d7d2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3712/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of revenues deposited in the Panama Canal Revolving Fund before such fiscal year and remaining unobligated at the beginning of such fiscal year; plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9043d7d3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3712/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the $100,000,000 borrowing authority provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3714"},"text":"section 3714 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Not later than 30 days after the end of each fiscal year, the Secretary of the Treasury shall report to the Congress the amount of revenues deposited in the Panama Canal Revolving Fund during such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9043d7d4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3712/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Commission to make deposits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With the approval of the Secretary of the Treasury, the Commission may deposit amounts in the Panama Canal Revolving Fund in any Federal Reserve bank, any depositary for public funds, or such other place and in such manner as the Commission and the Secretary may agree.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9043d7d5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3712/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs of implementation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9043d7d6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3712/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It is the sense of the Congress that the additional costs resulting from the implementation of the Panama Canal Treaty of 1977 and related agreements should be kept to the absolute minimum level. To this end, the Congress declares appropriated costs of implementation to be borne by the taxpayers over the life of such Treaty should be kept to a level no greater than the March 1979 estimate of those costs ($870,700,000) presented to the Congress by the executive branch during consideration of this chapter by the Congress, less personnel retirement costs of $205,000,000, which were subtracted and charged to tolls, therefore resulting in net taxpayer cost of approximately $665,700,000, plus appropriate adjustments for inflation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9043d7d7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3712/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It is further the sense of the Congress that the actual costs of implementation be consistent with the obligations of the United States to operate the Panama Canal safely and efficiently and keep it secure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9043d7d8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3712/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of Commission and Office of Transition Administration; transfer of Fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9043d7d9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3712/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Panama Canal Commission and the Office of Transition Administration (described in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s3504"},"text":"section 3504 of Public Law 106–65","children":[],"tail":") shall terminate on "},{"tag":"date","attrib":{"date":"2004-10-01"},"text":"October 1, 2004","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9043d7da-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3712/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon termination pursuant to paragraph (1), the Panama Canal Revolving Fund shall be transferred to the General Services Administration (GSA). GSA shall use the amounts in the Fund to make payments of any outstanding liabilities of the Commission, as well as any expenses associated with the termination of the Office of Transition Administration and the Commission. The fund shall be the exclusive source available for payment of any outstanding liabilities of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9043d7db-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70/tI/s1302"},"text":"Pub. L. 96–70, title I, § 1302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-27"},"text":"Sept. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/477"},"text":"93 Stat. 477","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/195/s1/a"},"text":"Pub. L. 99–195, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1349"},"text":"99 Stat. 1349","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tV/s5422/a"},"text":"Pub. L. 100–203, title V, § 5422(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-271"},"text":"101 Stat. 1330–271","children":[],"tail":", 1330–272; "},{"tag":"ref","attrib":{"href":"/us/pl/100/705/s9"},"text":"Pub. L. 100–705, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-19"},"text":"Nov. 19, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4687"},"text":"102 Stat. 4687","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dC/tXXXV/s3521/b/1"},"text":"Pub. L. 102–484, div. C, title XXXV, § 3521(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2657"},"text":"106 Stat. 2657","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dC/tXXXV/s3525"},"text":"Pub. L. 104–106, div. C, title XXXV, § 3525","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/640"},"text":"110 Stat. 640","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dC/tXXXV/s3539"},"text":"Pub. L. 104–201, div. C, title XXXV, § 3539","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2865"},"text":"110 Stat. 2865","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dC/tXXXV/s3528"},"text":"Pub. L. 105–85, div. C, title XXXV, § 3528","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2069"},"text":"111 Stat. 2069","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/309/s121"},"text":"Pub. L. 108–309, § 121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-09-30"},"text":"Sept. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1140"},"text":"118 Stat. 1140","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9043d7dc-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9043d7dd-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9043d7de-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a) and (d)(1), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70"},"text":"Pub. L. 96–70","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-27"},"text":"Sept. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/452"},"text":"93 Stat. 452","children":[],"tail":", known as the Panama Canal Act of 1979 which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3601"},"text":"section 3601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s3504"},"text":"Section 3504 of Public Law 106–65","children":[],"tail":", referred to in subsec. (e)(1), is "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/s3504"},"text":"section 3504 of Pub. L. 106–65","children":[],"tail":", div. C, title XXXV, "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/975"},"text":"113 Stat. 975","children":[],"tail":", which amended "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3714a"},"text":"section 3714a of this title","children":[],"tail":" and enacted provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3714a"},"text":"section 3714a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9043d7df-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/309"},"text":"Pub. L. 108–309","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s3528/b/1"},"text":"Pub. L. 105–85, § 3528(b)(1)","children":[],"tail":", substituted “for the following purposes:” for “for—” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1) to (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s3528/b/2"},"text":"Pub. L. 105–85, § 3528(b)(2)","children":[],"tail":", (3), capitalized initial letter of first word and substituted a period for the semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s3528/b/2"},"text":"Pub. L. 105–85, § 3528(b)(2)","children":[],"tail":", (4), capitalized initial letter of first word and substituted “industry.” for “industry; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s3528/b/2"},"text":"Pub. L. 105–85, § 3528(b)(2)","children":[],"tail":", capitalized initial letter of first word."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s3528/a"},"text":"Pub. L. 105–85, § 3528(a)","children":[],"tail":", added par. (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" amended section generally, reenacting section catchline without change, revising and restating former subsecs. (a)(1), (c), (d), and (f) as subsecs. (a) to (d), and striking out provisions of former subsecs. (a)(2), (b), and (e), which related to termination of the Fund, transfer of funds, and congressional review of Commission budgets."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s3525/1/A"},"text":"Pub. L. 104–106, § 3525(1)(A)","children":[],"tail":", struck out “and subject to paragraph (2)” after “"},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3713"},"text":"section 3713 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s3525/1/B"},"text":"Pub. L. 104–106, § 3525(1)(B)","children":[],"tail":", (C), redesignated par. (3) as (2) and struck out former par. (2) which read as follows: “No funds may be obligated or expended by the Commission in any fiscal year for administrative expenses except to the extent or in such amounts as are provided in appropriations Acts.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s3525/2"},"text":"Pub. L. 104–106, § 3525(2)","children":[],"tail":", added subsec. (e) and struck out former subsec. (e) which read as follows: “The Committee on Appropriations of each House of Congress shall review the annual budget of the Commission, including operations and capital expenditures.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/s3521/b/1/A"},"text":"Pub. L. 102–484, § 3521(b)(1)(A)","children":[],"tail":", inserted “(other than amounts of toll receipts deposited into the Panama Canal Commission Dissolution Fund under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3714a"},"text":"section 3714a of this title","children":[],"tail":")” after “toll receipts”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/s3521/b/1/B"},"text":"Pub. L. 102–484, § 3521(b)(1)(B)","children":[],"tail":", inserted “and the Panama Canal Dissolution Fund” after “Panama Canal Revolving Fund”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/705"},"text":"Pub. L. 100–705","children":[],"tail":" redesignated subsec. (e), relating to costs of implementation, as (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/s5422/b/1"},"text":"Pub. L. 100–203, § 5422(b)(1)","children":[],"tail":", substituted “Panama Canal Revolving Fund” for “Panama Canal Commission Fund” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/s5422/a"},"text":"Pub. L. 100–203, § 5422(a)","children":[],"tail":", added subsecs. (a) to (d) and struck out former subsecs. (a) to (d) which related to termination of Panama Canal Company Fund on "},{"tag":"date","attrib":{"date":"1979-10-01"},"text":"Oct. 1, 1979","children":[],"tail":", subsequent deposit of tolls and other receipts into Panama Canal Commission Fund, restriction on use of funds, and authority of the Commission to enter into contracts, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/s5422/a"},"text":"Pub. L. 100–203, § 5422(a)","children":[],"tail":", added subsec. (e), directing Appropriations Committee of each House to review annual budget of the Commission."}],"tai