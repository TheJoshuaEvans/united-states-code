{"tag":"section","attrib":{"id":"id90f6ad45-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8175"},"text":null,"children":[{"tag":"num","attrib":{"value":"8175"},"text":"§ 8175.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of IAEA notifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President shall notify Congress of any notifications issued by the IAEA to the United States under Article 10 of the Additional Protocol.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id90f6ad46-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/401/tII/s275"},"text":"Pub. L. 109–401, title II, § 275","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-18"},"text":"Dec. 18, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2753"},"text":"120 Stat. 2753","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
