{"tag":"section","attrib":{"id":"id907d0ffc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4705"},"text":null,"children":[{"tag":"num","attrib":{"value":"4705"},"text":"§ 4705.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to enter into agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President may enter into agreements with foreign governments in furtherance of the purposes of this chapter. Such agreements may provide for the creation or continuation of binational or multinational educational and cultural foundations and commissions for the purposes of administering programs under this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id907d0ffd-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/93/tVI/s605"},"text":"Pub. L. 99–93, title VI, § 605","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-16"},"text":"Aug. 16, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/441"},"text":"99 Stat. 441","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
