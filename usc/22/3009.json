{"tag":"section","attrib":{"id":"id902c09cc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3009"},"text":null,"children":[{"tag":"num","attrib":{"value":"3009"},"text":"§ 3009.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Printing and binding costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For purposes of costs relating to printing and binding, including the costs of personnel detailed from the Government Publishing Office, the Commission shall be deemed to be a committee of the Congress.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id902c09cd-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/304/s9"},"text":"Pub. L. 94–304, § 9","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/190/s134"},"text":"Pub. L. 99–190, § 134","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-19"},"text":"Dec. 19, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1322"},"text":"99 Stat. 1322","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/b"},"text":"Pub. L. 113–235, div. H, title I, § 1301(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id902c09ce-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id902c09cf-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName