{"tag":"section","attrib":{"id":"id90010172-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2724"},"text":null,"children":[{"tag":"num","attrib":{"value":"2724"},"text":"§ 2724.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees for commercial services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90010173-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2724/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to charge fee","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90010174-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2724/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (2), the Secretary of State is authorized to charge a fee to cover the actual or estimated cost of providing any person, firm or organization (other than agencies of the United States Government) with commercial services at posts abroad on matters within the authority of the Department of State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90010175-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2724/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority of this section may be exercised only in countries where the Department of Commerce does not perform commercial services for which it collects fees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90010176-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2724/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds collected under the authority of subsection (a) shall be deposited as an offsetting collection to any Department of State appropriation to recover the costs of providing commercial services. Funds deposited under this subsection shall remain available for obligation through September 30 of the fiscal year following the fiscal year in which the funds were deposited.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90010177-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch841"},"text":"Aug. 1, 1956, ch. 841","children":[],"tail":", title I, § 52, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s136"},"text":"Pub. L. 103–236, title I, § 136","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/396"},"text":"108 Stat. 396","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. B, title XXII, § 2204, "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-808"},"text":"112 Stat. 2681–808","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90010178-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90010179-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9001017a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" inserted at end “Funds deposited under this subsection shall remain available for obligation through September 30 of the fiscal year following the fiscal year in which the funds were deposited.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
