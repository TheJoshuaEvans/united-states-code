{"tag":"section","attrib":{"id":"id8f2f32ea-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2083"},"text":null,"children":[{"tag":"num","attrib":{"value":"2083"},"text":"§ 2083.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commissioner for Interama; procurement and appointment of personnel; powers and duties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f2f32eb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2083/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There shall be in the designated department or agency a Commissioner for Interama who shall be appointed by the President. Subject to the direction of the head of the designated department or agency, the Commissioner for Interama shall perform such duties as the President may prescribe to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f2f32ec-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2083/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In order to carry out the provisions of this chapter, the head of the designated department or agency is authorized—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f2f32ed-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2083/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to appoint and fix the compensation of such persons as he deems necessary without regard to the civil service laws and chapter 51 and subchapter III of chapter 53 of title 5; except that no person so appointed shall receive compensation at a rate in excess of that received by persons under chapter 51 and subchapter III of chapter 53 of title 5 for the performance of comparable duties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f2f32ee-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2083/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to procure temporary and intermittent services in accordance with the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"section 3109 of title 5","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f2f32ef-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2083/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enter into contracts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f2f32f0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2083/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to select, purchase, rent, construct, or otherwise acquire exhibits, including materials and equipment therefor, and to provide for the transportation, insurance, display, maintenance, and dismantling thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f2f32f1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2083/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to incur such other expenses as may be necessary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f2f32f2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2083/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to accept donations of money, property, and services and the loan of property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f2f32f3-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/355/s3"},"text":"Pub. L. 89–355, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-02-19"},"text":"Feb. 19, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/6"},"text":"80 Stat. 6","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/83/s10/b"},"text":"Pub. L. 90–83, § 10(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-09-11"},"text":"Sept. 11, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/224"},"text":"81 Stat. 224","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f2f32f4-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f2f32f5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8f2f32f6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (b)(1), (2), “chapter 51 and subchapter III of chapter 53 of title 5” and “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"section 3109 of title 5","children":[],"tail":"” substituted for “the Classification Act of 1949” and “section 15 of the Administrative Expenses Act of 1946 ("},{"tag":"ref","attrib":{"href":"/us/usc/t5/s55a"},"text":"5 U.S.C. 55a","children":[],"tail":")”, respectively, on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s7/b"},"text":"Pub. L. 89–554, § 7(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/631"},"text":"80 Stat. 631","children":[],"tail":", the first section of which enacted Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f2f32f7-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1967—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/83"},"text":"Pub. L. 90–83","children":[],"tail":" struck out provision that Commissioner of Interama receive compensation at a rate prescribed for level IV of the Federal Executive Salary Schedule."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
