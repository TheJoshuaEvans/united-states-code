{"tag":"section","attrib":{"id":"id90bd74e5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6533"},"text":null,"children":[{"tag":"num","attrib":{"value":"6533"},"text":"§ 6533.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Abolition of Office of Inspector General of United States Information Agency and transfer of functions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90bd74e6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6533/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Abolition of Office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office of Inspector General of the United States Information Agency is abolished.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90bd74e7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6533/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" to (d) Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90bd74e8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6533/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are transferred to the Office of the Inspector General of the Department of State and the Foreign Service the functions that the Office of Inspector General of the United States Information Agency exercised before the effective date of this subchapter (including all related functions of the Inspector General of the United Stat