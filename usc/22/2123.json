{"tag":"section","attrib":{"id":"id8f31a387-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2123"},"text":null,"children":[{"tag":"num","attrib":{"value":"2123"},"text":"§ 2123.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Travel Promotion","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f31a388-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2123/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office established","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Department of Commerce an office to be known as the Office of Travel Promotion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f31a389-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2123/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f31a38a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2123/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office shall be headed by a Director who shall be appointed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f31a38b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2123/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall be a citizen of the United States and have experience in a field directly related to the promotion of travel to and within the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f31a38c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2123/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall be responsible for ensuring the office is carrying out its functions effectively and shall report to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f31a38d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2123/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Office shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f31a38e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2123/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as liaison to the Corporation for Travel Promotion established by subsection (b) of section 11 of the Travel Promotion Act of 2009 ","children":[{"tag":"ref","attrib":{"idref":"fn002088"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002088"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and support and encourage the development of programs to increase the number of international visitors to the United States for business, leisure, educational, medical, exchange, and other purposes;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f31a38f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2123/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" work with the Corporation, the Secretary of State and the Secretary of Homeland Security—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8f31a390-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2123/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to disseminate information more effectively to potential international visitors about documentation and procedures required for admission to the United States as a visitor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f31a391-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2123/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that arriving international visitors are generally welcomed with accurate information and in an inviting manner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f31a392-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2123/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to collect accurate data on the total number of international visitors that visit each State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f31a393-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2123/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance the entry and departure experience for international visitors through the use of advertising, signage, and customer service; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f31a394-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2123/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support State, regional, and private sector initiatives to promote travel to and within the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f31a395-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2123/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within a year after ","children":[{"tag":"date","attrib":{"date":"2010-03-04"},"text":"March 4, 2010","children":[],"tail":", and periodically thereafter as appropriate, the Secretary shall transmit a report to the Senate Committee on Commerce, Science, and Transportation, the Senate Committee on Homeland Security and Governmental Affairs, the Senate Committee on Foreign Relations, the House of Representatives Committee on Energy and Commerce, the House of Representatives Committee on Homeland Security, and the House of Representatives Committee on Foreign Affairs describing the Office’s work with the Corporation, the Secretary of State and the Secretary of Homeland Security to carry out subsection (c)(2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f31a396-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/63/tII/s202"},"text":"Pub. L. 87–63, title II, § 202","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/145/s9/i"},"text":"Pub. L. 111–145, § 9(i)","children":[],"tail":", formerly § 9(g), "},{"tag":"date","attrib":{"date":"2010-03-04"},"text":"Mar. 4, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/63"},"text":"124 Stat. 63","children":[],"tail":"; renumbered 9(i), "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dB/tVI/s606/1"},"text":"Pub. L. 113–235, div. B, title VI, § 606(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2219"},"text":"128 Stat. 2219","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f31a397-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f31a398-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8f31a399-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsection (b) of section 11 of the Travel Promotion Act of 2009, referred to in subsec. (c)(1), probably should be a reference to subsection (b) of the Travel Promotion Act of 2009, which is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2131/b"},"text":"section 2131(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id8f31a39a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2123, ","children":[{"tag":"ref","attrib":{"href":"