{"tag":"section","attrib":{"id":"id90522f03-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3966"},"text":null,"children":[{"tag":"num","attrib":{"value":"3966"},"text":"§ 3966.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Within-class salary increases","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90522f04-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3966/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time period; limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any member of the Service receiving a salary under the Foreign Service Schedule shall be advanced to the next higher salary step in the member’s class at the beginning of the first applicable pay period following the completion by that member of a period of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90522f05-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3966/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 52 calendar weeks of service in each of salary steps 1 through 9, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90522f06-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3966/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 104 calendar weeks of service in each of salary steps 10 through 13,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"unless the performance of the member during that period is found in a review by a selection board established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4002"},"text":"section 4002 of this title","children":[],"tail":" to fall below the standards of performance for his or her salary class."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90522f07-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3966/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional increase for meritorious service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may grant, on the basis of especially meritorious service, to any member of the Service receiving an increase in salary under subsection (a), an additional salary increase to any higher step in the salary class in which the member is serving.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90522f08-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s406"},"text":"Pub. L. 96–465, title I, § 406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2089"},"text":"94 Stat. 2089","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
