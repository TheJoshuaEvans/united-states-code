{"tag":"section","attrib":{"id":"id9110eb78-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8792"},"text":null,"children":[{"tag":"num","attrib":{"value":"8792"},"text":"§ 8792.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of sanctions with respect to the transfer of goods or technologies to Syria that are likely to be used to commit human rights abuses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9110eb79-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8792/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall impose sanctions described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8791/c"},"text":"section 8791(c) of this title","children":[],"tail":" with respect to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id9110eb7a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8792/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each person on the list required by subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9110eb7b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8792/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any person that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9110eb7c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8792/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a successor entity to a person on the list;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9110eb7d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8792/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owns or controls a person on the list, if the person that owns or controls the person on the list had actual knowledge or should have known that the person on the list engaged in the activity described in subsection (b)(2) for which the person was included in the list; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9110eb7e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8792/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is owned or controlled by, or under common ownership or control with, the person on the list, if the person owned or controlled by, or under common ownership or control with (as the case may be), the person on the list knowingly engaged in the activity described in subsection (b)(2) for which the person was included in the list.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9110eb7f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8792/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" List","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9110eb80-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8792/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2012-08-10"},"text":"August 10, 2012","children":[],"tail":", the President shall submit to the appropriate congressional committees a list of persons that the President determines have knowingly engaged in an activity described in paragraph (2) on or after "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"August 10, 2012","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9110eb81-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8792/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activity described","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9110eb82-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8792/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person engages in an activity described in this paragraph if the person—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9110eb83-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8792/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfers, or facilitates the transfer of, goods or technologies described in subparagraph (C) to Syria; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9110eb84-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8792/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides services with respect to goods or technologies described in subparagraph (C) after such goods or technologies are transferred to Syria.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9110eb85-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8792/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability to contracts and other agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person engages in an activity described in subparagraph (A) without regard to whether the activity is carried out pursuant to a contract or other agreement entered into before, on, or after ","children":[{"tag":"date","attrib":{"date":"2012-08-10"},"text":"August 10, 2012","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9110eb86-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8792/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goods or technologies described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Goods or technologies described in this subparagraph are goods or technologies that the President determines are likely to be used by the Government of Syria or any of its agencies or instrumentalities to commit human rights abuses against the people of Syria, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9110eb87-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8792/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" firearms or ammunition (as those terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s921"},"text":"section 921 of title 18","children":[],"tail":"), rubber bullets, police batons, pepper or chemical sprays, stun grenades, electroshock weapons, tear gas, water cannons, or surveillance technology; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9110eb88-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8792/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sensitive technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9110eb89-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8792/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sensitive technology defined","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9110eb8a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8792/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subparagraph (C), the term “sensitive technology” means hardware, software, telecommunications equipment, or any other technology, that the President determines is to be used specifically—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id9110eb8b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8792/b/2/D/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to restrict the free flow of unbiased information in Syria; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id9110eb8c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8792/b/2/D/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to disrupt, monitor, or otherwise restrict speech of the people of Syria.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9110eb8d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8792/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “sensitive technology” does not include information or informational materials the exportation of which the President does not have the authority to regulate or prohibit pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1702/b/3"},"text":"section 1702(b)(3) of title 50","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9110eb8e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8792/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule to allow for termination of sanctionable activity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall not be required to include a person on the list required by paragraph (1) if the President certifies in writing to the appropriate congressional committees that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9110eb8f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8792/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person is no longer engaging in, or has taken significant verifiable steps toward stopping, the activity described in paragraph (2) for which the President would otherwise have included the person on the list; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9110eb90-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8792/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President has received reliable assurances that the person will not knowingly engage in any activity described in paragraph (2) in the future.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9110eb91-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8792/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates of list","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall submit to the appropriate congressional committees an updated list under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9110eb92-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8792/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 300 days after ","children":[{"tag":"date","attrib":{"date":"2012-08-10"},"text":"August 10, 2012","children":[],"tail":", and every 180 days thereafter; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9110eb93-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8792/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as new information becomes available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9110eb94-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8792/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of report; public availability","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9110eb95-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8792/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The list required by paragraph (1) shall be submitted in unclassified form but may contain a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9110eb96-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8792/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The unclassified portion of the list required by paragraph (1) shall be made available to the public and posted on the websites of the Department of the Treasury and the Department of State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9110eb97-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/158/tVII/s703"},"text":"Pub. L. 112–158, title VII, § 703","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1266"},"text":"126 Stat. 1266","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9110eb98-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id9110eb99-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8795"},"text":"section 8795 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
