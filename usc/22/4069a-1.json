{"tag":"section","attrib":{"id":"id9065421b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069a–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"4069a–1"},"text":"§ 4069a–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retirement benefits for certain former spouses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9065421c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069a–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility; percentage of benefits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any individual who was a former spouse of a participant or former participant on ","children":[{"tag":"date","attrib":{"date":"1981-02-14"},"text":"February 14, 1981","children":[],"tail":", shall be entitled, to the extent of available appropriations, and except to the extent such former spouse is disqualified under subsection (b), to benefits—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id9065421d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069a–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if married to the participant throughout the creditable service of the participant, equal to 50 percent of the benefits of the participant; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9065421e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069a–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if not married to the participant throughout such creditable service, equal to that former spouse’s pro rata share of 50 percent of such benefits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9065421f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069a–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disqualification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A former spouse shall not be entitled to benefits under this section if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90654220-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069a–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the former spouse remarries before age 55; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90654221-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069a–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the former spouse was not married to the participant at least 10 years during service of the participant which is creditable under this subchapter with at least 5 years occurring while the participant was a member of the Foreign Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90654222-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069a–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of entitlement; construction with other provisions; application approval and payment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90654223-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069a–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The entitlement of a former spouse to benefits under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90654224-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069a–1/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall commence on the later of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90654225-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069a–1/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the day the participant upon whose service the benefits are based becomes entitled to benefits under this subchapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90654226-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069a–1/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first day of the month in which the divorce or annulment involved becomes final; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90654227-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069a–1/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall terminate on the earlier of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90654228-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069a–1/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the last day of the month before the former spouse dies or remarries before 55 years of age; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90654229-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069a–1/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of the benefits of the participant terminates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9065422a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069a–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding paragraph (1), in the case of any former spouse of a disability annuitant—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9065422b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069a–1/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the benefits of the former spouse shall commence on the date the participant would qualify on the basis of his or her creditable service for benefits under this subchapter (other than a disability annuity) or the date the disability annuity begins, whichever is later, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9065422c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069a–1/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of benefits of the former spouse shall be calculated on the basis of benefits for which the participant would otherwise so qualify.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9065422d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069a–1/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Benefits under this section shall be treated the same as an annuity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4054/a/7"},"text":"section 4054(a)(7) of this title","children":[],"tail":" for purposes of "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4046/h"},"text":"section 4046(h) of this title","children":[],"tail":" or any comparable provision of law."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9065422e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069a–1/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9065422f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069a–1/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Benefits under this section shall not be payable unless appropriate written application is provided to the Secretary, complete with any supporting documentation which the Secretary may by regulation require, within 30 months after the effective date of this section. The Secretary may waive the 30-month application requirement under this subparagraph in any case in which the Secretary determines that the circumstances so warrant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90654230-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069a–1/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon approval of an application provided under subparagraph (A), the appropriate benefits shall be payable to the former spouse with respect to all periods before such approval during which the former spouse was entitled to such benefits under this section, but in no event shall benefits be payable under this section with respect to any period before the effective date of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90654231-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069a–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Benefits” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of this section, the term “benefits” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90654232-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069a–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a participant or former participant subject to this part, the annuity of the participant or former participant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90654233-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069a–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a participant or former participant subject to part II, the benefits of the participant or former participant under that part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90654234-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069a–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of section on annuity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to impair, reduce, or otherwise affect the annuity or the entitlement to an annuity of a participant or former participant under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90654235-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s831"},"text":"Pub. L. 96–465, title I, § 831","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/238/tII/s204/a"},"text":"Pub. L. 100–238, title II, § 204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-08"},"text":"Jan. 8, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1770"},"text":"101 Stat. 1770","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90654236-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90654237-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90654238-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For the effective date of this section, referred to in subsec. (c)(4), see Effective Date note set out below.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id90654239-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 831 of the Foreign Service Act of 1980 was enacted by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/204"},"text":"Pub. L. 100–204","children":[],"tail":" and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4069b"},"text":"section 4069b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9065423a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id9065423b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days after ","children":[{"tag":"date","attrib":{"date":"1988-01-08"},"text":"Jan. 8, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/238/s261/a"},"text":"section 261(a) of Pub. L. 100–238","children":[],"tail":", set out as an Effective Date of 1988 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4054"},"text":"section 4054 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
