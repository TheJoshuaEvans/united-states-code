l":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f63b073-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1985—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/83"},"text":"Pub. L. 99–83","children":[],"tail":" substituted “1988” for “1986”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":" struck out “in Latin America,” after “economic development of less-developed countries” and “in not more than six Latin American countries” after “establish pilot programs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":" struck out “in not more than five Latin American countries” after “nonprofit development organizations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":" substituted “1986” for “1983”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/438"},"text":"Pub. L. 97–438","children":[],"tail":" substituted “1983” for “1982”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/53/s112/b/1"},"text":"Pub. L. 96–53, § 112(b)(1)","children":[],"tail":", substituted “six” for “five”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/53/s112/b/2"},"text":"Pub. L. 96–53, § 112(b)(2)","children":[],"tail":", substituted “$20,000,000” for “$15,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/53/s112/b/3"},"text":"Pub. L. 96–53, § 112(b)(3)","children":[],"tail":", substituted “through "},{"tag":"date","attrib":{"date":"1982-09-30"},"text":"September 30, 1982","children":[],"tail":"” for “until "},{"tag":"date","attrib":{"date":"1979-09-30"},"text":"September 30, 1979","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/424/s115/b"},"text":"Pub. L. 95–424, § 115(b)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"1979-09-30"},"text":"September 30, 1979","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1978-09-30"},"text":"September 30, 1978","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/424/s502/d/1"},"text":"Pub. L. 95–424, § 502(d)(1)","children":[],"tail":", struck out subsec. (j) relating to a Presidential report to Congress on the results of the program established under this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/88"},"text":"Pub. L. 95–88","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1978-09-30"},"text":"September 30, 1978","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1977-12-31"},"text":"December 31, 1977","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f63b074-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8f63b075-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References to Subchapter I Deemed To Include Certain Parts of Subchapter II","children":[],"tail":null},{"tag":"p","attrib":{},"text":"References to subchapter I of this chapter are deemed to include parts IV (§ 2346 et seq.), VI (§ 2348 et seq.), and VIII (§ 2349aa et seq.) of subchapter II of this chapter, and references to subchapter II are deemed to exclude such parts. See ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/226/s202/b"},"text":"section 202(b) of Pub. L. 92–226","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2346"},"text":"section 2346 of this title","children":[],"tail":", and sections 2348c and 2349aa–5 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8f63b076-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/83"},"text":"Pub. L. 99–83","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1985-10-01"},"text":"Oct. 1, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/83/s1301"},"text":"section 1301 of Pub. L. 99–83","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151–1"},"text":"section 2151–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8f63b077-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1979 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/53"},"text":"Pub. L. 96–53","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1979-10-01"},"text":"Oct. 1, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/53/s512/a"},"text":"section 512(a) of Pub. L. 96–53","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8f63b078-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/424"},"text":"Pub. L. 95–424","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1978-10-01"},"text":"Oct. 1, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/424/s605"},"text":"section 605 of Pub. L. 95–424","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id8f63b079-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions, personnel, assets, and liabilities of the Overseas Private Investment Corporation and of non-Development Credit Authority guaranty programs of the United States Agency for International Development to the United States International Development Finance Corporation and treatment of related references, see sections 9683 and 9686(d) of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
