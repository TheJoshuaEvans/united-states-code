{"tag":"section","attrib":{"id":"id8eb595f6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s280i"},"text":null,"children":[{"tag":"num","attrib":{"value":"280i"},"text":"§ 280i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"There is hereby authorized to be appropriated to the Department of State, out of any money in the Treasury not otherwise appropriated—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8eb595f7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s280i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than $142,000 annually for the payment by the United States of its proportionate share of the expenses of the Commission and its auxiliary and subsidiary bodies, pursuant to article XV of the “agreement for the Establishment of the Caribbean Commission”; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8eb595f8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s280i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such additional sums as may be needed for the payment of all necessary expenses incident to participation by the United States in the activities of the Commission, including salaries of the United States Commissioners, their alternates, appropriate staff, without regard to the civil-service laws, and chapter 51 and subchapter III of chapter 53 of title 5; personal services in the District of Columbia; services as authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"section 3109 of title 5","children":[],"tail":"; hire of passenger motor vehicles and other local transportation; printing and binding without regard to "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s501"},"text":"section 501 of title 44","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s6101"},"text":"section 6101 of title 41","children":[],"tail":"; and such other expenses as the Secretary of State finds necessary to participation by the United States in the activities of the Commission: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s287r"},"text":"section 287r of this title","children":[],"tail":", and regulations thereunder, applicable to expenses incurred pursuant to subchapter XVII of this chapter shall be applicable to any expenses incurred pursuant to this paragraph."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8eb595f9-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-03-04/ch97/s2"},"text":"Mar. 4, 1948, ch. 97, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/66"},"text":"62 Stat. 66","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-10-28/ch782"},"text":"Oct. 28, 1949, ch. 782","children":[],"tail":", title II, § 202(2), title XI, § 1106(a), "},{"tag":"ref","attrib":{"href":"/us/stat/63/954"},"text":"63 Stat. 954","children":[],"tail":", 972.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8eb595fa-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8eb595fb-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8eb595fc-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"S