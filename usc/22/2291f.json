{"tag":"section","attrib":{"id":"id8f79351d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291f"},"text":null,"children":[{"tag":"num","attrib":{"value":"2291f"},"text":"§ 2291f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on assistance to drug traffickers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f79351e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall take all reasonable steps to ensure that assistance under this chapter and the Arms Export Control Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2751"},"text":"22 U.S.C. 2751","children":[],"tail":" et seq.] is not provided to or through any individual or entity that the President knows or has reason to believe—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f79351f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been convicted of a violation of, or a conspiracy to violate, any law or regulation of the United States, a State or the District of Columbia, or a foreign country relating to narcotic or psychotropic drugs or other controlled substances; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f7b7e10-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is or has been an illicit trafficker in any such controlled substance or is or has been a knowing assistor, abettor, conspirator, or colluder with others in the illicit trafficking in any such substance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f7b7e11-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall issue regulations specifying the steps to be taken in carrying out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f7b7e12-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional review of regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Regulations issued pursuant to subsection (b) shall be submitted to the Congress before they take effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f7b7e13-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. I, § 487, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tIV/s4503"},"text":"Pub. L. 100–690, title IV, § 4503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4285"},"text":"102 Stat. 4285","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/583/s6/b/6"},"text":"Pub. L. 102–583, § 6(b)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-02"},"text":"Nov. 2, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4932"},"text":"106 