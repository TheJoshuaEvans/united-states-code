{"tag":"section","attrib":{"id":"id8f01e0ea-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1461b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1461b"},"text":"§ 1461b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indemnification of owners of short-wave radio facilities against loss or damage","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding the provisions of sections 1341, 1342, 1349 to 1351 and subchapter II of chapter 15 of title 31, the United States Information Agency is authorized, in making contracts for the use of international shortwave radio stations and facilities, to agree on behalf of the United States to indemnify the owners and operators of said radio stations and facilities from such funds as may be hereafter appropriated for the purpose against loss or damage on account of injury to persons or property arising from such use of said radio stations and facilities.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f01e0eb-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/431/tV/s501"},"text":"Pub. L. 95–431, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-10"},"text":"Oct. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1041"},"text":"92 Stat. 1041","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/241/tIII/s303/b"},"text":"Pub. L. 97–241, title III, § 303(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-08-24"},"text":"Aug. 24, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/291"},"text":"96 Stat. 291","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f01e0ec-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"