{"tag":"section","attrib":{"id":"id911cd232-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9123"},"text":null,"children":[{"tag":"num","attrib":{"value":"9123"},"text":"§ 9123.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultations with foreign governments","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"As soon as practicable after the Secretary of State makes a determination under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9121"},"text":"section 9121 of this title","children":[],"tail":" in response to a failure to resolve unresolved abduction cases or the Secretary takes an action under subsection (d) or (e) of "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s9122"},"text":"section 9122 of this title","children":[],"tail":", based on a pattern of noncompliance, the Secretary shall request consultations with the government of such country regarding the situation giving rise to such determination."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id911cd233-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/150/tII/s203"},"text":"Pub. L. 113–150, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-08-08"},"text":"Aug. 8, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1820"},"text":"128 Stat. 1820","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
