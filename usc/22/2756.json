{"tag":"section","attrib":{"id":"id900ce8a2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2756"},"text":null,"children":[{"tag":"num","attrib":{"value":"2756"},"text":"§ 2756.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign intimidation and harassment of individuals in United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No letters of offer may be issued, no credits or guarantees may be extended, and no export licenses may be issued under this chapter with respect to any country determined by the President to be engaged in a consistent pattern of acts of intimidation or harassment directed against individuals in the United States. The President shall report any such determination promptly to the Speaker of the House of Representatives, the Committee on Foreign Affairs of the House of Representatives, and to the chairman of the Committee on Foreign Relations of the Senate.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id900ce8a3-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/629"},"text":"Pub. L. 90–629","children":[],"tail":", ch. 1, § 6, as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/113/tI/s115"},"text":"Pub. L. 97–113, title I, § 115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1528"},"text":"95 Stat. 1528","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/276/tII/s208/a/1"},"text":"Pub. L. 113–276, title II, § 208(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2992"},"text":"128 Stat. 2992","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id900ce8a4-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id900ce8a5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id900ce8a6-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/629"},"text":"Pub. L. 90–629","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1321"},"text":"82 Stat. 1321","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2751"},"text":"section 2751 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id900ce8a7-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/276"},"text":"Pub. L. 113–276","children":[],"tail":" substituted “the Speaker of the House of Representatives, the Committee on Foreign Affairs of the House of Representatives, and” for “the Speaker of the House of Representatives and”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
