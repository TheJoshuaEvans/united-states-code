{"tag":"section","attrib":{"id":"id903caaf9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3504"},"text":null,"children":[{"tag":"num","attrib":{"value":"3504"},"text":"§ 3504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authorities; fiscal requirement for authorities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id903caafa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To carry out the purposes and functions of the Institute, the President may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id903caafb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3504/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make and perform contracts and other agreements with any individual, institution, corporation, or other body of persons however designated, within or outside the United States, and with governments or government agencies, domestic or foreign;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903caafc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3504/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make advances, grants, and loans to any individual, institution, corporation, or other body of persons however designated, within or outside the United States, and to governments or government agencies, domestic or foreign;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903caafd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3504/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employ such personnel as necessary and fix their compensation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903caafe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3504/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make provision for compensation, transportation, housing, subsistence (or per diem in lieu thereof), and health care or health and accident insurance for foreign nationals engaged in activities authorized by this chapter while they are away from their homes, without regard to the provisions of any other law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903caaff-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3504/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept and use money, funds, property, and services of any kind by gift, devise, bequest, grant, or otherwise in furtherance of the purposes of the Institute;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903cab00-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3504/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire by purchase, lease, loan, bequest, or gift and hold and dispose of by sale, lease, loan, or grant, real and personal property of all kinds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903cab01-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3504/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe, amend, and repeal such rules and regulations as may be necessary to the conduct of the business of the Institute;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903cab02-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3504/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilize information, services, facilities, officers, and employees of any agency of the United States Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903cab03-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3504/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a principal office in the United States and such other offices within or outside the United States, as may be necessary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903cab04-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3504/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make such expenditures as may be necessary for administering the provisions of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903cab05-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3504/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopt, alter, and use an official seal for the Institute, which shall be judicially noticed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903cab06-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3504/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take such other actions as may be necessary and incident to carrying out the functions of the Institute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id903cab07-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any authority provided by this section involving the expenditure of appropriated funds shall be effective for a fiscal year only to such extent or in such amounts as are provided in appropriation Acts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id903cab08-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/53/tIV/s404"},"text":"Pub. L. 96–53, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-08-14"},"text":"Aug. 14, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/373"},"text":"93 Stat. 373","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id903cab09-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id903cab0a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id903cab0b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a)(4), (10), was in the original “this title”, meaning title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/53"},"text":"Pub. L. 96–53","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-08-14"},"text":"Aug. 14, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/371"},"text":"93 Stat. 371","children":[],"tail":", which is classified principally to this chapter. For complete classification of title IV to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id903cab0c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id903cab0d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1979-10-01"},"text":"Oct. 1, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/53/s512/a"},"text":"section 512(a) of Pub. L. 96–53","children":[],"tail":", set out as an Effective Date of 1979 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
