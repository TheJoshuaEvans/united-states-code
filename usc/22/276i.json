{"tag":"section","attrib":{"id":"id8eac1fef-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276i"},"text":null,"children":[{"tag":"num","attrib":{"value":"276i"},"text":"§ 276i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations; disbursements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"An appropriation of $120,000 annually is authorized, $60,000 of which shall be for the House delegation and $60,000 for the Senate delegation, or so much thereof as may be necessary, to assist in meeting the expenses of the United States group of the Mexico-United States Interparliamentary group for each fiscal year for which an appropriation is made, the House and Senate portions of such appropriation to be disbursed on vouchers to be approved by the Chairman of the House delegation and the Chairman of the Senate delegation, respectively.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8eac1ff0-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/420/s2"},"text":"Pub. L. 86–420, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-04-09"},"text":"Apr. 9, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/40"},"text":"74 Stat. 40","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/350/tI/s118/b"},"text":"Pub. L. 94–350, title I, § 118(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-07-12"},"text":"July 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/827"},"text":"90 Stat. 827","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/515/tIII/s304/c"},"text":"Pub. L. 101–515, title III, § 304(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2129"},"text":"104 Stat. 2129","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tV/s502/a/1"},"text":"Pub. L. 103–236, title V, § 502(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/461"},"text":"108 Stat. 461","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/77/tIV/s408/b/2"},"text":"Pub. L. 107–77, title IV, § 408(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-28"},"text":"Nov. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/790"},"text":"115 Stat. 790","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8eac1ff1-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8eac1ff2-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8eac1ff3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/77"},"text":"Pub. L. 107–77","children":[],"tail":" substituted “$120,000” for “$80,000” and substituted “$60,000” for “$40,000” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":" substituted “$80,000” for “$100,000” and substituted “$40,000” for “$50,000” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/515"},"text":"Pub. L. 101–515","children":[],"tail":" substituted “$100,000” for “$50,000” and “$50,000” for “$25,000” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/350"},"text":"Pub. L. 94–350","children":[],"tail":" increased annual appropriations authorization to $50,000 from $30,000 and amount for the House and Senate delegations to $25,000 from $15,000."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8eac1ff4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8eac1ff5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Permanent Appropriation for Delegation Expenses","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A permanent appropriation to carry out this section is contained in section 101(a) [title III, § 303] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s276e"},"text":"section 276e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
