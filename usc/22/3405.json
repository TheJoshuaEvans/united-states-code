{"tag":"section","attrib":{"id":"id903a3a72-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3405"},"text":null,"children":[{"tag":"num","attrib":{"value":"3405"},"text":"§ 3405.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contributions by other countries to support peace in the Middle East","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id903a3a73-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3405/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presidential consultations with other countries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of the Congress that other countries should give favorable consideration to providing support for the implementation of the peace treaty between Egypt and Israel. Therefore, the Congress requests that the President consult with other countries in order to (1) promote and develop an agreement for the establishment of a peace development fund whose purpose would be to underwrite the costs of implementing a Middle East peace, and (2) encourage investments in Israel and Egypt and other countries in the region should they join in Middle East peace agreements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id903a3a74-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3405/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/113/tVII/s734/a/4"},"text":"Pub. L. 97–113, title VII, § 734(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1560"},"text":"95 Stat. 1560","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id903a3a75-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/35/s7"},"text":"Pub. L. 96–35, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-20"},"text":"July 20, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/92"},"text":"93 Stat. 92","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/113/tVII/s734/a/4"},"text":"Pub. L. 97–113, title VII, § 734(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1560"},"text":"95 Stat. 1560","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id903a3a76-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id903a3a77-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id903a3a78-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1981—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/113"},"text":"Pub. L. 97–113","children":[],"tail":" struck out subsec. (b) which required a Presidential report to Congress no later than "},{"tag":"date","attrib":{"date":"1980-01-31"},"text":"Jan. 31, 1980","children":[],"tail":", on United States efforts to encourage aid to Egypt and Israel."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
