{"tag":"section","attrib":{"id":"id8f9101de-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2346c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2346c"},"text":"§ 2346c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of justice","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f9101df-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2346c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of assistance; purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may furnish assistance under this part to countries and organizations, including national and regional institutions, in order to strengthen the administration of justice in countries in Latin America and the Caribbean.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f9101e0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2346c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Assistance under this section may only include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f9101e1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2346c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support for specialized professional training, scholarships, and exchanges for continuing legal education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f9101e2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2346c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs to enhance prosecutorial and judicial capabilities and protection for participants in judicial cases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f9101e3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2346c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2420"},"text":"section 2420 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8f9101e4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2346c/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs to enhance professional capabilities to carry out investigative and forensic functions conducted under judicial or prosecutorial control;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f9101e5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2346c/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs to assist in the development of academic instruction and curricula for training law enforcement personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f9101e6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2346c/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs to improve the administrative and management capabilities of law enforcement agencies, especially their capabilities relating to career development, personnel evaluation, and internal discipline procedures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f9101e7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2346c/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs, conducted through multilateral or regional institutions, to improve penal institutions and the rehabilitation of offenders;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f9101e8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2346c/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthening professional organizations in order to promote services to members and the role of the bar in judicial selection, enforcement of ethical standards, and legal reform;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f9101e9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2346c/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing the availability of legal materials and publications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f9101ea-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2346c/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seminars, conferences, and training and educational programs to improve the administration of justice and to strengthen respect for the rule of law and internationally recognized human rights; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f9101eb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2346c/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" revision and modernization of legal codes and procedures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f9101ec-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2346c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than $20,000,000 of the funds made available to carry out this part for any fiscal year shall be available to carry out this section, in addition to amounts otherwise available for such purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f9101ed-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2346c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obligation of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds may not be obligated for assistance under this section unless the Committee on Foreign Affairs of the House of Representatives and the Committee on Foreign Relations of the Senate are notified of the amount and nature of the proposed assistance at least 15 days in advance in accordance with the procedures applicable to reprogrammings pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2394–1"},"text":"section 2394–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f9101ee-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2346c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation of Defense personnel in training prohibited; availability of funds; expiration of authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Personnel of the Department of Defense and members of the United States Armed Forces may not participate in the provision of training under this section. Of the funds made available to carry out this section, not more than $10,000,000 may be made available in fiscal year 1991 to carry out the provisions of subsection (b)(3) of this section. The authority of this section shall expire on ","children":[{"tag":"date","attrib":{"date":"1991-09-30"},"text":"September 30, 1991","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f9101ef-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. II, § 534, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/83/tVII/s712"},"text":"Pub. L. 99–83, title VII, § 712","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-08"},"text":"Aug. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/244"},"text":"99 Stat. 244","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/e/tV/s579"},"text":"Pub. L. 100–202, § 101(e) [title V, § 579]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-131"},"text":"101 Stat. 1329–131","children":[],"tail":", 1329–181; "},{"tag":"ref","attrib":{"href":"/us/pl/101/167/tII"},"text":"Pub. L. 101–167, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-21"},"text":"Nov. 21, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1206"},"text":"103 Stat. 1206","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/513/tII"},"text":"Pub. L. 101–513, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1990"},"text":"104 Stat. 1990","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/623/s2/b/6"},"text":"Pub. L. 101–623, § 2(b)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-21"},"text":"Nov. 21, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3351"},"text":"104 Stat. 3351","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f9101f0-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f9101f1-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id8f9101f2-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2346c, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. II, § 534, as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/113/tII/s202"},"text":"Pub. L. 97–113, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1530"},"text":"95 Stat. 1530","children":[],"tail":", prohibited the use of funds for nuclear facilities in foreign countries except under certain circumstances, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/83/tII/s201/a"},"text":"Pub. L. 99–83, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-08"},"text":"Aug. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/210"},"text":"99 Stat. 210","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 2346c, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. II, § 534, as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/384/s10/a"},"text":"Pub. L. 95–384, § 10(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-09-26"},"text":"Sept. 26, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/735"},"text":"92 Stat. 735","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/92/s8/d"},"text":"Pub. L. 96–92, § 8(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-29"},"text":"Oct. 29, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/704"},"text":"93 Stat. 704","children":[],"tail":", provided economic support for Turkey and Cyprus in amounts of $98,000,000 and $15,000,000 for fiscal year 1980, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/96/533/tII/s202"},"text":"Pub. L. 96–533, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-16"},"text":"Dec. 16, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3142"},"text":"94 Stat. 3142","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f9101f3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/623/s2/b/6/A"},"text":"Pub. L. 101–623, § 2(b)(6)(A)","children":[],"tail":", which directed the substitution of “$10,000,000 may be made available in fiscal year 1991” for “$7,000,000 may be made available in fiscal year 1990”, was executed by making the substitution for “$7,000,000 may be made available in fiscal year 1991” to reflect the probable intent of Congress and the intervening substitution of “fiscal year 1991” for “fiscal year 1990” by "},{"tag":"ref","attrib":{"href":"/us/pl/101/513"},"text":"Pub. L. 101–513","children":[],"tail":". See below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/623/s2/b/6/B"},"text":"Pub. L. 101–623, § 2(b)(6)(B)","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/101/513"},"text":"Pub. L. 101–513","children":[],"tail":", amended subsec. (e) identically, substituting “"},{"tag":"date","attrib":{"date":"1991-09-30"},"text":"September 30, 1991","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1990-09-30"},"text":"September 30, 1990","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/513"},"text":"Pub. L. 101–513","children":[],"tail":" substituted “fiscal year 1991” for “fiscal year 1990”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/167"},"text":"Pub. L. 101–167","children":[],"tail":" substituted “fiscal year 1990” for “each of fiscal years 1988 and 1989” and “"},{"tag":"date","attrib":{"date":"1990-09-30"},"text":"September 30, 1990","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1989-09-30"},"text":"September 30, 1989","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/e/tV/s579/a"},"text":"Pub. L. 100–202, § 101(e) [title V, § 579(a)]","children":[],"tail":", amended par. (3) generally. Prior to amendment, par. (3) read as follows: “notwithstanding "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2420"},"text":"section 2420 of this title","children":[],"tail":", programs to enhance investigative capabilities, conducted under judicial or prosecutorial control;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/e/tV/s579/b"},"text":"Pub. L. 100–202, § 101(e) [title V, § 579(b)]","children":[],"tail":", amended subsec. (e) generally. Prior to amendment, subsec. (e) read as follows: “The authority of this section shall expire on "},{"tag":"date","attrib":{"date":"1987-09-30"},"text":"September 30, 1987","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f9372f4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id8f9372f5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1985-10-01"},"text":"Oct. 1, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/83/s1301"},"text":"section 1301 of Pub. L. 99–83","children":[],"tail":", set out as an Effective Date of 1985 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151–1"},"text":"section 2151–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8f9372f6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Administration of Justice Activities","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/dD/tV/s536"},"text":"Pub. L. 108–199, div. D, title V, § 536","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/183"},"text":"118 Stat. 183","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/199/dD/tV/s536"},"text":"“Of the funds appropriated or otherwise made available by this Act or any subsequent Act for ‘Economic Support Fund’, assistance may be provided to strengthen the administration of justice in countries in Latin America and the Caribbean and in other regions consistent with the provisions of section 534(b) of the Foreign Assistance Act of 1961 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2346c/b"},"text":"22 U.S.C. 2346c(b)","children":[],"tail":"], except that programs to enhance protection of participants in judicial cases may be conducted notwithstanding section 660 of that Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2420"},"text":"22 U.S.C. 2420","children":[],"tail":"]. Funds made available pursuant to this section may be made available notwithstanding section 534(c) and the second and third sentences of section 534(e) of the Foreign Assistance Act of 1961 ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2346c/c"},"text":"22 U.S.C. 2346c(c)","children":[],"tail":", (e)].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/dE/tV/s536"},"text":"Pub. L. 108–7, div. E, title V, § 536","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/195"},"text":"117 Stat. 195","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/115/tV/s536"},"text":"Pub. L. 107–115, title V, § 536","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-10"},"text":"Jan. 10, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2152"},"text":"115 Stat. 2152","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/429/s101/a/tV/s540"},"text":"Pub. L. 106–429, § 101(a) [title V, § 540]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-06"},"text":"Nov. 6, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1900"},"text":"114 Stat. 1900","children":[],"tail":", 1900A–37."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/2/tV/s540"},"text":"Pub. L. 106–113, div. B, § 1000(a)(2) [title V, § 540]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1535"},"text":"113 Stat. 1535","children":[],"tail":", 1501A–95."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/d/tV/s542"},"text":"Pub. L. 105–277, div. A, § 101(d) [title V, § 542]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-150"},"text":"112 Stat. 2681–150","children":[],"tail":", 2681–184."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/118/tV/s541"},"text":"Pub. L. 105–118, title V, § 541","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-26"},"text":"Nov. 26, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2418"},"text":"111 Stat. 2418","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/c/tV/s543"},"text":"Pub. L. 104–208, div. A, title I, § 101(c) [title V, § 543]","children":