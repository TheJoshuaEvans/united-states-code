{"tag":"section","attrib":{"id":"id8f01e11e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1464b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1464b"},"text":"§ 1464b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voice of America hiring practices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f01e11f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1464b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After ","children":[{"tag":"date","attrib":{"date":"1990-02-16"},"text":"February 16, 1990","children":[],"tail":", the Voice of America shall not select candidates for employment who must be or are preapproved for employment at the Voice of America by a foreign government or an entity controlled by a foreign government."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f01e120-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1464b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The prohibition referred to in this section shall not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f01e121-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1464b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participants in the Voice of America’s exchange programs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f01e122-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1464b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clerical, technical, or maintenance staff at Voice of America offices in foreign countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f01e123-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1464b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Broadcasting Board of Governors determines that the prohibition under subsection (a) would require the termination of a specific Voice of America foreign language service, then, not less than 90 days before the Board begins to recruit such candidates, the Board shall submit to the Committee on Foreign Relations of the Senate and the Committee on Foreign Affairs of the House of Representatives a report concerning—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f01e124-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1464b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and location of speakers of the applicable foreign language who could be recruited by the Voice of America without violating this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f01e125-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1464b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the efforts made by the Voice of America to recruit such individuals for employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f01e126-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-01-27/ch36"},"text":"Jan. 27, 1948, ch. 36","children":[],"tail":", title V, § 506, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/246/tII/s232"},"text":"Pub. L. 101–246, title II, § 232","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-02-16"},"text":"Feb. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/57"},"text":"104 Stat. 57","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. A, title XIII, § 1335(a)(2), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-787"},"text":"112 Stat. 2681–787","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f01e127-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f01e128-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f01e129-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":", in introductory provisions, substituted “Broadcasting Board of Governors” for “Director of the United States Information Agency”, “Board begins” for “Agency begins”, and “Board shall” for “Director shall”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f01e12a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id8f01e12b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Broadcasting Board of Governors renamed United States Agency for Global Media pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6204/a/21"},"text":"section 6204(a)(21) of this title","children":[],"tail":". The renaming was effectuated by notice to congressional appropriations committees dated "},{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":", and became effective "},{"tag":"date","attrib":{"date":"2018-08-22"},"text":"Aug. 22, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8f01e12c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1999-10-01"},"text":"Oct. 1, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1301"},"text":"section 1301 of Pub. L. 105–277","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6531"},"text":"section 6531 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
