{"tag":"section","attrib":{"id":"id91050534-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8571"},"text":null,"children":[{"tag":"num","attrib":{"value":"8571"},"text":"§ 8571.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of policy","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is the policy of the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91050535-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8571/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to deny Iran the ability to engage in destabilizing activities, support international terrorism, fund the development and acquisition of weapons of mass destruction and the means to deliver such weapons by limiting export of petroleum and petroleum products by Iran;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91050536-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8571/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to deny Iran funds to oppress and commit human rights violations against the Iranian people assembling to peacefully redress the Iranian regime;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91050537-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8571/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to fully enforce sanctions against those entities which provide support to the Iranian energy sector; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91050538-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8571/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to counter Iran’s actions to finance and facilitate the participation of foreign terrorist organizations in ongoing conflicts and illicit activities due to the threat such actions pose to the vital national interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id91050539-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/50/dJ/s2"},"text":"Pub. L. 118–50, div. J, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-04-24"},"text":"Apr. 24, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/963"},"text":"138 Stat. 963","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9105053a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9105053b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id9105053c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Stop Harboring Iranian Petroleum Act, also known as the SHIP Act, and not as part of the Comprehensive Iran Sanctions, Accountability, and Divestment Act of 2010 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9105053d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id9105053e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For short title of this subchapter as the “Stop Harboring Iranian Petroleum Act”, also known as the “SHIP Act”, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/50/dJ/s1"},"text":"section 1 of div. J of Pub. L. 118–50","children":[],"tail":", set out as a Short Title of 2024 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s8501"},"text":"section 8501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
