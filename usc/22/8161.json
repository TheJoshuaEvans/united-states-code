{"tag":"section","attrib":{"id":"id90f6ad2a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8161"},"text":null,"children":[{"tag":"num","attrib":{"value":"8161"},"text":"§ 8161.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of certain information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90f6ad2b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8161/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Locations and facilities of direct national security significance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No current or former Department of Defense or Department of Energy location, site, or facility of direct national security significance shall be declared or be subject to IAEA inspection under the Additional Protocol.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90f6ad2c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8161/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information of direct national security significance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No information of direct national security significance regarding any location, site, or facility associated with activities of the Department of Defense or the Department of Energy shall be provided under the Additional Protocol.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90f6ad2d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8161/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restricted data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to permit the communication or disclosure to the IAEA or IAEA employees of restricted data controlled by the provisions of the Atomic Energy Act of 1954 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2011"},"text":"42 U.S.C. 2011","children":[],"tail":" et seq.), including in particular “Restricted Data” as defined under paragraph (1) of section 11 y. of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2014/y"},"text":"42 U.S.C. 2014(y)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90f6ad2e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8161/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Classified information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this Act shall be construed to permit the communication or disclosure to the IAEA or IAEA employees of national security information and other classified information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90f6ad2f-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/401/tII/s261"},"text":"Pub. L. 109–401, title II, § 261","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-18"},"text":"Dec. 18, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2751"},"text":"120 Stat. 2751","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90f6ad30-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90f6ad31-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90f6ad32-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Atomic Energy Act of 1954, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"act Aug. 1, 1946, ch. 724","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-30/ch1073/s1"},"text":"act Aug. 30, 1954, ch. 1073, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/919"},"text":"68 Stat. 919","children":[],"tail":", which is classified principally to chapter 23 (§ 2011 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2011"},"text":"section 2011 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/401"},"text":"Pub. L. 109–401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-18"},"text":"Dec. 18, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2726"},"text":"120 Stat. 2726","children":[],"tail":", which enacted this chapter and chapter 87 (§ 8001 et seq.) of this title and amended "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2652c"},"text":"section 2652c of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2153"},"text":"section 2153 of Title 42","children":[],"tail":", The Public Health and Welfare. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
