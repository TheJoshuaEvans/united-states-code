{"tag":"section","attrib":{"id":"id90272745-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2799a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2799a"},"text":"§ 2799a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" CFE Treaty obligations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The authorities provided in this subchapter shall be exercised consistent with the obligations incurred by the United States in connection with the CFE Treaty.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id90272746-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/629"},"text":"Pub. L. 90–629","children":[],"tail":", ch. 9, § 92, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/228/s2"},"text":"Pub. L. 102–228, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-12"},"text":"Dec. 12, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1691"},"text":"105 Stat. 1691","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
