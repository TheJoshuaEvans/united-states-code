{"tag":"section","attrib":{"id":"id908db222-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5453"},"text":null,"children":[{"tag":"num","attrib":{"value":"5453"},"text":"§ 5453.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical supplies, hospital equipment, and medical training for Poland","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id908db223-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5453/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to amounts otherwise available for such purposes, there are authorized to be appropriated to carry out chapter 4 of part II of the Foreign Assistance Act of 1961 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2346"},"text":"22 U.S.C. 2346","children":[],"tail":" and following; relating to the economic support fund) $4,000,000 for the 3-year period beginning "},{"tag":"date","attrib":{"date":"1989-10-01"},"text":"October 1, 1989","children":[],"tail":", which shall be available only—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id908db224-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5453/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for providing medical supplies and hospital equipment to Poland through private and voluntary organizations, including for the expenses of purchasing, transporting, and distributing such supplies and equipment, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908db225-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5453/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for training of Polish medical personnel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id908db226-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5453/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplicability of other laws","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Assistance may be provided under this section notwithstanding any other provision of law, other than—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id908db227-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5453/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 104(f) of the Foreign Assistance Act of 1961 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151b/f"},"text":"22 U.S.C. 2151b(f)","children":[],"tail":"; relating to the prohibition on the use of funds for abortions and involuntary sterilizations), and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908db228-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5453/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any provision of the annual Foreign Operations, Export Financing, and Related Programs Appropriations Act that relates to abortion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id908db229-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/179/tV/s503"},"text":"Pub. L. 101–179, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-28"},"text":"Nov. 28, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1318"},"text":"103 Stat. 1318","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id908db22a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id908db22b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id908db22c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Foreign Assistance Act of 1961, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/424"},"text":"75 Stat. 424","children":[],"tail":". Chapter 4 of part II of the Foreign Assistance Act of 1961 is classified to part IV (§ 2346 et seq.) of subchapter II of chapter 32 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Foreign Operations, Export Financing, and Related Programs Appropriations Act, referred to in subsec. (b)(2), is for fiscal year 1990, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/167"},"text":"Pub. L. 101–167","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-21"},"text":"Nov. 21, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1195"},"text":"103 Stat. 1195","children":[],"tail":". For complete classification of this and other Foreign Operations, Export Financing, and Related Programs Appropriations Acts to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
