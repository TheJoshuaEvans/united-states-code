{"tag":"section","attrib":{"id":"id8fedeff8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2658a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2658a"},"text":"§ 2658a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign Affairs Manual and Foreign Affairs Handbook changes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fedeff9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2658a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foreign Affairs Manual and the Foreign Affairs Handbook apply with equal force and effect and without exception to all Department of State personnel, including the Secretary of State, Department employees, and political appointees, regardless of an individual’s status as a Foreign Service officer, Civil Service employee, or political appointee hired under any legal authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fedeffa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2658a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after ","children":[{"tag":"date","attrib":{"date":"2021-12-27"},"text":"December 27, 2021","children":[],"tail":", the Secretary of State shall submit to the appropriate congressional committees a certification in unclassified form that the applicability described in subsection (a) has been communicated to all Department personnel, including the personnel referred to in such subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fedeffb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2658a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fedeffc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2658a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2021-12-27"},"text":"December 27, 2021","children":[],"tail":", and every 180 days thereafter for 8 years, the Secretary shall submit to the appropriate congressional committees a report detailing all significant changes made to the Foreign Affairs Manual or the Foreign Affairs Handbook."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fedeffd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2658a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered periods","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The first report required under paragraph (1) shall cover the 5-year period preceding the submission of such report. Each subsequent report shall cover the 180-day period preceding submission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fedeffe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2658a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report required under paragraph (1) shall contain the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fedefff-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2658a/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The location within the Foreign Affairs Manual or the Foreign Affairs Handbook where a change has been made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fedf000-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2658a/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The statutory basis for each such change, as applicable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fedf001-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2658a/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A side-by-side comparison of the Foreign Affairs Manual or Foreign Affairs Handbook before and after such change.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fedf002-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2658a/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A summary of such changes displayed in spreadsheet form.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fedf003-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dE/tLIII/s5318"},"text":"Pub. L. 117–81, div. E, title LIII, § 5318","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2367"},"text":"135 Stat. 2367","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dE/tI/s5178"},"text":"Pub. L. 119–60, div. E, title I, § 5178","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1590"},"text":"139 Stat. 1590","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fedf004-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8fedf005-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8fedf006-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" substituted “8 years” for “5 years”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8fedf007-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id8fedf008-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “appropriate congressional committees” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s5002"},"text":"section 5002 of Pub. L. 117–81","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s263c"},"text":"section 263c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
