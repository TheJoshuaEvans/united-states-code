{"tag":"section","attrib":{"id":"id9123fe62-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9241a"},"text":null,"children":[{"tag":"num","attrib":{"value":"9241a"},"text":"§ 9241a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rebuttable presumption applicable to goods made with North Korean labor","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9123fe63-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9241a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b), any significant goods, wares, articles, and merchandise mined, produced, or manufactured wholly or in part by the labor of North Korean nationals or citizens shall be deemed to be prohibited under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1307"},"text":"section 1307 of title 19","children":[],"tail":" and shall not be entitled to entry at any of the ports of the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9123fe64-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9241a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The prohibition described in subsection (a) shall not apply if the Commissioner of U.S. Customs and Border Protection finds, by clear and convincing evidence, that the goods, wares, articles, or merchandise described in such paragraph were not produced with convict labor, forced labor, or indentured labor under penal sanctions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9123fe65-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/122/tIII/s302A"},"text":"Pub. L. 114–122, title III, § 302A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/44/tIII/s321/b/1"},"text":"Pub. L. 115–44, title III, § 321(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-02"},"text":"Aug. 2, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/952"},"text":"131 Stat. 952","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
