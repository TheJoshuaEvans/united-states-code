{"tag":"section","attrib":{"id":"id90f6ace5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8124"},"text":null,"children":[{"tag":"num","attrib":{"value":"8124"},"text":"§ 8124.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited acts relating to complementary access","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It shall be unlawful for any person willfully to fail or refuse to permit, or to disrupt, delay, or otherwise impede, a complementary access authorized by this subchapter or an entry in connection with such access.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id90f6ace6-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/401/tII/s224"},"text":"Pub. L. 109–401, title II, § 224","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-18"},"text":"Dec. 18, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2747"},"text":"120 Stat. 2747","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
