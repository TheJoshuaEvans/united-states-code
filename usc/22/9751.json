{"tag":"section","attrib":{"id":"id914c6d1d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9751"},"text":null,"children":[{"tag":"num","attrib":{"value":"9751"},"text":"§ 9751.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Developing and implementing a coordinated sanctions strategy with partners in the Western Hemisphere and the European Union","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id914c6d1e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9751/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strengthening sanctions capacity in Latin America and the Caribbean","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State, in consultation with the Secretary of the Treasury, shall offer to provide technical assistance to partner governments in Latin America and the Caribbean to assist such governments in establishing the legislative and regulatory frameworks needed to impose targeted sanctions on officials of the Maduro regime who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id914c6d1f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9751/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are responsible for human rights abuses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914c6d20-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9751/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have engaged in public corruption; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914c6d21-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9751/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are undermining democratic institutions and processes in Venezuela.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id914c6d22-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9751/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordinating international sanctions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State, in consultation with the Secretary of the Treasury, shall engage in diplomatic efforts with partner governments, including the Government of Canada, governments in the European Union, and governments in Latin America and the Caribbean, to impose targeted sanctions on the Maduro regime officials described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id914c6d23-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9751/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategy requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"December 20, 2019","children":[],"tail":", the Secretary of State, in consultation with the Secretary of the Treasury, shall submit a strategy for carrying out the activities described in subsection (a) to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id914c6d24-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9751/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914c6d25-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9751/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914c6d26-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9751/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Banking, Housing, and Urban Affairs of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914c6d27-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9751/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914c6d28-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9751/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914c6d29-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9751/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Financial Services of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id914c6d2a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9751/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id914c6d2b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9751/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary of State for fiscal year 2020, $3,000,000 to carry out the activities set forth in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914c6d2c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9751/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts appropriated pursuant to paragraph (1) are subject to the notification requirements applicable to expenditures from the Economic Support Fund under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2346/c"},"text":"section 2346(c) of this title","children":[],"tail":" and the International Narcotics and Law Enforcement Fund under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2291h"},"text":"section 2291h of this title","children":[],"tail":" to the extent that such funds are expended."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id914c6d2d-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dJ/tI/s161"},"text":"Pub. L. 116–94, div. J, title I, § 161","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3040"},"text":"133 Stat. 3040","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
