"/us/pl/95/105/tI/s109/a/6"},"text":"Pub. L. 95–105, title I, § 109(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-17"},"text":"Aug. 17, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/846"},"text":"91 Stat. 846","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/105/tI/s109/a/6"},"text":"“The individual holding the position of Coordinator for Human Rights and Humanitarian Affairs on the date of enactment of this section [","children":[{"tag":"date","attrib":{"date":"1977-08-17"},"text":"Aug. 17, 1977","children":[],"tail":"] shall assume the duties of the Assistant Secretary of State for Human Rights and Humanitarian Affairs and shall not be required to be reappointed by reason of the enactment of this section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8fab4109-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report to Speaker of the House and Congressional Committees on Office of Assistant Secretary for Human Rights and Humanitarian Affairs","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/105/tI/s109/a/7"},"text":"Pub. L. 95–105, title I, § 109(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-17"},"text":"Aug. 17, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/847"},"text":"91 Stat. 847","children":[],"tail":", which required the Secretary of State, not later than "},{"tag":"date","attrib":{"date":"1978-01-31"},"text":"Jan. 31, 1978","children":[],"tail":", to transmit to the Speaker of the House of Representatives and the chairmen of the Senate Committee on Foreign Relations and the Senate Committee on the Judiciary a comprehensive report on the Office of the Assistant Secretary for Human Rights and Humanitarian Affairs, including its current manda