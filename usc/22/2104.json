{"tag":"section","attrib":{"id":"id8f2f3341-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2104"},"text":null,"children":[{"tag":"num","attrib":{"value":"2104"},"text":"§ 2104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Federal officers and agencies unaffected","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to repeal or restrict authority vested in the President, the Secretary of State, the Secretary of Health, Education, and Welfare, the Surgeon General of the Public Health Service, or any other officer or agency of the United States by any other provision of law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f2f3342-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/610/s6"},"text":"Pub. L. 86–610, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-07-12"},"text":"July 12, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/369"},"text":"74 Stat. 369","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f2f3343-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f2f3344-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8f2f3345-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this joint resolution”, which enacted this chapter and section 308 of the Public Health Service Act (","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"act July 1, 1944, ch. 373","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/58/682"},"text":"58 Stat. 682","children":[],"tail":"). Such section 308 was redesignated section 307 by "},{"tag":"ref","attrib":{"href":"/us/pl/93/353"},"text":"Pub. L. 93–353","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-07-23"},"text":"July 23, 1974","children":[],"tail":", title I, § 106, "},{"tag":"ref","attrib":{"href":"/us/stat/88/367"},"text":"88 Stat. 367","children":[],"tail":", and is classified to section 242"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of Title 42, The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f2f3346-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id8f2f3347-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"See Transfer of Functions notes set out under sections 2102 and 2103 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
