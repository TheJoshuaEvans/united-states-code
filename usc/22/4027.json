{"tag":"section","attrib":{"id":"id90595b06-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4027"},"text":null,"children":[{"tag":"num","attrib":{"value":"4027"},"text":"§ 4027.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Visiting Scholars Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90595b07-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4027/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be established at the institution a program whereby selected scholars would participate fully in the educational and training activities of the institution. This program may be referred to as the “Visiting Scholars Program”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90595b08-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4027/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection and appointment of scholars","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90595b09-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4027/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Scholars participating in the Visiting Scholars Program shall be selected by a five-member board described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90595b0a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4027/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each visiting scholar shall serve a term of one year, except that such term may be extended for one additional one-year period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90595b0b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4027/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of selection board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The board referred to in subsection (b) shall be composed of the Director of the institution, who shall serve as chairperson, and four other members appointed by the Secretary of State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90595b0c-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s707"},"text":"Pub. L. 96–465, title I, § 707","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/246/tI/s144/a"},"text":"Pub. L. 101–246, title I, § 144(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-02-16"},"text":"Feb. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/36"},"text":"104 Stat. 36","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s126/3"},"text":"Pub. L. 103–236, title I, § 126(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/394"},"text":"108 Stat. 394","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90595b0d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90595b0e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90595b0f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsecs. (a), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":" substituted “institution” for “Foreign Service Institute” and “Institute” in subsec. (a) and “institution” for “Foreign Service Institute” in subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
