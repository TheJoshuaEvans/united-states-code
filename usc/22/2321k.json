{"tag":"section","attrib":{"id":"id8f8e9162-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2321k"},"text":null,"children":[{"tag":"num","attrib":{"value":"2321k"},"text":"§ 2321k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of major non-NATO allies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f8e9163-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2321k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall notify the Congress in writing at least 30 days before—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f8e9164-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2321k/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designating a country as a major non-NATO ally for purposes of this chapter and the Arms Export Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2751"},"text":"22 U.S.C. 2751","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f8e9165-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2321k/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" terminating such a designation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f910166-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2321k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial designations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Australia, Egypt, Israel, Japan, the Republic of Korea, and New Zealand shall be deemed to have been so designated by the President as of the effective date of this section, and the President is not required to notify the Congress of such designation of those countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f910167-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. II, § 517, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/164/tI/s147/a/1"},"text":"Pub. L. 104–164, title I, § 147(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-07-21"},"text":"July 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1434"},"text":"110 Stat. 1434","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f910168-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f910169-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8f91016a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a)(1), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/424"},"text":"75 Stat. 424","children":[],"tail":", known as the Foreign Assistance Act of 1961. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Arms Export Control Act, referred to in subsec. (a)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/629"},"text":"Pub. L. 90–629","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1320"},"text":"82 Stat. 1320","children":[],"tail":", which is classified principally to chapter 39 (§ 2751 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2751"},"text":"section 2751 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The effective date of this section, referred to in subsec. (b), is ","children":[{"tag":"date","attrib":{"date":"1996-07-21"},"text":"July 21, 1996","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/104/164"},"text":"Pub. L. 104–164","children":[],"tail":", which enacted this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id8f91016b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2321k, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. II, § 517, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/231/s5"},"text":"Pub. L. 101–231, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-13"},"text":"Dec. 13, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1957"},"text":"103 Stat. 1957","children":[],"tail":"; amended "