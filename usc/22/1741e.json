{"tag":"section","attrib":{"id":"id8f1c20a9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1741e"},"text":"§ 1741e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f1c20aa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8f1c20ab-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations, the Committee on Appropriations, the Committee on Banking, Housing, and Urban Affairs, the Committee on the Judiciary, the Committee on Armed Services, and the Select Committee on Intelligence of the United States Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f1c20ac-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs, the Committee on Appropriations, the Committee on Financial Services, the Committee on the Judiciary, the Committee on Armed Services, and the Permanent Select Committee on Intelligence of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f1c20ad-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States national","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “United States national” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8f1c20ae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a United States national as defined in section 1101(a)(22) or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1408"},"text":"section 1408 of title 8","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f1c20af-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a lawful permanent resident alien with significant ties to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f1c20b0-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dFF/tIII/s307"},"text":"Pub. L. 116–260, div. FF, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3098"},"text":"134 Stat. 3098","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f1c20b1-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f1c20b2-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8f1c20b3-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in text, was in the original “this Act” and was translated as reading “this subtitle”, meaning subtitle A (§§ 301–308) of title III of div. FF of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3091"},"text":"134 Stat. 3091","children":[],"tail":", known as the Robert Levinson Hostage Recovery and Hostage-Taking Accountability Act, which enacted this subchapter, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
