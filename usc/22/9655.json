{"tag":"section","attrib":{"id":"id9147b2ab-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9655"},"text":null,"children":[{"tag":"num","attrib":{"value":"9655"},"text":"§ 9655.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Engagement with investors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9147b2ac-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9655/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Corporation, acting through the Chief Development Officer, shall, in cooperation with the Administrator of the United States Agency for International Development—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9147b2ad-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9655/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a strategic relationship with private sector entities focused at the nexus of business opportunities and development priorities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b2ae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9655/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage such entities and reduce business risks primarily through direct transaction support and facilitating investment partnerships;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b2af-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9655/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and support tools, approaches, and intermediaries that can mobilize private finance at scale in the developing world;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b2b0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9655/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursue highly developmental projects of all sizes, especially those that are small but designed for work in the most underdeveloped areas, including countries with chronic suffering as a result of extreme poverty, fragile institutions, or a history of violence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b2b1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9655/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursue projects consistent with the policy of the United States described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9611"},"text":"section 9611 of this title","children":[],"tail":" and the Joint Strategic Plan and the Mission Country Development Cooperation Strategies of the United States Agency for International Development."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9147b2b2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9655/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To achieve the goals described in subsection (a), the Corporation shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9147b2b3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9655/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop risk mitigation tools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b2b4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9655/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide transaction structuring support for blended finance models;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b2b5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9655/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support intermediaries linking capital supply and demand;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b2b6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9655/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with other Federal agencies to support or accelerate transactions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b2b7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9655/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" convene financial, donor, civil society, and public sector partners around opportunities for private finance within development priorities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b2b8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9655/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offer strategic planning and programming assistance to catalyze investment into priority sectors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b2b9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9655/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide transaction structuring support;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b2ba-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9655/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deliver training and knowledge management tools for engaging private investors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b2bb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9655/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" partner with private sector entities that provide access to capital and expertise; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b2bc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9655/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and screen new investment partners.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9147b2bd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9655/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall coordinate with the United States Agency for International Development and other agencies and departments, as necessary, on projects and programs supported by the Corporation that include technical assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9147b2be-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dF/tIV/s1445"},"text":"Pub. L. 115–254, div. F, title IV, § 1445","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3506"},"text":"132 Stat. 3506","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
