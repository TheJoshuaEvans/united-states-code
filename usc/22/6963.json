{"tag":"section","attrib":{"id":"id90cbcc1c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6963"},"text":null,"children":[{"tag":"num","attrib":{"value":"6963"},"text":"§ 6963.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition of Task Force","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury, the Secretary of Commerce, the Secretary of Labor, the Secretary of State, the Commissioner of U.S. Customs and Border Protection, and the heads of other executive branch agencies, as appropriate, acting through their respective designees at or above the level of Deputy Assistant Secretary, or in the case of the Customs Service, at or above the level of Assistant Commissioner, shall compose the Task Force. The designee of the Secretary of the Treasury shall chair the Task Force.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id90cbcc1d-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/286/dB/tV/s503"},"text":"Pub. L. 106–286, div. B, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-10"},"text":"Oct. 10, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/904"},"text":"114 Stat. 904","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/125/tVIII/s802/d/2"},"text":"Pub. L. 114–125, title VIII, § 802(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/210"},"text":"130 Stat. 210","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90cbcc1e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90cbcc1f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading",