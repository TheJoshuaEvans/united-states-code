{"tag":"section","attrib":{"id":"id90cbcbf4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6942"},"text":null,"children":[{"tag":"num","attrib":{"value":"6942"},"text":"§ 6942.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The purpose of this part is to authorize additional resources for the agencies and departments engaged in monitoring and enforcement of United States trade agreements and trade laws with respect to the People’s Republic of China.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id90cbcbf5-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/286/dB/tIV/s412"},"text":"Pub. L. 106–286, div. B, title IV, § 412","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-10"},"text":"Oct. 10, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/901"},"text":"114 Stat. 901","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
