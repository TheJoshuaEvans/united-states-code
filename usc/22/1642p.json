{"tag":"section","attrib":{"id":"id8f14f45a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1642p"},"text":null,"children":[{"tag":"num","attrib":{"value":"1642p"},"text":"§ 1642p.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to enable the Commission and the Treasury Department to pay their administrative expenses incurred in carrying out their functions under this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f14f45b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-03-10/ch54"},"text":"Mar. 10, 1950, ch. 54","children":[],"tail":", title IV, § 417, as added "},{"tag":"ref","attrib":{"href":"/us/pl/85/604/s1"},"text":"Pub. L. 85–604, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-08"},"text":"Aug. 8, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/530"},"text":"72 Stat. 530","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
