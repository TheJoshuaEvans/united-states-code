{"tag":"section","attrib":{"id":"id8ede2c84-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"290g–4"},"text":"§ 290g–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations; repayments and distributions from Fund to Treasury","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ede2c85-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is hereby authorized to be appropriated without fiscal year limitation, as the United States subscription, $25,000,000 to be paid by the Secretary of the Treasury to the Fund in three annual installments of $9,000,000, $8,000,000, and $8,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ede2c86-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any repayment or distribution of moneys from the Fund to the United States shall be covered into the Treasury as a miscellaneous receipt.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ede2c87-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/302/tII/s206"},"text":"Pub. L. 94–302, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-05-31"},"text":"May 31, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/594"},"text":"90 Stat. 594","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
