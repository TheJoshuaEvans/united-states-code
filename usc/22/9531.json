{"tag":"section","attrib":{"id":"id91325641-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9531"},"text":null,"children":[{"tag":"num","attrib":{"value":"9531"},"text":"§ 9531.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception relating to activities of the National Aeronautics and Space Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id91325642-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9531/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This chapter and the amendments made by this Act shall not apply with respect to activities of the National Aeronautics and Space Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91325643-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9531/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this chapter or the amendments made by this Act shall be construed to authorize the imposition of any sanction or other condition, limitation, restriction, or prohibition, that directly or indirectly impedes the supply by any entity of the Russian Federation of any product or service, or the procurement of such product or service by any contractor or subcontractor of the United States or any other entity, relating to or in connection with any space launch conducted for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91325644-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9531/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Aeronautics and Space Administration; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91325645-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9531/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other non-Department of Defense customer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id91325646-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/44/tII/s237"},"text":"Pub. L. 115–44, title II, § 237","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-02"},"text":"Aug. 2, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/922"},"text":"131 Stat. 922","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id91325647-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id91325648-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id91325649-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “This Act” and was translated as reading “This title”, meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/44"},"text":"Pub. L. 115–44","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-02"},"text":"Aug. 2, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/898"},"text":"131 Stat. 898","children":[],"tai