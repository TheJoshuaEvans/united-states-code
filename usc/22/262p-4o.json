{"tag":"section","attrib":{"id":"id8e9dc909-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–4o"},"text":null,"children":[{"tag":"num","attrib":{"value":"262p–4o"},"text":"§ 262p–4o.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Respect for indigenous peoples","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall direct the United States Executive Directors of the international financial institutions (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s262r/c/2"},"text":"section 262r(c)(2) of this title","children":[],"tail":") and the United States representative to the council of the Global Environment Facility administered by the International Bank for Reconstruction and Development to use the voice and vote of the United States to bring about the creation and full implementation of policies designed to promote respect for and full protection of the territorial rights, traditional economies, cultural integrity, traditional knowledge and human rights of indigenous peoples."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8e9dc90a-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/118/tXVI/s1620"},"text":"Pub. L. 95–118, title XVI, § 1620","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/306/tV/s526/e"},"text":"Pub. L. 103–306, title V, § 526(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-23"},"text":"Aug. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1633"},"text":"108 Stat. 1633","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8e9dc90b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8e9dc90c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{