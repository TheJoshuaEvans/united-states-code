{"tag":"section","attrib":{"id":"id8ede2c68-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g"},"text":null,"children":[{"tag":"num","attrib":{"value":"290g"},"text":"§ 290g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" African Development Fund; United States participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President is hereby authorized to accept participation for the United States in the African Development Fund (hereinafter referred to as the “Fund”) provided for by the agreement establishing the Fund (hereinafter referred to as the “agreement”) deposited in the Archives of the United Nations.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ede2c69-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/302/tII/s202"},"text":"Pub. L. 94–302, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-05-31"},"text":"May 31, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/593"},"text":"90 Stat. 593","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ede2c6a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ede2c6b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id8ede2c6c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/302/tII/s201"},"text":"Pub. L. 94–302, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-05-31"},"text":"May 31, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/593"},"text":"90 Stat. 593","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/302/tII/s201"},"text":"“This title [enacting this subchapter] may be cited as the ‘African Development Fund Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
