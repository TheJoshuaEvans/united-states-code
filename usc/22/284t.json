{"tag":"section","attrib":{"id":"id8ebcc215-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284t"},"text":null,"children":[{"tag":"num","attrib":{"value":"284t"},"text":"§ 284t.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Thirteenth replenishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ebcc216-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284t/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contribution authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ebcc217-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284t/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States Governor of the Association may contribute on behalf of the United States an amount equal to the amount appropriated under subsection (b), pursuant to the resolution of the Association entitled “Additions to IDA Resources: Thirteenth Replenishment”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ebcc218-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284t/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subject to appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any commitment to make the contribution authorized by paragraph (1) shall be effective only to such extent or in such amounts as are provided in advance in appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ebcc219-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284t/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the contribution authorized by subsection (a), there are authorized to be appropriated such sums as may be necessary for payment by the Secretary of the Treasury, without fiscal year limitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ebcc21a-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/565/s22"},"text":"Pub. L. 86–565, § 22","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/199/dD/tV/s580"},"text":"Pub. L. 108–199, div. D, title V, § 580","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/202"},"text":"118 Stat. 202","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
