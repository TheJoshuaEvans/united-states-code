{"tag":"section","attrib":{"id":"id907f8029-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4713"},"text":null,"children":[{"tag":"num","attrib":{"value":"4713"},"text":"§ 4713.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Latin American exchanges","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Of any funds authorized to be appropriated for activities authorized by this chapter, not less than 25 percent shall be allocated to fund grants and exchanges to Latin America and the Caribbean.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id907f802a-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/93/tVI/s613"},"text":"Pub. L. 99–93, title VI, § 613","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-16"},"text":"Aug. 16, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/444"},"text":"99 Stat. 444","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
