{"tag":"section","attrib":{"id":"id911cd24f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9141"},"text":null,"children":[{"tag":"num","attrib":{"value":"9141"},"text":"§ 9141.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization for judicial training on international parental child abduction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id911cd250-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9141/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State, subject to the availability of appropriations, shall seek to provide training, directly or through another government agency or nongovernmental organizations, on the effective handling of parental abduction cases to the judicial and administrative authorities in countries—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id911cd251-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9141/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which a significant number of unresolved abduction cases are pending; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911cd252-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9141/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that have been designated as having a pattern of noncompliance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9122/b"},"text":"section 9122(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id911cd253-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9141/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategy requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2014-08-08"},"text":"August 8, 2014","children":[],"tail":", the President shall submit a strategy to carry out the activities described in subsection (a) to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id911cd254-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9141/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911cd255-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9141/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911cd256-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9141/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911cd257-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9141/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id911cd258-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9141/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id911cd259-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9141/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary of State $1,000,000 for each of the fiscal years 2015 and 2016 to carry out subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911cd25a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9141/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts appropriated for the activities set forth in subsection (a) shall be used pursuant to the authorization and requirements under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id911cd25b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/150/tIII/s302"},"text":"Pub. L. 113–150, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-08-08"},"text":"Aug. 8, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1822"},"text":"128 Stat. 1822","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id911cd25c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id911cd25d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id911cd25e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Authority Pursuant to Section 302(b) of the Sean and David Goldman International Child Abduction Prevention and Return Act of 2014","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2015-05-07"},"text":"May 7, 2015","children":[],"tail":", 80 F.R. 32849, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum for the Secretary of State","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"By the authority vested in me as President by the Constitution and the laws of the United States of America, including ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of title 3","children":[],"tail":", United States Code, I hereby delegate the functions and authorities vested in the President by section 302(b) of the Sean and David Goldman International Child Abduction Prevention and Return Act of 2014 ("},{"tag":"ref","attrib":{"href":"/us/pl/113/150"},"text":"Public Law 113–150","children":[],"tail":") (the “Act”), to the Secretary of State."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Any reference in this memorandum to the Act shall be deemed to be a reference to any future act that is the same or substantially the same as such provision.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"You are authorized and directed to publish this memorandum in the Federal Register.","children":[],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"Barack Obama.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
