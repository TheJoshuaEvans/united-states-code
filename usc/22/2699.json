{"tag":"section","attrib":{"id":"id8ff78bd4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2699"},"text":null,"children":[{"tag":"num","attrib":{"value":"2699"},"text":"§ 2699.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment opportunities for family members","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ff78bd5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2699/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to expand employment opportunities for family members of United States Government personnel assigned abroad, the Secretary of State shall seek to conclude such bilateral and multilateral agreements as will facilitate the employment of such family members in foreign economies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff78bd6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2699/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any member of a family of a member of the Foreign Service may accept gainful employment in a foreign country unless such employment—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ff78bd7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2699/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would violate any law of such country or of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff78bd8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2699/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" could, as certified in writing by the United States chief of mission to such country, damage the interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ff78bd9-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch841"},"text":"Aug. 1, 1956, ch. 841","children":[],"tail":", title I, § 27, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/465/tII/s2201/a"},"text":"Pub. L. 96–465, title II, § 2201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2154"},"text":"94 Stat. 2154","children":[],"tail":"; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/97/241/tII/s202/a"},"text":"Pub. L. 97–241, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-08-24"},"text":"Aug. 24, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/282"},"text":"96 Stat. 282","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ff78bda-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ff78bdb-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id8ff78bdc-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1981-02-15"},"text":"Feb. 15, 1981","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/96/465/s2403"},"text":"section 2403 of Pub. L. 96–465","children":[],"tail":", set out as a note under 