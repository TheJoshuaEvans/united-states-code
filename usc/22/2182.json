":{"href":"/us/stat/79/654"},"text":"79 Stat. 654","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/583"},"text":"Pub. L. 89–583","children":[],"tail":", pt. I, § 104(b), "},{"tag":"date","attrib":{"date":"1966-09-19"},"text":"Sept. 19, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/798"},"text":"80 Stat. 798","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/137"},"text":"Pub. L. 90–137","children":[],"tail":", pt. I, § 104(b), "},{"tag":"date","attrib":{"date":"1967-11-14"},"text":"Nov. 14, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/451"},"text":"81 Stat. 451","children":[],"tail":", contained general provisions concerning foreign investment guaranties, prior to the general reorganization of this subpart by "},{"tag":"ref","attrib":{"href":"/us/pl/91/175"},"text":"Pub. L. 91–175","children":[],"tail":", pt. I, § 105, "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/807"},"text":"83 Stat. 807","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f63b05d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/513"},"text":"Pub. L. 101–513","children":[],"tail":" substituted “1992” for “1991”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/302"},"text":"Pub. L. 101–302","children":[],"tail":" substituted “$2,558,000,000” for “$2,158,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/167"},"text":"Pub. L. 101–167","children":[],"tail":" substituted “1991” for “1990”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":" substituted “1990” for “1988”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/83/s313/a"},"text":"Pub. L. 99–83, § 313(a)","children":[],"tail":", (b), substituted “$2,158,000,000” for “$1,958,000,000” and “1988” for “1986”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (k). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/83/s313/c"},"text":"Pub. L. 99–83, § 313(c)","children":[],"tail":", added subsec. (k)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":" substituted “$1,958,000,000” for “$1,718,000,000” and “1986” for “1984”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/113"},"text":"Pub. L. 97–113","children":[],"tail":" increased limitation on total principal amount of outstanding guarantees to $1,718,000,000 from $1,555,000,000 and extended termination date for exercise of guarantee authority to "},{"tag":"date","attrib":{"date":"1984-09-30"},"text":"Sept. 30, 1984","children":[],"tail":", from "},{"tag":"date","attrib":{"date":"1982-09-30"},"text":"Sept. 30, 1982","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/53"},"text":"Pub. L. 96–53","children":[],"tail":" substituted “$1,555,000,000” for “$1,180,000,000”, and “through "},{"tag":"date","attrib":{"date":"1982-09-30"},"text":"September 30, 1982","children":[],"tail":"” for “until "},{"tag":"date","attrib":{"date":"1980-09-30"},"text":"September 30, 1980","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/424"},"text":"Pub. L. 95–424","children":[],"tail":" amended section generally to provide a new consolidated section which provides a single authorization for the worldwide housing guarantee program, a new list of the types of programs to be emphasized, increased the worldwide authorization to $1,180,000,000, and encourages officials and governments in developing countries to consider the use of solar energy in housing projects."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/88"},"text":"Pub. L. 95–88","children":[],"tail":" inserted “or under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2181"},"text":"section 2181 of this title","children":[],"tail":"” after “Latin American housing guaranty authority repealed by the Foreign Assistance Act of 1969” and substituted “$1,030,000,000” for “$600,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/161"},"text":"Pub. L. 94–161","children":[],"tail":" substituted “$600,000,000” for “$550,000,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f63b05e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8f63b05f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/83"},"text":"Pub. L. 99–83","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1985-10-01"},"text":"Oct. 1, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/83/s1301"},"text":"section 1301 o