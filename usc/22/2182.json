{"tag":"section","attrib":{"id":"id8f613f4d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2182"},"text":null,"children":[{"tag":"num","attrib":{"value":"2182"},"text":"§ 2182.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization for worldwide shelter guarantees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f613f4e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2182/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization to issue guarantees to eligible investors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out the policy of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2181"},"text":"section 2181 of this title","children":[],"tail":", the President is authorized to issue guaranties to eligible investors (as defined in section 2198(c) "},{"tag":"ref","attrib":{"idref":"fn002105"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002105"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title) assuring against losses incurred in connection with loans made for projects meeting the criteria set forth in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2181"},"text":"section 2181 of this title","children":[],"tail":". The total principal amount of guaranties issued under this subpart or heretofore issued under prior housing guaranty authorities, which are outstanding at any one time, shall not exceed $2,558,000,000. The authority of this section shall continue through "},{"tag":"date","attrib":{"date":"1992-09-30"},"text":"September 30, 1992","children":[],"tail":". The President may issue regulations from time to time with regard to the terms and conditions upon which such guaranties shall be issued and the eligibility of lenders."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f613f4f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2182/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emphasis on certain activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Activities carried out under this section shall emphasize—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f613f50-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2182/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects which provide improved home sites to poor families on which to build shelter, and related services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f613f51-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2182/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects comprised of expandable core shelter units on serviced sites;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f613f52-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2182/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" slum upgrading projects designed to conserve and improve existing shelter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f613f53-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2182/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shelter projects for low-income people designed for demonstration or institution building purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f613f54-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2182/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community facilities and services in support of projects authorized under this section to improve the shelter occupied by the poor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f613f55-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2182/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of solar energy technology","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In issuing guaranties under this section with respect to projects in a country which require the use or conservation of energy, the President shall give consideration to the use of solar energy technologies, where such technologies are economically and technically feasible. Technologies which may be used include solar hot water systems, solar heating and cooling, passive solar heating, biomass conversion, photovoltaic and wind applications, and community-scale solar thermal applications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f613f56-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2182/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002106"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002106"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. No subsecs. (d) to (j) have been enacted."}],"tail":" Minimum annual program levels"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total principal amount of guaranties issued under this section for each of the fiscal years 1986 and 1987 shall be comparable to the total principal amount of such guaranties issued for fiscal year 1984, subject to the dollar limitations on the issuance of guaranties under this section which are contained in subsection (a) and in appropriation Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f613f57-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. I, § 222, as added "},{"tag":"ref","attrib":{"href":"/us/pl/91/175"},"text":"Pub. L. 91–175","children":[],"tail":", pt. I, § 105, "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/807"},"text":"83 Stat. 807","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/161/tIII/s311/4"},"text":"Pub. L. 94–161, title III, § 311(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-20"},"text":"Dec. 20, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/861"},"text":"89 Stat. 861","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/88/tI/s117/a/2"},"text":"Pub. L. 95–88, title I, § 117(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-03"},"text":"Aug. 3, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/540"},"text":"91 Stat. 540","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/424/tI/s115/a"},"text":"Pub. L. 95–424, title I, § 115(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-06"},"text":"Oct. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/950"},"text":"92 Stat. 950","chi