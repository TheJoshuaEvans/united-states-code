{"tag":"section","attrib":{"id":"id90b18dc3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6212"},"text":null,"children":[{"tag":"num","attrib":{"value":"6212"},"text":"§ 6212.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement for authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90b18dc4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6212/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on obligation and expenditure of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, for the fiscal year 1994 and for each subsequent fiscal year, any funds appropriated for the purposes of broadcasting subject to supervision of the Agency shall not be available for obligation or expenditure—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90b18dc5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6212/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unless such funds are appropriated pursuant to an authorization of appropriations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b18dc6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6212/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in excess of the authorized level of appropriations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90b18dc7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6212/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The limitation under subsection (a) shall not apply to the extent that an authorization of appropriations is enacted after such funds are appropriated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90b18dc8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6212/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The provisions of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90b18dc9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6212/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be superseded, except by a provision of law which specifically repeals, modifies, or supersedes the provisions of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b18dca-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6212/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not apply to, or affect in any manner, permanent appropriations, trust funds, and other similar accounts which are authorized by law and administered under or pursuant to this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90b18dcb-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tIII/s313"},"text":"Pub. L. 103–236, title III, § 313","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/444"},"text":"108 Stat. 444","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/228/dA/tV/s507/2"},"text":"Pub. L. 107–228, div. A, title V, § 507(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"Sept. 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1394"},"text":"116 Stat. 1394","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXII/s1299Q/e/9"},"text":"Pub. L. 116–283, div. A, title XII, § 1299Q(e)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4025"},"text":"134 Stat. 4025","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90b18dcc-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90b18dcd-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90b18dce-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (c)(2), was in the original “this title”, meaning title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/432"},"text":"108 Stat. 432","children":[],"tail":", known as the United States International Broadcasting Act of 1994, which is classified principally to this chapter. For complete classification of title III to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6201"},"text":"section 6201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id90b18dcf-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXII/s1299Q/e/9"},"text":"Pub. L. 116–283, div. A, title XII, § 1299Q(e)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4025"},"text":"134 Stat. 4025","children":[],"tail":", which amended this section, was itself amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dO/tXIII/s1301"},"text":"Pub. L. 116–260, div. O, title XIII, § 1301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2158"},"text":"134 Stat. 2158","children":[],"tail":", to make it effective 90 days after "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":". However, the amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" could not be executed because it was enacted before the provision from "},{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" that it amended."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90b18dd0-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “Agency” for “Board” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/228"},"text":"Pub. L. 107–228","children":[],"tail":" struck out “the direction and” after “broadcasting subject to” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90b18dd1-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id90b18dd2-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Continued Availability of Funds Following Repeal of Board for International Broadcasting Act of 1973","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/317/tV"},"text":"Pub. L. 103–317, title V","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-26"},"text":"Aug. 26, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1771"},"text":"108 Stat. 1771","children":[],"tail":", provided in part: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/317/tV"},"text":"“That on the date upon which the Board for International Broadcasting Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2871"},"text":"22 U.S.C. 2871","children":[],"tail":", et seq.) is repealed, as provided for by section 310(e) of the Foreign Relations Authorization Act, fiscal years 1994 and 1995 ("},{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Public Law 103–236","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/108/442"},"text":"108 Stat. 442","children":[],"tail":") [former "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6209/e"},"text":"22 U.S.C. 6209(e)","children":[],"tail":"], funds made available for expenses of the Board for International Broadcasting shall be made available until expended only for expenses necessary to enable the Broadcasting Board of Governors [now United States Agency for Global Media] to carry out the authorities provided in "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/s305/a"},"text":"section 305(a) of Public Law 103–236","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6204/a"},"text":"22 U.S.C. 6204(a)","children":[],"tail":"], including the appointment of staff personnel as authorized by "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/s305/a/11"},"text":"section 305(a)(11) of Public Law 103–236","children":[],"tail":": "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That such amounts appropriated to the Board for International Broadcasting in fiscal year 1994 as are certified by the Office of Management and Budget to the Congress as gains due to the fluctuation of foreign currency, may be used in fiscal year 1995 and thereafter either to offset foreign currency losses or to offset unfunded RFE/RL costs associated with the implementation of "},{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Public Law 103–236","children":[],"tail":" [see Tables for classification]: "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That obligated but unexpended balances appropriated in fiscal year 1990 to fund planned transmitter modernization expenses may be expended in fiscal year 1995 for unfunded RFE/RL costs associated with the implementation of "},{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Public Law 103–236","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
