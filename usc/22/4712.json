{"tag":"section","attrib":{"id":"id907f8022-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4712"},"text":null,"children":[{"tag":"num","attrib":{"value":"4712"},"text":"§ 4712.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding of scholarships for fiscal year 1986 and fiscal year 1987","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id907f8023-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4712/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Central American undergraduate scholarship program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The undergraduate scholarship program financed by the United States Information Agency for students from Central America for fiscal year 1986 and fiscal year 1987 shall be conducted in accordance with this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id907f8024-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4712/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scholarships for students from other developing countries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any funds appropriated to the United States Information Agency for fiscal year 1986 or fiscal year 1987 for any purpose (other than funds appropriated for educational exchange programs under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2452/a/1"},"text":"section 2452(a)(1) of this title","children":[],"tail":" "},{"tag":"ref","attrib":{"idref":"fn002305"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002305"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a closing parenthesis."}],"tail":" may be used to carry out this chapter with respect to students from developing countries outside Central America."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id907f8025-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/93/tVI/s612"},"text":"Pub. L. 99–93, title VI, § 612","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-16"},"text":"Aug. 16, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/443"},"text":"99 Stat. 443","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id907f8026-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id907f8027-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id907f8028-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"United States Information Agency (other than Broadcasting Board of Governors and International Broadcasting Bureau) abolished and functions transferred to Secretary of State, see sections 6531 and 6532 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
