{"tag":"section","attrib":{"id":"id8ebcc266-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285d"},"text":null,"children":[{"tag":"num","attrib":{"value":"285d"},"text":"§ 285d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Reserve banks as depositories","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any Federal Reserve bank which is requested to do so by the Bank shall act as its depository or as its fiscal agent, and the Board of Governors of the Federal Reserve System shall supervise and direct the carrying out of these functions by the Federal Reserve banks.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ebcc267-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/369/s6"},"text":"Pub. L. 89–369, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-03-16"},"text":"Mar. 16, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/72"},"text":"80 Stat. 72","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
