{"tag":"section","attrib":{"id":"id90fb67c0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8422"},"text":null,"children":[{"tag":"num","attrib":{"value":"8422"},"text":"§ 8422.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90fb67c1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8422/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International military education and training","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90fb67c2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8422/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary for each of the fiscal years 2010 through 2014 for assistance under chapter 5 of part II of the Foreign Assistance Act of 1961 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2347"},"text":"22 U.S.C. 2347","children":[],"tail":" et seq.; relating to international military education and training) for Pakistan, including expanded international military education and training (commonly known as “E–IMET”)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90fb67c3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8422/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of Congress that a substantial amount of funds made available to carry out this subsection for a fiscal year should be used to pay for courses of study and training in counterinsurgency and civil-military relations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90fb67c4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8422/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign Military Financing program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90fb67c5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8422/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary for each of the fiscal years 2010 through 2014 for grant assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2763"},"text":"section 2763 of this title","children":[],"tail":" (relating to the Foreign Military Financing program) for the purchase of defense articles, defense services, and military education and training for Pakistan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90fb67c6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8422/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90fb67c7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8422/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A significant portion of the amount made available to carry out this subsection for a fiscal year shall be for the purchase of defense articles, defense services, and military education and training for activities relating to counterinsurgency and counterterrorism operations in Pakistan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90fb67c8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8422/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of Congress that a significant majority of funds made available to carry out this subsection for a fiscal year should be used for the purpose described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90fb67c9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8422/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in sections 2753 and 2799aa–1 of this title, the second section 620J ","children":[{"tag":"ref","attrib":{"idref":"fn002404"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002404"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the Foreign Assistance Act of 1961 (as added by "},{"tag":"ref","attrib":{"href":"/us/pl/110/161"},"text":"Public Law 110–161","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2378d"},"text":"22 U.S.C. 2378d","children":[],"tail":"], and any provision of an Act making appropriations for the Department of State, foreign operations, and related programs that restricts assistance to the government of any country whose duly elected head of government is deposed by military coup or decree, and except as otherwise provided in this subchapter, amounts authorized to be made available to carry out paragraph (2) for fiscal years 2010 and 2011 are authorized to be made available notwithstanding any other provision of law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90fb67ca-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8422/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the terms “defense articles”, “defense services”, and “military education and training” have the meaning given such terms in section 644 of the Foreign Assistance Act of 1961 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2403"},"text":"22 U.S.C. 2403","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90fb67cb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8422/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of Congress that the United States should facilitate Pakistan’s establishment of a program to provide reconstruction assistance, including through Pakistan’s military as appropriate, in areas damaged by combat operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90fb67cc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8422/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exchange program between military and civilian personnel of Pakistan and certain other countries","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90fb67cd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8422/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State is authorized to establish an exchange program between—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90fb67ce-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8422/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" military and civilian personnel of Pakistan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90fb67cf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8422/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90fb67d0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8422/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" military and civilian personnel of countries determined by the Secretary of State to be in the process of consolidating and strengthening a democratic form of government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90fb67d1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8422/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" military and civilian personnel of North Atlantic Treaty Organization member countries,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"in order to foster greater mutual respect for and understanding of the principle of civilian rule of the military.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90fb67d2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8422/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements of program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The program authorized under paragraph (1) may include conferences, seminars, exchanges, and other events, distribution of publications and reimbursements of expenses of foreign military personnel participating in the program, including transportation, translation and administrative expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90fb67d3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8422/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Role of nongovernmental organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts authorized to be appropriated to carry out this section for a fiscal year are authorized to be made available for nongovernmental organizations to facilitate the implementation of the program authorized under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90fb67d4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8422/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary for each of the fiscal years 2010 through 2014 to carry out the program established by this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90fb67d5-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/73/tII/s202"},"text":"Pub. L. 111–73, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-15"},"text":"Oct. 15, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2069"},"text":"123 Stat. 2069","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90fb67d6-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90fb67d7-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90fb67d8-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Foreign Assistance Act of 1961, referred to in subsec. (a)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/424"},"text":"75 Stat. 424","children":[],"tail":". Chapter 5 of part II of the Act is classified generally to part V (§ 2347 et seq.) of subchapter II of chapter 32 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The second section 620J of the Foreign Assistance Act of 1961 (as added by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161"},"text":"Public Law 110–161","children":[],"tail":"), referred to in subsec. (b), which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2378d"},"text":"section 2378d of this title","children":[],"tail":", was renumbered section 620M of the Foreign Assistance Act of 1961 by "},{"tag":"ref","attrib":{"href":"/us/pl/112/74/dI/tVII/s7034/k/1"},"text":"Pub. L. 112–74, div. I, title VII, § 7034(k)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-23"},"text":"Dec. 23, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1216"},"text":"125 Stat. 1216","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
