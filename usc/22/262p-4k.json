{"tag":"section","attrib":{"id":"id8e9dc8e5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–4k"},"text":null,"children":[{"tag":"num","attrib":{"value":"262p–4k"},"text":"§ 262p–4k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotion of institution-building for nongovernmental organizations concerned with environment","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Treasury shall instruct the United States Executive Directors of the multilateral development banks to vigorously promote the adoption of policies and procedures which seek to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8e9dc8e6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–4k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase collaboration with, and, where necessary, strengthen, nongovernmental organizations in such countries which are concerned with environmental protection by providing appropriate assistance and support for programs and activities on environmental protection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e9dc8e7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–4k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage international collaboration for information exchange and project enhancement with nongovernmental organizations in developing countries which are concerned with environmental protection and government agencies and private voluntary organizations in developed countries which are concerned with environmental protection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8e9dc8e8-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/118/tXVI/s1616"},"text":"Pub. L. 95–118, title XVI, § 1616","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/240/tV/s512"},"text":"Pub. L. 101–240, title V, § 512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2510"},"text":"103 Stat. 2510","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8e9dc8e9-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8e9dc8ea-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id8e9dc8eb-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The definitions in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s262p–5"},"text":"section 262p–5 of this title","children":[],"tail":" apply to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
