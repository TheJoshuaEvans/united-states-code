{"tag":"section","attrib":{"id":"id8f5a144c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152d"},"text":null,"children":[{"tag":"num","attrib":{"value":"2152d"},"text":"§ 2152d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to foreign countries to meet minimum standards for the elimination of trafficking","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f5a144d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President is authorized to provide assistance to foreign countries directly, or through nongovernmental and multilateral organizations, for programs, projects, and activities designed to meet the minimum standards for the elimination of trafficking (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7102"},"text":"section 7102 of this title","children":[],"tail":"), including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f5a144e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the drafting of laws to prohibit and punish acts of trafficking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f5c844f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the investigation and prosecution of traffickers, including investigation of individuals and entities that may be involved in trafficking in persons involving sexual exploitation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f5c8450-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152d/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the creation and maintenance of facilities, programs, projects, and activities for the protection of victims; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f5c8451-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152d/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expansion of exchange programs and international visitor programs for governmental and nongovernmental personnel to combat trafficking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f5c8452-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts made available to carry out the other provisions of subchapter I of this chapter (including part IV of subchapter II of this chapter) and the Support for East European Democracy (SEED) Act of 1989 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s5401"},"text":"22 U.S.C. 5401","children":[],"tail":" et seq.] shall be made available to carry out this section. Assistance may be provided under this section notwithstanding "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2420"},"text":"section 2420 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f5c8453-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. I, § 134, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/386/dA/s109"},"text":"Pub. L. 106–386, div. A, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1481"},"text":"114 Stat. 1481","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/193/s6/f"},"text":"Pub. L. 108–193, § 6(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2883"},"text":"117 Stat. 2883","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/457/tI/s103/b"},"text":"Pub. L. 110–457, title I, § 103(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-12-23"},"text":"Dec. 23, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/5046"},"text":"122 Stat. 5046","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f5c8454-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f5c8455-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8f5c8456-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Support for East European Democracy (SEED) Act of 1989, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/179"},"text":"Pub. L. 101–179","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-28"},"text":"Nov. 28, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1298"},"text":"103 Stat. 1298","children":[],"tail":", which is classified principally to chapter 63 (§ 5401 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s5401"},"text":"section 5401 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f5c8457-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/457"},"text":"Pub. L. 110–457","children":[],"tail":" inserted “, including investigation of individuals and entities that may be involved in trafficking in persons involving sexual exploitation” before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/193"},"text":"Pub. L. 108–193","children":[],"tail":" inserted at end “Assistance may be provided under this section notwithstanding "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2420"},"text":"section 2420 of this title","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f5c8458-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8f5c8459-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References to Subchapter I Deemed To Include Certain Parts of Subchapter II","children":[],"tail":null},{"tag":"p","attrib":{},"text":"References to subchapter I of this chapter are deemed to include parts IV (§ 2346 et seq.), VI (§ 2348 et seq.), and VIII (§ 2349aa et seq.) of subchapter II of this chapter, and references to subchapter II are deemed to exclude such parts. See ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/226/s202/b"},"text":"section 202(b) of Pub. L. 92–226","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2346"},"text":"section 2346 of this title","children":[],"tail":", and sections 2348c and 2349aa–5 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id8f5c845a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id8f5c845b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions of President under this section, see Ex. Ord. No. 12163, ","children":[{"tag":"date","attrib":{"date":"1979-09-29"},"text":"Sept. 29, 1979","children":[],"tail":", 44 F.R. 56673, as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2381"},"text":"section 2381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
