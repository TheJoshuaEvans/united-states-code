{"tag":"section","attrib":{"id":"id8f745201-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2282"},"text":null,"children":[{"tag":"num","attrib":{"value":"2282"},"text":"§ 2282.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance for commercial debt exchanges","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f745202-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2282/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of the Agency for International Development is authorized to furnish assistance, in the form of grants on such terms and conditions as may be necessary, to nongovernmental organizations for the purchase on the open market of discounted commercial debt of a foreign government of an eligible country which will be canceled or redeemed under the terms of an agreement with that government as part of a debt-for-nature exchange.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f745203-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2282/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, a grantee (or any subgrantee) of the grants referred to in subsection (a) may retain, without deposit in the Treasury of the United States and without further appropriation by Congress, interest earned on the proceeds of any resulting debt-for-nature exchange pending the disbursements of such proceeds and interest for approved program purposes, which may include the establishment of an endowment, the income of which is used for such purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f745204-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. I, § 462 [472], as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/240/tVII/s711"},"text":"Pub. L. 101–240, title VII, § 711","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2521"},"text":"103 Stat. 2521","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f745205-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f745206-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8f745207-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195/s462"},"text":"section 462 of Pub. L. 87–195","children":[],"tail":" is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2272"},"text":"section 2272 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
