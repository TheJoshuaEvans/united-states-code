{"tag":"section","attrib":{"id":"id8eb807ed-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283v"},"text":null,"children":[{"tag":"num","attrib":{"value":"283v"},"text":"§ 283v.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loans to the Caribbean Development Bank","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The United States Governor of the Bank is authorized to agree to the amendments to article III, sections 1, 4, and 6(b) of the Agreement Establishing the Bank, as proposed by the Board of Executive Directors, to provide for lending to the Caribbean Development Bank.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8eb807ee-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/147/s25"},"text":"Pub. L. 86–147, § 25","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/302/tI/s103/a/1"},"text":"Pub. L. 94–302, title I, § 103(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-05-31"},"text":"May 31, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/592"},"text":"90 Stat. 592","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
