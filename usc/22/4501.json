{"tag":"section","attrib":{"id":"id907a9eaf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4501"},"text":null,"children":[{"tag":"num","attrib":{"value":"4501"},"text":"§ 4501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and declarations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress finds and declares that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id907a9eb0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4501/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" factual knowledge, independently verified, about the countries of Eastern Europe and the independent states of the former Soviet Union is of the utmost importance for the national security of the United States, for the furtherance of our national interests in the conduct of foreign relations, and for the prudent management of our domestic affairs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id907a9eb1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4501/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and maintenance of knowledge about the countries of Eastern Europe and the independent states of the former Soviet Union depends upon the national capability for advanced research by highly trained and experienced specialists, available for service in and out of Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id907a9eb2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4501/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" certain essential functions are necessary to ensure the existence of that knowledge and the capability to sustain it, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id907a9eb3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4501/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" graduate training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id907a9eb4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4501/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id907a9eb5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4501/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public dissemination of research data, methods, and findings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id907a9eb6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4501/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contact and collaboration among Government and private specialists; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id907a9eb7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4501/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" firsthand experience of the countries of Eastern Europe and the independent states of the former Soviet Union by American specialists, including on site conduct of advanced training and research to the extent practicable; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id907a9eb8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4501/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is in the national interest for the United States Government to provide a stable source of financial support for the functions described in this section and to supplement the financial support for those functions which is currently being furnished by Federal, State, local, regional, and private agencies, organizations, and individuals, and thereby to stabilize the conduct of these functions on a national scale, consistently, and on a long range unclassified basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id907a9eb9-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/164/tVIII/s802"},"text":"Pub. L. 98–164, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-11-22"},"text":"Nov. 22, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1047"},"text":"97 Stat. 1047","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/199/tIII/s302/3"},"text":"Pub. L. 103–199, title III, § 302(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-17"},"text":"Dec. 17, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2322"},"text":"107 Stat. 2322","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id907a9eba-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id907a9ebb-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id907a9ebc-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Pars. (1), (2), (3)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/199"},"text":"Pub. L. 103–199","children":[],"tail":" substituted “countries of Eastern Europe and the independent states of the former Soviet Union” for “Soviet Union and Eastern European countries”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id907a9ebd-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id907a9ebe-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/164/tVIII/s801"},"text":"Pub. L. 98–164, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-11-22"},"text":"Nov. 22, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1047"},"text":"97 Stat. 1047","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/103/199/tIII/s302/2"},"text":"Pub. L. 103–199, title III, § 302(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-17"},"text":"Dec. 17, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2322"},"text":"107 Stat. 2322","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/199/tIII/s302/2"},"text":"“This title [enacting this chapter] may be cited as the ‘Research and Training for Eastern Europe and the Independent States of the Former Soviet Union Act of 1983’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id907a9ebf-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In pars. (1), (2), and (3)(E), independent states of the former Soviet Union has the meaning given in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s5801"},"text":"section 5801 of this title","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/199/s3"},"text":"section 3 of Pub. L. 103–199","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s5801"},"text":"section 5801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
