{"tag":"section","attrib":{"id":"id8e969c63-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262n–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"262n–3"},"text":"§ 262n–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction of barriers to agricultural trade","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall instruct the United States Executive Director at the International Monetary Fund to use aggressively the voice and vote of the United States to vigorously promote policies to encourage the opening of markets for agricultural commodities and products by requiring recipient countries to make efforts to reduce trade barriers.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8e969c64-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/118/tXIV/s1404"},"text":"Pub. L. 95–118, title XIV, § 1404","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/d/tVI/s611"},"text":"Pub. L. 105–277, div. A, § 101(d) [title VI, § 611]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-150"},"text":"112 Stat. 2681–150","children":[],"tail":", 2681–228.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8e969c65-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8e969c66-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id8e969c67-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The definitions in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s262p–5"},"text":"section 262p–5 of this title","children":[],"tail":" apply to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
