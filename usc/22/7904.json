{"tag":"section","attrib":{"id":"id90f1f21f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7904"},"text":null,"children":[{"tag":"num","attrib":{"value":"7904"},"text":"§ 7904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trade-related barriers to export of greenhouse gas intensity reducing technologies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90f1f220-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7904/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the United States Trade Representative shall (as appropriate and consistent with applicable bilateral, regional, and mutual trade agreements)—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90f1f221-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7904/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify trade-relations barriers maintained by foreign countries to the export of greenhouse gas intensity reducing technologies and practices from the United States to the developing countries identified in the report submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7902/a/2/A"},"text":"section 7902(a)(2)(A) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f1f222-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7904/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" negotiate with foreign countries for the removal of those barriers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90f1f223-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after the date on which a report is submitted under subsection (a)(1) and annually thereafter, the United States Trade Representative shall submit to Congress a report that describes any progress made with respect to removing the barriers identified by the United States Trade Representative under subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90f1f224-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/240/tVII/s734"},"text":"Pub. L. 101–240, title VII, § 734","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXVI/s1611"},"text":"Pub. L. 109–58, title XVI, § 1611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1115"},"text":"119 Stat. 1115","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90f1f225-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90f1f226-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id90f1f227-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2005-10-01"},"text":"Oct. 1, 2005","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/240/s739"},"text":"section 739 of Pub. L. 101–240","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7901"},"text":"section 7901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
