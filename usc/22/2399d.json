{"tag":"section","attrib":{"id":"id8fb72736-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2399d"},"text":null,"children":[{"tag":"num","attrib":{"value":"2399d"},"text":"§ 2399d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Shipping differential","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purpose of facilitating implementation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s55305"},"text":"section 55305 of title 46","children":[],"tail":", funds made available for the purposes of part I of subchapter I of this chapter or for purposes of part IV of subchapter II of this chapter may be used to make grants to recipients to pay all or any portion of such differential as is determined by the Secretary of Commerce to exist between United States and foreign-flag vessel charter or freight rates. Grants made under this section shall be paid with United States-owned foreign currencies wherever feasible."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8fb72737-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. III, § 640C, as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/189/s21"},"text":"Pub. L. 93–189, § 21","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-17"},"text":"Dec. 17, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/726"},"text":"87 Stat. 726","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/533/tVII/s708"},"text":"Pub. L. 96–533, title VII, § 708","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-16"},"text":"Dec. 16, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3159"},"text":"94 Stat. 3159","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fb72738-2930-11f1-8918