{"tag":"section","attrib":{"id":"id90c4a0fe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6812"},"text":null,"children":[{"tag":"num","attrib":{"value":"6812"},"text":"§ 6812.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" African crisis response initiative and HIV/AIDS training","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90c4a0ff-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6812/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90c4a100-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6812/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the spread of HIV/AIDS constitutes a threat to security in Africa;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90c4a101-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6812/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" civil unrest and war may contribute to the spread of the disease to different parts of the continent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90c4a102-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6812/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage of soldiers in African militaries who are infected with HIV/AIDS is unknown, but estimates range in some countries as high as 40 percent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90c4a103-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6812/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is in the interests of the United States to assist the countries of Africa in combating the spread of HIV/AIDS.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90c4a104-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6812/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education on the prevention of the spread of AIDS","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In undertaking education and training programs for military establishments in African countries, the United States shall ensure that classroom training under the African Crisis Response Initiative includes military-based education on the prevention of the spread of AIDS.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90c4a105-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/264/tI/s114"},"text":"Pub. L. 106–264, title I, § 114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-08-19"},"text":"Aug. 19, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/754"},"text":"114 Stat. 754","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
