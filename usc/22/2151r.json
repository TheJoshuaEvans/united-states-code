{"tag":"section","attrib":{"id":"id8f57c944-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2151r"},"text":null,"children":[{"tag":"num","attrib":{"value":"2151r"},"text":"§ 2151r.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sahel development program; planning","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f57c945-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2151r/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Congress reaffirms its support of the initiative of the United States Government in undertaking consultations and planning with the countries concerned, with other nations providing assistance, with the United Nations, and with other concerned international and regional organizations, toward the development and support of a comprehensive long-term African Sahel development program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f57c946-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2151r/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presidential authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President is authorized to develop a long-term comprehensive development program for the Sahel and other drought-stricken nations in Africa.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f57c947-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2151r/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presidential guidelines","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing this long-term program, the President shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f57c948-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2151r/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider international coordination for the planning and implementation of such program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f57c949-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2151r/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek greater participation and support by African countries and organizations in determining development priorities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f57c94a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2151r/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" begin such planning immediately.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f57c94b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. I, § 120, formerly pt. III, § 639B, as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/189/s20"},"text":"Pub. L. 93–189, § 20","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-17"},"text":"Dec. 17, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/725"},"text":"87 Stat. 725","children":[],"tail":"; renumbered pt. I, § 494B and amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/161/tI/s101/5"},"text":"Pub. L. 94–161, title I, § 101(5)","childr