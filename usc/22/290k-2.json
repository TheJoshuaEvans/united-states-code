{"tag":"section","attrib":{"id":"id8ee2e7cf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290k–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"290k–2"},"text":"§ 290k–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Instructions for United States Director","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Immediately after taking office and prior to the issuance by the Agency of its first guarantee, the United States Director of the Agency shall propose and actively seek the adoption by the Board of Directors of policies and procedures under which the Agency will not issue guarantees in respect of any proposed investment that would—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ee2e7d0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290k–2/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be in any country which has not taken or is not taking steps to afford internationally recognized workers’ rights to workers in that country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ee2e7d1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290k–2/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be subject to trade-distorting performance requirements imposed by the host country that are likely to result in a significant net reduction in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ee2e7d2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290k–2/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employment in the United States or other member countries; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ee2e7d3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290k–2/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other trade benefits likely to accrue to the United States or other member countries from the investment; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ee2e7d4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290k–2/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase a country’s productive capacity in an industry already facing excess worldwide capacity for the same, similar or competing product, and cause substantial injury to producers of such product in another member country.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ee2e7d5-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/e/tI"},"text":"Pub. L. 100–202, § 101(e) [title I]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-131"},"text":"101 Stat. 1329–131","children":[],"tail":", 1329–134.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ee2e7d6-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ee2e7d7-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8ee2e7d8-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on section 405 of title IV of H.R. 3750, One Hundredth Congress, as introduced ","children":[{"tag":"date","attrib":{"date":"1987-12-11"},"text":"Dec. 11, 1987","children":[],"tail":", and enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
