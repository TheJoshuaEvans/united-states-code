{"tag":"section","attrib":{"id":"id911cd247-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9125"},"text":null,"children":[{"tag":"num","attrib":{"value":"9125"},"text":"§ 9125.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of actions by the Secretary of State","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Any specific action taken under this Act or any amendment made by this Act with respect to a foreign country shall terminate on the date on which the Secretary of State submits a written certification to Congress that the government of such country—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id911cd248-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9125/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has resolved any unresolved abduction case that gave rise to such specific action; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911cd249-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9125/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has taken substantial and verifiable steps to correct such country’s persistent pattern of noncompliance that gave rise to such specific action, as applicable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id911cd24a-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/150/tII/s205"},"text":"Pub. L. 113–150, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-08-08"},"text":"Aug. 8, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1821"},"text":"128 Stat. 1821","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id911cd24b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id911cd24c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id911cd24d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/150"},"text":"Pub. L. 113–150","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-08-08"},"text":"Aug. 8, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1807"},"text":"126 Stat. 1807","children":[],"tail":", known as the Sean and David Goldman International Child Abduction Prevention and Return Act of 2014, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s9101"},"text":"section 9101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
