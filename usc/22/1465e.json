{"tag":"section","attrib":{"id":"id8f04527a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1465e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1465e"},"text":"§ 1465e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation for Cuban interference with broadcasting in United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f04527b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1465e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interim assistance to United States broadcasters","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the intent of the Congress that the Secretary of State should seek prompt and full settlement of United States claims against the Government of Cuba arising from Cuban interference with broadcasting in the United States. Pending the settlement of these claims, it is appropriate to provide some interim assistance to the United States broadcasters who are adversely affected by Cuban radio interference and who seek to assert their right to measures to counteract the effects of such interference.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f04527c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1465e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Money payments pursuant to authority from Federal Communications Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Accordingly, the Board may make payments to the United States radio broadcasting station licensees upon their application for expenses which they have incurred before, on, or after ","children":[{"tag":"date","attrib":{"date":"1983-10-04"},"text":"October 4, 1983","children":[],"tail":", in mitigating, pursuant to special temporary authority from the Federal Communications Commission, the effects of activities by the Government of Cuba which directly interfere with the transmission or reception of broadcasts by these licensees. Such expenses shall be limited to the costs of equipment replaced (less depreciation) and associated technical and engineering costs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f04527d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1465e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations and procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal Communications Commission shall issue such regulations and establish such procedures for carrying out this section as the Federal Communications Commission finds appropriate. Such regulations shall be issued no later than one hundred and eighty days after ","children":[{"tag":"date","attrib":{"date":"1983-10-04"},"text":"October 4, 1983","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f04527e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1465e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Board, $5,000,000 for use in compensating United States radio broadcasting licensees pursuant to this section. Amounts appropriated under this section are authorized to be available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f04527f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1465e/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Four-year availability for appropriated funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds appropriated for implementation of this section shall be available for a period of no more than four years following the initial broadcast occurring as a result of programs described in this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f045280-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1465e/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presidential task force","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of the Congress that the President should establish a task force to analyze the level of interference from the operation of Cuban radio stations experienced by broadcasters in the United States and to seek a practical political and technical solution to this problem.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f045281-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1465e/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective Date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall enter into effect on ","children":[{"tag":"date","attrib":{"date":"1984-10-01"},"text":"October 1, 1984","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f045282-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/111/s7"},"text":"Pub. L. 98–111, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-10-04"},"text":"Oct. 4, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/752"},"text":"97 Stat. 752","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/411/tV/s512"},"text":"Pub. L. 98–411, title V, § 512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-08-30"},"text":"Aug. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1574"},"text":"98 Stat. 1574","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. A, title XIII, § 1324(2), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-781"},"text":"112 Stat. 2681–781","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f045283-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id8f045284-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeal of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section repealed upon transmittal of determination by President under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6063/c/3"},"text":"section 6063(c)(3) of this title","children":[],"tail":" that democratically elected government in Cuba is in power, see "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6037/c"},"text":"section 6037(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f045285-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8f045286-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Radio Broadcasting to Cuba Act which comprises this subchapter, and not as part of the United States Information and Educational Exchange Act of 1948 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f045287-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsecs. (b), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" substituted “Board” for “Agency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/411"},"text":"Pub. L. 98–411","children":[],"tail":" substituted “replaced (less” for “(replaced less”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f045288-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8f045289-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1999-10-01"},"text":"Oct. 1, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1301"},"text":"section 1301 of Pub. L. 105–277","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6531"},"text":"section 6531 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
