{"tag":"section","attrib":{"id":"id8fbe539f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430h"},"text":null,"children":[{"tag":"num","attrib":{"value":"2430h"},"text":"§ 2430h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enterprise for the Americas Board","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter, the Enterprise for the Americas Board shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fbe53a0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the Secretary of State on the negotiations of Americas Framework Agreements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe53a1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure, in consultation with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fbe53a2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the government of the beneficiary country,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fbe53a3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nongovernmental organizations of the beneficiary country,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fbe53a4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430h/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nongovernmental organizations of the region (if appropriate),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fbe53a5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430h/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environmental, scientific, child survival and child development, and academic leaders of the beneficiary country, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fbe53a6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430h/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environmental, scientific, child survival and child development, and academic leaders of the region (as appropriate),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"that a suitable administering body is identified for each Americas Fund; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe53a7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the programs, operations, and fiscal audits of each administering body.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fbe53a8-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. IV, § 709, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/549/tVI/s602/a"},"text":"Pub. L. 102–549, title VI, § 602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3668"},"text":"106 Stat. 3668","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fbe53a9-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8fbe53aa-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id8fbe53ab-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195/s709"},"text":"section 709 of Pub. L. 87–195","children":[],"tail":", pt. IV, "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/465"},"text":"75 Stat. 465","children":[],"tail":", amended "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s279a"},"text":"section 279a of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/87/565"},"text":"Pub. L. 87–565","children":[],"tail":", pt. IV, § 401, "},{"tag":"date","attrib":{"date":"1962-08-01"},"text":"Aug. 1, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/263"},"text":"76 Stat. 263","children":[],"tail":", except insofar as section 709 affected section 279a."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
