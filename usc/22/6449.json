{"tag":"section","attrib":{"id":"id90bb0418-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6449"},"text":null,"children":[{"tag":"num","attrib":{"value":"6449"},"text":"§ 6449.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of Presidential actions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Any Presidential action taken under this chapter with respect to a foreign country shall terminate on the earlier of the following dates:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90bb0419-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6449/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 2 years of the effective date of the Presidential action unless expressly reauthorized by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bb041a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6449/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign government actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the determination by the President, in consultation with the Commission, and certification to Congress that the foreign government has ceased or taken substantial and verifiable steps to cease the particularly severe violations of religious freedom.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90bb041b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/292/tIV/s409"},"text":"Pub. L. 105–292, title IV, § 409","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-27"},"text":"Oct. 27, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2809"},"text":"112 Stat. 2809","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90bb041c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90bb041d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90bb041e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/292"},"text":"Pub. L. 105–292","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-27"},"text":"Oct. 27, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2787"},"text":"112 Stat. 2787","children":[],"tail":", known as the International Religious Freedom Act of 1998, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6401"},"text":"section 6401 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
