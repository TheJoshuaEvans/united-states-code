{"tag":"section","attrib":{"id":"id905479ee-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4004"},"text":null,"children":[{"tag":"num","attrib":{"value":"4004"},"text":"§ 4004.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id905479ef-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4004/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The records described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4003/a"},"text":"section 4003(a) of this title","children":[],"tail":" shall be maintained in accordance with regulations prescribed by the Secretary. Except to the extent that they pertain to the receipt, disbursement, and accounting for public funds, such records shall be confidential and subject to inspection only by the President, the Secretary, such employees of the Government as may be authorized by law or assigned by the Secretary to work on such records, the legislative and appropriations committees of the Congress charged with considering legislation and appropriations for the Service, and representatives duly authorized by such committees. Access to such records relating to a member of the Service shall be granted to such member, upon written request."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id905479f0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4004/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding subsection (a), any record of disciplinary action that includes a suspension of more than five days taken against a member of the Service, including any correction of that record under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4137/b/1"},"text":"section 4137(b)(1) of this title","children":[],"tail":", shall remain a part of the personnel records until the member is tenured as a career member of the Service or next promoted."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id905479f1-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s604"},"text":"Pub. L. 96–465, title I, § 604","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2096"},"text":"94 Stat. 2096","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/7/dA/tIII/s327/a"},"text":"Pub. L. 106–113, div. B, § 1000(a)(7) [div. A, title III, § 327(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–438.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id905479f2-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id905479f3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id905479f4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":", in section catchline, substituted “Records” for “Confidentiality of records”, designated existing provisions as subsec. (a), and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id905479f5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id905479f6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1999 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/7/dA/tIII/s327/b"},"text":"Pub. L. 106–113, div. B, § 1000(a)(7) [div. A, title III, § 327(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–438, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/113/dB/s1000/a/7/dA/tIII/s327/b"},"text":"“The amendments made by this section [amending this section] apply to all disciplinary actions initiated on or after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
