{"tag":"section","attrib":{"id":"id8f280736-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1945"},"text":null,"children":[{"tag":"num","attrib":{"value":"1945"},"text":"§ 1945.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utilization of funds for assistance in Latin America; availability for transportation of immigrants from Ryukyuan Archipelago","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f280737-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1945/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds appropriated under sections 1943 and 1944 of this title may be used for assistance under sections 1942 to 1945 of this title pursuant to such provisions applicable to the furnishing of such assistance contained in any successor Act to the Mutual Security Act of 1954, as amended, as the President determines to be necessary to carry out the purposes for which such funds are appropriated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f280738-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1945/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Of the funds appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s1943"},"text":"section 1943 of this title","children":[],"tail":" not more than $800,000 shall be available only for assisting in transporting to and settling in Latin America selected immigrants from that portion of the Ryukyuan Archipelago under United States administration."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f280739-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/735/s4"},"text":"Pub. L. 86–735, § 4","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/87/1