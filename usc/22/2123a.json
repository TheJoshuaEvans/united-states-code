{"tag":"section","attrib":{"id":"id8f31a39b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2123a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2123a"},"text":"§ 2123a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f31a39c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2123a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Office of Travel and Tourism Industries shall expand and continue its research and development activities in connection with the promotion of international travel to the United States, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f31a39d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2123a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expanding access to the official Mexican travel surveys data to provide the States with traveler characteristics and visitation estimates for targeted marketing programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f31a39e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2123a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expanding the number of inbound air travelers sampled by the Commerce Department’s Survey of International Travelers to reach a 1 percent sample size and revising the design and format of questionnaires to accommodate a new survey instrument, improve response rates to at least double the number of States and cities with reliable international visitor estimates and improve market coverage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f31a39f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2123a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing estimates of international travel exports (expenditures) on a State-by-State basis to enable each State to compare its comparative position to national totals and other States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f31a3a0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2123a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the success of the Corporation in achieving its objectives and carrying out the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2131"},"text":"section 2131 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f31a3a1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2123a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research to support the annual reports required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2123/d"},"text":"section 2123(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f31a3a2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2123a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary of Commerce for fiscal years 2010 through 2014 such sums as may be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f31a3a3-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/63/tII/s203"},"text":"Pub. L. 87–63, title II, § 203","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/145/s9/j"},"text":"Pub. L. 111–145, § 9(j)","children":[],"tail":", formerly § 9(h), "},{"tag":"date","attrib":{"date":"2010-03-04"},"text":"Mar. 4, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/64"},"text":"124 Stat. 64","children":[],"tail":"; renumbered 9(j), "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dB/tVI/s606/1"},"text":"Pub. L. 113–235, div. B, title VI, § 606(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2219"},"text":"128 Stat. 2219","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f31a3a4-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f31a3a5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id8f31a3a6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2123a, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/63/tII/s203"},"text":"Pub. L. 87–63, title II, § 203","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/372/s8/a"},"text":"Pub. L. 102–372, § 8(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-09-30"},"text":"Sept. 3