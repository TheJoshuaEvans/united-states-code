{"tag":"section","attrib":{"id":"id8fdd4ca2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2621"},"text":null,"children":[{"tag":"num","attrib":{"value":"2621"},"text":"§ 2621.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fdd4ca3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2621/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “person” includes every person who occupies an office or a position in the Government of the United States, its territories and possessions, the Canal Zone government, and the government of the District of Columbia, or is a member of the Armed Forces of the United States, or a member of the family and household of any such person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fdd4ca4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2621/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “foreign government” includes every foreign government and every official, agent, or representative thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fdd4ca5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2621/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “gift” includes any present or thing, other than a decoration, tendered by or received from a foreign government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fdd4ca6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2621/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “decoration” includes any order, device, medal, badge, insignia, or emblem tendered by or received from a foreign government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fdd4ca7-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/673/s2"},"text":"Pub. L. 89–673, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-15"},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/952"},"text":"80 Stat. 952","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fdd4ca8-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8fdd4ca9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id8fdd4caa-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/673/s1"},"text":"Pub. L. 89–673, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-15"},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/952"},"text":"80 Stat. 952","children":[],"tail":", which provided that "},{"tag":"ref","attrib":{"href":"/us/pl/89/673"},"text":"Pub. L. 89–673","children":[],"tail":", enacting this chapter, amending "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s804"},"text":"section 804 of this title","children":[],"tail":", and repealing sections 114, 115, and 115a of former Title 5, Executive Departments and Government Officers and Employees, could be cited as the “Foreign Gifts and Decorations Act of 1966”, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/90/83/s10/b"},"text":"Pub. L. 90–83, § 10(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-09-11"},"text":"Sept. 11, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/224"},"text":"81 Stat. 224","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s7342"},"text":"section 7342 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8fdd4cab-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeal of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section was repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/83/s10/b"},"text":"Pub. L. 90–83, § 10(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-09-11"},"text":"Sept. 11, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/224"},"text":"81 Stat. 224","children":[],"tail":", except insofar as it applies to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2625"},"text":"section 2625 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
