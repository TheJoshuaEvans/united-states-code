{"tag":"section","attrib":{"id":"id8f95bc99-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2349b"},"text":"§ 2349b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver authorities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f95bc9a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Efficient and timely completion of authorized construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of the Congress that the President should take all necessary measures consistent with law to insure the efficient and timely completion of the construction authorized by this part, including the exercise of authority vested in him by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2393/a"},"text":"section 2393(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f95bc9b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds to pay for personal services abroad","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of paragraph (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2396/a"},"text":"section 2396(a) of this title","children":[],"tail":" shall be applicable to the use of funds available to carry out this part, except that no more than sixty persons may be engaged at any one time under that paragraph for purposes of this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id