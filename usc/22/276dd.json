{"tag":"section","attrib":{"id":"id8eae6a42-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276dd"},"text":null,"children":[{"tag":"num","attrib":{"value":"276dd"},"text":"§ 276dd.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Income from property covered into Treasury; disbursement and investment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The income from any property held or administered by the board, as and when collected, shall be deposited in the Treasury of the United States to the credit of the trust fund established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s276bb"},"text":"section 276bb of this title","children":[],"tail":", and it shall be and remain subject to investment, reinvestment, and disbursement by the board for the uses and purposes set forth herein."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8eae6a43-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-07-02/ch228/s4"},"text":"July 2, 1945, ch. 228, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/59/317"},"text":"59 Stat. 317","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8eae6a44-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8eae6a45-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8eae6a46-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s227"},"text":"section 227 of Title 5","children":[],"tail":" prior to the general revision and enactment of Title 5, Government Organization and Employees, by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s1"},"text":"Pub. L. 89–554, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/378"},"text":"80 Stat. 378","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
