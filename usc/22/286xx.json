{"tag":"section","attrib":{"id":"id8ecb1a9c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286xx"},"text":null,"children":[{"tag":"num","attrib":{"value":"286xx"},"text":"§ 286xx.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quota increase","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ecb1a9d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286xx/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States Governor of the Fund may consent to an increase in the quota of the United States in the Fund equivalent to 40,871,800,000 Special Drawing Rights.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ecb1a9e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286xx/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subject to appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority provided by subsection (a) shall be effective only to such extent or in such amounts as are provided in advance in appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ecb1a9f-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-07-31/ch339/s72"},"text":"July 31, 1945, ch. 339, § 72","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/113/dK/tIX/s9002"},"text":"Pub. L. 114–113, div. K, title IX, § 9002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2830"},"text":"129 Stat. 2830","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
