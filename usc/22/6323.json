":"content","attrib":{},"text":" all activities of the Federal Government in support of the objectives set forth in sections 6321 and 6322 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b3d7e1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6323/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendations of the President on additional measures to enhance the effectiveness of IAEA safeguards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b3d7e2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6323/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any initiatives that the President plans to take in support of each of the objectives set forth in sections 6321 and 6322 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90b3d7e3-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tVIII/s843"},"text":"Pub. L. 103–236, title VIII, § 843","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/524"},"text":"108 Stat. 524","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
