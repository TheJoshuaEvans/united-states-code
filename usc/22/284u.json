{"tag":"section","attrib":{"id":"id8ebcc21b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284u"},"text":null,"children":[{"tag":"num","attrib":{"value":"284u"},"text":"§ 284u.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fourteenth replenishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ebcc21c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284u/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Governor of the International Development Association is authorized to contribute on behalf of the United States $2,850,000,000 to the fourteenth replenishment of the resources of the Association, subject to obtaining the necessary appropriations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ebcc21d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284u/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to pay for the United States contribution provided for in subsection (a), there are authorized to be appropriated, without fiscal year limitation, $2,850,000,000 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ebcc21e-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/565/s23"},"text":"Pub. L. 86–565, § 23","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/102/tV/s599C/a"},"text":"Pub. L. 109–102, title V, § 599C(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-11-14"},"text":"Nov. 14, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2242"},"text":"119 Stat. 2242","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
