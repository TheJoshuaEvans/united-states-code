{"tag":"section","attrib":{"id":"id90ef804f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7817"},"text":null,"children":[{"tag":"num","attrib":{"value":"7817"},"text":"§ 7817.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special Envoy on North Korean human rights issues","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90ef8050-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7817/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special Envoy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall appoint a special envoy for North Korean human rights issues within the Department of State (hereafter in this section referred to as the “Special Envoy”), by and with the advice and consent of the Senate. The Special Envoy should be a person of recognized distinction in the field of human rights who shall have the rank of ambassador and shall hold the office at the pleasure of the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90ef8051-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7817/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Central objective","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The central objective of the Special Envoy is to coordinate and promote efforts to improve respect for the fundamental human rights of the people of North Korea, including, in coordination with the Bureau of Population, Refugees, and Migration, the protection of those people who have fled as refugees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90ef8052-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7817/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties and responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Special Envoy shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90ef8053-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7817/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participate in the formulation and the implementation of activities carried out pursuant to this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ef8054-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7817/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage in discussions with North Korean officials regarding human rights;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ef8055-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7817/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support international efforts to promote human rights and political freedoms in North Korea, including coordination and dialogue between the United States and the United Nations, the European Union, North Korea, and the other countries in Northeast Asia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ef8056-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7817/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with non-governmental organizations who have attempted to address human rights in North Korea;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ef8057-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7817/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations regarding the funding of activities authorized in sections 7812 and 7814 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ef8058-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7817/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review strategies for improving protection of human rights in North Korea, including technical training and exchange programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ef8059-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7817/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop an action plan for supporting implementation of the United Nations Commission on Human Rights Resolution 2004/13.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90ef805a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7817/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2004-10-18"},"text":"October 18, 2004","children":[],"tail":", and annually thereafter through 2022, the Special Envoy shall submit to the appropriate congressional committees a report on the activities undertaken in the preceding 12 months under subsection (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90ef805b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/333/tI/s107"},"text":"Pub. L. 108–333, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-18"},"text":"Oct. 18, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1292"},"text":"118 Stat. 1292","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/346/s8"},"text":"Pub. L. 110–346, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-07"},"text":"Oct. 7, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3941"},"text":"122 Stat. 3941","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/172/s7"},"text":"Pub. L. 112–172, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-16"},"text":"Aug. 16, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1309"},"text":"126 Stat. 1309","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/198/s7/c"},"text":"Pub. L. 115–198, § 7(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-07-20"},"text":"July 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1523"},"text":"132 Stat. 1523","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90ef805c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90ef805d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90ef805e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/198"},"text":"Pub. L. 115–198","children":[],"tail":" substituted “2022” for “2017”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/172"},"text":"Pub. L. 112–172","children":[],"tail":" substituted “2017” for “2012”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/346/s8/1"},"text":"Pub. L. 110–346, § 8(1)","children":[],"tail":", substituted “North Korean human rights issues” for “human rights in North Korea” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/346/s8/2"},"text":"Pub. L. 110–346, § 8(2)","children":[],"tail":", in first sentence, substituted “North Korean human rights issues” for “human rights in North Korea” and inserted “, by and with the advice and consent of the Senate” before period at end and, in second sentence, inserted “who shall have the rank of ambassador and shall hold the office at the pleasure of the President” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/346/s8/3"},"text":"Pub. L. 110–346, § 8(3)","children":[],"tail":", inserted “, including, in coordination with the Bureau of Population, Refugees, and Migration, the protection of those people who have fled as refugees” after “North Korea”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/346/s8/4"},"text":"Pub. L. 110–346, § 8(4)","children":[],"tail":", added par. (1), redesignated former pars. (1) to (6) as (2) to (7), respectively, and substituted “sections 7812 and 7814” for “section 7812” in par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/346/s8/5"},"text":"Pub. L. 110–346, § 8(5)","children":[],"tail":", substituted “thereafter through 2012” for “for the subsequent 5 year-period”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90ef805f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id90ef8060-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Consultations on Reuniting Korean Americans With Family Members in North Korea","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLV/s5599B"},"text":"Pub. L. 117–263, div. E, title LV, § 5599B","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3400"},"text":"136 Stat. 3400","children":[],"tail":", formerly set out as a note under this section, was transferred and is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7818"},"text":"section 7818 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
