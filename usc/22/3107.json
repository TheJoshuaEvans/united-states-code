{"tag":"section","attrib":{"id":"id902c0a33-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3107"},"text":null,"children":[{"tag":"num","attrib":{"value":"3107"},"text":"§ 3107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultations; creation of independent public advisory committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Officials performing functions pursuant to this chapter shall secure balanced, diverse, and responsible views from qualified persons representing business, organized labor, and the academic community and may, where appropriate, create such independent public advisory committees as are necessary to carry out the purposes of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id902c0a34-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/472/s8"},"text":"Pub. L. 94–472, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-11"},"text":"Oct. 11, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2064"},"text":"90 Stat. 2064","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/381/s3"},"text":"Pub. L. 95–381, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-09-22"},"text":"Sept. 22, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/726"},"text":"92 Stat. 726","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/33/s4"},"text":"Pub. L. 97–33, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-07"},"text":"Aug. 7, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/171"},"text":"95 Stat. 171","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id902c0a35-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id902c0a36-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id902c0a37-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1981—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/33"},"text":"Pub. L. 97–33","children":[],"tail":" struck out designation “(a)” before “Officials performing functions” and struck out subsec. (b) which provided that the President review the results of studies and surveys conducted pursuant to this chapter and report annually to the Committee on International Relations [Foreign Affairs] of the House of Representatives and the appropriate committees of the Senate on any trends or developments which might have had national policy implications and which in the President’s opinion warranted the review of the respective committees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/381"},"text":"Pub. L. 95–381","children":[],"tail":" substituted references to President, for references to Council on International Economic Policy."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id902c0a38-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"executiveOrder","id":"id902c0a39-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Executive Order No. 11962","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 11962, ","children":[{"tag":"date","attrib":{"date":"1977-01-19"},"text":"Jan. 19, 1977","children":[],"tail":", 42 F.R. 4323, which established the President’s Advisory Board on International Investment, was revoked by Ex. Ord. No. 12007, "},{"tag":"date","attrib":{"date":"1977-08-22"},"text":"Aug. 22, 1977","children":[],"tail":", 42 F.R. 42839, formerly set out as a note under section 14 of Appendix of Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
