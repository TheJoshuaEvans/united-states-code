{"tag":"section","attrib":{"id":"id8efd2646-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1438"},"text":null,"children":[{"tag":"num","attrib":{"value":"1438"},"text":"§ 1438.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Veterans’ preference","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No provision of this chapter shall be construed to modify or to repeal the provisions of sections 1302(b), (c), 2108, 3305(b), 3306(a)(2), 3308 to 3318, 3319(b), 3320, 3351, 3363, 3364, 3501 to 3504, 7511, 7512, and 7701 of title 5.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8efd2647-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-01-27/ch36"},"text":"Jan. 27, 1948, ch. 36","children":[],"tail":", title X, § 1007, "},{"tag":"ref","attrib":{"href":"/us/stat/62/14"},"text":"62 Stat. 14","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8efd2648-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8efd2649-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8efd264a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3306"},"text":"Section 3306 of title 5","children":[],"tail":", referred to in text, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/95/228/s1"},"text":"Pub. L. 95–228, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-02-10"},"text":"Feb. 10, 1978","children":