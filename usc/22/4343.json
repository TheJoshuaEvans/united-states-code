{"tag":"section","attrib":{"id":"id907854d7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4343"},"text":null,"children":[{"tag":"num","attrib":{"value":"4343"},"text":"§ 4343.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id907854d8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4343/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance; purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State may issue regulations to carry out the purposes of this chapter. The primary purpose of such regulations and related policies, rules, and procedures shall be to assure that employees and members of their families do not profit personally from sales or other transactions with persons who are not themselves entitled to exemption from import restrictions, duties, or taxes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id907854d9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4343/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contractors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such regulations shall require that, to the extent contractors enjoy importation or tax privileges in a foreign country because of their contractual relationship to the United States Government, after the effective date of this chapter contracting agencies shall include provisions in their contracts to carry out the purpose of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id907854da-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4343/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief of mission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to ensure that due account is taken of local conditions, including applicable laws, markets, exchange rate factors, and accommodation exchange facilities, such regulations may authorize the chief of mission to each foreign country to establish more detailed policies, rules, or procedures for the application of this chapter within that country to employees under the chief of mission’s jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id907854db-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch841"},"text":"Aug. 1, 1956, ch. 841","children":[],"tail":", title III, § 303, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/204/tI/s186/a"},"text":"Pub. L. 100–204, title I, § 186(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1368"},"text":"101 Stat. 1368","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id907854dc-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id907854dd-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id907854de-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For the effective date of this chapter, referred to in subsec. (b), as being 180 days after ","children":[{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/204/s186/b"},"text":"section 186(b) of Pub. L. 100–204","children":[],"tail":" set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4341"},"text":"section 4341 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id907854df-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id907854e0-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/204/s186/b"},"text":"section 186(b) of Pub. L. 100–204","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4741"},"text":"section 4741 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
