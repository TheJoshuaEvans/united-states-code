{"tag":"section","attrib":{"id":"id8ee558d9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290m–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"290m–5"},"text":"§ 290m–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants out of paid-in capital resources","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ee558da-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290m–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall instruct the United States Federal Government representatives on the Board of Directors of the North American Development Bank to oppose any proposal where grants out of the Bank’s paid-in capital resources, except for grants from paid-in capital authorized for the community adjustment and investment program under the Bank’s charter of 1993, would—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ee558db-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290m–5/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be made to a project that is not being financed, in part, by loans; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ee558dc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290m–5/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" account for more than 50 percent of the financing of any individual project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ee558dd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290m–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ee558de-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290m–5/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirements of subsection (a) shall not apply in cases where—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ee558df-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290m–5/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President determines there are exceptional economic circumstances for making the grant and consults with the Committee on Foreign Relations of the Senate and the Committee on Financial Services of the House of Representatives; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ee558e0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290m–5/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id8ee558e1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290m–5/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the grant is being made for a project that is so small that obtaining a loan is impractical; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8ee558e2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290m–5/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the grant does not exceed $250,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ee558e3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290m–5/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than an aggregate of $5,000,000 in grants may be made under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ee558e4-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/182/tV/s546"},"text":"Pub. L. 103–182, title V, § 546","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/215/s1/b"},"text":"Pub. L. 108–215, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-04-05"},"text":"Apr. 5, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/579"},"text":"118 Stat. 579","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/113/tVI/s601"},"text":"Pub. L. 116–113, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/78"},"text":"134 Stat. 78","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dO/tVI/s601/a/1"},"text":"Pub. L. 116–260, div. O, title VI, § 601(a)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2149"},"text":"134 Stat. 2149","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ee558e5-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ee558e6-2930