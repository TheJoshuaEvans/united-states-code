,"attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2020-07-01"},"text":"July 1, 2020","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dO/s601/h"},"text":"section 601(h) of div. O of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s81c"},"text":"section 81c of Title 19","children":[],"tail":", Customs Duties."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
