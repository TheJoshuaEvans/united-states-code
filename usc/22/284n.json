{"tag":"section","attrib":{"id":"id8ebcc1e7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284n"},"text":null,"children":[{"tag":"num","attrib":{"value":"284n"},"text":"§ 284n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fifth replenishment; authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ebcc1e8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284n/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Governor is authorized to agree on behalf of the United States to pay to the Association $2,400,000,000 as the United States contribution to the fifth replenishment of the Resources of the Association: ","children":[{"tag":"i","attrib":{},"text":"Provided, however","children":[],"tail":", That any commitment to make such contributions shall be made subject to obtaining the necessary appropriations."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ebcc1e9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284n/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to pay for the United States contribution provided for in this section, there are authorized to be appropriated, without fiscal year limitation, $2,400,000,000 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ebcc1ea-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/565/s16"},"text":"Pub. L. 86–565, § 16","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/118/tIV/s401"},"text":"Pub. L. 95–118, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-10-03"},"text":"Oct. 3, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1068"},"text":"91 Stat. 1068","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ebcc1eb-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ebcc1ec-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id8ebcc1ed-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1977-10-03"},"text":"Oct. 3, 1977","children":[],"tail":", except that no funds authorized to be appropriated by this section may be available for use or obligation prior to "},{"tag":"date","attrib":{"date":"1977-10-01"},"text":"Oct. 1, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/118/s1001"},"text":"section 1001 of Pub. L. 95–118","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s282i"},"text":"section 282i of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
