{"tag":"section","attrib":{"id":"id90868535-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4867"},"text":null,"children":[{"tag":"num","attrib":{"value":"4867"},"text":"§ 4867.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security management training for officials assigned to a high risk, high threat post","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90868536-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4867/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Officials described in subsection (c) who are assigned to a high risk, high threat post shall receive security training described in subsection (b) on a mandatory basis in order to improve the ability of such officials to make security-related management decisions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90868537-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4867/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security training described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Security training referred to in subsection (a) may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90868538-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4867/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of skills to better evaluate threats;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90868539-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4867/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effective use of security resources to mitigate such threats; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9086853a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4867/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improved familiarity of available security resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9086853b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4867/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officials described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Officials referred to in subsection (a) are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9086853c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4867/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the Senior Foreign Service appointed under section 3942(a)(1) or 3943 of this title or members of the Senior Executive Service (as such term is described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3132/a/2"},"text":"section 3132(a)(2) of title 5","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9086853d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4867/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Foreign Service officers appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3942/a/1"},"text":"section 3942(a)(1) of this title","children":[],"tail":" holding a positi