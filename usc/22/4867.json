":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “high risk, high threat post” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4866/d/2"},"text":"section 4866(d)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
