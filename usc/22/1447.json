{"tag":"section","attrib":{"id":"id8efd267f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1447"},"text":null,"children":[{"tag":"num","attrib":{"value":"1447"},"text":"§ 1447.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Books and materials","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to provide for interchanges between the United States and other countries of books and periodicals, including government publications, for the translation of such writings, and for the preparation, distribution, and interchange of other educational materials.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8efd2680-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-01-27/ch36"},"text":"Jan. 27, 1948, ch. 36","children":[],"tail":", title II, § 202, "},{"tag":"ref","attrib":{"href":"/us/stat/62/7"},"text":"62 Stat. 7","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
