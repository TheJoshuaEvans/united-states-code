{"tag":"section","attrib":{"id":"id90c22fcb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6723"},"text":null,"children":[{"tag":"num","attrib":{"value":"6723"},"text":"§ 6723.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to conduct inspections","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90c22fcc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6723/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No inspection of a plant, plant site, or other facility or location in the United States shall take place under the Convention without the authorization of the United States National Authority in accordance with the requirements of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90c22fcd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6723/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90c22fce-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6723/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical Secretariat inspection teams","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any duly designated member of an inspection team of the Technical Secretariat may inspect any plant, plant site, or other facility or location in the United States subject to inspection pursuant to the Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90c22fcf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6723/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States Government representatives","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The United States National Authority shall coordinate the designation of employees of the Federal Government (and, in the case of an inspection of a United States Government facility, the designation of contractor personnel who shall be led by an employee of the Federal Government) to accompany members of an inspection team of the Technical Secretariat and, in doing so, shall ensure that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90c22fd0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6723/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a special agent of the Federal Bureau of Investigation, as designated by the Federal Bureau of Investigation, accompanies each inspection team visit pursuant to paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90c22fd1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6723/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no employee of the Environmental Protection Agency or the Occupational Safety and Health Administration accompanies any inspection team visit conducted pursuant to paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90c22fd2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6723/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of duly designated representatives shall be kept to the minimum necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90c22fd3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6723/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Objections to individuals serving as inspectors","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90c22fd4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6723/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In deciding whether to exercise the right of the United States under the Convention to object to an individual serving as an inspector, the President shall give great weight to his reasonable belief that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90c22fd5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6723/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such individual is or has been a member of, or a participant in, any group or organization that has engaged in, or attempted or conspired to engage in, or aided or abetted in the commission of, any terrorist act or activity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90c22fd6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6723/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such individual has committed any act or activity which would be a felony under the laws of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90c22fd7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6723/b/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the participation of such individual as a member of an inspection team would pose a risk to the national security or economic well-being of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90c22fd8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6723/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Not subject to judicial review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any objection by the President to an individual serving as an inspector, whether made pursuant to this section or otherwise, shall not be reviewable in any court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90c22fd9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6723/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirement under subsection (b)(2)(A) shall not apply to inspections of United States chemical weapons destruction facilities (as used within the meaning of part IV(C)(13) of the Verification Annex to the Convention).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90c22fda-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dI/tIII/s303"},"text":"Pub. L. 105–277, div. I, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-873"},"text":"112 Stat. 2681–873","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/280/tIII/s305"},"text":"Pub. L. 106–280, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-06"},"text":"Oct. 6, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/854"},"text":"114 Stat. 854","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tXII/s1204/a"},"text":"Pub. L. 107–107, div. A, title XII, § 1204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1247"},"text":"115 Stat. 1247","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90c22fdb-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90c22fdc-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90c22fdd-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" inserted “(and, in the case of an inspection of a United States Government facility, the designation of contractor personnel who shall be led by an employee of the Federal Government)” after “designation of employees of the Federal Government” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/280"},"text":"Pub. L. 106–280","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90c22fde-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id90c22fdf-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Protection of United States Companies","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/7/dB/tXI/s1117"},"text":"Pub. L. 106–113, div. B, § 1000(a)(7) [div. B, title XI, § 1117]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–489, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/113/dB/s1000/a/7/dB/tXI/s1117"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"During the 2-year period beginning on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":"], the United States National Authority (as designated pursuant to section 101 of the Chemical Weapons Convention Implementation Act of 1998 ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6711"},"text":"22 U.S.C. 6711","children":[],"tail":"] (as contained in division I of "},{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Public Law 105–277","children":[],"tail":")) shall, upon request of the Director of the Federal Bureau of Investigation, reimburse the Federal Bureau of Investigation for all costs incurred by the Bureau for such period in connection with implementation of section 303(b)(2)(A) of that Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6723/b/2/A"},"text":"22 U.S.C. 6723(b)(2)(A)","children":[],"tail":"], except that such reimbursement may not exceed $2,000,000 for such 2-year period."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days prior to the expiration of the 2-year period described in subsection (a), the Director of the Federal Bureau of Investigation shall prepare and submit to the Committee on International Relations [now Committee on Foreign Affairs] of the House of Representatives and the Committee on Foreign Relations of the Senate a report on how activities under section 303(b)(2)(A) of the Chemical Weapons Convention Implementation Act of 1998 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6723/b/2/A"},"text":"22 U.S.C. 6723(b)(2)(A)","children":[],"tail":"] will be fully funded and implemented by the Federal Bureau of Investigation notwithstanding the expiration of the 2-year period described in subsection (a).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
