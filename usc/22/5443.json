{"tag":"section","attrib":{"id":"id908db1fb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5443"},"text":null,"children":[{"tag":"num","attrib":{"value":"5443"},"text":"§ 5443.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Science and technology exchange with Poland and Hungary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id908db1fc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5443/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement with Poland","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Secretary of State for purposes of continuing to implement the 1987 United States-Polish science and technology agreement—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id908db1fd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5443/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,500,000 for fiscal year 1990,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908db1fe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5443/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,000,000 for fiscal year 1991, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908db1ff-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5443/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,000,000 for fiscal year 1992.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id908db200-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5443/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement with Hungary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Secretary of State for purposes of implementing the 1989 United States-Hungarian science and technology agreement—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id908db201-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5443/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $500,000 for fiscal year 1990,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908db202-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5443/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000,000 for fiscal year 1991, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908db203-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5443/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000,000 for fiscal year 1992.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id908db204-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5443/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of agreements being funded","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id908db205-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5443/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “1987 United States-Polish science and technology agreement” refers to the agreement concluded in 1987 by the United States and Poland, entitled “Agreement Between the Government of the United States of America and the Polish People’s Republic on Cooperation in Science and Technology and Its Funding”, together with annexes relating thereto; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908db206-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5443/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “1989 United States-Hungarian science and technology agreement” refers to the agreement concluded in 1989 by the United States and Hungary, entitled “Agreement Between the Government of the United States of America and the Government of the Hungarian People’s Republic for Scientific and Technology Cooperation”, together with annexes relating thereto.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id908db207-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/179/tIV/s403"},"text":"Pub. L. 101–179, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-28"},"text":"Nov. 28, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1316"},"text":"103 Stat. 1316","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
