{"tag":"section","attrib":{"id":"id8f745208-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2283"},"text":null,"children":[{"tag":"num","attrib":{"value":"2283"},"text":"§ 2283.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f745209-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2283/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Administrator of the Agency for International Development shall seek to ensure that debt-for-nature exchanges under this part support one or more of the following activities by either the host government, a local private conservation group, or a combination thereof:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f74520a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2283/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restoration, protection, or sustainable use of the world’s oceans and atmosphere;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f74520b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2283/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restoration, protection, or sustainable use of diverse animal and plant species;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f74520c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2283/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishment, restoration, protection, and maintenance of parks and reserves;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f74520d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2283/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development and implementation of sound systems of natural resource management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f74520e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2283/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development and support of local conservation programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f74520f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2283/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training programs to strengthen conservation institutions and increase scientific, technical, and managerial capabilities of individuals and organizations involved in conservation efforts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f745210-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2283/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efforts to generate knowledge, increase understanding, and enhance public commitment to conservation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f745211-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2283/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" design and implementation of sound programs of land and ecosystem management; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f745212-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2283/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promotion of regenerative approaches in farming, forestry, fishing, and watershed management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f745213-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2283/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f745214-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2283/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In cooperation with nongovernmental organizations, the Administrator of the Agency for International Development shall seek to identify those areas, which because of an imminent threat, are in particular need of immediate attention to prevent the loss of unique biological life or valuable ecosystem.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f745215-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2283/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of the Agency for International Development shall encourage as many eligible countries as possible to propose such exchanges with the purpose of demonstrating to a large number of governments the feasibility and benefits of sustainable development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f745216-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. I, § 463 [473], as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/240/tVII/s711"},"text":"Pub. L. 101–240, title VII, § 711","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2522"},"text":"103 Stat. 2522","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f745217-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f745218-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8f745219-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195/s463"},"text":"section 463 of Pub. L. 87–195","children":[],"tail":" is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2273"},"text":"section 2273 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
