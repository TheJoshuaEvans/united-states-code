{"tag":"section","attrib":{"id":"id9128b9ab-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9421"},"text":null,"children":[{"tag":"num","attrib":{"value":"9421"},"text":"§ 9421.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Congress makes the following findings:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9128b9ac-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9421/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Annex B to United Nations Security Council Resolution 2231 (2015) restricts certain missile-related activities and transfers to and from Iran, including all items, materials, equipment, goods, and technology set out in the Missile Technology Control Regime Annex, absent advance, case-by-case approval from the United Nations Security Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9128b9ad-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9421/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Iran has transferred Shahed and Mohajer drones, covered under the Missile Technology Control Regime Annex, to the Russian Federation, the Government of Ethiopia, and other Iran-aligned entities, including the Houthis in Yemen and militia units in Iraq, without prior authorization from the United Nations Security Council, in violation of the restrictions set forth in Annex B to United Nations Security Council Resolution 2231.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9128b9ae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9421/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Certain missile-related restrictions in Annex B to United Nations Security Council Resolution 2231 expired in October 2023, removing international legal restrictions on missile-related activities and transfers to and from Iran.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9128b9af-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/50/dK/s2"},"text":"Pub. L. 118–50, div. K, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-04-24"},"text":"Apr. 24, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/970"},"text":"138 Stat. 970","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9128b9b0-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9128b9b1-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id9128b9b2-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/50/dK/s1"},"text":"Pub. L. 118–50, div. K, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-04-24"},"text":"Apr. 24, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/970"},"text":"138 Stat. 970","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/50/dK/s1"},"text":"“This division [enacting this chapter] may be cited as the ‘Fight and Combat Rampant Iranian Missile Exports Act’ or the ‘Fight CRIME Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
