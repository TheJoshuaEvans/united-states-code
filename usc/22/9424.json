ed material added to the Missile Technology Control Regime Annex after the day before ","children":[{"tag":"date","attrib":{"date":"2024-04-24"},"text":"April 24, 2024","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id912b29f8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9424/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Family member","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “family member” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id912b29f9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9424/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a child, grandchild, parent, grandparent, sibling, or spouse; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id912b29fa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9424/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any spouse, widow, or widower of an individual described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id912b29fb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9424/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Knowingly","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “knowingly” has the meaning given that term in section 14 of the Iran Sanctions Act of 1996 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"}],"t