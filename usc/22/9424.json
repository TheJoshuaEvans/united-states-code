"tail":null},{"tag":"subparagraph","attrib":{"id":"id912b29ee-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9424/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a United States citizen;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id912b29ef-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9424/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a permanent resident alien of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id912b29f0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9424/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity organized under the laws of the United States or of any jurisdiction within the United States, including a foreign branch of such an entity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id912b29f1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9424/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id912b29f2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9424/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Iran-aligned entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Iran-aligned entity” means a foreign person that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id912b29f3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s942