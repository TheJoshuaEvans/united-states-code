{"tag":"section","attrib":{"id":"id91218dc4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9223"},"text":null,"children":[{"tag":"num","attrib":{"value":"9223"},"text":"§ 9223.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proliferation prevention sanctions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id91218dc5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9223/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Export of certain goods or technology","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A validated license shall be required for the export to North Korea of any goods or technology otherwise covered under section 4605(j) ","children":[{"tag":"ref","attrib":{"idref":"fn002428"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002428"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 50. No defense exports may be approved for the Government of North Korea."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91218dc6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9223/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transactions in defense articles or defense services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91218dc7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9223/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall withhold assistance under the Foreign Assistance Act of 1961 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"22 U.S.C. 2151","children":[],"tail":" et seq.) to the government of any country that provides to or receives from the Government of North Korea a defense article or defense service, as such terms are defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2794"},"text":"section 2794 of this title","children":[],"tail":", if the President determines that a significant type or amount of such article or service has been so provided or received."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91218dc8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9223/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The prohibition under paragraph (1) with respect to a government shall terminate on the date that is 5 years after the date on which the prohibition under paragraph (1) is applied to that government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91218dc9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9223/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary of State may waive the prohibitions under this section with respect to a country if the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91218dca-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9223/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determines that such waiver is in the national interest of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91218dcb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9223/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submits a written report to the appropriate congressional committees that describes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91218dcc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9223/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the steps that the relevant agencies are taking to curtail the trade described in subsection (b)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91218dcd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9223/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" why such waiver is in the national interest of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91218dce-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9223/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The prohibitions under this section shall not apply to the provision of assistance for human rights, democracy, rule of law, maternal and child health, disease prevention and response, or humanitarian purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91218dcf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9223/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on arms trafficking involving North Korea","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91218dd0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9223/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2017-08-02"},"text":"August 2, 2017","children":[],"tail":", and annually thereafter for 5 years, the Secretary of State shall submit to the appropriate congressional committees a report that specifically describes the compliance of foreign countries and other foreign jurisdictions with the requirement to curtail the trade described in subsection (b)(1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91218dd1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9223/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report required under paragraph (1) shall be submitted in unclassified form but may contain a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id91218dd2-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/122/tII/s203"},"text":"Pub. L. 114–122, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-18"},"text":"Feb. 18, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/106"},"text":"130 Stat. 106","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/44/tIII/s313"},"text":"Pub. L. 115–44, title III, § 313","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-02"},"text":"Aug. 2, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/945"},"text":"131 Stat. 945","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dF/tLXXI/s7123"},"text":"Pub. L. 116–92, div. F, title LXXI, § 7123","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2248"},"text":"133 Stat. 2248","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id91218dd3-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id91218dd4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id91218dd5-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4605/j"},"text":"Section 4605(j) of title 50","children":[],"tail":", referred to in subsec. (a), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXVII/s1766/a"},"text":"Pub. L. 115–232, div. A, title XVII, § 1766(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2232"},"text":"132 Stat. 2232","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Foreign Assistance Act of 1961, referred to in subsec. (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/424"},"text":"75 Stat. 424","children":[],"tail":", which is classified principally to chapter 32 (§ 2151 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id91218dd6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" substituted “5 years” for “2 years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/44/s313/1/A"},"text":"Pub. L. 115–44, § 313(1)(A)","children":[],"tail":", substituted “Transactions in defense articles or defense services” for “Transactions in lethal military equipment” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/44/s313/1/B"},"text":"Pub. L. 115–44, § 313(1)(B)","children":[],"tail":", substituted “that provides to or receives from the Government of North Korea a defense article or defense service, as such terms are defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2794"},"text":"section 2794 of this title","children":[],"tail":", if the President determines that a significant type or amount of such article or service has been so provided or received” for “that provides lethal military equipment to the Government of North Korea”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/44/s313/1/C"},"text":"Pub. L. 115–44, § 313(1)(C)","children":[],"tail":", substituted “2 years” for “1 year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/44/s313/2"},"text":"Pub. L. 115–44, § 313(2)","children":[],"tail":", substituted “maternal and child health, disease prevention and response, or” for “or emergency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/44/s313/3"},"text":"Pub. L. 115–44, § 313(3)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
