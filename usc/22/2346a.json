children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/26"},"text":"86 Stat. 26","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/93/189/s13/1"},"text":"Pub. L. 93–189, § 13(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-17"},"text":"Dec. 17, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/722"},"text":"87 Stat. 722","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/559/s18"},"text":"Pub. L. 93–559, § 18","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-12-30"},"text":"Dec. 30, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1800"},"text":"88 Stat. 1800","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/329/tV/s501/a"},"text":"Pub. L. 94–329, title V, § 501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-06-30"},"text":"June 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/762"},"text":"90 Stat. 762","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/92/s8/b"},"text":"Pub. L. 95–92, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-04"},"text":"Aug. 4, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/617"},"text":"91 Stat. 617","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/384/s10/a"},"text":"Pub. L. 95–384, § 10(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-09-26"},"text":"Sept. 26, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/733"},"text":"92 Stat. 733","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/92/s8/b"},"text":"Pub. L. 96–92, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-29"},"text":"Oct. 29, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/703"},"text":"93 Stat. 703","children":[],"tail":", related to Middle East program, providing policy requirements, availability of funds, amount of grants, and cash transfers, regional programs, comprehensive peace settlement and process of peace, and assistance to Syria, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/96/533/tII/s202"},"text":"Pub. L. 96–533, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-16"},"text":"Dec. 16, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3142"},"text":"94 Stat. 3142","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f9101cd-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id8f9101ce-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1985-10-01"},"text":"Oct. 1, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/83/s1301"},"text":"section 1301 of Pub. L. 99–83","children":[],"tail":", set out as an Effective Date of 1985 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151–1"},"text":"section 2151–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8f9101cf-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Assistance Programs to Syria","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/164/tX/s1004"},"text":"Pub. L. 98–164, title X, § 1004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-11-22"},"text":"Nov. 22, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1057"},"text":"97 Stat. 1057","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/164/tX/s1004"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After the enactment of this section [","children":[{"tag":"date","attrib":{"date":"1983-11-22"},"text":"Nov. 22, 1983","children":[],"tail":"], funds available to the Agency for International Development may not be used for any payment or reimbursement of any kind to the Government of Syria or for the delivery of any goods or services of any kind to the Government of Syria."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Administrator of the Agency for International Development shall deobligate all funds which have been obligated for Syria under the Foreign Assistance Act of 1961 [this chapter] prior to the enactment of this section [","children":[{"tag":"date","attrib":{"date":"1983-11-22"},"text":"Nov. 22, 1983","children":[],"tail":"], except that—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such funds may continue to be used to finance the training or studies outside of Syria of students whose course of study began before the enactment of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator may adopt as a contract of the United States Government any contract with a United States or third-country contractor which would otherwise be terminated pursuant to this subsection, and may assume in whole or in part any liabilities arising under such contract, except that the authority provided by this paragraph may be exercised only to the extent that budget authority is available to meet the obligations of the United States under such contracts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts certified pursuant to section 1311 of the Supplemental Appropriation Act, 1955 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1108/c"},"text":"31 U.S.C. 1108(c)","children":[],"tail":", 1501, 1502(a)], as having been obligated for Syria under chapter 4 of part II of the Foreign Assistance Act of 1961 [this part] shall continue to be available until expended to meet necessary expenses arising from the termination of assistance programs for Syria pursuant to this subsection.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/151/s101/b/1"},"text":"Pub. L. 98–151, § 101(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-11-14"},"text":"Nov. 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/964"},"text":"97 Stat. 964","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/151/s101/b/1"},"text":"“None of the funds heretofore appropriated or otherwise made available for Syria for the purposes of carrying out the provisions of chapter 4 of part II of the Foreign Assistance Act of 1961 [this part] shall be expended after the date of enactment of this joint resolution [","children":[{"tag":"date","attrib":{"date":"1983-11-14"},"text":"Nov. 14, 1983","children":[],"tail":"]. The Administrator of the Agency for International Development is directed to terminate the economic assistance program to Syria and to deobligate all funds heretofore obligated for assistance to Syria, except that such funds may continue to be available to finance the training or studies outside of Syria of students whose course of study or training program began before enactment of this joint resolution. The Administrator of the Agency for International Development is authorized to adopt as a contract of the United States Government, and assume any liabilities arising thereunder (in whole or in part), any contract with a United States contractor which had been funded by the Agency for International Development prior to the date of enactment of this joint resolution. Amounts certified pursuant to section 1311 of the Supplemental Appropriations Act, 1955 ["},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1108/c"},"text":"31 U.S.C. 1108(c)","children":[],"tail":", 1501, 1502(a)], as having been obligated against appropriations heretofore made pursuant to chapter 4 of part II of the Foreign Assistance Act of 1961 (and predecessor legislation) for Syria are hereby continued available until expended to meet necessary expenses arising from the termination under this subsection of assistance programs for Syria authorized by such chapter: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That this shall not be construed as permitting payments or reimbursements of any kind to the Government of Syria.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8f9101d0-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Negotiations Between Israel and Egypt; Promotion, Etc.","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/384/s28"},"text":"Pub. L. 95–384, § 28","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-09-26"},"text":"Sept. 26, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/746"},"text":"92 Stat. 746","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/384/s28"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a lasting settlement of the Arab-Israel conflict is vital to United States national interests as well as to the interests of the countries of the region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support for a strong and secure Israel and the maintenance for this purpose of Israel’s effective defense capabilities as essential to peace remains a fundamental tenet of United States foreign policy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct, face-to-face negotiations between Israel and Egypt without preconditions is an historic opening for peace, and the support of such negotiations by other moderate Arab countries, can best promote a peace settlement based on mutual concessions and accommodations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of secure, recognized, and defensible borders between Israel and its neighbors will discourage hostilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" full, normalized relations between Israel and its Arab neighbors, including trade, travel, tourism, communications, and diplomatic relations are vital for peace.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It is the sense of the Congress that the Government of the United States should continue to promote direct negotiations between Israel and Egypt and to encourage other Arab countries to enter into negotiations leading to peace treaties with Israel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It is further the sense of the Congress that the United States should be responsive to Israel’s economic needs and defense requirements, including the provision of additional advanced aircraft, in order to maintain Israel’s defense capability which is essential to peace.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id8f9101d1-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id8f9101d2-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions of President under this section, see Ex. Ord. No. 12163, ","children":[{"tag":"date","attrib":{"date":"1979-09-29"},"text":"Sept. 29, 1979","children":[],"tail":", 44 F.R. 56673, as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2381"},"text":"section 2381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
