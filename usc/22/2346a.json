{"tag":"section","attrib":{"id":"id8f9101c4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2346a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2346a"},"text":"§ 2346a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorizations of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f9101c5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2346a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recipients and purposes of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the President to carry out the purposes of this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f9101c6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2346a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,015,000,000 for the fiscal year 1986 and $2,015,000,000 for the fiscal year 1987 for the following countries signing the Camp David agreement: Israel and Egypt; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f9101c7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2346a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,785,000,000 for the fiscal year 1986 and $1,785,000,000 for the fiscal year 1987 for assistance under this part for recipients or purposes other than the countries referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f9101c8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2346a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts appropriated to carry out this part are authorized to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f9101c9-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. II, § 532, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/83/tII/s201/a"},"text":"Pub. L. 99–83, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-08"},"text":"Aug. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/211"},"text":"99 Stat. 211","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f9101ca-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f9101cb-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id8f9101cc-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2346a, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. II, 532, as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/113/tII/s202"},"text":"Pub. L. 97–113, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1529"},"text":"95 Stat. 1529","children":[],"tail":"; amended "},{"tag":"ref","attri