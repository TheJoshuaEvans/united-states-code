{"tag":"section","attrib":{"id":"id90e5e43f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7612"},"text":null,"children":[{"tag":"num","attrib":{"value":"7612"},"text":"§ 7612.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" HIV/AIDS response Coordinator","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90e5e440-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7612/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90e5e441-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7612/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resources","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2003-05-27"},"text":"May 27, 2003","children":[],"tail":", the President shall specify the necessary financial and personnel resources, from funds appropriated pursuant to the authorization of appropriations under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7671"},"text":"section 7671 of this title","children":[],"tail":" for HIV/AIDS assistance, that shall be assigned to and under the direct control of the Coordinator of United States Government Activities to Combat HIV/AIDS Globally to establish and maintain the duties and supporting activities assigned to the Coordinator by this chapter and the amendments made by this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90e5e442-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7612/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of separate account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the general fund of the Treasury a separate account which shall be known as the “Activities to Combat HIV/AIDS Globally Fund” and which shall be administered by the Coordinator of United States Government Activities to Combat HIV/AIDS Globally. There shall be deposited into the Fund all amounts appropriated pursuant to the authorization of appropriations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7671"},"text":"section 7671 of this title","children":[],"tail":" for HIV/AIDS assistance, except for amounts appropriated for United States contributions to the Global Fund."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90e5e443-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7612/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90e5e444-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7612/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" full-time country level coordinators, preferably with management experience, should head each HIV/AIDS country team for United States missions overseeing significant HIV/AIDS programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90e5e445-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7612/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign service nationals provide critically important services in the design and implementation of United States country-level HIV/AIDS programs and their skills and experience as public health professionals should be recognized within hiring and compensation practices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90e5e446-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7612/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" staffing levels for United States country-level HIV/AIDS teams should be adequately maintained to fulfill oversight and other obligations of the positions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90e5e447-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/25/tI/s102"},"text":"Pub. L. 108–25, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-05-27"},"text":"May 27, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/721"},"text":"117 Stat. 721","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/293/tI/s103"},"text":"Pub. L. 110–293, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2935"},"text":"122 Stat. 2935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90e5e448-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90e5e449-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90