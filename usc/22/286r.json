{"tag":"section","attrib":{"id":"id8ec65f63-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286r"},"text":null,"children":[{"tag":"num","attrib":{"value":"286r"},"text":"§ 286r.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States participation in special drawing account","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The provisions of article XXI(b) of the Articles of Agreement of the Fund shall have full force and effect in the United States and its territories and possessions when the United States becomes a participant in the special drawing account.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ec65f64-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/349/s7"},"text":"Pub. L. 90–349, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-06-19"},"text":"June 19, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/189"},"text":"82 Stat. 189","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/564/s5/4"},"text":"Pub. L. 94–564, § 5(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-19"},"text":"Oct. 19, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2661"},"text":"90 Stat. 2661","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ec65f65-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ec65f66-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8ec65f67-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-07-31/ch339"},"text":"act July 31, 1945, ch. 339","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/59/512"},"text":"59 Stat. 512","children":[],"tail":", known as the Bretton Woods Agreement Act, which comprises this subchapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8ec65f68-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/564"},"text":"Pub. L. 94–564","children":[],"tail":" substituted “article XXI(b)” for “article XXVII(b)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ec65f69-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8ec65f6a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment effective ","children":[{"tag":"date","attrib":{"date":"1978-04-01"},"text":"Apr. 1, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/564/s9"},"text":"section 9 of Pub. L. 94–564","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s286a"},"text":"section 286a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
