{"tag":"section","attrib":{"id":"id8f82a9d1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2294"},"text":null,"children":[{"tag":"num","attrib":{"value":"2294"},"text":"§ 2294.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorizations of appropriations for Development Fund for Africa","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Funds appropriated to carry out this part are authorized to be made available until expended. It is the sense of the Congress that the authority of this subsection ","children":[{"tag":"ref","attrib":{"idref":"fn002129"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002129"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section”."}],"tail":" should be used to extend the period of availability of those funds whenever appropriate to improve the quality of assistance provided under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2293"},"text":"section 2293 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f82a9d2-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. I, § 497, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/513/tV/s562/a"},"text":"Pub. L. 101–513, title V, § 562(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2030"},"text":"104 Stat. 2030","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f82a9d3-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f82a9d4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"hea