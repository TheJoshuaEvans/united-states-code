{"tag":"section","attrib":{"id":"id8ee5592e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290n–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"290n–6"},"text":"§ 290n–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ee5592f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290n–6/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Commission” means the United States-Mexico Border Health Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ee55930-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290n–6/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health problem","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “health problem” means a disease or medical ailment or an environmental condition that poses the risk of disease or medical ailment. The term includes diseases, ailments, or risks of disease or ailment caused by or related to environmental factors, control of animals and rabies, control of insect and rodent vectors, disposal of solid and hazardous waste, and control and monitoring of air quality.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ee55931-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290n–6/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ee55932-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290n–6/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States-Mexico Border Area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States-Mexico Border Area” means the area located in the United States and Mexico within 100 kilometers of the border between the United States and Mexico.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ee55933-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/400/s8"},"text":"Pub. L. 103–400, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4171"},"text":"108 Stat. 4171","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
