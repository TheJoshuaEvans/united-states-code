{"tag":"section","attrib":{"id":"id8ea73e45-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s272b"},"text":null,"children":[{"tag":"num","attrib":{"value":"272b"},"text":"§ 272b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loyalty check on United States personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No person shall serve as representative, delegate, or alternate from the United States until such person has been investigated as to loyalty and security by the Director of the Office of Personnel Management.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ea73e46-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch756/s3"},"text":"June 30, 1948, ch. 756, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/1152"},"text":"62 Stat. 1152","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1952-04-05/ch159/s1"},"text":"Apr. 5, 1952, ch. 159, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/43"},"text":"66 Stat. 43","children":[],"tail":"; 1978 Reorg. Plan No. 2, § 102, eff. "},{"tag":"date","attrib":{"date":"1979-01-01"},"text":"Jan. 1, 1979","children":[],"tail":", 43 F.R. 36037, "},{"tag":"ref","attrib":{"href":"/us/stat/92/3784"},"text":"92 Stat. 3784","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ea9af47-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ea9af48-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8ea9af49-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"hea