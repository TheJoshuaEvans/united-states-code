{"tag":"section","attrib":{"id":"id9081cb4d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4835"},"text":null,"children":[{"tag":"num","attrib":{"value":"4835"},"text":"§ 4835.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to other proceedings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9081cb4e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4835/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No effect on existing remedies or defenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to create administrative or judicial review remedies or rights of action not otherwise available by law, nor shall any provision of this subchapter be construed to deprive any person of any right or legal defense which would otherwise be available to that person under any law, rule, or regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9081cb4f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4835/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Future inquiries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter may be construed to preclude the Secretary of State from convening a follow-up public board of inquiry to investigate any security incident if the incident was of such magnitude or significance that an internal process is deemed insufficient to understand and investigate the incident. All materials gathered during the procedures provided under this subchapter shall be provided to any related board of inquiry convened by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9081cb50-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/399/tIII/s305"},"text":"Pub. L. 99–399, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/862"},"text":"100 Stat. 862","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dI/tXCIII/s9302/h"},"text":"Pub. L. 117–263, div. I, title XCIII, § 9302(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3888"},"text":"136 Stat. 3888","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9081cb51-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9081cb52-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9081cb53-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
