{"tag":"section","attrib":{"id":"id8eea13fd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s296a"},"text":null,"children":[{"tag":"num","attrib":{"value":"296a"},"text":"§ 296a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance management of overseas prop­erty","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Director of the Office of Foreign Buildings Operations shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8eea13fe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s296a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct overseas posts to make annual building condition assessments of buildings and facilities used by the post;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8eea13ff-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s296a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"1991-10-28"},"text":"October 28, 1991","children":[],"tail":", revise the Foreign Affairs Manual to stipulate that the Buildings and Maintenance Handbook shall be used by each post to identify their maintenance needs, standardize their maintenance operations, and conduct annual assessments as required by paragraph (1);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8eea1400-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s296a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct the Office of Foreign Buildings Operations to provide proper training and assistance to posts to ensure that annual surveys are effectively completed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8eea1401-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s296a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct overseas posts to ensure that all maintenance program fiscal transactions are properly encoded in the Department of State accounting system to enable compilation of actual expenditures on routine maintenance and specific maintenance funded by the Office of Foreign Buildings Operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8eea1402-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/138/tI/s125"},"text":"Pub. L. 102–138, title I, § 125","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/659"},"text":"105 Stat. 659","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8eea1403-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8eea1404-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8eea1405-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Foreign Relations Authorization Act, Fiscal Years 1992 and 1993, and not as part of the Foreign Service Buildings Act, 1926, which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8eea1406-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8eea1407-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Authority of Secretary of State","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Except as otherwise provided, Secretary of State to have and exercise any authority vested by law in any official or office of Department of State and references to such officials or offices deemed to refer to Secretary of State or Department of State, as appropriate, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651a"},"text":"section 2651a of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/s161/d"},"text":"section 161(d) of Pub. L. 103–236","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651a"},"text":"section 2651a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
