{"tag":"section","attrib":{"id":"id902c0a44-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3141"},"text":null,"children":[{"tag":"num","attrib":{"value":"3141"},"text":"§ 3141.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress makes the following findings:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id902c0a45-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3141/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Government collects substantial amounts of information from foreign owned or controlled business enterprises or affiliates operating in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id902c0a46-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3141/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Additional analysis and presentation of this information is desirable to assist the public debate on the issue of foreign direct investments in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id902c0a47-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3141/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information collected from foreign owned or controlled firms by the Bureau of Economic Analysis has serious analytical limitations because it is largely collected on an “enterprise” basis that does not permit an adequate analysis by industry groupings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id902c0a48-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3141/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Statistical and analytic comparisons of the performance of foreign owned or controlled businesses operating within the United States with other business enterprises operating within the same industry can be accomplished under sections 3101(b) and 3104(c) of this title, and under Executive Order Numbered 11961, without the need to collect additional information, by sharing with other authorized Government agencies the employer identification numbers maintained by the Bureau of Economic Analysis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id902c0a49-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3141/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Public disclosures of confidential business information collected by the United States Government relating to international direct investment flows could cause serious damage to the accuracy of the statistical data base.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id902c0a4a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3141/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Government Accountability Office may have limited access to Government data on foreign direct investment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id902c0a4b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/533/s2"},"text":"Pub. L. 101–533, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-07"},"text":"Nov. 7, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2344"},"text":"104 Stat. 2344","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id902c0a4c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id902c0a4d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id902c0a4e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Executive Order Numbered 11961, referred to in par. (4), is set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3101"},"text":"section 3101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id902c0a4f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id902c0a50-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id902c0a51-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/533/s1"},"text":"Pub. L. 101–533, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-07"},"text":"Nov. 7, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2344"},"text":"104 Stat. 2344","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/533/s1"},"text":"“This Act [enacting this chapter and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t13/s401"},"text":"section 401 of Title 13","children":[],"tail":", Census, and amending sections 3101 and 3103 to 3105 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t13/s9"},"text":"section 9 of Title 13","children":[],"tail":"] may be cited as the ‘Foreign Direct Investment and International Financial Data Improvements Act of 1990’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
