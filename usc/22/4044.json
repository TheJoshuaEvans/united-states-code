{"tag":"section","attrib":{"id":"id905ba46f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044"},"text":null,"children":[{"tag":"num","attrib":{"value":"4044"},"text":"§ 4044.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this part, unless otherwise specified, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id905ba470-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “annuitant” means any individual, including a former participant or survivor, who meets all requirements for an annuity from the Fund under this chapter or any other Act and who has filed a claim for such annuity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id905ba471-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “child” means an individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id905ba472-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id905ba473-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an offspring or adopted child of the participant,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id905ba474-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a stepchild or recognized natural child of the participant and who received more than one-half support from the participant, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id905ba475-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lived with the participant, for whom a petition of adoption was filed by the participant, and who is adopted by the surviving spouse of the participant after the death of the participant;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id905ba476-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is unmarried; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id905ba477-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id905ba478-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is under the age of 18 years,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id905ba479-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a student under the age of 22 years (for purposes of this clause, an individual whose 22d birthday occurs before July 1 or after August 31 of the calendar year in which that birthday occurs, and while the individual is a student, is deemed to become 22 years of age on the first July 1 which occurs after that birthday), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id905ba47a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is incapable of self-support because of a physical or mental disability which was incurred before the individual reached the age of 18 years;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id905ba47b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “court” means any court of any State, the District of Columbia, the Commonwealth of Puerto Rico, Guam, the Northern Mariana Islands, or the Virgin Islands, and any Indian court as defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1301/3"},"text":"section 1301(3) of title 25","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id905ba47c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “court order” means any court decree of divorce or annulment, or any court order or court approved property settlement agreement incident to any court decree of divorce or annulment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id905ba47d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Foreign Service normal cost” means the level percentage of payroll required to be deposited in the Fund to meet the cost of benefits payable under the System (computed in accordance with generally accepted actuarial practice on an entry-age basis) less the value of retirement benefits earned under another retirement system for Government employees and less the cost of credit allowed for military and naval service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id905ba47e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “former spouse” means a former wife or husband of a participant or former participant who was married to such participant for not less than 10 years during periods of service by that participant which are creditable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4056"},"text":"section 4056 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id905ba47f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “Fund balance” means the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id905ba480-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the investments of the Fund calculated at par value, plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id905ba481-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cash balance of the Fund on the books of the Treasury;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id905ba482-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “lump-sum credit” means the compulsory and special contributions to the credit of a participant or former participant in the Fund plus interest on such contributions at 4 percent a year compounded annually to ","children":[{"tag":"date","attrib":{"date":"1976-12-31"},"text":"December 31, 1976","children":[],"tail":", and after such date, for a participant who separates from the Service after completing at least 1 year of civilian service and before completing 5 years of such service, at the rate of 3 percent per year to the date of separation (except that interest shall not be paid for a fractional part of a month in the total service or on compulsory and special contributions from an annuitant for recall service or other service performed after the date of separation which forms the basis for annuity);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id905ba483-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “military and naval service” means honorable active service—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id905ba484-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the Armed Forces of the United States,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id905ba485-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the Regular or Reserve Corps ","children":[{"tag":"ref","attrib":{"idref":"fn002279"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002279"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Change of Name note below."}],"tail":" of the Public Health Service after "},{"tag":"date","attrib":{"date":"1960-06-30"},"text":"June 30, 1960","children":[],"tail":", or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id905ba486-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a commissioned officer of the National Oceanic and Atmospheric Administration, or a predecessor organization, after ","children":[{"tag":"date","attrib":{"date":"1961-06-30"},"text":"June 30, 1961","children":[],"tail":","}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"but does not include service in the National Guard except when ordered to active duty in the service of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id905ba487-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “pro rata share”, in the case of any former spouse of any participant or former participant, means a percentage which is equal to the percentage that (A) the number of years during which the former spouse was married to the participant during the creditable service (creditable under part I or II) of that participant is of (B) the total number of years of such creditable service (creditable under part I or II);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id905ba488-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “spousal agreement” means any written agreement between—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id905ba489-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a participant or former participant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id905ba48a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" his or her spouse or former spouse;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id905ba48b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “student” means a child regularly pursuing a full-time course of study or training in residence in a high school, trade school, technical or vocational institute, junior college, college, university, or comparable recognized educational institution (for purposes of this paragraph, a child who is a student shall not be deemed to have ceased to be a student during any period between school years, semesters, or terms if the period of nonattendance does not exceed 5 calendar months and if the child shows to the satisfaction of the Secretary of State that he or she has a bona fide intention of continuing to pursue his or her course of study during the school year, semester, or term immediately following such period);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id905ba48c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “surviving spouse” means the surviving wife or husband of a participant or annuitant who was married to the participant or annuitant for at least 9 months immediately preceding his or her death or is a parent of a child born of the marriage, except that the requirement for at least 9 months of marriage shall be deemed satisfied in any case in which the participant or annuitant dies within the applicable 9-month period, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id905ba48d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the death of such participant or annuitant was accidental; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id905ba48e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the surviving spouse of such individual had been previously married to the individual and subsequently divorced and the aggregate time married is at least 9 months;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id905ba48f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “unfunded liability” means the estimated excess of the present value of all benefits payable from the Fund under this part over the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id905ba490-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044/14/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the present value of deductions to be withheld from the future basic salary of participants and of future agency contributions to be made on their behalf, plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id905ba491-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044/14/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the present value of Government payments to the Fund under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4061"},"text":"section 4061 of this title","children":[],"tail":", plus"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id905ba492-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044/14/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Fund balance as of the date the unfunded liability is determined; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id905ba493-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “special agent” means an employee of the Department of State with a primary skill code of 2501—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id905ba494-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044/15/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the duties of whose position—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id905ba495-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044/15/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" are primarily—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id905ba496-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044/15/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the investigation, apprehension, or detention of individuals suspected or convicted of offenses against the criminal laws of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id905ba497-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044/15/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the protection of persons pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2709/a/3"},"text":"section 2709(a)(3) of this title","children":[],"tail":" against threats to personal safety; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id905ba498-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044/15/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are sufficiently rigorous that employment opportunities should be limited to young and physically vigorous individuals, as determined by the Secretary of State pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4823"},"text":"section 4823 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id905ba499-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044/15/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performing duties described in subparagraph (A) before, on, or after ","children":[{"tag":"date","attrib":{"date":"1998-11-13"},"text":"November 13, 1998","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id905ba49a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4044/15/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transferred directly to a position which is supervisory or administrative in nature after performing duties described in subparagraph (A) for at least 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id905ba49b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s804"},"text":"Pub. L. 96–465, title I, § 804","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2102"},"text":"94 Stat. 2102","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/335/tIV"},"text":"Pub. L. 99–335, title IV","children":[],"tail":", §§ 402(a)(2), (3), 403, 404(a), "},{"tag":"date","attrib":{"date":"1986-06-06"},"text":"June 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/609"},"text":"100 Stat. 609","children":[],"tail":", 610; "},{"tag":"ref","attrib":{"href":"/us/pl/100/238/tII/s211"},"text":"Pub. L. 100–238, title II, § 211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-08"},"text":"Jan. 8, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1773"},"text":"101 Stat. 1773","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/382/s2/a/1"},"text":"Pub. L. 105–382, § 2(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3406"},"text":"112 Stat. 3406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id905ba49c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id905ba49d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id905ba49e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in par. (1), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465"},"text":"Pub. L. 96–465","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2071"},"text":"94 Stat. 2071","children":[],"tail":", known as the Foreign Service Act of 1980, which is classified principally to this chapter (§ 3901 et seq.). For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3901"},"text":"section 3901 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id905ba49f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Par. (15). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/382"},"text":"Pub. L. 105–382","children":[],"tail":" added par. (15)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Par. (13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/238/s211/1"},"text":"Pub. L. 100–238, § 211(1)","children":[],"tail":", which directed the amendment of par. (13) by striking out “, in the case of death in service or marriage after retirement,” was executed by striking out “, in the case of a death in service or marriage after retirement,” after “annuitant who”, as the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/238/s211/2"},"text":"Pub. L. 100–238, § 211(2)","children":[],"tail":", (3), substituted “9 months” for “one year” and inserted before semicolon at end “, except that the requirement for at least 9 months of marriage shall be deemed satisfied in any case in which the participant or annuitant dies within the applicable 9-month period, if—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the death of such participant or annuitant was accidental; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the surviving spouse of such individual had been previously married to the individual and subsequently divorced and the aggregate time married is at least 9 months”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/335/s402/a/2"},"text":"Pub. L. 99–335, § 402(a)(2)","children":[],"tail":", substituted “part” for “subchapter” in provision preceding par. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/335/s403"},"text":"Pub. L. 99–335, § 403","children":[],"tail":", substituted “, the District of Columbia, the Commonwealth of Puerto Rico, Guam, the Northern Mariana Islands, or the Virgin Islands, and any Indian court as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1301/3"},"text":"section 1301(3) of title 25","children":[],"tail":"” for “or of the District of Columbia”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/335/s404/a"},"text":"Pub. L. 99–335, § 404(a)","children":[],"tail":", inserted “(creditable under part I or II)” after “creditable service” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/335/s402/a/3"},"text":"Pub. L. 99–335, § 402(a)(3)","children":[],"tail":", inserted “under this part” after “payable from the Fund” in provision preceding subpar. (A)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id905ba4a0-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id905ba4a1-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to Reserve Corps of the Public Health Service deemed to be a reference to the Ready Reserve Corps, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s204/c/3"},"text":"section 204(c)(3) of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id905ba4a2-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/382/s4"},"text":"Pub. L. 105–382, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3409"},"text":"112 Stat. 3409","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/4/dB/tI/s145/a"},"text":"Pub. L. 106–554, § 1(a)(4) [div. B, title I, § 145(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–250, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/554/s1/a/4/dB/tI/s145/a"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b), this Act [amending this section and sections 4045, 4046, 4052, 4071a, and 4071d of this title and enacting provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3901"},"text":"section 3901 of this title","children":[],"tail":"] and the amendments made by this Act—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall apply with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any individual first appointed on or after that date as a special agent who will have any portion of such individual’s annuity computed in conformance with section 806(a)(6) of the Foreign Service Act [of 1980] [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4046/a/6"},"text":"22 U.S.C. 4046(a)(6)","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any individual making an election under subsection (b), subject to the provisions of such subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Election for Current Participants.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An election under this subsection may be made by any currently employed participant or participant who was serving as of ","children":[{"tag":"date","attrib":{"date":"1997-01-01"},"text":"January 1, 1997","children":[],"tail":" under chapter 8 of the Foreign Service Act of 1980 ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4041"},"text":"22 U.S.C. 4041","children":[],"tail":" et seq.] who is serving or has served as a special agent, or by a survivor of a special agent who was eligible to make an election under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of an election.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If an individual makes an election under this subsection, the amendments made by this Act [amending this section and sections 4045, 4046, 4052, 4071a, and 4071d of this title] shall become applicable with respect to such individual, subject to subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of prior service.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special contribution","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual may, after making the election under this subsection, make a special contribution up to the full amount of the difference between the contributions actually deducted from pay for prior service and the deductions that would have been required if the amendments made by this Act had then been in effect. Any special contributions under this clause shall be computed under regulations based on section 805(d) of the Foreign Service Act of 1980 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4045/d"},"text":"22 U.S.C. 4045(d)","children":[],"tail":"] (as amended by section 2), including provisions relating to the computation of interest."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Actuarial reduction.—","children":[],"tail":null}],"tail":null},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"     “(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule if the special contribution is paid","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the full amount of the special contribution under clause (i) is paid, no reduction under this clause shall apply.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"     “(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule if less than the entire amount is paid","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If no special contribution under clause (i) is paid, or if less than the entire amount of such special contribution is paid, the recomputed annuity shall be reduced by an amount sufficient to make up the actuarial present value of the shortfall.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations and Notice","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 6 months after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":"], the Secretary of State—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall promulgate such regulations as may be necessary to carry out this Act; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall take measures reasonably designed to provide notice to participants as to any rights they might have under this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Election Deadline","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An election under subsection (b) must be made not later than 90 days after the date on which the relevant notice under subsection (c)(2) is provided.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this section, the term ‘special agent’ has the meaning given such term under section 804(15) of the Foreign Service Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4044/15"},"text":"22 U.S.C. 4044(15)","children":[],"tail":"), as amended by section 2(a).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/4/dB/tI/s145/b"},"text":"Pub. L. 106–554, § 1(a)(4) [div. B, title I, § 145(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–250, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/554/s1/a/4/dB/tI/s145/b"},"text":"“The amendment made by this section [amending ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/382/s4"},"text":"section 4 of Pub. L. 105–382","children":[],"tail":", set out above] shall take effect on "},{"tag":"date","attrib":{"date":"2001-01-01"},"text":"January 1, 2001","children":[],"tail":".”"}],"tail":"\n]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id905ba4a3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/238"},"text":"Pub. L. 100–238","children":[],"tail":" effective 90 days after "},{"tag":"date","attrib":{"date":"1988-01-08"},"text":"Jan. 8, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/238/s261/a"},"text":"section 261(a) of Pub. L. 100–238","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4054"},"text":"section 4054 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id905ba4a4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/335"},"text":"Pub. L. 99–335","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1987-01-01"},"text":"Jan. 1, 1987","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/335/s702/a"},"text":"section 702(a) of Pub. L. 99–335","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8401"},"text":"section 8401 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
