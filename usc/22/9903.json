{"tag":"section","attrib":{"id":"id914ede60-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9903"},"text":null,"children":[{"tag":"num","attrib":{"value":"9903"},"text":"§ 9903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consolidated report on unified investment climate statement and country commercial guide","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id914ede61-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State and the Secretary of Commerce shall jointly produce and make publicly available on a United States Government internet website an annual country- and region-specific report regarding commercial relations with foreign countries and regions and safeguarding United States economic and business interests abroad, including with regard to United States exports and investments, including by small- and medium-size enterprises.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id914ede62-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matters to be included","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report required under subsection (a) shall include the following with respect to each country or region covered by each such report:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id914ede63-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9903/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information about doing business in each country or region.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914ede64-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9903/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Background information about each country’s or region’s political environment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914ede65-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9903/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information about selling United States products and services in each country or region.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914ede66-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9903/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Leading sectors for United States exports and investment in each country or region.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914ede67-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9903/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Information about trade regulations, customs, and standards in each country or region, such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id914ede68-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9903/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on import tariffs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914ede69-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9903/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" documentation about which United States businesses should be aware when exporting, including any prohibited items or temporary entry procedures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914ede6a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9903/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Investment climate statements describing each country’s or region’s openness to foreign investments, such as information relating to each country’s or region’s—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id914ede6b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9903/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investment policies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914ede6c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9903/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" market barriers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914ede6d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9903/b/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" business risks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914ede6e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9903/b/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" legal and regulatory system, including dispute resolution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914ede6f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9903/b/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" level of public and private sector corruption;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914ede70-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9903/b/6/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" level of political violence and instability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914ede71-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9903/b/6/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adherence to internationally recognized core labor standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914ede72-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9903/b/6/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protection of property rights.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914ede73-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9903/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Information about trade and project financing in each country or region, such as each country’s or region’s—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id914ede74-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9903/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" banking and financial system, and how United States businesses typically get paid;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914ede75-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9903/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign exchange controls; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914ede76-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9903/b/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" important sources of funding for project financing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914ede77-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9903/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Relevant business travel information and business customs in each country or region.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914ede78-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9903/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information about services and personnel of the diplomatic mission of the United States available to United States businesses to support their activities in each country or region.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914ede79-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9903/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any significant trade or commercial agreement that exists between the United States and each country or region.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914ede7a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9903/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A point of contact at the diplomatic or consular mission of the United States in each country or region for United States businesses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id914ede7b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9903/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section may be construed to require the duplication of existing reports.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id914ede7c-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dJ/tVII/s707"},"text":"Pub. L. 116–94, div. J, title VII, § 707","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3071"},"text":"133 Stat. 3071","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
