{"tag":"section","attrib":{"id":"id9110eb3f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8783"},"text":null,"children":[{"tag":"num","attrib":{"value":"8783"},"text":"§ 8783.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability to certain natural gas projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9110eb40-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8783/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for certain natural gas projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this Act or the amendments made by this Act shall apply to any activity relating to a project—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9110eb41-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8783/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the development of natural gas and the construction and operation of a pipeline to transport natural gas from Azerbaijan to Turkey and Europe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9110eb42-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8783/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that provides to Turkey and countries in Europe energy security and energy independence from the Government of the Russian Federation and other governments with jurisdiction over persons subject to sanctions imposed under this Act or amendments made by this Act; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9110eb43-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8783/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that was initiated before ","children":[{"tag":"date","attrib":{"date":"2012-08-10"},"text":"August 10, 2012","children":[],"tail":", pursuant to a production-sharing agreement, or an ancillary agreement necessary to further a production-sharing agreement, entered into with, or a license granted by, the government of a country other than Iran before "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"August 10, 2012","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9110eb44-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8783/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of exception","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9110eb45-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8783/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The exception under subsection (a) shall not apply with respect to a project described in that subsection on or after the date on which the President certifies to the appropriate congressional committees that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9110eb46-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8783/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage of the equity interest in the project held by or on behalf of an entity described in paragraph (2) has increased relative to the percentage of the equity interest in the project held by or on behalf of such an entity on ","children":[{"tag":"date","attrib":{"date":"2002-01-01"},"text":"January 1, 2002","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9110eb47-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8783/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity described in paragraph (2) has assumed an operational role in the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9110eb48-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8783/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entity described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity described in this paragraph is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9110eb49-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8783/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an entity—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9110eb4a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8783/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned or controlled by the Government of Iran or identified under section 560.304 of title 31, Code of Federal Regulations (relating to the definition of the Government of Iran); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9110eb4b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8783/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" organized under the laws of Iran or with the participation or approval of the Government of Iran;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9110eb4c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8783/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity owned or controlled by an entity described in subparagraph (A); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9110eb4d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8783/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a successor entity to an entity described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9110eb4e-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/158/tVI/s603"},"text":"Pub. L. 112–158, title VI, § 603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1264"},"text":"126 Stat. 1264","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9110eb4f-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9110eb50-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9110eb51-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/158"},"text":"Pub. L. 112–158","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1214"},"text":"126 Stat. 1214","children":[],"tail":", known as the Iran Threat Reduction and Syria Human Rights Act of 2012, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s8701"},"text":"section 8701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
