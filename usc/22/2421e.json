{"tag":"section","attrib":{"id":"id8fbbe27b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2421e"},"text":null,"children":[{"tag":"num","attrib":{"value":"2421e"},"text":"§ 2421e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of sections 2421a to 2421e of this title—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fbbe27c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2421e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “AID” means the Agency for International Development; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbbe27d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2421e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “capital project” means a project involving the construction, expansion, alteration of, or the acquisition of equipment for, a physical facility or physical infrastructure, including related engineering design (concept and detail) and other services, the procurement of equipment (including any related services), and feasibility studies or similar engineering and economic services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fbbe27e-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/549/tIII/s308"},"text":"Pub. L. 102–549, title III, § 308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3660"},"text":"106 Stat. 3660","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fbbe27f-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8fbbe280-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8fbbe281-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 2421a to 2421e of this title, referred to in text, was in the original “this title” meaning title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/549"},"text":"Pub. L. 102–549","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3658"},"text":"106 Stat. 3658","children":[],"tail":", known as the Aid, Trade, and Competitiveness Act of 1992, which enacted sections 2421a to 2421e of this title and provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2421a"},"text":"section 2421a of this title","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2421a"},"text":"section 2421a of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8fbbe282-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Aid, Trade, and Competitiveness Act of 1992 and also as part of the Jobs Through Exports Act of 1992, and not as part of the Foreign Assistance Act of 1961 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
