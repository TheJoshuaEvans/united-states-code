{"tag":"section","attrib":{"id":"id8eb59625-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s282"},"text":null,"children":[{"tag":"num","attrib":{"value":"282"},"text":"§ 282.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of membership by United States in International Finance Corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President is hereby authorized to accept membership for the United States in the International Finance Corporation (hereinafter referred to as the “Corporation”), provided for by the Articles of Agreement of the Corporation deposited in the archives of the International Bank for Reconstruction and Development.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8eb59626-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-08-11/ch788/s2"},"text":"Aug. 11, 1955, ch. 788, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/669"},"text":"69 Stat. 669","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8eb59627-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8eb59628-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id8eb59629-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1955-08-11/ch788/s1"},"text":"Act Aug. 11, 1955, ch. 788, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/669"},"text":"69 Stat. 669","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1955-08-11/ch788/s1"},"text":"“This Act [enacting this subchapter] may be cited as the ‘International Finance Corporation Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
