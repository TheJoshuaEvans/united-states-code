{"tag":"section","attrib":{"id":"id8f176583-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1731"},"text":null,"children":[{"tag":"num","attrib":{"value":"1731"},"text":"§ 1731.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection to naturalized citizens abroad","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All naturalized citizens of the United States while in foreign countries are entitled to and shall receive from this Government the same protection of persons and property which is accorded to native-born citizens.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f176584-2930-11f1-8918-be39dde81dc6"},"text":"(R.S. § 2000.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f176585-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f176586-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8f176587-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2000 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1868-07-27/ch249/s2"},"text":"Act July 27, 1868, ch. 249, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/15/224"},"text":"15 Stat. 224","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s903a"},"text":"section 903a of Title 8","children":[],"tail":", Aliens and Nationality."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f176588-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8f176589-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Equitable Treatment by United States of Its Citizens Living Abroad","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/426/tVI/s611"},"text":"Pub. L. 95–426, title VI, § 611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-07"},"text":"Oct. 7, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/989"},"text":"92 Stat. 989","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/96/60/tIV/s407"},"text":"Pub. L. 96–60, title IV, § 407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-08-15"},"text":"Aug. 15, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/405"},"text":"93 Stat. 405","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/241/tV/s505/a/2"},"text":"Pub. L. 97–241, title V, § 505(a)(2)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"1982-08-24"},"text":"Aug. 24, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/299"},"text":"96 Stat. 299","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/241/tV/s505/a/2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Congress finds that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States citizens living abroad should be provided fair and equitable treatment by the United States Government with regard to taxation, citizenship of progeny, veterans’ benefits, voting rights, Social Security benefits, and other obligations, rights, and benefits; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States statutes and regulations should be designed so as not to create competitive disadvantage for individual American citizens living abroad or working in international markets.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
