{"tag":"section","attrib":{"id":"id8f2ce9ba-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2057"},"text":null,"children":[{"tag":"num","attrib":{"value":"2057"},"text":"§ 2057.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated, to remain available until expended, such amounts as may be necessary to carry out the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f2ce9bb-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/472"},"text":"Pub. L. 86–472","children":[],"tail":", ch. VII, § 705, "},{"tag":"date","attrib":{"date":"1960-05-14"},"text":"May 14, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/142"},"text":"74 Stat. 142","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
