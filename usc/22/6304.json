{"tag":"section","attrib":{"id":"id90b3d797-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6304"},"text":null,"children":[{"tag":"num","attrib":{"value":"6304"},"text":"§ 6304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting on demarches","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90b3d798-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6304/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It is the sense of the Congress that the Department of State should, in the course of implementing its reporting responsibilities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3282/c"},"text":"section 3282(c) of this title","children":[],"tail":", include a summary of demarches that the United States has issued or received from foreign governments with respect to activities which are of significance from the proliferation standpoint."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b3d799-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6304/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this section, the term “demarche” means any official communication by one government to another, by written or oral means, intended by the originating government to express—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90b3d79a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6304/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a concern over a past, present, or possible future action or activity of the recipient government, or of a person within the jurisdiction of that government, contributing to the global spread of unsafeguarded special nuclear material or of nuclear explosive devices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b3d79b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6304/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a request for the recipient government to counter such action or activity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b3d79c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6304/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" both the concern and request described in subparagraphs (A) and (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90b3d79d-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tVIII/s828/b"},"text":"Pub. L. 103–236, title VIII, § 828(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/520"},"text":"108 Stat. 520","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90b3d79e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90b3d79f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id90b3d7a0-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 60 days after ","children":[{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/s831"},"text":"section 831 of Pub. L. 103–236","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
