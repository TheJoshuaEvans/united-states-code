{"tag":"section","attrib":{"id":"id8fbbe323-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430"},"text":null,"children":[{"tag":"num","attrib":{"value":"2430"},"text":"§ 2430.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The purpose of this subchapter is to encourage and support improvement in the lives of the people of Latin America and the Caribbean through market-oriented reforms and economic growth with interrelated actions to promote debt reduction, investment reforms, community based conservation, and sustainable use of the environment, and child survival and child development. The Facility will support these objectives through administration of debt reduction operations under this subchapter for those countries with democratically elected governments that meet investment reforms and other policy conditions.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8fbbe324-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. IV, § 701, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/549/tVI/s602/a"},"text":"Pub. L. 102–549, title VI, § 602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3664"},"text":"106 Stat. 3664","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fbbe325-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8fbbe326-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id8fbbe327-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195/s701"},"text":"section 701 of Pub. L. 87–195","children":[],"tail":", pt. IV, "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/463"},"text":"75 Stat. 463","children":[],"tail":", amended "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1651"},"text":"section 1651 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/87/565"},"text":"Pub. L. 87–565","children":[],"tail":", pt. IV, § 401, "},{"tag":"date","attrib":{"date":"1962-08-01"},"text":"Aug. 1, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/263"},"text":"76 Stat. 263","children":[],"tail":", except insofar as section 701 affected section 1651."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
