{"tag":"section","attrib":{"id":"id8e811884-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s212b"},"text":null,"children":[{"tag":"num","attrib":{"value":"212b"},"text":"§ 212b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unique passport identifiers for covered sex offenders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8e811885-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s212b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Immediately after receiving a written determination from the Angel Watch Center that an individual is a covered sex offender, through the process developed for that purpose under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s21507"},"text":"section 21507 of title 34","children":[],"tail":", the Secretary of State shall take appropriate action under subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8e811886-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s212b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to use unique passport identifiers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8e811887-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s212b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided under paragraph (2), the Secretary of State shall not issue a passport to a covered sex offender unless the passport contains a unique identifier, and may revoke a passport previously issued without such an identifier of a covered sex offender.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e811888-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s212b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to reissue","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (1), the Secretary of State may reissue a passport that does not include a unique identifier if an individual described in subsection (a) reapplies for a passport and the Angel Watch Center provides a written determination, through the process developed for that purpose under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s21507"},"text":"section 21507 of title 34","children":[],"tail":", to the Secretary of State that the individual is no longer required to register as a covered sex offender."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e811889-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s212b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clarification with respect to continuing registration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual may not be issued or reissued a passport without a unique identifier solely because the individual has moved or otherwise resides outside the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8e81188a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s212b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Defined terms","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8e81188b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s212b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “covered sex offender” means an individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8e81188c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s212b/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a sex offender, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s21503/f"},"text":"section 21503(f) of title 34","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8e81188d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s212b/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is currently required to register under the sex offender registration program of any jurisdiction;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e81188e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s212b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “unique identifier” means any visual designation affixed to a conspicuous location on the passport indicating that the individual is a covered sex offender; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e81188f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s212b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “passport” means a passport book or passport card.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8e811890-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s212b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State, the Secretary of Homeland Security, and the Attorney General, and their agencies, officers, employees, and agents, shall not be liable to any person for any action taken under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8e811891-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s212b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In furtherance of this section, the Secretary of State may require a passport applicant to disclose that they are a registered sex offender.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8e811892-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s212b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall take effect upon certification by the Secretary of State, the Secretary of Homeland Security, and the Attorney General, that the process developed and reported to the appropriate congressional committees under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s21507"},"text":"section 21507 of title 34","children":[],"tail":" has been successfully implemented."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8e811893-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/457/tII/s240"},"text":"Pub. L. 110–457, title II, § 240","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/119/s8"},"text":"Pub. L. 114–119, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/24"},"text":"130 Stat. 24","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/347/tIII/s323/b"},"text":"Pub. L. 117–347, title III, § 323(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6207"},"text":"136 Stat. 6207","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8e811894-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8e811895-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8e811896-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/347"},"text":"Pub. L. 117–347","children":[],"tail":" added par. (3)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
