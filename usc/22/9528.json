{"tag":"section","attrib":{"id":"id912fe4fc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9528"},"text":null,"children":[{"tag":"num","attrib":{"value":"9528"},"text":"§ 9528.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanctions with respect to the transfer of arms and related materiel to Syria","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id912fe4fd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9528/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of sanctions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id912fe4fe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9528/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall impose on a foreign person the sanctions described in subsection (b) if the President determines that such foreign person has, on or after ","children":[{"tag":"date","attrib":{"date":"2017-08-02"},"text":"August 2, 2017","children":[],"tail":", knowingly exported, transferred, or otherwise provided to Syria significant financial, material, or technological support that contributes materially to the ability of the Government of Syria to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id912fe4ff-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9528/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire or develop chemical, biological, or nuclear weapons or related technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id912fe500-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9528/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire or develop ballistic or cruise missile capabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id912fe501-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9528/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire or develop destabilizing numbers and types of advanced conventional weapons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id912fe502-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9528/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire significant defense articles, defense services, or defense information (as such terms are defined under the Arms Export Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2751"},"text":"22 U.S.C. 2751","children":[],"tail":" et seq.)); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id912fe503-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9528/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire items designated by the President for purposes of the United States Munitions List under section 38(a)(1) of the Arms Export Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2778/a/1"},"text":"22 U.S.C. 2778(a)(1)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id912fe504-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9528/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability to other foreign persons","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The sanctions described in subsection (b) shall also be imposed on any foreign person that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id912fe505-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9528/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a successor entity to a foreign person described in paragraph (1); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id912fe506-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9528/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is owned or controlled by, or has acted for or on behalf of, a foreign person described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id912fe507-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9528/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanctions described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The sanctions to be imposed on a foreign person described in subsection (a) are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id912fe508-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9528/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Blocking of property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall exercise all powers granted by the International Emergency Economic Powers Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":" et seq.) (except that the requirements of section 202 of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":") shall not apply) to the extent necessary to block and prohibit all transactions in all property and interests in property of the foreign person if such property and interests in property are in the United States, come within the United States, or are or come within the possession or control of a United States person."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id912fe509-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9528/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aliens ineligible for visas, admission, or parole","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id912fe50a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9528/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion from the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the foreign person is an individual, the Secretary of State shall deny a visa to, and the Secretary of Homeland Security shall exclude from the United States, the foreign person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id912fe50b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9528/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Current visas revoked","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id912fe50c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9528/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The issuing consular officer, the Secretary of State, or the Secretary of Homeland Security (or a designee of one of such Secretaries) shall revoke any visa or other entry documentation issued to the foreign person regardless of when issued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id912fe50d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9528/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of revocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A revocation under clause (i) shall take effect immediately and shall automatically cancel any other valid visa or entry documentation that is in the possession of the foreign person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id912fe50e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9528/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9511"},"text":"section 9511 of this title","children":[],"tail":", the President may waive the application of sanctions under subsection (b) with respect to a person if the President determines that such a waiver is in the national security interest of the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id912fe50f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9528/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id912fe510-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9528/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial, material, or technological support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “financial, material, or technological support” has the meaning given such term in section 542.304 of title 31, Code of Federal Regulations (or any corresponding similar regulation or ruling).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id912fe511-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9528/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “foreign person” has the meaning given such term in section 594.304 of title 31, Code of Federal Regulations (or any corresponding similar regulation or ruling).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id912fe512-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9528/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Syria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Syria” has the meaning given such term in section 542.316 of title 31, Code of Federal Regulations (or any corresponding similar regulation or ruling).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id912fe513-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/44/tII/s234"},"text":"Pub. L. 115–44, title II, § 234","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-02"},"text":"Aug. 2, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/918"},"text":"131 Stat. 918","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id912fe514-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id912fe515-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id912fe516-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Arms Export Control Act, referred to in subsec. (a)(1)(D), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/629"},"text":"Pub. L. 90–629","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1320"},"text":"82 Stat. 1320","children":[],"tail":", which is classified principally to chapter 39 (§ 2751 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2751"},"text":"section 2751 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The International Emergency Economic Powers Act, referred to in subsec. (b)(1), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/223"},"text":"Pub. L. 95–223","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-12-28"},"text":"Dec. 28, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1626"},"text":"91 Stat. 1626","children":[],"tail":", which is classified generally to chapter 35 (§ 1701 et seq.) of Title 50, War and National Defense. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"section 1701 of Title 50","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
