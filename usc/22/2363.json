{"tag":"section","attrib":{"id":"id8f9ce873-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2363"},"text":null,"children":[{"tag":"num","attrib":{"value":"2363"},"text":"§ 2363.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accounting, valuation, reporting, and administration of foreign currencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f9ce874-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2363/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibility of Secretary of the Treasury; regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under the direction of the President, the Secretary of the Treasury shall have responsibility for valuation and central accounting with respect to foreign credits (including currencies) owed to or owned by the United States. In order to carry out such responsibility the Secretary shall issue regulations binding upon all agencies of the Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f9ce875-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2363/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of exchange rates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall have sole authority to establish for all foreign currencies or credits the exchange rates at which such currencies are to be reported by all agencies of the Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f9ce876-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2363/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/113/tVII/s734/a/1"},"text":"Pub. L. 97–113, title VII, § 734(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1560"},"text":"95 Stat. 1560","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f9ce877-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2363/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest income on foreign currency proceeds; regulations; waiver; report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In cases where assistance is to be furnished to any recipient country in furtherance of the purposes of this chapter or any other Act on a basis which will result in the accrual of foreign currency proceeds to the United States, the Secretary of the Treasury shall issue regulations requiring that agreements, in respect of such assistance, include provisions for the receipt of interest income on the foreign currency proceeds deposited in authorized depositaries: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That whenever the Secretary of State determines it not to be in the national interest to conclude arrangements for the receipt of interest income he may waive the requirement thereof: "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That the Secretary of State, or his delegate, shall promptly make a complete report to the Congress on each such determination and the reasons therefor."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f9ce878-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. III, § 613, "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/443"},"text":"75 Stat. 443","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/171"},"text":"Pub. L. 89–171","children":[],"tail":", pt. III, § 301(c), "},{"tag":"date","attrib":{"date":"1965-09-06"},"text":"Sept. 6, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/659"},"text":"79 Stat. 659","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/273/s46"},"text":"Pub. L. 94–273, § 46","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-21"},"text":"Apr. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/382"},"text":"90 Stat. 382","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/113/tVII/s734/a/1"},"text":"Pub. L. 97–113, title VII, § 734(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1560"},"text":"95 Stat. 1560","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f9ce879-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f9ce87a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8f9ce87b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (d), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/424"},"text":"75 Stat. 424","children":[],"tail":", known as the Foreign Assistance Act of 1961. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f9ce87c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1981—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/113"},"text":"Pub. L. 97–113","children":[],"tail":" struck out subsec. (c) which provided for semi-annual reports on foreign currencies acquired without payment of dollars by the United States. See "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2394/a/8"},"text":"section 2394(a)(8) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/273"},"text":"Pub. L. 94–273","children":[],"tail":" inserted provision relating to reports after "},{"tag":"date","attrib":{"date":"1975-12-31"},"text":"Dec. 31, 1975","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/171"},"text":"Pub. L. 89–171","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id8f9ce87d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id8f9ce87e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions of President under this section, see Ex. Ord. No. 12163, ","children":[{"tag":"date","attrib":{"date":"1979-09-29"},"text":"Sept. 29, 1979","children":[],"tail":", 44 F.R. 56673, as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2381"},"text":"section 2381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
