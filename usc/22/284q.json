{"tag":"section","attrib":{"id":"id8ebcc1fe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284q"},"text":null,"children":[{"tag":"num","attrib":{"value":"284q"},"text":"§ 284q.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special Facility for Sub-Saharan Africa","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ebcc1ff-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284q/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Treasury shall pay to the Special Facility for Sub-Saharan Africa, administered by the Association, amounts appropriated pursuant to subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ebcc200-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284q/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of the United States contribution provided for in subsection (a), there are authorized to be appropriated, without fiscal year limitation, $225,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ebcc201-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/565/s19"},"text":"Pub. L. 86–565, § 19","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/190/s101/i/tI"},"text":"Pub. L. 99–190, § 101(i) [title I, (a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-19"},"text":"Dec. 19, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1291"},"text":"99 Stat. 1291","children":[],"tail":", 1294.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ebcc202-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ebcc203-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8ebcc204-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/86/565/s19"},"text":"Section 19 of Pub. L. 86–565","children":[],"tail":" is based on section 102 of title I of H.R. 2253, Ninety-ninth Congress, as reported "},{"tag":"date","attrib":{"date":"1985-05-15"},"text":"May 15, 1985","children":[],"tail":", and enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/99/190"},"text":"Pub. L. 99–190","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ebcc205-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8ebcc206-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 101 of title I of H.R. 2253, as enacted into permanent law by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/190/s101/i/tI"},"text":"Pub. L. 99–190, § 101(i) [title I]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-19"},"text":"Dec. 19, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1291"},"text":"99 Stat. 1291","children":[],"tail":", 1294, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/190/s101/i/tI"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Congress hereby finds that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sub-Saharan Africa faces a virtually unprecedented condition of human misery which threatens the lives of one hundred and fifty million people;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only the combined effort of both the African nations themselves and international aid donors can overcome the obstacles to economic development which have given rise to conditions of famine, declining food production, infant mortality, desertification, and deteriorating infrastructure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" international relief efforts have helped to address the immediate crisis of starvation in Africa and the United States has made important contributions to this effort both bilaterally and through contributions to the multilateral development institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a serious shortfall in the external capital resources necessary to support the policy reform efforts of the African governments and to achieve the long-term development necessary to avert a chronic state of crisis in Sub-Saharan Africa;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Special Facility for Sub-Saharan Africa will have as its primary goal the implementation of policy reforms to help the African countries to help themselves;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to succeed, these efforts must be reinforced by development resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appalling conditions prevalent in the countries of Sub-Saharan Africa underscore the need for the United States to participate in a coordinated framework with the other aid donor countries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"“(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Special Facility for Sub-Saharan Africa provides such a framework and it is in the humanitarian, economic, and strategic interests of the United States to participate.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
