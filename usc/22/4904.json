{"tag":"section","attrib":{"id":"id90868584-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4904"},"text":null,"children":[{"tag":"num","attrib":{"value":"4904"},"text":"§ 4904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary of State","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90868585-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4904/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall determine which of the individuals selected by the Board will serve at each United States diplomatic or consular mission abroad and the position in which each will serve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90868586-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Fellows may be employed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90868587-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4904/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under a temporary appointment in the civil service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90868588-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4904/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under a limited appointment in the Foreign Service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90868589-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4904/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by contract under the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2669/c"},"text":"section 2669(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9086858a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4904/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds appropriated to the Department of State for “Salaries and Expenses” shall be used for the expenses incurred in carrying out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9086858b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/399/tX/s1005"},"text":"Pub. L. 99–399, title X, § 1005","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/894"},"text":"100 Stat. 894","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/204/tI/s187"},"text":"Pub. L. 100–204, title I, § 187","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1368"},"text":"101 Stat. 1368","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/454/s9/d"},"text":"Pub. L. 101–454, § 9(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-24"},"text":"Oct. 24, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1066"},"text":"104 Stat. 1066","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9086858c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9086858d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9086858e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/454"},"text":"Pub. L. 101–454","children":[],"tail":" substituted “abroad” for “in the Soviet Union or Eastern Europe”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/204"},"text":"Pub. L. 100–204","children":[],"tail":" amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “Such service shall be in accordance with the relevant authorities of the Foreign Service Act of 1980, the State Department Basic Authorities Act of 1956, and title 5.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
