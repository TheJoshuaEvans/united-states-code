{"tag":"section","attrib":{"id":"id904648a0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3753"},"text":null,"children":[{"tag":"num","attrib":{"value":"3753"},"text":"§ 3753.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disaster relief","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If an emergency arises because of disaster or calamity by flood, hurricane, earthquake, fire, pestilence, or like cause, not foreseen or otherwise provided for, and occurring in the Republic of Panama in such circumstances as to constitute an actual or potential hazard to health, safety, security, or property in the areas and installations made available to the United States pursuant to the Panama Canal Treaty of 1977 and related agreements, the Commission may expend funds available to the Commission for such purpose, and utilize or furnish materials, supplies, equipment, and services for relief, assistance, and protection.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id904648a1-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70/tI/s1343"},"text":"Pub. L. 96–70, title I, § 1343","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-27"},"text":"Sept. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/483"},"text":"93 Stat. 483","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tV/s5428/b"},"text":"Pub. L. 100–203, title V, § 5428(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-274"},"text":"101 Stat. 1330–274","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id904648a2-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id904648a3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id904648a4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" substituted “funds available” for “available funds appropriated”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id904648a5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id904648a6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1987 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1988-01-01"},"text":"Jan. 1, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/s5429"},"text":"section 5429 of Pub. L. 100–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3712"},"text":"section 3712 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
