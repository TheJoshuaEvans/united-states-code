{"tag":"section","attrib":{"id":"id8f25bd0b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1937"},"text":null,"children":[{"tag":"num","attrib":{"value":"1937"},"text":"§ 1937.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Irish counterpart account; approval of disposition","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Pursuant to section 1513(b)(6) ","children":[{"tag":"ref","attrib":{"idref":"fn002078"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002078"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, the disposition within Ireland of the unencumbered balance, in the amount of approximately 6,000,000 Irish pounds, of the special account of Irish funds established under article IV of the Economic Cooperation Agreement between the United States of America and Ireland, dated "},{"tag":"date","attrib":{"date":"1948-06-28"},"text":"June 28, 1948","children":[],"tail":", for the purposes of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f25bd0c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1937/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" scholarship exchange between the United States and Ireland;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f25bd0d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1937/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other programs and projects (including the establishment of an Agricultural Institute) to improve and develop the agricultural production and marketing potential of Ireland and to increase the production and efficiency of Irish industry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"pa