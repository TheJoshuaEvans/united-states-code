{"tag":"section","attrib":{"id":"id90678b87-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069c–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"4069c–1"},"text":"§ 4069c–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health benefits for certain former spouses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90678b88-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069c–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (c)(1), any individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90678b89-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069c–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" formerly married to an employee or former employee of the Foreign Service, whose marriage was dissolved by divorce or annulment before ","children":[{"tag":"date","attrib":{"date":"1985-05-07"},"text":"May 7, 1985","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90678b8a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069c–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who, at any time during the 18-month period before the divorce or annulment became final, was covered under a health benefits plan as a member of the family of such employee or former employee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90678b8b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069c–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who was married to such employee for not less than 10 years during periods of government service by such employee, is eligible for coverage under a health benefits plan in accordance with the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90678b8c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069c–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prerequisites for enrollment; notification of rights","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90678b8d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069c–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any individual eligible for coverage under subsection (a) may enroll in a health benefits plan for self alone or for self and family if, before the expiration of the 6-month period beginning on the effective date of this section, and in accordance with such procedures as the Director of the Office of Personnel Management shall by regulation prescribe, such individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90678b8e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069c–1/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" files an election for such enrollment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90678b8f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069c–1/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arranges to pay currently into the Employees Health Benefits Fund under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8909"},"text":"section 8909 of title 5","children":[],"tail":" an amount equal to the sum of the employee and agency contributions payable in the case of an employee enrolled under chapter 89 of such title in the same health benefits plan and with the same level of benefits."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90678b90-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069c–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall, as soon as possible, take all steps practicable—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90678b91-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069c–1/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine the identity and current address of each former spouse eligible for coverage under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90678b92-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069c–1/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to notify each such former spouse of that individual’s rights under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90678b93-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069c–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall waive the 6-month limitation set forth in paragraph (1) in any case in which the Secretary determines that the circumstances so warrant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90678b94-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069c–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disqualification","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90678b95-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069c–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any former spouse who remarries before age 55 is not eligible to make an election under subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90678b96-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069c–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any former spouse enrolled in a health benefits plan pursuant to an election under subsection (b)(1) may continue the enrollment under the conditions of eligibility which the Director of the Office of Personnel Management shall by regulation prescribe, except that any former spouse who remarries before age 55 shall not be eligible for continued enrollment under this section after the end of the 31-day period beginning on the date of remarriage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90678b97-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069c–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on coverage by more than one plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No individual may be covered by a health benefits plan under this section during any period in which such individual is enrolled in a health benefits plan under any other authority, nor may any individual be covered under more than one enrollment under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90678b98-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069c–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Health benefits plan” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section the term “health benefits plan” means an approved health benefits plan under chapter 89 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90678b99-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s833"},"text":"Pub. L. 96–465, title I, § 833","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/238/tII/s204/a"},"text":"Pub. L. 100–238, title II, § 204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-08"},"text":"Jan. 8, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1772"},"text":"101 Stat. 1772","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90678b9a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90678b9b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90678b9c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For the effective date of this section, referred to in subsec. (b)(1), see Effective Date note set out below.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90678b9d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id90678b9e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days after ","children":[{"tag":"date","attrib":{"date":"1988-01-08"},"text":"Jan. 8, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/238/s261/a"},"text":"section 261(a) of Pub. L. 100–238","children":[],"tail":", set out as an Effective Date of 1988 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4054"},"text":"section 4054 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
