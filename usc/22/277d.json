{"tag":"section","attrib":{"id":"id8eae6a73-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s277d"},"text":null,"children":[{"tag":"num","attrib":{"value":"277d"},"text":"§ 277d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds received from Mexico; expenditure","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any moneys contributed by or received from the United Mexican States, the North American Development Bank, or the Border Environment Cooperation Commission for the purpose of cooperating or assisting in carrying out the provisions of sections 277 to 277d of this title shall be available for expenditure in connection with any appropriation which may be made for the purposes of such sections.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8eae6a74-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1924-05-13/ch153/s5"},"text":"May 13, 1924, ch. 153, § 5","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1935-08-19/ch561"},"text":"Aug. 19, 1935, ch. 561","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/660"},"text":"49 Stat. 660","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/228/dA/tII/s210"},"text":"Pub. L. 107–228, div. A, title II, § 210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"Sept. 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1365"},"text":"116 Stat. 1365","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8eae6a75-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8eae6a76-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8eae6a77-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/228"},"text":"Pub. L. 107–228","children":[],"tail":" inserted “, the North American Development Bank, or the Border Environment Cooperation Commission” after “United Mexican States”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
