{"tag":"section","attrib":{"id":"id91218deb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9225"},"text":null,"children":[{"tag":"num","attrib":{"value":"9225"},"text":"§ 9225.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhanced inspection authorities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id91218dec-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9225/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report required","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91218ded-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9225/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2017-08-02"},"text":"August 2, 2017","children":[],"tail":", and annually thereafter for 5 years, the President shall submit to the appropriate congressional committees a report—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91218dee-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9225/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identifying the operators of foreign sea ports and airports that knowingly—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id91218def-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9225/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significantly fail to implement or enforce regulations to inspect ships, aircraft, cargo, or conveyances in transit to or from North Korea, as required by applicable United Nations Security Council resolutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91218df0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9225/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate the transfer, transshipment, or conveyance of significant types or quantities of cargo, vessels, or aircraft owned or controlled by persons designated under applicable United Nations Security Council resolutions; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91218df1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9225/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate any of the activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9214/a"},"text":"section 9214(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91218df2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9225/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describing the extent to which the requirements of applicable United Nations Security Council resolutions to de-register any vessel owned, controlled, or operated by or on behalf of the Government of North Korea have been implemented by other foreign countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91218df3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9225/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describing the compliance of the Islamic Republic of Iran with the sanctions mandated in applicable United Nations Security Council resolutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91218df4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9225/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying vessels, aircraft, and conveyances owned or controlled by the Reconnaissance General Bureau of the Workers’ Party of Korea; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91218df5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9225/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describing the diplomatic and enforcement efforts by the President to secure the full implementation of the applicable United Nations Security Council resolutions, as described in subparagraphs (A) through (C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91218df6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9225/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report required under paragraph (1) shall be submitted in unclassified form but may contain a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91218df7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9225/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report required under subsection (a) shall include specific findings with respect to the following ports and airports:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91218df8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9225/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The ports of Dandong, Dalian, and any other port in the People’s Republic of China that the President deems appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91218df9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9225/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The ports of Abadan, Bandar-e-Abbas, Chabahar, Bandar-e-Khomeini, Bushehr Port, Asaluyeh Port, Kish, Kharg Island, Bandar-e-Lenge, and Khorramshahr, and Tehran Imam Khomeini International Airport, in the Islamic Republic of Iran.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91218dfa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9225/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The ports of Nakhodka, Vanino, and Vladivostok, in the Russian Federation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91218dfb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9225/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The ports of Latakia, Banias, and Tartous, and Damascus International Airport, in the Syrian Arab Republic.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91218dfc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9225/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhanced security targeting requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91218dfd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9225/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (2), the Secretary of Homeland Security may, using a layered approach, require enhanced screening procedures to determine whether physical inspections are warranted of any cargo bound for or landed in the United States that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91218dfe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9225/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been transported through a sea port or airport the operator of which has been identified by the President in accordance with subsection (a)(1) as having repeatedly failed to comply with applicable United Nations Security Council resolutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91218dff-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9225/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is aboard a vessel or aircraft, or within a conveyance that has, within the last 365 days, entered the territory or waters of North Korea, or landed in any of the sea ports or airports of North Korea; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91218e00-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9225/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is registered by a country or jurisdiction whose compliance has been identified by the President as deficient pursuant to subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91218e01-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9225/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for food, medicine, and humanitarian shipments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply to any vessel, aircraft, or conveyance that has entered the territory or waters of North Korea, or landed in any of the sea ports or airports of North Korea, exclusively for the purposes described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9228/b/3/B"},"text":"section 9228(b)(3)(B) of this title","children":[],"tail":", or to import food, medicine, or supplies into North Korea to meet the humanitarian needs of the North Korean people."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91218e02-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9225/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Seizure and forfeiture","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A vessel, aircraft, or conveyance used to facilitate any of the activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9214/a"},"text":"section 9214(a) of this title","children":[],"tail":" under the jurisdiction of the United States may be seized and forfeited, or subject to forfeiture, under—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id91218e03-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9225/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 46 of title 18; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91218e04-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9225/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" part V of title IV of the Tariff Act of 1930 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1581"},"text":"19 U.S.C. 1581","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id91218e05-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/122/tII/s205"},"text":"Pub. L. 114–122, title II, § 205","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/44/tIII/s314"},"text":"Pub. L. 115–44, title III, § 314","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-02"},"text":"Aug. 2, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/946"},"text":"131 Stat. 946","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id91218e06-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id91218e07-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id91218e08-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Tariff Act of 1930, referred to in subsec. (d)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"act June 17, 1930, ch. 497","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/590"},"text":"46 Stat. 590","children":[],"tail":". Part V of title IV of the Act is classified generally to part V (§ 1581 et seq.) of subtitle III of chapter 4 of Title 19, Customs Duties. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1654"},"text":"section 1654 of Title 19","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id91218e09-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 9225, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/122/tII/s205"},"text":"Pub. L. 114–122, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-18"},"text":"Feb. 18, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/108"},"text":"130 Stat. 108","children":[],"tail":", related to enhanced inspection authorities, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/115/44/tIII/s314"},"text":"Pub. L. 115–44, title III, § 314","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-02"},"text":"Aug. 2, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/946"},"text":"131 Stat. 946","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id91218e0a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id91218e0b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions and authorities of President under subsec. (a) of this section delegated to Director of National Intelligence, in consultation with Secretary of State, by Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2016-05-18"},"text":"May 18, 2016","children":[],"tail":", 81 F.R. 37479, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s9212"},"text":"section 9212 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
