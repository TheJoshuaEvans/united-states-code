{"tag":"section","attrib":{"id":"id90595ae6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4025"},"text":null,"children":[{"tag":"num","attrib":{"value":"4025"},"text":"§ 4025.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90595ae7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4025/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Family members attending approved programs of study; limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To facilitate training provided to members of families of Government employees under this subchapter, the Secretary may make grants (by advance payment or by reimbursement) to family members attending approved programs of study. No such grant may exceed the amount actually expended for necessary costs incurred in conjunction with such attendance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90595ae8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4025/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation for individuals unable to participate in language training furnished by Government","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a member of the Service who is assigned abroad, or a member of his or her family, is unable to participate in language training furnished by the Government through the institution or otherwise, the Secretary may compensate that individual for all or part of the costs of language training, related to the assignment abroad, which is undertaken at a public or private institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90595ae9-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s705"},"text":"Pub. L. 96–465, title I, § 705","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2101"},"text":"94 Stat. 2101","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s126/3"},"text":"Pub. L. 103–236, title I, § 126(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/394"},"text":"108 Stat. 394","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90595aea-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90595aeb-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90595aec-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":" substituted “institution” for “Institute” after “through the”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
