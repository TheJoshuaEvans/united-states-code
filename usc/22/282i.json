{"tag":"section","attrib":{"id":"id8eb5964a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s282i"},"text":null,"children":[{"tag":"num","attrib":{"value":"282i"},"text":"§ 282i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increase in capital stock of Corporation; subscription to additional shares","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8eb5964b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s282i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The United States Governor of the Corporation is authorized—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8eb5964c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s282i/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to vote for an increase of five hundred and forty thousand shares in the authorized capital stock of the Corporation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8eb5964d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s282i/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such increase becomes effective, to subscribe on behalf of the United States to one hundred and eleven thousand four hundred and ninety-three additional shares of the capital stock of the Corporation: ","children":[{"tag":"i","attrib":{},"text":"Provided, however","children":[],"tail":", That any commitment to make payment for such additional subscriptions shall be made subject to obtaining the necessary appropriations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8eb8074e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s282i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to pay for the increase in the United States subscription to the Corporation provided for in this section, there are authorized to be appropriated, without fiscal year limitation, $111,493,000 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8eb8074f-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-08-11/ch788/s11"},"text":"Aug. 11, 1955, ch. 788, § 11","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/118/tIII/s301"},"text":"Pub. L. 95–118, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-10-03"},"text":"Oct. 3, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1068"},"text":"91 Stat. 1068","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8eb80750-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8eb80751-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id8eb80752-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/118/tX/s1001"},"text":"Pub. L. 95–118, title X, § 1001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-10-03"},"text":"Oct. 3, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1072"},"text":"91 Stat. 1072","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/118/tX/s1001"},"text":"“This Act [enacting this section and sections 262c, 262d, 262e to 262g, 284n, 285s, 285t, 286e–1f, and 290g–10 of this title, repealing sections 283y, 284m, 290g–9 of this title, and enacting provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s262c"},"text":"section 262c of this title","children":[],"tail":"] shall take effect on the date of its enactment ["},{"tag":"date","attrib":{"date":"1977-10-03"},"text":"Oct. 3, 1977","children":[],"tail":"], except that no funds authorized to be appropriated by any amendment contained in title II, III, IV, V, or VI [enacting this section and sections 286e–1f, 284n, 285s, 285t, or 290g–10 of this title] may be available for use or obligation prior to "},{"tag":"date","attrib":{"date":"1977-10-01"},"text":"October 1, 1977","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
