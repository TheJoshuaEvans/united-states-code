{"tag":"section","attrib":{"id":"id8ea4f495-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s263a"},"text":null,"children":[{"tag":"num","attrib":{"value":"263a"},"text":"§ 263a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International Criminal Police Organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Attorney General is authorized to accept and maintain, on behalf of the United States, membership in the International Criminal Police Organization, and to designate any departments and agencies which may participate in the United States representation with that organization. All dues and expenses to be paid for the membership of the United States shall be paid out of sums authorized and appropriated for the Department of Justice.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ea4f496-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-10/ch335"},"text":"June 10, 1938, ch. 335","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/640"},"text":"52 Stat. 640","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/768"},"text":"Pub. L. 85–768","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-27"},"text":"Aug. 27, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/921"},"text":"72 Stat. 921","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/159"},"text":"Pub. L. 90–159","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-11-28"},"text":"Nov. 28, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/517"},"text":"81 Stat. 517","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/380/s1"},"text":"Pub. L. 92–380, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-08-10"},"text":"Aug. 10, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/531"},"text":"86 Stat. 531","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/468/s1"},"text":"Pub. L. 93–468, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-24"},"text":"Oct. 24, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1422"},"text":"88 Stat. 1422","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/624/s21/a"},"text":"Pub. L. 95–624, § 21(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3466"},"text":"92 Stat. 3466","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ea4f497-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ea4f498-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8ea4f499-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/624"},"text":"Pub. L. 95–624","children":[],"tail":" substituted provision authorizing payment of all dues and expenses for membership of the United States out of sums authorized and appropriated for Department of Justice for provisions authorizing each participating department and agency to pay its pro rata share of expenses of such membership and forbidding total dues paid for such membership to exceed $120,000 per annum."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/468"},"text":"Pub. L. 93–468","children":[],"tail":" substituted “$120,000” for “$80,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/380"},"text":"Pub. L. 92–380","children":[],"tail":" substituted “$80,000” for “$28,500”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/159"},"text":"Pub. L. 90–159","children":[],"tail":" substituted “$28,500” for “$25,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/768"},"text":"Pub. L. 85–768","children":[],"tail":" authorized the Attorney General to designate departments and agencies which may participate, on a pro rata share basis, in the United States representation with the International Criminal Police Organization, and increased from $1,500 to $25,000 per annum the amount of expenses which may be incurred by reason of United States membership."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
