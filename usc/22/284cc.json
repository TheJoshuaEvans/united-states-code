{"tag":"section","attrib":{"id":"id8ebcc23e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"284cc"},"text":"§ 284cc.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nineteenth replenishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ebcc23f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284cc/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States Governor of the International Development Association is authorized to contribute on behalf of the United States $3,004,200,000 to the nineteenth replenishment of the resources of the Association, subject to obtaining the necessary appropriations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ebcc240-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284cc/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to pay for the United States contribution provided for in subsection (a), there are authorized to be appropriated, without fiscal year limitation, $3,004,200,000 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ebcc241-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/565/s31"},"text":"Pub. L. 86–565, § 31","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/dB/tXI/s21012/b/1"},"text":"Pub. L. 116–136, div. B, title XI, 