{"tag":"section","attrib":{"id":"id900101de-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2732a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2732a"},"text":"§ 2732a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Avoiding duplication of programs and efforts","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id900101df-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2732a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify opportunities for greater efficiency of operations, including through improved coordination of efforts across public diplomacy bureaus and offices of the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id900101e0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2732a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maximize shared use of resources between, and within, such public diplomacy bureaus and offices in cases in which programs, facilities, or administrative functions are duplicative or substantially overlapping.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id900101e1-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dE/tLVI/s5602"},"text":"Pub. L. 117–81, div. E, title LVI, § 5602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2377"},"text":"135 Stat. 2377","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id900101e2-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id900101e3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id900101e4-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “Secretary” and “Department” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s5002"},"text":"section 5002 of Pub. L. 117–81","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s263c"},"text":"section 263c of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dE/tLVI/s5607"},"text":"Pub. L. 117–81, div. E, title LVI, § 5607","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2380"},"text":"135 Stat. 2380","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/81/dE/tLVI/s5607"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In this title [enacting this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2732b"},"text":"section 2732b of this title","children":[],"tail":", amending "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6553"},"text":"section 6553 of this title","children":[],"tail":", and enacting provisions set out as notes under sections 1475g and 2651 of this title]:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Audience research","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘audience research’ means research conducted at the outset of a public diplomacy program or the outset of campaign planning and design regarding specific audience segments to understand the attitudes, interests, knowledge, and behaviors of such audience segments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Digital analytics","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘digital analytics’ means the analysis of qualitative and quantitative data, accumulated in digital format, to indicate the outputs and outcomes of a public diplomacy program or campaign.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Impact evaluation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘impact evaluation’ means an assessment of the changes in the audience targeted by a public diplomacy program or campaign that can be attributed to such program or campaign.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public diplomacy bureaus and offices","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘public diplomacy bureaus and offices’ means, with respect to the Department, the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Bureau of Educational and Cultural Affairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Bureau of Global Public Affairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Policy, Planning, and Resources for Public Diplomacy and Public Affairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Global Engagement Center.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The public diplomacy functions within the regional and functional bureaus.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
