{"tag":"section","attrib":{"id":"id90bd7493-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6501"},"text":null,"children":[{"tag":"num","attrib":{"value":"6501"},"text":"§ 6501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this chapter are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90bd7494-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6501/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to strengthen—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90bd7495-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6501/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the coordination of United States foreign policy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90bd7496-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6501/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the leading role of the Secretary of State in the formulation and articulation of United States foreign policy;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bd7497-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6501/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to consolidate and reinvigorate the foreign affairs functions of the United States within the Department of State by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90bd7498-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6501/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" abolishing the United States Arms Control and Disarmament Agency, the United States Information Agency, and the United States International Development Cooperation Agency, and transferring the functions of these agencies to the Department of State while preserving the special missions and skills of these agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90bd7499-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6501/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transferring certain functions of the Agency for International Development to the Department of State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90bd749a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6501/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing for the reorganization of the Department of State to maximize the efficient use of resources, which may lead to budget savings, eliminated redundancy in functions, and improvement in the management of the Department of State;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bd749b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6501/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that programs critical to the promotion of United States national interests be maintained;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bd749c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6501/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist congressional efforts to balance the Federal budget and reduce the Federal debt;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bd749d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6501/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that the United States maintains effective representation abroad within budgetary restraints; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bd749e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6501/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage United States foreign affairs agencies to maintain a high percentage of the best qualified, most competent United States citizens serving in the United States Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90bd749f-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. A, title XI, § 1102, "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-765"},"text":"112 Stat. 2681–765","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90bd74a0-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90bd74a1-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90bd74a2-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this subdivision”, meaning subdiv. A of div. G of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-765"},"text":"112 Stat. 2681–765","children":[],"tail":", known as the Foreign Affairs Agencies Consolidation Act of 1998. For complete classification of this subdivision to the Code, see Short Title note below and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90bd74a3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id90bd74a4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG/s1001"},"text":"Pub. L. 105–277, div. G, § 1001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-761"},"text":"112 Stat. 2681–761","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/277/dG/s1001"},"text":"“This division [see Tables for classification] may be cited as the ‘Foreign Affairs Reform and Restructuring Act of 1998’.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. A, title XI, § 1101, "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-765"},"text":"112 Stat. 2681–765","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/277/dG"},"text":"“This subdivision [see Tables for classification] may be cited as the ‘Foreign Affairs Agencies Consolidation Act of 1998’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
