{"tag":"section","attrib":{"id":"id9147b21a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9633"},"text":null,"children":[{"tag":"num","attrib":{"value":"9633"},"text":"§ 9633.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum contingent liability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9147b21b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9633/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The maximum contingent liability of the Corporation outstanding at any one time shall not exceed in the aggregate $205,000,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9147b21c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9633/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The maximum contingent liability shall apply to all extension of liability by the Corporation regardless of the authority cited thereto.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9147b21d-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dF/tIII/s1433"},"text":"Pub. L. 115–254, div. F, title III, § 1433","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3501"},"text":"132 Stat. 3501","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dH/tLXXXVII/s8753"},"text":"Pub. L. 119–60, div. H, title LXXXVII, § 8753","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1964"},"text":"139 Stat. 1964","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9147b21e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9147b21f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9147b220-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" amended section generally. Prior to amendment, text of section read as follows: “The maximum contingent liability of the Corporation outstanding at any one time shall not exceed in the aggregate $60,000,000,000.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
