{"tag":"section","attrib":{"id":"id907a9e96-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4414"},"text":null,"children":[{"tag":"num","attrib":{"value":"4414"},"text":"§ 4414.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements relating to the Endowment and its grantees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id907a9e97-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4414/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partisan politics","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id907a9e98-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4414/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds may not be expended, either by the Endowment or by any of its grantees, to finance the campaigns of candidates for public office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id907a9e99-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4414/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No funds granted by the Endowment may be used to finance activities of the Republican National Committee or the Democratic National Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id907a9e9a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4414/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No grants may be made to any institute, foundation, or organization engaged in partisan activities on behalf of the Republican or Democratic National Committee, on behalf of any candidate for public office, or on behalf of any political party in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id907a9e9b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4414/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with Department of State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Endowment shall consult with the Department of State on any overseas program funded by the Endowment prior to the commencement of the activities of that program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id907a9e9c-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/164/tV/s505"},"text":"Pub. L. 98–164, title V, § 505","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/93/tII/s210/a"},"text":"Pub. L. 99–93, title II, § 210(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-16"},"text":"Aug. 16, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/431"},"text":"99 Stat. 431","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
