{"tag":"section","attrib":{"id":"id8ec17d69-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286e–1g"},"text":null,"children":[{"tag":"num","attrib":{"value":"286e–1g"},"text":"§ 286e–1g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional increase in quota of United States; condition","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The United States Governor of the Fund is authorized to consent to an increase in the quota of the United States in the Fund equivalent to 4,202.5 million Special Drawing Rights, limited to such amounts as are appropriated in advance in appropriation Acts.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ec17d6a-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-07-31/ch339/s32"},"text":"July 31, 1945, ch. 339, § 32","children":[],"tail":", as added and amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/389"},"text":"Pub. L. 96–389","children":[],"tail":", §§ 1, 11, "},{"tag":"date","attrib":{"date":"1980-10-07"},"text":"Oct. 7, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1551"},"text":"94 Stat. 1551","children":[],"tail":", 1555.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ec17d6b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ec17d6c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8ec17d6d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/389/s11"},"text":"Pub. L. 96–389, § 11","children":[],"tail":", substituted “limited to such amounts as are appropriated in advance in appropriation Acts” for “to such extent or in such amounts as are provided in appropriations Acts”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ec17d6e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id8ec17d6f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1980-10-07"},"text":"Oct. 7, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/389/s12"},"text":"section 12 of Pub. L. 96–389","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s286s"},"text":"section 286s of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
