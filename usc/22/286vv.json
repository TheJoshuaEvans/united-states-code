{"tag":"section","attrib":{"id":"id8ecb1a87-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286vv"},"text":null,"children":[{"tag":"num","attrib":{"value":"286vv"},"text":"§ 286vv.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capital stock increases","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ecb1a88-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286vv/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increases authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The United States Governor of the Bank is authorized—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ecb1a89-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286vv/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ecb1a8a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286vv/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to vote in favor of a resolution to increase the capital stock of the Bank on a selective basis by 230,374 shares; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ecb1a8b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286vv/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to subscribe on behalf of the United States to 38,459 additional shares of the capital stock of the Bank, as part of the selective increase in the capital stock of the Bank, except that any subscription to such additional shares shall be effective only to such extent or in such amounts as are provided in advance in appropriations Acts;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ecb1a8c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286vv/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ecb1a8d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286vv/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to vote in favor of a resolution to increase the capital stock of the Bank on a general basis by 484,102 shares; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ecb1a8e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286vv/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to subscribe on behalf of the United States to 81,074 additional shares of the capital stock of the Bank, as part of the general increase in the capital stock of the Bank, except that any subscription to such additional shares shall be effective only to such extent or in such amounts as are provided in advance in appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ecb1a8f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286vv/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ecb1a90-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286vv/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to pay for the increase in the United States subscription to the Bank under subsection (a)(2)(B), there are authorized to be appropriated, without fiscal year limitation, $9,780,361,991 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ecb1a91-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286vv/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Of the amount authorized to be appropriated under paragraph (2)(A)— ","children":[{"tag":"ref","attrib":{"idref":"fn002032"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002032"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “paragraph (1)—”."}],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ecb1a92-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286vv/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $586,821,720 shall be for paid in shares of the Bank; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ecb1a93-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286vv/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $9,193,540,271 shall be for callable shares of the Bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ecb1a94-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286vv/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to pay for the increase in the United States subscription to the Bank under subsection (a)(1)(B), there are authorized to be appropriated, without fiscal year limitation, $4,639,501,466 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ecb1a95-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286vv/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Of the amount authorized to be appropriated under paragraph (3), $278,370,088 shall be for paid in shares of the Bank, and $4,361,131,378 shall be for callable shares of the Bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ecb1a96-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-07-31/ch339/s70"},"text":"July 31, 1945, ch. 339, § 70","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/74/dI/tVII/s7081/a"},"text":"Pub. L. 112–74, div. I, title VII, § 7081(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-23"},"text":"Dec. 23, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1259"},"text":"125 Stat. 1259","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/6/dF/tVII/s1704/d"},"text":"Pub. L. 113–6, div. F, title VII, § 1704(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-03-26"},"text":"Mar. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/429"},"text":"127 Stat. 429","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ecb1a97-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ecb1a98-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8ecb1a99-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—Subsec. (b)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/6"},"text":"Pub. L. 113–6","children":[],"tail":" added pars. (3) and (4)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
