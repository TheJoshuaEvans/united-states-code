{"tag":"section","attrib":{"id":"id9027270a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798"},"text":null,"children":[{"tag":"num","attrib":{"value":"2798"},"text":"§ 2798.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanctions against certain foreign persons","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9027270b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of sanctions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9027270c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination by the President","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b)(2), the President shall impose both of the sanctions described in subsection (c) if the President determines that a foreign person, on or after ","children":[{"tag":"date","attrib":{"date":"1991-10-28"},"text":"October 28, 1991","children":[],"tail":", has knowingly and materially contributed—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9027270d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through the export from the United States of any goods or technology that are subject to the jurisdiction of the United States,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9027270e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through the export from any other country of any goods or technology that would be, if they were United States goods or technology, subject to the jurisdiction of the United States, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9027270f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through any other transaction not subject to sanctions pursuant to the Export Administration Act of 1979,","children":[{"tag":"ref","attrib":{"idref":"fn002236"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002236"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"to the efforts by any foreign country, project, or entity described in paragraph (2) to use, develop, produce, stockpile, or otherwise acquire chemical or biological weapons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90272710-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Countries, projects, or entities receiving assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) applies in the case of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90272711-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any foreign country that the President determines has, at any time after ","children":[{"tag":"date","attrib":{"date":"1980-01-01"},"text":"January 1, 1980","children":[],"tail":"—"}],"tail":null},{"tag":"clause","attrib":{"id":"id90272712-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used chemical or biological weapons in violation of international law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90272713-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used lethal chemical or biological weapons against its own nationals; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90272714-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made substantial preparations to engage in the activities described in clause (i) or (ii);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90272715-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any foreign country whose government is determined for purposes of section 6(j) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of the Export Administration Act of 1979 to be a government that has repeatedly provided support for acts of international terrorism; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90272716-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other foreign country, project, or entity designated by the President for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90272717-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons against whom sanctions are to be imposed","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Sanctions shall be imposed pursuant to paragraph (1) on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90272718-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the foreign person with respect to which the President makes the determination described in that paragraph;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90272719-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any successor entity to that foreign person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9027271a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any foreign person that is a parent or subsidiary of that foreign person if that parent or subsidiary knowingly assisted in the activities which were the basis of that determination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9027271b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any foreign person that is an affiliate of that foreign person if that affiliate knowingly assisted in the activities which were the basis of that determination and if that affiliate is controlled in fact by that foreign person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9027271c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultations with and actions by foreign government of jurisdiction","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9027271d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the President makes the determinations described in subsection (a)(1) with respect to a foreign person, the Congress urges the President to initiate consultations immediately with the government with primary jurisdiction over that foreign person with respect to the imposition of sanctions pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9027271e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions by government of jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to pursue such consultations with that government, the President may delay imposition of sanctions pursuant to this section for a period of up to 90 days. Following these consultations, the President shall impose sanctions unless the President determines and certifies to the Congress that that government has taken specific and effective actions, including appropriate penalties, to terminate the involvement of the foreign person in the activities described in subsection (a)(1). The President may delay imposition of sanctions for an additional period of up to 90 days if the President determines and certifies to the Congress that that government is in the process of taking the actions described in the preceding sentence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9027271f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall report to the Congress, not later than 90 days after making a determination under subsection (a)(1), on the status of consultations with the appropriate government under this subsection, and the basis for any determination under paragraph (2) of this subsection that such government has taken specific corrective actions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90272720-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanctions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90272721-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Description of sanctions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The sanctions to be imposed pursuant to subsection (a)(1) are, except as provided in paragraph (2) of this subsection, the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90272722-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procurement sanction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States Government shall not procure, or enter into any contract for the procurement of, any goods or services from any person described in subsection (a)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90272723-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Import sanctions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The importation into the United States of products produced by any person described in subsection (a)(3) shall be prohibited.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90272724-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall not be required to apply or maintain sanctions under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90272725-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of procurement of defense articles or defense services—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90272726-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under existing contracts or subcontracts, including the exercise of options for production quantities to satisfy United States operational military requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90272727-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the President determines that the person or other entity to which the sanctions would otherwise be applied is a sole source supplier of the defense articles or services, that the defense articles or services are essential, and that alternative sources are not readily or reasonably available; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90272728-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the President determines that such articles or services are essential to the national security under defense coproduction agreements;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90272729-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to products or services provided under contracts entered into before the date on which the President publishes his intention to impose sanctions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9027272a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9027272b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" spare parts,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9027272c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" component parts, but not finished products, essential to United States products or production, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9027272d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/c/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" routine servicing and maintenance of products, to the extent that alternative sources are not readily or reasonably available;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9027272e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to information and technology essential to United States products or production; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9027272f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to medical or other humanitarian items.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90272730-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of sanctions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The sanctions imposed pursuant to this section shall apply for a period of at least 12 months following the imposition of sanctions and shall cease to apply thereafter only if the President determines and certifies to the Congress that reliable information indicates that the foreign person with respect to which the determination was made under subsection (a)(1) has ceased to aid or abet any foreign government, project, or entity in its efforts to acquire chemical or biological weapons capability as described in that subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90272731-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90272732-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criterion for waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may waive the application of any sanction imposed on any person pursuant to this section, after the end of the 12-month period beginning on the date on which that sanction was imposed on that person, if the President determines and certifies to the Congress that such waiver is important to the national security interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90272733-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of and report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the President decides to exercise the waiver authority provided in paragraph (1), the President shall so notify the Congress not less than 20 days before the waiver takes effect. Such notification shall include a report fully articulating the rationale and circumstances which led the President to exercise the waiver authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90272734-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Foreign person” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this section, the term “foreign person” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90272735-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual who is not a citizen of the United States or an alien admitted for permanent residence to the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90272736-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2798/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a corporation, partnership, or other entity which is created or organized under the laws of a foreign country or which has its principal place of business outside the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90272737-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/629"},"text":"Pub. L. 90–629","children":[],"tail":", ch. 8, § 81, as added and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/182/tIII"},"text":"Pub. L. 102–182, title III","children":[],"tail":", §§ 305(b), 309(b)(2), "},{"tag":"date","attrib":{"date":"1991-12-04"},"text":"Dec. 4, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1250"},"text":"105 Stat. 1250","children":[],"tail":", 1258.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90272738-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90272739-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9027273a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Export Administration Act of 1979, referred to in subsec. (a)(1)(C), (2)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/72"},"text":"Pub. L. 96–72","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-29"},"text":"Sept. 29, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/503"},"text":"93 Stat. 503","children":[],"tail":", which was classified principally to chapter 56 (§ 4601 et seq.) of Title 50, War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXVII/s1766/a"},"text":"Pub. L. 115–232, div. A, title XVII, § 1766(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2232"},"text":"132 Stat. 2232","children":[],"tail":", except for sections 11A, 11B, and 11C thereof ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4611"},"text":"50 U.S.C. 4611","children":[],"tail":", 4612, 4613). Section 6 of the Act was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4605"},"text":"section 4605 of Title 50","children":[],"tail":" prior to repeal."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id9027273b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior subchapter VIII, consisting of former section 2798, as added by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/138/tV/s505/b"},"text":"Pub. L. 102–138, title V, § 505(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/727"},"text":"105 Stat. 727","children":[],"tail":", was substantially identical to subchapter VIII, as added by "},{"tag":"ref","attrib":{"href":"/us/pl/102/182/s305/b"},"text":"section 305(b) of Pub. L. 102–182","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/182/tIII/s309/a"},"text":"Pub. L. 102–182, title III, § 309(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-04"},"text":"Dec. 4, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1258"},"text":"105 Stat. 1258","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9027273c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/182/s309/b/2"},"text":"Pub. L. 101–182, § 309(b)(2)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"October 28, 1991","children":[],"tail":"” for reference to the “date of the enactment of this section” which was enacted "},{"tag":"date","attrib":{"date":"1991-12-04"},"text":"Dec. 4, 1991","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id9027273d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id9027273e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of certain functions of the President under this section, see Ex. Ord. No. 12851, § 1(a), ","children":[{"tag":"date","attrib":{"date":"1993-06-11"},"text":"June 11, 1993","children":[],"tail":", 58 F.R. 33181, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2797"},"text":"section 2797 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
