{"tag":"section","attrib":{"id":"id8ff06028-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2661b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2661b"},"text":"§ 2661b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Services provided to the press","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In fiscal year 2001 and thereafter reimbursements for services provided to the press in connection with the travel of senior-level officials may be collected and credited to this appropriation and shall remain available until expended.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ff06029-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/553/s1/a/2/tIV"},"text":"Pub. L. 106–553, § 1(a)(2) [title IV]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2762"},"text":"114 Stat. 2762","children":[],"tail":", 2762A–90.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ff0602a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ff0602b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8ff0602c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This appropriation, referred to in text, probably means appropriations under the headings “DEPARTMENT OF STATE”, “","children":[{"tag":"inline","attrib":{},"text":"Administration of Foreign Affairs","children":[],"tail":"”, and “"},{"tag":"inline","attrib":{},"text":"diplomatic and consular programs","children":[],"tail":"” of the annual Department of State and Related Agency Appropriations Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ff0602d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8ff0602e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References to Diplomatic and Consular Programs Account","children":[],"tail":null},{"tag":"p","attrib":{},"text":"References to the Diplomatic and Consular Programs account to be construed to include the Diplomatic Programs account in fiscal year 2020 and each fiscal year thereafter, see par. (7) of title I of div. G of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94"},"text":"Pub. L. 116–94","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
