{"tag":"section","attrib":{"id":"id90489222-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3791"},"text":null,"children":[{"tag":"num","attrib":{"value":"3791"},"text":"§ 3791.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prescription of measurement rules and rates of tolls","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Commission may, subject to the provisions of this chapter, prescribe and from time to time change—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90489223-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3791/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rules for the measurement of vessels for the Panama Canal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90489224-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3791/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the tolls that shall be levied for use of the Panama Canal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90489225-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70/tI/s1601"},"text":"Pub. L. 96–70, title I, § 1601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-27"},"text":"Sept. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/489"},"text":"93 Stat. 489","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dC/tXXXV/s3527"},"text":"Pub. L. 104–106, div. C, title XXXV, § 3527","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/641"},"text":"110 Stat. 641","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90489226-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90489227-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90489228-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70"},"text":"Pub. L. 96–70","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-27"},"text":"Sept. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/452"},"text":"93 Stat. 452","children":[],"tail":", known as the Panama Canal Act of 1979, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3601"},"text":"section 3601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90489229-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" reenacted section catchline without change and amended text generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) The President is authorized, subject to the provisions of this part, to prescribe and from time to time change—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) the rules for the measurement of vessels for the Panama Canal; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) the tolls that shall be levied for the use of the Canal.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) Such rules of measurement and tolls prevailing on ","children":[{"tag":"date","attrib":{"date":"1979-10-01"},"text":"October 1, 1979","children":[],"tail":", shall continue in effect until changed as provided in this part.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
