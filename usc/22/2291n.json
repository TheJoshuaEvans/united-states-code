{"tag":"section","attrib":{"id":"id8f7def0e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291n"},"text":null,"children":[{"tag":"num","attrib":{"value":"2291n"},"text":"§ 2291n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exchange program on demand reduction matters relating to illicit use of covered synthetic drugs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f7def0f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291n/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall establish or continue and strengthen, as appropriate, an exchange program for governmental and nongovernmental personnel in the United States and in foreign countries to provide educational and professional development on demand reduction matters relating to the illicit use of covered synthetic drugs and other drugs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f7def10-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291n/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program required by subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f7def11-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291n/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be limited to individuals who have expertise and experience in matters described in subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f7def12-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291n/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of inbound exchanges, may be carried out as part of exchange programs and international visitor programs administered by the Bureau of Educational and Cultural Affairs of the Department of State, including the International Visitor Leadership Program, in coordination with the Bureau of International Narcotics and Law Enforcement Affairs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f7def13-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291n/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall include outbound exchanges for governmental or nongovernmental personnel in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f7def14-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291n/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary of State to carry out this section $1,000,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f7def15-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLV/s5554"},"text":"Pub. L. 117–263, div. E, title LV, § 5554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3342"},"text":"136 Stat. 3342","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f7def16-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f7def17-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8f7def18-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Fighting Emerging Narcotics Through Additional Nations to Yield Lasting Results Act, also known as the FENTANYL Results Act, and also as part of the James M. Inhofe National Defense Authorization Act for Fiscal Year 2023, and not as part of the Foreign Assistance Act of 1961 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f7def19-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8f7def1a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Nothing in subtitle C (§§ 5551–5558) of title LV of div. E of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":", or the amendments made by that subtitle, to be construed as affecting the prioritization of extradition requests, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5557"},"text":"section 5557 of Pub. L. 117–263","children":[],"tail":", set out as a note under section 2291"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id8f7def1b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “covered synthetic drug” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5558"},"text":"section 5558 of Pub. L. 117–263","children":[],"tail":", set out as a note under section 2291"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
