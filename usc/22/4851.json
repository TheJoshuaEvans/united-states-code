{"tag":"section","attrib":{"id":"id9081cb55-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4851"},"text":null,"children":[{"tag":"num","attrib":{"value":"4851"},"text":"§ 4851.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9081cb56-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4851/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Diplomatic security program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9081cb57-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4851/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to amounts otherwise available for such purposes, the following amounts are authorized to be appropriated for fiscal years 1986 and 1987, for the Department of State to carry out diplomatic security construction, acquisition, and operations pursuant to the Department of State’s Supplemental Diplomatic Security Program, as justified to the Congress for the respective fiscal year for “Administration of Foreign Affairs”, as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9081cb58-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4851/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For “Salaries and Expenses”, $308,104,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9081cb59-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4851/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For “Acquisition and Maintenance of Buildings Abroad”, $857,806,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9081cb5a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4851/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For “Counterterrorism Research and Development”, $15,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9081cb5b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4851/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9081cb5c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4851/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s101/c"},"text":"Pub. L. 103–236, title I, § 101(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/388"},"text":"108 Stat. 388","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9081cb5d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4851/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of amounts authorized to be appropriated","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts authorized to be appropriated by this subsection, and by the amendment made by paragraph (2), shall be allocated as provided in the table entitled “Diplomatic Security Program” relating to this section which appears in the Joint Explanatory Statement of the Committee of Conference to accompany H.R. 4151 of the 99th Congress (the Omnibus Diplomatic Security and Antiterrorism Act of 1986).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9081cb5e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4851/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification to authorizing Committees of requests for appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any fiscal year, whenever the Secretary of State submits to the Congress a request for appropriations to carry out the program described in subsection (a), the Secretary shall notify the Committee on Foreign Affairs of the House of Representatives and the Committee on Foreign Relations of the Senate of such request, together with a justification of each item listed in such request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9081cb5f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4851/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s122/b"},"text":"Pub. L. 103–236, title I, § 122(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/392"},"text":"108 Stat. 392","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9081cb60-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4851/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on reallocations of authorizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2696/d"},"text":"Section 2696(d) of this title","children":[],"tail":" shall not apply with respect to any amounts authorized to be appropriated under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9081cb61-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4851/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security requirements of other foreign affairs agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Based solely on security requirements and within the total amount of funds available for security, the Secretary of State shall ensure that an equitable level of funding is provided for the security requirements of other foreign affairs agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9081cb62-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4851/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insufficiency of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the event that sufficient funds are not available in any fiscal year for all of the diplomatic security construction, acquisition, and operations pursuant to the Department of State’s Supplemental Diplomatic Security Program, as justified to the Congress for such fiscal year, the Secretary of State shall report to the Congress the effect that the insufficiency of funds will have with respect to the Department of State and each of the other foreign affairs agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9081cb63-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4851/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of funds for certain security programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amount of funds authorized to be appropriated by subsection (a)(1)(A), $34,537,000 shall be available to the Secretary of State only for the protection of classified office equipment, the expansion of information systems security, and the hiring of American systems managers and operators for computers at high threat locations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9081cb64-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4851/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Furniture, furnishings, and equipment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9081cb65-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4851/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of existing furniture, furnishings, and equipment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If physically possible, facilities constructed or acquired pursuant to subsection (a) shall be furnished and equipped with the furniture, furnishings, and equipment that were being used in the facilities being replaced, rather than with newly acquired furniture, furnishings, and equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9081cb66-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4851/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9081cb67-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4851/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s122/b"},"text":"Pub. L. 103–236, title I, § 122(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/392"},"text":"108 Stat. 392","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9081cb68-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/399/tIV/s401"},"text":"Pub. L. 99–399, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/862"},"text":"100 Stat. 862","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/204/tI/s101/c"},"text":"Pub. L. 100–204, title I, § 101(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1336"},"text":"101 Stat. 1336","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI"},"text":"Pub. L. 103–236, title I","children":[],"tail":", §§ 101(c), 122(b), "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/388"},"text":"108 Stat. 388","children":[],"tail":", 392.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9081cb69-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9081cb6a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9081cb6b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The amendment made by paragraph (2), referred to in subsec. (a)(4), is the amendment made by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/399/s401/a/2"},"text":"section 401(a)(2) of Pub. L. 99–399","children":[],"tail":" to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2349aa–4"},"text":"section 2349aa–4 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"H.R. 4151 of the 99th Congress (the Omnibus Diplomatic Security and Antiterrorism Act of 1986), referred to in subsec. (a)(4), as enacted into law, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/399"},"text":"Pub. L. 99–399","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/853"},"text":"100 Stat. 853","children":[],"tail":". The Joint Explanatory Statement of the Committee of Conference to accompany H.R. 4151 is set forth in H. Rept. No. 99–783, 99th Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id9081cb6c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/399/s401"},"text":"section 401 of Pub. L. 99–399","children":[],"tail":". Subsecs. (a)(2) and (h)(2) of "},{"tag":"ref","attrib":{"href":"/us/pl/99/399/s401"},"text":"section 401 of Pub. L. 99–399","children":[],"tail":" amended sections 2349aa–4 and 300, respectively, of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9081cb6d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/s101/c"},"text":"Pub. L. 103–236, § 101(c)","children":[],"tail":", struck out heading and text of par. (3). Text read as follows: “There is authorized to be appropriated for the Department of State for ‘Acquisition and Maintenance of Buildings Abroad’ for each of the fiscal years 1988 through 1990, $417,962,000 to carry out diplomatic security construction, acquisition, and operations pursuant to the Department of State’s Supplemental Diplomatic Security Program. Authorizations of appropriations under this paragraph shall remain available until the appropriations are made.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/s122/b"},"text":"Pub. L. 103–236, § 122(b)","children":[],"tail":", struck out heading and text of subsec. (c). Text read as follows: “Amounts made available for capital projects pursuant to subsection (a) of this section shall be treated as a reprogramming of funds under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2706"},"text":"section 2706 of this title","children":[],"tail":" and shall not be available for obligation or expenditure except in compliance with the procedures applicable to such reprogramming.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/s122/b"},"text":"Pub. L. 103–236, § 122(b)","children":[],"tail":", struck out heading and text of par. (3). Text read as follows: “Amounts made available for furniture, furnishings, and equipment pursuant to subsection (a) of this section shall be treated as a reprogramming of funds under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2706"},"text":"section 2706 of this title","children":[],"tail":" and shall not be available for obligation or expenditure except in compliance with the procedures applicable to such reprogramming.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/204"},"text":"Pub. L. 100–204","children":[],"tail":" inserted sentence at end providing that authorizations of appropriations under this paragraph remain available until appropriations are made."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9081cb6e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9081cb6f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s101/c"},"text":"Pub. L. 103–236, title I, § 101(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/388"},"text":"108 Stat. 388","children":[],"tail":", provided that the amendment made by that section is effective "},{"tag":"date","attrib":{"date":"1995-10-01"},"text":"Oct. 1, 1995","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9081cb70-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Embassy Security Requests and Deficiencies","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dE/tLII/s5209"},"text":"Pub. L. 117–81, div. E, title LII, § 5209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2357"},"text":"135 Stat. 2357","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/81/dE/tLII/s5209"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Secretary of State shall provide to the appropriate congressional committees, the Committee on Armed Services of the House of Representatives, and the Committee on Armed Services of the Senate upon request information on physical security deficiencies at United States diplomatic posts, including relating to the following:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Requests made over the previous year by United States diplomatic posts for security upgrades.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Significant security deficiencies at United States diplomatic posts that are not operating out of a new embassy compound or new consulate compound.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definition of “appropriate congressional committees” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s5209"},"text":"section 5209 of Pub. L. 117–81","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s5002"},"text":"section 5002 of Pub. L. 117–81","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s263c"},"text":"section 263c of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id90843b71-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction Security Certification","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/204/tI/s160"},"text":"Pub. L. 100–204, title I, § 160","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1356"},"text":"101 Stat. 1356","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/101/246/tI/s135"},"text":"Pub. L. 101–246, title I, § 135","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-02-16"},"text":"Feb. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/33"},"text":"104 Stat. 33","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/246/tI/s135"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before undertaking any new construction or major renovation project in any foreign facility intended for the storage of classified materials or the conduct of classified activities, or approving occupancy of a similar facility for which construction or major renovation began before the effective date of this section [","children":[{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":"], the Secretary of State, after consultation with the Director of Central Intelligence, shall certify to the Committee on Foreign Affairs of the House of Representatives and the Committee on Foreign Relations of the Senate that—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate and adequate steps have been taken to ensure the security of the construction project (including an evaluation of how all security-related factors with respect to such project are being addressed);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the facility resulting from such project incorporates—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adequate measures for protecting classified information and national security-related activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adequate protection for the personnel working in the diplomatic facility; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan has been put into place for the continued evaluation and maintenance of adequate security at such facility, which plan shall specify the physical security methods and technical countermeasures necessary to ensure secure operations, including any personnel requirements for such purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Documentation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All documentation with respect to a certification referred to in subsection (a) and any dissenting views thereto shall be available, in an appropriately classified form, to the Chairman of the Committee on Foreign Affairs of the House of Representatives and the Chairman of the Committee on Foreign Relations of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Director of Central Intelligence","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of Central Intelligence shall provide to the Secretary of State such assistance with respect to the implementation of this section as the Secretary of State may request.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Dissenting Views","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Director of Central Intelligence disagrees with the Secretary of State with respect to any project certification made pursuant to subsection (a), the Director shall submit in writing disagreeing views to the Secretary of State.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[Reference to the Director of Central Intelligence or the Director of the Central Intelligence Agency in the Director’s capacity as the head of the intelligence community deemed to be a reference to the Director of National Intelligence. Reference to the Director of Central Intelligence or the Director of the Central Intelligence Agency in the Director’s capacity as the head of the Central Intelligence Agency deemed to be a reference to the Director of the Central Intelligence Agency. See section 1081(a), (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of Title 50","children":[],"tail":", War and National Defense.]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id90843b72-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report to Congress on Obligation of Funds","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/459/tIII/s302"},"text":"Pub. L. 100–459, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-01"},"text":"Oct. 1, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2207"},"text":"102 Stat. 2207","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/459/tIII/s302"},"text":"“The Secretary of State shall report to the appropriate committees of the Congress on the obligation of funds provided for diplomatic security and related expenses every month.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/a/tIII/s302"},"text":"Pub. L. 100–202, § 101(a) [title III, § 302]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329"},"text":"101 Stat. 1329","children":[],"tail":", 1329–23."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500/s101/b/tIII/s302"},"text":"Pub. L. 99–500, § 101(b) [title III, § 302]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1783-39"},"text":"100 Stat. 1783–39","children":[],"tail":", 1783–60, and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/s101/b/tIII/s302"},"text":"Pub. L. 99–591, § 101(b) [title III, § 302]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-30"},"text":"Oct. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3341-39"},"text":"100 Stat. 3341–39","children":[],"tail":", 3341–60."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
