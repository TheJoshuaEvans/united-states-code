{"tag":"section","attrib":{"id":"id914a23ac-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9711"},"text":null,"children":[{"tag":"num","attrib":{"value":"9711"},"text":"§ 9711.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Humanitarian relief for the Venezuelan people","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id914a23ad-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9711/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id914a23ae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9711/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Government should expand efforts to peacefully address Venezuela’s humanitarian crisis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914a23af-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9711/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" humanitarian assistance—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id914a23b0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9711/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" should be targeted toward those most in need and delivered through partners that uphold internationally recognized humanitarian principles; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914a23b1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9711/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" should not be passed through the control or distribution mechanisms of the Maduro regime.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id914a23b2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9711/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Humanitarian relief","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id914a23b3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9711/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State, in coordination with the Administrator of the United States Agency for International Development, shall provide—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id914a23b4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9711/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" humanitarian assistance to individuals and communities in Venezuela, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id914a23b5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9711/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public health commodities and services, including medicines and basic medical supplies and equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id914a23b6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9711/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" basic food commodities and nutritional supplements needed to address growing malnutrition and improve food security for the people of Venezuela, with a specific emphasis on the most vulnerable populations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id914a23b7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9711/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical assistance to ensure that health and food commodities are appropriately selected, procured, targeted, and distributed; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914a23b8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9711/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Venezuelans and hosting communities, as appropriate, in neighboring countries with humanitarian aid, such as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id914a23b9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9711/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" urgently needed health and nutritional assistance, including logistical and technical assistance to hospitals and health centers in affected communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id914a23ba-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9711/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" food assistance for vulnerable individuals, including assistance to improve food security for affected communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id914a23bb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9711/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hygiene supplies and sanitation services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914a23bc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9711/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aid to Venezuelans in neighboring countries","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The aid described in paragraph (1)(B)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id914a23bd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9711/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may be provided—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id914a23be-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9711/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directly to Venezuelans in neighboring countries, including countries of the Caribbean; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id914a23bf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9711/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indirectly through the communities in which the Venezuelans reside; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914a23c0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9711/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" should focus on the most vulnerable Venezuelans in neighboring countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id914a23c1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9711/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Humanitarian assistance strategy update","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"December 20, 2019","children":[],"tail":", the Secretary of State, in coordination with the Administrator of the United States Agency for International Development, shall submit, to the appropriate congressional committees, an update to the Venezuela humanitarian assistance strategy described in the conference report accompanying the Consolidated Appropriations Act ("},{"tag":"ref","attrib":{"href":"/us/pl/116/6"},"text":"Public Law 116–6","children":[],"tail":"), to cover a 2-year period and include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id914a23c2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9711/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the United States humanitarian assistance provided under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914a23c3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9711/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of United States diplomatic efforts to ensure support from international donors, including regional partners in Latin America and the Caribbean, for the provision of humanitarian assistance to the people of Venezuela;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914a23c4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9711/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification of governments that are willing to provide financial and technical assistance for the provision of such humanitarian assistance to the people of Venezuela and a description of such assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914a23c5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9711/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification of the financial and technical assistance to be provided by multilateral institutions, including the United Nations humanitarian agencies, the Pan American Health Organization, the Inter-American Development Bank, and the World Bank, and a description of such assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id914a23c6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9711/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Diplomatic engagement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State, in consultation with the Administrator of the United States Agency for International Development, shall work with relevant foreign governments and multilateral organizations to coordinate a donors summit and carry out diplomatic engagement to advance the strategy required under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id914a23c7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9711/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated $400,000,000 for fiscal year 2020 to carry out the activities set forth in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id914a23c8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9711/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Defined term","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id914a23c9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9711/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914a23ca-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9711/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914a23cb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9711/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914a23cc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9711/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id914a23cd-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dJ/tI/s121"},"text":"Pub. L. 116–94, div. J, title I, § 121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3032"},"text":"133 Stat. 3032","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id914a23ce-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id914a23cf-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id914a23d0-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Consolidated Appropriations Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/6"},"text":"Public Law 116–6","children":[],"tail":"), referred to in subsec. (c), is "},{"tag":"ref","attrib":{"href":"/us/pl/116/6"},"text":"Pub. L. 116–6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-02-15"},"text":"Feb. 15, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/13"},"text":"133 Stat. 13","children":[],"tail":", known as the Consolidated Appropriations Act, 2019. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
