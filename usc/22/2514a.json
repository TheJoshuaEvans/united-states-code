{"tag":"section","attrib":{"id":"id8fd16662-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2514a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2514a"},"text":"§ 2514a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization for Peace Corps to provide separation pay for host country resident personal services contractors of the Peace Corps","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fd16663-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2514a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury of the United States a fund for the Peace Corps to provide separation pay for host country resident personal services contractors of the Peace Corps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fd16664-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2514a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Peace Corps may deposit in the fund established under subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fd16665-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2514a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts previously obligated and not canceled to provide the separation pay described in such subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fd16666-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2514a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts obligated for fiscal years after fiscal year 2006 for current and future costs of providing such separation pay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fd16667-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2514a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning in fiscal year 2007, amounts deposited in the fund established under subsection (a) shall be available without fiscal year limitation for severance, retirement, or other separation payments to host country resident personal services contractors of the Peace Corps in countries where such payments are legally authorized.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fd16668-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/86/s1"},"text":"Pub. L. 110–86, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-27"},"text":"Sept. 27, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/979"},"text":"121 Stat. 979","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fd16669-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8fd1666a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8fd1666b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Peace Corps Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
