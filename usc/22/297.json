{"tag":"section","attrib":{"id":"id8eea1408-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s297"},"text":null,"children":[{"tag":"num","attrib":{"value":"297"},"text":"§ 297.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of property by lease","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The authority granted to acquire sites and buildings by purchase or otherwise shall include authority to acquire leaseholds.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8eea1409-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1926-05-07/ch250/s6"},"text":"May 7, 1926, ch. 250, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/405"},"text":"44 Stat. 405","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1952-06-19/ch446/s4"},"text":"June 19, 1952, ch. 446, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/140"},"text":"66 Stat. 140","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/105/tI/s106/b"},"text":"Pub. L. 95–105, title I, § 106(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-17"},"text":"Aug. 17, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/845"},"text":"91 Stat. 845","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8eea140a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8eea140b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8eea140c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"te