{"tag":"section","attrib":{"id":"id90dc6d9c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7205"},"text":null,"children":[{"tag":"num","attrib":{"value":"7205"},"text":"§ 7205.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State sponsors of international terrorism","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90dc6d9d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7205/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90dc6d9e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7205/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this chapter (other than ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7203"},"text":"section 7203 of this title","children":[],"tail":"), the export of agricultural commodities, medicine, or medical devices to Cuba, the Taliban or the territory of Afghanistan controlled by the Taliban, or to the government of a country that has been determined by the Secretary of State to have repeatedly provided support for acts of international terrorism under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2371"},"text":"section 2371 of this title","children":[],"tail":", section 4605(j)(1) "},{"tag":"ref","attrib":{"idref":"fn002380"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002380"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 50, or "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2780/d"},"text":"section 2780(d) of this title","children":[],"tail":", or to any other entity in such a country, shall only be made pursuant to 1-year licenses issued by the United States Government for contracts entered into during the 1-year period of the license and shipped within the 12-month period beginning on the date of the signing of the contract, except that the requirements of such 1-year licenses shall be no more restrictive than license exceptions administered by the Department of Commerce or general licenses administered by the Department of the Treasury, except that procedures shall be in place to deny licenses for exports to any entity within such country, or in the territory of Afghanistan controlled by the Taliban, promoting international terrorism."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90dc6d9f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7205/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply with respect to the export of agricultural commodities, medicine, or medical devices to the Government of Syria or to the Government of North Korea, or to any other entity in Syria or North Korea.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90dc6da0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7205/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quarterly reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The applicable department or agency of the Federal Government shall submit to the appropriate congressional committees on a quarterly basis a report on any activities undertaken under subsection (a)(1) during the preceding calendar quarter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90dc6da1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7205/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biennial reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2000-10-28"},"text":"October 28, 2000","children":[],"tail":", and every 2 years thereafter, the applicable department or agency of the Federal Government shall submit a report to the appropriate congressional committees on the operation of the licensing system under this section for the preceding 2-year period, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90dc6da2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7205/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and types of licenses applied for;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90dc6da3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7205/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and types of licenses approved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90dc6da4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7205/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average amount of time elapsed from the date of filing of a license application until the date of its approval;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90dc6da5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7205/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the licensing procedures were effectively implemented; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90dc6da6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7205/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of comments received from interested parties about the extent to which the licensing procedures were effective, after the applicable department or agency holds a public 30-day comment period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90dc6da7-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/387/s1/a/tIX/s906"},"text":"Pub. L. 106–387, § 1(a) [title IX, § 906]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1549"},"text":"114 Stat. 1549","children":[],"tail":", 1549A–69; "},{"tag":"ref","attrib":{"href":"/us/pl/107/56/tII/s221/a/2"},"text":"Pub. L. 107–56, title II, § 221(a)(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/292"},"text":"115 Stat. 292","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90dc6da8-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90dc6da9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90dc6daa-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4605/j/1"},"text":"Section 4605(j)(1) of title 50","children":[],"tail":", referred to in subsec. (a)(1), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXVII/s1766/a"},"text":"Pub. L. 115–232, div. A, title XVII, § 1766(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2232"},"text":"132 Stat. 2232","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90dc6dab-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56/s221/a/2"},"text":"Pub. L. 107–56, § 221(a)(2)","children":[],"tail":", inserted “, the Taliban or the territory of Afghanistan controlled by the Taliban,” after “Cuba” and “, or in the territory of Afghanistan controlled by the Taliban,” after “entity within such country”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56/s221/a/3"},"text":"Pub. L. 107–56, § 221(a)(3)","children":[],"tail":", inserted “, or to any other entity in Syria or North Korea” before period at end."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
