{"tag":"section","attrib":{"id":"id8fe6c2c1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2655c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2655c"},"text":"§ 2655c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bureau of Educational and Cultural Affairs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fe6c2c2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2655c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be in the Department a Bureau of Educational and Cultural Affairs described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2460"},"text":"section 2460 of title 22","children":[],"tail":", which shall be responsible for the functions described in such section and such other relevant functions related to academic, cultural, and professional exchanges as the Under Secretary for Public Diplomacy may prescribe."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fe6c2c3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2655c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Head of Bureau","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary for Educational and Cultural Affairs shall be the head of the Bureau of Educational and Cultural Affairs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fe6c2c4-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dE/tIV/s5403"},"text":"Pub. L. 119–60, div. E, title IV, § 5403","children":[],"tail":", "},{"tag":"date",