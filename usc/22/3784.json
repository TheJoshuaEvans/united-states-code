{"tag":"section","attrib":{"id":"id90489212-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3784"},"text":null,"children":[{"tag":"num","attrib":{"value":"3784"},"text":"§ 3784.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of property to Republic of Panama","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90489213-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3784/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conveyance of Panama Railroad","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90489214-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3784/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On ","children":[{"tag":"date","attrib":{"date":"1979-10-01"},"text":"October 1, 1979","children":[],"tail":", the Secretary of State may convey to the Republic of Panama the Panama Railroad and such property located in the area which, immediately before such date, comprised the Canal Zone and which is not within the land and water areas the use of which is made available to the United States pursuant to the Panama Canal Treaty of 1977 and related agreements."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90489215-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3784/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Property transferred pursuant to paragraph (1) of this subsection may not include buildings and other facilities, except housing, located outside such areas, the use of which is retained by the United States pursuant to the Panama Canal Treaty of 1977 and related agreements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90489216-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3784/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of certain property pursuant to Panama Canal Treaty of 1977; report to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to the transfer of all other property (not described in subsection (a)(1) of this section) to be transferred in accordance with the terms of the Panama Canal Treaty of 1977 and related agreements, the Secretary of State may convey such property from time to time in accordance with the terms of such Treaty and related agreements. Before the transfer of any such property, the President must submit a written report to the Congress—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90489217-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3784/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" precisely identifying and describing the particular property to be transferred;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90489218-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3784/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certifying the state of compliance by the Republic of Panama with such Treaty and related agreements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90489219-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3784/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" setting forth the reasons for the conveyance being made at the particular time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9048921a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3784/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction on transfer of Panama Canal and certain other property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Panama Canal, and such other property referred to in paragraph 2(d) of Article XIII of the Panama Canal Treaty of 1977 that has not been previously transferred in accordance with paragraphs 2(a), 2(b), and 2(c) of such Article, shall not be transferred to the Republic of Panama prior to ","children":[{"tag":"date","attrib":{"date":"1999-12-31"},"text":"December 31, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9048921b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70/tI/s1504"},"text":"Pub. L. 96–70, title I, § 1504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-27"},"text":"Sept. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/488"},"text":"93 Stat. 488","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/223/s7"},"text":"Pub. L. 99–223, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-28"},"text":"Dec. 28, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1740"},"text":"99 Stat. 1740","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9048921c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9048921d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9048921e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1985—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/223"},"text":"Pub. L. 99–223","children":[],"tail":" substituted “Before” for “At least 180 days before”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id9048921f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id90489220-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions vested in President by subsec. (b) delegated to Secretary of State, see section 1–402 of Ex. Ord. No. 12215, ","children":[{"tag":"date","attrib":{"date":"1980-05-27"},"text":"May 27, 1980","children":[],"tail":", 45 F.R. 36044, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3601"},"text":"section 3601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
