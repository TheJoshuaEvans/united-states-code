{"tag":"section","attrib":{"id":"id908b67e5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401"},"text":null,"children":[{"tag":"num","attrib":{"value":"5401"},"text":"§ 5401.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support for East European Democracy (SEED) Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id908b67e6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SEED Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States shall implement, beginning in fiscal year 1990, a concerted Program of Support for East European Democracy (which may also be referred to as the “SEED Program”). The SEED Program shall be comprised of diverse undertakings designed to provide cost-effective assistance to those countries of Eastern Europe that have taken substantive steps toward institutionalizing political democracy and economic pluralism.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id908b67e7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Objectives of SEED assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President should ensure that the assistance provided to East European countries pursuant to this chapter is designed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id908b67e8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to contribute to the development of democratic institutions and political pluralism characterized by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id908b67e9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of fully democratic and representative political systems based on free and fair elections,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id908b67ea-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effective recognition of fundamental liberties and individual freedoms, including freedom of speech, religion, and association,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id908b67eb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" termination of all laws and regulations which impede the operation of a free press and the formation of political parties,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id908b67ec-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creation of an independent judiciary, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id908b67ed-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishment of non-partisan military, security, and police forces;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908b67ee-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to promote the development of a free market economic system characterized by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id908b67ef-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" privatization of economic entities,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id908b67f0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishment of full rights to acquire and hold private property, including land and the benefits of contractual relations,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id908b67f1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" simplification of regulatory controls regarding the establishment and operation of businesses,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id908b67f2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dismantlement of all wage and price controls,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id908b67f3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" removal of trade restrictions, including on both imports and exports,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id908b67f4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" liberalization of investment and capital, including the repatriation of profits by foreign investors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id908b67f5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tax policies which provide incentives for economic activity and investment,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id908b67f6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishment of rights to own and operate private banks and other financial service firms, as well as unrestricted access to private sources of credit, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id908b67f7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" access to a market for stocks, bonds, and other instruments through which individuals may invest in the private sector; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908b67f8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not to contribute any substantial benefit—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id908b67f9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to Communist or other political parties or organizations which are not committed to respect for the democratic process, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id908b67fa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the defense or security forces of any member country of the Warsaw Pact.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id908b67fb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SEED Actions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Assistance and other activities under the SEED Program (which may be referred to as “SEED Actions”) shall include activities such as the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id908b67fc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leadership in the World Bank and International Monetary Fund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"United States leadership in supporting—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id908b67fd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" loans by the International Bank for Reconstruction and Development and its affiliated institutions in the World Bank group that are designed to modernize industry, agriculture, and infrastructure, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id908b67fe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" International Monetary Fund programs designed to stimulate sound economic growth.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908b67ff-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Currency stabilization loans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"United States leadership in supporting multilateral agreement to provide government-to-government loans for currency stabilization where such loans can reduce inflation and thereby foster conditions necessary for the effective implementation of economic reforms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908b6800-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Debt reduction and rescheduling","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Participation in multilateral activities aimed at reducing and rescheduling a country’s international debt, when reduction and deferral of debt payments can assist the process of political and economic transition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908b6801-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Assistance through the grant and concessional sale of food and other agricultural commodities and products when such assistance can ease critical shortages but not inhibit agricultural production and marketing in the recipient country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908b6802-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enterprise Funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants to support private, nonprofit “Enterprise Funds”, designated by the President pursuant to law and governed by a Board of Directors, which undertake loans, grants, equity investments, feasibility studies, technical assistance, training, and other forms of assistance to private enterprise activities in the Eastern European country for which the Enterprise Fund so is designated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908b6803-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Labor market-oriented technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Technical assistance programs directed at promoting labor market reforms and facilitating economic adjustment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908b6804-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical training","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Programs to provide technical skills to assist in the development of a market economy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908b6805-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peace Corps","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Establishment of Peace Corps programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908b6806-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support for indigenous credit unions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Support for the establishment of indigenous credit unions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908b6807-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Generalized System of Preferences","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Eligibility for trade benefits under the Generalized System of Preferences.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908b6808-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/c/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Normal trade relations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The granting of temporary or permanent nondiscriminatory treatment to the products of an East European country through the application of the criteria and procedures established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2432"},"text":"section 2432 of title 19","children":[],"tail":" (commonly referred to as the “Jackson-Vanik amendment”)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908b6809-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/c/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States International Development Finance Corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Programs of the United States International Development Finance Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908b680a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/c/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Export-Import Bank programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Programs of the Export-Import Bank of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908b680b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/c/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trade and Development Program activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Trade and Development Agency activities under the Foreign Assistance Act of 1961 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"22 U.S.C. 2151","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908b680c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/c/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment treaties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Negotiation of bilateral investment treaties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908b680d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/c/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special tax treatment of below-market loans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Exempting bonds from Internal Revenue Code [title 26] rules relating to below-market loans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908b680e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/c/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exchange activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Expanded exchange activities under the Fulbright, International Visitors, and other programs conducted by the United States Information Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908b680f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/c/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cultural centers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Contributions toward the establishment of reciprocal cultural centers that can facilitate educational and cultural exchange and expanded understanding of Western social democracy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908b6810-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/c/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sister institutions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Establishment of sister institution programs between American and East European schools and universities, towns and cities, and other organizations in such fields as medicine and health care, business management, environmental protection, and agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908b6811-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/c/20"},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"(20)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scholarships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Scholarships to enable students to study in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908b6812-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/c/21"},"text":null,"children":[{"tag":"num","attrib":{"value":"21"},"text":"(21)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Science and technology exchanges","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants for the implementation of bilateral agreements providing for cooperation in science and technology exchange.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908b6813-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/c/22"},"text":null,"children":[{"tag":"num","attrib":{"value":"22"},"text":"(22)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance for democratic institutions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Assistance designed to support the development of legal, legislative, electoral, journalistic, and other institutions of free, pluralist societies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908b6814-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/c/23"},"text":null,"children":[{"tag":"num","attrib":{"value":"23"},"text":"(23)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Environmental assistance directed at overcoming crucial deficiencies in air and water quality and other determinants of a healthful society.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908b6815-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/c/24"},"text":null,"children":[{"tag":"num","attrib":{"value":"24"},"text":"(24)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Medical assistance specifically targeted to overcome severe deficiencies in pharmaceuticals and other basic health supplies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908b6816-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5401/c/25"},"text":null,"children":[{"tag":"num","attrib":{"value":"25"},"text":"(25)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Encouragement for private investment and voluntary assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Encouraging private investment and voluntary private assistance, using a variety of means including a SEED Information Center System and the provision by the Department of Defense of transportation for private nonfinancial contributions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id908b6817-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/179/s2"},"text":"Pub. L. 101–179, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-28"},"text":"Nov. 28, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1299"},"text":"103 Stat. 1299","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/549/tII/s202/e"},"text":"Pub. L. 102–549, title II, § 202(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3658"},"text":"106 Stat. 3658","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tV/s5003/b/6"},"text":"Pub. L. 105–206, title V, § 5003(b)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/790"},"text":"112 Stat. 790","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dF/tVI/s1470/m/1"},"text":"Pub. L. 115–254, div. F, title VI, § 1470(m)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3518"},"text":"132 Stat. 3518","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id908b6818-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id908b6819-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id908b681a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/179"},"text":"Pub. L. 101–179","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-28"},"text":"Nov. 28, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1298"},"text":"103 Stat. 1298","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out below and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Foreign Assistance Act of 1961, referred to in subsec. (c)(14), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/424"},"text":"75 Stat. 424","children":[],"tail":", which is classified principally to chapter 32 (§ 2151 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id908b681b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" added par. (12) and struck out former par. (12). Prior to amendment, text read as follows: “Programs of the Overseas Private Investment Corporation.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (c)(11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206"},"text":"Pub. L. 105–206","children":[],"tail":" in heading substituted “Normal trade relations” for “Most favored nation trade status” and in text struck out “(commonly referred to as ‘most favored nation status’)” after “nondiscriminatory treatment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (c)(14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/549"},"text":"Pub. L. 102–549","children":[],"tail":" substituted “Agency” for “Program”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id908b681c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id908b681d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" effective at the end of the transition period, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s9681"},"text":"section 9681 of this title","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1470/w"},"text":"section 1470(w) of Pub. L. 115–254","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s905"},"text":"section 905 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id908b681e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/179/s1/a"},"text":"Pub. L. 101–179, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-28"},"text":"Nov. 28, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1298"},"text":"103 Stat. 1298","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/179/s1/a"},"text":"“This Act [enacting this chapter and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2185"},"text":"section 2185 of this title","children":[],"tail":", amending sections 2184 and 2199 of this title, "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1757"},"text":"section 1757 of Title 12","children":[],"tail":", Banks and Banking, and "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2462"},"text":"section 2462 of Title 19","children":[],"tail":", Customs Duties, enacting provisions set out as notes under sections 2185, 2199, and 2421 of this title, "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s635"},"text":"section 635 of Title 12","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s7872"},"text":"section 7872 of Title 26","children":[],"tail":", Internal Revenue Code, and amending provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s7872"},"text":"section 7872 of Title 26","children":[],"tail":"] may be cited as the ‘Support for East European Democracy (SEED) Act of 1989’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id908b681f-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"United States Information Agency (other than Broadcasting Board of Governors and International Broadcasting Bureau) abolished and functions transferred to Secretary of State, see sections 6531 and 6532 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id908b6820-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"executiveOrder","id":"id908b6821-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Ex. Ord. No. 12703. Support for East European Democracy (SEED) Program","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 12703, ","children":[{"tag":"date","attrib":{"date":"1990-02-20"},"text":"Feb. 20, 1990","children":[],"tail":", 55 F.R. 6351, as amended by Ex. Ord. No. 13118, § 10(2), "},{"tag":"date","attrib":{"date":"1999-03-31"},"text":"Mar. 31, 1999","children":[],"tail":", 64 F.R. 16598, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"By the authority vested in me as President by the Constitution and laws of the United States of America, including the Support for East European Democracy (SEED) Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/179"},"text":"P.L. 101–179","children":[],"tail":", hereinafter referred to as the “Act”) ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s5401"},"text":"22 U.S.C. 5401","children":[],"tail":" et seq.] and "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of Title 3","children":[],"tail":" of the United States Code, it is hereby ordered as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Section","children":[],"tail":" 1. "},{"tag":"i","attrib":{},"text":"SEED Program Coordinator","children":[],"tail":". The functions conferred by Title VII of the Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s5471"},"text":"22 U.S.C. 5471","children":[],"tail":" et seq.] relating to reports to the Congress are hereby delegated to the Coordinator of the SEED Program. The Coordinator is authorized to assign responsibility for particular aspects of the reports to appropriate agencies."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Sec. 2. ","children":[{"tag":"i","attrib":{},"text":"Department of State","children":[],"tail":". The functions conferred upon the President by section 201 of the Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s5421"},"text":"22 U.S.C. 5421","children":[],"tail":"] relating to Enterprise Funds for Poland and Hungary are hereby delegated to the Secretary of State."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 3. "},{"tag":"i","attrib":{},"text":"Department of Commerce","children":[],"tail":". The functions conferred upon the President by section 602 of the Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s5462"},"text":"22 U.S.C. 5462","children":[],"tail":"] regarding the establishment of a SEED Information Center System in cooperation with the Governments of Poland and Hungary are hereby delegated to the Secretary of Commerce. This authority is to be exercised in consultation with the SEED Program Coordinator and in consultation with other agencies as appropriate."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 4. "},{"tag":"i","attrib":{},"text":"Department of the Treasury","children":[],"tail":". The functions conferred upon the President by section 104 of the Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s5414"},"text":"22 U.S.C. 5414","children":[],"tail":"] regarding debt reduction of certain East European countries are hereby delegated to the Secretary of the Treasury. The Secretary shall consult, as appropriate, with other relevant agencies in exercising the functions herein delegated."}],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"George Bush.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
