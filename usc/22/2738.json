{"tag":"section","attrib":{"id":"id9005e3d4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2738"},"text":null,"children":[{"tag":"num","attrib":{"value":"2738"},"text":"§ 2738.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mid-Career Mentoring Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9005e3d5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2738/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in collaboration with the Director of the Foreign Service Institute, is authorized to establish a Mid-Career Mentoring Program (referred to in this section as the “Program”) to assist in the retention of, and to decrease mid-career attrition of, employees, including those who have demonstrated potential for advancement and may be at risk of leaving the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9005e3d6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2738/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9005e3d7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2738/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nominations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The head of each bureau shall semiannually nominate participants for the Program from a pool of applicants in the positions described in paragraph (2)(B), including from posts both domestically and abroad.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9005e3d8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2738/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of slate of nominees to Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Foreign Service Institute, in consultation with the Director General of the Foreign Service, shall semiannually—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9005e3d9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2738/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vet the nominees most recently nominated pursuant to paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9005e3da-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2738/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit to the Secretary a slate of applicants to participate in the Program, who shall consist of at least—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9005e3db-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2738/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10 Foreign Service Officers and specialists classified at the FS-03 or FS-04 level of the Foreign Service Salary Schedule;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9005e3dc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2738/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10 Civil Service employees classified at GS–12 or GS–13 of the General Schedule; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9005e3dd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2738/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 5 Foreign Service Officers from the United States Agency for International Development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9005e3de-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2738/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final selection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall select the applicants who will be invited to participate in the Program from the slate received pursuant to paragraph (2)(B) and extend such an invitation to each selected applicant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9005e3df-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2738/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Merit principles","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3905"},"text":"Section 3905 of this title","children":[],"tail":" shall apply to nominations, submissions to the Secretary, and selections for the Program under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9005e3e0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2738/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program sessions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9005e3e1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2738/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Frequency; duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All of the participants who accept invitations extended pursuant to subsection (b)(3) shall meet 3 to 4 times per year for training sessions with high-level leaders of the Department and USAID, including private group meetings with the Secretary and the Administrator of the United States Agency for International Development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9005e3e2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2738/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Themes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each session referred to in paragraph (1) shall focus on specific themes developed jointly by the Foreign Service Institute and the Executive Secretariat focused on substantive policy issues and leadership practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9005e3e3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2738/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mentoring program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and the Administrator each is authorized to establish a mentoring and coaching program that pairs a senior leader of the Department or USAID with each of the program participants who complete the Program during the 1-year period immediately following their participation in the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9005e3e4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2738/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than one year after ","children":[{"tag":"date","attrib":{"date":"2023-12-22"},"text":"December 22, 2023","children":[],"tail":", and annually thereafter for three years, the Secretary shall submit a report to the appropriate congressional committees that describes the activities of the Program during the most recent year and includes disaggregated demographic data on participants in the Program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9005e3e5-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dF/tLXII/s6205"},"text":"Pub. L. 118–31, div. F, title LXII, § 6205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/973"},"text":"137 Stat. 973","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9005e3e6-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9005e3e7-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9005e3e8-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The General Schedule, referred to in subsec. (b)(2)(B)(ii), is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9005e3e9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id9005e3ea-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “Secretary”, “Department”, and “appropriate congressional committees” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s6002"},"text":"section 6002 of Pub. L. 118–31","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
