{"tag":"section","attrib":{"id":"id9110eb9a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8793"},"text":null,"children":[{"tag":"num","attrib":{"value":"8793"},"text":"§ 8793.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of sanctions with respect to persons who engage in censorship or other forms of repression in Syria","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9110eb9b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8793/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall impose sanctions described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8791/c"},"text":"section 8791(c) of this title","children":[],"tail":" with respect to each person on the list required by subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9110eb9c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8793/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" List of persons who engage in censorship","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9110eb9d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8793/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2012-08-10"},"text":"August 10, 2012","children":[],"tail":", the President shall submit to the appropriate congressional committees a list of persons that the President determines have engaged in censorship, or activities relating to censorship, in a manner that prohibits, limits, or penalizes the legitimate exercise of freedom of expression by citizens of Syria."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9110eb9e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8793/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates of list","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall submit to the appropriate congressional committees an updated list under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9110eb9f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8793/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 300 days after ","children":[{"tag":"date","attrib":{"date":"2012-08-10"},"text":"August 10, 2012","children":[],"tail":", and every 180 days thereafter; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9110eba0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8793/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as new information becomes available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9110eba1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8793/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of report; public availability","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9110eba2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8793/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The list required by paragraph (1) shall be submitted in unclassified form but may contain a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9110eba3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8793/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The unclassified portion of the list required by paragraph (1) shall be made available to the public and posted on the websites of the Department of the Treasury and the Department of State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9110eba4-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/158/tVII/s704"},"text":"Pub. L. 112–158, title VII, § 704","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1268"},"text":"126 Stat. 1268","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9110eba5-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id9110eba6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8795"},"text":"section 8795 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
