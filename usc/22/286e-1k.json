{"tag":"section","attrib":{"id":"id8ec17d90-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286e–1k"},"text":null,"children":[{"tag":"num","attrib":{"value":"286e–1k"},"text":"§ 286e–1k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capital stock increase","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ec17d91-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286e–1k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increase authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The United States Governor of the Bank is authorized—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ec17d92-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286e–1k/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to vote for an increase of 620,000 shares in the authorized capital stock of the Bank; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ec17d93-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286e–1k/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to subscribe on behalf of the United States to 116,262 additional shares of the capital stock of the Bank, except that any subscription to such additional shares shall be effective only to such extent or in such amounts as are provided in advance in appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ec17d94-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286e–1k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to pay for the increase in the United States subscription to the Bank provided for in this section, there are authorized to be appropriated, without fiscal year limitation, $14,025,266,370, for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ec17d95-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-07-31/ch339/s53"},"text":"July 31, 1945, ch. 339, § 53","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/461/tV/s555"},"text":"Pub. L. 100–461, title V, § 555","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-01"},"text":"Oct. 1, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2268-36"},"text":"102 Stat. 2268–36","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ec17d96-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ec17d97-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8ec17d98-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 53 of act ","children":[{"tag":"date","attrib":{"date":"1945-07-31"},"text":"July 31, 1945","children":[],"tail":", is based on section 1 of H.R. 4645, One Hundredth Congress, as reported "},{"tag":"date","attrib":{"date":"1988-09-28"},"text":"Sept. 28, 1988","children":[],"tail":", and enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/100/461"},"text":"Pub. L. 100–461","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
