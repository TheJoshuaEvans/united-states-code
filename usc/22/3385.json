{"tag":"section","attrib":{"id":"id903a39fc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3385"},"text":null,"children":[{"tag":"num","attrib":{"value":"3385"},"text":"§ 3385.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports and audits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id903a39fd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3385/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the selection of the first class of fellows under this subchapter, and annually thereafter for 7 years, the Department of State shall offer to brief the appropriate committees of Congress regarding the following issues:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id903a39fe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3385/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of the performance of the implementing partner in fulfilling the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903a39ff-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3385/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The names and sponsoring agencies of the fellows selected by the implementing partner and the extent to which such fellows represent the diversity of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903a3a00-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3385/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The names of the parliamentary offices, ministries, other agencies of Taiwan, and nongovernmental institutions to which each fellow was assigned during the second year of the fellowship.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903a3a01-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3385/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any recommendations, as appropriate, to improve the implementation of the Taiwan Fellowship Program, including added flexibilities in the administration of the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903a3a02-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3385/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of the Taiwan Fellowship Program’s value upon the relationship between the United States and Taiwan or the United States and Asian countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id903a3a03-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3385/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual financial audit","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id903a3a04-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3385/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The financial records of any implementing partner shall be audited annually in accordance with generally accepted government auditing standards by independent certified public accountants or independent licensed public accountants who are certified or licensed by a regulatory authority of a State or another political subdivision of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903a3a05-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3385/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Location","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each audit under paragraph (1) shall be conducted at the place or places where the financial records of the implementing partner are normally kept.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903a3a06-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3385/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to documents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The implementing partner shall make available to the accountants conducting an audit under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id903a3a07-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3385/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all books, financial records, files, other papers, things, and property belonging to, or in use by, the implementing partner that are necessary to facilitate the audit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id903a3a08-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3385/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" full facilities for verifying transactions with the balances or securities held by depositories, fiscal agents, and custodians.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903a3a09-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3385/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id903a3a0a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3385/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 270 days after the end of each fiscal year, the implementing partner shall provide a report of the audit conducted for such fiscal year under paragraph (1) to the Department of State and the American Institute in Taiwan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id903a3a0b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3385/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each audit report shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id903a3a0c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3385/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth the scope of the audit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id903a3a0d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3385/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include such statements, along with the auditor’s opinion of those statements, as may be necessary to present fairly the implementing partner’s assets and liabilities, surplus or deficit, with reasonable detail;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id903a3a0e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3385/b/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a statement of the implementing partner’s income and expenses during the year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id903a3a0f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3385/b/4/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include a schedule of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id903a3a10-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3385/b/4/B/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all contracts and cooperative agreements requiring payments greater than $5,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id903a3a11-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3385/b/4/B/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any payments of compensation, salaries, or fees at a rate greater than $5,000 per year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id903a3a12-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3385/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Copies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each audit report shall be produced in sufficient copies for distribution to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id903a3a13-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLV/s5531"},"text":"Pub. L. 117–263, div. E, title LV, § 5531","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3329"},"text":"136 Stat. 3329","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
