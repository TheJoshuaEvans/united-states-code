{"tag":"section","attrib":{"id":"id904166f2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3662"},"text":null,"children":[{"tag":"num","attrib":{"value":"3662"},"text":"§ 3662.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeals to Board; procedures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id904166f3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3662/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons entitled to appeal; form; time","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An employee may appeal to the Panama Canal Board of Appeals from an adverse determination made by an agency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3660"},"text":"section 3660 of this title","children":[],"tail":". The appeal shall be made in writing within a reasonable time (as specified in regulations prescribed by, or under the authority of, the Commission) after the date of the transmittal by the agency to the employee of written notice of the adverse determination."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id904166f4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3662/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personal appearance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may authorize, in connection with an appeal pursuant to subsection (a) of this section, a personal appearance before the Board by the employee, or by a representative of the employee designated for that purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id904166f5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3662/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of evidence; decision","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After investigation and consideration of the evidence submitted, the Board shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id904166f6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3662/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare a written decision on the appeal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904166f7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3662/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transmit its decision to the agency concerned; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904166f8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3662/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transmit copies of the decision to the employee concerned or to the designated representative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id904166f9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3662/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finality of decision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The decision of the Board on any question or other matter relating to an appeal is final and conclusive. The agency concerned shall take action in accordance with the decision of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id904166fa-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70/tI/s1222"},"text":"Pub. L. 96–70, title I, § 1222","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-27"},"text":"Sept. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/467"},"text":"93 Stat. 467","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dC/tXXXV/s3548"},"text":"Pub. L. 105–85, div. C, title XXXV, § 3548","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2073"},"text":"111 Stat. 2073","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id904166fb-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id904166fc-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id904166fd-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" substituted “Commission” for “President”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
