{"tag":"section","attrib":{"id":"id90d541ff-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7105b"},"text":null,"children":[{"tag":"num","attrib":{"value":"7105b"},"text":"§ 7105b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improving domestic victim screening procedures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90d54200-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7105b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Victim screening tools","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2018-10-01"},"text":"October 1, 2018","children":[],"tail":", the Attorney General shall compile and disseminate, to all grantees who are awarded grants to provide victims’ services under subsection (b) or (f) of "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7105"},"text":"section 7105 of this title","children":[],"tail":", information about reliable and effective tools for the identification of victims of human trafficking."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90d54201-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7105b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of screening procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning not later than ","children":[{"tag":"date","attrib":{"date":"2018-10-01"},"text":"October 1, 2018","children":[],"tail":", the Attorney General, in consultation with the Secretary of Health and Human Services, shall identify recommended practices for the screening of human trafficking victims and shall encourage the use of such practices by grantees receiving a grant to provide victim services to youth under subsection (b) or (f) of "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7105"},"text":"section 7105 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90d54202-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/386/dA/s107B"},"text":"Pub. L. 106–386, div. A, § 107B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/393/tIII/s303/a"},"text":"Pub. L. 115–393, title III, § 303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5273"},"text":"132 Stat. 5273","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90d54203-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90d54204-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90d54205-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsection (f) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7105"},"text":"section 7105 of this title","children":[],"tail":", referred to in text, was in the original a reference to subsec. (f) of "},{"tag":"ref","attrib":{"href":"/us/pl/106/386/s107"},"text":"section 107 of Pub. L. 106–386","children":[],"tail":" and was translated as referring to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7105/f"},"text":"section 7105(f) of this title","children":[],"tail":", which relates to assistance for trafficking victims who are United States citizens and lawful permanent residents. Another subsec. (f) of "},{"tag":"ref","attrib":{"href":"/us/pl/106/386/s107"},"text":"section 107 of Pub. L. 106–386","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1255"},"text":"section 1255 of Title 8","children":[],"tail":", Aliens and Nationality."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
