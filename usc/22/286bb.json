{"tag":"section","attrib":{"id":"id8ec8a8af-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"286bb"},"text":"§ 286bb.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elimination of predatory agricultural export subsidies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall instruct the United States Executive Director of the Fund to propose and work for the adoption of a policy encouraging Fund members to eliminate all predatory agricultural export subsidies which might result in the reduction of other member countries’ exports.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ec8a8b0-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-07-31/ch339/s44"},"text":"July 31, 1945, ch. 339, § 44","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/181/tI"},"text":"Pub. L. 98–181, title I","children":[],"tail":" [title VIII, § 805], "},{"tag":"date","attrib":{"date":"1983-11-30"},"text":"Nov. 30, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1271"},"text":"97 Stat. 1271","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
