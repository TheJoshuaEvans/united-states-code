{"tag":"section","attrib":{"id":"id9134a034-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9601"},"text":null,"children":[{"tag":"num","attrib":{"value":"9601"},"text":"§ 9601.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9134a035-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9601/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advancing income country","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “advancing income country”, with respect to a fiscal year for the Corporation, means a country the gross national income per capita of which at the start of such fiscal year is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9134a036-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9601/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" greater than the World Bank threshold for initiating the International Bank for Reconstruction and Development graduation process; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9134a037-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9601/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is equal to or less than the per capita income threshold for classification as a high-income economy (as defined by the World Bank).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9134a038-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9601/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9134a039-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9601/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations and the Committee on Appropriations of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9134a03a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9601/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs and the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9134a03b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9601/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Country of concern","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “country of concern” means any of the following countries:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9134a03c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9601/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Bolivarian Republic of Venezuela.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9134a03d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9601/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Republic of Cuba.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9134a03e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9601/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Democratic People’s Republic of Korea.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9134a03f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9601/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Islamic Republic of Iran.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9134a040-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9601/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The People’s Republic of China.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9134a041-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9601/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Russian Federation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9134a042-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9601/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Republic of Belarus.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9134a043-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9601/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High-income country","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “high-income country”, with respect to a fiscal year for the Corporation, means a country with a high-income economy (as defined by the World Bank) at the start of such fiscal year but does not include any wealthy country except to the extent investments in such wealthy country are permitted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9612/f"},"text":"section 9612(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9134a044-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9601/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Less developed country","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “less developed country”, with respect to a fiscal year for the Corporation, means a country the gross national income per capita of which at the start of such fiscal year is equal to or less than the World Bank threshold for initiating the International Bank for Reconstruction Development graduation process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9134a045-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9601/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Predecessor authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “predecessor authority” means authorities repealed by subchapter VI of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9134a046-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9601/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying sovereign entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualifying sovereign entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9134a047-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9601/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any agency or instrumentality of a foreign state (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1603"},"text":"section 1603 of title 28","children":[],"tail":") that has a purpose that is similar to the purpose of the Corporation as described in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s9612/b"},"text":"section 9612(b) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9134a048-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9601/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any international financial institution (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s262r/c"},"text":"section 262r(c) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9134a049-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9601/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wealthy country","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “wealthy country”, with respect to a fiscal year for the Corporation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9134a04a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9601/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means a country that is among the top 20 countries with the highest gross domestic product per capita at purchasing power parity, as calculated by the World Bank; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9134a04b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9601/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include members of the ‘Five Eyes’ alliance or the overseas territories of the 20 countries referred to in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9134a04c-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dF/s1402"},"text":"Pub. L. 115–254, div. F, § 1402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3485"},"text":"132 Stat. 3485","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dH/tLXXXVII/s8711"},"text":"Pub. L. 119–60, div. H, title LXXXVII, § 8711","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1946"},"text":"139 Stat. 1946","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9134a04d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9134a04e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9134a04f-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this division”, meaning division F of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3485"},"text":"132 Stat. 3485","children":[],"tail":", which is classified principally to this chapter. For complete classification of division F to the Code, see Short Title note set out below and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subchapter VI of this chapter, referred to in par. (3), was in the original “title VI”, meaning title VI (§§ 1461–1470) of div. F of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3510"},"text":"132 Stat. 3510","children":[],"tail":", which is classified principally to subchapter VI of this chapter and which repealed title IV of chapter 2 of part I of the Foreign Assistance Act of 1961 ("},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2191"},"text":"22 U.S.C. 2191","children":[],"tail":" et seq.), other than subsections (g), ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), (m), and (n) of section 237 thereof ("},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2197/g"},"text":"22 U.S.C. 2197(g)","children":[],"tail":", ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), (m), (n)), among other amendments. For complete classification of title VI to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9134a050-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Pars. (1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8711/1"},"text":"Pub. L. 119–60, § 8711(1)","children":[],"tail":", (2), added par. (1) and redesignated former par. (1) as par. (2). Former par. (2) redesignated (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8711/3"},"text":"Pub. L. 119–60, § 8711(3)","children":[],"tail":", added pars. (3) and (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8711/4"},"text":"Pub. L. 119–60, § 8711(4)","children":[],"tail":", added par. (5) and struck out former par. (5), as so redesignated. Prior to amendment, text of par. (5) read as follows: "},{"tag":"quotedContent","attrib":{},"text":"“The term “less developed country” means a country with a low-income economy, lower-middle-income economy, or upper-middle-income economy, as defined by the International Bank for Reconstruction and Development and the International Development Association (collectively referred to as the “World Bank”).”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8711/1"},"text":"Pub. L. 119–60, § 8711(1)","children":[],"tail":", redesignated par. (2) as (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (6), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8711/1"},"text":"Pub. L. 119–60, § 8711(1)","children":[],"tail":", redesignated pars. (3) and (4) as (6) and (7), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8711/5"},"text":"Pub. L. 119–60, § 8711(5)","children":[],"tail":", added par. (8)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9134a051-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id9134a052-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dH/tLXXXVII/s8701"},"text":"Pub. L. 119–60, div. H, title LXXXVII, § 8701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1946"},"text":"139 Stat. 1946","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dH/tLXXXVII/s8701"},"text":"“This title [amending sections 9601, 9612—9614, 9621, 9622, 9624, 9632, 9633, 9652—9654, 9656, and 9671 of this title] may be cited as the ‘DFC Modernization and Reauthorization Act of 2025’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id9134a053-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dF/s1401"},"text":"Pub. L. 115–254, div. F, § 1401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3485"},"text":"132 Stat. 3485","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/254/dF/s1401"},"text":"“This division [enacting this chapter, amending sections 2151n, 2197, 2291, 2296b, 5401, 5421, 6062, 6445, 7102, 7902, 8926, 9303, and 9546 of this title, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s905"},"text":"section 905 of Title 2","children":[],"tail":", The Congress, sections 5313 to 5316 of Title 5, Government Organization and Employees, "},{"tag":"ref","attrib":{"href":"/us/pl/95/452/s8G"},"text":"section 8G of Pub. L. 95–452","children":[],"tail":", set out in the Appendix to Title 5, sections 649, 4721, 4727, and 4902 of Title 15, Commerce and Trade, "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s709"},"text":"section 709 of Title 18","children":[],"tail":", Crimes and Criminal Procedure, "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4421"},"text":"section 4421 of Title 19","children":[],"tail":", Customs Duties, "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1131c"},"text":"section 1131c of Title 20","children":[],"tail":", Education, "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s9101"},"text":"section 9101 of Title 31","children":[],"tail":", Money and Finance, and sections 17334 and 17336 of Title 42, The Public Health and Welfare, repealing subpart iv of part II of subchapter I of chapter 32 of this title, except for "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2197"},"text":"section 2197 of this title","children":[],"tail":", enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s905"},"text":"section 905 of Title 2","children":[],"tail":", amending provisions set out as notes under sections 2293 and 2394c of this title] may be cited as the ‘Better Utilization of Investments Leading to Development Act of 2018’ or the ‘BUILD Act of 2018’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
