{"tag":"section","attrib":{"id":"id904d4db1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3928"},"text":null,"children":[{"tag":"num","attrib":{"value":"3928"},"text":"§ 3928.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director General of Foreign Service","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President shall appoint, by and with the advice and consent of the Senate, a Director General of the Foreign Service, who shall be a current or former career member of the Foreign Service. The Director General should assist the Secretary of State in the management of the Service and perform such functions as the Secretary of State may prescribe.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id904d4db2-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s208"},"text":"Pub. L. 96–465, title I, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2080"},"text":"94 Stat. 2080","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s163"},"text":"Pub. L. 103–236, title I, § 163","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/411"},"text":"108 Stat. 411","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id904d4db3-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id904d4db4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id904d4db5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “There shall be a Director General of the Foreign Service, who shall be appointed by the President, by and with the advice and consent of the Senate, from among the career members of the Senior Foreign Service. The Director General shall assist the Secretary of State in the management of the Service and shall perform such functions as the Secretary of State may prescribe.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
