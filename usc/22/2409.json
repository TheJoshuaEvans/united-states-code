{"tag":"section","attrib":{"id":"id8fb72795-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2409"},"text":null,"children":[{"tag":"num","attrib":{"value":"2409"},"text":"§ 2409.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of United States Armed Forces","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The furnishing of economic, military, or other assistance under this chapter shall not be construed as creating a new commitment or as affecting any existing commitment to use Armed Forces of the United States for the defense of any foreign country.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8fb72796-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. III, § 650, as added "},{"tag":"ref","attrib":{"href":"/us/pl/90/137"},"text":"Pub. L. 90–137","children":[],"tail":", pt. III, § 303(b), "},{"tag":"date","attrib":{"date":"1967-11-14"},"text":"Nov. 14, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/462"},"text":"81 Stat. 462","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fb72797-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8fb72798-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8fb72799-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"