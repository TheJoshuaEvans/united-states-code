{"tag":"section","attrib":{"id":"id9024dda5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2797a"},"text":"§ 2797a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial of transfer of missile equipment or technology by United States persons","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9024dda6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanctions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9024dda7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the President determines that a United States person knowingly—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9024dda8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exports, transfers, or otherwise engages in the trade of any item on the MTCR Annex, in violation of the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2778"},"text":"section 2778 of this title","children":[],"tail":", section 4604 or 4605 "},{"tag":"ref","attrib":{"idref":"fn002231"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002231"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 50 or any regulations or orders issued under any such provisions,"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9024dda9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conspires to or attempts to engage in such export, transfer, or trade, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9024ddaa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797a/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitates such export, transfer, or trade by any other person,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then the President shall impose the applicable sanctions described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9024ddab-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The sanctions which apply to a United States person under paragraph (1) are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9024ddac-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the item on the MTCR Annex involved in the export, transfer, or trade is missile equipment or technology within category II of the MTCR Annex, then the President shall deny to such United States person for a period of 2 years—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9024ddad-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797a/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States Government contracts relating to missile equipment or technology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9024ddae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797a/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" licenses for the transfer of missile equipment or technology controlled under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9024ddaf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the item on the MTCR Annex involved in the export, transfer, or trade is missile equipment or technology within category I of the MTCR, then the President shall deny to such United States person for a period of not less than 2 years—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9024ddb0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797a/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all United States Government contracts, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9024ddb1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797a/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all export licenses and agreements for items on the United States Munitions List.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9024ddb2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discretionary sanctions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any determination made pursuant to subsection (a), the President may pursue any penalty provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2778/c"},"text":"section 2778(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9024ddb3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presumption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining whether to apply sanctions under subsection (a) to a United States person involved in the export, transfer, or trade of an item on the MTCR Annex, it should be a rebuttable presumption that such item is designed for use in a missile listed in the MTCR Annex if the President determines that the final destination of the item is a country the government of which the Secretary of State has determined, for purposes of ","children":[{"tag":"ref","attrib":{"idref":"fn002232"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002232"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be followed by “section”."}],"tail":" 4605(j)(1)(A) "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of title 50, has repeatedly provided support for acts of international terrorism."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9024ddb4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President may waive the imposition of sanctions under subsection (a) with respect to a product or service if the President certifies to the Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9024ddb5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the product or service is essential to the national security of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9024ddb6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such person is a sole source supplier of the product or service, the product or service is not available from any alternative reliable supplier, and the need for the product or service cannot be met in a timely manner by improved manufacturing processes or technological developments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9024ddb7-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/629"},"text":"Pub. L. 90–629","children":[],"tail":", ch. 7, § 72, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXVII/s1703"},"text":"Pub. L. 101–510, div. A, title XVII, § 1703","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1745"},"text":"104 Stat. 1745","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tVII/s734/a"},"text":"Pub. L. 103–236, title VII, § 734(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/505"},"text":"108 Stat. 505","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9024ddb8-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9024ddb9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9024ddba-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 4604 and 4605 of title 50, referred to in subsecs. (a)(1)(A) and (c), were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXVII/s1766/a"},"text":"Pub. L. 115–232, div. A, title XVII, § 1766(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2232"},"text":"132 Stat. 2232","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a)(2)(A)(ii), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/629"},"text":"Pub. L. 90–629","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1321"},"text":"82 Stat. 1321","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2751"},"text":"section 2751 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9024ddbb-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":" added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id9024ddbc-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id9024ddbd-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of certain functions of the President under this section, see Ex. Ord. No. 12851, § 2(a), ","children":[{"tag":"date","attrib":{"date":"1993-06-11"},"text":"June 11, 1993","children":[],"tail":", 58 F.R. 33181, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2797"},"text":"section 2797 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
