ense industries;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90a0c49e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5911/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than $15,000,000 may be made available for programs referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s5902/b/6"},"text":"section 5902(b)(6) of this title","children":[],"tail":" relating to military-to-military contacts;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90a0c49f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5911/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than $25,000,000 may be made available for joint research development programs pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s5931"},"text":"section 5931 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90a0c4a0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5911/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than $10,000,000 may be made available for the study, assessment, and identification of nuclear waste disposal activities by the former Soviet Union in the Arctic region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90a0c4a1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5911/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than $25,000,000 may be made available for Project PEACE; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90a0c4a2-2930-11