{"tag":"section","attrib":{"id":"id9037f0ac-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3381"},"text":null,"children":[{"tag":"num","attrib":{"value":"3381"},"text":"§ 3381.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Congress makes the following findings:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9037f0ad-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3381/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Taiwan Relations Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/8"},"text":"Public Law 96–8","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3301"},"text":"22 U.S.C. 3301","children":[],"tail":" et seq.) affirmed United States policy “to preserve and promote extensive, close, and friendly commercial, cultural, and other relations between the people of the United States and the people on Taiwan, as well as the people on the China mainland and all other peoples of the Western Pacific area”."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9037f0ae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3381/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Consistent with the Asia Reassurance Initiative Act of 2018 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/409"},"text":"Public Law 115–409","children":[],"tail":"), the United States has grown its strategic partnership with Taiwan’s vibrant democracy of 23,000,000 people."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9037f0af-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3381/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","at