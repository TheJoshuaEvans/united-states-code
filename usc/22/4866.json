{"tag":"section","attrib":{"id":"id90868525-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4866"},"text":null,"children":[{"tag":"num","attrib":{"value":"4866"},"text":"§ 4866.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security training for personnel assigned to a high risk, high threat post","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90868526-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4866/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Individuals assigned permanently to or who are in long-term temporary duty status as designated by the Secretary of State at a high risk, high threat post shall receive security training described in subsection (b) on a mandatory basis in order to prepare such individuals for living and working at such posts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90868527-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4866/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security training described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Security training referred to in subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90868528-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4866/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is training to improve basic knowledge and skills; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90868529-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4866/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9086852a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4866/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an ability to recognize, avoid, and respond to potential terrorist situations, including a complex attack;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9086852b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4866/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting surveillance detection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9086852c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4866/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing emergency medical care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9086852d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4866/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ability to detect the presence of improvised explosive devices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9086852e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4866/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimal firearms familiarization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9086852f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4866/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" defensive driving maneuvers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90868530-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4866/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements of this section shall take effect upon ","children":[{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90868531-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4866/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4867"},"text":"section 4867 of this title","children":[],"tail":":"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90868532-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4866/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Complex attack","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “complex attack” has the meaning given such term by the North Atlantic Treaty Organization, as follows: “An attack conducted by multiple hostile elements which employ at least two distinct classes of weapon systems (i.e., indirect fire and direct fire, improvised explosive devices, and surface to air fire).”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90868533-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4866/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High risk, high threat post","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “high risk, high threat post” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4803"},"text":"section 4803 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90868534-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/399/tIV/s416"},"text":"Pub. L. 99–399, title IV, § 416","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/323/tI/s121/a"},"text":"Pub. L. 114–323, title I, § 121(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1913"},"text":"130 Stat. 1913","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
