{"tag":"section","attrib":{"id":"id90c95a86-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6911"},"text":null,"children":[{"tag":"num","attrib":{"value":"6911"},"text":"§ 6911.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Congressional-Executive Commission on the People’s Republic of China","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is established a Congressional-Executive Commission on the People’s Republic of China (in this subchapter referred to as the “Commission”).","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id90c95a87-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/286/dB/tIII/s301"},"text":"Pub. L. 106–286, div. B, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-10"},"text":"Oct. 10, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/895"},"text":"114 Stat. 895","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
