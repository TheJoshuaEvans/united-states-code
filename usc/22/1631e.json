{"tag":"section","attrib":{"id":"id8f103968-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1631e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1631e"},"text":"§ 1631e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules by district courts; appeals","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The district courts of the United States are given jurisdiction to make and enter all such rules as to notice and otherwise, and all such orders and decrees, and to issue such process as may be necessary and proper in the premises to enforce the provisions of this subchapter, with a right of appeal from the final order or decree of such court as provided in chapter 83 of title 28.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f103969-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-03-10/ch54"},"text":"Mar. 10, 1950, ch. 54","children":[],"tail":", title II, § 206, as added "},{"tag":"ref","attrib":{"href":"/us/act/1955-08-09/ch645/s3"},"text":"Aug. 9, 1955, ch. 645, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/563"},"text":"69 Stat. 563","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/352/s6/g"},"text":"Pub. L. 100–352, § 6(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-06-27"},"text":"June 27, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/664"},"text":"102 Stat. 664","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f10396a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f10396b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f10396c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/352"},"text":"Pub. L. 100–352","children":[],"tail":" substituted “chapter 83” for “sections 1252, 1254, 1291, and 1292”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f10396d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8f10396e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/352"},"text":"Pub. L. 100–352","children":[],"tail":" effective ninety days after "},{"tag":"date","attrib":{"date":"1988-06-27"},"text":"June 27, 1988","children":[],"tail":", except that such amendment not to apply to cases pending in Supreme Court on such effective date or affect right to review or manner of reviewing judgment or decree of court which was entered before such effective date, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/352/s7"},"text":"section 7 of Pub. L. 100–352","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1254"},"text":"section 1254 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
