{"tag":"section","attrib":{"id":"id90e128c0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7555"},"text":null,"children":[{"tag":"num","attrib":{"value":"7555"},"text":"§ 7555.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Formulation of long-term strategy for Afghanistan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90e128c1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7555/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategy","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90e128c2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7555/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2004-12-17"},"text":"December 17, 2004","children":[],"tail":", the President shall formulate a 5-year strategy for Afghanistan and submit such strategy to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90e128c3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7555/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e128c4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7555/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on International Relations of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e128c5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7555/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e128c6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7555/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90e128c7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7555/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The strategy formulated under paragraph (1) shall include specific and measurable goals for addressing the long-term development and security needs of Afghanistan, including sectors such as agriculture and irrigation, parliamentary and democratic development, the judicial system and rule of law, human rights, education, health, telecommunications, electricity, women’s rights, counternarcotics, police, border security, anti-corruption, and other law-enforcement activities, as well as the anticipated costs and time frames associated with achieving those goals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90e128c8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7555/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90e128c9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7555/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002384"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002384"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No par. (2) has been enacted."}],"tail":" Annual report"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall transmit on an annual basis through 2010 a report describing the progress made toward the implementation of the strategy required by subsection (a) and any changes to the strategy since the date of the submission of the last report to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90e399ca-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7555/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e399cb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7555/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on International Relations of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e399cc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7555/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e399cd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7555/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90e399ce-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/327/tIII/s305"},"text":"Pub. L. 107–327, title III, § 305","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tVII/s7104/e/4/A"},"text":"Pub. L. 108–458, title VII, § 7104(e)(4)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3782"},"text":"118 Stat. 3782","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90e399cf-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90e399d0-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id90e399d1-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on International Relations of House of Representatives changed to Committee on Foreign Affairs of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id90e399d2-2930-11f1-8918-be39dde81dc6"},"text":null,"c