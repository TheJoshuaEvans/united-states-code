{"tag":"section","attrib":{"id":"id8f686bbf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2214"},"text":null,"children":[{"tag":"num","attrib":{"value":"2214"},"text":"§ 2214.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f686bc0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2214/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2006-06-30"},"text":"June 30, 2006","children":[],"tail":", and each June 30 thereafter, the Administrator of the Agency, acting through the Director of the office, shall submit to the appropriate congressional committees a report that contains a detailed description of the implementation of this subpart for the previous fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f686bc1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2214/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent practicable, the report submitted under subsection (a) should contain the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f686bc2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2214/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Information about assistance provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2211a"},"text":"section 2211a of this title","children":[],"tail":", including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8f686bc3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2214/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of each grant or other form of assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f686bc4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2214/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name and type of each intermediary and implementing partner organization receiving assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f686bc5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2214/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of each country receiving assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f686bc6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2214/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the methodology used to ensure compliance with the targeted assistance requirements under subsection (c) of such section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f686bc7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2214/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The percentage of assistance provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2211a"},"text":"section 2211a of this title","children":[],"tail":", disaggregated by income level, including for the very poor, and by gender."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f686bc8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2214/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The estimated number of individuals that received assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2211a"},"text":"section 2211a of this title","children":[],"tail":", disaggregated by income level (or an appropriate proxy for income level, including for the very poor), by gender, and by type of assistance."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f686bc9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2214/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The results of the monitoring system required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2211b"},"text":"section 2211b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f686bca-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2214/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information about any method in place to assess poverty levels under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2211c"},"text":"section 2211c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f686bcb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2214/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability to public","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib"