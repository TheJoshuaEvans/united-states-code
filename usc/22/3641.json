{"tag":"section","attrib":{"id":"id903f1d46-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3641"},"text":null,"children":[{"tag":"num","attrib":{"value":"3641"},"text":"§ 3641.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id903f1d47-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3641/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Executive agency” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s105"},"text":"section 105 of title 5","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903f1d48-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3641/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “uniformed services” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2101/3"},"text":"section 2101(3) of title 5","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903f1d49-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3641/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “competitive service” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2102"},"text":"section 2102 of title 5","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903f1d4a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3641/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “United States”, when used in a geographic sense, means each of the several States and the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id903f1d4b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70/tI/s1201"},"text":"Pub. L. 96–70, title I, § 1201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-27"},"text":"Sept. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/461"},"text":"93 Stat. 461","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id903f1d4c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id903f1d4d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id903f1d4e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Employment of Commission Employees by Government of Panama","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/dC/tXXXV/s3504"},"text":"Pub. L. 103–160, div. C, title XXXV, § 3504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1965"},"text":"107 Stat. 1965","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/c/32"},"text":"Pub. L. 117–286, § 4(c)(32)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4358"},"text":"136 Stat. 4358","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/286/s4/c/32"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consent of Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subsection (b), the Congress consents to employees of the Panama Canal Commission who are not citizens of the United States accepting civil employment with agencies and organizations affiliated with the Government of Panama (and compensation for that employment) for which the consent of Congress is required by the 8th clause of section 9 of article I of the Constitution of the United States, relating to acceptance of emolument, office, or title from a foreign State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Condition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Employees described in subsection (a) may accept employment described in such subsection (and compensation for that employment) only if the employment is approved by the designated agency ethics official of the Panama Canal Commission designated pursuant to chapter 131 of title 5, United States Code, and by the Administrator of the Panama Canal Commission.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
