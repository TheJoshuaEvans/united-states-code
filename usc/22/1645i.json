{"tag":"section","attrib":{"id":"id8f17650a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1645i"},"text":null,"children":[{"tag":"num","attrib":{"value":"1645i"},"text":"§ 1645i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award payment procedures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f17650b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1645i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification of amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall certify to the Secretary of the Treasury, in terms of United States currency, each award made pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s1645b"},"text":"section 1645b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f17650c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1645i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority of payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f17650d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1645i/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Upon certification of each award made pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s1645b"},"text":"section 1645b of this title","children":[],"tail":", the Secretary of the Treasury shall, out of the sums covered into the Claims Fund, make payments on account of such awards as follows, and in the following order of priority:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8f17650e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1645i/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payment in the amount of $2,500 or the principal amount of the award, whichever is less.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f17650f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1645i/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Thereafter, payments from time to time, in ratable proportions, on account of the unpaid balance of the principal amounts of all awards according to the proportions which the unpaid balance of such awards bear to the total amount in the Claims Fund available for distribution at the time such payments are made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f176510-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1645i/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After payment has been made in full of the principal amounts of all awards pursuant to paragraph (1), pro rata payments may be made on account of any interest that may be allowed on such awards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f176511-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1645i/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Payments or applications for payments under subsection (b) shall be made in accordance with such regulations as the Secretary of the Treasury may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f176512-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-03-10/ch54"},"text":"Mar. 10, 1950, ch. 54","children":[],"tail":", title VII, § 710, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/606"},"text":"Pub. L. 96–606","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-28"},"text":"Dec. 28, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3537"},"text":"94 Stat. 3537","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
