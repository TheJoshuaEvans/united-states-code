{"tag":"section","attrib":{"id":"id90f91de3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8261"},"text":null,"children":[{"tag":"num","attrib":{"value":"8261"},"text":"§ 8261.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" The United Nations Democracy Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90f91de4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8261/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of Congress that the United States should work with other countries to enhance the goals and work of the United Nations Democracy Fund, an essential tool to promote democracy, and in particular support civil society in foreign countries in their efforts to help consolidate democracy and bring about transformational change.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90f91de5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8261/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated $14,000,000 for each of fiscal years 2008 and 2009 to the Secretary for a United States contribution to the United Nations Democracy Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90f91de6-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/tXXI/s2161"},"text":"Pub. L. 110–53, title XXI, § 2161","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/536"},"text":"121 Stat. 536","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
