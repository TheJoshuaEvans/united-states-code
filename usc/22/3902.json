{"tag":"section","attrib":{"id":"id904b02fe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3902"},"text":null,"children":[{"tag":"num","attrib":{"value":"3902"},"text":"§ 3902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id904b02ff-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3902/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “abroad” means all areas not included within the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904b0300-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3902/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “agency” means an agency as defined in section 552(e) ","children":[{"tag":"ref","attrib":{"idref":"fn002272"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002272"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 5;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904b0301-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3902/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “chief of mission” means the principal officer in charge of a diplomatic mission of the United States or of a United States office abroad which is designated by the Secretary of State as diplomatic in nature, including any individual assigned under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3982/c"},"text":"section 3982(c) of this title","children":[],"tail":" to be temporarily in charge of such a mission or office;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904b0302-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3902/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Department” means the Department of State, except that with reference to the exercise of functions under this chapter with respect to another agency authorized by law to utilize the Foreign Service personnel system, such term means that other agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904b0303-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3902/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “employee” (except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4102/8"},"text":"section 4102(8) of this title","children":[],"tail":") means, when used with respect to an agency or to the Government generally, an officer or employee (including a member of the Service) or a member of the Armed Forces of the United States, the commissioned corps of the Public Health Service, or the commissioned corps of the National Oceanic and Atmospheric Administration;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904b0304-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3902/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “function” includes any duty, obligation, power, authority, responsibility, right, privilege, discretion, or activity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904b0305-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3902/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Government” means the Government of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904b0306-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3902/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “merit principles” means the principles set out in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2301/b"},"text":"section 2301(b) of title 5","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904b0307-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3902/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “principal officer” means the officer in charge of a diplomatic mission, consular mission (other than a consular agency), or other Foreign Service post;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904b0308-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3902/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Secretary” means the Secretary of State, except that (subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3921"},"text":"section 3921 of this title","children":[],"tail":") with reference to the exercise of functions under this Act with respect to any agency authorized by law to utilize the Foreign Service personnel system, such term means the head of that agency;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904b0309-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3902/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Service” or “Foreign Service” means the Foreign Service of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904b030a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3902/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “United States”, when used in a geographic sense, means the several States and the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id904b030b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s102"},"text":"Pub. L. 96–465, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2075"},"text":"94 Stat. 2075","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/164/tI/s130/a"},"text":"Pub. L. 98–164, title I, § 130(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-11-22"},"text":"Nov. 22, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1027"},"text":"97 Stat. 1027","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id904b030c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id904b030d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id904b030e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/e"},"text":"Section 552(e) of title 5","children":[],"tail":", referred to in par. (2), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/f"},"text":"section 552(f) of title 5","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/99/570/s1802/b"},"text":"section 1802(b) of Pub. L. 99–570","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id904b030f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/164"},"text":"Pub. L. 98–164","children":[],"tail":" struck out “(a)” before “As used in this chapter”, and struck out subsec. (b) which provided that references to Foreign Service officers in any provision be deemed to refer to, with respect to the United States Information Agency, Foreign Service Information officers."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
