{"tag":"section","attrib":{"id":"id90dedec9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7433"},"text":null,"children":[{"tag":"num","attrib":{"value":"7433"},"text":"§ 7433.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to international efforts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90dedeca-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7433/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall prohibit the United States from rendering assistance to international efforts to bring to justice Saddam Hussein, Slobodan Milosovic, Osama bin Laden, other members of Al Queda,","children":[{"tag":"ref","attrib":{"idref":"fn002381"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002381"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" leaders of Islamic Jihad, and other foreign nationals accused of genocide, war crimes or crimes against humanity, or from rendering assistance to the International Criminal Court to assist with investigations and prosecutions of foreign nationals related to the Situation in Ukraine, including to support victims and witnesses."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90dedecb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7433/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Assistance made available pursuant to subsection (a) of this section may be made available notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7401"},"text":"section 7401 of this title","children":[],"tail":", except that none of the funds made available pursuant to this subsection may be made available for the purpose of supporting investigations or prosecutions of U.S. servicemembers or other covered United States persons or covered allied persons as such terms are defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7432"},"text":"section 7432 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90dedecc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7433/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall notify the Committees on Appropriations, the Committee on Foreign Relations of the Senate, and the Committee on Foreign Affairs of the House of Representatives, of any amounts obligated pursuant to subsection (b) not later than 15 days before such obligation is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90dedecd-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/206/tII/s2015"},"text":"Pub. L. 107–206, title II, § 2015","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-02"},"text":"Aug. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/909"},"text":"116 Stat. 909","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dK/tVII/s7073/b"},"text":"Pub. L. 117–328, div. K, title VII, § 7073(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5092"},"text":"136 Stat. 5092","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90dedece-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90dedecf-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90deded0-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" substituted subsecs. (a) to (c) for “Nothing in this subchapter shall prohibit the United States from rendering assistance to international efforts to bring to justice Saddam Hussein, Slobodan Milosovic, Osama bin Laden, other members of Al Queda, leaders of Islamic Jihad, and other foreign nationals accused of genocide, war crimes or crimes against humanity.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90deded1-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id90deded2-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Nothing in amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" to be construed to modify the existing roles or authorities of any Federal agency or official, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/s7073/c"},"text":"section 7073(c) of Pub. L. 117–328","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7423"},"text":"section 7423 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
