{"tag":"section","attrib":{"id":"id904b0310-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3903"},"text":null,"children":[{"tag":"num","attrib":{"value":"3903"},"text":"§ 3903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members of Service","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The following are the members of the Service:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id904b0311-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3903/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chiefs of mission, appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3942/a/1"},"text":"section 3942(a)(1) of this title","children":[],"tail":" or assigned under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3982/c"},"text":"section 3982(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904b0312-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3903/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ambassadors at large, appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3942/a/1"},"text":"section 3942(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904b0313-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3903/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the Senior Foreign Service, appointed under section 3942(a)(1) or 3943 of this title, who are the corps of leaders and experts for the management of the Service and the performance of its functions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904b0314-2930-1