{"tag":"section","attrib":{"id":"id911a6201-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9007"},"text":null,"children":[{"tag":"num","attrib":{"value":"9007"},"text":"§ 9007.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs and fees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id911a6202-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9007/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No department, agency, or instrumentality of the Federal Government or of any State or local government may impose on an applicant any fee in relation to the administrative processing of applications submitted under the Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id911a6203-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9007/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs incurred in civil actions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id911a6204-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9007/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Petitioners may be required to bear the costs of legal counsel or advisors, court costs incurred in connection with their petitions, and travel costs for the return of the child involved and any accompanying persons, except as provided in paragraphs (2) and (3).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a6205-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9007/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (3), legal fees or court costs incurred in connection with an action brought under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9003"},"text":"section 9003 of this title","children":[],"tail":" shall be borne by the petitioner unless they are covered by payments from Federal, State, or local legal assistance or other programs."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a6206-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9007/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any court ordering the return of a child pursuant to an action brought under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9003"},"text":"section 9003 of this title","children":[],"tail":" shall order the respondent to pay necessary expenses incurred by or on behalf of the petitioner, including court costs, legal fees, foster home or other care during the course of proceedings in the action, and transportation costs related to the return of the child, unless the respondent establishes that such order would be clearly inappropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id911a6207-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/300/s8"},"text":"Pub. L. 100–300, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-29"},"text":"Apr. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/440"},"text":"102 Stat. 440","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id911a6208-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id911a6209-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id911a620a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11607"},"text":"section 11607 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
