{"tag":"section","attrib":{"id":"id91515004-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10221"},"text":null,"children":[{"tag":"num","attrib":{"value":"10221"},"text":"§ 10221.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91515005-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10221/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Admitted; alien","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “admitted” and “alien” have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of title 8","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91515006-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10221/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91515007-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10221/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations and the Committee on Banking, Housing, and Urban Affairs of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91515008-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10221/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs and the Committee on Financial Services of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91515009-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10221/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Correspondent account; payable-through account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “correspondent account” and “payable-through account” have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s5318A"},"text":"section 5318A of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9151500a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10221/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign financial institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “foreign financial institution” has the meaning of that term as determined by the Secretary of the Treasury by regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9151500b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10221/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “foreign person” means a person that is not a United States person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9151500c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10221/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Knowingly","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “knowingly”, with respect to conduct, a circumstance, or a result, means that a person has actual knowledge, or should have known, of the conduct, the circumstance, or the result.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9151500d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10221/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person” means an individual or entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9151500e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10221/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “support”, with respect to the Burmese military, means to knowingly have materially assisted, sponsored, or provided financial, material, or technological support for, or goods or services to or in support of the Burmese military.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9151500f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10221/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States person","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “United States person” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91515010-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10221/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a United States citizen or an alien lawfully admitted to the United States for permanent residence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91515011-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10221/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity organized under the laws of the United States or any jurisdiction within the United States, including a foreign branch of such an entity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91515012-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10221/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id91515013-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLV/s5570"},"text":"Pub. L. 117–263, div. E, title LV, § 5570","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3362"},"text":"136 Stat. 3362","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
