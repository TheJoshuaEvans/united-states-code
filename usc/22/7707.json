{"tag":"section","attrib":{"id":"id90ed0ffd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7707"},"text":null,"children":[{"tag":"num","attrib":{"value":"7707"},"text":"§ 7707.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional and public notification of candidate countries, eligibility criteria, and eligible countries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90ed0ffe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7707/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of candidate countries","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days prior to the date on which the Board determines eligible countries under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7706"},"text":"section 7706 of this title","children":[],"tail":" for a fiscal year, the Chief Executive Officer—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90ed0fff-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7707/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall prepare and submit to the appropriate congressional committees a report that contains a list of all candidate countries identified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7705"},"text":"section 7705 of this title","children":[],"tail":", and all countries that would be candidate countries if the countries met the requirement contained in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7705/a/2"},"text":"section 7705(a)(2) of this title","children":[],"tail":", for the fiscal year; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ed1000-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7707/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall publish in the Federal Register the information contained in the report described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90ed1001-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7707/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of eligibility criteria and methodology","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days prior to the date on which the Board determines eligible countries under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7706"},"text":"section 7706 of this title","children":[],"tail":" for a fiscal year, the Chief Executive Officer—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90ed1002-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7707/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall prepare and submit to the appropriate congressional committees a report that contains a list of the criteria and methodology described in subsections (a) and (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7706"},"text":"section 7706 of this title","children":[],"tail":" that will be used to determine eligibility for each candidate country identified under subsection (a);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ed1003-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7707/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall publish in the Federal Register the information contained in the report described in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ed1004-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7707/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may conduct one or more public hearings on the eligibility criteria and methodology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90ed1005-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7707/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public comment and congressional consultation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90ed1006-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7707/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public comment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Executive Officer shall, for the 30-day period beginning on the date of publication in the Federal Register of the information contained in the report described in subsection (b)(1), accept public comment and consider such comment for purposes of determining eligible countries under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7706"},"text":"section 7706 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ed1007-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7707/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Executive Officer shall consult with the appropriate congressional committees on the extent to which the candidate countries meet the criteria described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7706/b"},"text":"section 7706(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90ed1008-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7707/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of eligible countries","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 5 days after the date on which the Board determines eligible countries under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7706"},"text":"section 7706 of this title","children":[],"tail":" for a fiscal year, the Chief Executive Officer—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90ed1009-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7707/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall prepare and submit to the appropriate congressional committees a report that contains a list of all such eligible countries, an identification of those countries on such list with respect to which the Board will seek to enter into a Compact under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7708"},"text":"section 7708 of this title","children":[],"tail":", and a justification for such eligibility determination and selection for Compact negotiation; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ed100a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7707/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall publish in the Federal Register the information contained in the report described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90ed100b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/dD/tVI/s608"},"text":"Pub. L. 108–199, div. D, title VI, § 608","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/217"},"text":"118 Stat. 217","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dE/tLI/s5122/c/1"},"text":"Pub. L. 118–159, div. E, title LI, § 5122(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2430"},"text":"138 Stat. 2430","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90ed100c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90ed100d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90ed100e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" substituted “section 7705(a)(2)” for “section 7705(a)(1)(B)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
