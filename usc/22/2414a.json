n":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-02-16"},"text":"Feb. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/67"},"text":"104 Stat. 67","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500/s101/f/tV/s528"},"text":"Pub. L. 99–500, § 101(f) [title V, § 528]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1783-213"},"text":"100 Stat. 1783–213","children":[],"tail":", 1783–230, and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/s101/f/tV/s528"},"text":"Pub. L. 99–591, § 101(f) [title V, § 528]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-30"},"text":"Oct. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3341-214"},"text":"100 Stat. 3341–214","children":[],"tail":", 3341–230; repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/101/167/tV/s527/e/4"},"text":"Pub. L. 101–167, title V, § 527(e)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-21"},"text":"Nov. 21, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1224"},"text":"103 Stat. 1224","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/101/246/tIV/s406/e/3"},"text":"Pub. L. 101–246, title IV, § 406(e)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-02-16"},"text":"Feb. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/67"},"text":"104 Stat. 67","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/190/s101/i/tV/s529"},"text":"Pub. L. 99–190, § 101(i) [title V, § 529]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-19"},"text":"Dec. 19, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1291"},"text":"99 Stat. 1291","children":[],"tail":", 1307; repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/101/167/tV/s527/e/3"},"text":"Pub. L. 101–167, title V, § 527(e)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-21"},"text":"Nov. 21, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1224"},"text":"103 Stat. 1224","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/101/246/tIV/s406/e/2"},"text":"Pub. L. 101–246, title IV, § 406(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-02-16"},"text":"Feb. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/67"},"text":"104 Stat. 67","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tI/s101/1"},"text":"Pub. L. 98–473, title I, § 101(1)","children":[],"tail":" [title V, § 530], "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1884"},"text":"98 Stat. 1884","children":[],"tail":", 1900; repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/101/167/tV/s527/e/2"},"text":"Pub. L. 101–167, title V, § 527(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-21"},"text":"Nov. 21, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1224"},"text":"103 Stat. 1224","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/151/s101/b/1"},"text":"Pub. L. 98–151, § 101(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-11-14"},"text":"Nov. 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/967"},"text":"97 Stat. 967","children":[],"tail":"; repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/101/167/tV/s527/e/1"},"text":"Pub. L. 101–167, title V, § 527(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-21"},"text":"Nov. 21, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1224"},"text":"103 Stat. 1224","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/101/246/tIV/s406/e/1"},"text":"Pub. L. 101–246, title IV, § 406(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-02-16"},"text":"Feb. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/67"},"text":"104 Stat. 67","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8fb998e4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Statement of Policy on Member State’s Voting Practices at the United Nations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/323/tIII/s309"},"text":"Pub. L. 114–323, title III, § 309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1924"},"text":"130 Stat. 1924","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/323/tIII/s309"},"text":"“It is the policy of the United States to strongly consider a Member State’s voting practices at the United Nations before entering into any agreements with the Member State.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8fb998e5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Requirement for Disclosure of Foreign Aid in Report of Secretary of State","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/429/s101/a/tV/s559"},"text":"Pub. L. 106–429, § 101(a) [title V, § 559]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-06"},"text":"Nov. 6, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1900"},"text":"114 Stat. 1900","children":[],"tail":", 1900A–45, which required that the report submitted to Congress under subsec. (a) of this section include, in addition to the voting practices of a foreign country, a side-by-side comparison of individual countries’ overall support for the United States at the United Nations and the amount of United States assistance, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2291/e/4"},"text":"section 2291(e)(4) of this title","children":[],"tail":", provided to such country in fiscal year 2000, was from the Foreign Operations, Export Financing, and Related Programs Appropriations Act, 2001, and was not repeated in subsequent appropriation acts. Similar provisions were contained in the following prior appropriation acts:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/2/tV/s560"},"text":"Pub. L. 106–113, div. B, § 1000(a)(2) [title V, § 560]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1535"},"text":"113 Stat. 1535","children":[],"tail":", 1501A–104."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/d/tV/s562"},"text":"Pub. L. 105–277, div. A, § 101(d) [title V, § 562]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-150"},"text":"112 Stat. 2681–150","children":[],"tail":", 2681–193."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/118/tV/s563"},"text":"Pub. L. 105–118, title V, § 563","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-26"},"text":"Nov. 26, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2427"},"text":"111 Stat. 2427","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/c/tV/s580"},"text":"Pub. L. 104–208, div. A, title I, § 101(c) [title V, § 580]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-121"},"text":"110 Stat. 3009–121","children":[],"tail":", 3009–170."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
