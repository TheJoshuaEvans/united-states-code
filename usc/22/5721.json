{"tag":"section","attrib":{"id":"id90974ebc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5721"},"text":null,"children":[{"tag":"num","attrib":{"value":"5721"},"text":"§ 5721.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continued application of United States law","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90974ebd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5721/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any change in the exercise of sovereignty over Hong Kong, the laws of the United States shall continue to apply with respect to Hong Kong, on and after ","children":[{"tag":"date","attrib":{"date":"1997-07-01"},"text":"July 1, 1997","children":[],"tail":", in the same manner as the laws of the United States were applied with respect to Hong Kong before such date unless otherwise expressly provided by law or by Executive order under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s5722"},"text":"section 5722 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90974ebe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5721/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For all purposes, including actions in any court in the United States, the Congress approves the continuation in force on and after ","children":[{"tag":"date","attrib":{"date":"1997-07-01"},"text":"July 1, 1997","children":[],"tail":", of all treaties and other international agreements, including multilateral conventions, entered into before "},{"tag":"date","attrib":{"date":"2019-11-27"},"text":"November 27, 2019","children":[],"tail":", between the United States and Hong Kong, or entered into before "},{"tag":"date","attrib":{"date":"2019-11-27"},"text":"November 27, 2019","children":[],"tail":", between the United States and the United Kingdom and applied to Hong Kong, unless or until terminated in accordance with law. If in carrying out this subchapter, the President determines that Hong Kong is not legally competent to carry out its obligations under any such treaty or other international agreement, or that the continuation of Hong Kong’s obligations or rights under any such treaty or other international agreement is not appropriate under the circumstances, such determination shall be reported to the Congress in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s5731"},"text":"section 5731 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90974ebf-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/383/tII/s201"},"text":"Pub. L. 102–383, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-05"},"text":"Oct. 5, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1452"},"text":"106 Stat. 1452","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/76/s4/a/1"},"text":"Pub. L. 116–76, § 4(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-11-27"},"text":"Nov. 27, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1163"},"text":"133 Stat. 1163","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90974ec0-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90974ec1-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90974ec2-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/76"},"text":"Pub. L. 116–76","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2019-11-27"},"text":"November 27, 2019","children":[],"tail":"” for “such date” in two places."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
