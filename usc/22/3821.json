{"tag":"section","attrib":{"id":"id9048926e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3821"},"text":null,"children":[{"tag":"num","attrib":{"value":"3821"},"text":"§ 3821.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vessels subject to inspection","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"With the exception of private vessels merely transiting the Panama Canal, and of public vessels of all nations, vessels navigating the waters of the Panama Canal shall be subject to an annual inspection of hulls, boilers, machinery, equipment, and passenger accommodations.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id9048926f-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70/tI/s1811"},"text":"Pub. L. 96–70, title I, § 1811","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-27"},"text":"Sept. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/492"},"text":"93 Stat. 492","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
