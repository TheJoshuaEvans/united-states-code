{"tag":"section","attrib":{"id":"id90f6ad05-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8143"},"text":null,"children":[{"tag":"num","attrib":{"value":"8143"},"text":"§ 8143.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90f6ad06-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8143/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The district courts of the United States shall have jurisdiction over civil actions brought by the head of an executive agency designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8111/a"},"text":"section 8111(a) of this title","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90f6ad07-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8143/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to restrain any conduct in violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8124"},"text":"section 8124 of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s8141"},"text":"section 8141 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f6ad08-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8143/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to compel the taking of any action required by or under this chapter or the Additional Protocol.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90f6ad09-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8143/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil actions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90f6ad0a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8143/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A civil action described in subsection (a) may be brought—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90f6ad0b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8143/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a civil action described in paragraph (1) of such subsection, in the United States district court for the judicial district in which any act, omission, or transaction constituting a violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8124"},"text":"section 8124 of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s8141"},"text":"section 8141 of this title","children":[],"tail":" occurred or in which the defendant is found or transacts business; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90f6ad0c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8143/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a civil action described in paragraph (2) of such subsection, in the United States district court for the judicial district in which the defendant is found or transacts business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f6ad0d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8143/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service of process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any such civil action, process shall be served on a defendant wherever the defendant may reside or may be found.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90f6ad0e-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/401/tII/s243"},"text":"Pub. L. 109–401, title II, § 243","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-18"},"text":"Dec. 18, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2749"},"text":"120 Stat. 2749","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
