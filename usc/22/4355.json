{"tag":"section","attrib":{"id":"id90785527-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4355"},"text":null,"children":[{"tag":"num","attrib":{"value":"4355"},"text":"§ 4355.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to Privacy Act and Freedom of Information Act","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90785528-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4355/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privacy Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter may be construed as requiring the public disclosure of records or portions of records protected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of title 5","children":[],"tail":" (relating to the privacy of personal records)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90785529-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4355/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Freedom of Information Act","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9078552a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4355/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), no record (or portion thereof) shall be excluded from publication in the FRUS series under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4353"},"text":"section 4353 of this title","children":[],"tail":", or exempted from the declassification requirement of "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4354"},"text":"section 4354 of this title","children":[],"tail":", solely by virtue of the application of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b"},"text":"section 552(b) of title 5","children":[],"tail":" (relating to the exemption of certain matters from freedom of information requirements)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9078552b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4355/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Records described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1202/f"},"text":"section 1202(f) of title 8","children":[],"tail":" (relating to visa records) shall be excluded from publication in the FRUS series under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4353"},"text":"section 4353 of this title","children":[],"tail":" and, to the extent applicable, exempted from the declassification requirement of "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4354"},"text":"section 4354 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9078552c-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch841"},"text":"Aug. 1, 1956, ch. 841","children":[],"tail":", title IV, § 405, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/138/tI/s198/a"},"text":"Pub. L. 102–138, title I, § 198(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/688"},"text":"105 Stat. 688","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
