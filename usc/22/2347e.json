{"tag":"section","attrib":{"id":"id8f93735a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2347e"},"text":null,"children":[{"tag":"num","attrib":{"value":"2347e"},"text":"§ 2347e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on grant assistance for certain high income foreign countries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f93735b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2347e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"None of the funds made available for a fiscal year for assistance under this part may be made available for assistance on a grant basis for any of the high-income foreign countries described in subsection (b) for military education and training of military and related civilian personnel of such country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f93735c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2347e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High-income foreign countries described","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The high-income foreign countries described in this subsection are Austria, Finland, the Republic of Korea, Singapore, and Spain.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f93735d-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. II, § 546, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/164/tI/s112/c/1"},"text":"Pub. L. 104–164, title I, § 112(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-07-21"},"text":"July 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1427"},"text":"110 Stat. 1427","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
