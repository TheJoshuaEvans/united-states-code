{"tag":"section","attrib":{"id":"id90ef8061-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7818"},"text":null,"children":[{"tag":"num","attrib":{"value":"7818"},"text":"§ 7818.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National registry of Korean American divided families","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90ef8062-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7818/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National registry","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90ef8063-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7818/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State, acting through the Special Envoy on North Korean Human Rights Issues, the Assistant Secretary of State for Consular Affairs, or such other individual as the Secretary may designate, shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90ef8064-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7818/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage, to the extent practicable, Korean American families who wish to be reunited with family members residing in North Korea from which such Korean American families were divided after the signing of the Agreement Concerning a Military Armistice in Korea, signed at Panmunjom ","children":[{"tag":"date","attrib":{"date":"1953-07-27"},"text":"July 27, 1953","children":[],"tail":" (commonly referred to as the “Korean War Armistice Agreement” ), in anticipation of future reunions for such families and family members, including in-person and video reunions; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ef8065-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7818/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish a private, internal national registry of the names and other relevant information of such Korean American families—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90ef8066-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7818/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate such future reunions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90ef8067-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7818/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide for a repository of information about such Korean American families and family members in North Korea, including information about individuals who may be deceased.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ef8068-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7818/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure of information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State may enter into agreements with Korean individuals and families, academic institutions, or other members of the public, as appropriate, to share, in whole or in part, information collected and housed in the database if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90ef8069-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7818/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States person whose personally identifiable information would be disclosed as a result of an agreement has provided consent to such disclosure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ef806a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7818/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the agreement outlines reasonable steps and commitments to ensure that any information disclosed as a result of such agreement is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90ef806b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7818/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" kept private and confidential; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90ef806c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7818/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will not be disclosed improperly to other parties outside the agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90ef806d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7818/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions to facilitate dialogue between the United States and North Korea","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90ef806e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7818/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State should take steps to ensure that any direct dialogue between the United States and North Korea includes progress towards holding future reunions for Korean American families and their family members in North Korea.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ef806f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7818/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall consult with the Government of the Republic of Korea, as appropriate, in carrying out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ef8070-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7818/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirement","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90ef8071-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7818/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State, acting through the Special Envoy on North Korean Human Rights Issues, shall include in each report required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7817/d"},"text":"section 7817(d) of this title","children":[],"tail":" a description of the consultations described in paragraph (2) conducted during the year preceding the submission of the report."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ef8072-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7818/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The reporting required under subparagraph (A) should include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90ef8073-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7818/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of the national registry established pursuant to subsection (a)(1)(B);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90ef8074-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7818/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the number of individuals included on the registry who—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id90ef8075-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7818/b/3/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have met their family members in North Korea during previous reunions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id90ef8076-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7818/b/3/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have yet to meet their family members in North Korea;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90ef8077-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7818/b/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of responses by North Korea to requests by the United States Government to hold reunions of divided families; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90ef8078-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7818/b/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of actions taken by North Korea that prevent the emigration of family members of Korean American families.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90ef8079-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7818/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term ‘appropriate congressional committees’ means the Committee on Foreign Relations of the Senate and the Committee on Foreign Affairs of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90ef807a-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dH/tLXXXIII/s8361"},"text":"Pub. L. 119–60, div. H, title LXXXIII, § 8361","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1884"},"text":"139 Stat. 1884","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90ef807b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90ef807c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id90ef807d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the National Defense Authorization Act for Fiscal Year 2026, and not as part of the North Korean Human Rights Act of 2004, which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90ef807e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id90ef807f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Consultations on Reuniting Korean Americans With Family Members in North Korea","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLV/s5599B"},"text":"Pub. L. 117–263, div. E, title LV, § 5599B","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3400"},"text":"136 Stat. 3400","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dE/tLV/s5599B"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultations with south korea","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of State, or a designee of the Secretary, should consult with officials of South Korea, as appropriate, on potential opportunities to reunite Korean American families with family members in North Korea from which such Korean American families were divided after the signing of the Korean War Armistice Agreement, including potential opportunities for video reunions for Korean Americans with such family members.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultations with korean americans","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Special Envoy on North Korean Human Rights Issues of the Department of State should regularly consult with representatives of Korean Americans who have family members in North Korea with respect to efforts to reunite families divided after the signing of the Korean War Armistice Agreement, including potential opportunities for video reunions for Korean Americans with such family members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 120 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"], and annually thereafter for three years, the Secretary of State, acting through the Special Envoy on North Korean Human Rights Issues or other appropriate designee, shall submit to the Committee on Foreign Affairs of the House of Representatives and the Committee on Foreign Relations of the Senate a report on the consultations conducted pursuant to this section during the preceding year.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
