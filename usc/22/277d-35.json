{"tag":"section","attrib":{"id":"id8eb0db07-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s277d–35"},"text":null,"children":[{"tag":"num","attrib":{"value":"277d–35"},"text":"§ 277d–35.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction, operation, and maintenance of works; property relocation, contracts; transfer of authority","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Commissioner is authorized—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8eb0db08-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s277d–35/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to construct, operate, and maintain all works provided for in the treaty and title I of this Act;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8eb0db09-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s277d–35/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enter into contracts with the owners of properties to be relocated whereby such owners undertake to perform, at the expense of the United States, any or all operations involved in such relocations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8eb0db0a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s277d–35/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to turn over the operation and maintenance of any works referred to in paragraph (1) of this section to any Federal agency, or any State, county, municipality, district, or other political subdivision within which such works may be situated, in whole or in part, upon such terms, conditions, and requirements as the Commissioner may deem appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8eb0db0b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/549/tI/s102"},"text":"Pub. L. 92–549, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-25"},"text":"Oct. 25, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1161"},"text":"86 Stat. 1161","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8eb0db0c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8eb0db0d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8eb0db0e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/549"},"text":"Pub. L. 92–549","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-25"},"text":"Oct. 25, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1161"},"text":"86 Stat. 1161","children":[],"tail":", known as the “American-Mexican Boundary Treaty Act of 1972”. Title I of this Act enacted sections 277d–34 to 277d–40 of this title and amended "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1322"},"text":"section 1322 of Title 19","children":[],"tail":", Customs Duties. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s277d–34"},"text":"section 277d–34 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
