{"tag":"section","attrib":{"id":"id8ffeb7da-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2719a"},"text":"§ 2719a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign affairs training","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ffeb7db-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ffeb7dc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Congress has recognized, including in division E of the National Defense Authorization Act for Fiscal Year 2022 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Public Law 117–81","children":[],"tail":"), that the Department is a crucial national security agency, whose employees, both Foreign Service and Civil Service, require the best possible training and professional development at every stage of their careers to prepare them to promote and defend United States national interests and the health and safety of United States citizens abroad; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffeb7dd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the new and evolving challenges of national security in the 21st century necessitate the expansion of standardized training and professional development opportunities linked to equal, accountable, and transparent promotion and leadership practices for Department and other national security agency personnel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ffeb7de-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Defined term","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “appropriate committees of Congress” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ffeb7df-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffeb7e0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffeb7e1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffeb7e2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ffeb7e3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ffeb7e4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fellowships","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director General of the Foreign Service shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ffeb7e5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" expand and establish new fellowship programs for Foreign Service and Civil Service officers that include short- and long-term opportunities at organizations, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ffeb7e6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" think tanks and nongovernmental organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ffeb7e7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Defense and other relevant Federal agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ffeb7e8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" industry entities, especially such entities related to technology, global operations, finance, and other fields directly relevant to international affairs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ffeb7e9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" schools of international relations and other relevant programs at universities throughout the United States; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffeb7ea-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", submit a report to Congress that describes how the Department could expand the Pearson Fellows Program for Foreign Service Officers and the Brookings Fellow Program for Civil Servants to provide fellows in such programs with the opportunity to undertake a follow-on assignment within the Department in an office in which fellows will gain practical knowledge of the people and processes of Congress, including offices other than the Legislative Affairs Bureau, including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ffeb7eb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the current state of congressional fellowships, including the demand for fellowships, support for applicants to pursue and perform such fellowships, and the value the fellowships provide to both the career of the officer and to the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ffeb7ec-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the options for making congressional fellowships for both the Foreign Service and the Civil Service more career-enhancing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ffeb7ed-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of Visitors of the Foreign Service Institute","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ffeb7ee-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to establish a Board of Visitors of the Foreign Service Institute (referred to in this subsection as the “Board”). It is the sense of Congress that the Board should be established not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffeb7ef-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board authorized by this subsection shall be comprised of 12 members, who shall be appointed by the Secretary and shall provide the Secretary with independent advice and recommendations regarding organizational management, strategic planning, resource management, curriculum development, and other matters of interest to the Foreign Service Institute, including regular observations about how well the Department is integrating training and professional development into the work of the Bureau for Global Talent Management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffeb7f0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ffeb7f1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Members of the Board shall be appointed from among individuals who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id8ffeb7f2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/e/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are not officers or employees of the Federal Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8ffeb7f3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/e/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are eminent authorities in the fields of diplomacy, national security, management, leadership, economics, trade, technology, or advanced international relations education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ffeb7f4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outside expertise","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id8ffeb7f5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/e/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not fewer than 6 members of the Board shall have a minimum of 10 years of relevant expertise outside the field of diplomacy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8ffeb7f6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/e/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prior senior service at the Department","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 6 members of the Board may be persons who previously served in the Senior Foreign Service or the Senior Executive Service at the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffeb7f7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each member of the Board shall be appointed for a term of 3 years, except that of the members first appointed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ffeb7f8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 4 members shall be appointed for a term of 3 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ffeb7f9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 4 members shall be appointed for a term of 2 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ffeb7fa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/e/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 4 members shall be appointed for a term of 1 year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffeb7fb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson; Vice Chairperson","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ffeb7fc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/e/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chairperson and Vice Chairperson of the Board shall be approved by the Secretary of State based upon a recommendation from the members of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ffeb7fd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/e/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chairperson and Vice Chairperson shall serve at the discretion of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffeb7fe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall meet—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ffeb7ff-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/e/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the call of the Director of the Foreign Service Institute and the Chairperson; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ffeb800-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/e/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not fewer than 2 times per year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffeb801-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/e/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member of the Board shall serve without compensation, except that a member of the Board shall be allowed travel expenses, including per diem in lieu of subsistence, at rates authorized for employees of agencies under subchapter I of chapter 57 of title 5, while away from their homes or regular places of business in the performance of service for the Board. Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1342"},"text":"section 1342 of title 31","children":[],"tail":", the Secretary may accept the voluntary and uncompensated service of members of the Board."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffeb802-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/e/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of Federal Advisory Committee Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal Advisory Committee Act (5 U.S.C. App.) ","children":[{"tag":"ref","attrib":{"idref":"fn002206"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002206"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" shall apply to the Board established under this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ffeb803-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Provost of the Foreign Service Institute","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ffeb804-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Foreign Service Institute the position of Provost.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffeb805-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment; reporting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Provost shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ffeb806-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be appointed by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ffeb807-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report to the Director of the Foreign Service Institute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffeb808-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Provost, who should be a member of the Senior Executive Service, shall have—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ffeb809-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" experience in the field of diplomacy, national security, education, management, leadership, economics, history, trade, adult education, or technology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ffeb80a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significant experience outside the Department, whether in other national security agencies or in the private sector, and preferably in positions of authority in educational institutions or the field of professional development and mid-career training with oversight for the evaluation of academic programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffeb80b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Provost shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ffeb80c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" oversee, review, evaluate, and coordinate the academic curriculum for all courses taught and administered by the Foreign Service Institute; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ffeb80d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate the development of an evaluation system to ascertain the utility of the information and skills imparted by each such course, such that, to the extent practicable, performance assessments can be included in the personnel records maintained by the Bureau of Global Talent Management and utilized in Foreign Service Selection Boards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffeb80e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Provost shall receive a salary commensurate with the rank and experience of a member of the Senior Executive Service, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ffeb80f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other Agency responsibilities and opportunities for congressional staff","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ffeb810-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"National security agencies other than the Department should be afforded the ability to increase the enrollment of their personnel in courses at the Foreign Service Institute and other training and professional development facilities of the Department to promote a whole-of-government approach to mitigating national security challenges.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffeb811-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional staff","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", the Secretary shall submit a report to the appropriate committees of Congress that describes—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ffeb812-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the training and professional development opportunities at the Foreign Service Institute and other Department facilities available to congressional staff;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ffeb813-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the budget impacts of offering such opportunities to congressional staff; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ffeb814-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" potential course offerings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ffeb815-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategy for adapting training requirements for modern diplomatic needs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ffeb816-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", the Secretary shall develop and submit to the appropriate committees of Congress a strategy for adapting and evolving training requirements to better meet the Department’s current and future needs for 21st century diplomacy."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffeb817-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The strategy required under paragraph (1) shall include the following elements:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ffeb818-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Integrating training requirements into the Department’s promotion policies, including establishing educational and professional development standards for training and attainment to be used as a part of tenure and promotion guidelines.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ffeb819-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Addressing multiple existing and emerging national security challenges, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id8ffeb81a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/h/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" democratic backsliding and authoritarianism;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8ffeb81b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/h/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" countering, and assisting United States allies to address, state-sponsored disinformation, including through the Global Engagement Center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8ffeb81c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/h/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cyber threats;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8ffeb81d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/h/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggression and malign influence of Russia, Cuba, Iran, North Korea, the Maduro Regime, and the Chinese Communist Party’s multi-faceted and comprehensive challenge to the rules-based order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8ffeb81e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/h/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the implications of climate change for United States diplomacy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8ffeb81f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/h/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nuclear threats.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ffeb820-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/h/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An examination of the likely advantages and disadvantages of establishing residential training for the A–100 orientation course administered by the Foreign Service Institute and evaluating the feasibility of residential training for other long-term training opportunities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ffeb821-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/h/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An examination of the likely advantages and disadvantages of establishing a press freedom curriculum for the National Foreign Affairs Training Center that enables Foreign Service officers to better understand issues of press freedom and the tools that are available to help protect journalists and promote freedom of the press norms, which may include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id8ffeb822-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/h/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the historic and current issues facing press freedom, including countries of specific concern;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8ffeb823-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/h/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department’s role in promoting press freedom as an American value, a human rights issue, and a national security imperative;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8ffeb824-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/h/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ways to incorporate press freedom promotion into other aspects of diplomacy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8ffeb825-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/h/2/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" existing tools to assist journalists in distress and methods for engaging foreign governments and institutions on behalf of individuals engaged in journalistic activity who are at risk of harm.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ffeb826-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/h/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The expansion of external courses offered by the Foreign Service Institute at academic institutions or professional associations on specific topics, including in-person and virtual courses on monitoring and evaluation, audience analysis, and the use of emerging technologies in diplomacy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffeb827-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utilization of existing resources","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In examining the advantages and disadvantages of establishing a residential training program pursuant to paragraph (2)(C), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ffeb828-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/h/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborate with other national security departments and agencies that employ residential training for their orientation courses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ffeb829-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/h/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider using the Department’s Foreign Affairs Security Training Center in Blackstone, Virginia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ffeb82a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report and briefing requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ffeb82b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", the Secretary shall submit a report to the appropriate committees of Congress that includes—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ffeb82c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/i/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a strategy for broadening and deepening professional development and training at the Department, including assessing current and future needs for 21st century diplomacy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ffeb82d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/i/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the process used and resources needed to implement the strategy referred to in subparagraph (A) throughout the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ffeb82e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/i/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results and impact of the strategy on the workforce of the Department, particularly the relationship between professional development and training and promotions for Department personnel, and the measurement and evaluation methods used to evaluate such results.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffeb82f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Briefing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after the date on which the Secretary submits the report required under paragraph (1), and annually thereafter for 2 years, the Secretary shall provide to the appropriate committees of Congress a briefing on the information required to be included in the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ffeb830-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign language maintenance incentive program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ffeb831-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to establish and implement an incentive program, with a similar structure as the Foreign Language Proficiency Bonus offered by the Department of Defense, to encourage members of the Foreign Service who possess language proficiency in any of the languages that qualify for additional incentive pay, as determined by the Secretary, to maintain critical foreign language skills.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffeb832-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719a/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", the Secretary shall submit a report to the appropriate committees of Congress that includes a detailed plan for implementing the program authorized under paragraph (1), including anticipated resource requirements to carry out such program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ffeb833-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dI/tXCII/s9205"},"text":"Pub. L. 117–263, div. I, title XCII, § 9205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3865"},"text":"136 Stat. 3865","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ffeb834-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ffeb835-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8ffeb836-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","childre