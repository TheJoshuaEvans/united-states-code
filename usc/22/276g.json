{"tag":"section","attrib":{"id":"id8eac1fe7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276g"},"text":null,"children":[{"tag":"num","attrib":{"value":"276g"},"text":"§ 276g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Auditing of accounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The certificate of the Chairman of the House delegation or the Senate delegation of the Canada-United States Interparliamentary group shall hereafter be final and conclusive upon the accounting officers in the auditing of the accounts of the United States group of the Canada-United States Interparliamentary group.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8eac1fe8-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/42/s4"},"text":"Pub. L. 86–42, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-06-11"},"text":"June 11, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/73"},"text":"73 Stat. 73","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
