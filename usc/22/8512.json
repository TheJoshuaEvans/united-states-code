{"tag":"section","attrib":{"id":"id91002293-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8512"},"text":null,"children":[{"tag":"num","attrib":{"value":"8512"},"text":"§ 8512.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Economic sanctions relating to Iran","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id91002294-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8512/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding section 101 of the Iran Freedom Support Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/293"},"text":"Public Law 109–293","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/120/1344"},"text":"120 Stat. 1344","children":[],"tail":"), and in addition to any other sanction in effect, beginning on the date that is 90 days after "},{"tag":"date","attrib":{"date":"2010-07-01"},"text":"July 1, 2010","children":[],"tail":", the economic sanctions described in subsection (b) shall apply with respect to Iran."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91002295-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8512/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanctions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The sanctions described in this subsection are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91002296-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8512/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on imports","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91002297-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8512/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), no good or service of Iranian origin may be imported directly or indirectly into the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91002298-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8512/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The exceptions provided for in section 203(b) of the International Emergency Economic Powers Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1702/b"},"text":"50 U.S.C. 1702(b)","children":[],"tail":"), including the exception for information and informational materials, shall apply to the prohibition in subparagraph (A) of this paragraph to the same extent that such exceptions apply to the authority provided under section 203(a) of that Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91002299-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8512/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on exports","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9100229a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8512/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), no good, service, or technology of United States origin may be exported to Iran from the United States or by a United States person, wherever located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9100229b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8512/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9100229c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8512/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personal communications; articles to relieve human suffering; information and informational materials; transactions incident to travel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The exceptions provided for in section 203(b) of the International Emergency Economic Powers Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1702/b"},"text":"50 U.S.C. 1702(b)","children":[],"tail":"), including the exception for information and informational materials, shall apply to the prohibition in subparagraph (A) of this paragraph to the same extent that such exceptions apply to the authority provided under section 203(a) of that Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9100229d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8512/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Food; medicine; humanitarian assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The prohibition in subparagraph (A) shall not apply to the exportation of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id9100229e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8512/b/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agricultural commodities, food, medicine, or medical devices; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id9100229f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8512/b/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" articles exported to Iran to provide humanitarian assistance to the people of Iran.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id910022a0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8512/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Internet communications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The prohibition in subparagraph (A) shall not apply to the exportation of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id910022a1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8512/b/2/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" services incident to the exchange of personal communications over the Internet or software necessary to enable such services, as provided for in section 560.540 of title 31, Code of Federal Regulations (or any corresponding similar regulation or ruling);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id910022a2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8512/b/2/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hardware necessary to enable such services; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id910022a3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8512/b/2/B/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hardware, software, or technology necessary for access to the Internet.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id910022a4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8512/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goods, services, or technologies necessary to ensure the safe operation of commercial aircraft","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The prohibition in subparagraph (A) shall not apply to the exportation of goods, services, or technologies necessary to ensure the safe operation of commercial aircraft produced in the United States or commercial aircraft into which aircraft components produced in the United States are incorporated, if the exportation of such goods, services, or technologies is approved by the Secretary of the Treasury, in consultation with the Secretary of Commerce, pursuant to regulations issued by the Secretary of the Treasury regarding the exportation of such goods, services, or technologies, if appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id910022a5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8512/b/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goods, services, or technologies exported to support international organizations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The prohibition in subparagraph (A) shall not apply to the exportation of goods, services, or technologies that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id910022a6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8512/b/2/B/v/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are provided to the International Atomic Energy Agency and are necessary to support activities of that Agency in Iran; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id910022a7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8512/b/2/B/v/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are necessary to support activities, including the activities of nongovernmental organizations, relating to promoting democracy in Iran.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id910022a8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8512/b/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exports in the national interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The prohibition in subparagraph (A) shall not apply to the exportation of goods, services, or technologies if the President determines the exportation of such goods, services, or technologies to be in the national interest of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910022a9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8512/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Freezing assets","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id910022aa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8512/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"At such time as the President determines that a person in Iran, including an Iranian diplomat or representative of another government or military or quasi-governmental institution of Iran (including Iran’s Revolutionary Guard Corps and its affiliates), satisfies the criteria for designation with respect to the imposition of sanctions under the authority of the International Emergency Economic Powers Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":" et seq.), the President shall take such action as may be necessary to freeze, as soon as possible—"}],"tail":null},{"tag":"clause","attrib":{"id":"id910022ab-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8512/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the funds and other assets belonging to that person; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id910022ac-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8512/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any funds or other assets that person transfers, on or after the date on which the President determines the person satisfies such criteria, to any family member or associate acting for or on behalf of the person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910022ad-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8512/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to the Office of Foreign Assets Control","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The action described in subparagraph (A) includes requiring any United States financial institution that holds funds or assets of a person described in that subparagraph or funds or assets that person transfers to a family member or associate described in that subparagraph to report promptly to the Office of Foreign Assets Control information regarding such funds and assets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910022ae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8512/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 14 days after a decision is made to freeze the funds or assets of any person under subparagraph (A), the President shall report the name of the person to the appropriate congressional committees. Such a report may contain a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910022af-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8512/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall release assets or funds frozen under subparagraph (A) if the person to which the assets or funds belong or the person that transfers the assets or funds as described in subparagraph (A)(ii) (as the case may be) no longer satisfies the criteria for designation with respect to the imposition of sanctions under the authority of the International Emergency Economic Powers Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910022b0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8512/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States financial institution defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this paragraph, the term “United States financial institution” means a financial institution (as defined in section 14 of the Iran Sanctions Act of 1996 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/172"},"text":"Public Law 104–172","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":" note)) that is a United States person."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id910022b1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8512/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The penalties provided for in subsections (b) and (c) of section 206 of the International Emergency Economic Powers Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1705"},"text":"50 U.S.C. 1705","children":[],"tail":") shall apply to a person that violates, attempts to violate, conspires to violate, or causes a violation of this section or regulations prescribed under this section to the same extent that such penalties apply to a person that commits an unlawful act described in section 206(a) of that Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id910022b2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8512/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulatory authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id910022b3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8512/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall prescribe regulations to carry out this section, which may include regulatory exceptions to the sanctions described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910022b4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8512/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of certain regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No exception to the prohibition under subsection (b)(1) may be made for the commercial importation of an Iranian origin good described in section 560.534(a) of title 31, Code of Federal Regulations (as in effect on the day before ","children":[{"tag":"date","attrib":{"date":"2010-07-01"},"text":"July 1, 2010","children":[],"tail":"), unless the President—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id910022b5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8512/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribes a regulation providing for such an exception on or after ","children":[{"tag":"date","attrib":{"date":"2010-07-01"},"text":"July 1, 2010","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910022b6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8512/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submits to the appropriate congressional committees—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id910022b7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8512/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification in writing that the exception is in the national interest of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id910022b8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8512/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a report describing the reasons for the exception.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id910022b9-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/195/tI/s103"},"text":"Pub. L. 111–195, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-01"},"text":"July 1, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1328"},"text":"124 Stat. 1328","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id910022ba-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id910022bb-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8551/a"},"text":"section 8551(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id910022bc-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id910022bd-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 101 of the Iran Freedom Support Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/293/s101"},"text":"section 101 of Pub. L. 109–293","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"section 1701 of Title 50","children":[],"tail":", War and National Defense."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The International Emergency Economic Powers Act, referred to in subsec. (b)(3)(A), (D), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/223"},"text":"Pub. L. 95–223","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-12-28"},"text":"Dec. 28, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1626"},"text":"91 Stat. 1626","children":[],"tail":", which is classified generally to chapter 35