{"tag":"section","attrib":{"id":"id8fbe548b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431h"},"text":null,"children":[{"tag":"num","attrib":{"value":"2431h"},"text":"§ 2431h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservation Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fbe548c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each beneficiary country that enters into a Conservation Agreement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2431g"},"text":"section 2431g of this title","children":[],"tail":" shall be required to establish a Conservation Fund to receive payments of interest and principal on new obligations undertaken by the beneficiary country under this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fc09d7d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements relating to operation of Fund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following terms and conditions shall apply to the Fund in the same manner as such terms as ","children":[{"tag":"ref","attrib":{"idref":"fn002164"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002164"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “and”."}],"tail":" conditions apply to an Enterprise for the Americas Fund under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2430f"},"text":"section 2430f of this title","children":[],"tail":":"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fc09d7e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431h/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provision relating to deposits under subsection (b) of such section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fc09d7f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431h/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provision relating to investments under subsection (c) of such section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fc09d80-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431h/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provision relating to disbursements under subsection (d) of such section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fc09d81-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. V, § 810, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/214/s1"},"text":"Pub. L. 105–214, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-29"},"text":"July 29, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/892"},"text":"112 Stat. 892","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/323/s3/c"},"text":"Pub. L. 108–323, § 3(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-06"},"text":"Oct. 6, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1219"},"text":"118 Stat. 1219","children":[],"tail":"; 