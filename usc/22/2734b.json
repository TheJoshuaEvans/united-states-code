{"tag":"section","attrib":{"id":"id90037241-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2734b"},"text":"§ 2734b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on diversity recruitment, employment, retention, and promotion","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90037242-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary should provide oversight to the employment, retention, and promotion of traditionally underrepresented minority groups.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90037243-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional recruitment and outreach required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Department should conduct recruitment activities that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90037244-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and implement effective mechanisms to ensure that the Department is able effectively to recruit and retain highly qualified candidates from a wide diversity of institutions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90037245-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve and expand recruitment and outreach programs at minority-serving institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90037246-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":", and quadrennially thereafter, the Secretary shall submit to Congress a comprehensive report that describes the efforts, consistent with existing law, including procedures, effects, and results of the Department since the period covered by the prior such report, to promote equal opportunity and inclusion for all American employees in direct hire and personal service contractors status, particularly employees of the Foreign Service, including equal opportunity for all traditionally underrepresented minority groups."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90037247-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/323/tIV/s410"},"text":"Pub. L. 114–323, title IV, § 410","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1931"},"text":"130 Stat. 1931","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90037248-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90037249-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id9003724a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “Secretary”, “Department”, and “Foreign Service” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/323/s2"},"text":"section 2 of Pub. L. 114–323","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
