{"tag":"section","attrib":{"id":"id9073736f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4302"},"text":null,"children":[{"tag":"num","attrib":{"value":"4302"},"text":"§ 4302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90737370-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90737371-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4302/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “benefit” (with respect to a foreign mission) means any acquisition, or authorization for an acquisition, in the United States by or for a foreign mission, including the acquisition of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90737372-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4302/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" real property by purchase, lease, exchange, construction, or otherwise,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90737373-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4302/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public services, including services relating to customs, importation, and utilities, and the processing of applications or requests relating to public services,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90737374-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4302/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supplies, maintenance, and transportation,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90737375-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4302/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" locally engaged staff on a temporary or regular basis,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90737376-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4302/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" travel and related services,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90737377-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4302/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protective services, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90737378-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4302/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financial and currency exchange services,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"and includes such other benefits as the Secretary may designate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90737379-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4302/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “chancery” means the principal offices of a foreign mission used for diplomatic or related purposes, and annexes to such offices (including ancillary offices and support facilities), and includes the site and any building on such site which is used for such purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9073737a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4302/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “foreign mission” means any mission to or agency or entity in the United States which is involved in the diplomatic, consular, or other activities of, or which is substantially owned or effectively controlled by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9073737b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4302/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a foreign government, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9073737c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4302/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an organization (other than an international organization, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4309/b"},"text":"section 4309(b) of this title","children":[],"tail":") representing a territory or political entity which has been granted diplomatic or other official privileges and immunities under the laws of the United States or which engages in some aspect of the conduct of the international affairs of such territory or political entity,"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"including any real property of such a mission and including the personnel of such a mission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9073737d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4302/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “real property” includes any right, title, or interest in or to, or the beneficial use of, any real property in the United States, including any office or other building;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9073737e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4302/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Secretary” means the Secretary of State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9073737f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4302/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “sending State” means the foreign government, territory, or political entity represented by a foreign mission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90737380-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4302/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “United States” means, when used in a geographic sense, the several States, the District of Columbia, the Commonwealth of Puerto Rico, and the territories and possessions of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90737381-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Determinations with respect to the meaning and applicability of the terms used in subsection (a) shall be committed to the discretion of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90737382-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch841"},"text":"Aug. 1, 1956, ch. 841","children":[],"tail":", title II, § 202, as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/241/tII/s202/b"},"text":"Pub. L. 97–241, title II, § 202(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-08-24"},"text":"Aug. 24, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/283"},"text":"96 Stat. 283","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/93/tI/s127/b"},"text":"Pub. L. 99–93, title I, § 127(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-16"},"text":"Aug. 16, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/418"},"text":"99 Stat. 418","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/569/tVII/s701"},"text":"Pub. L. 99–569, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3204"},"text":"100 Stat. 3204","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/204/tI/s153/e"},"text":"Pub. L. 100–204, title I, § 153(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1353"},"text":"101 Stat. 1353","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s162"},"text":"Pub. L. 103–236, title I, § 162","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(1), "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/409"},"text":"108 Stat. 409","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90737383-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90737384-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90737385-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a), was in the original “this title”, meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch841"},"text":"act Aug. 1, 1956, ch. 841","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1982-08-24"},"text":"Aug. 24, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/97/241/tII/s202/b"},"text":"Pub. L. 97–241, title II, § 202(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/283"},"text":"96 Stat. 283","children":[],"tail":", known as the Foreign Missions Act, which is classified principally to this chapter. For complete classification of title II to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4301"},"text":"section 4301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90737386-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(3) to (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":" struck out par. (3) and redesignated former pars. (4) to (8) as (3) to (7), respectively. Prior to amendment, par. (3) read as follows: “ ‘Director’ means the Director of the Office of Foreign Missions established pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4303/a"},"text":"section 4303(a) of this title","children":[],"tail":";”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (a)(1)(G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/204"},"text":"Pub. L. 100–204","children":[],"tail":" added subpar. (G)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/569"},"text":"Pub. L. 99–569","children":[],"tail":" amended par. (4) generally, substituting “which is involved in the diplomatic, consular, or other activities of, or which is substantially owned or effectively controlled by” for “involving diplomatic, consular, or other governmental activities of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/93"},"text":"Pub. L. 99–93","children":[],"tail":" substituted “mission to or agency in” for “official mission to” in introductory provisions, and inserted “or which engages in some aspect of the conduct of the international affairs of such territory or political entity” before the comma at end of subpar. (B)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90737387-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id90737388-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":" applicable with respect to officials, offices, and bureaus of Department of State when executive orders, regulations, or departmental directives implementing the amendments by sections 161 and 162 of "},{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":" become effective, or 90 days after "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", whichever comes earlier, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/s161/b"},"text":"section 161(b) of Pub. L. 103–236","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651a"},"text":"section 2651a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id9075e389-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1982-10-01"},"text":"Oct. 1, 1982","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/241/s204"},"text":"section 204 of Pub. L. 97–241","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4301"},"text":"section 4301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
