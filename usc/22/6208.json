{"tag":"section","attrib":{"id":"id90af1c3d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6208"},"text":null,"children":[{"tag":"num","attrib":{"value":"6208"},"text":"§ 6208.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Radio Free Asia","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90af1c3e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6208/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90af1c3f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6208/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Grants authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6204"},"text":"section 6204 of this title","children":[],"tail":" shall be available to make annual grants for the purpose of carrying out radio broadcasting to Asia."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90af1c40-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6208/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such broadcasting service shall be referred to as “Radio Free Asia”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90af1c41-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6208/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Radio Free Asia shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90af1c42-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6208/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide accurate and timely information, news, and commentary about events in Asia and elsewhere; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90af1c43-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6208/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a forum for a variety of opinions and voices from within Asian nations whose people do not fully enjoy freedom of expression.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90af1c44-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6208/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant agreement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any grant agreement or grants under this section shall be subject to the following limitations and restrictions:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90af1c45-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6208/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Agency may not make any grant to Radio Free Asia unless the headquarters of Radio Free Asia and its senior administrative and managerial staff are in a location which ensures economy, operational effectiveness, and accountability to the Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90af1c46-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6208/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any grant agreement under this section shall require that any contract entered into by Radio Free Asia shall specify that all obligations are assumed by Radio Free Asia and not by the United States Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90af1c47-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6208/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any grant agreement shall require that any lease agreements entered into by Radio Free Asia shall be, to the maximum extent possible, assignable to the United States Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90af1c48-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6208/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Grants made for the operating costs of Radio Free Asia may not exceed $30,000,000 in each of the fiscal years 2000 and 2001.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90af1c49-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6208/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Grants awarded under this section shall be made pursuant to a grant agreement which requires that grant funds be used only for activities consistent with this section, and that failure to comply with such requirements shall permit the grant to be terminated without fiscal obligation to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90af1c4a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6208/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on administrative and managerial costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of the Congress that administrative and managerial costs for operation of Radio Free Asia should be kept to a minimum and, to the maximum extent feasible, should not exceed the costs that would have been incurred if Radio Free Asia had been operated as a Federal entity rather than as a grantee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90af1c4b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6208/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment of effectiveness of Radio Free Asia","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 3 years after the date on which initial funding is provided for the purpose of operating Radio Free Asia, the Agency shall submit to the appropriate congressional committees a report on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90af1c4c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6208/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether Radio Free Asia is technically sound and cost-effective,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90af1c4d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6208/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether Radio Free Asia consistently meets the standards for quality and objectivity established by this chapter,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90af1c4e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6208/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether Radio Free Asia is received by a sufficient audience to warrant its continuation,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90af1c4f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6208/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which such broadcasting is already being received by the target audience from other credible sources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90af1c50-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6208/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the interests of the United States are being served by maintaining broadcasting of Radio Free Asia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90af1c51-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6208/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification and consultation regarding displacement of Voice of America broadcasting","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90af1c52-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6208/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Agency shall notify the appropriate congressional committees before—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90af1c53-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6208/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entering into any agreements for the utilization of Voice of America transmitters, equipment, or other resources that will significantly reduce the broadcasting activities of the Voice of America in Asia or any other region in order to accommodate the broadcasting activities of Radio Free Asia; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90af1c54-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6208/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entering into any agreements in regard to the utilization of Radio Free Asia transmitters, equipment, or other resources that will significantly reduce the broadcasting activities of Radio Free Asia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90af1c55-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6208/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Executive Officer of the Agency shall consult with such committees on the impact of any such reduction in Voice of America broadcasting activities or Radio Free Asia broadcasting activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90b18d56-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6208/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative grantee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Chief Executive Officer determines at any time that Radio Free Asia is not carrying out the functions described in this section in an effective and economical manner, the Agency may award the grant to carry out such functions to another entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90b18d57-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6208/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Not a Federal agency or instrumentality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter may be construed to make Radio Free Asia a Federal agency or instrumentality.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90b18d58-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tIII/s309"},"text":"Pub. L. 103–236, title III, § 309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/439"},"text":"108 Stat. 439","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/415/s1/s/2"},"text":"Pub. L. 103–415, § 1(s)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4302"},"text":"108 Stat. 4302","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/7/dA/tV/s501"},"text":"Pub. L. 106–113, div. B, § 1000(a)(7) [div. A, title V, § 501]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–450; "},{"tag":"ref","attrib":{"href":"/us/pl/110/321/s4"},"text":"Pub. L. 110–321, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-09-19"},"text":"Sept. 19, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3535"},"text":"122 Stat. 3535","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/71/s1"},"text":"Pub. L. 111–71, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-09"},"text":"Oct. 9, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2058"},"text":"123 Stat. 2058","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/202/s3"},"text":"Pub. L. 111–202, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-13"},"text":"July 13, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1374"},"text":"124 Stat. 1374","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/323/tVII/s703/a"},"text":"Pub. L. 114–323, title VII, § 703(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1941"},"text":"130 Stat. 1941","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXII/s1288/6"},"text":"Pub. L. 114–328, div. A, title XII, § 1288(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2553"},"text":"130 Stat. 2553","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXII/s1299Q/e/4"},"text":"Pub. L. 116–283, div. A, title XII, § 1299Q(e)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4025"},"text":"134 Stat. 4025","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90b18d59-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90b18d5a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90b18d5b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (e)(2) and (h), was in the original “this title”, meaning title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/432"},"text":"108 Stat. 432","children":[],"tail":", known as the United States International Broadcasting Act of 1994, which is classified principally to this chapter. For complete classification of title III to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6201"},"text":"section 6201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id90b18d5c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXII/s1299Q/e/4"},"text":"Pub. L. 116–283, div. A, title XII, § 1299Q(e)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4025"},"text":"134 Stat. 4025","children":[],"tail":", which amended this section, was itself amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dO/tXIII/s1301"},"text":"Pub. L. 116–260, div. O, title XIII, § 1301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2158"},"text":"134 Stat. 2158","children":[],"tail":", to make it effective 90 days after "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":". However, the amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" could not be executed because it was enacted before the provision from "},{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" that it amended."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90b18d5d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1299Q/e/4/A"},"text":"Pub. L. 116–283, § 1299Q(e)(4)(A)","children":[],"tail":", substituted “Agency” for “Board” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1299Q/e/4/B"},"text":"Pub. L. 116–283, § 1299Q(e)(4)(B)","children":[],"tail":", substituted “Agency” for “Board” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1299Q/e/4/C"},"text":"Pub. L. 116–283, § 1299Q(e)(4)(C)","children":[],"tail":", substituted “Agency” for “Board” in introductory provisions of par. (1) and in par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1299Q/e/4/D"},"text":"Pub. L. 116–283, § 1299Q(e)(4)(D)","children":[],"tail":", substituted “Agency” for “Board”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/323/s703/a/1"},"text":"Pub. L. 114–323, § 703(a)(1)","children":[],"tail":", substituted “Asia.” for “the following countries: The People’s Republic of China, Burma, Cambodia, Laos, North Korea, Tibet, and Vietnam.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/323/s703/a/2"},"text":"Pub. L. 114–323, § 703(a)(2)","children":[],"tail":", struck out “the respective countries of” before “Asia”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1288/6/A"},"text":"Pub. L. 114–328, § 1288(6)(A)","children":[],"tail":", substituted “Chief Executive Officer of the Board” for “Chairman of the Board”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (g), (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1288/6/B"},"text":"Pub. L. 114–328, § 1288(6)(B)","children":[],"tail":", (C), added subsec. (g) and redesignated former subsec. (g) as (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/202/s3/1"},"text":"Pub. L. 111–202, § 3(1)","children":[],"tail":", struck out “, and shall further specify that funds to carry out the activities of Radio Free Asia may not be available after "},{"tag":"date","attrib":{"date":"2010-09-30"},"text":"September 30, 2010","children":[],"tail":"” after “Government”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f) to (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/202/s3/2"},"text":"Pub. L. 111–202, § 3(2)","children":[],"tail":"–(4), redesignated subsecs. (g) and (h) as (f) and (g), respectively, designated first sentence of subsec. (f) as par. (1), inserted heading, inserted subpar. (A) designation before “entering into any agreements for the utilization of Voice of America”, added subpar. (B), designated second sentence of subsec. (f) as par. (2), inserted heading, inserted “or Radio Free Asia broadcasting activities” before period at end, and struck out former subsec. (f) which related to sunset provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/71"},"text":"Pub. L. 111–71","children":[],"tail":" substituted “2010” for “2009”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/321"},"text":"Pub. L. 110–321","children":[],"tail":" substituted “2010” for “2009”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/s1000/a/7/dA/tV/s501/1"},"text":"Pub. L. 106–113, § 1000(a)(7) [div. A, title V, § 501(1), (2)]","children":[],"tail":", redesignated subsec. (d) as (c) and struck out heading and text of former subsec. (c), which required the Board, through the Director of the United States Information Agency, to submit to Congress a detailed plan for the establishment and operation of Radio Free Asia prior to the awarding of a grant to carry out this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/s1000/a/7/dA/tV/s501/3/A"},"text":"Pub. L. 106–113, § 1000(a)(7) [div. A, title V, § 501(3)(A)]","children":[],"tail":", struck out “(A)” after “(1)” and struck out subpar. (B) which read as follows: “Not later than 90 days after confirmation of all members of the Board, the Board shall provide a report to Congress on the number of administrative, managerial, and technical staff of Radio Free Asia who will be located within the metropolitan area of Washington, D.C., and the number of employees whose principal place of business will be located outside the metropolitan area of Washington, D.C.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/s1000/a/7/dA/tV/s501/3/B"},"text":"Pub. L. 106–113, § 1000(a)(7) [div. A, title V, § 501(3)(B)]","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"September 30, 2009","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1999-09-30"},"text":"September 30, 1999","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/s1000/a/7/dA/tV/s501/3/C"},"text":"Pub. L. 106–113, § 1000(a)(7) [div. A, title V, § 501(3)(C)]","children":[],"tail":", substituted “$30,000,000 in each of the fiscal years 2000 and 2001” for “$22,000,000 in any fiscal year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/s1000/a/7/dA/tV/s501/3/D"},"text":"Pub. L. 106–113, § 1000(a)(7) [div. A, title V, § 501(3)(D), (E)]","children":[],"tail":", redesignated par. (6) as (5) and struck out former par. (5) which read as follows: “The total amount of grant funds made available for one-time capital costs of Radio Free Asia may not exceed $8,000,000.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/s1000/a/7/dA/tV/s501/2"},"text":"Pub. L. 106–113, § 1000(a)(7) [div. A, title V, § 501(2)]","children":[],"tail":", redesignated subsecs. (e) and (f) as (d) and (e), respectively. Former subsec. (d) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/s1000/a/7/dA/tV/s501/4"},"text":"Pub. L. 106–113, § 1000(a)(7) [div. A, title V, § 501(4)]","children":[],"tail":", reenacted subsec. heading without change and amended text generally. Prior to amendment, text read as follows: “The Board may not make any grant for the purpose of operating Radio Free Asia after "},{"tag":"date","attrib":{"date":"1998-09-30"},"text":"September 30, 1998","children":[],"tail":", unless the President of the United States determines in the President’s fiscal year 1999 budget submission that continuation of funding for Radio Free Asia for 1 additional year is in the interest of the United States.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/s1000/a/7/dA/tV/s501/2"},"text":"Pub. L. 106–113, § 1000(a)(7) [div. A, title V, § 501(2)]","children":[],"tail":", redesignated subsec. (g) as (f). Former subsec. (f) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (g) to (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/s1000/a/7/dA/tV/s501/2"},"text":"Pub. L. 106–113, § 1000(a)(7) [div. A, title V, § 501(2)]","children":[],"tail":", redesignated subsecs. (h) and (i) as (g) and (h), respectively. Former subsec. (g) redesignated (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (d)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/415"},"text":"Pub. L. 103–415","children":[],"tail":" inserted “of all members” after “confirmation”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90b18d5e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id90b18d5f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/202/s1"},"text":"Pub. L. 111–202, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-13"},"text":"July 13, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1373"},"text":"124 Stat. 1373","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/202/s1"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Congress finds the following:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Radio Free Asia (referred to in this Act [amending this section] as ‘RFA’)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was authorized under section 309 of the United States International Broadcasting Act of 1994 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6208"},"text":"22 U.S.C. 6208","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was incorporated as a private, non-profit corporation in March 1996 in the hope that its operations would soon be obviated by the global advancement of democracy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is headquartered in Washington, DC, with additional offices in Bangkok, Hong Kong, Phnom Penh, Seoul, Ankara, and Taipei.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" RFA broadcasts serve as substitutes for indigenous free media in regions lacking free media outlets.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The mission of RFA is ‘to provide accurate and timely news and information to Asian countries whose governments prohibit access to a free press’ in order to enable informed decisionmaking by the people within Asia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" RFA provides daily broadcasts of news, commentary, analysis, and cultural programming to Asian countries in several languages, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 12 hours per day in Mandarin;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 8 hours per day in 3 Tibetan dialects, Uke, Kham, and Amdo;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 4 hours per day in Korean and Burmese;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 hours per day in Cantonese, Vietnamese, Laotian, Khmer (Cambodian), and Uyghur; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1½ hours per week in Wu (local Shanghai dialect).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The governments of the countries targeted for these broadcasts have consistently denied and blocked attempts at Medium Wave and FM transmissions into their countries, forcing RFA to rely on Shortwave broadcasts and the Internet.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" RFA has provided continuous online news to its Asian audiences since 2004, although some countries—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" routinely and aggressively block RFA’s website;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor access to RFA’s website; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discourage online users by making it illegal to access RFA’s website.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Despite these attempts, RFA has successfully managed to reach its online audiences through proxies, cutting-edge software, and active republication and repostings by its audience.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"“(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" RFA also provides forums for local opinions and experiences through message boards, podcasts, web logs (blogs), cell phone-distributed newscasts, and new media, including Facebook, Flickr, Twitter, and YouTube.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"“(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Freedom House has documented that freedom of the press is in decline in nearly every region of the world, particularly in Asia, where none of the countries served by RFA have increased their freedom of the press during the past 5 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"“(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In fiscal year 2010, RFA is operating on a $37,000,000 budget, less than $400,000 of which is available to fund Internet censorship circumvention.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"“(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Congress currently provides grant funding for RFA’s operations on a fiscal year basis.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
