{"tag":"section","attrib":{"id":"id906541db-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4068"},"text":null,"children":[{"tag":"num","attrib":{"value":"4068"},"text":"§ 4068.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remarriage","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this part, any benefit payable under this part to a surviving spouse, former spouse, or surviving former spouse that would otherwise terminate or be lost if the individual remarried before 60 years of age, shall not terminate or be lost if the remarriage occurred on or after ","children":[{"tag":"date","attrib":{"date":"1984-11-08"},"text":"November 8, 1984","children":[],"tail":", and the individual was 55 years of age or over on the date of the remarriage."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id906541dc-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s828"},"text":"Pub. L. 96–465, title I, § 828","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/335/tIV/s412"},"text":"Pub. L. 99–335, title IV, § 412","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-06"},"text":"June 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/614"},"text":"100 Stat. 614","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id906541dd-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id906541de-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id906541df-2930-11f1-8918-be39dde81dc6