{"tag":"section","attrib":{"id":"id90e85543-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7632"},"text":null,"children":[{"tag":"num","attrib":{"value":"7632"},"text":"§ 7632.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations to combat tuberculosis","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90e85544-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7632/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to funds available under section 104(c) of the Foreign Assistance Act of 1961 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151b/c"},"text":"22 U.S.C. 2151b(c)","children":[],"tail":") for such purpose or under any other provision of that Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"22 U.S.C. 2151","children":[],"tail":" et seq.], there are authorized to be appropriated to the President, from amounts authorized to be appropriated under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7671"},"text":"section 7671 of this title","children":[],"tail":", a total of $4,000,000,000 for the 5-year period beginning on "},{"tag":"date","attrib":{"date":"2008-10-01"},"text":"October 1, 2008","children":[],"tail":"."},{"tag":"ref","attrib":{"idref":"fn002387"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002387"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The period probably should not appear."}],"tail":" to carry out section 104B of the Foreign Assistance Act of 1961, as added by subsection (a) ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151b–3"},"text":"22 U.S.C. 2151b–3","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90e85545-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7632/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts appropriated pursuant to the authorization of appropriations under paragraph (1) are authorized to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90e85546-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7632/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of prior year funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Unobligated balances of funds made available for fiscal year 2001, 2002, or 2003 under section 104(c)(7) of the Foreign Assistance Act of 1961 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151b/c/7"},"text":"22 U.S.C. 2151b(c)(7)","children":[],"tail":" (as in effect immediately before "},{"tag":"date","attrib":{"date":"2003-05-27"},"text":"May 27, 2003","children":[],"tail":") shall be transferred to, merged with, and made available for the same purposes as funds made available for fiscal years 2009 through 2013."},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90e85547-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/25/tIII/s302/b"},"text":"Pub. L. 108–25, title III, § 302(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-05-27"},"text":"May 27, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/736"},"text":"117 Stat. 736","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/293/tIII/s302/f"},"text":"Pub. L. 110–293, title III, § 302(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2959"},"text":"122 Stat. 2959","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90e85548-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90e85549-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90e8554a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Foreign Assistance Act of 1961, referred to in par. (1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/424"},"text":"75 Stat. 424","children":[],"tail":", which is classified principally to chapter 32 (§ 2151 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90e8554b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/293/s302/f/1"},"text":"Pub. L. 110–293, § 302(f)(1)","children":[],"tail":", substituted “a total of $4,000,000,000 for the 5-year period beginning on "},{"tag":"date","attrib":{"date":"2008-10-01"},"text":"October 1, 2008","children":[],"tail":".” for “such sums as may be necessary for each of the fiscal years 2004 through 2008”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/293/s302/f/2"},"text":"Pub. L. 110–293, § 302(f)(2)","children":[],"tail":", substituted “fiscal years 2009 through 2013.” for “fiscal years 2004 through 2008”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
