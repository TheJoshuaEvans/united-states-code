{"tag":"section","attrib":{"id":"id90bb040a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6448"},"text":null,"children":[{"tag":"num","attrib":{"value":"6448"},"text":"§ 6448.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication in Federal Register","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90bb040b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6448/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (b), the President shall cause to be published in the Federal Register the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90bb040c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6448/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinations of governments, officials, and entities of particular concern","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any designation of a country of particular concern for religious freedom under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6442/b/1"},"text":"section 6442(b)(1) of this title","children":[],"tail":", together with, when applicable and to the extent practicable, the identities of the officials or entities determined to be responsible for the violations under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6442/b/2"},"text":"section 6442(b)(2) of this title","children":[],"tail":". Any designation of a non-state actor as an entity of particular concern for religious freedom under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6442a"},"text":"section 6442a of this title","children":[],"tail":" and, if applicable and to the extent practicable, the identities of individuals determined to be responsible for violations described in subsection (f) of such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bb040d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6448/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presidential actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A description of any Presidential action under paragraphs (9) through (15) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6445/a"},"text":"section 6445(a) of this title","children":[],"tail":" (or commensurate action in substitution thereto) and the effective date of the Presidential action."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bb040e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6448/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delays in transmittal of Presidential action reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any delay in transmittal of a Presidential action report, as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6444/b"},"text":"section 6444(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bb040f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6448/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waivers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any waiver under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6447"},"text":"section 6447 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90bb0410-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6448/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited disclosure of information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President may limit publication of information under this section in the same manner and to the same extent as the President may limit the publication of findings and determinations described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2414/c"},"text":"section 2414(c) of this title","children":[],"tail":", if the President determines that the publication of information under this section—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90bb0411-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6448/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would be harmful to the national security of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bb0412-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6448/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would not further the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90bb0413-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/292/tIV/s408"},"text":"Pub. L. 105–292, title IV, § 408","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-27"},"text":"Oct. 27, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2808"},"text":"112 Stat. 2808","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/281/tIII/s305"},"text":"Pub. L. 114–281, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1436"},"text":"130 Stat. 1436","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90bb0414-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90bb0415-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90bb0416-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b)(2), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/292"},"text":"Pub. L. 105–292","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-27"},"text":"Oct. 27, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2787"},"text":"112 Stat. 2787","children":[],"tail":", known as the International Religious Freedom Act of 1998, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6401"},"text":"section 6401 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90bb0417-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/281"},"text":"Pub. L. 114–281","children":[],"tail":" inserted at end “Any designation of a non-state actor as an entity of particular concern for religious freedom under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6442a"},"text":"section 6442a of this title","children":[],"tail":" and, if applicable and to the extent practicable, the identities of individuals determined to be responsible for violations described in subsection (f) of such section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
