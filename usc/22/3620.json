{"tag":"section","attrib":{"id":"id903f1d08-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3620"},"text":null,"children":[{"tag":"num","attrib":{"value":"3620"},"text":"§ 3620.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Ambassador; independence of Commission regarding its Panama Canal responsibilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id903f1d09-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3620/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Ambassador","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States Ambassador to the Republic of Panama shall have full responsibility for the coordination of the transfer to the Republic of Panama of those functions that are to be assumed by the Republic of Panama pursuant to the Panama Canal Treaty of 1977 and related agreements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id903f1d0a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3620/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independence of Commission regarding its Panama Canal responsibilities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id903f1d0b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3620/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission shall not be subject to the direction or supervision of the United States Chief of Mission in the Republic of Panama with respect to the responsibilities of the Commission for the operation, management, or maintenance of the Panama Canal, as established in this chapter or any other Act or in the Panama Canal Treaty of 1977 and related agreements, except that the Commission shall keep the Ambassador fully and currently informed with respect to all activities and operations of the Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903f1d0c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3620/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (1) of this subsection, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3927"},"text":"section 3927 of this title","children":[],"tail":" shall apply with respect to the activities of the Commission."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id903f1d0d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3620/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements for United States to provide post-transfer administrative services for certain employee benefits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id903f1d0e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3620/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of State may enter into one or more agreements to provide for the United States to furnish administrative services relating to the benefits described in paragraph (2) after ","children":[{"tag":"date","attrib":{"date":"1999-12-31"},"text":"December 31, 1999","children":[],"tail":", and to establish appropriate procedures for providing advance funding for the services."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903f1d0f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3620/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The benefits referred to in paragraph (1) are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id903f1d10-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3620/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pension, disability, and medical benefits provided by the Panama Canal Commission pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3682"},"text":"section 3682 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id903f1d11-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3620/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Compensation for work injuries covered by chapter 81 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id903f1d12-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70/tI/s1110"},"text":"Pub. L. 96–70, title I, § 1110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-27"},"text":"Sept. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/459"},"text":"93 Stat. 459","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dC/tXXXV/s3550/d/4"},"text":"Pub. L. 105–85, div. C, title XXXV, § 3550(d)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2074"},"text":"111 Stat. 2074","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/dC/tXXXV/s3506"},"text":"Pub. L. 105–261, div. C, title XXXV, § 3506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2269"},"text":"112 Stat. 2269","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id903f1d13-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id903f1d14-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id903f1d15-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b)(1), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70"},"text":"Pub. L. 96–70","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-27"},"text":"Sept. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/452"},"text":"93 Stat. 452","children":[],"tail":", known as the Panama Canal Act of 1979, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3601"},"text":"section 3601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id903f1d16-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261"},"text":"Pub. L. 105–261","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" substituted “section 3927” for “section 2680a”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
