{"tag":"section","attrib":{"id":"id8fbbe35d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430d"},"text":null,"children":[{"tag":"num","attrib":{"value":"2430d"},"text":"§ 2430d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment of principal","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fbbe35e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Currency of payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The principal amount of each new obligation issued pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2430c/b"},"text":"section 2430c(b) of this title","children":[],"tail":" shall be repaid in United States dollars."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fbbe35f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Principal repayments of new obligations shall be deposited in the United States Government account established for principal repayments of the obligations for which those obligations were exchanged.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fbbe360-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. IV, § 705, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/549/tVI/s602/a"},"text":"Pub. L. 102–549, title VI, § 602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-1