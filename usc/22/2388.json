{"tag":"section","attrib":{"id":"id8fad8a44-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2388"},"text":null,"children":[{"tag":"num","attrib":{"value":"2388"},"text":"§ 2388.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detail of personnel to international organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever the President determines it to be consistent with and in furtherance of the purposes of this chapter, the head of any agency of the United States Government is authorized to detail, assign, or otherwise make available to any international organization any officer or employee of his agency to serve with, or as a member of, the international staff of such organization, or to render any technical, scientific, or professional advice or service to, or in cooperation with, such organization.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8fad8a45-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. III, § 628, "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/452"},"text":"75 Stat. 452","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fad8a46-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8fad8a47-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8fad8a48-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"t