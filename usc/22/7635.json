{"tag":"section","attrib":{"id":"id90e8559e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7635"},"text":null,"children":[{"tag":"num","attrib":{"value":"7635"},"text":"§ 7635.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on treatment activities by relevant executive branch agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90e8559f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7635/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 15 months after ","children":[{"tag":"date","attrib":{"date":"2003-05-27"},"text":"May 27, 2003","children":[],"tail":", the President shall submit to appropriate congressional committees a report on the programs and activities of the relevant executive branch agencies that are directed to the treatment of individuals in foreign countries infected with HIV or living with AIDS."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90e855a0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7635/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90e855a1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7635/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of the activities of relevant executive branch agencies with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90e855a2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7635/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the treatment of opportunistic infections;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e855a3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7635/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of antiretrovirals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e855a4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7635/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of research into successful treatment protocols for individuals in the developing world;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e855a5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7635/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical assistance and training of local health care workers (in countries affected by the pandemic) to administer antiretrovirals, manage side effects, and monitor patients’ viral loads and immune status;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e855a6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7635/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of strategies to promote sustainability of HIV/AIDS pharmaceuticals (including antiretrovirals) and the effects of drug resistance on HIV/AIDS patients; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e855a7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7635/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of appropriate law enforcement officials working to ensure that HIV/AIDS pharmaceutical treatment is not diminished through illegal counterfeiting and black market sales of such pharmaceuticals;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90e855a8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7635/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on existing pilot projects, including a discussion of why a given population was selected, the number of people treated, the cost of treatment, the mechanisms established to ensure that treatment is being administered effectively and safely, and plans for scaling up pilot projects (including projected timelines and required resources); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90e855a9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7635/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation of how those activities relate to efforts to prevent the transmission of the HIV infection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90e855aa-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/25/tIII/s305"},"text":"Pub. L. 108–25, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-05-27"},"text":"May 27, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/739"},"text":"117 Stat. 739","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90e855ab-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id90e855ac-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id90e855ad-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions of President under this section, see Ex. Ord. No. 12163, ","children":[{"tag":"date","attrib":{"date":"1979-09-29"},"text":"Sept. 29, 1979","children":[],"tail":", 44 F.R. 56673, as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2381"},"text":"section 2381 of this title","children":[],"tail":", and Memorandum of President of "},{"tag":"date","attrib":{"date":"2004-02-23"},"text":"Feb. 23, 2004","children":[],"tail":", 69 F.R. 9509, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7611"},"text":"section 7611 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
