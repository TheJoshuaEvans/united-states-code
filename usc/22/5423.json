{"tag":"section","attrib":{"id":"id908db1a4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5423"},"text":null,"children":[{"tag":"num","attrib":{"value":"5423"},"text":"§ 5423.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical training for private sector development in Poland and Hungary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id908db1a5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5423/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical training program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Agency for International Development shall develop and implement a program for extending basic agribusiness, commercial, entrepreneurial, financial, scientific, and technical skills to the people of Poland and Hungary to enable them to better meet their needs and develop a market economy. This program shall include management training and agricultural extension activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id908db1a6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5423/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation by Enterprise Funds and other agencies and organizations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsection (a), the Agency for International Development may utilize the Polish-American Enterprise Fund and the Hungarian-American Enterprise Fund and other appropriate Government and private agencies, programs, and organizations such as—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id908db1a7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5423/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908db1a8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5423/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Farmer-to-Farmer Program under section 1736(a)(1) and (2) of title 7;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908db1a9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5423/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the International Executive Service Corps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908db1aa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5423/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Foundation for the Development of Polish Agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908db1ab-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5423/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the World Council of Credit Unions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908db1ac-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5423/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other United States, Polish, and Hungarian private and voluntary organizations and private sector entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id908db1ad-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5423/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplicability of other provisions of law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Assistance provided pursuant to subsection (a) under the authorities of part I of the Foreign Assistance Act of 1961 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"22 U.S.C. 2151","children":[],"tail":" et seq.] may be provided notwithstanding any other provision of law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id908db1ae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5423/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of implementing this section, there are authorized to be appropriated $10,000,000 for the 3-year period beginning ","children":[{"tag":"date","attrib":{"date":"1989-10-01"},"text":"October 1, 1989","children":[],"tail":", to carry out chapter 1 of part I of the Foreign Assistance Act of 1961 ("},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"22 U.S.C. 2151","children":[],"tail":" and following; relating to development assistance), in addition to amounts otherwise available for such purposes."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id908db1af-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5423/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation with respect to Farmer-to-Farmer Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any activities carried out pursuant to this chapter through the Farmer-to-Farmer Program under section 1736(a)(1) and (2) of title 7 shall be funded with funds authorized to be appropriated by this chapter and local currencies made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s5425"},"text":"section 5425 of this title","children":[],"tail":", and shall not be funded with funds made available pursuant to section 1107 of the Food Security Act of 1985 ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1736"},"text":"7 U.S.C. 1736","children":[],"tail":" note) or a similar, subsequent provision of law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id908db1b0-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/179/tII/s203"},"text":"Pub. L. 101–179, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-28"},"text":"Nov. 28, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1309"},"text":"103 Stat. 1309","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/tIII/s3001/b/1/A"},"text":"Pub. L. 110–246, title III, § 3001(b)(1)(A)","children":[],"tail":", (2)(U), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1820"},"text":"122 Stat. 1820","children":[],"tail":", 1821.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id908db1b1-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id908db1b2-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id908db1b3-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Foreign Assistance Act of 1961, referred to in subsecs. (c) and (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/424"},"text":"75 Stat. 424","children":[],"tail":". Part I of the Foreign Assistance Act of 1961 is classified generally to subchapter I (§ 2151 et seq.) of chapter 32 of this title. Chapter 1 of part I of the Foreign Assistance Act of 1961 is classified generally to part I (§ 2151 et seq.) of subchapter I of chapter 32 of this title. For provisions deeming references to subchapter I to include parts IV (§ 2346 et seq.), VI (§ 2348 et seq.), and VIII (§ 2349aa et seq.) of subchapter II of chapter 32, see "},{"tag":"ref","attrib":{"href":"/us/pl/92/226/s202/b"},"text":"section 202(b) of Pub. L. 92–226","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2346"},"text":"section 2346 of this title","children":[],"tail":", and sections 2348c and 2349aa–5 of this title. For provisions deeming references to part I of subchapter I to include a reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2293"},"text":"section 2293 of this title","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2293/d/1"},"text":"section 2293(d)(1) of this title","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (e), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/179"},"text":"Pub. L. 101–179","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-28"},"text":"Nov. 28, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1298"},"text":"103 Stat. 1298","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s5401"},"text":"section 5401 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 1107 of the Food Security Act of 1985, referred to in subsec. (e), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1107"},"text":"section 1107 of Pub. L. 99–198","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1736"},"text":"section 1736 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id908db1b4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsecs. (b)(2), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made technical amendment to reference in original act which appears in text as reference to section 1736(a)(1) and (2) of title 7."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id908db1b5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id908db1b6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/b"},"text":"section 4(b) of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
