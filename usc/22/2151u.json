dren":[],"tail":", 1329–139."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500/s101/f/tII"},"text":"Pub. L. 99–500, § 101(f) [title II]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1783-213"},"text":"100 Stat. 1783–213","children":[],"tail":", 1783–218, and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/s101/f/tII"},"text":"Pub. L. 99–591, § 101(f) [title II]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-30"},"text":"Oct. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3341-214"},"text":"100 Stat. 3341–214","children":[],"tail":", 3341–218."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/190/s101/i/tII"},"text":"Pub. L. 99–190, § 101(i) [title II]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-19"},"text":"Dec. 19, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1291"},"text":"99 Stat. 1291","children":[],"tail":", 1296."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tI/s101/1/tII"},"text":"Pub. L. 98–473, title I, § 101(1) [title II]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1884"},"text":"98 Stat. 1884","children":[],"tail":", 1889; repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/d/tII"},"text":"Pub. L. 105–277, div. A, § 101(d) [title II]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-150"},"text":"112 Stat. 2681–150","children":[],"tail":", 2681–156."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8f57c987-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Shipment of Humanitarian Assistance","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/dD/tV/s534/f"},"text":"Pub. L. 108–199, div. D, title V, § 534(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/182"},"text":"118 Stat. 182","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/199/dD/tV/s534/f"},"text":"“During fiscal year 2004 and each fiscal year thereafter, of the amounts made available by the United States Agency for International Development to carry out the provisions of section 123(b) of the Foreign Assistance Act of 1961 [this section], funds may be made available to nongovernmental organizations for administrative costs necessary to implement a program to obtain available donated space on commercial ships for the shipment of humanitarian assistance overseas.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/dE/tV/s534/g"},"text":"Pub. L. 108–7, div. E, title V, § 534(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/194"},"text":"117 Stat. 194","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/206/tI/s602"},"text":"Pub. L. 107–206, title I, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-02"},"text":"Aug. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/859"},"text":"116 Stat. 859","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8f57c988-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study and Report Concerning Use of Private and Voluntary Organizations, Cooperatives, and Private Sector","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/83/tIII/s311"},"text":"Pub. L. 99–83, title III, § 311","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-08"},"text":"Aug. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/216"},"text":"99 Stat. 216","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/83/tIII/s311"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Study","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator of the Agency for International Development shall undertake a comprehensive study of additional ways to provide development assistance through nongovernmental organizations, including United States and indigenous private and voluntary organizations, cooperatives, the business community, and other private entities. Such study shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the percentage of development assistance allocated to governmental and nongovernmental programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of structural impediments, within both the United States and foreign governments, to additional use of nongovernmental programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the comparative economic benefits of governmental and nongovernmental programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall report the results of this study to the Congress no later than ","children":[{"tag":"date","attrib":{"date":"1986-09-30"},"text":"September 30, 1986","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8f57c989-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"African Development Foundation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/424/tI/s122"},"text":"Pub. L. 95–424, title I, § 122","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-06"},"text":"Oct. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/954"},"text":"92 Stat. 954","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/97/113/tVII/s734/a/5"},"text":"Pub. L. 97–113, title VII, § 734(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1560"},"text":"95 Stat. 1560","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/113/tVII/s734/a/5"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Congress declares that the United States should place higher priority on the formulation and implementation of policies and programs to enable the people of African nations to develop their potential, fulfill their aspirations, and enjoy better, more productive lives. In furtherance of these objectives, the Congress finds that additional support is needed for community-based self-help activities in Africa and that an African Development Foundation, organized to further the purposes set forth in section 123 of the Foreign Assistance Act of 1961 [this section], can complement current United States development programs in Africa.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" [Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/113/tVII/s734/a/5"},"text":"Pub. L. 97–113, title VII, § 734(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1560"},"text":"95 Stat. 1560","children":[],"tail":".]"}],"tail":null},{"tag":"content","attrib":{},"text":"”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[African Development Foundation changed to United States African Development Foundation by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/76/dK/tIII"},"text":"Pub. L. 113–76, div. K, title III","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-01-17"},"text":"Jan. 17, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/482"},"text":"128 Stat. 482","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s290h–1"},"text":"section 290h–1 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id8f57c98a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id8f57c98b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions of President under this section, see Ex. Ord. No. 12163, ","children":[{"tag":"date","attrib":{"date":"1979-09-29"},"text":"Sept. 29, 1979","children":[],"tail":", 44 F.R. 56673, as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2381"},"text":"section 2381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
