{"tag":"section","attrib":{"id":"id90d2d14b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7104c"},"text":null,"children":[{"tag":"num","attrib":{"value":"7104c"},"text":"§ 7104c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification to Inspectors General and cooperation with government","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The head of an executive agency making or awarding a grant, contract, or cooperative agreement shall require that the recipient of the grant, contract, or cooperative agreement—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90d2d14c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7104c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" immediately inform the Inspector General of the executive agency of any information it receives from any source that alleges credible information that the recipient; any subcontractor or subgrantee of the recipient; or any agent of the recipient or of such a subcontractor or subgrantee, has engaged in conduct described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7104/g"},"text":"section 7104(g) of this title","children":[],"tail":", as amended by section 1702 of this Act; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90d2d14d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7104c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fully cooperate with any Federal agencies responsible for audits, investigations, or corrective actions relating to trafficking in persons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90d2d14e-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tXVII/s1705"},"text":"Pub. L. 112–239, div. A, title XVII, § 1705","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2097"},"text":"126 Stat. 2097","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90d2d14f-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90d2d150-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90d2d151-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7104/g"},"text":"Section 7104(g) of this title","children":[],"tail":", as amended by section 1702 of this Act, referred to in par. (1), means "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7104/g"},"text":"section 7104(g) of this title","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/s1702"},"text":"section 1702 of Pub. L. 112–239","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id90d2d152-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the National Defense Authorization Act for Fiscal Year 2013, and not as part of the Trafficking Victims Protection Act of 2000 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
