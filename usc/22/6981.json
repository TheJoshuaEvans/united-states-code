{"tag":"section","attrib":{"id":"id90cbcc30-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6981"},"text":null,"children":[{"tag":"num","attrib":{"value":"6981"},"text":"§ 6981.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of technical assistance and rule of law programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90cbcc31-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6981/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commerce rule of law program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce, in consultation with the Secretary of State, is authorized to establish a program to conduct rule of law training and technical assistance related to commercial activities in the People’s Republic of China.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90cbcc32-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6981/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Labor rule of law program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90cbcc33-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6981/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Labor, in consultation with the Secretary of State, is authorized to establish a program to conduct rule of law training and technical assistance related to the protection of internationally recognized worker rights in the People’s Republic of China.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90cbcc34-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6981/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of amounts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out paragraph (1), the Secretary of Labor shall focus on activities including, but not limited to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90cbcc35-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6981/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing,","children":[{"tag":"ref","attrib":{"idref":"fn002359"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002359"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Comma probably should not appear."}],"tail":" laws, regulations, and other measures to implement internationally recognized worker rights;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90cbcc36-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6981/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing national mechanisms for the enforcement of national labor laws and regulations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90cbcc37-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6981/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training government officials concerned with implementation and enforcement of national labor laws and regulations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90cbcc38-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6981/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing an educational infrastructure to educate workers about their legal rights and protections under national labor laws and regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90cbcc39-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6981/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Labor may not provide assistance under the program established under this subsection to the All-China Federation of Trade Unions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90cbcc3a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6981/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Legal system and civil society rule of law program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State is authorized to establish a program to conduct rule of law training and technical assistance related to development of the legal system and civil society generally in the People’s Republic of China.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90cbcc3b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6981/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conduct of programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The programs authorized by this section may be used to conduct activities such as seminars and workshops, drafting of commercial and labor codes, legal training, publications, financing the operating costs for nongovernmental organizations working in this area, and funding the travel of individuals to the United States and to the People’s Republic of China to provide and receive training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90cbcc3c-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/286/dB/tV/s511"},"text":"Pub. L. 106–286, div. B, title V, § 511","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-10"},"text":"Oct. 10, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/905"},"text":"114 Stat. 905","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
