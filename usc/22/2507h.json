{"tag":"section","attrib":{"id":"id8fcef5bc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507h"},"text":null,"children":[{"tag":"num","attrib":{"value":"2507h"},"text":"§ 2507h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal and assessment and evaluation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fcef5bd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a volunteer requests removal from the site in which such volunteer is serving because the volunteer feels at risk of imminent bodily harm, the President shall, as expeditiously as practical after receiving such request, remove the volunteer from the site. If the President receives such a request, the President shall assess and evaluate the safety of such site and may not assign another volunteer to the site until such time as the assessment and evaluation is complete and the site has been determined to be safe. Volunteers may remain at a site during the assessment and evaluation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fcef5be-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of site as unsafe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the President determines that a site is unsafe for any remaining volunteers at the site, the President shall, as expeditiously as practical, remove all volunteers from the site.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fcef5bf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507h/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tracking and recording","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall establish a global tracking and recording system to track and record incidents of crimes against volunteers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fcef5c0-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/293/tI/s8H"},"text":"Pub. L. 87–293, title I, § 8H","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/57/s2"},"text":"Pub. L. 112–57, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-11-21"},"text":"Nov. 21, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/743"},"text":"125 Stat. 743","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
