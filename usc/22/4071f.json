{"tag":"section","attrib":{"id":"id90678c2e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4071f"},"text":null,"children":[{"tag":"num","attrib":{"value":"4071f"},"text":"§ 4071f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Government contributions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90678c2f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4071f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each agency employing any participant shall contribute to the Fund the amount computed in a manner similar to that used under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8423/a"},"text":"section 8423(a) of title 5","children":[],"tail":" pursuant to determinations of the normal cost percentage for the Foreign Service Pension System by the Secretary of State."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90678c30-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4071f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90678c31-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4071f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of State shall compute the amount of the supplemental liability of the Fund as of the close of each fiscal year beginning after ","children":[{"tag":"date","attrib":{"date":"1987-09-30"},"text":"September 30, 1987","children":[],"tail":". The amount of any such supplemental liability shall be amortized in 30 equal annual installments with interest computed at the rate used in the most recent valuation of the System."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90678c32-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4071f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At the end of each fiscal year, the Secretary of State shall notify the Secretary of the Treasury of the amount of the installment computed under this subsection for such year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90678c33-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4071f/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Before closing the accounts for a fiscal year, the Secretary of the Treasury shall credit to the Fund, as a Government contribution, out of any money in the Treasury of the United States not otherwise appropriated, the amount under paragraph (2) of this subsection for such year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90678c34-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4071f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90678c35-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4071f/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraphs (2) and (3), for purposes of any period in any year beginning after ","children":[{"tag":"date","attrib":{"date":"2013-12-31"},"text":"December 31, 2013","children":[],"tail":", the normal-cost percentage under this section shall be determined and applied as if section 402(b) of the Bipartisan Budget Act of 2013 had not been enacted."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90678c36-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4071f/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any contributions under this section in excess of the amounts which (but for paragraph (1)) would otherwise have been payable shall be applied toward reducing the unfunded liability of the Foreign Service Retirement and Disability System.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90678c37-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4071f/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After the unfunded liability of the Foreign Service Retirement and Disability System has been eliminated, as determined by the Secretary of State, Government contributions under this section shall be determined and made disregarding this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90678c38-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s857"},"text":"Pub. L. 96–465, title I, § 857","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/335/tIV/s415"},"text":"Pub. L. 99–335, title IV, § 415","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-06"},"text":"June 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/618"},"text":"100 Stat. 618","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/67/dA/tIV/s402/c"},"text":"Pub. L. 113–67, div. A, title IV, § 402(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/1185"},"text":"127 Stat. 1185","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90678c39-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90678c3a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90678c3b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 402(b) of the Bipartisan Budget Act of 2013, referred to in subsec. (c)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/67/dA/s402/b"},"text":"section 402(b) of div. A of Pub. L. 113–67","children":[],"tail":", which amended "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4071e"},"text":"section 4071e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90678c3c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/67"},"text":"Pub. L. 113–67","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
