":"May 16, 1979","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2501"},"text":"section 2501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8fccaafc-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Appointment to Civilian Career Services","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Appointment of former volunteer leaders to civilian career services, see Ex. Ord. No. 11103, ","children":[{"tag":"date","attrib":{"date":"1963-04-10"},"text":"Apr. 10, 1963","children":[],"tail":", 28 F.R. 3571, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2504"},"text":"section 2504 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
