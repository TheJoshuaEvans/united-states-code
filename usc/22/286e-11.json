{"tag":"section","attrib":{"id":"id8ec3edeb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286e–11"},"text":null,"children":[{"tag":"num","attrib":{"value":"286e–11"},"text":"§ 286e–11.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance by the Fund to any country harboring international terrorists","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Treasury shall instruct the Executive Director of the United States to the International Monetary Fund to work in opposition to any extension of financial or technical assistance by the Supplemental Financing Facility or by any other agency or facility of such Fund to any country the government of which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ec3edec-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286e–11/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permits entry into the territory of such country to any person who has committed an act of international terrorism, including any act of aircraft hijacking, or otherwise supports, encourages, or harbors such person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ec3eded-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286e–11/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fails to take appropriate measures to prevent any such person from committing any such act outside the territory of such country.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ec3edee-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/435/s6"},"text":"Pub. L. 95–435, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-10"},"text":"Oct. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1053"},"text":"92 Stat. 1053","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ec3edef-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ec3edf0-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8ec3edf1-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-07-31/ch339"},"text":"act July 31, 1945, ch. 339","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/59/512"},"text":"59 Stat. 512","children":[],"tail":", known as the Bretton Woods Agreements Act, which comprises this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
