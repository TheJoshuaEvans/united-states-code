{"tag":"section","attrib":{"id":"id9147b2bf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9656"},"text":null,"children":[{"tag":"num","attrib":{"value":"9656"},"text":"§ 9656.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notifications to be provided by the Corporation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9147b2c0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9656/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 15 days prior to the Corporation making a financial commitment associated with the provision of support under subchapter II of this title in an amount in excess of $20,000,000, the Chief Executive Officer of the Corporation shall submit to the appropriate congressional committees a report in writing that contains the information required by subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9147b2c1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9656/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The information required by this subsection includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9147b2c2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9656/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of each such financial commitment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b2c3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9656/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of the recipient or beneficiary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b2c4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9656/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the project, activity, or asset and the Corporation’s impact quotient outlining the development goal or purpose to be achieved by providing support by the Corporation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b2c5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9656/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9147b2c6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9656/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information relating to whether the Corporation has accepted a creditor status that is subordinate to that of other creditors in the project, activity, or asset; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9147b2c7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9656/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for all projects, activities, or assets that the Corporation has accepted a creditor status that is subordinate to that of other creditors the Corporation shall include a description of the substantive policy rationale required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9623/b/12"},"text":"section 9623(b)(12) of this title","children":[],"tail":" that influenced the decision to accept such a creditor status."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9147b2c8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9656/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bilateral agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Executive Officer of the Corporation shall notify the appropriate congressional committees not later than 30 days after entering into a new bilateral agreement described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9631/a"},"text":"section 9631(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9147b2c9-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dF/tIV/s1446"},"text":"Pub. L. 115–254, div. F, title IV, § 1446","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3507"},"text":"132 Stat. 3507","children":[],"tail":"; (As amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dH/tLXXXVII/s8757"},"text":"Pub. L. 119–60, div. H, title LXXXVII, § 8757","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1967"},"text":"139 Stat. 1967","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9147b2ca-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9147b2cb-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9147b2cc-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8757/1"},"text":"Pub. L. 119–60, § 8757(1)","children":[],"tail":", substituted “$20,000,000” for “$10,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8757/2/B/i"},"text":"Pub. L. 119–60, § 8757(2)(B)(i)","children":[],"tail":", inserted “the Corporation’s impact quotient outlining” after “asset and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8757/2/B/ii"},"text":"Pub. L. 119–60, § 8757(2)(B)(ii)","children":[],"tail":", (C), added par. (4)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
