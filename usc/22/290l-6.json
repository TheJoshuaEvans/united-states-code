{"tag":"section","attrib":{"id":"id8ee2e84b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290l–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"290l–6"},"text":"§ 290l–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effectiveness of Agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Agreement shall have full force and effect in the United States, its territories and possessions, and the Commonwealth of Puerto Rico, upon acceptance of membership by the United States in the Bank and the entry into force of the Agreement.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ee2e84c-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/513/tV/s562/c/8"},"text":"Pub. L. 101–513, title V, § 562(c)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2035"},"text":"104 Stat. 2035","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
