{"tag":"section","attrib":{"id":"id8f17651b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1645n"},"text":null,"children":[{"tag":"num","attrib":{"value":"1645n"},"text":"§ 1645n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of other statutory provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f17651c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1645n/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the extent they are not inconsistent with the provisions of this subchapter, the following provisions of subchapter I of this chapter shall be applicable to this subchapter; subsections (b), (c), (d), (e), and (h) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s1623"},"text":"section 1623 of this title","children":[],"tail":" and subsections (c), (d), (e), and (f) of "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s1626"},"text":"section 1626 of this title","children":[],"tail":". Any reference in such provisions to “this subchapter” shall be deemed to be a reference to those provisions and to this subchapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f17651d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1645n/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise provided in this subchapter and in those provisions of subchapter I referred to in subsection (a), the Commission shall comply with the provisions of subchapter II of chapter 5, and the provisions of chapter 7, of title 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f17651e-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-03-10/ch54"},"text":"Mar. 10, 1950, ch. 54","children":[],"tail":", title VII, § 715, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/606"},"text":"Pub. L. 96–606","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-28"},"text":"Dec. 28, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3538"},"text":"94 Stat. 3538","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
