{"tag":"section","attrib":{"id":"id90037331-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2736b"},"text":"§ 2736b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leadership engagement and accountability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90037332-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reward and recognize efforts to promote diversity and inclusion","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90037333-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall implement performance and advancement requirements that reward and recognize the efforts of individuals in senior positions and supervisors in the Department in fostering an inclusive environment and cultivating talent consistent with merit system principles, such as through participation in mentoring programs or sponsorship initiatives, recruitment events, and other similar opportunities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90037334-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outreach events","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall create opportunities for individuals in senior positions and supervisors in the Department to participate in outreach events and to discuss issues relating to diversity and inclusion with the workforce on a regular basis, including with employee resource groups.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90037335-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" External advisory committees and boards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each external advisory committee or board to which individuals in senior positions in the Department appoint members, the Secretary is strongly encouraged by Congress to ensure such external advisory committee or board is developed, reviewed, and carried out by qualified teams that represent the diversity of the organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90037336-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dE/tLIV/s5404"},"text":"Pub. L. 117–81, div. E, title LIV, § 5404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2373"},"text":"135 Stat. 2373","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90037337-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90037338-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id90037339-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “Secretary” and “Department” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s5002"},"text":"section 5002 of Pub. L. 117–81","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s263c"},"text":"section 263c of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “diversity” and “workforce” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s5401"},"text":"section 5401 of Pub. L. 117–81","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2736"},"text":"section 2736 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
