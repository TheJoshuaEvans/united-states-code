ons."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/107"},"text":"Pub. L. 104–107","children":[],"tail":" inserted “"},{"tag":"date","attrib":{"date":"1996-03-31"},"text":"March 31, 1996","children":[],"tail":",” after “"},{"tag":"date","attrib":{"date":"1995-03-31"},"text":"March 31, 1995","children":[],"tail":",” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90974f0e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id90974f0f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Extension of Reporting Time","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/115/tV/s586/b"},"text":"Pub. L. 107–115, title V, § 586(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-10"},"text":"Jan. 10, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2173"},"text":"115 Stat. 2173","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/115/tV/s586/b"},"text":"“The requirement in section 301 of the United States-Hong Kong Policy Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s5731"},"text":"22 U.S.C. 5731","children":[],"tail":"], as amended by subsection (a), that a report under that section shall be transmitted not later than "},{"tag":"date","attrib":{"date":"2001-03-31"},"text":"March 31, 2001","children":[],"tail":", shall be considered satisfied by the transmittal of such report by "},{"tag":"date","attrib":{"date":"2001-08-07"},"text":"August 7, 2001","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id90974f10-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report on Sino-British Joint Declaration on Question of Hong Kong","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/c/tV/s571"},"text":"Pub. L. 104–208, div. A, title I, § 101(c) [title V, § 571]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-121"},"text":"110 Stat. 3009–121","children":[],"tail":", 3009–167, which directed that the additional report required to be submitted during 1997 under this section include detailed information on the status of, and other developments affecting, implementation of the Sino-British Joint Declaration on the Question of Hong Kong, was from the Foreign Operations, Export Financing, and Related Programs Appropriations Act, 1997, and was not repeated in subsequent appropriations acts. Similar provisions were contained in the following prior appropriation act:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/107/tV/s576/b"},"text":"Pub. L. 104–107, title V, § 576(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-12"},"text":"Feb. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/750"},"text":"110 Stat. 750","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
