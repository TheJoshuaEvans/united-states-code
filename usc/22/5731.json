{"tag":"section","attrib":{"id":"id90974efc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5731"},"text":null,"children":[{"tag":"num","attrib":{"value":"5731"},"text":"§ 5731.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90974efd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5731/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2019-03-31"},"text":"March 31, 2019","children":[],"tail":", and annually thereafter through 2024, the Secretary of State shall submit to the appropriate congressional committees a report on conditions in Hong Kong of interest to the United States. This report shall cover (in the case of the initial report) the period since "},{"tag":"date","attrib":{"date":"1992-10-05"},"text":"October 5, 1992","children":[],"tail":", or (in the case of subsequent reports) the period since the most recent report pursuant to this section and shall describe—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90974efe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5731/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significant developments in United States relations with Hong Kong, including a description of agreements that have entered into force between the United States and Hong Kong;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90974eff-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5731/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other matters, including developments related to the change in the exercise of sovereignty over Hong Kong, affecting United States interests in Hong Kong or United States relations with Hong Kong;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90974f00-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5731/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature and extent of United States-Hong Kong cultural, education, scientific, and academic exchanges, both official and unofficial;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90974f01-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5731/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the laws of the United States with respect to which the application of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s5721/a"},"text":"section 5721(a) of this title","children":[],"tail":" has been suspended pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s5722/a"},"text":"section 5722(a) of this title","children":[],"tail":" or with respect to which such a suspension has been terminated pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s5722/d"},"text":"section 5722(d) of this title","children":[],"tail":", and the reasons for the suspension or termination, as the case may be;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90974f02-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5731/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" treaties and other international agreements with respect to which the President has made a determination described in the last sentence of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s5721/b"},"text":"section 5721(b) of this title","children":[],"tail":", and the reasons for each such determination;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90974f03-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5731/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significant problems in cooperation between Hong Kong and the United States in the area of export controls;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90974f04-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5731/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of democratic institutions in Hong Kong; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90974f05-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5731/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature and extent of Hong Kong’s participation in multilateral forums.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90974f06-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5731/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report required by subsection (a) shall be submitted in unclassified form and shall be published on a publicly available website of the Department of State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90974f07-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5731/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90974f08-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5731/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations and the Committee on Armed Services of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90974f09-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5731/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs and the Committee on Armed Services of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90974f0a-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/383/tIII/s301"},"text":"Pub. L. 102–383, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-05"},"text":"Oct. 5, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1453"},"text":"106 Stat. 1453","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/107/tV/s576/a"},"text":"Pub. L. 104–107, title V, § 576(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-12"},"text":"Feb. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/750"},"text":"110 Stat. 750","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/115/tV/s586/a"},"text":"Pub. L. 107–115, title V, § 586(a)","children":[],"tail":", "},{"tag":"date","attrib":{"d