{"tag":"section","attrib":{"id":"id90cbcc50-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7001"},"text":null,"children":[{"tag":"num","attrib":{"value":"7001"},"text":"§ 7001.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorizations of appropriations for broadcasting capital improvements and international broadcasting operations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90cbcc51-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7001/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Broadcasting capital improvements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to such sums as may otherwise be authorized to be appropriated, there are authorized to be appropriated for “Department of State and Related Agency, Related Agency, Broadcasting Board of Governors, Broadcasting Capital Improvements” $65,000,000 for the fiscal year 2003.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90cbcc52-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7001/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International broadcasting operations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90cbcc53-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7001/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to such sums as are otherwise authorized to be appropriated, there are authorized to be appropriated $34,000,000 for each of the fiscal years 2001, 2002, and 2003 for “Department of State and Related Agency, Related Agency, Broadcasting Board of Governors, International Broadcasting Operations” for the purposes under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90cbcc54-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7001/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to other authorized purposes, funds appropriated pursuant to paragraph (1) shall be used for the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90cbcc55-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7001/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To increase personnel for the program development office to enhance marketing programming in the People’s Republic of China and neighboring countries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90cbcc56-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7001/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To enable Radio Free Asia’s expansion of news research, production, call-in show capability, and web site/Internet enhancement for the People’s Republic of China and neighboring countries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90cbcc57-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7001/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" VOA enhancements, including the opening of new news bureaus in Taipei and Shanghai, enhancement of TV Mandarin, and an increase of stringer presence abroad.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90cbcc58-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/286/dB/tVII/s701"},"text":"Pub. L. 106–286, div. B, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-10"},"text":"Oct. 10, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/907"},"text":"114 Stat. 907","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/228/dA/tI/s121/b"},"text":"Pub. L. 107–228, div. A, title I, § 121(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"Sept. 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1361"},"text":"116 Stat. 1361","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90cbcc59-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90cbcc5a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90cbcc5b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/228/s121/b/1"},"text":"Pub. L. 107–228, § 121(b)(1)","children":[],"tail":", substituted “2003” for “2001”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/228/s121/b/2"},"text":"Pub. L. 107–228, § 121(b)(2)","children":[],"tail":", substituted “2001, 2002, and 2003” for “2001 and 2002”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90cbcc5c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id90cbcc5d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Broadcasting Board of Governors renamed United States Agency for Global Media pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6204/a/21"},"text":"section 6204(a)(21) of this title","children":[],"tail":". The renaming was effectuated by notice to congressional appropriations committees dated "},{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":", and became effective "},{"tag":"date","attrib":{"date":"2018-08-22"},"text":"Aug. 22, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
