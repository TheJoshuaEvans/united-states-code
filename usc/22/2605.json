{"tag":"section","attrib":{"id":"id8fdadc83-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2605"},"text":null,"children":[{"tag":"num","attrib":{"value":"2605"},"text":"§ 2605.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds and personnel; savings provision","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fdadc84-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2605/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds made available for the purposes of this chapter shall be available for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fdadc85-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2605/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compensation, allowances, and travel of personnel, including members of the Foreign Service whose services are utilized primarily for the purpose of this chapter, and without regard to the provisions of any other law, for printing and binding, and for expenditures outside the United States for the procurement of supplies and services and for other administrative and operating purposes (other than compensation of personnel) without regard to such laws and regulations governing the obligation and expenditure of Government funds as may be necessary to accomplish the purposes of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fdadc86-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2605/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employment or assignment of members of the Foreign Service serving under limited appointments for the duration of operations under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fdadc87-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2605/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exchange of funds without regard to section 3651 ","children":[{"tag":"ref","attrib":{"idref":"fn002182"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002182"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the Revised Statutes ("},{"tag":"ref","attrib":{"href":"/us/usc/t31/s543"},"text":"31 U.S.C. 543","children":[],"tail":"), and loss by exchanges;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fdadc88-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2605/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expenses authorized by the Foreign Service Act of 1980 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3901"},"text":"22 U.S.C. 3901","children":[],"tail":" et seq.], not otherwise provided for;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fdadc89-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2605/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expenses authorized by the Act of ","children":[{"tag":"date","attrib":{"date":"1956-08-01"},"text":"August 1, 1956","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/70/890-892"},"text":"70 Stat. 890–892","children":[],"tail":"), as amended;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fdadc8a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2605/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contracting for personal services abroad, and individuals employed by contract to perform such services shall not be considered to be employees of the United States for purposes of any law administered by the Office of Personnel Management, except that the Secretary of State may determine the applicability to such individuals of section 2(f) of the State Department Basic Authorities Act of 1956 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2669/f"},"text":"22 U.S.C. 2669(f)","children":[],"tail":") and of any other law administered by the Secretary concerning the employment of such individuals abroad; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fdadc8b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2605/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all other expenses determined by the President to be necessary to carry out the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fdadc8c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2605/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings provision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as may be expressly provided to the contrary in this chapter, all determinations, authorizations, regulations, orders, contracts, agreements and other actions issued, undertaken, or entered into under authority of any provision of law repealed by this chapter shall continue in full force and effect until modified, revoked, or superseded under the authority of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fdadc8d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2605/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Personnel funded pursuant to this section are authorized to provide administrative assistance to personnel assigned to the bureau charged with carrying out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fdadc8e-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/510/s5"},"text":"Pub. L. 87–510, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-06-28"},"text":"June 28, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/123"},"text":"76 Stat. 123","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/465/tII/s2206/a/10"},"text":"Pub. L. 96–465, title II, § 2206(a)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2162"},"text":"94 Stat. 2162","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/93/tI/s112/a"},"text":"Pub. L. 99–93, title I, § 112(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-16"},"text":"Aug. 16, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/410"},"text":"99 Stat. 410","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s164/b"},"text":"Pub. L. 103–236, title I, § 164(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/411"},"text":"108 Stat. 411","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/415/s1/ff"},"text":"Pub. L. 103–415, § 1(ff)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4303"},"text":"108 Stat. 4303","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fdadc8f-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8fdadc90-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8fdadc91-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/510"},"text":"Pub. L. 87–510","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-06-28"},"text":"June 28, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/121"},"text":"76 Stat. 121","children":[],"tail":", known as the Migration and Refugee Assistance Act of 1962, which enacted this chapter, amended "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1104"},"text":"section 1104 of Title 8","children":[],"tail":", Aliens and Nationality, repealed sections 1925(a), (c), (d), and 1951(c) of this title, enacted a provision set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2601"},"text":"section 2601 of this title","children":[],"tail":", and amended a provision set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1182"},"text":"section 1182 of title 8","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2601"},"text":"section 2601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3651 of the Revised Statutes (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s543"},"text":"31 U.S.C. 543","children":[],"tail":"), referred to in subsec. (a)(3), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s5/b"},"text":"Pub. L. 97–258, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1068"},"text":"96 Stat. 1068","children":[],"tail":", the first section of which enacted Title 31, Money and Finance."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Foreign Service Act of 1980, referred to in subsec. (a)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465"},"text":"Pub. L. 96–465","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2071"},"text":"94 Stat. 2071","children":[],"tail":", which is classified principally to chapter 52 (§ 3901 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3901"},"text":"section 3901 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1956-08-01"},"text":"August 1, 1956","children":[],"tail":", as amended, referred to in subsec. (a)(5), is "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch841"},"text":"act Aug. 1, 1956, ch. 841","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/890"},"text":"70 Stat. 890","children":[],"tail":", known as the State Department Basic Authorities Act of 1956. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8fdadc92-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/103/415"},"text":"Pub. L. 103–415","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (a)(6), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/93/s112/a"},"text":"Pub. L. 99–93, § 112(a)","children":[],"tail":", added par. (6) and redesignated former par. (6) as (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/s2206/a/10/A"},"text":"Pub. L. 96–465, § 2206(a)(10)(A)","children":[],"tail":", substituted “members of the Foreign Service” for “Foreign Service personnel”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/s2206/a/10/B"},"text":"Pub. L. 96–465, § 2206(a)(10)(B)","children":[],"tail":", substituted “members of the Foreign Service serving under limited appointments” for “Foreign Service Reserve officers”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/s2206/a/10/C"},"text":"Pub. L. 96–465, § 2206(a)(10)(C)","children":[],"tail":", substituted reference to the Foreign Service Act of 1980 for reference to the Foreign Service Act of 1946."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8fdadc93-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8fdadc94-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/93/tI/s112/b"},"text":"Pub. L. 99–93, title I, § 112(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-16"},"text":"Aug. 16, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/411"},"text":"99 Stat. 411","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/93/tI/s112/b"},"text":"“Authority provided by the amendment made by subsection (a) [amending this section] shall only apply with respect to funds appropriated after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1985-08-16"},"text":"Aug. 16, 1985","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8fdadc95-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465"},"text":"Pub. L. 96–465","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-02-15"},"text":"Feb. 15, 1981","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/96/465/s2403"},"text":"section 2403 of Pub. L. 96–465","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3901"},"text":"section 