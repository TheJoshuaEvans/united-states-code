{"tag":"section","attrib":{"id":"id90595b4d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4030"},"text":null,"children":[{"tag":"num","attrib":{"value":"4030"},"text":"§ 4030.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suitability reviews for Foreign Service Institute instructors","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall take reasonable steps to ensure that all instructors at the Foreign Service Institute, including direct hires and contractors, who provide language instruction are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90595b4e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4030/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to suitability reviews and background investigations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90595b4f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4030/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to periodic background checks or reinvestigations to the extent consistent with Department and Executive policy for other Department personnel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90595b50-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dF/tLXI/s6116"},"text":"Pub. L. 118–31, div. F, title LXI, § 6116","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/970"},"text":"137 Stat. 970","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90595b51-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90595b52-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id90595b53-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Department of State Authorization Act of 2023, and also as part of the National Defense Authorization Act for Fiscal Year 2024, and not as part of the Foreign Service Act of 1980 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90595b54-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id90595b55-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “Secretary” and “Department” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s6002"},"text":"section 6002 of Pub. L. 118–31","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
