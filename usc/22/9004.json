{"tag":"section","attrib":{"id":"id911a61e3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9004"},"text":null,"children":[{"tag":"num","attrib":{"value":"9004"},"text":"§ 9004.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisional remedies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id911a61e4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9004/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of courts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In furtherance of the objectives of article 7(b) and other provisions of the Convention, and subject to the provisions of subsection (b) of this section, any court exercising jurisdiction of an action brought under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9003/b"},"text":"section 9003(b) of this title","children":[],"tail":" may take or cause to be taken measures under Federal or State law, as appropriate, to protect the well-being of the child involved or to prevent the child’s further removal or concealment before the final disposition of the petition."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id911a61e5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9004/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No court exercising jurisdiction of an action brought under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9003/b"},"text":"section 9003(b) of this title","children":[],"tail":" may, under subsection (a) of this section, order a child removed from a person having physical control of the child unless the applicable requirements of State law are satisfied."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id911a61e6-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/300/s5"},"text":"Pub. L. 100–300, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-29"},"text":"Apr. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/439"},"text":"102 Stat. 439","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id911a61e7-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id911a61e8-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id911a61e9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11604"},"text":"section 11604 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
