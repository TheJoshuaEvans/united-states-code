{"tag":"section","attrib":{"id":"id8eec851d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s462"},"text":null,"children":[{"tag":"num","attrib":{"value":"462"},"text":"§ 462.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compelling foreign vessels to depart","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It shall be lawful for the President to employ such part of the land or naval forces of the United States, or of the militia thereof, as he may deem necessary to compel any foreign vessel to depart from the United States or any of its possessions in all cases in which, by the law of nations or the treaties of the United States, it ought not to remain, and to detain or prevent any foreign vessel from so departing in all cases in which, by the law of nations or the treaties of the United States, it is not entitled to depart.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8eec851e-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s15"},"text":"Mar. 4, 1909, ch. 321, § 15","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1091"},"text":"35 Stat. 1091","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1917-06-15/ch30"},"text":"June 15, 1917, ch. 30","children":[],"tail":", title V, § 10, "},{"tag":"ref","attrib":{"href":"/us/stat/40/223"},"text":"40 Stat. 223","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8eec851f-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8eec8520-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8eec8521-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s27"},"text":"section 27 of title 18","children":[],"tail":" prior to the general revision and enactment of Title 18, Crimes and Criminal Procedure, by "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645/s1"},"text":"act June 25, 1948, ch. 645, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/683"},"text":"62 Stat. 683","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1917-06-15"},"text":"June 15, 1917","children":[],"tail":", inserted provisions relating to detention of vessels."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id8eec8522-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section was derived from R.S. § 5288 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1818-04-20/ch88/s9"},"text":"act Apr. 20, 1818, ch. 88, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/3/449"},"text":"3 Stat. 449","children":[],"tail":"), which was repealed by "},{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s341"},"text":"act Mar. 4, 1909, ch. 321, § 341","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1153"},"text":"35 Stat. 1153","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
