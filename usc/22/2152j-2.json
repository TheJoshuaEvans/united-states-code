{"tag":"section","attrib":{"id":"id8f5ef576-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152j–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2152j–2"},"text":"§ 2152j–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training requirements regarding the participation of women in conflict prevention and peace building","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f5ef577-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152j–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign Service","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State, in conjunction with the Administrator of the United States Agency for International Development, shall ensure that all appropriate personnel (including special envoys, members of mediation or negotiation teams, relevant members of the civil service or Foreign Service, and contractors) responsible for or deploying to countries or regions considered to be at risk of, undergoing, or emerging from violent conflict obtain training, as appropriate, in the following areas, each of which shall include a focus on women and ensuring meaningful participation by women:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f5ef578-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152j–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Conflict prevention, mitigation, and resolution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f5ef579-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152j–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Protecting civilians from violence, exploitation, and trafficking in persons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f5ef57a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152j–2/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" International human rights law and international humanitarian law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f5ef57b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152j–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Defense","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall ensure that relevant personnel receive training, as appropriate, in the following areas:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f5ef57c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152j–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Training in conflict prevention, peace processes, mitigation, resolution, and security initiatives that specifically addresses the importance of meaningful participation by women.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f5ef57d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152j–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Gender considerations and meaningful participation by women, including training regarding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8f5ef57e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152j–2/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" international human rights law and international humanitarian law, as relevant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f5ef57f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152j–2/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protecting civilians from violence, exploitation, and trafficking in persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f5ef580-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152j–2/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Effective strategies and best practices for ensuring meaningful participation by women.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f5ef581-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/68/s6"},"text":"Pub. L. 115–68, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-10-06"},"text":"Oct. 6, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1204"},"text":"131 Stat. 1204","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f5ef582-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f5ef583-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8f5ef584-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Women, Peace, and Security Act of 2017, and not as part of the Foreign Assistance Act of 1961 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
