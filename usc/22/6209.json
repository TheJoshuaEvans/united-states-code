{"tag":"section","attrib":{"id":"id90b18d96-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6209"},"text":null,"children":[{"tag":"num","attrib":{"value":"6209"},"text":"§ 6209.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incorporation and non-Federal status of broadcasting entities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90b18d97-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6209/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Defined term","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90b18d98-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6209/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “grant” includes agreements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s6305"},"text":"section 6305 of title 31","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b18d99-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6209/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “grantee” includes recipients of an agreement described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90b18d9a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6209/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incorporation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Chief Executive Officer is authorized to incorporate grantees in accordance with the regular notification procedures of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90b18d9b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6209/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b18d9c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6209/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b18d9d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6209/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b18d9e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6209/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90b18d9f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6209/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal status","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter or in any other Act, and no action taken pursuant to this chapter or any other Act, may be construed to make a grantee incorporated pursuant to subsection (b), or any other grantee or entity provided funding by the Agency, a Federal agency or instrumentality.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90b18da0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6209/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leadership of grantee organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The chief executive officer or the equivalent official of RFE/RL Inc., Radio Free Asia, the Open Technology Fund, and the Middle East Broadcasting Networks, and any other organization that is established or authorized under this chapter, shall serve at the pleasure of, and may be named by, the Chief Executive Officer of the Agency, with the concurrence of the Grantee Board and subject to the approval of the Advisory Board pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6205"},"text":"section 6205 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90b18da1-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tIII/s310"},"text":"Pub. L. 103–236, title III, § 310","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXII/s1288/7"},"text":"Pub. L. 114–328, div. A, title XII, § 1288(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2553"},"text":"130 Stat. 2553","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXII"},"text":"Pub. L. 116–283, div. A, title XII","children":[],"tail":", §§ 1299P(c)(2), (3), 1299Q(e)(5), (f), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4020"},"text":"134 Stat. 4020","children":[],"tail":", 4025, 4026; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dI/tXCVII/s9705"},"text":"Pub. L. 117–263, div. I, title XCVII, § 9705","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3915"},"text":"136 Stat. 3915","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90b18da2-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90b18da3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90b18da4-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a), (c), and (d), was so in the original, but probably should have been a reference to “this title”, meaning title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/432"},"text":"108 Stat. 432","children":[],"tail":", known as the United States International Broadcasting Act of 1994, which is classified principally to this chapter. For complete classification of title III to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6201"},"text":"section 6201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"to