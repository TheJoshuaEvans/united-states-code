{"tag":"section","attrib":{"id":"id915ac5df-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10607"},"text":null,"children":[{"tag":"num","attrib":{"value":"10607"},"text":"§ 10607.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of support for certain governments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id915ac5e0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10607/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Foundation may not provide support for any government, or any entity owned or controlled by a government, if the Secretary has determined that such government—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id915ac5e1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10607/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has repeatedly provided support for acts of international terrorism, as determined under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id915ac5e2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10607/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4813/c/1/A/i"},"text":"section 4813(c)(1)(A)(i) of title 50","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915ac5e3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10607/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2371/a"},"text":"section 2371(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915ac5e4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10607/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2780/d"},"text":"section 2780(d) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915ac5e5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10607/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other relevant provision of law;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id915ac5e6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10607/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been identified pursuant to section 2151n(a) or 2304(a)(2) of this title or any other relevant provision of law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id915ac5e7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10607/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has failed the “control of corruption” indicator, as determined by the Millennium Challenge Corporation, within any of the preceding 3 years of the intended grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id915ac5e8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10607/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of support for sanctioned persons","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation may not engage in any dealing prohibited under United States sanctions laws or regulations, including dealings with persons on the list of specially designated persons and blocked persons maintained by the Office of Foreign Assets Control of the Department of the Treasury, except to the extent otherwise authorized by the Secretary or by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id915ac5e9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10607/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of support for activities subject to sanctions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation shall require any person receiving support to certify that such person, and any entity owned or controlled by such person, is in compliance with all United States sanctions laws and regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id915ac5ea-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dE/tLI/s5107"},"text":"Pub. L. 118–159, div. E, title LI, § 5107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2421"},"text":"138 Stat. 2421","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
