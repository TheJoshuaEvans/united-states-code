{"tag":"section","attrib":{"id":"id90f1f1f6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7902"},"text":null,"children":[{"tag":"num","attrib":{"value":"7902"},"text":"§ 7902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction of greenhouse gas intensity","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90f1f1f7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7902/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lead agency","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90f1f1f8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7902/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Department of State shall act as the lead agency for integrating into United States foreign policy the goal of reducing greenhouse gas intensity in developing countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f1f1f9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7902/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90f1f1fa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7902/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Secretary of State shall submit to the appropriate authorizing and appropriating committees of Congress an initial report, based on the most recent information available to the Secretary from reliable public sources, that identifies the 25 developing countries that are the largest greenhouse gas emitters, including for each country—"}],"tail":null},{"tag":"clause","attrib":{"id":"id90f1f1fb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7902/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the quantity and types of energy used;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90f1f1fc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7902/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the greenhouse gas intensity of the energy, manufacturing, agricultural, and transportation sectors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90f1f1fd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7902/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description ","children":[{"tag":"ref","attrib":{"idref":"fn002394"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002394"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “description of”."}],"tail":" the progress of any significant projects undertaken to reduce greenhouse gas intensity;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90f1f1fe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7902/a/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the potential for undertaking projects to reduce greenhouse gas intensity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90f1f1ff-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7902/a/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of any obstacles to the reduction of greenhouse gas intensity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90f1f200-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7902/a/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the best practices learned by the Agency for International Development from conducting previous pilot and demonstration projects to reduce greenhouse gas intensity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90f1f201-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7902/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Update","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 18 months after the date on which the initial report is submitted under subparagraph (A), the Secretary shall submit to the appropriate authorizing and appropriating committees of Congress, based on the best information available to the Secretary, an update of the information provided in the initial report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90f1f202-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7902/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90f1f203-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7902/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall use the initial report submitted under subparagraph (A) to establish baselines for the developing countries identified in the report with respect to the information provided under clauses (i) and (ii) of that subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90f1f204-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7902/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall use the annual reports prepared under subparagraph (B) and any other information available to the Secretary to track the progress of the developing countries with respect to reducing greenhouse gas intensity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90f1f205-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7902/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State, in coordination with Administrator of the United States Agency for International Development, shall (directly or through agreements with the World Bank, the International Monetary Fund, the United States International Development Finance Corporation, and other development institutions) provide assistance to developing countries specifically for projects to reduce greenhouse gas intensity, including projects to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90f1f206-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7902/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leverage, through bilateral agreements, funds for reduction of greenhouse gas intensity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f1f207-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7902/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase private investment in projects and activities to reduce greenhouse gas intensity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f1f208-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7902/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expedite the deployment of technology to reduce greenhouse gas intensity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90f1f209-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7902/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Focus","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In providing assistance under subsection (b), the Secretary of State shall focus on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90f1f20a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7902/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting the rule of law, property rights, contract protection, and economic freedom; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f1f20b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7902/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing capacity, infrastructure, and training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90f1f20c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7902/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In providing assistance under subsection (b), the Secretary of State shall give priority to projects in the 25 developing countries identified in the report submitted under subsection (a)(2)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90f1f20d-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/240/tVII/s732"},"text":"Pub. L. 101–240, title VII, § 732","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXVI/s1611"},"text":"Pub. L. 109–58, title XVI, § 1611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1113"},"text":"119 Stat. 1113","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dF/tVI/s1470/q"},"text":"Pub. L. 115–254, div. F, title VI, § 1470(q)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3518"},"text":"132 Stat. 3518","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90f1f20e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90f1f20f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90f1f210-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" substituted “United States International Development Finance Corporation” for “Overseas Private Investment Corporation” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90f1f211-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id90f1f212-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" effective at the end of the transition period, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s9681"},"text":"section 9681 of this title","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1470/w"},"text":"section 1470(w) of Pub. L. 115–254","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s905"},"text":"section 905 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id90f1f213-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2005-10-01"},"text":"Oct. 1, 2005","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/240/s739"},"text":"section 739 of Pub. L. 101–240","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7901"},"text":"section 7901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
