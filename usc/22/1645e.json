{"tag":"section","attrib":{"id":"id8f1764fe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1645e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1645e"},"text":"§ 1645e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offsets","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In determining the amount of any claim under this subchapter, the Commission shall deduct all amounts the claimant has received from any source on account of the same loss or losses for which the claim is filed.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f1764ff-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-03-10/ch54"},"text":"Mar. 10, 1950, ch. 54","children":[],"tail":", title VII, § 706, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/606"},"text":"Pub. L. 96–606","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-28"},"text":"Dec. 28, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3536"},"text":"94 Stat. 3536","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
