{"tag":"section","attrib":{"id":"id8ecb1a77-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286tt"},"text":null,"children":[{"tag":"num","attrib":{"value":"286tt"},"text":"§ 286tt.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions on use of United States funds for foreign governments; protection of American taxpayers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ecb1a78-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286tt/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Treasury shall instruct the United States Executive Director at the International Monetary Fund—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ecb1a79-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286tt/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to evaluate, prior to consideration by the Board of Executive Directors of the Fund, any proposal submitted to the Board for the Fund to make a loan to a country if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ecb1a7a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286tt/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the public debt of the country exceeds the gross domestic product of the country as of the most recent year for which such information is available; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ecb1a7b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286tt/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the country is not eligible for assistance from the International Development Association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ecb1a7c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286tt/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Opposition to loans unlikely to be repaid in full","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If any such evaluation indicates that the proposed loan is not likely to be repaid in full, the Secretary of the Treasury shall instruct the United States Executive Director at the Fund to use the voice and vote of the United States to oppose the proposal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ecb1a7d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286tt/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Within 30 days after the Board of Executive Directors of the Fund approves a proposal described in subsection (a), and annually thereafter by June 30, for the duration of any program approved under such proposals, the Secretary of the Treasury shall report in writing to the Committee on Financial Services of the House of Representatives and the Committee on Foreign Relations and the Committee on Banking, Housing, and Urban Affairs of the Senate assessing the likelihood that loans made pursuant to such proposals will be repaid in full, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ecb1a7e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286tt/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the borrowing country’s current debt status, including, to the extent possible, its maturity structure, whether it has fixed or floating rates, whether it is indexed, and by whom it is held;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ecb1a7f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286tt/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the borrowing country’s external and internal vulnerabilities that could potentially affect its ability to repay; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ecb1a80-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286tt/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the borrowing country’s debt management strategy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ecb1a81-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-07-31/ch339/s68"},"text":"July 31, 1945, ch. 339, § 68","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tXV/s1501"},"text":"Pub. L. 111–203, title XV, § 1501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2212"},"text":"124 Stat. 2212","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ecb1a82-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ecb1a83-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id8ecb1a84-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 1 day after ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s4"},"text":"section 4 of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
