{"tag":"section","attrib":{"id":"id91560ad0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10412"},"text":null,"children":[{"tag":"num","attrib":{"value":"10412"},"text":"§ 10412.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of senior official for Department of Defense activities relating to, and implementation plan for, the AUKUS partnership","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id91560ad1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10412/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of senior official","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2023-12-22"},"text":"December 22, 2023","children":[],"tail":", the Secretary of Defense shall designate a senior civilian official of the Department of Defense who shall be responsible for overseeing Department of Defense activities relating to the AUKUS partnership."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91560ad2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10412/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91560ad3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10412/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2023-12-22"},"text":"December 22, 2023","children":[],"tail":", the Secretary of Defense, in coordination with the Administrator for Nuclear Security and the Secretary of State, shall submit to the appropriate committees of Congress a report containing an implementation plan outlining Department of Defense efforts relating to the AUKUS partnership."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91560ad4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10412/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan required by paragraph (1) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91560ad5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10412/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Timelines and major anticipated milestones for the implementation of the AUKUS partnership.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91560ad6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10412/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An identification of dependencies of such milestones on defense requirements that are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id91560ad7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10412/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unrelated to the AUKUS partnership; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91560ad8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10412/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solely within the decisionmaking responsibility of Australia or the United Kingdom.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91560ad9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10412/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A consideration of the implications of the plan on the industrial base with respect to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id91560ada-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10412/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expansion of existing United States submarine construction capacity to fulfill United States, United Kingdom, and Australia requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91560adb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10412/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acceleration of the restoration of United States capabilities for producing highly enriched uranium to fuel submarine reactors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91560adc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10412/b/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stabilization of commodity markets and expanding supplies of high-grade steel, construction materials, and other resources required for improving shipyard condition and expanding throughput capacity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91560add-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10412/b/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordination and synchronization of industrial sourcing opportunities among Australia, the United Kingdom, and the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91560ade-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10412/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A description of resourcing and personnel requirements, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id91560adf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10412/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed assessment of the feasibility of hiring and retaining additional foreign disclosure officers to facilitate more rapid technology transfer to Australia and the United Kingdom; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91560ae0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10412/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of any additional requirements for Department of Defense personnel to support the transfer of defense articles to Australia and the United Kingdom.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91560ae1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10412/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A plan for improving information sharing, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id91560ae2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10412/b/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for modifications to foreign disclosure policies and processes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91560ae3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10412/b/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the promulgation of written information-sharing guidelines or policies to improve information sharing under the AUKUS partnership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91560ae4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10412/b/2/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of an information handling caveat specific to the AUKUS partnership; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91560ae5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10412/b/2/E/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reduction in use of the Not Releasable to Foreign Nations (NOFORN) information handling caveat.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91560ae6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10412/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Processes for the protection of privately held intellectual property, including patents.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91560ae7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10412/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recommended updates to other title 10 authorities or regulatory, policy, or process frameworks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91560ae8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10412/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Semiannual updates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after the date on which the plan required by subsection (b) is submitted, and semiannually thereafter not later than April 1 and October 1 each year through 2029, the senior civilian official designated under subsection (a) shall provide the congressional defense committees and the Committee on Foreign Affairs of the House of Representatives and the Committee on Foreign Relations of the Senate with a briefing on the status of all Department activities to implement the AUKUS partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id91560ae9-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXIII/s1332"},"text":"Pub. L. 118–31, div. A, title XIII, § 1332","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/505"},"text":"137 Stat. 505","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id91560aea-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id91560aeb-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id91560aec-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Congressional Defense Committees” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Congressional defense committees means the Committees on Armed Services and Appropriations of the Senate and the House of Representatives, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s3"},"text":"section 3 of Pub. L. 118–31","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
