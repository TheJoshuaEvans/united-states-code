{"tag":"section","attrib":{"id":"id8f176523-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1650"},"text":null,"children":[{"tag":"num","attrib":{"value":"1650"},"text":"§ 1650.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointments of representatives and panel members under Convention on the Settlement of Investment Disputes","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President may make such appointments of representatives and panel members as may be provided for under the convention.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f176524-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/532/s2"},"text":"Pub. L. 89–532, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-08-11"},"text":"Aug. 11, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/344"},"text":"80 Stat. 344","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f176525-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f176526-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8f176527-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The convention, referred to in text, is the Convention on the Settlement of Investment Disputes Between States and Nationals of Other States which was signed on ","children":[{"tag":"date","attrib":{"date":"1965-08-27"},"text":"Aug. 27, 1965","children":[],"tail":", approved by the Senate on "},{"tag":"date","attrib":{"date":"1966-05-16"},"text":"May 16, 1966","children":[],"tail":", and ratified by the President on "},{"tag":"date","attrib":{"date":"1966-06-01"},"text":"June 1, 1966","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f176528-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id8f176529-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/532/s1"},"text":"Pub. L. 89–532, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-08-11"},"text":"Aug. 11, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/344"},"text":"80 Stat. 344","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/89/532/s1"},"text":"“That this Act [enacting this chapter] may be cited as the ‘Convention on the Settlement of Investment Disputes Act of 1966’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
