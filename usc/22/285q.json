{"tag":"section","attrib":{"id":"id8ebf329c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285q"},"text":null,"children":[{"tag":"num","attrib":{"value":"285q"},"text":"§ 285q.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subscription to additional shares; authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ebf329d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285q/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Governor of the Bank is authorized to subscribe on behalf of the United States to thirty thousand additional shares of the capital stock of the Bank in accordance with and subject to the terms and conditions of Resolution Numbered 46 adopted by the Bank’s Board of Governors on ","children":[{"tag":"date","attrib":{"date":"1971-11-30"},"text":"November 30, 1971","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ebf329e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285q/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to pay for the increase in the United States subscription to the Bank provided for in this section, there is hereby authorized to be appropriated without fiscal year limitation $361,904,726 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ebf329f-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/369/s20"},"text":"Pub. L. 89–369, § 20","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/537"},"text":"Pub. L. 93–537","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-12-22"},"text":"Dec. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1735"},"text":"88 Stat. 1735","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
