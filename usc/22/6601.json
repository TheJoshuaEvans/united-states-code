{"tag":"section","attrib":{"id":"id90bfbe90-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601"},"text":null,"children":[{"tag":"num","attrib":{"value":"6601"},"text":"§ 6601.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reorganization plan and report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90bfbe91-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of plan and report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"1998-10-21"},"text":"October 21, 1998","children":[],"tail":", the President shall transmit to the appropriate congressional committees a reorganization plan and report regarding—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90bfbe92-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the abolition of the United States Arms Control and Disarmament Agency, the United States Information Agency, and the United States International Development Cooperation Agency in accordance with this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bfbe93-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the Agency for International Development, the consolidation and streamlining of the Agency and the transfer of certain functions of the Agency to the Department in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6581"},"text":"section 6581 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bfbe94-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the termination of functions of each covered agency as may be necessary to effectuate the reorganization under this chapter, and the termination of the affairs of each agency abolished under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bfbe95-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transfer to the Department of the functions and personnel of each covered agency consistent with the provisions of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bfbe96-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the consolidation, reorganization, and streamlining of the Department in connection with the transfer of such functions and personnel in order to carry out such functions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90bfbe97-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered agencies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The agencies covered by this section are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90bfbe98-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Arms Control and Disarmament Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bfbe99-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Information Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bfbe9a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States International Development Cooperation Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bfbe9b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Agency for International Development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90bfbe9c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan transmitted under subsection (a) shall contain, consistent with this chapter, such elements as the President deems appropriate, including elements that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90bfbe9d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the functions of each covered agency that will be transferred to the Department under the plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bfbe9e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify the steps to be taken by the Secretary of State to reorganize internally the functions of the Department, including the consolidation of offices and functions, that will be required under the plan in order to permit the Department to carry out the functions transferred to it under the plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bfbe9f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify the funds available to each covered agency that will be transferred to the Department as a result of the transfer of functions of such agency to the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bfbea0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify the proposed allocations within the Department of unexpended funds transferred in connection with the transfer of functions under the plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bfbea1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify the proposed disposition of the property, facilities, contracts, records, and other assets and liabilities of each covered agency in connection with the transfer of the functions of such agency to the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90bfbea2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reorganization plan of Agency for International Development","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to applicable provisions of subsection (c), the reorganization plan transmitted under this section for the Agency for International Development—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90bfbea3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may provide for the abolition of the Agency for International Development and the transfer of all its functions to the Department of State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bfbea4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in lieu of the abolition and transfer of functions under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90bfbea5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide for the transfer to and consolidation within the Department of the functions set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6581"},"text":"section 6581 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90bfbea6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may provide for additional consolidation, reorganization, and streamlining of AID, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90bfbea7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the termination of functions and reductions in personnel of AID;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90bfbea8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transfer of functions of AID, and the personnel associated with such functions, to the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90bfbea9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/d/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the consolidation, reorganization, and streamlining of the Department upon the transfer of such functions and personnel in order to carry out the functions transferred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90bfbeaa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modification of plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may, on the basis of consultations with the appropriate congressional committees, modify or revise any part of the plan transmitted under subsection (a) until that part of the plan becomes effective in accordance with subsection (g).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90bfbeab-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report accompanying the reorganization plan for the Department and the covered agencies submitted pursuant to this section shall describe the implementation of the plan and shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90bfbeac-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a detailed description of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90bfbead-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actions necessary or planned to complete the reorganization,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90bfbeae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the anticipated nature and substance of any orders, directives, and other administrative and operational actions which are expected to be required for completing or implementing the reorganization, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90bfbeaf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any preliminary actions which have been taken in the implementation process;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bfbeb0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of personnel and positions of each covered agency (including civil service personnel, Foreign Service personnel, and detailees) that are expected to be transferred to the Department, separated from service with such agency, or eliminated under the plan, and a projected schedule for such transfers, separations, and terminations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bfbeb1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of personnel and positions of the Department (including civil service personnel, Foreign Service personnel, and detailees) that are expected to be transferred within the Department, separated from service with the Department, or eliminated under the plan, and a projected schedule for such transfers, separations, and terminations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bfbeb2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a projected schedule for completion of the implementation process; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bfbeb3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations, if any, for legislation necessary to carry out changes made by this chapter relating to personnel and to incidental transfers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90bfbeb4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90bfbeb5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The reorganization plan described in this section, including any modifications or revisions of the plan under subsection (e), shall become effective on the earlier of the date for the respective covered agency specified in paragraph (2) or the date announced by the President under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bfbeb6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statutory effective dates","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The effective dates under this paragraph for the reorganization plan described in this section are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90bfbeb7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"1999-04-01"},"text":"April 1, 1999","children":[],"tail":", with respect to functions of the Agency for International Development described in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6581"},"text":"section 6581 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90bfbeb8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"1999-04-01"},"text":"April 1, 1999","children":[],"tail":", with respect to the abolition of the United States Arms Control and Disarmament Agency and the United States International Development Cooperation Agency."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90bfbeb9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"1999-10-01"},"text":"October 1, 1999","children":[],"tail":", with respect to the abolition of the United States Information Agency."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bfbeba-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date by Presidential determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An effective date under this paragraph for a reorganization plan described in this section is such date as the President shall determine to be appropriate and announce by notice published in the Federal Register, which date may be not earlier than 90 calendar days after the President has transmitted the reorganization plan to the appropriate congressional committees pursuant to subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bfbebb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statutory construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection may be construed to require the transfer of functions, personnel, records, balance of appropriations, or other assets of a covered agency on a single date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bfbebc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supersedes existing law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall apply notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s905/b"},"text":"section 905(b) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90bfbebd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6601/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The reorganization plan described in this section shall be printed in the Federal Register after the date upon which it first becomes effective.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90bfbebe-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. A, title XVI, § 1601, "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-795"},"text":"112 Stat. 2681–795","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90bfbebf-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90bfbec0-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90bfbec1-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a)(1), (3), (4), (c), and (f)(5), was in the original “this subdivision”, meaning subdiv. A of div. G of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-765"},"text":"112 Stat. 2681–765","children":[],"tail":", known as the Foreign Affairs Agencies Consolidation Act of 1998. For complete classification of this subdivision to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6501"},"text":"section 6501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id90bfbec2-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id90bfbec3-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of the Functions Vested in the President by Sections 1601(e) and 1601(g) of the Foreign Affairs Reform and Restructuring Act of 1998, as Enacted in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Public Law 105–277","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"1999-03-31"},"text":"Mar. 31, 1999","children":[],"tail":", 64 F.R. 17079, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum for the Secretary of State","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"By the authority vested in me by the Constitution and laws of the United States, including ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of title 3","children":[],"tail":" of the United States Code, I hereby delegate to you the functions vested in the President by sections 1601(e) and 1601(g) of the Foreign Affairs Reform and Restructuring Act of 1998, as enacted in "},{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Public Law 105–277","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6601/e"},"text":"22 U.S.C. 6601(e)","children":[],"tail":", (g)]."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The functions delegated by this memorandum may be redelegated as appropriate.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"You are authorized and directed to publish this memorandum in the Federal Register.","children":[],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"William J. Clinton.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
