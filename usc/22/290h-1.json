{"tag":"section","attrib":{"id":"id8ee09e04-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290h–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"290h–1"},"text":"§ 290h–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States African Development Foundation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ee09e05-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290h–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Foundation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established a body corporate to be known as the “United States African Development Foundation” (hereafter in this subchapter referred to as the “Foundation”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ee09e06-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290h–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Principal and branch offices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation shall establish a principal office in the United States and may establish such branch offices in Africa as may be necessary to carry out its functions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ee09e07-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/533/tV/s503"},"text":"Pub. L. 96–533, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-16"},"text":"Dec. 16, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3152"},"text":"94 Stat. 3152","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/76/dK/tIII"},"text":"Pub. L. 113–76, div. K, title III","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-01-17"},"text":"Jan. 17, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/482"},"text":"128 Stat. 482","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ee09e08-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ee09e09-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8ee09e0a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/76"},"text":"Pub. L. 113–76","children":[],"tail":" inserted “United States” before “African Development”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
