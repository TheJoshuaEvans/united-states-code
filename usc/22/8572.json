{"tag":"section","attrib":{"id":"id9105053f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572"},"text":null,"children":[{"tag":"num","attrib":{"value":"8572"},"text":"§ 8572.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of sanctions with respect to Iranian petroleum","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id91050540-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On and after the date that is 180 days after ","children":[{"tag":"date","attrib":{"date":"2024-04-24"},"text":"April 24, 2024","children":[],"tail":", and except as provided in subsection (e)(2), the President shall impose the sanctions described in subsection (c) with respect to each foreign person that the President determines knowingly engaged, on or after "},{"tag":"date","attrib":{"date":"2024-04-24"},"text":"April 24, 2024","children":[],"tail":", in an activity described in subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91050541-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A foreign person engages in an activity described in this subsection if the foreign person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91050542-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" owns or operates a foreign port at which, on or after ","children":[{"tag":"date","attrib":{"date":"2024-04-24"},"text":"April 24, 2024","children":[],"tail":", such person knowingly permits to dock a vessel—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91050543-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is included on the list of specially designated nationals and blocked persons maintained by the Office of Foreign Assets Control of the Department of the Treasury for transporting Iranian crude oil or petroleum products; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91050544-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of which the operator or owner of such vessel otherwise knowingly engages in a significant transaction involving such vessel to transport, offload, or deal in significant transactions in condensate, refined, or unrefined petroleum products, or other petrochemical products originating from the Islamic Republic of Iran;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91050545-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owns or operates a vessel through which such owner knowingly conducts a ship to ship transfer involving a significant transaction of any petroleum product originating from the Islamic Republic of Iran;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91050546-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owns or operates a refinery through which such owner knowingly engages in a significant transaction to process, refine, or otherwise deal in any petroleum product originating from the Islamic Republic of Iran;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91050547-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a covered family member of a foreign person described in paragraph (1), (2), or (3); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91050548-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is owned or controlled by a foreign person described in paragraph (1), (2), or (3), and knowingly engages in an activity described in paragraph (1), (2), or (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91050549-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanctions described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The sanctions described in this subsection with respect to a foreign person described in subsection (a) are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9105054a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanctions on foreign vessels","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to such regulations as the President may prescribe, the President may prohibit a vessel described in subsection (b)(1)(A) or (b)(1)(B) from landing at any port in the United States—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9105054b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a vessel described in subsection (b)(1)(A), for a period of not more than 2 years beginning on the date on which the President imposes sanctions with respect to a related foreign port described in subsection (b)(1)(A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9105054c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a vessel described in subsection (b)(1)(B), for a period of not more than 2 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9105054d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Blocking of property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall exercise all of the powers granted to the President under the International Emergency Economic Powers Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":" et seq.) to the extent necessary to block and prohibit all transactions in property and interests in property of the foreign person if such property and interests in property are in the United States, come within the United States, or are or come within the possession or control of a United States person."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9105054e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ineligibility for visas, admission, or parole","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9105054f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Visas, admission, or parole","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An alien described in subsection (a) is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id91050550-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inadmissible to the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91050551-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ineligible to receive a visa or other documentation to enter the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91050552-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/c/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise ineligible to be admitted or paroled into the United States or to receive any other benefit under the Immigration and Nationality Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"8 U.S.C. 1101","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91050553-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Current visas revoked","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id91050554-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An alien described in subsection (a) is subject to revocation of any visa or other entry documentation regardless of when the visa or other entry documentation is or was issued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91050555-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Immediate effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A revocation under clause (i) shall take effect immediately and automatically cancel any other valid visa or entry documentation that is in the alien’s possession.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91050556-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Sanctions under this paragraph shall not apply with respect to an alien if admitting or paroling the alien into the United States is necessary—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id91050557-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/c/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to permit the United States to comply with the Agreement regarding the Headquarters of the United Nations, signed at Lake Success ","children":[{"tag":"date","attrib":{"date":"1947-06-26"},"text":"June 26, 1947","children":[],"tail":", and entered into force "},{"tag":"date","attrib":{"date":"1947-11-21"},"text":"November 21, 1947","children":[],"tail":", between the United Nations and the United States, or other applicable international obligations; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91050558-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/c/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out or assist law enforcement activity in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91050559-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The penalties provided for in subsections (b) and (c) of section 206 of the International Emergency Economic Powers Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1705"},"text":"50 U.S.C. 1705","children":[],"tail":") shall apply to a person that violates, attempts to violate, conspires to violate, or causes a violation of this section or any regulations promulgated to carry out this section to the same extent that such penalties apply to a person that commits an unlawful act described in section 206(a) of that Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9105055a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules of construction","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9105055b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of determinations under subsection (a) that a foreign person engaged in activities described in subsection (b), a foreign person shall not be determined to know that petroleum or petroleum products originated from Iran if such person relied on a certificate of origin or other documentation confirming that the origin of the petroleum or petroleum products was a country other than Iran, unless such person knew or had reason to know that such documentation was falsified.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9105055c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this subchapter shall be construed to affect the availability of any existing authorities to issue waivers, exceptions, exemptions, licenses, or other authorization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9105055d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation; regulations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9105055e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may exercise all authorities under sections 203 and 205 of the International Emergency Economic Powers Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1702"},"text":"50 U.S.C. 1702","children":[],"tail":" and 1704) for purposes of carrying out this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9105055f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline for regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2024-04-24"},"text":"April 24, 2024","children":[],"tail":", the President shall prescribe such regulations as may be necessary for the implementation of this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91074e50-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 10 days before the prescription of regulations under paragraph (2), the President shall brief and provide written notification to the appropriate congressional committees regarding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91074e51-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proposed regulations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91074e52-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the specific provisions of this subchapter that the regulations are implementing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91074e53-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for humanitarian assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91074e54-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Sanctions under this section shall not apply to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91074e55-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conduct or facilitation of a transaction for the provision of agricultural commodities, food, medicine, medical devices, or humanitarian assistance, or for humanitarian purposes; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91074e56-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transactions that are necessary for or related to the activities described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91074e57-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91074e58-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural commodity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “agricultural commodity” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5602"},"text":"section 5602 of title 7","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91074e59-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical device","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “medical device” has the meaning given the term “device” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s321"},"text":"section 321 of title 21","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91074e5a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medicine","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “medicine” has the meaning given the term “drug” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s321"},"text":"section 321 of title 21","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91074e5b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for safety of vessels and crew","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Sanctions under this section shall not apply with respect to a person providing provisions to a vessel otherwise subject to sanctions under this section if such provisions are intended for the safety and care of the crew aboard the vessel, the protection of human life aboard the vessel, or the maintenance of the vessel to avoid any environmental or other significant damage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91074e5c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91074e5d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may, on a case-by-case basis and for periods not to exceed 180 days each, waive the application of sanctions imposed with respect to a foreign person under this section if the President certifies to the appropriate congressional committees, not later than 15 days after such waiver is to take effect, that the waiver is vital to the national interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91074e5e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall not be required to impose sanctions under this section with respect to a foreign person described in subsection (a) if the President certifies in writing to the appropriate congressional committees that the foreign person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91074e5f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is no longer engaging in activities described in subsection (b); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91074e60-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has taken and is continuing to take significant, verifiable steps toward permanently terminating such activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91074e61-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The authorities provided by this section shall cease to have effect on and after the date that is 30 days after the date on which the President certifies to the appropriate congressional committees that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91074e62-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Government of Iran no longer repeatedly provides support for international terrorism as determined by the Secretary of State pursuant to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91074e63-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/i/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4813/c/1/A"},"text":"section 4813(c)(1)(A) of title 50","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91074e64-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/i/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2371"},"text":"section 2371 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91074e65-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/i/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2780"},"text":"section 2780 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91074e66-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/i/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other provision of law; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91074e67-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8572/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Iran has ceased the pursuit, acquisition, and development of, and verifiably dismantled, its nuclear, biological, and chemical weapons, ballistic missiles, and ballistic missile launch technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id91074e68-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/50/dJ/s3"},"text":"Pub. L. 118–50, div. J, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-04-24"},"text":"Apr. 24, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/963"},"text":"138 Stat. 963","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id91074e69-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id91074e6a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id91074e6b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The International Emergency Economic Powers Act, referred to in subsec. (c)(2), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/223"},"text":"Pub. L. 95–223","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-12-28"},"text":"Dec. 28, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1626"},"text":"91 Stat. 1626","children":[],"tail":", which is classified generally to chapter 35 (§ 1701 et seq.) of Title 50, War and National Defense. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"section 1701 of Title 50","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Immigration and Nationality Act, referred to in subsec. (c)(3)(A)(iii), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"act June 27, 1952, ch. 477","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/163"},"text":"66 Stat. 163","children":[],"tail":", which is classified principally to chapter 12 (§ 1101 et seq.) of Title 8, Aliens and Nationality. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of Title 8","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id91074e6c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Stop Harboring Iranian Petroleum Act, also known as the SHIP Act, and not as part of the Comprehensive Iran Sanctions, Accountability, and Divestment Act of 2010 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id91074e6d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id91074e6e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum of President of the United States, § 1, ","children":[{"tag":"date","attrib":{"date":"2024-09-13"},"text":"Sept. 13, 2024","children":[],"tail":", 89 F.R. 77757, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(a) I hereby delegate to the Secretary of the Treasury, in consultation with the Secretary of State, the functions and authorities vested in the President by sections 3(a), 3(c)(1), and 3(e) of the Stop Harboring Iranian Petroleum Act (Division J of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/50"},"text":"Public Law 118–50","children":[],"tail":") (the “SHIP Act”) ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s8572/a"},"text":"22 U.S.C. 8572(a)","children":[],"tail":", (c)(1), (e)]."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(b) I hereby delegate to the Secretary of the Treasury the functions and authorities vested in the President by section 3(c)(2) of the SHIP Act.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(c) I hereby delegate to the Secretary of State the functions and authorities vested in the President by sections 3(h) and 3(i) of the SHIP Act.","children":[],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"J.R. Biden, Jr.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
