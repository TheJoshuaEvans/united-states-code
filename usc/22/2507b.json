{"tag":"section","attrib":{"id":"id8fcef55d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2507b"},"text":"§ 2507b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sexual assault policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fcef55e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall develop and implement a comprehensive sexual assault policy that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fcef55f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a system for restricted and unrestricted reporting of sexual assault;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fcef560-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mandates, for each Peace Corps country program, the designation of a Sexual Assault Response Liaison (SARL), who shall receive comprehensive training on procedures to respond to reports of sexual assault, with duties including ensuring that volunteers who are victims of sexual assault are moved to a safe environment and accompanying victims through the in-country response at the request of the victim;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fcef561-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires any employee of the Peace Corps to immediately contact a Victim’s Advocate upon receiving a report of sexual assault in accordance with the restricted and unrestricted reporting guidelines promulgated by the Peace Corps and require the Peace Corps to designate the staff at each post who shall be responsible for providing the services described in subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fcef562-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507b/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, conforms to best practices in the sexual assault field;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fcef563-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507b/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is applicable to all posts at which volunteers serve;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fcef564-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507b/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a guarantee that volunteers will not suffer loss of living allowances for reporting a sexual assault;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fcef565-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507b/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintains a record documenting the resignation of any employee or volunteer of the Peace Corps who resigns before a determination has been made regarding an alleged violation of the sexual misconduct policy or other serious policy violations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fcef566-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507b/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" takes into account the record maintained under paragraph (7) before such employee or volunteer is hired, enrolled, or otherwise invited to work with the Peace Corps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fcef567-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507b/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provides orientation or information regarding the awareness and prevention of sexual assault and sexual harassment to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fcef568-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507b/a/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Peace Corps-selected host families; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fcef569-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507b/a/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a designated person of authority at the volunteer’s initial workplace; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fcef56a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507b/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensures, to the extent practicable and appropriate, that any assault on, or any harm or injury to, a volunteer that is committed by any member of a host family or any national of a host country that was assigned by the Peace Corps to facilitate volunteer work is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fcef56b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507b/a/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" documented in an appropriate site history file and in the global tracking and recording system established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2507h/c"},"text":"section 2507h(c) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fcef56c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507b/a/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" taken into account with respect to determinations regarding placements of future volunteers at such post and the provision of any funds or other benefit by the Peace Corps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fcef56d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development and consultation with experts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing the sexual assault policy under subsection (a), the President shall consult with and incorporate, as appropriate, the recommendations and views of experts in the sexual assault field, including experts with international experience.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fcef56e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The sexual assault policy developed under subsection (a) shall include, at a minimum, the following services with respect to a volunteer who has been a victim of sexual assault:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fcef56f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The option of pursuing either restricted or unrestricted reporting of an assault.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fcef570-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provision of a SARL and Victim’s Advocate to the volunteer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fcef571-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At a volunteer’s discretion, provision of a sexual assault forensic exam in accordance with applicable host country law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fcef572-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507b/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If necessary, the provision of emergency health care, including a mechanism for such volunteer to evaluate such provider.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fcef573-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507b/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If necessary, the provision of counseling and psychiatric medication.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fcef574-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507b/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Completion of a safety and treatment plan with the volunteer, if necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fcef575-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507b/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Evacuation of such volunteer for medical treatment, accompanied by a Peace Corps staffer at the request of such volunteer. When evacuated to the United States, such volunteer shall be provided, to the extent practicable, a choice of medical providers including a mechanism for such volunteers to evaluate the provider.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fcef576-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507b/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An explanation to the volunteer of available law enforcement and prosecutorial options, and legal representation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fcef577-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall train all staff outside the United States regarding the sexual assault policy developed under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fcef578-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/293/tI/s8B"},"text":"Pub. L. 87–293, title I, § 8B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/57/s2"},"text":"Pub. L. 112–57, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-11-21"},"text":"Nov. 21, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/738"},"text":"125 Stat. 738","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/256/tIII/s303"},"text":"Pub. L. 115–256, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-09"},"text":"Oct. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3657"},"text":"132 Stat. 3657","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fcef579-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8fcef57a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8fcef57b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/256/s303/1"},"text":"Pub. L. 115–256, § 303(1)","children":[],"tail":", substituted “any employee of the Peace Corps” for “SARLs” and “Victim’s Advocate” for “Victim Advocate” and inserted “and require the Peace Corps to designate the staff at each post who shall be responsible for providing the services described in subsection (c)” before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7) to (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/256/s303/2"},"text":"Pub. L. 115–256, § 303(2)","children":[],"tail":"–(4), added pars. (7) to (10)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
