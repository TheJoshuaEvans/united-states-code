{"tag":"section","attrib":{"id":"id9123fedf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9265a"},"text":null,"children":[{"tag":"num","attrib":{"value":"9265a"},"text":"§ 9265a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports on certain licensing actions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9123fee0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9265a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report required","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9123fee1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9265a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"December 20, 2019","children":[],"tail":", and every 180 days thereafter, the President shall submit to the committees specified in paragraph (2) a report on the operation of the system for issuing licenses for transactions under covered regulatory provisions during the preceding 180-day period that includes—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9123fee2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9265a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and types of such licenses applied for during that period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9123fee3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9265a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of such licenses issued during that period and information identifying the person receiving each such license.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9123fee4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9265a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Committees specified","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The committees specified in this paragraph are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9123fee5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9265a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee on Financial Services and the Committee on Foreign Affairs of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9123fee6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9265a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee on Banking, Housing, and Urban Affairs and the Committee on Foreign Relations of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9123fee7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9265a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of copies of licenses on request","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall expeditiously provide a copy of any license identified in a report required by subsection (a)(1) to the Committee on Financial Services of the House of Representatives and the Committee on Banking, Housing, and Urban Affairs of the Senate if an appropriate Member of Congress requests a copy of that license not later than 30 days after submission of the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9123fee8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9265a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each report required by subsection (a), and each copy of a license submitted under subsection (b), shall be submitted in unclassified form but may include a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9123fee9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9265a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9123feea-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9265a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate Member of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate Member of Congress” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9123feeb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9265a/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the chairman or ranking member of the Committee on Financial Services of the House of Representatives; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9123feec-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9265a/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the chairman or ranking member of the Committee on Banking, Housing, and Urban Affairs of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9123feed-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9265a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered regulatory provision","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered regulatory provision” means any of the following provisions, as in effect on the day before ","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"December 20, 2019","children":[],"tail":", and as such provisions relate to North Korea:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9123feee-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9265a/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Part 743, 744, or 746 of title 15, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9123feef-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9265a/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Part 510 of title 31, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9123fef0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9265a/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other provision of title 31, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9123fef1-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dF/tLXXI/s7132"},"text":"Pub. L. 116–92, div. F, title LXXI, § 7132","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2252"},"text":"133 Stat. 2252","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9123fef2-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9123fef3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id9123fef4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Otto Warmbier North Korea Nuclear Sanctions and Enforcement Act of 2019, and also as part of the National Defense Authorization Act for Fiscal Year 2020, and not as part of the North Korea Sanctions and Policy Enhancement Act of 2016 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id9123fef5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id9123fef6-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions and authorities of President under this section delegated to Secretary of the Treasury and Secretary of Commerce by section 1(c) of Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2020-02-21"},"text":"Feb. 21, 2020","children":[],"tail":", 85 F.R. 13717, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s286yy"},"text":"section 286yy of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
