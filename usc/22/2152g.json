{"tag":"section","attrib":{"id":"id8f5c84a0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152g"},"text":null,"children":[{"tag":"num","attrib":{"value":"2152g"},"text":"§ 2152g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f5c84a1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than one year after the date on which the President transmits to the appropriate congressional committees the strategy required by section 4(a), and annually thereafter, the President shall transmit to the appropriate congressional committees a report on the implementation of this Act and the amendments made by this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f5c84a2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report shall contain the following information for grants, cooperative agreements, contracts, contributions, and other forms of assistance awarded or entered into under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2152f"},"text":"section 2152f of this title","children":[],"tail":":"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f5c84a3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152g/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of funding, the name of recipient organizations, the location of programs and activities, the status of progress of programs and activities, and the estimated number of orphans and other vulnerable children who received direct or indirect assistance under the programs and activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f5c84a4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152g/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The results of the monitoring and evaluation system with respect to assistance for orphans and other vulnerable children.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f5c84a5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152g/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The percentage of assistance provided in support of orphans or other vulnerable children affected by HIV/AIDS.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f5c84a6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152g/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other appropriate information relating to the needs of orphans and other vulnerable children in developing countries that could be addressed through the provision of assistance authorized in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2152f"},"text":"section 2152f of this title","children":[],"tail":" or under any other provision of law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f5c84a7-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/95/s5"},"text":"Pub. L. 109–95, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-11-08"},"text":"Nov. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2117"},"text":"119 Stat. 2117","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f5c84a8-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f5c84a9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8f5c84aa-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 4(a), referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/95/s4/a"},"text":"section 4(a) of Pub. L. 109–95","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2152f"},"text":"section 2152f of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/95"},"text":"Pub. L. 109–95","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-11-08"},"text":"Nov. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2111"},"text":"119 Stat. 2111","children":[],"tail":", known as the Assistance for Orphans and Other Vulnerable Children in Developing Countries Act of 2005, which enacted this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2152f"},"text":"section 2152f of this title","children":[],"tail":" and enacted provisions set out as notes under this section and sections 2151 and 2152f of this title. For complete classification of this Act to the Code, see Short Title of 2005 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8f5c84ab-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Assistance for Orphans and Other Vulnerable Children in Developing Countries Act of 2005, and not as part of the Foreign Assistance Act of 1961 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f5c84ac-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8f5c84ad-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Appropriate Congressional Committees Defined","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/95/s6"},"text":"Pub. L. 109–95, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-11-08"},"text":"Nov. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2118"},"text":"119 Stat. 2118","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/95/s6"},"text":"“In this Act [see Short Title of 2005 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":"], the term ‘appropriate congressional committees’ means the Committee on Appropriations and the Committee on Foreign Relations of the Senate and the Committee on Appropriations and the Committee on International Relations [now Committee on Foreign Affairs] of the House of Representatives.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
