"ref","attrib":{"href":"/us/pl/115/232/dA/tXVII/s1766/a"},"text":"Pub. L. 115–232, div. A, title XVII, § 1766(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2232"},"text":"132 Stat. 2232","children":[],"tail":". Provisions similar to those in former "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4605/j/1/A"},"text":"section 4605(j)(1)(A) of title 50","children":[],"tail":" can be found in "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4813/c/1/A/i"},"text":"section 4813(c)(1)(A)(i) of title 50","children":[],"tail":", as enacted by "},{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id910504bb-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":" substituted “105B(a), or 105C(a)” for “or 105B(a)” and “105B(b), or 105C(b)” for “or 105B(b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/158/s605/b"},"text":"Pub. L. 112–158, § 605(b)","children":[],"tail":", inserted “, and verifiably dismantled its,” after “development of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/158/s403/d"},"text":"Pub. L. 112–158, § 403(d)","children":[],"tail":", inserted “, 105A(a), or 105B(a)” after “105(a)” and “, 105A(b), or 105B(b)” after “105(b)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id910504bc-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"childr