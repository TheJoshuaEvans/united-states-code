tag":"p","attrib":{},"text":"Other delegations of functions vested in the President by this section were contained in the following:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2013-06-03"},"text":"June 3, 2013","children":[],"tail":", 78 F.R. 35545, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s8801"},"text":"section 8801 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2010-09-23"},"text":"Sept. 23, 2010","children":[],"tail":", 75 F.R. 67025, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s8501"},"text":"section 8501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
