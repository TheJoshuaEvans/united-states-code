{"tag":"section","attrib":{"id":"id90ef8013-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7812"},"text":null,"children":[{"tag":"num","attrib":{"value":"7812"},"text":"§ 7812.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support for human rights and democracy programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90ef8014-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7812/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President is authorized to provide grants to private, nonprofit organizations to support programs that promote human rights, democracy, rule of law, and the development of a market economy in North Korea. Such programs may include appropriate educational and cultural exchange programs with North Korean participants, to the extent not otherwise prohibited by law. The President is also authorized to provide grants to entities to undertake research on North Korea’s denial of human rights, including on the political and military chains of command responsible for authorizing and implementing systemic human rights abuses, including at prison camps and detention facilities where political prisoners are held.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90ef8015-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7812/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90ef8016-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7812/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the President $2,000,000 for each of the fiscal years 2005 through 2008 and $2,000,000 for each of fiscal years 2009 through 2022 to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ef8017-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7812/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts appropriated pursuant to the authorization of appropriations under paragraph (1) are authorized to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90ef8018-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/333/tI/s102"},"text":"Pub. L. 108–333, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-18"},"text":"Oct. 18, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1290"},"text":"118 Stat. 1290","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/346/s5"},"text":"Pub. L. 110–346, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-07"},"text":"Oct. 7, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3941"},"text":"122 Stat. 3941","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/172/s4"},"text":"Pub. L. 112–172, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-16"},"text":"Aug. 16, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1308"},"text":"126 Stat. 1308","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/198/s7/a"},"text":"Pub. L. 115–198, § 7(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-07-20"},"text":"July 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1523"},"text":"132 Stat. 1523","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90ef8019-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90ef801a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90ef801b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/198/s7/a/1"},"text":"Pub. L. 115–198, § 7(a)(1)","children":[],"tail":", inserted at end “The President is also authorized to provide grants to entities to undertake research on North Korea’s denial of human rights, including on the political and military chains of command responsible for authorizing and implementing systemic human rights abuses, including at prison camps and detention facilities where political prisoners are held.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/198/s7/a/2"},"text":"Pub. L. 115–198, § 7(a)(2)","children":[],"tail":", substituted “2022” for “2017”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/172"},"text":"Pub. L. 112–172","children":[],"tail":" substituted “2017” for “2012”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/346"},"text":"Pub. L. 110–346","children":[],"tail":" inserted “and $2,000,000 for each of fiscal years 2009 through 2012” after “2008”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
