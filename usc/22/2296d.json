{"tag":"section","attrib":{"id":"id8f851bb4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2296d"},"text":null,"children":[{"tag":"num","attrib":{"value":"2296d"},"text":"§ 2296d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strengthening democracy, tolerance, and the development of civil society","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f851bb5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2296d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose of assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of assistance under this section is to promote institutions of democratic government and to create the conditions for the growth of pluralistic societies, including religious tolerance and respect for internationally recognized human rights.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f851bb6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2296d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization for assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To carry out the purpose of subsection (a), the President is authorized to provide the following types of assistance to the countries of the South Caucasus and Central Asia:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f851bb7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2296d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assistance for democracy building, including programs to strengthen parliamentary institutions and practices.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f851bb8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2296d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assistance for the development of nongovernmental organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f851bb9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2296d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assistance for development of independent media.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f851bba-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2296d/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assistance for the development of the rule of law, a strong independent judiciary, and transparency in political practice and commercial transactions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f851bbb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2296d/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" International exchanges and advanced professional training programs in skill areas central to the development of civil society.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f851bbc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2296d/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assistance to promote increased adherence to civil and political rights under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151n/e"},"text":"section 2151n(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f851bbd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2296d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities supported","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Activities that may be supported by assistance under subsection (b) include activities that are designed to advance progress toward the development of democracy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f851bbe-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. I, § 499D, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/2/tV/s596/b"},"text":"Pub. L. 106–113, div. B, § 1000(a)(2) [title V, § 596(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1535"},"text":"113 Stat. 1535","children":[],"tail":", 1501A–125.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f851bbf-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id8f851bc0-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id8f851bc1-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions of President under this section, see Ex. Ord. No. 12163, ","children":[{"tag":"date","attrib":{"date":"1979-09-29"},"text":"Sept. 29, 1979","children":[],"tail":", 44 F.R. 56673, as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2381"},"text":"section 2381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
