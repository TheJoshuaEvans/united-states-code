{"tag":"section","attrib":{"id":"id8f06c392-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1475a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1475a"},"text":"§ 1475a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Replacement of passenger motor vehicles","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The exchange allowances or proceeds derived from the exchange or sale of passenger motor vehicles used abroad for purposes of this chapter or the Mutual Educational and Cultural Exchange Act of 1961 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2451"},"text":"22 U.S.C. 2451","children":[],"tail":" et seq.] shall be available without fiscal year limitation for replacement of an equal number of such vehicles in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s503"},"text":"section 503 of title 40","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f06c393-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-01-27/ch36"},"text":"Jan. 27, 1948, ch. 36","children":[],"tail":", title VIII, § 806, as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/350/tII/s204"},"text":"Pub. L. 94–350, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-07-12"},"text":"July 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/830"},"text":"90 Stat. 830","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/60/tII/s204/c"},"text":"Pub. L. 96–60, title II, § 204(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-08-15"},"text":"Aug. 15, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/400"},"text":"93 Stat. 400","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f06c394-2930-11f1-8918-be39dde81dc6"},"text":"\n","child