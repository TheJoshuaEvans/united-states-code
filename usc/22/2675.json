{"tag":"section","attrib":{"id":"id8ff2d12f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2675"},"text":null,"children":[{"tag":"num","attrib":{"value":"2675"},"text":"§ 2675.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation or transfer to other agencies of funds appropriated to Department of State; authority for expenditure of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of State may allocate or transfer to any department, agency, or independent establishment of the United States Government (with the consent of the head of such department, agency, or establishment) any funds appropriated to the Department of State, for direct expenditure by such department, agency, or independent establishment for the purposes for which the funds were appropriated in accordance with authority granted in this Act or under authority governing the activities of such department, agency, or independent establishment.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ff2d130-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch841"},"text":"Aug. 1, 1956, ch. 841","children":[],"tail":", title I, § 8, "},{"tag":"ref","attrib":{"href":"/us/stat/70/891"},"text":"70 Stat. 891","children":[],"tail":"; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/97/241/tII/s202/a"},"text":"Pub. L. 97–241, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-08-24"},"text":"Aug. 24, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/282"},"text":"96 Stat. 282","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/164/tI/s121"},"text":"Pub. L. 98–164, title I, § 121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-11-22"},"text":"Nov. 22, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1023"},"text":"97 Stat. 1023","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ff2d131-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ff2d132-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8ff2d133-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch841"},"text":"act Aug. 1, 1956, ch. 841","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/890"},"text":"70 Stat. 890","children":[],"tail":", known as the State Department Basic Authorities Act of 1956. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8ff2d134-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s170m"},"text":"section 170m of Title 5","children":[],"tail":" prior to the general revision and enactment of Title 5, Government Organization and Employees, by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s1"},"text":"Pub. L. 89–554, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib"