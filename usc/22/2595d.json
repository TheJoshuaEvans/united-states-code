{"tag":"section","attrib":{"id":"id8fdadc3f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2595d"},"text":null,"children":[{"tag":"num","attrib":{"value":"2595d"},"text":"§ 2595d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report on comprehensive nuclear-test-ban treaty sensors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fdadc40-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2595d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2021-12-27"},"text":"December 27, 2021","children":[],"tail":", and not later than September 1 of each subsequent year, the Secretary of State shall submit to the appropriate congressional committees a report on the sensors used in the international monitoring system of the Comprehensive Nuclear-Test-Ban Treaty Organization. Each such report shall include, with respect to the period covered by the report—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fdadc41-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2595d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of incidents where such sensors are disabled, turned off, or experience “technical difficulties”; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fdadc42-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2595d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to each such incident—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fdadc43-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2595d/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the location of the sensor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fdadc44-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2595d/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the duration of the incident; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fdadc45-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2595d/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the Secretary determines there is reason to believe that the incident was a deliberate act on the part of the host nation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fdadc46-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2595d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fdadc47-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2595d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs and the Committee on Armed Services of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fdadc48-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2595d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations and the Committee on Armed Services of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fdadc49-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXIII/s1335"},"text":"Pub. L. 117–81, div. A, title XIII, § 1335","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2011"},"text":"135 Stat. 2011","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fdadc4a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8fdadc4b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8fdadc4c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the National Defense Authorization Act for Fiscal Year 2022, and not as part of the Arms Control and Disarmament Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
