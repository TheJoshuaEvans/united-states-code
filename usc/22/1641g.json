{"tag":"section","attrib":{"id":"id8f12a9ed-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1641g"},"text":null,"children":[{"tag":"num","attrib":{"value":"1641g"},"text":"§ 1641g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification of awards","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Commission shall as soon as possible, and in the order of the making of such awards, certify to the Secretary of the Treasury, in terms of United States currency, each award made pursuant to this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f12a9ee-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-03-10/ch54"},"text":"Mar. 10, 1950, ch. 54","children":[],"tail":", title III, § 308, as added "},{"tag":"ref","attrib":{"href":"/us/act/1955-08-09/ch645/s3"},"text":"Aug. 9, 1955, ch. 645, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/573"},"text":"69 Stat. 573","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
