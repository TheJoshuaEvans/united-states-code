{"tag":"section","attrib":{"id":"id8ec17d4d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286e–1a"},"text":null,"children":[{"tag":"num","attrib":{"value":"286e–1a"},"text":"§ 286e–1a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increase in capital stock of Bank","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The United States Governor of the Bank is authorized to vote for an increase of $1,000,000,000 in the authorized capital stock of the Bank under article II, section 2, of the articles of agreement of the Bank, as recommended in the report, dated ","children":[{"tag":"date","attrib":{"date":"1962-11-06"},"text":"November 6, 1962","children":[],"tail":", to the Board of Governors of the Bank by the Bank’s Executive Directors."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ec17d4e-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-07-31/ch339/s19"},"text":"July 31, 1945, ch. 339, § 19","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/88/178"},"text":"Pub. L. 88–178","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-11-13"},"text":"Nov. 13, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/334"},"text":"77 Stat. 334","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
