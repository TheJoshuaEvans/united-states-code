{"tag":"section","attrib":{"id":"id8f19d58a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1732"},"text":null,"children":[{"tag":"num","attrib":{"value":"1732"},"text":"§ 1732.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Release of citizens imprisoned by foreign governments","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever it is made known to the President that any citizen of the United States has been unjustly deprived of his liberty by or under the authority of any foreign government, it shall be the duty of the President forthwith to demand of that government the reasons of such imprisonment; and if it appears to be wrongful and in violation of the rights of American citizenship, the President shall forthwith demand the release of such citizen, and if the release so demanded is unreasonably delayed or refused, the President shall use such means, not amounting to acts of war and not otherwise prohibited by law, as he may think necessary and proper to obtain or effectuate the release; and all the facts and proceedings relative thereto shall as soon as practicable be communicated by the President to Congress.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f19d58b-2930-11f1-8918-be39dde81dc6"},"text":"(R.S. § 2001; ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/222/s9"},"text":"Pub. L. 101–222, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-12"},"text":"Dec. 12, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1900"},"text":"103 Stat. 1900","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f19d58c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f19d58d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8f19d58e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 2001 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1868-07-27/ch249/s3"},"text":"act July 27, 1868, ch. 249, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/15/224"},"text":"15 Stat. 224","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s903b"},"text":"section 903b of Title 8","children":[],"tail":", Aliens and Nationality."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f19d58f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/222"},"text":"Pub. L. 101–222","children":[],"tail":" inserted “and not otherwise prohibited by law” after “acts of war”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id8f19d590-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8f19d591-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Release of American Hostages in Iran","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For Executive Order provisions relating to the release of the American hostages in Iran, see Ex. Ord. Nos. 12276 to 12285, ","children":[{"tag":"date","attrib":{"date":"1981-01-19"},"text":"Jan. 19, 1981","children":[],"tail":", 46 F.R. 7913 to 7932, listed in a table under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"section 1701 of Title 50","children":[],"tail":", War and National Defense."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
