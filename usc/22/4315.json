{"tag":"section","attrib":{"id":"id90785491-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4315"},"text":null,"children":[{"tag":"num","attrib":{"value":"4315"},"text":"§ 4315.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of foreign mission in manner incompatible with its status as foreign mission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90785492-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4315/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of limitation on certain uses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A foreign mission may not allow an unaffiliated alien the use of any premise of that foreign mission which is inviolable under United States law (including any treaty) for any purpose which is incompatible with its status as a foreign mission, including use as a residence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90785493-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4315/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary lodging","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of this section, the term “residence” does not include such temporary lodging as may be permitted under regulations issued by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90785494-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4315/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may waive subsection (a) with respect to all foreign missions of a country (and may revoke such a waiver) 30 days after providing written notification of such a waiver, together with the reasons for such waiver (or revocation of such a waiver), to the Committee on Foreign Affairs of the House of Representatives and the Committee on Foreign Relations of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90785495-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4315/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"1987-12-22"},"text":"December 22, 1987","children":[],"tail":", the Secretary of State shall submit a report to the Congress concerning the implementation of this section and shall submit such other reports to the Congress concerning changes in implementation as may be necessary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90785496-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4315/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90785497-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4315/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “foreign mission” includes any international organization as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4309/b"},"text":"section 4309(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90785498-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4315/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “unaffiliated alien” means, with respect to a foreign country, an alien who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90785499-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4315/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is admitted to the United States as a nonimmigrant, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9078549a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4315/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not a member, or a family member of a member, of a foreign mission of that foreign country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9078549b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch841"},"text":"Aug. 1, 1956, ch. 841","children":[],"tail":", title II, § 215, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/204/tI/s128/a"},"text":"Pub. L. 100–204, title I, § 128(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1343"},"text":"101 Stat. 1343","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9078549c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9078549d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id9078549e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"date","attrib":{"date":"1987-12-22"},"text":"December 22, 1987","children":[],"tail":", referred to in subsec. (d), was in the original “the date of the enactment of this Act”, which was translated as meaning the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/100/204"},"text":"Pub. L. 100–204","children":[],"tail":", which enacted this section, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9078549f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id907854a0-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/204/tI/s128/b"},"text":"Pub. L. 100–204, title I, § 128(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1343"},"text":"101 Stat. 1343","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/204/tI/s128/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), the amendment made by subsection (a) [enacting this section] shall apply to any foreign mission beginning on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendment made by subsection (a) shall apply beginning 6 months after the date of enactment of this Act with respect to any nonimmigrant alien who is using a foreign mission as a residence or a place of business on the date of enactment of this Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of State may delay the effective date provided for in subparagraph (A) for not more than 6 months with respect to any nonimmigrant alien if the Secretary finds that a hardship to that alien would result from the implementation of subsection (a).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
