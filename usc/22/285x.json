{"tag":"section","attrib":{"id":"id8ebf32cd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285x"},"text":null,"children":[{"tag":"num","attrib":{"value":"285x"},"text":"§ 285x.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional subscription to shares","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ebf32ce-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285x/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States share","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ebf32cf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285x/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Governor of the Bank is authorized to subscribe on behalf of the United States to one hundred twenty-three thousand three hundred and seventy-five additional shares of the capital stock of the Bank.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ebf32d0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285x/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any subscription to the capital stock of the Bank shall be effective only to such extent or in such amounts as are provided in advance in appropriation Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ebf32d1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285x/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to pay for the increase in the United States subscription to the Bank provided for in subsection (a), there are authorized to be appropriated, without fiscal year limitation, $1,322,999,476 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ebf32d2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285x/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continued membership of Republic of China in Bank","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ebf32d3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285x/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Congress hereby finds that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ebf32d4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285x/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Republic of China (Taiwan) is a charter member in good standing of the Asian Development Bank;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ebf32d5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285x/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Republic of China has grown from a borrower to a lender in the Asian Development Bank; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ebf32d6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285x/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Republic of China provides, through its economic success, a model for other nations in Asia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ebf32d7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285x/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" It is the sense of the Congress that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ebf32d8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285x/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Taiwan, Republic of China, should remain a full member of the Asian Development Bank, and that its status within that body should remain unaltered no matter how the issue of the People’s Republic of China’s application for membership is disposed of;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ebf32d9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285x/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President and the Secretary of State should express support of Taiwan, Republic of China, making it clear that the United States will not countenance attempts to expel Taiwan, Republic of China, from the Asian Development Bank; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ebf32da-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285x/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Senate and Clerk of the House shall transmit a copy of this resolution to the President with the request that he transmit such copy to the Board of Governors of the Asian Development Bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ebf32db-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/369/s27"},"text":"Pub. L. 89–369, § 27","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/181/tI"},"text":"Pub. L. 98–181, title I","children":[],"tail":" [title X, § 1002], "},{"tag":"date","attrib":{"date":"1983-11-30"},"text":"Nov. 30, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1285"},"text":"97 Stat. 1285","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
