{"tag":"section","attrib":{"id":"id907372c7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4199"},"text":null,"children":[{"tag":"num","attrib":{"value":"4199"},"text":"§ 4199.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for failure to give bond and for embezzlement","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Every consular officer who accepts any appointment to any office of trust mentioned in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4198"},"text":"section 4198 of this title","children":[],"tail":" without first having complied with the provisions thereof by due execution of a bond as therein required, or who shall willfully fail or neglect to account for, pay over, and deliver any money, property, or effects so received to any person lawfully entitled thereto, after having been requested by the latter, his representative or agent so to do, shall be deemed guilty of embezzlement and shall be punishable by imprisonment for not more than five years and by a fine of not more than $5,000."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id907372c8-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1902-06-30/ch1331/s2"},"text":"June 30, 1902, ch. 1331, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/547"},"text":"32 Stat. 547","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id907372c9-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id907372ca-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id907372cb-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Foreign Service Act of 1980 which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s1179"},"text":"section 1179 of this title","children":[],"tail":", and prior thereto to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s79"},"text":"section 79 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
