{"tag":"section","attrib":{"id":"id8f530e3b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2151g"},"text":null,"children":[{"tag":"num","attrib":{"value":"2151g"},"text":"§ 2151g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever the President determines it to be necessary for the purposes of this part, not to exceed 15 per centum of the funds made available for any provision of this part may be transferred to, and consolidated with, the funds made available for any other provision of this part, and may be used for any of the purposes for which such funds may be used, except that the total in the provision for the benefit of which the transfer is made shall not be increased by more than 25 per centum of the amount of funds made available for such provision. The authority of sections 2360(a) and 2364(a) of this title may not be used to transfer funds made available under this part for use for purposes of any other provision of this chapter, except that the authority of such sections may be used to transfer for the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2427"},"text":"section 2427 of this title","children":[],"tail":" not to exceed five per centum of the amount of funds made available for "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2427/a/1"},"text":"section 2427(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f530e3c-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. I, § 109, as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/189/s2/3"},"text":"Pub. L. 93–189, § 2(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-17"},"text":"Dec. 17, 1973","children":[],"tail":", "},{"tag":"ref","at