{"tag":"section","attrib":{"id":"id8ffeb874-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2722"},"text":null,"children":[{"tag":"num","attrib":{"value":"2722"},"text":"§ 2722.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International meetings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ffeb875-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2722/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to pay expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the United States Government hosts an international meeting or conference in the United States, the Secretary of State is authorized to pay all reasonable expenses of such meeting or conference. Such expenses may include rental of quarters (by contract or otherwise) and personal services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ffeb876-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2722/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retention of reimbursements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent provided in an appropriation Act, transfers of funds or other reimbursements for payments under subsection (a) are authorized to be retained and credited to the appropriate appropriation account of the Department of State which is available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ffeb877-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch841"},"text":"Aug. 1, 1956, ch. 841","children":[],"tail":", title I, § 50, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/138/tI/s119"},"text":"Pub. L. 102–138, title I, § 119","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/658"},"text":"105 Stat. 658","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
