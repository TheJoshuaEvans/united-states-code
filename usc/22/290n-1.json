{"tag":"section","attrib":{"id":"id8ee55910-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290n–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"290n–1"},"text":"§ 290n–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It should be the duty of the Commission—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ee55911-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290n–1/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct a comprehensive needs assessment in the United States-Mexico Border Area for the purposes of identifying, evaluating, preventing, and resolving health problems and potential health problems that affect the general population of the area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ee55912-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290n–1/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to implement the actions recommended by the needs assessment through—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ee55913-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290n–1/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting in the coordination and implementation of the efforts of public and private entities to prevent and resolve such health problems, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ee55914-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290n–1/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting in the coordination and implementation of efforts of public and private entities to educate such population, in a culturally competent manner, concerning such health problems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ee55915-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/400/s3"},"text":"Pub. L. 103–400, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4169"},"text":"108 Stat. 4169","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/4/tV/s516/2"},"text":"Pub. L. 106–113, div. B, § 1000(a)(4) [title V, § 516(2)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1535"},"text":"113 Stat. 1535","children":[],"tail":", 1501A–276.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ee55916-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ee55917-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8ee55918-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/s1000/a/4/tV/s516/2/A"},"text":"Pub. L. 106–113, § 1000(a)(4) [title V, § 516(2)(A)]","children":[],"tail":", substituted “; and” for semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/s1000/a/4/tV/s516/2/B"},"text":"Pub. L. 106–113, § 1000(a)(4) [title V, § 516(2)(B)]","children":[],"tail":", substituted period for “; and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/s1000/a/4/tV/s516/2/C"},"text":"Pub. L. 106–113, § 1000(a)(4) [title V, § 516(2)(C)]","children":[],"tail":", struck out par. (3) which read as follows: “to formulate recommendations to the Governments of the United States and Mexico concerning a fair and reasonable method by which the government of one country could reimburse a public or private entity in the other country for the cost of a health care service that the entity furnishes to a citizen of the first country who is unable, through insurance or otherwise, to pay for the service.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
