{"tag":"section","attrib":{"id":"id90f6acb6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8122"},"text":null,"children":[{"tag":"num","attrib":{"value":"8122"},"text":"§ 8122.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures for complementary access","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90f6acb7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8122/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each instance of complementary access to a location in the United States under the Additional Protocol shall be conducted in accordance with this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90f6acb8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8122/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90f6acb9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8122/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Complementary access referred to in subsection (a) may occur only upon the issuance of an actual written notice by the United States Government to the owner, operator, occupant, or agent in charge of the location to be subject to complementary access.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f6acba-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8122/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time of notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The notice under paragraph (1) shall be submitted to such owner, operator, occupant, or agent as soon as possible after the United States Government has received notification that the IAEA seeks complementary access. Notices may be posted prominently at the location if the United States Government is unable to provide actual written notice to such owner, operator, occupant, or agent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f6acbb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8122/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content of notice","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90f6acbc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8122/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002399"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002399"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No subpar. (B) has been enacted."}],"tail":" In general"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The notice required by paragraph (1) shall specify—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90f6acbd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8122/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purpose for the complementary access;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90f6acbe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8122/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the basis for the selection of the facility, site, or other location for the complementary access sought;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90f6acbf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8122/b/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the activities that will be carried out during the complementary access;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90f6acc0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8122/b/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the time and date that the complementary access is expected to begin, and the anticipated period covered by the complementary access; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90f6acc1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8122/b/3/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the names and titles of the inspectors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f6acc2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8122/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separate notices required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A separate notice shall be provided each time that complementary access is sought by the IAEA.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90f6acc3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8122/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credentials","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The complementary access team of the IAEA and representatives or designees of the United States Government shall display appropriate identifying credentials to the owner, operator, occupant, or agent in charge of the location before gaining entry in connection with complementary access.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90f6acc4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8122/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90f6acc5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8122/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in a warrant issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8123"},"text":"section 8123 of this title","children":[],"tail":", and subject to the rights of the United States Government under the Additional Protocol to limit complementary access, complementary access to a location pursuant to this chapter may extend to all activities specifically permitted for such locations under Article 6 of the Additional Protocol."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f6acc6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8122/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Unless required by the Additional Protocol, no inspection under this chapter shall extend to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90f6acc7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8122/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financial data (other than production data);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90f6acc8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8122/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sales and marketing data (other than shipment data);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90f6acc9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8122/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pricing data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90f6acca-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8122/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personnel data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90f6accb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8122/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" patent data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90f6accc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8122/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data maintained for compliance with environmental or occupational health and safety regulations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90f6accd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8122/d/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90f6acce-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8122/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environment, health, safety, and security","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out their activities, members of the IAEA complementary access team and representatives or designees of the United States Government shall observe applicable environmental, health, safety, and security regulations established at the location subject to complementary access, including those for protection of controlled environments within a facility and for personal safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90f6accf-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/401/tII/s222"},"text":"Pub. L. 109–401, title II, § 222","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-18"},"text":"Dec. 18, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2744"},"text":"120 Stat. 2744","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
