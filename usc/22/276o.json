{"tag":"section","attrib":{"id":"id8eac202b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276o"},"text":null,"children":[{"tag":"num","attrib":{"value":"276o"},"text":"§ 276o.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States Senate-Russia Interparliamentary Group","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8eac202c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276o/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not to exceed 12 Senators shall be appointed to meet annually with representatives of the Federation Council of Russia for discussion of common problems in the interest of relations between the United States and Russia. The Senators so appointed shall be referred to as the “United States group” of the United States Senate-Russia Interparliamentary Group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8eac202d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276o/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment of Members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The majority and minority leaders of the Senate shall appoint the Senators of the United States group. The majority leader of the Senate shall designate 1 Senator as the Chair of the United States group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8eac202e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276o/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated $100,000 for each fiscal year to assist in meeting the expenses of the United States group for each fiscal year for which an appropriation is made. Appropriations shall be disbursed on vouchers to be approved by the Chair of the United States group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8eac202f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276o/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification of expenditures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The certificate of the Chair of the United States group shall be final and conclusive upon the accounting officers in the auditing of the accounts of the United States group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8eac2030-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276o/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal year 2004 funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized within the contingent fund of the Senate under the appropriation account “","children":[{"tag":"inline","attrib":{},"text":"miscellaneous items","children":[],"tail":"” $75,000 for fiscal year 2004 to assist in meeting the official expenses of the United States Senate-Russia Interparliamentary Group including conference room expenses, hospitality expenses, and food and food-related expenses. Expenses shall be paid on vouchers to be approved by the Chair of the United States group. The Secretary of the Senate is authorized to advance such sums as necessary to carry out this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8eac2031-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276o/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are appropriated, out of any money in the Treasury not otherwise appropriated, for the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"2004-09-30"},"text":"September 30, 2004","children":[],"tail":", $100,000 for the United States Senate-Russia Interparliamentary Group."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8eac2032-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276o/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8eac2033-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276o/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsections (a) though (d) shall apply to fiscal year 2004, and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8eac2034-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276o/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal year 2004","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsections (e) and (f) shall apply to fiscal year 2004.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8eac2035-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/dH/s154"},"text":"Pub. L. 108–199, div. H, § 154","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/449"},"text":"118 Stat. 449","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
