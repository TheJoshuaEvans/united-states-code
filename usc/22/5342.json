{"tag":"section","attrib":{"id":"id908b67b2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5342"},"text":null,"children":[{"tag":"num","attrib":{"value":"5342"},"text":"§ 5342.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of national treatment in underwriting government debt instruments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id908b67b3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5342/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id908b67b4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5342/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States companies can successfully compete in foreign markets if they are given fair access to such markets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908b67b5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5342/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a trade surplus in services could offset the deficit in manufactured goods and help lower the overall trade deficit significantly;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908b67b6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5342/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in contrast to the barriers faced by United States firms in Japan, Japanese firms generally have enjoyed access to United States financial markets on the same terms as United States firms; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908b67b7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5342/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" United States firms seeking to compete in Japan face or have faced a variety of discriminatory barriers effectively precluding such firms from fairly competing for Japanese business, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id908b67b8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5342/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limitations on membership on the Tokyo Stock Exchange;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id908b67b9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5342/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" high fixed commission rates (ranging as high as 80 percent) which must be paid to members of the exchange by nonmembers for executing trades;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id908b67ba-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5342/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unequal opportunities to participate in and act as lead manager for equity and bond underwritings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id908b67bb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5342/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restrictions on access to automated teller machines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id908b67bc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5342/a/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arbitrarily applied employment requirements for opening branch offices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id908b67bd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5342/a/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" long delays in processing applications and granting approvals for licenses to operate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id908b67be-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5342/a/4/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restrictions on foreign institutions’ participation in Ministry of Finance policy advisory councils.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id908b67bf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5342/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of certain persons as primary dealers prohibited","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id908b67c0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5342/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Neither the Board of Governors of the Federal Reserve System nor the Federal Reserve Bank of New York may designate, or permit the continuation of any prior designation of, any person of a foreign country as a primary dealer in government debt instruments if such foreign country does not accord to United States companies the same competitive opportunities in the underwriting and distribution of government debt instruments issued by such country as such country accords to domestic companies of such country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908b67c1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5342/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain prior acquisitions excepted","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall not apply to the continuation of the prior designation of a company as a primary dealer in government debt instruments if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id908b67c2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5342/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such designation occurred before ","children":[{"tag":"date","attrib":{"date":"1987-07-31"},"text":"July 31, 1987","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id908b67c3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5342/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" before ","children":[{"tag":"date","attrib":{"date":"1987-07-31"},"text":"July 31, 1987","children":[],"tail":"—"}],"tail":null},{"tag":"clause","attrib":{"id":"id908b67c4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5342/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" control of such company was acquired from a person (other than a person of a foreign country) by a person of a foreign country; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id908b67c5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5342/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in conjunction with a person of a foreign country, such company informed the Federal Reserve Bank of New York of the intention of such person to acquire control of such company.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id908b67c6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5342/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for countries having or negotiating bilateral agreements with United States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (b) shall not apply to any person of a foreign country if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id908b67c7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5342/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that country, as of ","children":[{"tag":"date","attrib":{"date":"1987-01-01"},"text":"January 1, 1987","children":[],"tail":", was negotiating a bilateral agreement with the United States under the authority of "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2112/b/4/A"},"text":"section 2112(b)(4)(A) of title 19","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908b67c8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5342/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that country has a bilateral free trade area agreement with the United States which entered into force before ","children":[{"tag":"date","attrib":{"date":"1987-01-01"},"text":"January 1, 1987","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id908b67c9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5342/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Person of a foreign country” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, a person is a “person of a foreign country” if that person, or any other person which directly or indirectly owns or controls that person, is a resident of that country, is organized under the laws of that country, or has its principal place of business in that country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id908b67ca-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5342/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall take effect 12 months after ","children":[{"tag":"date","attrib":{"date":"1988-08-23"},"text":"August 23, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id908b67cb-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tIII/s3502"},"text":"Pub. L. 100–418, title III, § 3502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1386"},"text":"102 Stat. 1386","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
