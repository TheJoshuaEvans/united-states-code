{"tag":"section","attrib":{"id":"id8e91e150-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262k–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"262k–2"},"text":"§ 262k–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Female genital mutilation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8e91e151-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262k–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning 1 year after ","children":[{"tag":"date","attrib":{"date":"1996-09-30"},"text":"September 30, 1996","children":[],"tail":", the Secretary of the Treasury shall instruct the United States Executive Director of each international financial institution to use the voice and vote of the United States to oppose any loan or other utilization of the funds of their respective institution, other than to address basic human needs, for the government of any country which the Secretary of the Treasury determines—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8e91e152-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262k–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has, as a cultural custom, a known history of the practice of female genital mutilation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e91e153-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262k–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not taken steps to implement educational programs designed to prevent the practice of female genital mutilation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8e91e154-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262k–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “International financial institution” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “international financial institution” shall include the institutions identified in section 532(b) of this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8e91e155-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/c/tV/s579"},"text":"Pub. L. 104–208, div. A, title I, § 101(c) [title V, § 579]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-121"},"text":"110 Stat. 3009–121","children":[],"tail":", 3009–170.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8e91e156-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8e91e157-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8e91e158-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 532(b) of this Act, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s532/b"},"text":"section 532(b) of Pub. L. 104–208","children":[],"tail":", div. A, title I, § 101(c) [title V], "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-121"},"text":"110 Stat. 3009–121","children":[],"tail":", 3009–152, which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
