{"tag":"section","attrib":{"id":"id8e9dc88e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–4g"},"text":null,"children":[{"tag":"num","attrib":{"value":"262p–4g"},"text":"§ 262p–4g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Directives regarding government-owned enterprises in countries receiving IADB loans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8e9dc88f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–4g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Congress finds that a principal focus of United States Government policy in the multilateral development banks has been and should be to foster greater development of the private sector in member borrowing countries of such banks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8e9dc890-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–4g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance to transform government-owned enterprises into privately owned enterprises","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to assist and strengthen the advancement of ongoing efforts to have the Inter-American Development Bank play a key role in building a viable private sector in member borrowing countries of such bank, and to further assist such bank in its determination to facilitate the transfer of government-owned enterprises in such countries to private ownership, the Secretary of the Treasury shall instruct the United States Executive Director of such bank to vigorously encourage the provision of technical assistance to such countries to transform enterprises owned, in whole or in part, by the governments of such countries into privately owned, self-sufficient enterprises. Such technical assistance may involve the valuation of the assets of such government-owned enterprises, the assessment of tender offers, and the creation or strengthening of market-based mechanisms to facilitate such a transfer of ownership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8e9dc891-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/118/tXVI/s1612"},"text":"Pub. L. 95–118, title XVI, § 1612","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/240/tII/s206"},"text":"Pub. L. 101–240, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2499"},"text":"103 Stat. 2499","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8e9dc892-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8e9dc893-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id8e9dc894-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/118/s1612"},"text":"section 1612 of Pub. L. 95–118","children":[],"tail":" was renumbered section 1622 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s262p–5"},"text":"section 262p–5 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8e9dc895-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id8e9dc896-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The definitions in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s262p–5"},"text":"section 262p–5 of this title","children":[],"tail":" apply to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
