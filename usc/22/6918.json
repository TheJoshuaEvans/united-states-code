{"tag":"section","attrib":{"id":"id90cbcbd4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6918"},"text":null,"children":[{"tag":"num","attrib":{"value":"6918"},"text":"§ 6918.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff of the Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90cbcbd5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6918/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel and administration committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall have a personnel and administration committee composed of the Chairman, the Cochairman, the senior member of the Commission from the minority party of the House of Representatives, and the senior member of the Commission from the minority party of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90cbcbd6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6918/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Committee functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"All decisions pertaining to the hiring, firing, and fixing of pay of personnel of the Commission shall be by a majority vote of the personnel and administration committee, except that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90cbcbd7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6918/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chairman shall be entitled to appoint and fix the pay of the staff director, and the Cochairman shall be entitled to appoint and fix the pay of the Cochairman’s senior staff member; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90cbcbd8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6918/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chairman and Cochairman shall each have the authority to appoint, with the approval of the personnel and administration committee, at least four professional staff members who shall be responsible to the Chairman or the Cochairman (as the case may be) who appointed them.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Subject to subsection (d), the personnel and administration committee may appoint and fix the pay of such other personnel as it considers desirable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90cbcbd9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6918/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff appointments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All staff appointments shall be made without regard to the provisions of title 5 governing appointments in the competitive service, and without regard to the provisions of chapter 51 and subchapter III of chapter 53 of such title relating to classification and general schedule pay rates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90cbcbda-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6918/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications of professional staff","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The personnel and administration committee shall ensure that the professional staff of the Commission consists of persons with expertise in areas including human rights, internationally recognized worker rights, international economics, law (including international law), rule of law and other foreign assistance programming, Chinese politics, economy and culture, and the Chinese language.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90cbcbdb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6918/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission employees as congressional employees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90cbcbdc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6918/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of pay and other employment benefits, rights, and privileges, and for all other purposes, any employee of the Commission shall be considered to be a congressional employee as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2107"},"text":"section 2107 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90cbcbdd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6918/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive status","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of section 3304(i)(1) ","children":[{"tag":"ref","attrib":{"idref":"fn002357"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002357"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 5, employees of the Commission shall be considered as if they are in positions in which they are paid by the Secretary of the Senate or the Clerk of the House of Representatives."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90cbcbde-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/286/dB/tIII/s308"},"text":"Pub. L. 106–286, div. B, title III, § 308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-10"},"text":"Oct. 10, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/899"},"text":"114 Stat. 899","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/188/s2/a/2/C"},"text":"Pub. L. 118–188, § 2(a)(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2645"},"text":"138 Stat. 2645","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90cbcbdf-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90cbcbe0-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90cbcbe1-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3304/i/1"},"text":"Section 3304(i)(1) of title 5","children":[],"tail":", referred to in subsec. (e)(2), probably means "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3304/c/1"},"text":"section 3304(c)(1) of title 5","children":[],"tail":" prior to the amendments made by "},{"tag":"ref","attrib":{"href":"/us/pl/104/65/s16/a"},"text":"Pub. L. 104–65, § 16(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1995-12-19"},"text":"Dec. 19, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/703"},"text":"109 Stat. 703","children":[],"tail":", which struck out "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3304/c"},"text":"section 3304(c) of title 5","children":[],"tail":" and redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3304/d"},"text":"section 3304(d) of title 5","children":[],"tail":" as 3304(c), and by "},{"tag":"ref","attrib":{"href":"/us/pl/118/188/s2/a/1/A"},"text":"Pub. L. 118–188, § 2(a)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2644"},"text":"138 Stat. 2644","children":[],"tail":", which redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3304/c"},"text":"section 3304(c) of title 5","children":[],"tail":" as section 3304(i). Prior to these amendments, section 3304(c)(1) related to acquisition of competitive status by an individual who served for at least 3 years in the legislative branch in a position in which he was paid by the Secretary of the Senate or the Clerk of the House of Representatives."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90cbcbe2-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/188"},"text":"Pub. L. 118–188","children":[],"tail":" substituted “3304(i)(1)” for “3304(c)(1)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
