{"tag":"section","attrib":{"id":"id906c6e5e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4105"},"text":null,"children":[{"tag":"num","attrib":{"value":"4105"},"text":"§ 4105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management rights","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id906c6e5f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to subsection (b), nothing in this subchapter shall affect the authority of any management official of the Department, in accordance with applicable law—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id906c6e60-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4105/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine the mission, budget, organization, and internal security practices of the Department, and the number of individuals in the Service or in the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6e61-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4105/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to hire, assign, direct, lay off, and retain individuals in the Service or in the Department, to suspend, remove, or take other disciplinary action against such individuals, and to determine the number of members of the Service to be promoted and to remove the name of or delay the promotion of any member in accordance with regulations prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4005/b"},"text":"section 4005(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6e62-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4105/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct reductions in force, and to prescribe regulations for the separation of employees pursuant to such reductions in force conducted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4010a"},"text":"section 4010a of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6e63-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4105/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assign work, to make determinations with respect to contracting out, and to determine the personnel by which the operations of the Department shall be conducted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6e64-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4105/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to fill positions from any appropriate source;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6e65-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4105/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine the need for uniform personnel policies and procedures between or among the agencies to which this subchapter applies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6e66-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4105/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to take whatever actions may be necessary to carry out the mission of the Department during emergencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id906c6e67-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Nothing in this section shall preclude the Department and the exclusive representative from negotiating—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id906c6e68-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4105/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the election of the Department, on the numbers, types, and classes of employees or positions assigned to any organizational subdivision, work project, or tour of duty, or on the technology, methods, and means of performing work;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6e69-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4105/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures which management officials of the Department will observe in exercising any function under this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6e6a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4105/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate arrangements for employees adversely affected by the exercise of any function under this section by such management officials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id906c6e6b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s1005"},"text":"Pub. L. 96–465, title I, § 1005","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2131"},"text":"94 Stat. 2131","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s181/b"},"text":"Pub. L. 103–236, title I, § 181(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/417"},"text":"108 Stat. 417","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/415/s1/jj/2"},"text":"Pub. L. 103–415, § 1(jj)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4303"},"text":"108 Stat. 4303","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id906c6e6c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id906c6e6d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id906c6e6e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(3) to (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/103/415"},"text":"Pub. L. 103–415","children":[],"tail":", added par. (3) and redesignated former pars. (3) to (6) as (4) to (7), respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
