{"tag":"section","attrib":{"id":"id8ff06053-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2665b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2665b"},"text":"§ 2665b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Veterans Innovation Partnership Fellowship Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ff06054-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2665b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be in the Department a Veterans Innovation Partnership Fellowship Program (hereinafter in this section referred to as the “VIP Fellowship Program”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff06055-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2665b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Congress finds that the VIP Fellowship Program plays a vital role in providing veterans with professional experience, training, and pathways to careers in international affairs, while strengthening the Department’s recruitment of skilled, diverse, and service-minded personnel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff06056-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2665b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Objectives","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program required by subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ff06057-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2665b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expand opportunities for veterans to gain professional experience in diplomacy, development, and international cooperation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff06058-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2665b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leverage the skills, leadership, and expertise of veterans to enhance the work of the Department and other participating agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff06059-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2665b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the transition of veterans into public service careers, particularly in foreign affairs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff0605a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2665b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The program required by subsection (a) shall be administered by the Department, consistent with existing law and regulations, and in coordination with relevant Federal departments and agencies and veteran-serving organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ff0605b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dE/tI/s5133"},"text":"Pub. L. 119–60, div. E, title I, § 5133","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1567"},"text":"139 Stat. 1567","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ff0605c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ff0605d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id8ff0605e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “Department” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s5002"},"text":"section 5002 of Pub. L. 119–60","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
