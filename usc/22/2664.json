{"tag":"section","attrib":{"id":"id8ff06037-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2664"},"text":null,"children":[{"tag":"num","attrib":{"value":"2664"},"text":"§ 2664.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of duties of officers, clerks, and employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of State may prescribe duties for the Assistant Secretaries and the clerks of bureaus, as well as for all the other employees in the department, and may make changes and transfers therein when, in his judgment, it becomes necessary.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ff06038-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1874-06-20/ch328"},"text":"June 20, 1874, ch. 328","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/18/90"},"text":"18 Stat. 90","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1924-05-24/ch182/s30"},"text":"May 24, 1924, ch. 182, § 30","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1931-02-23/ch276/s7"},"text":"Feb. 23, 1931, ch. 276, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/1214"},"text":"46 Stat. 1214","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ff06039-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ff0603a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8ff0603b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s154"},"text":"section 154 of Title 5","children":[],"tail":" prior to the general revision and enactment of Title 5, Government Organization and Employees, by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s1"},"text":"Pub. L. 89–554, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/378"},"text":"80 Stat. 378","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions of this section which related to the Solicitor of the Department were omitted in view of act ","children":[{"tag":"date","attrib":{"date":"1924-05-24"},"text":"May 24, 1924","children":[],"tail":", which abolished the office."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
