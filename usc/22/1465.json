{"tag":"section","attrib":{"id":"id8f01e130-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1465"},"text":null,"children":[{"tag":"num","attrib":{"value":"1465"},"text":"§ 1465.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional findings and declaration of purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress finds and declares—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f01e131-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1465/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that it is the policy of the United States to support the right of the people of Cuba to seek, receive, and impart information and ideas through any media and regardless of frontiers, in accordance with article 19 of Universal Declaration of Human Rights;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f01e132-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1465/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that, consonant with this policy, radio broadcasting to Cuba may be effective in furthering the open communication of accurate information and ideas to the people of Cuba, in particular information about Cuba;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f01e133-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1465/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that such broadcasting to Cuba, operated in a manner not inconsistent with the broad foreign policy of the United States and in accordance with high professional standards, would be in the national interest; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f01e134-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1465/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the Voice of America already broadcasts to Cuba information that represents America, not any single segment of American society, and includes a balanced and comprehensive projection of significant American thought and institutions but that there is a need for broadcasts to Cuba which provide news, commentary and other information about events in Cuba and elsewhere to promote the cause of freedom in Cuba.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f01e135-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/111/s2"},"text":"Pub. L. 98–111, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-10-04"},"text":"Oct. 4, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/749"},"text":"97 Stat. 749","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f01e136-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id8f01e137-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeal of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section repealed upon transmittal of determination by President under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6063/c/3"},"text":"section 6063(c)(3) of this title","children":[],"tail":" that democratically elected government in Cuba is in power, see "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6037/c"},"text":"section 6037(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f01e138-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8f01e139-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Radio Broadcasting to Cuba Act which comprises this subchapter, and not as part of the United States Information and Educational Exchange Act of 1948 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f01e13a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id8f01e13b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/111/s1"},"text":"Pub. L. 98–111, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-10-04"},"text":"Oct. 4, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/749"},"text":"97 Stat. 749","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/111/s1"},"text":"“That this Act [enacting this subchapter] may be cited as the ‘Radio Broadcasting to Cuba Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
