{"tag":"section","attrib":{"id":"id8ee55935-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290o"},"text":null,"children":[{"tag":"num","attrib":{"value":"290o"},"text":"§ 290o.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of membership","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President is hereby authorized to accept membership for the United States in the Bank for Economic Cooperation and Development in the Middle East and North Africa (in this subchapter referred to as the “Bank”) provided for by the agreement establishing the Bank (in this subchapter referred to as the “Agreement”), signed on ","children":[{"tag":"date","attrib":{"date":"1996-05-31"},"text":"May 31, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ee55936-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/c/tVII/s702"},"text":"Pub. L. 104–208, div. A, title I, § 101(c) [title VII, § 702]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-121"},"text":"110 Stat. 3009–121","children":[],"tail":", 3009–179.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ee55937-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ee55938-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8ee55939-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text"