{"tag":"section","attrib":{"id":"id8f1e917e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1896b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1896b"},"text":"§ 1896b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Colombo Plan Council for Technical Cooperation; authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"To enable the United States to maintain membership in the Colombo Plan Council for Technical Cooperation, there is authorized to be appropriated from time to time to the Department of State such sums as may be necessary for the payment by the United States of its share of the expenses of the Colombo Plan Council for Technical Cooperation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f1e917f-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/108"},"text":"Pub. L. 86–108","children":[],"tail":", ch. V, § 502, "},{"tag":"date","attrib":{"date":"1959-07-24"},"text":"July 24, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/256"},"text":"73 Stat. 256","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f1e9180-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f1e9181-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8f1e9182-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Mutual Security Act of 1959.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":