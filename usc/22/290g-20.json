{"tag":"section","attrib":{"id":"id8ede2cd7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–20"},"text":null,"children":[{"tag":"num","attrib":{"value":"290g–20"},"text":"§ 290g–20.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Twelfth replenishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ede2cd8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–20/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Governor of the Fund is authorized to contribute on behalf of the United States $585,000,000 to the twelfth replenishment of the resources of the Fund, subject to obtaining the necessary appropriations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ede2cd9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–20/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to pay for the United States contribution provided for in subsection (a), there are authorized to be appropriated, without fiscal year limitation, $585,000,000 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ede2cda-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/302/tII/s221"},"text":"Pub. L. 94–302, title II, § 221","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/74/dI/tVII/s7083/b"},"text":"Pub. L. 112–74, div. I, title VII, § 7083(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-23"},"text":"Dec. 23, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1263"},"text":"125 Stat. 1263","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
