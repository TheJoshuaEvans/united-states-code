{"tag":"section","attrib":{"id":"id90f91dcb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8243"},"text":null,"children":[{"tag":"num","attrib":{"value":"8243"},"text":"§ 8243.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel policies at the Department of State","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In addition to the awards and other incentives already implemented, the Secretary should increase incentives for members of the Foreign Service and other employees of the Department who take assignments relating to the promotion of democracy and the protection of human rights, including the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90f91dcc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8243/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing performance pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3965"},"text":"section 3965 of this title","children":[],"tail":" to such members and employees who carry out their assignment in an outstanding manner."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f91dcd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8243/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Considering such an assignment as a basis for promotion into the Senior Foreign Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f91dce-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8243/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing Foreign Service Awards under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4013"},"text":"section 4013 of this title","children":[],"tail":" to such members and employees who provide distinguished or meritorious service in the promotion of democracy or the protection of human rights."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90f91dcf-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/tXXI/s2143"},"text":"Pub. L. 110–53, title XXI, § 2143","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/535"},"text":"121 Stat. 535","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
