{"tag":"section","attrib":{"id":"id9037f0b7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3382"},"text":null,"children":[{"tag":"num","attrib":{"value":"3382"},"text":"§ 3382.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this subchapter are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9037f0b8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3382/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to further strengthen the United States-Taiwan strategic partnership and broaden understanding of the Indo-Pacific region by temporarily assigning officials of any agencies of the United States Government to Taiwan for intensive study in Mandarin and placement as Fellows in a Taiwanese civic institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9037f0b9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3382/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to provide for eligible United States personnel—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9037f0ba-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3382/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to learn or strengthen Mandarin Chinese language skills; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9037f0bb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3382/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to expand their understanding of the political economy of Taiwan and the Indo-Pacific region; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9037f0bc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3382/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to better position the United States to advance its economic, security, and human rights interests and values in the Indo-Pacific region.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9037f0bd-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLV/s5528"},"text":"Pub. L. 117–263, div. E, title LV, § 5528","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3325"},"text":"136 Stat. 3325","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
