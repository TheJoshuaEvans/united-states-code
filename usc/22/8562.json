{"tag":"section","attrib":{"id":"id910504e1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8562"},"text":null,"children":[{"tag":"num","attrib":{"value":"8562"},"text":"§ 8562.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id910504e2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8562/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Admission; admitted; alien","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “admission”, “admitted”, and “alien” have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of title 8","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910504e3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8562/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id910504e4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8562/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Banking, Housing, and Urban Affairs, the Committee on Foreign Relations, the Committee on the Judiciary, and the Select Committee on Intelligence of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910504e5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8562/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Financial Services, the Committee on Foreign Affairs, the Committee on the Judiciary, and the Permanent Select Committee on Intelligence of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910504e6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8562/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Correspondent account; payable-through account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “correspondent account” and “payable-through account” have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s5318A"},"text":"section 5318A of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910504e7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8562/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign financial institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “foreign financial institution” has the meaning of that term as determined by the Secretary of the Treasury pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8513/i"},"text":"section 8513(i) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910504e8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8562/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “foreign person” means any individual or entity that is not a United States person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910504e9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8562/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States person","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “United States person” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id910504ea-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8562/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a United States citizen or an alien lawfully admitted for permanent residence to the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910504eb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8562/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity organized under the laws of the United States or any jurisdiction within the United States, including a foreign branch of such an entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id910504ec-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dAA/tII/s203"},"text":"Pub. L. 117–328, div. AA, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5532"},"text":"136 Stat. 5532","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id910504ed-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id910504ee-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id910504ef-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Masih Alinejad Harassment and Unlawful Targeting Act of 2022, also known as the Masih Alinejad HUNT Act of 2022, and not as part of the Comprehensive Iran Sanctions, Accountability, and Divestment Act of 2010 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
