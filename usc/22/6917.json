{"tag":"section","attrib":{"id":"id90cbcbcc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6917"},"text":null,"children":[{"tag":"num","attrib":{"value":"6917"},"text":"§ 6917.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations for the Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90cbcbcd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6917/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization; disbursements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90cbcbce-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6917/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Commission for fiscal year 2001, and each fiscal year thereafter, such sums as may be necessary to enable it to carry out its functions. Appropriations to the Commission are authorized to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90cbcbcf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6917/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disbursements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Appropriations to the Commission shall be disbursed on vouchers approved—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90cbcbd0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6917/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" jointly by the Chairman and the Cochairman; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90cbcbd1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6917/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by a majority of the members of the personnel and administration committee established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6918"},"text":"section 6918 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90cbcbd2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6917/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign travel for official purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Foreign travel for official purposes by members and staff of the Commission may be authorized by either the Chairman or the Cochairman.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90cbcbd3-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/286/dB/tIII/s307"},"text":"Pub. L. 106–286, div. B, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-10"},"text":"Oct. 10, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/899"},"text":"114 Stat. 899","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
