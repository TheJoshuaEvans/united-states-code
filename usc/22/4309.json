{"tag":"section","attrib":{"id":"id9075e44d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4309"},"text":null,"children":[{"tag":"num","attrib":{"value":"4309"},"text":"§ 4309.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to public international organizations and official missions to such organizations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9075e44e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4309/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4306"},"text":"section 4306 of this title","children":[],"tail":", or any other provision of this chapter, applicable with respect to an international organization to the same extent that it is applicable with respect to a foreign mission if the Secretary determines that such application is necessary to carry out the policy set forth in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4301/b"},"text":"section 4301(b) of this title","children":[],"tail":" and to further the objectives set forth in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4304/b"},"text":"section 4304(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9075e44f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4309/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “International organization” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, “international organization” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9075e450-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4309/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public international organization designated as such pursuant to the International Organizations Immunities Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s288"},"text":"22 U.S.C. 288","children":[],"tail":"—288f–2) or a public international organization created pursuant to a treaty or other international agreement as an instrument through or by which two or more foreign governments engage in some aspect of their conduct of international affairs; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9075e451-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4309/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an official mission (other than a United States mission) to such a public international organization,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"including any real property of such an organization or mission and including the personnel of such an organization or mission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9075e452-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch841"},"text":"Aug. 1, 1956, ch. 841","children":[],"tail":", title II, § 209, as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/241/tII/s202/b"},"text":"Pub. L. 97–241, title II, § 202(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-08-24"},"text":"Aug. 24, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/289"},"text":"96 Stat. 289","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9075e453-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9075e454-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9075e455-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The International Organizations Immunities Act, referred to in subsec. (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-12-29/ch652/tI"},"text":"act Dec. 29, 1945, ch. 652, title I","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/59/669"},"text":"59 Stat. 669","children":[],"tail":", which is classified principally to subchapter XVIII (§ 288 et seq.) of chapter 7 of this title. For complete classification of that Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s288"},"text":"section 288 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9075e456-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id9075e457-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1982-10-01"},"text":"Oct. 1, 1982","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/241/s204"},"text":"section 204 of Pub. L. 97–241","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4301"},"text":"section 4301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
