{"tag":"section","attrib":{"id":"id8f7def46-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2292"},"text":null,"children":[{"tag":"num","attrib":{"value":"2292"},"text":"§ 2292.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f7def47-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2292/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Congress, recognizing that prompt United States assistance to alleviate human suffering caused by natural and manmade disasters is an important expression of the humanitarian concern and tradition of the people of the United States, affirms the willingness of the United States to provide assistance for the relief and rehabilitation of people and countries affected by such disasters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f7def48-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2292/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to limitations in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2292a"},"text":"section 2292a of this title","children":[],"tail":", and notwithstanding any other provision of this chapter or any other Act, the President is authorized to furnish assistance to any foreign country, international organization, or private voluntary organization, on such terms and conditions as he may determine, for international disaster relief and rehabilitation, including assistance relating to disaster preparedness, and to the prediction of, and contingency planning for, natural disasters abroad."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f7def49-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2292/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency Food Security Program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f7def4a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2292/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the limitations in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2292a"},"text":"section 2292a of this title","children":[],"tail":", and notwithstanding any other provision of this chapter or any other Act, the President is authorized to make available emergency food assistance, including in the form of funds, transfers, vouchers, and agricultural commodities (including products derived from agricultural commodities) acquired through local or regional procurement, to meet emergency food needs arising from manmade and natural disasters."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f7def4b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2292/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available under this subsection shall be known as the “International Disaster Assistance – Emergency Food Security Program”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f7def4c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2292/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific direction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the provisions of this section the President shall insure that the assistance provided by the United States shall, to the greatest extent possible, reach those most in need of relief and rehabilitation as a result of natural and manmade disasters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f7def4d-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. I, § 491, as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/161/tI/s101/3"},"text":"Pub. L. 94–161, title I, § 101(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-20"},"text":"Dec. 20, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/849"},"text":"89 Stat. 849","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/424/tI/s118/a"},"text":"Pub. L. 95–424, title I, § 118(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-06"},"text":"Oct. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/953"},"text":"92 Stat. 953","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/533/tIV/s404/b"},"text":"Pub. L. 96–533, title IV, § 404(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-16"},"text":"Dec. 16, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3150"},"text":"94 Stat. 3150","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/195/s7/c/1"},"text":"Pub. L. 114–195, § 7(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-20"},"text":"July 20, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/681"},"text":"130 Stat. 681","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f7def4e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f7def4f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8f7def50-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (b) and (c)(1), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/424"},"text":"75 Stat. 424","children":[],"tail":", known as the Foreign Assistance Act of 1961. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id8f7def51-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195/s491"},"text":"section 491 of Pub. L. 87–195","children":[],"tail":", pt. I, as added "},{"tag":"ref","attrib":{"href":"/us/pl/92/226"},"text":"Pub. L. 92–226","children":[],"tail":", pt. I, § 109, "},{"tag":"date","attrib":{"date":"1972-02-07"},"text":"Feb. 7, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/24"},"text":"86 Stat. 24","children":[],"tail":", provided for East Pakistan refugee relief assistance, including appropriations authorization of $250,000,000 for fiscal year 1972, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/94/161/s101/2"},"text":"section 101(2) of Pub. L. 94–161","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f7def52-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/195"},"text":"Pub. L. 114–195","children":[],"tail":" added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/533"},"text":"Pub. L. 96–533","children":[],"tail":" substituted “limitations” for “limitation on appropriations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/424"},"text":"Pub. L. 95–424","children":[],"tail":" substituted “, international organization, or private voluntary organization” for “or international organization”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f803943-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8f803944-2930-11f1-8918-be39dde81dc6"},"text":null,"childre