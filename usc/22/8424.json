{"tag":"section","attrib":{"id":"id90fb67f5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8424"},"text":null,"children":[{"tag":"num","attrib":{"value":"8424"},"text":"§ 8424.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pakistan Counterinsurgency Capability Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90fb67f6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8424/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" For fiscal year 2010","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90fb67f7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8424/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For fiscal year 2010, the Department of State’s Pakistan Counterinsurgency Capability Fund established under the Supplemental Appropriations Act, 2009 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/32"},"text":"Public Law 111–32","children":[],"tail":"), hereinafter in this section referred to as the “Fund”, shall consist of the following:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90fb67f8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8424/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts appropriated to carry out this subsection (which may not include any amounts appropriated to carry out subchapter I of this chapter).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90fb67f9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8424/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts otherwise available to the Secretary of State to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90fb67fa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8424/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes of Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts in the Fund made available to carry out this subsection for any fiscal year are authorized to be used by the Secretary of State, with the concurrence of the Secretary of Defense, to build and maintain the counterinsurgency capability of Pakistan under the same terms and conditions (except as otherwise provided in this subsection) that are applicable to amounts made available under the Fund for fiscal year 2009.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90fb67fb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8424/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer authority","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90fb67fc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8424/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State is authorized to transfer amounts in the Fund made available to carry out this subsection for any fiscal year to the Department of Defense’s Pakistan Counterinsurgency Fund established under the Supplemental Appropriations Act, 2009 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/32"},"text":"Public Law 111–32","children":[],"tail":") and such amounts may be transferred back to the Fund if the Secretary of Defense, with the concurrence of the Secretary of State, determines that such amounts are not needed for the purposes for which initially transferred."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90fb67fd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8424/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of transferred funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsections (d) and (e) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8423"},"text":"section 8423 of this title","children":[],"tail":", transfers from the Fund under the authority of subparagraph (A) shall be merged with and be available for the same purposes and for the same time period as amounts in the Department of Defense’s Pakistan Counterinsurgency Fund."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90fb67fe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8424/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to other authorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority to provide assistance under this subsection is in addition to any other authority to provide assistance to foreign countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90fb67ff-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8424/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall, not less than 15 days prior to making transfers from the Fund under subparagraph (A), notify the appropriate congressional committees in writing of the details of any such transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90fb6800-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8424/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of notifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any notification required by this section may be submitted in classified or unclassified form, as necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90fb6801-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8424/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90fb6802-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8424/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations, the Committee on Armed Services, and the Committee on Foreign Affairs of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90fb6803-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8424/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations, the Committee on Armed Services, and the Committee on Foreign Relations of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90fb6804-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/73/tII/s204"},"text":"Pub. L. 111–73, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-15"},"text":"Oct. 15, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2072"},"text":"123 Stat. 2072","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90fb6805-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90fb6806-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90fb6807-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Supplemental Appropriations Act, 2009, referred to in subsec. (a)(1), (3)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/32"},"text":"Pub. L. 111–32","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-06-24"},"text":"June 24, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1859"},"text":"123 Stat. 1859","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
