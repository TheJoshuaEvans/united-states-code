{"tag":"section","attrib":{"id":"id9065423c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069b"},"text":null,"children":[{"tag":"num","attrib":{"value":"4069b"},"text":"§ 4069b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Survivor benefits for certain former spouses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9065423d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility; amount of annuity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any individual who was a former spouse of a participant or former participant on ","children":[{"tag":"date","attrib":{"date":"1981-02-14"},"text":"February 14, 1981","children":[],"tail":", shall be entitled, to the extent or in such amounts as are provided in advance in appropriations Acts, and except to the extent such former spouse is disqualified under subsection (b), to a survivor annuity equal to 55 percent of the greater of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id9065423e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the full amount of the participant’s or former participant’s annuity, as computed under this subchapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9065423f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the full amount of what such annuity as so computed would be if the participant or former participant had not withdrawn a lump-sum portion of contributions made with respect to such annuity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90654240-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election by former spouse","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an election has been made with respect to such former spouse under section 4159 or 4046(f) of this title, then the survivor annuity under subsection (a) of such former spouse shall be equal to the full amount of the participant’s or former participant’s annuity referred to in subsection (a) less the amount of such election.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90654241-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disqualification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A former spouse shall not be entitled to a survivor annuity under this section if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90654242-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the former spouse remarries before age 55; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90654243-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the former spouse was not married to the participant at least 10 years during service of the participant which is creditable under this subchapter with at least 5 years occurring while the participant was a member of the Foreign Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90654244-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of entitlement; application approval and payment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90654245-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The entitlement of a former spouse to a survivor annuity under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90654246-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069b/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall commence—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90654247-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069b/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a former spouse of a participant or former participant who is deceased as of ","children":[{"tag":"date","attrib":{"date":"1987-12-22"},"text":"December 22, 1987","children":[],"tail":", beginning on "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"December 22, 1987","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90654248-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069b/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of any other former spouse, beginning on the later of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id90654249-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069b/d/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date that the participant or former participant to whom the former spouse was married dies; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id9065424a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069b/d/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"1987-12-22"},"text":"December 22, 1987","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9065424b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069b/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall terminate on the last day of the month before the former spouse’s death or remarriage before attaining the age 55.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9065424c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9065424d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069b/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A survivor annuity under this section shall not be payable unless appropriate written application is provided to the Secretary, complete with any supporting documentation which the Secretary may by regulation require, within 30 months after ","children":[{"tag":"date","attrib":{"date":"1987-12-22"},"text":"December 22, 1987","children":[],"tail":". The Secretary may waive the 30-month application requirement under this subparagraph in any case in which the Secretary determines that the circumstances so warrant."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9065424e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069b/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon approval of an application provided under subparagraph (A), the appropriate survivor annuity shall be payable to the former spouse with respect to all periods before such approval during which the former spouse was entitled to such annuity under this section, but in no event shall a survivor annuity be payable under this section with respect to any period before ","children":[{"tag":"date","attrib":{"date":"1987-12-22"},"text":"December 22, 1987","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9065424f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promulgation of regulations; notification of rights","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90654250-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as soon as possible, but not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"1987-12-22"},"text":"December 22, 1987","children":[],"tail":", issue such regulations as may be necessary to carry out this section; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90654251-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, and as soon as possible, inform each individual who was a former spouse of a participant or former participant on ","children":[{"tag":"date","attrib":{"date":"1981-02-14"},"text":"February 14, 1981","children":[],"tail":", of any rights which such individual may have under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90654252-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of section on annuity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to impair, reduce, or otherwise affect the annuity or the entitlement to an annuity of a participant or former participant under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90654253-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069b/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Former spouses of United States Information Agency and Agency for International Development employees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any individual who on ","children":[{"tag":"date","attrib":{"date":"1981-02-14"},"text":"February 14, 1981","children":[],"tail":", was an otherwise qualified former spouse pursuant to this section, but who was married to a former Foreign Service employee of the United States Information Agency or of the Agency of International Development, shall be entitled to benefits under this section if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90654254-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069b/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the former employee retired from the Civil Service Retirement and Disability System on a date before his employing agency could legally participate in the Foreign Service Retirement and Disability System; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90654255-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069b/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the marriage included at least five years during which the employee was assigned overseas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90654256-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s831"},"text":"Pub. L. 96–465, title I, § 831","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/204/tI/s188/a"},"text":"Pub. L. 100–204, title I, § 188(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1370"},"text":"101 Stat. 1370","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/246/tI/s146/b"},"text":"Pub. L. 101–246, title I, § 146(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-02-16"},"text":"Feb. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/37"},"text":"104 Stat. 37","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90654257-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90654258-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id90654259-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 831 of the Foreign Service Act of 1980 was enacted by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/238"},"text":"Pub. L. 100–238","children":[],"tail":" and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4069a–1"},"text":"section 4069a–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9065425a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/246"},"text":"Pub. L. 101–246","children":[],"tail":" added subsec. (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9065425b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id9065425c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"United States Information Agency (other than Broadcasting Board of Governors and International Broadcasting Bureau) abolished and functions transferred to Secretary of State, see sections 6531 and 6532 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
