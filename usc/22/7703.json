ldren":[],"tail":". Subsec. (b)(4)(B) of "},{"tag":"ref","attrib":{"href":"/us/pl/108/199/dD/s604"},"text":"section 604 of div. D of Pub. L. 108–199","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90eac6c9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/167"},"text":"Pub. L. 115–167","children":[],"tail":" amended subpar. (B) generally. Prior to amendment, text read as follows: “Each member of the Board described in paragraph (3)(B) shall be appointed for a term of 3 years and may be reappointed for a term of an additional 2 years.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
