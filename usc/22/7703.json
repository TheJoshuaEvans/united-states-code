{"tag":"section","attrib":{"id":"id90eac698-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703"},"text":null,"children":[{"tag":"num","attrib":{"value":"7703"},"text":"§ 7703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and management of the Millennium Challenge Corporation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90eac699-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the executive branch a corporation to be known as the “Millennium Challenge Corporation” that shall be responsible for carrying out this chapter. The Corporation shall be a government corporation, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s103"},"text":"section 103 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90eac69a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief Executive Officer","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90eac69b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be in the Corporation a Chief Executive Officer who shall be responsible for the management of the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90eac69c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90eac69d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), the Chief Executive Officer shall be appointed by the President, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90eac69e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interim CEO","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of the Board of Directors described in subsection (c)(3)(A) may designate by unanimous consent in writing an individual who is an officer within any Federal department or agency (and who has been appointed to such position by the President, by and with the advice and consent of the Senate) to carry out the duties described in this subsection until the Chief Executive Officer is appointed pursuant to subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90eac69f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Executive Officer shall report to and be under the direct authority of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90eac6a0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation and rank","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90eac6a1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Executive Officer shall be compensated at the rate provided for level II of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of title 5","children":[],"tail":" and shall have the equivalent rank of Deputy Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90eac6a2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90eac6a3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorities and duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Executive Officer shall be responsible for the management of the Corporation and shall exercise the powers and discharge the duties of the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90eac6a4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to appoint officers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In consultation and with approval of the Board, the Chief Executive Officer shall appoint all officers of the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90eac6a5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of Directors","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90eac6a6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be in the Corporation a Board of Directors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90eac6a7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall perform the functions specified to be carried out by the Board in this chapter and may prescribe, amend, and repeal bylaws, rules, regulations, and procedures governing the manner in which the business of the Corporation may be conducted and in which the powers granted to it by law may be exercised.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90eac6a8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall consist of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90eac6a9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of State, the Secretary of the Treasury, the Administrator of the United States Agency for International Development, the Chief Executive Officer of the Corporation, and the United States Trade Representative; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90eac6aa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" four other individuals with relevant international experience who shall be appointed by the President, by and with the advice and consent of the Senate, of which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90eac6ab-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one individual should be appointed from among a list of individuals submitted by the majority leader of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90eac6ac-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one individual should be appointed from among a list of individuals submitted by the minority leader of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90eac6ad-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703/c/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one individual should be appointed from among a list of individuals submitted by the majority leader of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90eac6ae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703/c/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one individual should be appointed from among a list of individuals submitted by the minority leader of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90eac6af-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90eac6b0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officers of the Federal Government","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member of the Board described in paragraph (3)(A) shall serve for a term that is concurrent with the term of service of the individual’s position as an officer within the other Federal department or agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90eac6b1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each member of the Board described in paragraph (3)(B)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90eac6b2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703/c/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be appointed for a term of 3 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90eac6b3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703/c/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be reappointed for a term of an additional 2 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90eac6b4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703/c/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may continue to serve in each such appointment until the earlier of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id90eac6b5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703/c/4/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which his or her successor is appointed; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id90eac6b6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703/c/4/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date that is 1 year after the expiration of his or her appointment or reappointment, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90eac6b7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A vacancy in the Board shall be filled in the manner in which the original appointment was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90eac6b8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be a Chairperson of the Board. The Secretary of State shall serve as the Chairperson.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90eac6b9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A majority of the members of the Board shall constitute a quorum, which, except with respect to a meeting of the Board during the 135-day period beginning on ","children":[{"tag":"date","attrib":{"date":"2004-01-23"},"text":"January 23, 2004","children":[],"tail":", shall include at least one member of the Board described in paragraph (3)(B)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90eac6ba-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall meet at the call of the Chairperson.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90eac6bb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90eac6bc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703/c/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officers of the Federal Government","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90eac6bd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703/c/8/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Board described in paragraph (3)(A) may not receive additional pay, allowances, or benefits by reason of the member’s service on the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90eac6be-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703/c/8/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each such member of the Board shall receive travel expenses, including per diem in lieu of subsistence, in accordance with applicable provisions under subchapter I of chapter 57 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90eac6bf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703/c/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other members","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90eac6c0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703/c/8/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in clause (ii), a member of the Board described in paragraph (3)(B)—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id90eac6c1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703/c/8/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be paid compensation out of funds made available for the purposes of this chapter at the daily equivalent of the highest rate payable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":" for each day (including travel time) during which the member is engaged in the actual performance of duties as a member of the Board; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id90eac6c2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703/c/8/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while away from the member’s home or regular place of business on necessary travel in the actual performance of duties as a member of the Board, shall be paid per diem, travel, and transportation expenses in the same manner as is provided under subchapter I of chapter 57 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90eac6c3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7703/c/8/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Board may not be paid compensation under clause (i)(II) for more than 90 days in any calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90eac6c4-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/dD/tVI/s604"},"text":"Pub. L. 108–199, div. D, title VI, § 604","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/212"},"text":"118 Stat. 212","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/167/tII/s202"},"text":"Pub. L. 115–167, title II,