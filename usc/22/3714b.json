{"tag":"section","attrib":{"id":"id9043d81c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3714b"},"text":null,"children":[{"tag":"num","attrib":{"value":"3714b"},"text":"§ 3714b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Printing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9043d81d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3714b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sections 501 through 517 and 1101 through 1123 of title 44 shall not apply to direct purchase by the Commission for its use of printing, binding, and blank-book work in the Republic of Panama when the Commission determines that such direct purchase is in the best interest of the Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9043d81e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3714b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section shall not affect the Commission’s authority, under chapter 5 of title 44, to operate a field printing plant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9043d81f-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70/tI/s1306"},"text":"Pub. L. 96–70, title I, § 1306","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dC/tXXXV/s3540"},"text":"Pub. L. 104–201, div. C, title XXXV, § 3540","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2866"},"text":"110 Stat. 2866","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dC/tXXXV/s3549"},"text":"Pub. L. 105–85, div. C, title XXXV, § 3549","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2073"},"text":"111 Stat. 2073","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9043d820-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9043d821-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90464822-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" substituted “Sections 501 through 517 and 1101 through 1123” for “Section 501”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
