{"tag":"section","attrib":{"id":"id90cbcbc8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6915"},"text":null,"children":[{"tag":"num","attrib":{"value":"6915"},"text":"§ 6915.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditure of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For each fiscal year for which an appropriation is made to the Commission, the Commission shall issue a report to the Congress on its expenditures under that appropriation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id90cbcbc9-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/286/dB/tIII/s305"},"text":"Pub. L. 106–286, div. B, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-10"},"text":"Oct. 10, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/899"},"text":"114 Stat. 899","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
