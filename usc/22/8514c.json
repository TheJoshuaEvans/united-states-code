{"tag":"section","attrib":{"id":"id910293b4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514c"},"text":null,"children":[{"tag":"num","attrib":{"value":"8514c"},"text":"§ 8514c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of sanctions with respect to persons engaged in the diversion of goods intended for the people of Iran","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id910293b5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of sanctions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id910293b6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall impose sanctions described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8514/c"},"text":"section 8514(c) of this title","children":[],"tail":" with respect to each person on the list required by subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910293b7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirement to impose sanctions under paragraph (1) shall not include the authority to impose sanctions on the importation of goods.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id910293b8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" List of persons who engage in diversion","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id910293b9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As relevant information becomes available, the President shall submit to the appropriate congressional committees a list of persons that the President determines have, on or after ","children":[{"tag":"date","attrib":{"date":"2013-01-02"},"text":"January 2, 2013","children":[],"tail":", engaged in corruption or other activities relating to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id910293ba-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514c/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the diversion of goods, including agricultural commodities, food, medicine, and medical devices, intended for the people of Iran; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910293bb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514c/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the misappropriation of proceeds from the sale or resale of such goods.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910293bc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of report; public availability","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id910293bd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514c/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The list required by paragraph (1) shall be submitted in unclassified form but may contain a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910293be-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514c/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The unclassified portion of the list required by paragraph (1) shall be made available to the public and posted on the websites of the Department of the Treasury and the Department of State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id910293bf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Good defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “good” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8801/a"},"text":"section 8801(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id910293c0-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/195/tI/s105C"},"text":"Pub. L. 111–195, title I, § 105C","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tXII/s1249/a"},"text":"Pub. L. 112–239, div. A, title XII, § 1249(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2015"},"text":"126 Stat. 2015","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id910293c1-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id910293c2-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id910293c3-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of certain functions and authorities vested in the President by this section, see Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2013-06-03"},"text":"June 3, 2013","children":[],"tail":", 78 F.R. 35545, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s8801"},"text":"section 8801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
