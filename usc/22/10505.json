{"tag":"section","attrib":{"id":"id91587bf0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10505"},"text":null,"children":[{"tag":"num","attrib":{"value":"10505"},"text":"§ 10505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of embassy anti-corruption points of contact","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id91587bf1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10505/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall annually designate an anti-corruption point of contact at the United States diplomatic post to each country identified pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s10502/b"},"text":"section 10502(b) of this title","children":[],"tail":", or which the Secretary otherwise determines is in need of such a point of contact. The point of contact shall be the chief of mission or the chief of mission’s designee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91587bf2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10505/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each anti-corruption point of contact designated under subsection (a) shall be responsible for enhancing coordination and promoting the implementation of a whole-of-government approach among the relevant Federal departments and agencies undertaking efforts to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91587bf3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10505/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote good governance in foreign countries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91587bf4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10505/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" enhance the ability of such countries—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91587bf5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10505/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to combat public corruption; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91587bf6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10505/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop and implement corruption risk assessment tools and mitigation strategies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91587bf7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10505/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall implement appropriate training for anti-corruption points of contact designated under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id91587bf8-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dE/tLIV/s5406"},"text":"Pub. L. 118–31, div. E, title LIV, § 5406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/947"},"text":"137 Stat. 947","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
