<note style="-uslm-lc:I74" role="crossHeading" topic="editorialNotes" id="id8ee09e09-2930-11f1-8918-be39dde81dc6"><heading class="centered"><b>Editorial Notes</b></heading></note>
<note style="-uslm-lc:I74" topic="amendments" id="id8ee09e0a-2930-11f1-8918-be39dde81dc6"><heading class="centered smallCaps">Amendments</heading><p style="-uslm-lc:I21" class="indent0">2014—<ref href="/us/pl/113/76">Pub. L. 113–76</ref> inserted “United States” before “African Development”.</p>
</note>
</notes>
