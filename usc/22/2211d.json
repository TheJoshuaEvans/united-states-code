{"tag":"section","attrib":{"id":"id8f686b75-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2211d"},"text":null,"children":[{"tag":"num","attrib":{"value":"2211d"},"text":"§ 2211d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional authorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, amounts made available for development assistance for micro, small, and medium-sized enterprises under any provision of law other than this subpart may be provided to further the purposes of this subpart. To the extent assistance described in the preceding sentence is provided in accordance with such sentence, the Administrator of the Agency shall include, as part of the report required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2214"},"text":"section 2214 of this title","children":[],"tail":", a detailed description of such assistance."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f686b76-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. I, § 255, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/484/s3"},"text":"Pub. L. 108–484, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-23"},"text":"Dec. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3926"},"text":"118 Stat. 3926","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/428/s4/e"},"text":"Pub. L. 115–428, § 4(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-09"},"text":"Jan. 9, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5514"},"text":"132 Stat. 5514","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f686b77-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f686b78-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f686b79-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/428"},"text":"Pub. L. 115–428","children":[],"tail":" substituted “development assistance for micro, small, and medium-sized enterprises” for “assistance for microenterprise development assistance” and struck out “and, to the extent applicable, the information required by paragraphs (1) through (11) of subsection (b) of such section with respect to such assistance” after “of such assistance”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
