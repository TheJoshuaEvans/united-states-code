{"tag":"section","attrib":{"id":"id907129c6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4196"},"text":null,"children":[{"tag":"num","attrib":{"value":"4196"},"text":"§ 4196.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of death of decedent; transmission of inventory of effects","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the information of the representative of the deceased, the consular officer, or, if no consular officer is present, a diplomatic officer, in the settlement of his estate shall immediately notify his death in one of the gazettes published in the consular district, and also to the Secretary of State, that the same may be notified in the State to which the deceased belonged; and he shall, as soon as may be, transmit to the Secretary of State an inventory of the effects of the deceased taken as before directed.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id907129c7-2930-11f1-8918-be39dde81dc6"},"text":"(R.S. § 1710; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-07-12/ch618"},"text":"July 12, 1940, ch. 618","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/760"},"text":"54 Stat. 760","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id907129c8-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id907129c9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id907129ca-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 1710 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1792-04-14/ch24/s2"},"text":"act Apr. 14, 1792, ch. 24, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/1/255"},"text":"1 Stat. 255","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Foreign Service Act of 1980 which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s1176"},"text":"section 1176 of this title","children":[],"tail":", and prior thereto to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s76"},"text":"section 76 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id907372bb-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1940—Act ","children":[{"tag":"date","attrib":{"date":"1940-07-12"},"text":"July 12, 1940","children":[],"tail":", substituted “the consular officer, or, if no consular officer is present, a diplomatic officer,” for “the consul or vice-consul,”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
