{"tag":"section","attrib":{"id":"id90d7b289-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7108"},"text":null,"children":[{"tag":"num","attrib":{"value":"7108"},"text":"§ 7108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions against significant traffickers in persons","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90d7b28a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7108/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to sanction significant traffickers in persons","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90d7b28b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7108/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President may exercise the authorities set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1702"},"text":"section 1702 of title 50","children":[],"tail":" without regard to "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"section 1701 of title 50","children":[],"tail":", or "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s10102"},"text":"section 10102 of this title","children":[],"tail":", in the case of any of the following persons:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90d7b28c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7108/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any foreign person that plays a significant role in a severe form of trafficking in persons, directly or indirectly in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90d7b28d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7108/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Foreign persons that materially assist in, or provide financial or technological support for or to, or provide goods or services in support of, activities of a significant foreign trafficker in persons identified pursuant to subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90d7b28e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7108/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Foreign persons that are owned, controlled, or directed by, or acting for or on behalf of, a significant foreign trafficker identified pursuant to subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90d7b28f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7108/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Officials of a foreign government who participate in, facilitate, or condone severe forms of trafficking in persons for significant financial gain.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90d7b290-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7108/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The penalties set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1705"},"text":"section 1705 of title 50","children":[],"tail":" apply to violations of any license, order, or regulation issued under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90d7b291-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7108/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress on identification and sanctioning of significant traffickers in persons","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90d7b292-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7108/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon exercising the authority of subsection (a), the President shall report to the appropriate congressional committees—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90d7b293-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7108/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying publicly the foreign persons that the President determines are appropriate for sanctions pursuant to this section and the basis for such determination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90d7b294-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7108/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" detailing publicly the sanctions imposed pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90d7b295-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7108/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal of sanctions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon suspending or terminating any action imposed under the authority of subsection (a), the President shall report to the committees described in paragraph (1) on such suspension or termination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90d7b296-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7108/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of classified information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Reports submitted under this subsection may include an annex with classified information regarding the basis for the determination made by the President under paragraph (1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90d7b297-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7108/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Law enforcement and intelligence activities not affected","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section prohibits or otherwise limits the authorized law enforcement or intelligence activities of the United States, or the law enforcement activities of any State or subdivision thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90d7b298-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7108/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90d7b299-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7108/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90d7b29a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7108/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation of authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may delegate any authority granted by this section, including the authority to designate foreign persons under paragraphs (1)(B) and (1)(C) of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90d7b29b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7108/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promulgation of rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The head of any agency, including the Secretary of Treasury, is authorized to take such actions as may be necessary to carry out any authority delegated by the President pursuant to paragraph (1), including promulgating rules and regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90d7b29c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7108/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Opportunity for review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such rules and regulations shall include procedures affording an opportunity for a person to be heard in an expeditious manner, either in person or through a representative, for the purpose of seeking changes to or termination of any determination, order, designation or other action associated with the exercise of the authority in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90d7b29d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7108/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of foreign persons","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “foreign person” means any citizen or national of a foreign state or any entity not organized under the laws of the United States, including a foreign government official, but does not include a foreign state.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90d7b29e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7108/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed as precluding judicial review of the exercise of the authority described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90d7b29f-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/386/dA/s111"},"text":"Pub. L. 106–386, div. A, § 111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1484"},"text":"114 Stat. 1484","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/425/tI/s124"},"text":"Pub. L. 115–425, title I, § 124","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-08"},"text":"Jan. 8, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5479"},"text":"132 Stat. 5479","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90d7b2a0-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90d7b2a1-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id90d7b2a2-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/386/s111"},"text":"section 111 of Pub. L. 106–386","children":[],"tail":". Subsec. (d) of "},{"tag":"ref","attrib":{"href":"/us/pl/106/386/s111"},"text":"section 111 of Pub. L. 106–386","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1182"},"text":"section 1182 of Title 8","children":[],"tail":", Aliens and Nationality."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90d7b2a3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/425/s124/1"},"text":"Pub. L. 115–425, § 124(1)","children":[],"tail":", inserted “, or "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s10102"},"text":"section 10102 of this title","children":[],"tail":",” after “without regard to "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"section 1701 of title 50","children":[],"tail":"” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/425/s124/2"},"text":"Pub. L. 115–425, § 124(2)","children":[],"tail":", added subpar. (D)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
