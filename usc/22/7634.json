{"tag":"section","attrib":{"id":"id90e8556a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634"},"text":null,"children":[{"tag":"num","attrib":{"value":"7634"},"text":"§ 7634.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Malaria response Coordinator","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90e8556b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the United States Agency for International Development a Coordinator of United States Government Activities to Combat Malaria Globally (referred to in this section as the “Malaria Coordinator”), who shall be appointed by the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90e8556c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Malaria Coordinator, acting through nongovernmental organizations (including faith-based and community-based organizations), partner country finance, health, and other relevant ministries, and relevant executive branch agencies as may be necessary and appropriate to carry out this section, is authorized to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90e8556d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operate internationally to carry out prevention, care, treatment, support, capacity development, and other activities to reduce the prevalence, mortality, and incidence of malaria;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90e8556e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide grants to, and enter into contracts and cooperative agreements with, nongovernmental organizations (including faith-based organizations) to carry out this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90e8556f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfer and allocate executive branch agency funds that have been appropriated for the purposes described in paragraphs (1) and (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90e85570-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90e85571-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Malaria Coordinator has primary responsibility for the oversight and coordination of all resources and international activities of the United States Government relating to efforts to combat malaria.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90e85572-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Malaria Coordinator shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90e85573-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate program and policy coordination of antimalarial efforts among relevant executive branch agencies and nongovernmental organizations by auditing, monitoring, and evaluating such programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e85574-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that each relevant executive branch agency undertakes antimalarial programs primarily in those areas in which the agency has the greatest expertise, technical capability, and potential for success;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e85575-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate relevant executive branch agency activities in the field of malaria prevention and treatment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e85576-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate planning, implementation, and evaluation with the Global AIDS Coordinator in countries in which both programs have a significant presence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e85577-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with national governments, international agencies, civil society, and the private sector; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e85578-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish due diligence criteria for all recipients of funds appropriated by the Federal Government for malaria assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90e85579-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance for the World Health Organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the President may provide financial assistance to the Roll Back Malaria Partnership of the World Health Organization to improve the capacity of countries with high rates of malaria and other affected countries to implement comprehensive malaria control programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90e8557a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of assistance efforts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section and in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151b–4"},"text":"section 2151b–4 of this title","children":[],"tail":", the Malaria Coordinator shall coordinate the provision of assistance by working with—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90e8557b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" relevant executive branch agencies, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90e8557c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of State (including the Office of the Global AIDS Coordinator);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e8557d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Health and Human Services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e8557e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e8557f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of the United States Trade Representative;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90e85580-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" relevant multilateral institutions, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90e85581-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the World Health Organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e85582-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United Nations Children’s Fund;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e85583-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United Nations Development Programme;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e85584-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Global Fund;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e85585-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the World Bank; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e85586-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/e/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Roll Back Malaria Partnership;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90e85587-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" program delivery and efforts to lift barriers that would impede effective and comprehensive malaria control programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90e85588-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" partner or recipient country governments and national entities including universities and civil society organizations (including faith- and community-based organizations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90e85589-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out this section, the Malaria Coordinator, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151b–4"},"text":"section 2151b–4 of this title","children":[],"tail":", shall ensure that operations and implementation research conducted under this chapter will closely complement the clinical and program research being undertaken by the National Institutes of Health. The Centers for Disease Control and Prevention should advise the Malaria Coordinator on priorities for operations and implementation research and should be a key implementer of this research."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90e8558a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To ensure that adequate malaria controls are established and implemented, the Centers for Disease Control and Prevention should advise the Malaria Coordinator on monitoring, surveillance, and evaluation activities and be a key implementer of such activities under this chapter. Such activities shall complement, rather than duplicate, the work of the World Health Organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90e8558b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90e8558c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", and annually thereafter, the President shall submit a report to the appropriate congressional committees that describes United States assistance for the prevention, treatment, control, and elimination of malaria."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90e8558d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report required under paragraph (1) shall describe—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90e8558e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the countries and activities to which malaria resources have been allocated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e8558f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of people reached through malaria assistance programs, including data on children and pregnant women;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e85590-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/h/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research efforts to develop new tools to combat malaria, including drugs and vaccines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e85591-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/h/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the collaboration and coordination of United States antimalarial efforts with the World Health Organization, the Global Fund, the World Bank, other donor governments, major private efforts, and relevant executive agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e85592-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/h/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the coordination of United States antimalarial efforts with the national malarial strategies of other donor or partner governments and major private initiatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e85593-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/h/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated impact of United States assistance on childhood mortality and morbidity from malaria;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e85594-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/h/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the coordination of antimalarial efforts with broader health and development programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e85595-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/h/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the constraints on implementation of programs posed by health workforce shortages or capacities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e85596-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7634/h/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of personnel trained as health workers and the training levels achieved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90e85597-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/25/tIII/s304"},"text":"Pub. L. 108–25, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-05-27"},"text":"May 27, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/737"},"text":"117 Stat. 737","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/293/tIII/s304"},"text":"Pub. L. 110–293, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2961"},"text":"122 Stat. 2961","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90e85598-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90e85599-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90e8559a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (f) and (g), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/25"},"text":"Pub. L. 108–25","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-05-27"},"text":"May 27, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/711"},"text":"117 Stat. 711","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7601"},"text":"section 7601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90e8559b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/293"},"text":"Pub. L. 110–293","children":[],"tail":" amended section generally. Prior to amendment, section consisted of subsecs. (a) to (h) relating to a pilot program for the placement of health care professionals in overseas areas severely affected by HIV/AIDS, tuberculosis, and malaria."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id90e8559c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id90e8559d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions of President under this section, see Ex. Ord. No. 12163, ","children":[{"tag":"date","attrib":{"date":"1979-09-29"},"text":"Sept. 29, 1979","children":[],"tail":", 44 F.R. 56673, as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2381"},"text":"section 2381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
