{"tag":"section","attrib":{"id":"id8fbe53f4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2431c"},"text":"§ 2431c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fbe53f5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for benefits from the Facility under this subchapter, a country shall be a developing country with a tropical forest or coral reef—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fbe53f6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose government is democratically elected;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe53f7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose government has not repeatedly provided support for acts of international terrorism;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe53f8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose government is not failing to cooperate on international narcotics control matters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe53f9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431c/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose government (including its military or other security forces) does not engage in a consistent pattern of gross violations of internationally recognized human rights;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe53fa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431c/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that has in effect, has received approval for, or is making significant progress toward—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fbe53fb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431c/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an International Monetary Fund standby arrangement, extended Fund arrangement, or an arrangement under the structural adjustment facility or enhanced structural adjustment facility, or a Fund monitored program, or is implementing sound macroeconomic policies, unless the President determines that such an arrangement or program could reasonably be expected to have significant adverse social or environmental effect; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fbe53fc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431c/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as appropriate, structural or sectoral adjustment loans from the International Bank for Reconstruction and Development or the International Development Association, unless the President determines that the resulting adjustment requirements could reasonably be expected to have significant adverse social or environmental effects;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe53fd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431c/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if appropriate, has ","children":[{"tag":"ref","attrib":{"idref":"fn002163"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002163"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be preceded by “that”."}],"tail":" agreed with its commercial bank lenders on a satisfactory financing program, including, as appropriate, debt or debt service reduction; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe53fe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431c/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that has put in place investment reforms, as evidenced by the conclusion of a bilateral investment treaty with the United States, implementation of an investment sector loan with the Inter-American Development Bank, World Bank-supported investment reforms, or other measures, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fbe53ff-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility determinations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fbe5400-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Consistent with subsection (a), the President shall determine whether a country is eligible to receive benefits under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe5401-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall notify the appropriate congressional committees of his intention to designate a country as an eligible country at least 15 days in advance of any formal determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fbe5402-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. V, § 805, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/214/s1"},"text":"Pub. L. 105–214, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-29"},"text":"July 29, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/887"},"text":"112 Stat. 887","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/26/s1"},"text":"Pub. L. 107–26, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-08-17"},"text":"Aug. 17, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/206"},"text":"115 Stat. 206","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/440/s5"},"text":"Pub. L. 115–440, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-14"},"text":"Jan. 14, 2019","children"