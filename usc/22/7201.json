{"tag":"section","attrib":{"id":"id90d9fd62-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7201"},"text":null,"children":[{"tag":"num","attrib":{"value":"7201"},"text":"§ 7201.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90d9fd63-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7201/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural commodity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “agricultural commodity” has the meaning given the term in section 102 of the Agricultural Trade Act of 1978 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5602"},"text":"7 U.S.C. 5602","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90d9fd64-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7201/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “agricultural program” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90d9fd65-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7201/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any program administered under the Food for Peace Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1691"},"text":"7 U.S.C. 1691","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90d9fd66-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7201/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any program administered under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1431"},"text":"section 1431 of title 7","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90d9fd67-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7201/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any program administered under the Agricultural Trade Act of 1978 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5601"},"text":"7 U.S.C. 5601","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90d9fd68-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7201/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any commercial export sale of agricultural commodities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90d9fd69-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7201/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any export financing (including credits or credit guarantees) provided by the United States Government for agricultural commodities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90d9fd6a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7201/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint resolution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “joint resolution” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90d9fd6b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7201/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7202/a/1"},"text":"section 7202(a)(1) of this title","children":[],"tail":", only a joint resolution introduced within 10 session days of Congress after the date on which the report of the President under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7202/a/1"},"text":"section 7202(a)(1) of this title","children":[],"tail":" is received by Congress, the matter after the resolving clause of which is as follows: “That Congress approves the report of the President pursuant to section 903(a)(1) of the Trade Sanctions Reform and Export Enhancement Act of 2000, transmitted on _______.”, with the blank completed with the appropriate date; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90d9fd6c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7201/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of section 7205(1) ","children":[{"tag":"ref","attrib":{"idref":"fn002378"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002378"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be section “7204”."}],"tail":" of this title, only a joint resolution introduced within 10 session days of Congress after the date on which the report of the President under section 7205(2) "},{"tag":"ref","attrib":{"idref":"fn002378"},"text":"1","children":[],"tail":" of this title is received by Congress, the matter after the resolving clause of which is as follows: “That Congress approves the report of the President pursuant to section 906(1) of the Trade Sanctions Reform and Export Enhancement Act of 2000, transmitted on _______.”, with the blank completed with the appropriate date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90d9fd6d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7201/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical device","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “medical device” has the meaning given the term “device” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s321"},"text":"section 321 of title 21","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90d9fd6e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7201/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medicine","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “medicine” has the meaning given the term “drug” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s321"},"text":"section 321 of title 21","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90d9fd6f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7201/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unilateral agricultural sanction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “unilateral agricultural sanction” means any prohibition, restriction, or condition on carrying out an agricultural program with respect to a foreign country or foreign entity that is imposed by the United States for reasons of foreign policy or national security, except in a case in which the United States imposes the measure pursuant to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90d9fd70-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7201/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a multilateral regime and the other member countries of that regime have agreed to impose substantially equivalent measures; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90d9fd71-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7201/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a mandatory decision of the United Nations Security Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90d9fd72-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7201/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unilateral medical sanction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “unilateral medical sanction” means any prohibition, restriction, or condition on exports of, or the provision of assistance consisting of, medicine or a medical device with respect to a foreign country or foreign entity that is imposed by the United States for reasons of foreign policy or national security, except in a case in which the United States imposes the measure pursuant to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90dc6d73-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7201/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a multilateral regime and the other member countries of that regime have agreed to impose substantially equivalent measures; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90dc6d74-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7201/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a mandatory decision of the United Nations Security Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90dc6d75-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/387/s1/a/tIX/s902"},"text":"Pub. L. 106–387, § 1(a) [title IX, § 902]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1549"},"text":"114 Stat. 1549","children":[],"tail":", 1549A–67; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/tIII/s3001/b/1/A"},"text":"Pub. L. 110–246, title III, § 3001(b)(1)(A)","children":[],"tail":", (2)(X), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1820"},"text":"122 Stat. 1820","children":[],"tail":", 1821; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tI/s1423/b"},"text":"Pub. L. 113–79, title I, § 1423(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/695"},"text":"128 Stat. 695","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90dc6d76-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90dc6d77-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90dc6d78-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Food for Peace Act, referred to in par. (2)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-10/ch469"},"text":"act July 10, 1954, ch. 469","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/454"},"text":"68 Stat. 454","children":[],"tail":", which is classified principally to chapter 41 (§ 1691 et seq.) of Title 7, Agriculture. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1691"},"text":"section 1691 of Title 7","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Agricultural Trade Act of 1978, referred to in par. (2)(C), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/501"},"text":"Pub. L. 95–501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-21"},"text":"Oct. 21, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1685"},"text":"92 Stat. 1685","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1531"},"text":"Pub. L. 101–624, title XV, § 1531","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3668"},"text":"104 Stat. 3668","children":[],"tail":", which is classified generally to chapter 87 (§ 5601 et seq.) of Title 7, Agriculture. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s5601"},"text":"section 5601 of Title 7","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 903(a)(1) of the Trade Sanctions Reform and Export Enhancement Act of 2000, referred to in par. (3)(A), is section 1(a) [title IX, § 903(a)(1)] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/387"},"text":"Pub. L. 106–387","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7202/a/1"},"text":"section 7202(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 906 of the Trade Sanctions Reform and Export Enhancement Act of 2000, referred to in par. (3)(B), is section 1(a) [title IX, § 906] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/387"},"text":"Pub. L. 106–387","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7205"},"text":"section 7205 of this title","children":[],"tail":". Provisions relating to report of the President and enactment into law of a joint resolution are contained in section 905 of the Act, which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7204"},"text":"section 7204 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90dc6d79-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Par. (2)(D)–(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" redesignated subpars. (E) and (F) as (D) and (E), respectively, and struck out former subpar. (D) which read as follows: “the dairy export incentive program administered under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s713a–14"},"text":"section 713a–14 of title 15","children":[],"tail":";”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Par. (2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" substituted “Food for Peace Act” for “Agricultural Trade Development and Assistance Act of 1954”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90dc6d7a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id90dc6d7b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/b"},"text":"section 4(b) of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id90dc6d7c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/387/s1/a/tIX/s911"},"text":"Pub. L. 106–387, § 1(a) [title IX, § 911]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1549"},"text":"114 Stat. 1549","children":[],"tail":", 1549A–72, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/387/s1/a/tIX/s911"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), this title [enacting this chapter] shall take effect on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":"], and shall apply thereafter in any fiscal year."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Existing Sanctions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of any unilateral agricultural sanction or unilateral medical sanction that is in effect as of the date of enactment of this Act, this title shall take effect 120 days after the date of enactment of this Act, and shall apply thereafter in any fiscal year.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id90dc6d7d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/387/s1/a/tIX/s901"},"text":"Pub. L. 106–387, § 1(a) [title IX, § 901]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1549"},"text":"114 Stat. 1549","children":[],"tail":", 1549A–67, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/387/s1/a/tIX/s901"},"text":"“This title [enacting this chapter] may be cited as the ‘Trade Sanctions Reform and Export Enhancement Act of 2000’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id90dc6d7e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/387/s1/a/tVII/s775"},"text":"Pub. L. 106–387, § 1(a) [title VII, § 775]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1549"},"text":"114 Stat. 1549","children":[],"tail":", 1549A–45, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/387/s1/a/tVII/s775"},"text":"“For purposes of administering title IX of this Act [enacting this chapter], the term ‘agricultural commodity’ shall also include fertilizer and organic fertilizer, except to the extent provided pursuant to section 904 of that title [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7203"},"text":"22 U.S.C. 7203","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
