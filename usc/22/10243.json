{"tag":"section","attrib":{"id":"id9153997b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10243"},"text":null,"children":[{"tag":"num","attrib":{"value":"10243"},"text":"§ 10243.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees defined","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter, the term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9153997c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10243/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations, the Committee on Armed Services, and the Committee on Appropriations of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9153997d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10243/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs, the Committee on Armed Services, and the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9153997e-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLV/s5577"},"text":"Pub. L. 117–263, div. E, title LV, § 5577","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3370"},"text":"136 Stat. 3370","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
