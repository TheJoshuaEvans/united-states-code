{"tag":"section","attrib":{"id":"id90ce15e5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102"},"text":null,"children":[{"tag":"num","attrib":{"value":"7102"},"text":"§ 7102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90ce15e6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Abuse or threatened abuse of law or legal process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “abuse or threatened abuse of the legal process” means the use or threatened use of a law or legal process, whether administrative, civil, or criminal, in any manner or for any purpose for which the law was not designed, in order to exert pressure on another person to cause that person to take some action or refrain from taking some action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ce15e7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “appropriate congressional committees” means the Committee on Foreign Relations and the Committee on the Judiciary of the Senate and the Committee on Foreign Affairs and the Committee on the Judiciary of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ce15e8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coercion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “coercion” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90ce15e9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" threats of serious harm to or physical restraint against any person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ce15ea-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any scheme, plan, or pattern intended to cause a person to believe that failure to perform an act would result in serious harm to or physical restraint against any person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ce15eb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the abuse or threatened abuse of the legal process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ce15ec-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercial sex act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “commercial sex act” means any sex act on account of which anything of value is given to or received by any person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ce15ed-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Concrete actions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “concrete actions” means actions that demonstrate increased efforts by the government of a country to meet the minimum standards for the elimination of trafficking, including any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90ce15ee-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Enforcement actions taken.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ce15ef-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Investigations actively underway.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ce15f0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Prosecutions conducted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ce15f1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Convictions attained.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ce15f2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Training provided.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ce15f3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/5/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Programs and partnerships actively underway.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ce15f4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/5/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Efforts to prevent severe forms of trafficking, including programs to reduce the vulnerability of particularly vulnerable populations, involving survivors of trafficking in community engagement and policy making, engagement with foreign migrants, ending recruitment fees, and other such measures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ce15f5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/5/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Victim services offered, including immigration services and restitution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ce15f6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/5/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of money the government has committed to the actions described in subparagraphs (A) through (H).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ce15f7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credible information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “credible information” includes all of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90ce15f8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reports by the Department of State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ce15f9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reports of other Federal agencies, including the Department of Labor’s List of Goods Produced by Child Labor or Forced Labor and List of Products Produced by Forced Labor or Indentured Child Labor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ce15fa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Documentation provided by a foreign country, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90ce15fb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/6/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" copies of relevant laws, regulations, and policies adopted or modified; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90ce15fc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/6/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an official record of enforcement actions taken, judicial proceedings, training conducted, consultations conducted, programs and partnerships launched, and services provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ce15fd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Materials developed by civil society organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ce15fe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information from survivors of human trafficking, vulnerable persons, and whistleblowers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ce15ff-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/6/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All relevant media and academic reports that, in light of reason and common sense, are worthy of belief.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ce1600-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/6/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information developed by multilateral institutions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ce1601-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/6/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of the impact of the actions described in subparagraphs (A) through (I) of paragraph (5) on the prevalence of human trafficking in the country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ce1602-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Debt bondage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “debt bondage” means the status or condition of a debtor arising from a pledge by the debtor of his or her personal services or of those of a person under his or her control as a security for debt, if the value of those services as reasonably assessed is not applied toward the liquidation of the debt or the length and nature of those services are not respectively limited and defined.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ce1603-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Involuntary servitude","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “involuntary servitude” includes a condition of servitude induced by means of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90ce1604-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any scheme, plan, or pattern intended to cause a person to believe that, if the person did not enter into or continue in such condition, that person or another person would suffer serious harm or physical restraint; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ce1605-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the abuse or threatened abuse of the legal process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ce1606-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum standards for the elimination of trafficking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “minimum standards for the elimination of trafficking” means the standards set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7106"},"text":"section 7106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ce1607-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonhumanitarian, nontrade-related foreign assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “nonhumanitarian, nontrade-related foreign assistance” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90ce1608-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any assistance under the Foreign Assistance Act of 1961 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"22 U.S.C. 2151","children":[],"tail":" et seq.], other than—"}],"tail":null},{"tag":"clause","attrib":{"id":"id90ce1609-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/10/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance under chapter 4 of part II of that Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2346"},"text":"22 U.S.C. 2346","children":[],"tail":" et seq.] in support of programs of nongovernmental organizations that is made available for any program, project, or activity eligible for assistance under chapter 1 of part I of that Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"22 U.S.C. 2151","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90ce160a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/10/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance under chapter 8 of part I of that Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2291"},"text":"22 U.S.C. 2291","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90ce160b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/10/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other narcotics-related assistance under part I of that Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"22 U.S.C. 2151","children":[],"tail":" et seq.] or under chapter 4 or 5 "},{"tag":"ref","attrib":{"idref":"fn002360"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002360"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “of”."}],"tail":" part II of that Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2346"},"text":"22 U.S.C. 2346","children":[],"tail":" et seq., 2347 et seq.], but any such assistance provided under this clause shall be subject to the prior notification procedures applicable to reprogrammings pursuant to section 634A of that Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2394–1"},"text":"22 U.S.C. 2394–1","children":[],"tail":"];"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90ce160c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/10/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disaster relief assistance, including any assistance under chapter 9 of part I of that Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2292"},"text":"22 U.S.C. 2292","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90ce160d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/10/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" antiterrorism assistance under chapter 8 of part II of that Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2349aa"},"text":"22 U.S.C. 2349aa","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90ce160e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/10/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance for refugees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90ce160f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/10/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" humanitarian and other development assistance in support of programs of nongovernmental organizations under chapters 1 and 10 ","children":[{"tag":"ref","attrib":{"idref":"fn002361"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002361"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" of that Act;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90ce1610-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/10/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any support under subchapter II of chapter 103 of this title relating to the United States International Development Finance Corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90ce1611-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/10/A/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other programs involving trade-related or humanitarian assistance; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ce1612-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sales, or financing on any terms, under the Arms Export Control Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2751"},"text":"22 U.S.C. 2751","children":[],"tail":" et seq.], other than sales or financing provided for narcotics-related purposes following notification in accordance with the prior notification procedures applicable to reprogrammings pursuant to section 634A of the Foreign Assistance Act of 1961 ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2394–1"},"text":"22 U.S.C. 2394–1","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ce1613-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Severe forms of trafficking in persons","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “severe forms of trafficking in persons” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90ce1614-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sex trafficking in which a commercial sex act is induced by force, fraud, or coercion, or in which the person induced to perform such act has not attained 18 years of age; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ce1615-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recruitment, harboring, transportation, provision, or obtaining of a person for labor or services, through the use of force, fraud, or coercion for the purpose of subjection to involuntary servitude, peonage, debt bondage, or slavery.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ce1616-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sex trafficking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “sex trafficking” means the recruitment, harboring, transportation, provision, obtaining, patronizing, or soliciting of a person for the purpose of a commercial sex act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ce1617-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each of the several States of the United States, the District of Columbia, the Commonwealth of Puerto Rico, the United States Virgin Islands, Guam, American Samoa, the Commonwealth of the Northern Mariana Islands, and territories and possessions of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ce1618-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Task Force","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Task Force” means the Interagency Task Force to Monitor and Combat Trafficking established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7103"},"text":"section 7103 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ce1619-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States” means the fifty States of the United States, the District of Columbia, the Commonwealth of Puerto Rico, the Virgin Islands, American Samoa, Guam, the Commonwealth of the Northern Mariana Islands, and the territories and possessions of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ce161a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Victim of a severe form of trafficking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “victim of a severe form of trafficking” means a person subject to an act or practice described in paragraph (11).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ce161b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Victim of trafficking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “victim of trafficking” means a person subjected to an act or practice described in paragraph (11) or (12).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ce161c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7102/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grounds related to human trafficking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “grounds related to human trafficking” means grounds related to the criteria for inadmissibility to the United States described in subsection (a)(2)(H) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1182"},"text":"section 1182 of title 8","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90ce161d-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/386/dA/s103"},"text":"Pub. L. 106–386, div. A, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1469"},"text":"114 Stat. 1469","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/193/s8/b/1"},"text":"Pub. L. 108–193, § 8(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2887"},"text":"117 Stat. 2887","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/457/tIII/s304/a"},"text":"Pub. L. 110–457, title III, § 304(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-12-23"},"text":"Dec. 23, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/5087"},"text":"122 Stat. 5087","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/4/tXII/s1212/b/1"},"text":"Pub. L. 113–4, title XII, § 1212(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-03-07"},"text":"Mar. 7, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/143"},"text":"127 Stat. 143","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/22/tI/s108/b"},"text":"Pub. L. 114–22, title I, § 108(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-05-29"},"text":"May 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/239"},"text":"129 Stat. 239","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dF/tVI/s1470/p"},"text":"Pub. L. 115–254, div. F, title VI, § 1470(p)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3518"},"text":"132 Stat. 3518","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/427/s2"},"text":"Pub. L. 115–427, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-09"},"text":"Jan. 9, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5503"},"text":"132 Stat. 5503","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXII/s1299R/d/2"},"text":"Pub. L. 116–283, div. A, title XII, § 1299R(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4028"},"text":"134 Stat. 4028","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/73/s7"},"text":"Pub. L. 119–73, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2026-01-23"},"text":"Jan. 23, 2026","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/2009"},"text":"139 Stat. 2009","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90ce161e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90ce161f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90ce1620-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this division”, meaning division A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/386"},"text":"Pub. L. 106–386","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1466"},"text":"114 Stat. 1466","children":[],"tail":", known as the Trafficking Victims Protection Act of 2000, which is classified principally to this chapter. For complete classification of division A to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7101"},"text":"section 7101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Foreign Assistance Act of 1961, referred to in par. (10)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/424"},"text":"75 Stat. 424","children":[],"tail":", which is classified principally to chapter 32 (§ 2151 et seq.) of this title. Part I of the Act is classified generally to subchapter I (§ 2151 et seq.) of chapter 32 of this title. Chapters 1, 8, and 9 of part I of the Act are classified generally to parts I (§ 2151 et seq.), VIII (§ 2291 et seq.), and IX (§ 2292 et seq.), respectively, of subchapter I of chapter 32 of this title. Title IV of chapter 2 of part I of the Act was classified generally to subpart iv (§ 2191 et seq.) of part II of subchapter I of chapter 32 of this title, and was repealed, except for subsections (g), ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), (m), and (n) of "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2197"},"text":"section 2197 of this title","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dF/tVI/s1464/2"},"text":"Pub. L. 115–254, div. F, title VI, § 1464(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3513"},"text":"132 Stat. 3513","children":[],"tail":", effective at the end of the transition period, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s9681"},"text":"section 9681 of this title","children":[],"tail":". Chapters 4, 5, and 8 of part II of the Act are classified generally to part IV (§ 2346 et seq.), part V (§ 2347 et seq.), and part VIII (§ 2349aa et seq.), respectively, of subchapter II of chapter 32 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Chapters 1 and 10 of that Act, referred to in par. (10)(A)(vii), probably means chapters 1 and 10 of part I of the Foreign Assistance Act of 1961, which are classified generally to parts I (§ 2151 et seq.) and X (§ 2293 et seq.), respectively, of subchapter I of chapter 32 of this title. For complete classification of these chapters to the Code, see Tables.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Arms Export Control Act, referred to in par. (10)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/629"},"text":"Pub. L. 90–629","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1320"},"text":"82 Stat. 1320","children":[],"tail":", which is classified principally to chapter 39 (§ 2751 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2751"},"text":"section 2751 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90ce1621-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2026—Par. (16). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/73/s7/1"},"text":"Pub. L. 119–73, § 7(1)","children":[],"tail":", substituted “paragraph (11)” for “paragraph (9)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (17). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/73/s7/2"},"text":"Pub. L. 119–73, § 7(2)","children":[],"tail":", substituted “paragraph (11) or (12)” for “paragraph (9) or (10)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Par. (18). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" added par. (18)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Pars. (5) to (17). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/427"},"text":"Pub. L. 115–427","children":[],"tail":" added pars. (5) and (6) and redesignated former pars. (5) to (15) as (7) to (17), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Par. (8)(A)(viii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" amended cl. (viii) generally. Prior to amendment, cl. (viii) read as follows: “programs under title IV of chapter 2 of part I of that Act, relating to the Overseas Private Investment Corporation; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Par. (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/22"},"text":"Pub. L. 114–22","children":[],"tail":" substituted “obtaining, patronizing, or soliciting” for “or obtaining”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4"},"text":"Pub. L. 113–4","children":[],"tail":" added par. (1), redesignated former pars. (1) to (14) as (2) to (15), respectively, and substituted “paragraph (9)” for “paragraph (8)” in par. (14) and “paragraph (9) or (10)” for “paragraph (8) or (9)” in par. (15)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/457"},"text":"Pub. L. 110–457","children":[],"tail":" substituted “Committee on Foreign Affairs” for “Committee on International Relations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Par. (7)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/193"},"text":"Pub. L. 108–193","children":[],"tail":" inserted “in support of programs of nongovernmental organizations” before “that is made available”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90ce1622-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id90ce1623-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" effective at the end of the transition period, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s9681"},"text":"section 9681 of this title","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1470/w"},"text":"section 1470(w) of Pub. L. 115–254","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s905"},"text":"section 905 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
