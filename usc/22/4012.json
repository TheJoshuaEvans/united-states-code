{"tag":"section","attrib":{"id":"id9056ea6a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4012"},"text":null,"children":[{"tag":"num","attrib":{"value":"4012"},"text":"§ 4012.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of appointments of consular agents and foreign national employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9056ea6b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4012/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of State may terminate at any time the appointment of any consular agent in light of the criteria and procedures normally followed in the locality in similar circumstances.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9056ea6c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4012/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may terminate at any time the appointment of any foreign national employee in light of the criteria and procedures normally followed in the locality in similar circumstances.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9056ea6d-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s613"},"text":"Pub. L. 96–465, title I, § 613","children":[],"tail":", formerly § 612, "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2099"},"text":"94 Stat. 2099","children":[],"tail":"; renumbered § 613, "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s181/a/1"},"text":"Pub. L. 103–236, title I, § 181(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},