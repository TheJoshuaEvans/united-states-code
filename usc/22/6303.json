{"tag":"section","attrib":{"id":"id90b3d76b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6303"},"text":null,"children":[{"tag":"num","attrib":{"value":"6303"},"text":"§ 6303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on assisting nuclear proliferation through provision of financing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90b3d76c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Prohibited activity” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “prohibited activity” means the act of knowingly, materially, and directly contributing or attempting to contribute, through the provision of financing, to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90b3d76d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6303/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acquisition of unsafeguarded special nuclear material; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b3d76e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6303/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use, development, production, stockpiling, or other acquisition of any nuclear explosive device,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"by any individual, group, or non-nuclear-weapon state.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90b3d76f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent that the United States has jurisdiction to prohibit such activity by such person, no United States person and no foreign person may engage in any prohibited activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90b3d770-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presidential determination and order with respect to United States and foreign persons","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the President determines,,","children":[{"tag":"ref","attrib":{"idref":"fn002338"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002338"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" that a United States person or a foreign person has engaged in a prohibited activity (without regard to whether subsection (b) applies), the President shall, by order, impose the sanctions described in subsection (d) on such person."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90b3d771-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6303/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanctions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following sanctions shall be imposed pursuant to any order issued under subsection (c) with respect to any United States person or any foreign person:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90b3d772-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6303/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ban on dealings in Government finance","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90b3d773-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6303/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation as primary dealer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Neither the Board of Governors of the Federal Reserve System nor the Federal Reserve Bank of New York may designate, or permit the continuation of any prior designation of, the person as a primary dealer in United States Government debt instruments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b3d774-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6303/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service as depositary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The person may not serve as a depositary for United States Government funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b3d775-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6303/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions on operations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The person may not, directly or indirectly—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90b3d776-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6303/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commence any line of business in the United States in which the person was not engaged as of the date of the order; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b3d777-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6303/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct business from any location in the United States at which the person did not conduct business as of the date of the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90b3d778-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6303/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with and actions by foreign government of jurisdiction","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90b3d779-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6303/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the President makes a determination under subsection (c) with respect to a foreign person, the Congress urges the President to initiate consultations immediately with any appropriate foreign government with respect to the imposition of any sanction pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b3d77a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6303/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions by government of jurisdiction","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90b3d77b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6303/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension of period for imposing sanctions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to pursue consultations described in paragraph (1) with any government referred to in such paragraph, the President may delay, for up to 90 days, the effective date of an order under subsection (c) imposing any sanction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b3d77c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6303/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with activities of foreign government","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Following consultations described in paragraph (1), the order issued by the President under subsection (c) imposing any sanction on a foreign person shall take effect unless the President determines, and certifies in writing to the Congress, that the government referred to in paragraph (1) has taken specific and effective actions, including the imposition of appropriate penalties, to terminate the involvement of the foreign person in any prohibited activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b3d77d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6303/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After the end of the period described in subparagraph (A), the President may delay, for up to an additional 90 days, the effective date of an order issued under subsection (b) imposing any sanction on a foreign person if the President determines, and certifies in writing to the Congress, that the appropriate foreign government is in the process of taking actions described in subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b3d77e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6303/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before the end of the 90-day period beginning on the date on which an order is issued under subsection (c), the President shall submit to the Congress a report on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90b3d77f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6303/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of consultations under this subsection with the government referred to in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b3d780-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6303/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the basis for any determination under paragraph (2) that such government has taken specific corrective actions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90b3d781-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6303/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of sanctions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any sanction imposed on any person pursuant to an order issued under subsection (c) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90b3d782-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6303/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remain in effect for a period of not less than 12 months; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b3d783-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6303/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" cease to apply after the end of such 12-month period only if the President determines, and certifies in writing to the Congress, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90b3d784-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6303/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person has ceased to engage in any prohibited activity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b3d785-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6303/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President has received reliable assurances from such person that the person will not, in the future, engage in any prohibited activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90b3d786-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6303/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may waive the continued application of any sanction imposed on any person pursuant to an order issued under subsection (c) if the President determines, and certifies in writing to the Congress, that the continued imposition of the sanction would have a serious adverse effect on the safety and soundness of the domestic or international financial system or on domestic or international payments systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90b3d787-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6303/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement action","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General may bring an action in an appropriate district court of the United States for injunctive and other appropriate relief with respect to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90b3d788-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6303/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any violation of subsection (b); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b3d789-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6303/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any order issued pursuant to subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90b3d78a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6303/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Knowingly” defined","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90b3d78b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6303/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “knowingly” means the state of mind of a person with respect to conduct, a circumstance, or a result in which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90b3d78c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6303/i/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such person is aware that such person is engaging in such conduct, that such circumstance exists, or that such result is substantially certain to occur; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b3d78d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6303/i/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such person has a firm belief that such circumstance exists or that such result is substantially certain to occur.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b3d78e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6303/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Knowledge of the existence of a particular circumstance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If knowledge of the existence of a particular circumstance is required for an offense, such knowledge is established if a person is aware of a high probability of the existence of such circumstance, unless the person actually believes that such circumstance does not exist.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90b3d78f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6303/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply with respect to prohibited activities which occur on or after the date this subchapter takes effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90b3d790-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tVIII/s824"},"text":"Pub. L. 103–236, title VIII, § 824","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/512"},"text":"108 Stat. 512","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/164/tI/s157/b"},"text":"Pub. L. 104–164, title I, § 157(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-07-21"},"text":"July 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1440"},"text":"110 Stat. 1440","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90b3d791-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90b3d792-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90b3d793-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For the date this subchapter takes effect, referred to in subsec. (j), as 60 days after ","children":[{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/s831"},"text":"section 831 of Pub. L. 103–236","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90b3d794-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/164/s157/b/1"},"text":"Pub. L. 104–164, § 157(b)(1)","children":[],"tail":", struck out “in writing after opportunity for a hearing on the record” after “If the President determines,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/164/s157/b/2"},"text":"Pub. L. 104–164, § 157(b)(2)","children":[],"tail":", (3), redesignated subsec. (f) as (e) and struck out heading and text of former subsec. (e). Text read as follows: “Any determination of the President under subsection (c) of this section shall be subject to judicial review in accordance with chapter 7 of part I of title 5.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f) to (k). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/164/s157/b/3"},"text":"Pub. L. 104–164, § 157(b)(3)","children":[],"tail":", redesignated subsecs. (g) to (k) as (f) to (j), respectively. Former subsec. (f) redesignated (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90b3d795-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id90b3d796-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 60 days after ","children":[{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/s831"},"text":"section 831 of Pub. L. 103–236","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
