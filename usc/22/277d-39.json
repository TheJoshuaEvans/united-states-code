{"tag":"section","attrib":{"id":"id8eb0db18-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s277d–39"},"text":null,"children":[{"tag":"num","attrib":{"value":"277d–39"},"text":"§ 277d–39.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hidalgo-Reynosa lands; administration; part of national wildlife refuge system","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Upon transfer of sovereignty from Mexico to the United States of the 481.68 acres of land acquired by the United States from Mexico near Hidalgo-Reynosa, administration over the portion of that land which is determined by the Commissioner not to be required for the construction and maintenance of the relocated river channel shall be assumed by the Department of the Interior; and the Department of the Interior, United States Fish and Wildlife Service, is authorized to plan, establish, develop, and administer such portion of the acquired lands as a part of the national wildlife refuge system.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8eb0db19-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/549/tI/s106"},"text":"Pub. L. 92–549, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-25"},"text":"Oct. 25, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1162"},"text":"86 Stat. 1162","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/271/s1/3"},"text":"Pub. L. 93–271, § 1(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-04-22"},"text":"Apr. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/92"},"text":"88 Stat. 92","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8eb0db1a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8eb0db1b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id8eb0db1c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“United States Fish and Wildlife Service” substituted in text for “Fish and Wildlife Service, Bureau of Sport Fisheries and Wildlife” pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/271/s1/3"},"text":"section 1(3) of Pub. L. 93–271","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s742b"},"text":"section 742b of Title 16","children":[],"tail":", Conservation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
