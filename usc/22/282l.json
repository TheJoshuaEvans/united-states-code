{"tag":"section","attrib":{"id":"id8eb80760-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s282l"},"text":null,"children":[{"tag":"num","attrib":{"value":"282l"},"text":"§ 282l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capital stock increase","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8eb80761-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s282l/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subscription authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8eb80762-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s282l/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The United States Governor of the Corporation may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8eb80763-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s282l/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vote for an increase of 1,000,000 shares in the authorized capital stock of the Corporation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8eb80764-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s282l/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subscribe on behalf of the United States to 250,000 additional shares of the capital stock of the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8eb80765-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s282l/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prior appropriation required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The subscription authority provided in paragraph (1) shall be effective only to such extent or in such amounts as are provided in advance in appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8eb80766-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s282l/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to pay for the subscription authorized in subsection (a), there are authorized to be appropriated, without fiscal year limitation, $50,000,000 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8eb80767-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-08-11/ch788/s14"},"text":"Aug. 11, 1955, ch. 788, § 14","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/145/s125/a"},"text":"Pub. L. 102–145, § 125(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/266/s102"},"text":"Pub. L. 102–266, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-04-01"},"text":"Apr. 1, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/97"},"text":"106 Stat. 97","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
