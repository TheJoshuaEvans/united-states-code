{"tag":"section","attrib":{"id":"id915ac587-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10605"},"text":null,"children":[{"tag":"num","attrib":{"value":"10605"},"text":"§ 10605.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safeguards and accountability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id915ac588-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10605/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safeguards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation shall develop, and incorporate into any agreement for support provided by the Foundation, appropriate safeguards, policies, and guidelines, consistent with United States law and best practices and standards for environmental and social safeguards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id915ac589-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10605/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independent accountability mechanism","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id915ac58a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10605/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, or the Secretary’s designee, shall establish a transparent and independent accountability mechanism, consistent with best practices, which shall provide—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id915ac58b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10605/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a compliance review function that assesses whether Foundation-supported projects adhere to the requirements developed pursuant to subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915ac58c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10605/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a dispute resolution function for resolving and remedying concerns between complainants and project implementers regarding the impacts of specific Foundation-supported projects with respect to such standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915ac58d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10605/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an advisory function that reports to the Board on projects, policies, and practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id915ac58e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10605/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The accountability mechanism shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id915ac58f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10605/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report annually to the Board and the appropriate congressional committees regarding the Foundation’s compliance with best practices and standards in accordance with paragraph (1)(A) and the nature and resolution of any complaint;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915ac590-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10605/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id915ac591-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10605/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have permanent staff, led by an independent accountability official, to conduct compliance reviews and dispute resolutions and perform advisory functions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id915ac592-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10605/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain a roster of experts to serve such roles, to the extent needed; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915ac593-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10605/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hold a public comment period lasting not fewer than 60 days regarding the initial design of the accountability mechanism.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id915ac594-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10605/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Internal accountability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation shall establish an ombudsman position at a senior level of executive staff as a confidential, neutral source of information and assistance to anyone affected by the activities of the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id915ac595-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10605/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, periodically, but not less frequent than annually, review assistance provided by the Foundation for the purpose of implementing ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s10602/b"},"text":"section 10602(b) of this title","children":[],"tail":" to ensure consistency with the provisions under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2378d"},"text":"section 2378d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id915ac596-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dE/tLI/s5105"},"text":"Pub. L. 118–159, div. E, title LI, § 5105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2417"},"text":"138 Stat. 2417","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
