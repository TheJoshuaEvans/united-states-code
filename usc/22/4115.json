{"tag":"section","attrib":{"id":"id906c6eea-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4115"},"text":null,"children":[{"tag":"num","attrib":{"value":"4115"},"text":"§ 4115.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unfair labor practices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id906c6eeb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4115/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of State","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It shall be an unfair labor practice for the Department—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id906c6eec-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4115/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to interfere with, restrain, or coerce any employee in the exercise by the employee of any right under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6eed-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4115/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage or discourage membership in any labor organization by discrimination in connection with hiring, tenure, promotion, or other conditions of employment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6eee-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4115/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to sponsor, control, or otherwise assist any labor organization, other than to furnish upon request customary and routine services and facilities on an impartial basis to labor organizations having equivalent status;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6eef-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4115/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to discipline or otherwise discriminate against an employee because the employee has filed a complaint or petition, or has given any information, affidavit, or testimony under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6ef0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4115/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to refuse to consult or negotiate in good faith with a labor organization, as required under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6ef1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4115/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to fail or refuse to cooperate in impasse procedures and impasse decisions, as required under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6ef2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4115/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enforce any rule or regulation (other than a rule or regulation implementing ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2302"},"text":"section 2302 of title 5","children":[],"tail":") which is in conflict with an applicable collective bargaining agreement if the agreement was in effect before the date the rule or regulation was prescribed; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6ef3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4115/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to fail or refuse otherwise to comply with any provision of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id906c6ef4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4115/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Labor organizations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It shall be an unfair labor practice for a labor organization—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id906c6ef5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4115/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to interfere with, restrain, or coerce any employee in the exercise by the employee of any right under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6ef6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4115/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to cause or attempt to cause the Department to discriminate against any employee in the exercise by the employee of any right under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6ef7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4115/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to coerce, discipline, fine, or attempt to coerce a member of the labor organization as punishment or reprisal, or for the purpose of hindering or impeding the member’s work performance or productivity as an employee or the discharge of the member’s functions as an employee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6ef8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4115/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to discriminate against an employee with regard to the terms and conditions of membership in the labor organization on the basis of race, color, creed, national origin, sex, age preferential or nonpreferential civil service status, political affiliation, marital status, or disability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6ef9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4115/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to refuse to consult or negotiate in good faith with the Department, as required under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6efa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4115/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to fail or refuse to cooperate in impasse procedures and impasse decisions, as required under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6efb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4115/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id906c6efc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4115/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to call, or participate in, a strike, work stoppage, or slowdown, or to picket the Department in a labor-management dispute (except that any such picketing in the United States which does not interfere with the Department’s operations shall not be an unfair labor practice); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id906c6efd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4115/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to condone any unfair labor practice described in subparagraph (A) by failing to take action to prevent or stop such activity;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6efe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4115/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to deny membership to any employee in the unit represented by the labor organization except—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id906c6eff-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4115/b/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for failure to tender dues uniformly required as a condition of acquiring and retaining membership, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id906c6f00-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4115/b/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the exercise of disciplinary procedures consistent with the organization’s constitution or bylaws and this subchapter; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6f01-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4115/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to fail or refuse otherwise to comply with any provision of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id906c6f02-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4115/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personal views, arguments, opinions, or statements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The expression of any personal view, argument, or opinion, or the making of any statement, which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id906c6f03-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4115/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publicizes the fact of a representational election and encourages employees to exercise their right to vote in such an election;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6f04-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4115/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" corrects the record with respect to any false or misleading statement made by any person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6f05-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4115/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" informs employees of the Government’s policy relating to labor-management relations and representation,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"if the expression contains no threat of reprisal or force or promise of benefit and was not made under coercive conditions shall not—","children":[],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id906c6f06-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4115/c/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" constitute an unfair labor practice under this subchapter, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id906c6f07-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4115/c/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" constitute grounds for the setting aside of any election conducted under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id906c6f08-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4115/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election of remedies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Issues which can properly be raised under an appeals procedure may not be raised as unfair labor practices prohibited under this section. Except for matters wherein, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4139/a/2"},"text":"section 4139(a)(2) of this title","children":[],"tail":", an employee has an option of using the grievance procedure under subchapter XI or an appeals procedure, issues which can be raised under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4114"},"text":"section 4114 of this title","children":[],"tail":" or subchapter XI may, in the discretion of the aggrieved party, be raised either under such section or subchapter or else raised as an unfair labor practice under this section, but may not be raised both under this section and under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4114"},"text":"section 4114 of this title","children":[],"tail":" or subchapter XI."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id906c6f09-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s1015"},"text":"Pub. L. 96–465, title I, § 1015","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2137"},"text":"94 Stat. 2137","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/138/tI/s153/d/2"},"text":"Pub. L. 102–138, title I, § 153(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/674"},"text":"105 Stat. 674","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dI/tXCII/s9219/4"},"text":"Pub. L. 117–263, div. I, title XCII, § 9219(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3879"},"text":"136 Stat. 3879","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id906c6f0a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id906c6f0b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id906c6f0c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" substituted “disability” for “handicapping condition”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/138"},"text":"Pub. L. 102–138","children":[],"tail":" substituted “section 4139(a)(2)” for “section 4139(b)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id906c6f0d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id906c6f0e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/138/tI/s153/f"},"text":"Pub. L. 102–138, title I, § 153(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/674"},"text":"105 Stat. 674","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/138/tI/s153/f"},"text":"“The amendments made by this section [amending this section and sections 4131, 4134, 4137, 4139, and 4140 of this title] shall not apply with respect to any grievance (within the meaning of section 1101 of the Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4131"},"text":"22 U.S.C. 4131","children":[],"tail":"], as amended by this section) arising before the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
