{"tag":"section","attrib":{"id":"id90dede95-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7427"},"text":null,"children":[{"tag":"num","attrib":{"value":"7427"},"text":"§ 7427.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to free members of the Armed Forces of the United States and certain other persons detained or imprisoned by or on behalf of the International Criminal Court","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90dede96-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7427/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President is authorized to use all means necessary and appropriate to bring about the release of any person described in subsection (b) who is being detained or imprisoned by, on behalf of, or at the request of the International Criminal Court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90dede97-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7427/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons authorized to be freed","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The authority of subsection (a) shall extend to the following persons:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90dede98-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7427/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Covered United States persons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90dede99-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7427/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Covered allied persons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90dede9a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7427/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Individuals detained or imprisoned for official actions taken while the individual was a covered United States person or a covered allied person, and in the case of a covered allied person, upon the request of such government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90dede9b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7427/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of legal assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"When any person described in subsection (b) is arrested, detained, investigated, prosecuted, or imprisoned by, on behalf of, or at the request of the International Criminal Court, the President is authorized to direct any agency of the United States Government to provide—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90dede9c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7427/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" legal representation and other legal assistance to that person (including, in the case of a person entitled to assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1037"},"text":"section 1037 of title 10","children":[],"tail":", representation and other assistance in the manner provided in that section);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90dede9d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7427/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exculpatory evidence on behalf of that person; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90dede9e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7427/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" defense of the interests of the United States through appearance before the International Criminal Court pursuant to Article 18 or 19 of the Rome Statute, or before the courts or tribunals of any country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90dede9f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7427/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bribes and other inducements not authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section does not authorize the payment of bribes or the provision of other such incentives to induce the release of a person described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90dedea0-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/206/tII/s2008"},"text":"Pub. L. 107–206, title II, § 2008","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-02"},"text":"Aug. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/905"},"text":"116 Stat. 905","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
