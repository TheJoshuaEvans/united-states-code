{"tag":"section","attrib":{"id":"id8eb595d5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s280a"},"text":null,"children":[{"tag":"num","attrib":{"value":"280a"},"text":"§ 280a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"When used in this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8eb595d6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s280a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Secretary” means the Secretary of State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8eb595d7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s280a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Government agency” means any department, independent establishment, or other agency of the Government of the United States, or any corporation wholly owned by the Government of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8eb595d8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s280a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Commission” means the South Pacific Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8eb595d9-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-01-28/ch38/s2"},"text":"Jan. 28, 1948, ch. 38, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/15"},"text":"62 Stat. 15","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
