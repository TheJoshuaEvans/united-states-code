{"tag":"section","attrib":{"id":"id91074e6f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8573"},"text":null,"children":[{"tag":"num","attrib":{"value":"8573"},"text":"§ 8573.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on Iranian petroleum and petroleum products exports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id91074e70-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8573/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2024-04-24"},"text":"April 24, 2024","children":[],"tail":", and annually thereafter until the date described in subsection (d), the Administrator of the Energy Information Administration shall submit to the appropriate congressional committees a report describing Iran’s growing exports of petroleum and petroleum products, that includes the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id91074e71-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8573/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An analysis of Iran’s exports and sale of petroleum and petroleum products, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91074e72-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8573/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of Iran’s petroleum export and sale revenue per year since 2018;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91074e73-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8573/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of Iran’s petroleum export and sale revenue to China per year since 2018;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91074e74-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8573/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of petroleum and crude oil barrels exported per year since 2018;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91074e75-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8573/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of petroleum and crude oil barrels exported to China per year since 2018;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91074e76-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8573/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of petroleum and crude oil barrels exported to countries other than China per year since 2018;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91074e77-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8573/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average price per petroleum and crude oil barrel exported per year since 2018; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91074e78-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8573/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average price per petroleum and crude oil barrel exported to China per year since 2018.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91074e79-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8573/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An analysis of Iran’s labeling practices of exported petroleum and petroleum products.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91074e7a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8573/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of companies involved in the exporting and sale of Iranian petroleum and petroleum products.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91074e7b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8573/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of ships involved in the exporting and sale of Iranian petroleum and petroleum products.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91074e7c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8573/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of ports involved in the exporting and sale of Iranian petroleum and petroleum products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91074e7d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8573/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report required by subsection (a) shall be submitted in unclassified form but may include a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91074e7e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8573/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The unclassified portion of the report required by subsection (a) shall be posted on a publicly available website of the Energy Information Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91074e7f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8573/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirement to submit reports under this section shall be terminated on the date on which the President makes the certification described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8572/i"},"text":"section 8572(i) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id91074e80-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/50/dJ/s4"},"text":"Pub. L. 118–50, div. J, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-04-24"},"text":"Apr. 24, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/967"},"text":"138 Stat. 967","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id91074e81-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id91074e82-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id91074e83-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Stop Harboring Iranian Petroleum Act, also known as the SHIP Act, and not as part of the Comprehensive Iran Sanctions, Accountability, and Divestment Act of 2010 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
