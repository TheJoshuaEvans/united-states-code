{"tag":"section","attrib":{"id":"id90bd7485-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6483"},"text":null,"children":[{"tag":"num","attrib":{"value":"6483"},"text":"§ 6483.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress regarding national security strategy to promote religious freedom through United States foreign policy","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that the annual national security strategy report of the President required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3043"},"text":"section 3043 of title 50","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90bd7486-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6483/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" should promote international religious freedom as a foreign policy and national security priority; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bd7487-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6483/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" should articulate that promotion of the right to freedom of religion is a strategy that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90bd7488-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6483/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protects other, related human rights, and advances democracy outside the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90bd7489-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6483/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes clear its importance to United States foreign policy goals of stability, security, development, and diplomacy;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bd748a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6483/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" should be a guide for the strategies and activities of relevant Federal agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bd748b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6483/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" should inform the Department of Defense quadrennial defense review under section 118 ","children":[{"tag":"ref","attrib":{"idref":"fn002348"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002348"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 10 and the Department of State Quadrennial Diplomacy and Development Review."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90bd748c-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/292/tVII/s703"},"text":"Pub. L. 105–292, title VII, § 703","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/281/tVI/s601"},"text":"Pub. L. 114–281, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1439"},"text":"130 Stat. 1439","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90bd748d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90bd748e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90bd748f-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s118"},"text":"Section 118 of title 10","children":[],"tail":", referred to in par. (4), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tIX/s941/b/1"},"text":"Pub. L. 114–328, div. A, title IX, § 941(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2367"},"text":"130 Stat. 2367","children":[],"tail":". Subsequently, a new "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s118"},"text":"section 118 of Title 10","children":[],"tail":", Armed Forces, related to annual report on major weapons systems sustainment, was added by "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tIII/s351/a/1"},"text":"Pub. L. 116–92, div. A, title III, § 351(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1319"},"text":"133 Stat. 1319","children":[],"tail":". For provisions related to national defense strategy similar to those contained in former "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s118"},"text":"section 118 of Title 10","children":[],"tail":" prior to repeal, see "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s113/g"},"text":"section 113(g) of Title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
