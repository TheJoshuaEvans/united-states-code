{"tag":"section","attrib":{"id":"id8f982ea1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2349cc–2"},"text":"§ 2349cc–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of emergency assistance capacity","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f982ea2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State, in consultation as appropriate with other relevant Federal departments and agencies is authorized to conduct a review that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f982ea3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analyzes the United States Government’s capacity to promptly and effectively deliver emergency support to countries experiencing major cybersecurity and ICT incidents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f982ea4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies relevant factors constraining the support referred to in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f982ea5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc–2/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develops a strategy to improve coordination among relevant Federal agencies and to resolve such constraints.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f982ea6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than one year after ","children":[{"tag":"date","attrib":{"date":"2023-12-22"},"text":"December 22, 2023","children":[],"tail":", the Secretary of State shall submit to the Committee on Foreign Relations and the Committee on Homeland Security and Governmental Affairs of the Senate and the Committee on Foreign Affairs and the Committee on Oversight and Accountability of the House of Representatives a report that contains the results of the review conducted pursuant to subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f982ea7-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. II, § 593, as added "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dF/tLXIII/s6307"},"text":"Pub. L. 118–31, div. F, title LXIII, § 6307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/992"},"text":"137 Stat. 992","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
