{"tag":"section","attrib":{"id":"id8fe6c2b6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2655b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2655b"},"text":"§ 2655b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Diplomatic presence overseas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fe6c2b7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2655b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of this section is to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fe6c2b8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2655b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" elevate the stature given United States diplomatic initiatives relating to nonproliferation and political-military issues; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fe6c2b9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2655b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a group of highly specialized, technical experts with country expertise capable of administering the nonproliferation and political-military affairs functions of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fe6c2ba-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2655b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out the purposes of subsection (a), the Secretary is authorized to establish the position of Counselor for Nonproliferation and Political Military Affairs in United States diplomatic missions overseas, to be filled by individuals who are career Civil Service officers or Foreign Service officers committed to follow-on assignments in the Nonproliferation Bureau or the Political Military Affairs Bureau of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fe6c2bb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2655b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After being selected to serve as Counselor, any person so selected shall spend not less than 10 months in language training courses at the Foreign Service Institute,","children":[{"tag":"ref","attrib":{"idref":"fn002186"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002186"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Change of Name note below."}],"tail":" or in technical courses administered by the Department of Defense, the Department of Energy, or other appropriate departments and agencies of the United States, except that such requirement for training may be waived by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fe6c2bc-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/228/dB/tXVI/s1604"},"text":"Pub. L. 107–228, div. B, title XVI, § 1604","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"Sept. 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1460"},"text":"116 Stat. 1460","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fe6c2bd-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8fe6c2be-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id8fe6c2bf-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"References to Foreign Service Institute considered to refer to George P. Shultz National Foreign Affairs Training Center, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/132/s1/b"},"text":"section 1(b) of Pub. L. 107–132","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4021"},"text":"section 4021 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id8fe6c2c0-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “Department” and “Secretary” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/228/s3"},"text":"section 3 of Pub. L. 107–228","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
