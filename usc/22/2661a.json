{"tag":"section","attrib":{"id":"id8ff06021-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2661a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2661a"},"text":"§ 2661a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign contracts or arrangements; discrimination","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Information should not be disseminated about opportunities for, and there should be no participation or other assistance by any officer or employee of the Department of State (including the Agency for International Development) in, the negotiation of any contract or arrangement with a foreign country, individual, or entity, if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ff06022-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2661a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any United States person (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s7701/a/30"},"text":"section 7701(a)(30) of title 26","children":[],"tail":") is prohibited from entering into such contract or arrangement, or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff06023-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2661a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such contract or arrangement requires that any such person be excluded from participating in the implementation of such contract or arrangement,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"on account of the race, religion, national origin, or sex of such person in the case of an individual or, in the case of a partnership, corporation, association, or other entity, any officer, employee, agent, director, or owner thereof.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ff06024-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/350/tI/s121"},"text":"Pub. L. 94–350, title I, § 121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-07-12"},"text":"July 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/829"},"text":"90 Stat. 829","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ff06025-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ff06026-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8ff06027-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “Internal Revenue Code of 1986” for “Internal Revenue Code of 1954”, which for purposes of codification was translated as “title 26” thus requiring no change in text."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
