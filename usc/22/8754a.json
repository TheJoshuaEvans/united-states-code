{"tag":"section","attrib":{"id":"id910e7ab7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8754a"},"text":null,"children":[{"tag":"num","attrib":{"value":"8754a"},"text":"§ 8754a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategy and grant program to promote internet freedom in Iran","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id910e7ab8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8754a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategy","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id910e7ab9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8754a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2024-12-23"},"text":"December 23, 2024","children":[],"tail":", the Secretary of State, in consultation with the heads of other Federal agencies, as appropriate, shall develop a strategy to support and enhance access to information by civil society in Iran."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e7aba-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8754a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The strategy required in subparagraph (A) ","children":[{"tag":"ref","attrib":{"idref":"fn002414"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002414"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “paragraph (1)”."}],"tail":" shall include the following elements:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id910e7abb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8754a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An evaluation of the use of virtual private networks by civil society in Iran.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910e7abc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8754a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of the level of internet access for Iranians who do not use virtual private networks, including levels of reliable connectivity, bandwidth, and coverage, as well as censorship, surveillance, and other limitations on internet access.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910e7abd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8754a/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A strategy to increase the accessibility of virtual private networks in Iran.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910e7abe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8754a/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of alternatives to virtual private networks that are capable of circumventing restrictions on open internet access imposed by the Government of Iran.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910e7abf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8754a/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of how companies providing Iranian civilians with technology and other tools to overcome technical and political obstacles are able to access the open internet.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910e7ac0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8754a/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of the ability of the Government of Iran to cut off all access to the internet in Iran.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910e7ac1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8754a/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A strategy to circumvent internet blackouts for Iranian civil society.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e7ac2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8754a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial update","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2024-12-23"},"text":"December 23, 2024","children":[],"tail":", the Secretary, in consultation with the heads of other Federal agencies, as appropriate, shall submit to the Committee on Foreign Affairs of the House of Representatives and the Committee on Foreign Relations of the Senate an updated version of the strategy required in paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e7ac3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8754a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic review and updates","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with the heads of other Federal agencies, as appropriate, shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id910e7ac4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8754a/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less frequently than twice each year, review the strategy required in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910e7ac5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8754a/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the results of such review indicate that modifications to such strategy are required to more effectively promote internet freedom and access to information for civil society in Iran, submit to the Committee on Foreign Affairs of the House of Representatives and the Committee on Foreign Relations of the Senate an updated version of such strategy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e7ac6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8754a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each strategy required to be submitted under this subsection shall be submitted in unclassified form, but may include a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id910e7ac7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8754a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant program and contract authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id910e7ac8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8754a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State, in consultation with the Administrator of the United States Agency for International Development and the President of the Open Technology Fund, as appropriate, may award grants and enter into contracts to private organizations to support and develop programs in Iran that promote or expand—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id910e7ac9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8754a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an open, interoperable, reliable, and secure internet; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910e7aca-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8754a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the online exercise of internationally recognized human rights and fundamental freedoms of civil society in Iran.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e7acb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8754a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program goals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The goal of each program developed with a grant funds awarded pursuant to paragraph (1) shall be to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id910e7acc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8754a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support unrestricted access to the internet in Iran;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910e7acd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8754a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the availability of internet freedom tools to overcome technical and political obstacles to internet access in Iran;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910e7ace-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8754a/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the distribution of such technologies and tools throughout Iran;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910e7acf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8754a/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct research on repressive tactics that undermine internet freedom in Iran;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910e7ad0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8754a/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that information regarding digital safety is available to civil society in Iran; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910e7ad1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8754a/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage private industry, including e-commerce firms and social networking companies, regarding the importance of preserving unrestricted internet access in Iran.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e7ad2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8754a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant award requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award grants authorized in paragraph (1) to recipients through an evidence-based process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e7ad3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8754a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security audits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall conduct a comprehensive security audit of each new technology developed using grant funds distributed pursuant to paragraph (1) to ensure that each such technology is secure and has not been compromised in a manner detrimental to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id910e7ad4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8754a/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the interests of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910e7ad5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8754a/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual or organization benefitting from a program supported by such funding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e7ad6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8754a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id910e7ad7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8754a/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated for the Open Technology Fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6208a"},"text":"section 6208a of this title","children":[],"tail":" $15,000,000 for each of fiscal years 2025 and 2026 to carry out the grant program authorized under this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910e7ad8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8754a/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts appropriated pursuant to the authorization in subparagraph (A) are authorized remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id910e7ad9-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dE/tLI/s5124"},"text":"Pub. L. 118–159, div. E, title LI, § 5124","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2431"},"text":"138 Stat. 2431","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id910e7ada-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id910e7adb-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id910e7adc-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Servicemember Quality of Life Improvement and National Defense Authorization Act for Fiscal Year 2025, and not as part of the Iran Threat Reduction and Syria Human Rights Act of 2012 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
