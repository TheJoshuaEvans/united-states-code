{"tag":"section","attrib":{"id":"id9153995d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10225"},"text":null,"children":[{"tag":"num","attrib":{"value":"10225"},"text":"§ 10225.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sunset","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9153995e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10225/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority to impose sanctions and the sanctions imposed under this subchapter shall terminate on the date that is 8 years after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9153995f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10225/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification for early sunset of sanctions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Sanctions imposed under this subchapter may be removed before the date specified in subsection (a), if the President submits to the appropriate congressional committees a certification that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91539960-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10225/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Burmese military has released all political prisoners taken into custody on or after ","children":[{"tag":"date","attrib":{"date":"2021-02-01"},"text":"February 1, 2021","children":[],"tail":", or is providing legal recourse to those that remain in custody;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91539961-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10225/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the elected government of Burma has been reinstated or new free and fair elections have been held;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91539962-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10225/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all legal charges against those winning election in November 2020 are dropped; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91539963-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10225/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 2008 constitution of Burma has been amended or replaced to place the Burmese military under civilian oversight and ensure that the Burmese military no longer automatically receives 25 percent of seats in Burma’s state, regional, and national Hluttaws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91539964-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10225/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification for early sunset of sanctions on individuals","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91539965-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10225/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President may terminate the application of sanctions under this subchapter with respect to specific individuals if the President submits to the appropriate congressional committees—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91539966-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10225/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a notice of and justification for the termination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91539967-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10225/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a notice that the individual is not engaging in the activity or is no longer occupying the position that was the basis for the sanctions or has taken significant verifiable steps toward stopping the activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91539968-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10225/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The notice required by paragraph (1) shall be submitted in unclassified form but may include a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id91539969-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLV/s5574"},"text":"Pub. L. 117–263, div. E, title LV, § 5574","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3368"},"text":"136 Stat. 3368","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
