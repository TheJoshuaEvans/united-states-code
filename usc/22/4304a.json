{"tag":"section","attrib":{"id":"id9075e3bc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4304a"},"text":null,"children":[{"tag":"num","attrib":{"value":"4304a"},"text":"§ 4304a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement of compliance with liability insurance requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9075e3bd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4304a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to Secretary by head of foreign mission of lapse or termination of coverage; report to Secretary by head of foreign mission respecting motor vehicles, vessels and aircraft registered in United States","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9075e3be-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4304a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of a foreign mission shall notify promptly the Secretary of the lapse or termination of any liability insurance coverage held by a member of the mission, by a member of the family of such member, or by an individual described in section 19 of the Convention on Privileges and Immunities of the United Nations of ","children":[{"tag":"date","attrib":{"date":"1946-02-13"},"text":"February 13, 1946","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9075e3bf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4304a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than February 1 of each year, the head of each foreign mission shall prepare and transmit to the Secretary a report including a list of motor vehicles, vessels, and aircraft registered in the United States by members of the mission, members of the families of such members, individuals described in section 19 of the Convention on Privileges and Immunities of the United Nations of ","children":[{"tag":"date","attrib":{"date":"1946-02-13"},"text":"February 13, 1946","children":[],"tail":", and by the mission itself. Such list shall set forth for each such motor vehicle, vessel, or aircraft—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9075e3c0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4304a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the jurisdiction in which it is registered;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9075e3c1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4304a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the insured;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9075e3c2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4304a/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the insurance company;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9075e3c3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4304a/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the insurance policy number and the extent of insurance coverage; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9075e3c4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4304a/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9075e3c5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4304a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surcharge or fee covering unsatisfied part of judgment; preconditions for imposition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whenever the Secretary finds that a member of a foreign mission, a member of the family of such member, or an individual described in section 19 of the Convention on Privileges and Immunities of the United Nations of ","children":[{"tag":"date","attrib":{"date":"1946-02-13"},"text":"February 13, 1946","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id9075e3c6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4304a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is at fault for personal injury, death, or property damage arising out of the operation of a motor vehicle, vessel, or aircraft in the United States,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9075e3c7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4304a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not covered by liability insurance, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9075e3c8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4304a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not satisfied a court-rendered judgment against him or is not legally liable,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Secretary shall impose a surcharge or fee on the foreign mission of which such member or individual is a part, amounting to the unsatisfied portion of the judgment rendered against such member or individual or, if there is no court-rendered judgment, an estimated amount of damages incurred by the victim. The payment of any such surcharge or fee shall be available only for compensation of the victim or his estate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9075e3c9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4304a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9075e3ca-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4304a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “head of a foreign mission” has the same meaning as is ascribed to the term “head of a mission” in Article 1 of the Vienna Convention on Diplomatic Relations of ","children":[{"tag":"date","attrib":{"date":"1961-04-18"},"text":"April 18, 1961","children":[],"tail":" (T.I.A.S. numbered 7502; 23 U.S.T. 3227); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9075e3cb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4304a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “members of a mission” and “family” have the same meanings as is ascribed to them by paragraphs (1) and (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s254a"},"text":"section 254a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9075e3cc-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch841"},"text":"Aug. 1, 1956, ch. 841","children":[],"tail":", title II, § 204A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/164/tVI/s603"},"text":"Pub. L. 98–164, title VI, § 603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-11-22"},"text":"Nov. 22, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1042"},"text":"97 Stat. 1042","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s162"},"text":"Pub. L. 103–236, title I, § 162","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(4), "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/410"},"text":"108 Stat. 410","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9075e3cd-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9075e3ce-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9075e3cf-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":" substituted “Secretary” for “Director” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9075e3d0-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9075e3d1-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":" applicable with respect to officials, offices, and bureaus of Department of State when executive orders, regulations, or departmental directives implementing the amendments by sections 161 and 162 of "},{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":" become effective, or 90 days after "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", whichever comes earlier, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/s161/b"},"text":"section 161(b) of Pub. L. 103–236","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651a"},"text":"section 2651a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
