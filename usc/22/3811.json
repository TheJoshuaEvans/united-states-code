{"tag":"section","attrib":{"id":"id90489263-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3811"},"text":null,"children":[{"tag":"num","attrib":{"value":"3811"},"text":"§ 3811.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operating regulations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Commission may prescribe, and from time to time amend, regulations governing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90489264-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3811/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the operation of the Panama Canal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90489265-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3811/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the navigation of the harbors and other waters of the Panama Canal and areas adjacent thereto, including the ports of Balboa and Cristobal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90489266-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3811/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the passage and control of vessels through the Panama Canal or any part thereof, including the locks and approaches thereto;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90489267-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3811/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pilotage in the Panama Canal or the approaches thereto through the adjacent waters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90489268-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3811/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the licensing of officers or other operators of vessels navigating the waters of the Panama Canal and areas adjacent thereto, including the ports of Balboa and Cristobal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90489269-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70/tI/s1801"},"text":"Pub. L. 96–70, title I, § 1801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-27"},"text":"Sept. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/492"},"text":"93 Stat. 492","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dC/tXXXV/s3545"},"text":"Pub. L. 104–201, div. C, title XXXV, § 3545","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2867"},"text":"110 Stat. 2867","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9048926a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9048926b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9048926c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" substituted “Commission” for “President” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
