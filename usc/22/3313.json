{"tag":"section","attrib":{"id":"id90357f10-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3313"},"text":null,"children":[{"tag":"num","attrib":{"value":"3313"},"text":"§ 3313.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional oversight","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90357f11-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3313/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring activities of Senate Foreign Relations Committee, House Foreign Affairs Committee, and other Congressional committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee on Foreign Affairs of the House of Representatives, the Committee on Foreign Relations of the Senate, and other appropriate committees of the Congress shall monitor—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90357f12-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3313/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the implementation of the provisions of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90357f13-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3313/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the operation and procedures of the Institute;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90357f14-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3313/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the legal and technical aspects of the continuing relationship between the United States and Taiwan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90357f15-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3313/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the implementation of the policies of the United States concerning security and cooperation in East Asia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90357f16-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3313/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Committee reports to their respective Houses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such committees shall report, as appropriate, to their respective Houses on the results of their monitoring.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90357f17-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/8/s14"},"text":"Pub. L. 96–8, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-04-10"},"text":"Apr. 10, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/20"},"text":"93 Stat. 20","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90357f18-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90357f19-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id90357f1a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"