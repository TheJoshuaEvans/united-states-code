{"tag":"section","attrib":{"id":"id910e7ae3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8756"},"text":null,"children":[{"tag":"num","attrib":{"value":"8756"},"text":"§ 8756.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary of State assistance for prisoners in Islamic Republic of Iran","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id910e7ae4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8756/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of policy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the policy of the United States that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id910e7ae5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8756/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Islamic Republic of Iran should allow the United Nations Special Rapporteur on the Situation of Human Rights in the Islamic Republic of Iran unimpeded access to facilitate the full implementation of the mandate of the United Nations Special Rapporteur, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id910e7ae6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8756/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investigating alleged violations of human rights that are occurring or have occurred both within prisons and elsewhere;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910e7ae7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8756/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transmitting urgent appeals and letters to the Islamic Republic of Iran regarding alleged violations of human rights; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910e7ae8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8756/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engaging with relevant stakeholders in the Islamic Republic of Iran and the surrounding region;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e7ae9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8756/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Islamic Republic of Iran should immediately end violations of the human rights of political prisoners or persons imprisoned for exercising the right to freedom of speech, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id910e7aea-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8756/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" torture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910e7aeb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8756/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" denial of access to health care; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910e7aec-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8756/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" denial of a fair trial;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e7aed-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8756/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all prisoners of conscience and political prisoners in the Islamic Republic of Iran should be unconditionally and immediately released;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e7aee-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8756/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all diplomatic tools of the United States should be invoked to ensure that all prisoners of conscience and political prisoners in the Islamic Republic of Iran are released, including raising individual cases of particular concern; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e7aef-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8756/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all officials of the government of the Islamic Republic of Iran who are responsible for human rights abuses in the form of politically motivated imprisonment should be held to account, including through the imposition of sanctions pursuant to the Global Magnitsky Human Rights Accountability Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s10101"},"text":"22 U.S.C. 10101","children":[],"tail":" et seq.) and other applicable statutory authorities of the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id910e7af0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8756/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance for prisoners","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State is authorized to continue to provide assistance to civil society organizations that support prisoners of conscience and political prisoners in the Islamic Republic of Iran, including organizations that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id910e7af1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8756/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work to secure the release of such prisoners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e7af2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8756/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" document violations of human rights with respect to such prisoners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e7af3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8756/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support international advocacy to raise awareness of issues relating to such prisoners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e7af4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8756/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the health, including mental health, of such prisoners; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e7af5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8756/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide post-incarceration assistance to enable such prisoners to resume normal lives, including access to education, employment, or other forms of reparation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id910e7af6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8756/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id910e7af7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8756/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “political prisoner” means a person who has been detained or imprisoned on politically motivated grounds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e7af8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8756/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “prisoner of conscience” means a person who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id910e7af9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8756/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is imprisoned or otherwise physically restricted solely in response to the peaceful exercise of the human rights of such person; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910e7afa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8756/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not used violence or advocated violence or hatred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id910e7afb-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLV/s5592"},"text":"Pub. L. 117–263, div. E, title LV, § 5592","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3384"},"text":"136 Stat. 3384","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id910e7afc-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id910e7afd-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id910e7afe-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Global Magnitsky Human Rights Accountability Act, referred to in subsec. (a)(5), is subtitle F (§§ 1261–1264) of title XII of div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2533"},"text":"130 Stat. 2533","children":[],"tail":", which is classified generally to chapter 108 (§ 10101 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s10101"},"text":"section 10101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id910e7aff-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the James M. Inhofe National Defense Authorization Act for Fiscal Year 2023, and not as part of the Iran Threat Reduction and Syria Human Rights Act of 2012 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
