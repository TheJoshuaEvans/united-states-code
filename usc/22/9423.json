{"tag":"section","attrib":{"id":"id9128b9b9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9423"},"text":null,"children":[{"tag":"num","attrib":{"value":"9423"},"text":"§ 9423.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanctions to combat the proliferation of Iranian missiles","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9128b9ba-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9423/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The sanctions described in subsection (b) shall apply to any foreign person the President determines, on or after ","children":[{"tag":"date","attrib":{"date":"2024-04-24"},"text":"April 24, 2024","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id9128b9bb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9423/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly engages in any effort to acquire, possess, develop, transport, transfer, or deploy covered technology to, from, or involving the Government of Iran or Iran-aligned entities, regardless of whether the restrictions set forth in Annex B to United Nations Security Council Resolution 2231 (2015) remain in effect after October 2023;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9128b9bc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9423/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly provides entities owned or controlled by the Government of Iran or Iran-aligned entities with goods, technology, parts, or components, that may contribute to the development of covered technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9128b9bd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9423/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly participates in joint missile or drone development, including development of covered technology, with the Government of Iran or Iran-aligned entities, including technical training, storage, and transport;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9128b9be-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9423/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly imports, exports, or re-exports to, into, or from Iran, whether directly or indirectly, any significant arms or related materiel prohibited under paragraph (5) or (6) to Annex B of United Nations Security Council Resolution 2231 (2015) as of ","children":[{"tag":"date","attrib":{"date":"2023-04-01"},"text":"April 1, 2023","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9128b9bf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9423/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly provides significant financial, material, or technological support to, or knowingly engages in a significant transaction with, a foreign person subject to sanctions for conduct described in paragraph (1), (2), (3), or (4); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9128b9c0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9423/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an adult family member of a person subject to sanctions for conduct described in paragraph (1), (2), (3), or (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9128b9c1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9423/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanctions described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The sanctions described in this subsection are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9128b9c2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9423/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Blocking of property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall exercise all authorities granted under the International Emergency Economic Powers Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":" et seq.) to the extent necessary to block and prohibit all transactions in property and interests in property of the foreign person if such property and interests in property are in the United States, come within the United States, or come within the possession or control of a United States person."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9128b9c3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9423/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ineligibility for visas, admission, or parole","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9128b9c4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9423/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Visas, admission, or parole","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An alien described in subsection (a) shall be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9128b9c5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9423/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inadmissible to the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9128b9c6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9423/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ineligible to receive a visa or other documentation to enter the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9128b9c7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9423/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise ineligible to be admitted or paroled into the United States or to receive any other benefit under the Immigration and Nationality Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"8 U.S.C. 1101","children":[],"tail":" et 16 "},{"tag":"ref","attrib":{"idref":"fn002445"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002445"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The number “16” probably should not appear."}],"tail":" seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9128b9c8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9423/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Current visas revoked","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9128b9c9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9423/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The visa or other entry documentation of any alien described in subsection (a) is subject to revocation regardless of the issue date of the visa or other entry documentation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9128b9ca-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9423/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Immediate effect","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A revocation under clause (i) shall, in accordance with section 221(i) of the Immigration and Nationality Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1201/i"},"text":"8 U.S.C. 1201(i)","children":[],"tail":")—"}],"tail":null},{"tag":"subclause","attrib":{"id":"id9128b9cb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9423/b/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take effect immediately; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id9128b9cc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9423/b/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cancel any other valid visa or entry documentation that is in the possession of the alien.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9128b9cd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9423/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person that violates, or attempts to violate, subsection (b) or any regulation, license, or order issued pursuant to that subsection, shall be subject to the penalties set forth in subsections (b) and (c) of section 206 of the International Economic ","children":[{"tag":"ref","attrib":{"idref":"fn002446"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002446"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be preceded by “Emergency”."}],"tail":" Powers Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1705"},"text":"50 U.S.C. 1705","children":[],"tail":") to the same extent as a person that commits an unlawful act described in subsection (a) of that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9128b9ce-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9423/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may waive the application of sanctions under this section with respect to a foreign person for renewable periods not to exceed 180 days only if, not later than 15 days after the date on which the waiver is to take effect, the President submits to the appropriate congressional committees a written determination and justification that the waiver is in the vital national security interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9128b9cf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9423/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may exercise all authorities provided under sections 203 and 205 of the International Emergency Economic Powers Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1702"},"text":"50 U.S.C. 1702","children":[],"tail":" and 1704) to carry out any amendments made by this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9128b9d0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9423/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9128b9d1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9423/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall, not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2024-04-24"},"text":"April 24, 2024","children":[],"tail":", promulgate regulations as necessary for the implementation of this division and the amendments made by this division."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9128b9d2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9423/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 10 days before the promulgation of regulations under subsection (a), the President shall notify the appropriate congressional committees of the proposed regulations and the provisions of this division and the amendments made by this division that the regulations are implementing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9128b9d3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9423/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9128b9d4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9423/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for intelligence activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Sanctions under this section shall not apply to any activity subject to the reporting requirements under title V of the National Security Act of 1947 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3091"},"text":"50 U.S.C. 3091","children":[],"tail":" et seq.) or any authorized intelligence activities of the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9128b9d5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9423/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception to comply with international obligations and for law enforcement activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Sanctions under this section shall not apply with respect to an alien if admitting or paroling the alien into the United States is necessary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9128b9d6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9423/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to permit the United States to comply with the Agreement regarding the Headquarters of the United Nations, signed at Lake Success ","children":[{"tag":"date","attrib":{"date":"1947-06-26"},"text":"June 26, 1947","children":[],"tail":", and entered into force "},{"tag":"date","attrib":{"date":"1947-11-21"},"text":"November 21, 1947","children":[],"tail":", between the United Nations and the United States, or other applicable international obligations; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9128b9d7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9423/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out or assist authorized law enforcement activity in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9128b9d8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9423/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of sanctions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section shall cease to be effective beginning on the date that is 30 days after the date on which the President certifies to the appropriate congressional committees that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9128b9d9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9423/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Government of Iran no longer repeatedly provides support for international terrorism as determined by the Secretary of State pursuant to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9128b9da-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9423/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4813/c/1/A"},"text":"section 4813(c)(1)(A) of title 50","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9128b9db-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9423/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2371"},"text":"section 2371 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9128b9dc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9423/h/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2780"},"text":"section 2780 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9128b9dd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9423/h/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other provision of law; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9128b9de-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9423/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Iran has ceased the pursuit, acquisition, and development of, and verifiably dismantled its, nuclear, biological, and chemical weapons and ballistic missiles and ballistic missile launch technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9128b9df-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/50/dK/s5"},"text":"Pub. L. 118–50, div. K, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-04-24"},"text":"Apr. 24, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/972"},"text":"138 Stat. 972","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9128b9e0-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9128b9e1-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9128b9e2-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The International Emergency Economic Powers Act, referred to in subsec. (b)(1), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/223"},"text":"Pub. L. 95–223","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-12-28"},"text":"Dec. 28, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1626"},"text":"91 Stat. 1626","children":[],"tail":", which is classified generally to chapter 35 (§ 1701 et seq.) of Title 50, War and National Defense. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"section 1701 of Title 50","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Immigration and Nationality Act, referred to in subsec. (b)(2)(iii), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"act June 27, 1952, ch. 477","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/163"},"text":"66 Stat. 163","children":[],"tail":", which is classified principally to chapter 12 (§ 1101 et seq.) of Title 8, Aliens and Nationality. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of Title 8","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This division, referred to in subsec. (f), is div. K of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/50"},"text":"Pub. L. 118–50","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-04-24"},"text":"Apr. 24, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/970"},"text":"138 Stat. 970","children":[],"tail":", known as the Fight and Combat Rampant Iranian Missile Exports Act and also as the Fight CRIME Act, which enacted this chapter. Division K did not make any amendments."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The National Security Act of 1947, referred to in subsec. (g)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"act July 26, 1947, ch. 343","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/495"},"text":"61 Stat. 495","children":[],"tail":". Title V of the Act is classified generally to subchapter III (§ 3091 et seq.) of chapter 44 of Title 50, War and National Defense. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id9128b9e3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9128b9e4-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum of President of the United States, § 2, ","children":[{"tag":"date","attrib":{"date":"2024-09-13"},"text":"Sept. 13, 2024","children":[],"tail":", 89 F.R. 77757, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(a) I hereby delegate to the Secretary of State, in consultation with the Secretary of the Treasury, the functions and authorities vested in the President by sections 5(a)(1), 5(a)(2), 5(a)(3), and 5(a)(4) of the Fight and Combat Rampant Iranian Missile Exports Act (Division K of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/50"},"text":"Public Law 118–50","children":[],"tail":") (the “Fight CRIME Act”) ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s9423/a/1"},"text":"22 U.S.C. 9423(a)(1)","children":[],"tail":" to (4)]."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(b) I hereby delegate to the Secretary of the Treasury, in consultation with the Secretary of State, the functions and authorities vested in the President by sections 5(a)(5), 5(a)(6), 5(e), and 5(f) of the Fight CRIME Act.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(c) I hereby delegate to the Secretary of the Treasury the functions and authorities vested in the President by section 5(b)(1) of the Fight CRIME Act.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(d) I hereby delegate to the Secretary of State the functions and authorities vested in the President by sections 5(d), 5(h), and 6(c) of the Fight CRIME Act.","children":[],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"J.R. Biden, Jr.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
