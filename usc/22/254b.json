{"tag":"section","attrib":{"id":"id8e85fa4f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s254b"},"text":null,"children":[{"tag":"num","attrib":{"value":"254b"},"text":"§ 254b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privileges and immunities of mission of nonparty to Vienna Convention","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"With respect to a nonparty to the Vienna Convention, the mission, the members of the mission, their families, and diplomatic couriers shall enjoy the privileges and immunities specified in the Vienna Convention.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8e85fa50-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/393/s3/b"},"text":"Pub. L. 95–393, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-09-30"},"text":"Sept. 30, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/808"},"text":"92 Stat. 808","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/241/tII/s203/b/2"},"text":"Pub. L. 97–241, title II, § 203(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-08-24"},"text":"Aug. 24, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/291"},"text":"96 Stat. 291","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8e85fa51-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8e85fa52-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8e85fa53-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"