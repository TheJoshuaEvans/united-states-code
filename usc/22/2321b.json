{"tag":"section","attrib":{"id":"id8f8c46e2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2321b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2321b"},"text":"§ 2321b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excess defense article","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f8c46e3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2321b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" to (c) Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/329/tII/s210/c/2"},"text":"Pub. L. 94–329, title II, § 210(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-06-30"},"text":"June 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/740"},"text":"90 Stat. 740","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f8c46e4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2321b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall promptly and fully inform the Speaker of the House of Representatives and the Committee on Foreign Relations and the Committee on Appropriations of the Senate of each decision to furnish on a grant basis to any country excess defense articles which are major weapons systems to the extent such major weapons system was not included in the presentation material previously submitted to the Congress. The annual presentation materials for security assistance programs shall include a table listing by country the total value of all deliveries of excess defense articles, disclosing both the aggregate original acquisition cost and the aggregate value at the time of delivery.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f8c46e5-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/672/s8"},"text":"Pub. L. 91–672, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-12"},"text":"Jan. 12, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/2054"},"text":"84 Stat. 2054","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/226"},"text":"Pub. L. 92–226","children":[],"tail":", pt. IV, § 402, "},{"tag":"date","attrib":{"date":"1972-02-07"},"text":"Feb. 7, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/33"},"text":"86 Stat. 33","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/189/s26/1"},"text":"Pub. L. 93–189, § 26(1)","children":[],"tail":"–(3), "},{"tag":"date","attrib":{"date":"1973-12-17"},"text":"Dec. 17, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/731"},"text":"87 Stat. 731","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/559/s13"},"text":"Pub. L. 93–559, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-12-30"},"text":"Dec. 30, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1799"},"text":"88 Stat. 1799","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/329/tII/s210/c/2"},"text":"Pub. L. 94–329, title II, § 210(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-06-30"},"text":"June 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/740"},"text":"90 Stat. 740","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/384/s29/a"},"text":"Pub. L. 95–384, § 29(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-09-26"},"text":"Sept. 26, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/747"},"text":"92 Stat. 747","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f8c46e6-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f8c46e7-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8f8c46e8-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Foreign Assistance Act of 1961 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f8c46e9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/384"},"text":"Pub. L. 95–384","children":[],"tail":" substituted “The annual presentation materials for security assistance programs shall include a table” for “Additionally, the President shall also submit a quarterly report to the Congress”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/329"},"text":"Pub. L. 94–329","children":[],"tail":" struck out subsec. (a) which provided that the value of excess defense article granted to a foreign country or international organization shall be considered to be an expenditure from the funds of this chapter for military assistance, and established accounting procedure when an order for excess defense article was placed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/329"},"text":"Pub. L. 94–329","children":[],"tail":" struck out subsec. (b) which provided that in the case of excess defense articles that were generated abroad, provisions of former subsec. (a) shall apply during any fiscal year only to the extent that the aggregate value of excess defense articles ordered during that year exceeded $100,000,000."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/329"},"text":"Pub. L. 94–329","children":[],"tail":" struck out subsec. (c) which defined “value” as that meaning found in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2403m"},"text":"section 2403m of this title","children":[],"tail":", except the term shall not include a value for any excess defense article which was less than 33⅓ percent of the amount the United States paid for such article when it was acquired."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/329"},"text":"Pub. L. 94–329","children":[],"tail":" struck out subsec. (e) which provided that except for excess defense articles granted under this subchapter, the provisions of this section did not apply to grants of such articles to South Vietnam prior to "},{"tag":"date","attrib":{"date":"1972-07-01"},"text":"July 1, 1972","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/559/s13/a/1"},"text":"Pub. L. 93–559, § 13(a)(1)","children":[],"tail":", substituted “$100,000,000” for “$150,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/559/s13/a/2"},"text":"Pub. L. 93–559, § 13(a)(2)","children":[],"tail":", inserted exception provision respecting definitions of value for excess defense articles."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/189/s26/1"},"text":"Pub. L. 93–189, § 26(1)","children":[],"tail":", inserted provision preceding cl. (1) relating to the subtraction of amounts to be transferred under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2392/d"},"text":"section 2392(d) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/189/s26/2"},"text":"Pub. L. 93–189, § 26(2)","children":[],"tail":", substituted “In the case of excess defense articles which are generated abroad, the provisions”, for “The provisions” and “$150,000,000” for “$185,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/189/s26/3"},"text":"Pub. L. 93–189, § 26(3)","children":[],"tail":", substituted provisions defining “value” as that meaning given it in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2403/m"},"text":"section 2403(m) of this title","children":[],"tail":", for provisions defining such term as not less than 33⅓ per centum of the amount the United States paid at the time the excess defense articles were acquired by the United States."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/226/s402/1"},"text":"Pub. L. 92–226, § 402(1)","children":[],"tail":", substituted in first sentence “by any department, agency, or independent establishment of the United States Government (other than the Agency for International Development)” for “subchapter II of this chapter” and “the Foreign Assistance Act of 1961” for “that Act”, codified in the text as “this chapter” and in second sentence “Unless such department, agency, or establishment certifies to the Comptroller General of the United States that the excess defense article it is ordering is not to be transferred by any means to a foreign country or international organization, when an order is placed for a defense article” for “When an order is placed under the military assistance program with the military departments for a defense article”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/226/s402/2"},"text":"Pub. L. 92–226, § 402(2)","children":[],"tail":", substituted “$185,000,000” for “$100,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/226/s402/3"},"text":"Pub. L. 92–226, § 402(3)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f8c46ea-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8f8c46eb-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/329/tII/s210/c/2"},"text":"Pub. L. 94–329, title II, § 210(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-06-30"},"text":"June 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/740"},"text":"90 Stat. 740","children":[],"tail":", provided in part that the amendment of subsecs. (a) to (c) and (e) by "},{"tag":"ref","attrib":{"href":"/us/pl/94/329"},"text":"Pub. L. 94–329","children":[],"tail":" is effective "},{"tag":"date","attrib":{"date":"1976-07-01"},"text":"July 1, 1976","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8f8c46ec-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transfer of Suspense Account Funds to General Fund of Treasury","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/329/tII/s210/c/2"},"text":"Pub. L. 94–329, title II, § 210(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-06-30"},"text":"June 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/740"},"text":"90 Stat. 740","children":[],"tail":", provided in part that all funds in the suspense account referred to in former subsec. (a) of this section on "},{"tag":"date","attrib":{"date":"1976-07-01"},"text":"July 1, 1976","children":[],"tail":", shall be transferred to the general fund of the Treasury."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id8f8c46ed-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id8f8c46ee-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions of President under this section, see Ex. Ord. No. 12163, ","children":[{"tag":"date","attrib":{"date":"1979-09-29"},"text":"Sept. 29, 1979","children":[],"tail":", 44 F.R. 56673, as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2381"},"text":"section 2381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
