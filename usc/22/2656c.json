{"tag":"section","attrib":{"id":"id8feba515-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2656c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2656c"},"text":"§ 2656c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of President","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8feba516-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2656c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification, evaluation and initiation of scientific and technological developments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President, in consultation with the Director of the Office of Science and Technology Policy and other officials whom the President considers appropriate, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8feba517-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2656c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notwithstanding any other provision of law, insure that the Secretary of State is informed and consulted before any agency of the United States Government takes any major action, primarily involving science or technology, with respect to any foreign government or international organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8feba518-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2656c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and evaluate elements of major domestic science and technology programs and activities of the United States Government with significant international implications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8feba519-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2656c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and evaluate international scientific or technological developments with significant implications for domestic programs and activities of the United States Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8feba51a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2656c/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess and initiate appropriate international scientific and technological activities which are based upon domestic scientific and technological activities of the United States Government and which are beneficial to the United States and foreign countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8feba51b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2656c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/66/tI/s1111/b"},"text":"Pub. L. 104–66, title I, § 1111(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-21"},"text":"Dec. 21, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/723"},"text":"109 Stat. 723","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8feba51c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2656c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure of sensitive information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided by law, nothing in this section shall be construed as requiring the public disclosure of sensitive information relating to intelligence sources or methods or to persons engaged in monitoring scientific or technological developments for intelligence purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8feba51d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2656c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability to United States Trade Representative of information and recommendations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8feba51e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2656c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The information and recommendations developed under subsection (b)(3) shall be made available to the United States Trade Representative for use in his consultations with Federal agencies pursuant to Executive orders pertaining to the transfer of science and technology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8feba51f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2656c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In providing such information and recommendations, the President shall utilize information developed by any Federal departments, agencies, or interagency committees as he may consider necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8feba520-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/426/tV/s503"},"text":"Pub. L. 95–426, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-07"},"text":"Oct. 7, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/983"},"text":"92 Stat. 983","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tV/s5171/b"},"text":"Pub. L. 100–418, title V, § 5171(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1453"},"text":"102 Stat. 1453","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/tI/s1111/b"},"text":"Pub. L. 104–66, title I, § 1111(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-21"},"text":"Dec. 21, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/723"},"text":"109 Stat. 723","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8feba521-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8feba522-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8feba523-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1995—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/66"},"text":"Pub. L. 104–66","children":[],"tail":" struck out subsec. (b) which related to reports to Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/s5171/b/1"},"text":"Pub. L. 100–418, § 5171(b)(1)","children":[],"tail":", (2), substituted “the Speaker of the House of Representatives and the Committees on Foreign Relations and Governmental Affairs of the Senate a report containing information and recommendations” for “Congress a report containing recommendations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/s5171/b/3"},"text":"Pub. L. 100–418, § 5171(b)(3)","children":[],"tail":"–(5), added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/s5171/c"},"text":"Pub. L. 100–418, § 5171(c)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
