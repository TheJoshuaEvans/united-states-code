{"tag":"section","attrib":{"id":"id906eb763-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4133"},"text":null,"children":[{"tag":"num","attrib":{"value":"4133"},"text":"§ 4133.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Freedom of action","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id906eb764-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4133/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nature of protection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any individual filing a grievance under this subchapter (hereinafter in this subchapter referred to as the “grievant”), and any witness, labor organization, or other person involved in a grievance proceeding, shall be free from any restraint, interference, coercion, harassment, discrimination, or reprisal in those proceedings or by virtue of them.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id906eb765-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4133/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right to representation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id906eb766-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4133/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The grievant has the right to a representative of his or her own choosing at every stage of the proceedings under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906eb767-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4133/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any case where the grievant is a member of a bargaining unit represented by an exclusive representative, but is not represented in the grievance by that exclusive representative, the exclusive representative shall have the right to appear during the grievance proceedings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906eb768-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4133/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The grievant, and any representative of the grievant who is a member of the Service or employee of the Department, shall be granted reasonable periods of administrative leave to prepare and present the grievance and to attend proceedings under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id906eb769-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4133/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative leave for witnesses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any witness who is a member of the Service or employee of the Department shall be granted reasonable periods of administrative leave to appear and testify at any proceedings under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id906eb76a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4133/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id906eb76b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4133/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" No record of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id906eb76c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4133/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a determination by the Secretary to reject a recommendation of the Foreign Service Grievance Board,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id906eb76d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4133/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a finding by the Grievance Board against the grievant, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id906eb76e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4133/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fact that a grievance proceeding is pending or has been held,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be entered in the personnel records of the grievant (except by order of the Grievance Board as a remedy for the grievance) or those of any other individual connected with the grievance. Nothing in this subsection shall prevent a grievant from placing a rebuttal to accompany a record of disciplinary action in such grievant’s personnel records nor prevent the Department from including a response to such rebuttal, including documenting those cases in which the Board has reviewed and upheld the discipline.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906eb76f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4133/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department shall maintain records pertaining to grievances under appropriate safeguards to preserve confidentiality.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906eb770-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4133/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Foreign Service Grievance Board may enforce compliance with the requirements of paragraphs (1) and (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id906eb771-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4133/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expedition of security clearance procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Department will use its best endeavors to expedite security clearance procedures whenever necessary to assure a fair and prompt resolution of a grievance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id906eb772-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s1103"},"text":"Pub. L. 96–465, title I, § 1103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2143"},"text":"94 Stat. 2143","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/7/dA/tIII/s329"},"text":"Pub. L. 106–113, div. B, § 1000(a)(7) [div. A, title III, § 329]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–438.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id906eb773-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id906eb774-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id906eb775-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":" inserted at end “Nothing in this subsection shall prevent a grievant from placing a rebuttal to accompany a record of disciplinary action in such grievant’s personnel records nor prevent the Department from including a response to such rebuttal, including documenting those cases in which the Board has reviewed and upheld the discipline.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
