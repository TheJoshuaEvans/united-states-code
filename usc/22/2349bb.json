{"tag":"section","attrib":{"id":"id8f95bd1f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"2349bb"},"text":"§ 2349bb.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of assistance under this part are to halt the proliferation of nuclear, chemical, and biological weapons, and conventional weaponry, through support of activities designed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f95bd20-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349bb/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enhance the nonproliferation and export control capabilities of friendly countries by providing training and equipment to detect, deter, monitor, interdict, and counter proliferation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f95bd21-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349bb/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to strengthen the bilateral ties of the United States with friendly governments by offering concrete assistance in this area of vital national security interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f95bd22-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349bb/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to accomplish the activities and objectives set forth in sections 5853 and 5854 of this title, without regard to the limitation of those sections to the independent states of the former Soviet Union; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f95bd23-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349bb/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote multilateral activities, including cooperation with international organizations, relating to nonproliferation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f95bd24-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. II, § 581, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/280/tIII/s301"},"text":"Pub. L. 106–280, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-06"},"text":"Oct. 6, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/851"},"text":"114 Stat. 851","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f95bd25-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f95bd26-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8f95bd27-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Nonproliferation Technology Acquisition Programs for Friendly Foreign Countries","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/228/dB/tXIII/s1302"},"text":"Pub. L. 107–228, div. B, title XIII, § 1302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"Sept. 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1435"},"text":"116 Stat. 1435","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/228/dB/tXIII/s1302"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of enhancing the nonproliferation and export control capabilities of friendly countries, of the amount authorized to be appropriated for fiscal year 2003 by section 585 [586] of the Foreign Assistance Act of 1961 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2349bb"},"text":"22 U.S.C. 2349bb","children":[],"tail":" et seq.) ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2349bb–4"},"text":"22 U.S.C. 2349bb–4","children":[],"tail":"], the Secretary is authorized to make available—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000,000 for the procurement and provision of nuclear, chemical, and biological detection systems, including spectroscopic and pulse echo technologies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,000,000 for the procurement and provision of x-ray systems capable of imaging sea-cargo containers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports on Training Program.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Initial report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2003-03-31"},"text":"March 31, 2003","children":[],"tail":", the Secretary shall submit a report to the appropriate congressional committees setting forth his plans and budget for a multiyear training program to train foreign personnel in the utilization of the systems described in subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subsequent reports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2004-03-31"},"text":"March 31, 2004","children":[],"tail":", and annually thereafter for the next three years, the Secretary shall submit a report to the appropriate congressional committees describing the progress, current status, and budget of that training program and of the provision of those systems.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definitions of “Secretary” and “appropriate congressional committees” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/228/s1302"},"text":"section 1302 of Pub. L. 107–228","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/228/s3"},"text":"section 3 of Pub. L. 107–228","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
