{"tag":"section","attrib":{"id":"id8f1764d7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1644i"},"text":null,"children":[{"tag":"num","attrib":{"value":"1644i"},"text":"§ 1644i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time limitation on completion of affairs of Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Commission shall complete its affairs in connection with the settlement of claims pursuant to this subchapter not later than three years following the final date for the filing of claims as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s1644b"},"text":"section 1644b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f1764d8-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-03-10/ch54"},"text":"Mar. 10, 1950, ch. 54","children":[],"tail":", title VI, § 609, as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/542"},"text":"Pub. L. 94–542","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-18"},"text":"Oct. 18, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2512"},"text":"90 Stat. 2512","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
