{"tag":"section","attrib":{"id":"id90ed10ac-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7715"},"text":null,"children":[{"tag":"num","attrib":{"value":"7715"},"text":"§ 7715.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to certain candidate countries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90ed10ad-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7715/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board, acting through the Chief Executive Officer, is authorized to provide assistance to a candidate country described in subsection (b) for the purpose of assisting such country to become an eligible country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90ed10ae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7715/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Candidate country described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A candidate country referred to in subsection (a) is a candidate country that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90ed10af-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7715/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" satisfies the requirements contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7705/a"},"text":"section 7705(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ed10b0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7715/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates a significant commitment to meet the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7706/b"},"text":"section 7706(b) of this title","children":[],"tail":" but fails to meet such requirements (including by reason of the absence or unreliability of data)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90ed10b1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7715/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Assistance under this section may be provided through the United States Agency for International Development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90ed10b2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7715/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90ed10b3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7715/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 10 percent of the amounts made available to carry out this chapter for a fiscal year may be made available to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ed10b4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7715/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction relating to assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"None of the funds authorized to carry out the purposes of this chapter shall be available for assistance under this section to a country that does not qualify as a candidate country under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7705"},"text":"section 7705 of this title","children":[],"tail":" for the fiscal year during which such assistance is provided."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90ed10b5-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/dD/tVI/s616"},"text":"Pub. L. 108–199, div. D, title VI, § 616","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/224"},"text":"118 Stat. 224","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/13/dA/tII/s2109"},"text":"Pub. L. 109–13, div. A, title II, § 2109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-05-11"},"text":"May 11, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/268"},"text":"119 Stat. 268","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/167/tII/s207"},"text":"Pub. L. 115–167, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-04-23"},"text":"Apr. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1282"},"text":"132 Stat. 1282","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dE/tLI/s5122/c/3"},"text":"Pub. L. 118–159, div. E, title LI, § 5122(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2431"},"text":"138 Stat. 2431","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90ed10b6-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90ed10b7-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90ed10b8-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (d), was in the original “this Act”, meaning title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/dD"},"text":"Pub. L. 108–199, div. D","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/211"},"text":"118 Stat. 211","children":[],"tail":", known as the Millennium Challenge Act of 2003, which is classified generally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7701"},"text":"section 7701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90ed10b9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" substituted “section 7705(a)” for “subsection (a) or (b) of section 7705”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/167"},"text":"Pub. L. 115–167","children":[],"tail":" amended subsec. (d) generally. Prior to amendment, text read as follows: “Not more than 10 percent of the amount appropriated pursuant to the authorization of appropriations under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7718/a"},"text":"section 7718(a) of this title","children":[],"tail":" for fiscal year 2004 is authorized to be made available to carry out this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/13"},"text":"Pub. L. 109–13","children":[],"tail":" substituted “subsection (a) or (b) of section 7705” for “subparagraphs (A) and (B) of section 7705(a)(1)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
