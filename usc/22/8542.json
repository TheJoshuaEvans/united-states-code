{"tag":"section","attrib":{"id":"id91050462-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8542"},"text":null,"children":[{"tag":"num","attrib":{"value":"8542"},"text":"§ 8542.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of countries of concern with respect to the diversion of certain goods, services, and technologies to or through Iran","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id91050463-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8542/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2010-07-01"},"text":"July 1, 2010","children":[],"tail":", the Director of National Intelligence shall submit to the President, the Secretary of Defense, the Secretary of Commerce, the Secretary of State, the Secretary of the Treasury, and the appropriate congressional committees a report that identifies each country the government of which the Director believes, based on all information available to the Director, is allowing the diversion through the country of goods, services, or technologies described in subsection (b) to Iranian end-users or Iranian intermediaries."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91050464-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8542/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goods, services, and technologies described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Goods, services, or technologies described in this subsection are goods, services, or technologies—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91050465-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8542/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91050466-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8542/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" originated in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91050467-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8542/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" would make a material contribution to Iran’s—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id91050468-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8542/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of nuclear, chemical, or biological weapons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91050469-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8542/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ballistic missile or advanced conventional weapons capabilities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9105046a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8542/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support for international terrorism; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9105046b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8542/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9105046c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8542/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" items on the Commerce Control List or services related to those items; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9105046d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8542/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" defense articles or defense services on the United States Munitions List; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9105046e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8542/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that are prohibited for export to Iran under a resolution of the United Nations Security Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9105046f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8542/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of National Intelligence shall update the report required by subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91050470-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8542/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as new information becomes available; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91050471-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8542/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less frequently than annually.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91050472-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8542/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report required by subsection (a) and the updates required by subsection (c) may be submitted in classified form.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id91050473-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/195/tIII/s302"},"text":"Pub. L. 111–195, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-01"},"text":"July 1, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1346"},"text":"124 Stat. 1346","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id91050474-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id91050475-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8551/a"},"text":"section 8551(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
