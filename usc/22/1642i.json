{"tag":"section","attrib":{"id":"id8f14f445-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1642i"},"text":null,"children":[{"tag":"num","attrib":{"value":"1642i"},"text":"§ 1642i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification of awards","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Commission shall certify to the Secretary of the Treasury, in terms of United States currency, each award made pursuant to this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f14f446-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-03-10/ch54"},"text":"Mar. 10, 1950, ch. 54","children":[],"tail":", title IV, § 410, as added "},{"tag":"ref","attrib":{"href":"/us/pl/85/604/s1"},"text":"Pub. L. 85–604, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-08"},"text":"Aug. 8, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/529"},"text":"72 Stat. 529","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
