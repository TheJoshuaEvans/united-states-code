{"tag":"section","attrib":{"id":"id911cd1ba-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9112"},"text":null,"children":[{"tag":"num","attrib":{"value":"9112"},"text":"§ 9112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards and assistance","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of State shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id911cd1bb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9112/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure that United States diplomatic and consular missions abroad—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911cd1bc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9112/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain a consistent reporting standard with respect to abduction and access cases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911cd1bd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9112/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate at least 1 senior official in each such mission, at the discretion of the Chief of Mission, to assist left-behind parents from the United States who are visiting such country or otherwise seeking to resolve abduction or access cases; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911cd1be-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9112/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor developments in abduction and access cases; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911cd1bf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9112/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and implement written strategic plans for engagement with any Convention or non-Convention country in which there are 5 or more cases of international child abduction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id911cd1c0-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/150/tI/s102"},"text":"Pub. L. 113–150, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-08-08"},"text":"Aug. 8, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1815"},"text":"128 Stat. 1815","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
