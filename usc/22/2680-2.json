{"tag":"section","attrib":{"id":"id8ff2d1a5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2680–2"},"text":"§ 2680–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facilitating access to Department of State","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ff2d1a6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures to facilitate access","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Department of State shall maintain procedures to ensure that the members and staff of the congressional committees of jurisdiction are granted easy access to the Department of State in the conduct of their duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff2d1a7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Department of State shall also make available adequate parking for members and staff of the congressional committees of jurisdiction in order to facilitate attendance of meetings at the Department of State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ff2d1a8-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s129"},"text":"Pub. L. 103–236, title I, § 129","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/394"},"text":"108 Stat. 394","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
