{"tag":"section","attrib":{"id":"id8e8389d6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s214a"},"text":null,"children":[{"tag":"num","attrib":{"value":"214a"},"text":"§ 214a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees erroneously charged and paid; refund","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever a fee is erroneously charged and paid for the issue of a passport to a person who is exempted from the payment of such a fee by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s214"},"text":"section 214 of this title","children":[],"tail":", the Department of State is authorized to refund to the person who paid such fee the amount thereof, and the money for that purpose is authorized to be appropriated."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8e8389d7-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1926-07-03/ch772/s3"},"text":"July 3, 1926, ch. 772, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/887"},"text":"44 Stat. 887","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8e8389d8-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8e8389d9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8e8389da-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Certain Appropriation Accounts Abolished","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Effective ","children":[{"tag":"date","attrib":{"date":"1935-07-01"},"text":"July 1, 1935","children":[],"tai