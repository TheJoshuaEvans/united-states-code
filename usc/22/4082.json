{"tag":"section","attrib":{"id":"id9069fcbf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4082"},"text":null,"children":[{"tag":"num","attrib":{"value":"4082"},"text":"§ 4082.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan of household effects","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may, as a means of eliminating transportation costs, provide members of the Service with basic household furnishing and equipment for use on a loan basis in personally owned or leased residences.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id9069fcc0-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s902"},"text":"Pub. L. 96–465, title I, § 902","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2127"},"text":"94 Stat. 2127","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
