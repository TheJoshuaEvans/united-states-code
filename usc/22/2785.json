{"tag":"section","attrib":{"id":"id901ffbb5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2785"},"text":null,"children":[{"tag":"num","attrib":{"value":"2785"},"text":"§ 2785.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" End-use monitoring of defense articles and defense services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id901ffbb6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2785/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of monitoring program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id901ffbb7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2785/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to improve accountability with respect to defense articles and defense services sold, leased, or exported under this chapter or the Foreign Assistance Act of 1961 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"22 U.S.C. 2151","children":[],"tail":" et seq.), the President shall establish a program which provides for the end-use monitoring of such articles and services."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id901ffbb8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2785/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements of program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent practicable, such program—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id901ffbb9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2785/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide for the end-use monitoring of defense articles and defense services in accordance with the standards that apply for identifying high-risk exports for regular end-use verification developed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2778/g/7"},"text":"section 2778(g)(7) of this title","children":[],"tail":" (commonly referred to as the “Blue Lantern” program); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id901ffbba-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2785/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall be designed to provide reasonable assurance that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id901ffbbb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2785/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recipient is complying with the requirements imposed by the United States Government with respect to use, transfers, and security of defense articles and defense services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id901ffbbc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2785/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such articles and services are being used for the purposes for which they are provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id901ffbbd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2785/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conduct of program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program established under subsection (a), the President shall ensure that the program—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id901ffbbe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2785/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides for the end-use verification of defense articles and defense services that incorporate sensitive technology, defense articles and defense services that are particularly vulnerable to diversion or other misuse, or defense articles or defense services whose diversion or other misuse could have significant consequences; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id901ffbbf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2785/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevents the diversion (through reverse engineering or other means) of technology incorporated in defense articles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id901ffbc0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2785/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 6 months after ","children":[{"tag":"date","attrib":{"date":"1996-07-21"},"text":"July 21, 1996","children":[],"tail":", and annually thereafter as a part of the annual congressional presentation documents submitted under section 634 of the Foreign Assistance Act of 1961 ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2394"},"text":"22 U.S.C. 2394","children":[],"tail":"], the President shall transmit to the Congress a report describing the actions taken to implement this section, including a detailed accounting of the costs and number of personnel associated with the monitoring program and the numbers, range, and findings of end-use monitoring of United States transfers of small arms and light weapons."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id901ffbc1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2785/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Third country transfers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, defense articles and defense services sold, leased, or exported under this chapter or the Foreign Assistance Act of 1961 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"22 U.S.C. 2151","children":[],"tail":" et seq.) includes defense articles and defense services that are transferred to a third country or other third party."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id901ffbc2-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/629"},"text":"Pub. L. 90–629","children":[],"tail":", ch. 3A, § 40A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/164/tI/s150/a"},"text":"Pub. L. 104–164, title I, § 150(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-07-21"},"text":"July 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1436"},"text":"110 Stat. 1436","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/228/dB/tXII/s1205/b"},"text":"Pub. L. 107–228, div. B, title XII, § 1205(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"Sept. 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1428"},"text":"116 Stat. 1428","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id901ffbc3-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id901ffbc4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id901ffbc5-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a)(1) and (d), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/629"},"text":"Pub. L. 90–629","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1321"},"text":"82 Stat. 1321","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2751"},"text":"section 2751 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Foreign Assistance Act of 1961, referred to in subsecs. (a)(1) and (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/424"},"text":"75 Stat. 424","children":[],"tail":", which is classified principally to chapter 32 (§ 2151 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id901ffbc6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/629/s40A"},"text":"section 40A of Pub. L. 90–629","children":[],"tail":" is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2781"},"text":"section 2781 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id901ffbc7-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/228"},"text":"Pub. L. 107–228","children":[],"tail":" inserted “and the numbers, range, and findings of end-use monitoring of United States transfers of small arms and light weapons” before period at end."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id901ffbc8-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id901ffbc9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/164/tI/s150/b"},"text":"Pub. L. 104–164, title I, § 150(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-07-21"},"text":"July 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1437"},"text":"110 Stat. 1437","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/164/tI/s150/b"},"text":"“Section 40A of the Arms Export Control Act, as added by subsection (a) [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2785"},"text":"22 U.S.C. 2785","children":[],"tail":"], applies with respect to defense articles and defense services provided before or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1996-07-21"},"text":"July 21, 1996","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id901ffbca-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id901ffbcb-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions of the President under this section, with certain conditions, see section 1(p) of Ex. Ord. No. 13637, ","children":[{"tag":"date","attrib":{"date":"2013-03-08"},"text":"Mar. 8, 2013","children":[],"tail":", 78 F.R. 16130, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2751"},"text":"section 2751 of this title","children":[],"tail":". Functions were previously delegated by Ex. Ord. No. 11958, which was formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2751"},"text":"section 2751 of this title","children":[],"tail":" and was revoked, subject to a savings provision, by section 4 of Ex. Ord. No. 13637."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
