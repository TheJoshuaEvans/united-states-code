{"tag":"section","attrib":{"id":"id8fa1a43c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2370c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2370c"},"text":"§ 2370c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In sections 2370c to 2370c–2 of this title:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fa1a43d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2370c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fa1a43e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2370c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fa1a43f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2370c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fa1a440-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2370c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fa1a441-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2370c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fa1a442-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2370c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Child soldier","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Consistent with the provisions of the Optional Protocol to the Convention of the Rights of the Child, the term “child soldier”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fa1a443-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2370c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id8fa1a444-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2370c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person under 18 years of age who takes a direct part in hostilities as a member of governmental armed forces, police, or other security forces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8fa1a445-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2370c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person under 18 years of age who has been compulsorily recruited into governmental armed forces, police, or other security forces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8fa1a446-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2370c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person under 15 years of age who has been voluntarily recruited into governmental armed forces, police, or other security forces; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8fa1a447-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2370c/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person under 18 years of age who has been recruited or used in hostilities by armed forces distinct from the armed forces of a state; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fa1a448-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2370c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes any person described in clause (ii), (iii), or (iv) of subparagraph (A) who is serving in any capacity, including in a support role such as a cook, porter, messenger, medic, guard, or sex slave.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fa1a449-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/457/tIV/s402"},"text":"Pub. L. 110–457, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-12-23"},"text":"Dec. 23, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/5088"},"text":"122 Stat. 5088","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/425/tII/s212/a"},"text":"Pub. L. 115–425, title II, § 212(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-08"},"text":"Jan. 8, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5485"},"text":"132 Stat. 5485","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fa1a44a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8fa1a44b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8fa1a44c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 2370c to 2370c–2 of this title, referred to in text, was in the original “this title”, meaning title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/457"},"text":"Pub. L. 110–457","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-12-23"},"text":"Dec. 23, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/5087"},"text":"122 Stat. 5087","children":[],"tail":", known as the Child Soldiers Prevention Act of 2008, which is classified principally to sections 2370c to 2370c–2 of this title. For complete classification of this Act to the Code, see Short Title of 2008 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8fa1a44d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Child Soldiers Prevention Act of 2008, and also as part of the William Wilberforce Trafficking Victims Protection Reauthorization Act of 2008, and not as part of the Foreign Assistance Act of 1961 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8fa1a44e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Par. (2)(A)(i) to (iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/425/s212/a/1"},"text":"Pub. L. 115–425, § 212(a)(1)","children":[],"tail":", inserted “, police, or other security forces” after “governmental armed forces”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/425/s212/a/2"},"text":"Pub. L. 115–425, § 212(a)(2)","children":[],"tail":", substituted “clause” for “clauses”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8fa1a44f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id8fa1a450-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/457/tIV/s407"},"text":"Pub. L. 110–457, title IV, § 407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-12-23"},"text":"Dec. 23, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/5091"},"text":"122 Stat. 5091","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/457/tIV/s407"},"text":"“This title [enacting this section and sections 2370c–1 and 2370c–2 of this title, amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4028"},"text":"section 4028 of this title","children":[],"tail":", and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":"], and the amendments made by this title, shall take effect 180 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2008-12-23"},"text":"Dec. 23, 2008","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8fa1a451-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/425/tII/s211"},"text":"Pub. L. 115–425, title II, § 211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-08"},"text":"Jan. 8, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5485"},"text":"132 Stat. 5485","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/425/tII/s211"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Congress finds the following:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The recruitment or use of children in armed conflict is unacceptable for any government or government-supported entity receiving United States assistance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The recruitment or use of children in armed conflict, including direct combat, support roles, and sexual slavery, occurred during 2016 or 2017 in Afghanistan, Iran, Mali, Niger, South Sudan, Sudan, Burma, the Democratic Republic of the Congo, Iraq, Nigeria, Rwanda, Somalia, Syria, and Yemen.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Entities of the Government of Afghanistan, particularly the Afghan Local Police and Afghan National Police, continue to recruit children to serve as combatants or as servants, including as sex slaves.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Police forces of the Government of Afghanistan participate in counterterrorism operations, direct and indirect combat, security operations, fight alongside regular armies, and are targeted for violence by the Taliban and other opposition groups.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In February 2016, a 10-year-old boy was assassinated by the Taliban after he had been publicly honored by Afghan local police forces for his assistance in combat operations against the Taliban.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recruitment and use of children in armed conflict by government forces has continued in South Sudan with the return to hostilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At least 19,000 children have been recruited since South Sudan’s civil war began in 2013.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
