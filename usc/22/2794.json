{"tag":"section","attrib":{"id":"id90226d04-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2794"},"text":null,"children":[{"tag":"num","attrib":{"value":"2794"},"text":"§ 2794.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90226d05-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2794/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “excess defense article” has the meaning provided by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2403/g"},"text":"section 2403(g) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90226d06-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2794/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “value” means, in the case of an excess defense article, except as otherwise provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2761/a"},"text":"section 2761(a) of this title","children":[],"tail":", not less than the greater of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90226d07-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2794/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the gross cost incurred by the United States Government in repairing, rehabilitating, or modifying such article, plus the scrap value; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90226d08-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2794/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the market value, if ascertainable;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90226d09-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2794/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “defense article”, except as provided in paragraph (7) of this section, means, with respect to a sale or transfer by the United States under the authority of this chapter or any other foreign assistance or sales program of the United States—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90226d0a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2794/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any weapon, weapons system, munition, aircraft, vessel, boat, or other implement of war,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90226d0b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2794/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any property, installation, commodity, material, equipment, supply, or goods used for the purposes of making military sales,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90226d0c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2794/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any machinery, facility, tool, material, supply, or other item necessary for the manufacture, production, processing, repair, servicing, storage, construction, transportation, operation, or use of any article listed in this paragraph, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90226d0d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2794/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any component or part of any article listed in this paragraph,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"but does not include merchant vessels or (as defined by the Atomic Energy Act of 1954 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2011"},"text":"42 U.S.C. 2011","children":[],"tail":" et seq.]) source material (except uranium depleted in the isotope 235 which is incorporated in defense articles solely to take advantage of high density or pyrophoric characteristics unrelated to radioactivity), byproduct material, special nuclear material, production facilities, utilization facilities, or atomic weapons or articles involving Restricted Data;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90226d0e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2794/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “defense service”, except as provided in paragraph (7) of this section, means, with respect to a sale or transfer by the United States under the authority of this chapter or any other foreign assistance or sales program of the United States, any service, test, inspection, repair, training, publication, technical or other assistance, or defense information (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2403/e"},"text":"section 2403(e) of this title","children":[],"tail":"), used for the purposes of making military sales, but does not include design and construction services under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2769"},"text":"section 2769 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90226d0f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2794/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “training” includes formal or informal instruction of foreign students in the United States or overseas by officers or employees of the United States, contract technicians, or contractors (including instruction at civilian institutions), or by correspondence courses, technical, educational, or information publications and media of all kinds, training aid, orientation, training exercise, and military advice to foreign military units and forces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90226d10-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2794/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “major defense equipment” means any item of significant military equipment on the United States Munitions List having a nonrecurring research and development cost of more than $50,000,000 or a total production cost of more than $200,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90226d11-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2794/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “defense articles and defense services” means, with respect to commercial exports subject to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2778"},"text":"section 2778 of this title","children":[],"tail":", those items designated by the President pursuant to subsection (a)(1) of such section;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90226d12-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2794/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “design and construction services” means, with respect to sales under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2769"},"text":"section 2769 of this title","children":[],"tail":", the design and construction of real property facilities, including necessary construction equipment and materials, engineering services, construction contract management services relating thereto, and technical advisory assistance in the operation and maintenance of real property facilities provided or performed by any department or agency of the Department of Defense or by a contractor pursuant to a contract with such department or agency;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90226d13-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2794/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “significant military equipment” means articles—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90226d14-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2794/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which special export controls are warranted because of the capacity of such articles for substantial military utility or capability; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90226d15-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2794/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identified on the United States Munitions List;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90226d16-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2794/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “weapons of mass destruction” has the meaning provided by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2302/1"},"text":"section 2302(1) of title 50","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90226d17-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2794/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Sales territory” means a country or group of countries to which a defense article or defense service is authorized to be reexported.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90226d18-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/629"},"text":"Pub. L. 90–629","children":[],"tail":", ch. 4, § 47, as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/189/s25/12"},"text":"Pub. L. 93–189, § 25(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-17"},"text":"Dec. 17, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/731"},"text":"87 Stat. 731","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/329/tII/s215"},"text":"Pub. L. 94–329, title II, § 215","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-06-30"},"text":"June 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/746"},"text":"90 Stat. 746","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/92/s22"},"text":"Pub. L. 96–92, § 22","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-29"},"text":"Oct. 29, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/710"},"text":"93 Stat. 710","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/533/tI/s105/f"},"text":"Pub. L. 96–533, title I, § 105(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-16"},"text":"Dec. 16, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3135"},"text":"94 Stat. 3135","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/83/tI/s107/b"},"text":"Pub. L. 99–83, title I, § 107(b)","children":[],"tail":", title XII, § 1211(b)(3), "},{"tag":"date","attrib":{"date":"1985-08-08"},"text":"Aug. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/197"},"text":"99 Stat. 197","children":[],"tail":", 279; "},{"tag":"ref","attrib":{"href":"/us/pl/104/164/tI/s144"},"text":"Pub. L. 104–164, title I, § 144","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-07-21"},"text":"July 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1434"},"text":"110 Stat. 1434","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/228/dB/tXII/s1202/b"},"text":"Pub. L. 107–228, div. B, title XII, § 1202(b)","children":[],"tail":", title XIV, § 1405(a)(4), "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"Sept. 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1427"},"text":"116 Stat. 1427","children":[],"tail":", 1458; "},{"tag":"ref","attrib":{"href":"/us/pl/113/276/tII"},"text":"Pub. L. 113–276, title II","children":[],"tail":", §§ 207, 208(b)(1)(B), "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2992"},"text":"128 Stat. 2992","children":[],"tail":", 2993.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90226d19-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90226d1a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90226d1b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/629"},"text":"Pub. L. 90–629","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1321"},"text":"82 Stat. 1321","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2751"},"text":"section 2751 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Atomic Energy Act of 1954, referred to in par. (3), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"act Aug. 1, 1946, ch. 724","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-30/ch1073/s1"},"text":"act Aug. 30, 1954, ch. 1073, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/919"},"text":"68 Stat. 919","children":[],"tail":", which is classified principally to chapter 23 (§ 2011 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2011"},"text":"section 2011 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90226d1c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/276/s208/b/1/B"},"text":"Pub. L. 113–276, § 208(b)(1)(B)","children":[],"tail":", substituted “2761(a) of this title,” for “2761(a) of this title,,” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/276/s207/1"},"text":"Pub. L. 113–276, § 207(1)","children":[],"tail":", in introductory provisions, substituted “means, with respect to a sale or transfer by the United States under the authority of this chapter or any other foreign assistance or sales program of the United States—” for “includes—”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/276/s207/2"},"text":"Pub. L. 113–276, § 207(2)","children":[],"tail":", substituted “means, with respect to a sale or transfer by the United States under the authority of this chapter or any other foreign assistance or sales program of the United States,” for “includes”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Par. (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/228/s1202/b"},"text":"Pub. L. 107–228, § 1202(b)","children":[],"tail":", added par. (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/228/s1405/a/4"},"text":"Pub. L. 107–228, § 1405(a)(4)","children":[],"tail":", added par. (11)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Par. (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/164"},"text":"Pub. L. 104–164","children":[],"tail":" added par. (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/83/s107/b"},"text":"Pub. L. 99–83, § 107(b)","children":[],"tail":", inserted “, except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2761/a"},"text":"section 2761(a) of this title","children":[],"tail":",”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/83/s1211/b/3"},"text":"Pub. L. 99–83, § 1211(b)(3)","children":[],"tail":", substituted “military” for “combat”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/533/s105/f/1"},"text":"Pub. L. 96–533, § 105(f)(1)","children":[],"tail":", excluded from term “defense service” design and construction services under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2769"},"text":"section 2769 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/533/s105/f/2"},"text":"Pub. L. 96–533, § 105(f)(2)","children":[],"tail":"–(4), added par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/92"},"text":"Pub. L. 96–92","children":[],"tail":" defined “defense article” to include uranium depleted in the isotope 235 which is incorporated in defense articles solely to take advantage of high density or pyrophoric characteristics unrelated to radioactivity."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Pars. (3) to (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/329"},"text":"Pub. L. 94–329","children":[],"tail":" added pars. (3) to (7)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90226d1d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id90226d1e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/83"},"text":"Pub. L. 99–83","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1985-10-01"},"text":"Oct. 1, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/83/s1301"},"text":"section 1301 of Pub. L. 99–83","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151–1"},"text":"section 2151–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
