{"tag":"section","attrib":{"id":"id90ed10cc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7718"},"text":null,"children":[{"tag":"num","attrib":{"value":"7718"},"text":"§ 7718.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90ed10cd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7718/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this chapter such sums as may be necessary for each of the fiscal years 2004 and 2005.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90ed10ce-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7718/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90ed10cf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7718/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation may allocate or transfer to any agency of the United States Government any of the funds available for carrying out this chapter. Such funds shall be available for obligation and expenditure for the purposes for which the funds were authorized, in accordance with authority granted in this chapter or under authority governing the activities of the United States Government agency to which such funds are allocated or transferred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ed10d0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7718/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall notify the appropriate congressional committees not less than 15 days prior to an allocation or transfer of funds pursuant to paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90ed10d1-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/dD/tVI/s619"},"text":"Pub. L. 108–199, div. D, title VI, § 619","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/225"},"text":"118 Stat. 225","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90ed10d2-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90ed10d3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90ed10d4-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a) and (b)(1), was in the original “this title”, meaning title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/dD"},"text":"Pub. L. 108–199, div. D","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/211"},"text":"118 Stat. 211","children":[],"tail":", which is classified generally to this chapter. For complete classification of this title to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7701"},"text":"section 7701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
