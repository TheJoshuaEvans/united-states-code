{"tag":"section","attrib":{"id":"id911334d0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8802"},"text":null,"children":[{"tag":"num","attrib":{"value":"8802"},"text":"§ 8802.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress relating to violations of human rights by Iran","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id911334d1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8802/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Congress finds that the interests of the United States and international peace are threatened by the ongoing and destabilizing actions of the Government of Iran, including its massive, systematic, and extraordinary violations of the human rights of its own citizens.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id911334d2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8802/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that the United States should—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id911334d3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8802/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deny the Government of Iran the ability to continue to oppress the people of Iran and to use violence and executions against pro-democracy protestors and regime opponents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911334d4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8802/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fully and publicly support efforts made by the people of Iran to promote the establishment of basic freedoms that build the foundation for the emergence of a freely elected, open, and democratic political system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911334d5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8802/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" help the people of Iran produce, access, and share information freely and safely via the Internet and through other media; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911334d6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8802/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" defeat all attempts by the Government of Iran to jam or otherwise obstruct international satellite broadcast signals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id911334d7-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tXII/s1243"},"text":"Pub. L. 112–239, div. A, title XII, § 1243","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2005"},"text":"126 Stat. 2005","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
