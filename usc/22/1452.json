{"tag":"section","attrib":{"id":"id8eff9790-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1452"},"text":null,"children":[{"tag":"num","attrib":{"value":"1452"},"text":"§ 1452.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status and allowances of assigned personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any person in the employ or service of the Government of the United States, while assigned for service to or in cooperation with another government under the authority of this chapter, shall be considered, for the purpose of preserving his rights, allowances, and privileges as such, an officer or employee of the Government of the United States and of the Government agency from which assigned and he shall continue to receive compensation from that agency. He may also receive, under such regulations as the President may prescribe, representation allowances similar to those allowed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4085"},"text":"section 4085 of this title","children":[],"tail":". The authorization of such allowances and other benefits and the payment thereof out of any appropriations available therefor shall be considered as meeting all the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5536"},"text":"section 5536 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8eff9791-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-01-27/ch36"},"text":"Jan. 27, 1948, ch. 36","children":[],"tail":", title III, § 302, "},{"tag":"ref","attrib":{"href":"/us/stat/62/8"},"text":"62 Stat. 8","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/241/tIII/s304/a/1/B"},"text":"Pub. L. 97–241, title III, § 304(a)(1)(B)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"1982-08-24"},"text":"Aug. 24, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/292"},"text":"96 Stat. 292","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8eff9792-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8eff9793-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8eff9794-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/241"},"text":"Pub. L. 97–241","children":[],"tail":" substituted “person in the employ or service of the Government of the United States” for “citizen of the United States”, “"},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4085"},"text":"section 4085 of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t22/s1131/3"},"text":"section 1131(3) of this title","children":[],"tail":"”, and “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5536"},"text":"section 5536 of title 5","children":[],"tail":"” for “section 1765 of the Revised Statutes”. Prior to the amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/97/241"},"text":"Pub. L. 97–241","children":[],"tail":", “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5536"},"text":"section 5536 of title 5","children":[],"tail":"” had been substituted for “section 1765 of the Revised Statutes” (which was formerly classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s70"},"text":"section 70 of title 5","children":[],"tail":") on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s7/b"},"text":"Pub. L. 89–554, § 7(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/631"},"text":"80 Stat. 631","children":[],"tail":", the first section of which enacted Title 5, Government Organization and Employees, thereby requiring no change in text."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
