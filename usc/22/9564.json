{"tag":"section","attrib":{"id":"id9134a027-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9564"},"text":null,"children":[{"tag":"num","attrib":{"value":"9564"},"text":"§ 9564.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Progress reports","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Not later than one year after ","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"December 20, 2019","children":[],"tail":", and annually thereafter, the President shall submit to the Committee on Foreign Relations of the Senate and the Committee on Foreign Affairs of the House of Representatives a report on progress made in providing assistance for projects under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s9563"},"text":"section 9563 of this title","children":[],"tail":" that includes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id9134a028-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9564/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the energy infrastructure projects the United States has identified for such assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9134a029-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9564/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for each such project—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9134a02a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9564/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the role of the United States in the project, including in early-stage project support and late-stage project support;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9134a02b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9564/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount and form of any debt financing and insurance provided by the United States Government for the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9134a02c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9564/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount and form of any early-stage project support; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9134a02d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9564/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an update on the progress made on the project as of the date of the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9134a02e-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dP/tXX/s2005"},"text":"Pub. L. 116–94, div. P, title XX, § 2005","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3226"},"text":"133 Stat. 3226","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9134a02f-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9134a030-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id9134a031-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the European Energy Security and Diversification Act of 2019, and also as part of the Further Consolidated Appropriations Act, 2020, and not as part of the Countering Russian Influence in Europe and Eurasia Act of 2017 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
