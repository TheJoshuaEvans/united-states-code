{"tag":"section","attrib":{"id":"id904648dc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3774"},"text":null,"children":[{"tag":"num","attrib":{"value":"3774"},"text":"§ 3774.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delays for which no responsibility is assumed","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Commission is not responsible, and may not consider any claim, for demurrage or delays caused by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id904648dd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3774/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" landslides or other natural causes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904648de-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3774/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" necessary construction or maintenance work on Canal locks, terminals, or equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904648df-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3774/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obstruction arising from accidents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904648e0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3774/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" time necessary for admeasurement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904648e1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3774/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" congestion of traffic;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904648e2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3774/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investigation of a marine accident that is conducted within 24 hours after the accident occurs, except that any liability of the Commission beyond that 24-hour period shall be limited to the extent to which the accident was caused, or contributed to, by the negligence of an employee of the Commission acting within the scope of the employee’s official duties; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904891d3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3774/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as specially set forth in this subpart, any other cause.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id904891d4-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70/tI/s1414"},"text":"Pub. L. 96–70, title I, § 1414","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-27"},"text":"Sept. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/486"},"text":"93 Stat. 486","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/209/s3"},"text":"Pub. L. 99–209, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1717"},"text":"99 Stat. 1717","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id904891d5-2930-11f1-8918-be39dde81dc6"},"text":