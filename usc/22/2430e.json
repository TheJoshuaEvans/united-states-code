{"tag":"section","attrib":{"id":"id8fbbe364-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430e"},"text":null,"children":[{"tag":"num","attrib":{"value":"2430e"},"text":"§ 2430e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest on new obligations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fbbe365-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rate of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"New obligations issued by a beneficiary country pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2430c/b"},"text":"section 2430c(b) of this title","children":[],"tail":" shall bear interest at a concessional rate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fbbe366-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Currency of payment; deposits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fbbe367-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local currency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the beneficiary country has entered into an Americas Framework Agreement, interest shall be paid in the local currency of the beneficiary country and deposited in an Americas Fund. Such interest shall be the property of the beneficiary country, until such time as it is disbursed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2430f/d"},"text":"section 2430f(d) of this title","children":[],"tail":". Such local currencies shall be used for the purposes specified in the Americas Framework Agreement."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbbe368-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States dollars","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the beneficiary country has not entered into an Americas Framework Agreement, interest shall be paid in United States dollars and deposited in the United States Government account established for interest payments of the obligations for which the new obligations were exchanged.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fbbe369-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest already paid","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a beneficiary country enters into an Americas Framework Agreement subsequent to the date on which interest first became due on the newly issued obligation, any interest already paid on such new obligation shall not be redeposited into the Americas Fund established for that country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fbbe36a-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. IV, § 706, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/549/tVI/s602/a"},"text":"Pub. L. 102–549, title VI, § 602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3666"},"text":"106 Stat. 3666","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fbbe36b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8fbbe36c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id8fbbe36d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195/s706"},"text":"section 706 of Pub. L. 87–195","children":[],"tail":", pt. IV, "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/463"},"text":"75 Stat. 463","children":[],"tail":", enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s1945"},"text":"section 1945 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/87/565"},"text":"Pub. L. 87–565","children":[],"tail":", pt. IV, § 401, "},{"tag":"date","attrib":{"date":"1962-08-01"},"text":"Aug. 1, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/263"},"text":"76 Stat. 263","children":[],"tail":", except insofar as section 706 affected section 1945."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
