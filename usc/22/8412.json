{"tag":"section","attrib":{"id":"id90fb67a3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8412"},"text":null,"children":[{"tag":"num","attrib":{"value":"8412"},"text":"§ 8412.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90fb67a4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8412/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the President, for the purposes of providing assistance to Pakistan under this subchapter and to provide assistance to Pakistan under the Foreign Assistance Act of 1961 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"22 U.S.C. 2151","children":[],"tail":" et seq.), up to $1,500,000,000 for each of the fiscal years 2010 through 2014."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90fb67a5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8412/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90fb67a6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8412/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the amounts appropriated in each fiscal year pursuant to the authorization of appropriations in subsection (a)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90fb67a7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8412/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" none of the amounts appropriated for assistance to Pakistan may be made available after the date that is 60 days after ","children":[{"tag":"date","attrib":{"date":"2009-10-15"},"text":"October 15, 2009","children":[],"tail":", unless the Pakistan Assistance Strategy Report has been submitted to the appropriate congressional committees pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s8441/a"},"text":"section 8441(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90fb67a8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8412/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not more than $750,000,000 may be made available for assistance to Pakistan unless the President’s Special Representative to Afghanistan and Pakistan submits to the appropriate congressional committees during such fiscal year—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90fb67a9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8412/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification that assistance provided to Pakistan under this subchapter or the Foreign Assistance Act of 1961 to date has made or is making reasonable progress toward achieving the principal objectives of United States assistance to Pakistan contained in the Pakistan Assistance Strategy Report; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90fb67aa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8412/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a memorandum explaining the reasons justifying the certification described in clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90fb67ab-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8412/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maker of certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the event of a vacancy in, or the termination of, the position of the President’s Special Representative to Afghanistan and Pakistan, the certification and memorandum described under paragraph (1)(B) may be made by the Secretary of State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90fb67ac-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8412/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State may waive the limitations in subsection (b) if the Secretary determines, and certifies to the appropriate congressional committees, that it is in the national security interests of the United States to do so.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90fb67ad-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8412/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress on foreign assistance funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of Congress that, subject to an improving political and economic climate in Pakistan, there should be authorized to be appropriated up to $1,500,000,000 for each of the fiscal years 2015 through 2019 for the purpose of providing assistance to Pakistan under the Foreign Assistance Act of 1961 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"22 U.S.C. 2151","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90fb67ae-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/73/tI/s102"},"text":"Pub. L. 111–73, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-15"},"text":"Oct. 15, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2068"},"text":"123 Stat. 2068","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90fb67af-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90fb67b0-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90fb67b1-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Foreign Assistance Act of 1961, referred to in subsecs. (a), (b)(1)(B)(i), and (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/424"},"text":"75 Stat. 424","children":[],"tail":", which is classified principally to chapter 32 (§ 2151 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
