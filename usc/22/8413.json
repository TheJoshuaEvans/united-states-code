{"tag":"section","attrib":{"id":"id90fb67b2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8413"},"text":null,"children":[{"tag":"num","attrib":{"value":"8413"},"text":"§ 8413.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Auditing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90fb67b3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8413/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Inspector General of the Department of State, the Inspector General of the United States Agency for International Development, and the inspectors general of other Federal departments and agencies (other than the Inspector General of the Department of Defense) carrying out programs, projects, and activities using amounts appropriated to carry out this subchapter shall audit, investigate, and oversee the obligation and expenditure of such amounts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90fb67b4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8413/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization for in-country presence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Inspector General of the Department of State and the Inspector General of the United States Agency for International Development, after consultation with the Secretary of State and the Administrator of the United States Agency for International Development, are authorized to establish field offices in Pakistan with sufficient staff from each of the Offices of the Inspector General, respectively, to carry out subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90fb67b5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8413/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90fb67b6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8413/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts authorized to be appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8412"},"text":"section 8412 of this title","children":[],"tail":" for each of the fiscal years 2010 through 2014, up to $30,000,000 for each fiscal year is authorized to be made available to carry out this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90fb67b7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8413/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to other available funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts made available under paragraph (1) are in addition to amounts otherwise available for such purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90fb67b8-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/73/tI/s103"},"text":"Pub. L. 111–73, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-15"},"text":"Oct. 15, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2069"},"text":"123 Stat. 2069","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
