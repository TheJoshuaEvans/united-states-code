{"tag":"section","attrib":{"id":"id8ff0605f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2665c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2665c"},"text":"§ 2665c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Thomas R. Pickering Foreign Affairs Fellowship Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ff06060-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2665c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be in the Department a Thomas R. Pickering Foreign Affairs Fellowship Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff06061-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2665c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The program required by subsection (a) shall continue to provide financial assistance, mentoring, and professional development opportunities to graduate students who commit to pursuing careers in the Foreign Service of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff06062-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2665c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The program required by subsection (a) shall be administered by the Department, consistent with existing law and regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ff06063-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dE/tI/s5134"},"text":"Pub. L. 119–60, div. E, title I, § 5134","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1568"},"text":"139 Stat. 1568","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ff06064-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ff06065-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id8ff06066-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “Department” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s5002"},"text":"section 5002 of Pub. L. 119–60","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
