{"tag":"section","attrib":{"id":"id90c4a108-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6821"},"text":null,"children":[{"tag":"num","attrib":{"value":"6821"},"text":"§ 6821.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90c4a109-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6821/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Negotiations for establishment of Trust Fund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Treasury shall seek to enter into negotiations with the World Bank or the Association, in consultation with the Administrator of the United States Agency for International Development and other United States Government agencies, and with the member nations of the World Bank or the Association and with other interested parties, for the establishment within the World Bank of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90c4a10a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6821/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the World Bank AIDS Trust Fund (in this subchapter referred to as the “Trust Fund”) in accordance with the provisions of this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90c4a10b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6821/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Advisory Board to the Trust Fund in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6824"},"text":"section 6824 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90c4a10c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6821/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of the Trust Fund should be to use contributed funds to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90c4a10d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6821/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist in the prevention and eradication of HIV/AIDS and the care and treatment of individuals infected with HIV/AIDS; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90c4a10e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6821/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide support for the establishment of programs that provide health care and primary and secondary education for children orphaned by the HIV/AIDS epidemic.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90c4a10f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6821/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90c4a110-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6821/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Trust Fund should be governed by a Board of Trustees, which should be composed of representatives of the participating donor countries to the Trust Fund. Individuals appointed to the Board should have demonstrated knowledge and experience in the fields of public health, epidemiology, health care (including delivery systems), and development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90c4a111-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6821/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States representation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90c4a112-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6821/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the effective date of this paragraph, there shall be a United States member of the Board of Trustees, who shall be appointed by the President, by and with the advice and consent of the Senate, and who shall have the qualifications described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90c4a113-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6821/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective and termination dates","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90c4a114-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6821/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This paragraph shall take effect upon the date the Secretary of the Treasury certifies to Congress that an agreement establishing the Trust Fund and providing for a United States member of the Board of Trustees is in effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90c4a115-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6821/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The position established by subparagraph (A) is abolished upon the date of termination of the Trust Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90c4a116-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/264/tI/s121"},"text":"Pub. L. 106–264, title I, § 121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-08-19"},"text":"Aug. 19, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/754"},"text":"114 Stat. 754","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
