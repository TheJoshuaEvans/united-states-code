{"tag":"section","attrib":{"id":"id91514f1c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10007"},"text":null,"children":[{"tag":"num","attrib":{"value":"10007"},"text":"§ 10007.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension of assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id91514f1d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10007/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President is authorized to suspend the provision of assistance authorized under section 10003, 10004, 10005, or 10006 of this title to the Government of Sudan if the President determines that conditions in Sudan or the composition of the Government of Sudan changes such that it is no longer in the United States national interest to continue to provide such assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91514f1e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10007/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days after making a determination under subsection (a), the President shall submit to the appropriate congressional committees a report that describes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91514f1f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10007/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the political and security conditions in Sudan that led to such determination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91514f20-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10007/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any planned diplomatic engagement to restart the provision of such assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id91514f21-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXII/s1268"},"text":"Pub. L. 116–283, div. A, title XII, § 1268","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3972"},"text":"134 Stat. 3972","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
