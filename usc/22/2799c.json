{"tag":"section","attrib":{"id":"id9027275a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2799c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2799c"},"text":"§ 2799c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notifications and reports to Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9027275b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2799c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 15 days before transferring any defense articles pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2799b/a"},"text":"section 2799b(a) of this title","children":[],"tail":", the President shall notify the Committee on Foreign Affairs of the House of Representatives and the Committee on Foreign Relations of the Senate in accordance with the procedures applicable to reprogramming notifications pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2394–1"},"text":"section 2394–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9027275c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2799c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than February 1 each year, the President shall submit to the Committee on Foreign Affairs and the Committee on Armed Services of the House of Representatives and the Committee on Foreign Relations and the Committee on Armed Services of the Senate a report that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9027275d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2799c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lists all transfers made to each recipient NATO/CFE country by the United States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2799b/a"},"text":"section 2799b(a) of this title","children":[],"tail":" during the preceding calendar year;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9027275e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2799c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes how those transfers further the purposes described in paragraphs (1) through (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2799"},"text":"section 2799 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9027275f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2799c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" lists, on a country-by-country basis, all transfers to another country of conventional armaments and equipment limited by the CFE Treaty—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90272760-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2799c/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by each NATO/CFE country (other than the United States) in implementing the CFE Treaty, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90272761-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2799c/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by each country of the Eastern Group of States Parties in implementing the CFE Treaty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90272762-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/629"},"text":"Pub. L. 90–629","children":[],"tail":", ch. 9, § 94, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/228/s2"},"text":"Pub. L. 102–228, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-12"},"text":"Dec. 12, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1692"},"text":"105 Stat. 1692","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/199/tIV/s402/1"},"text":"Pub. L. 103–199, title IV, § 402(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-17"},"text":"Dec. 17, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2324"},"text":"107 Stat. 2324","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90272763-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90272764-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90272765-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (b)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/199"},"text":"Pub. L. 103–199","children":[],"tail":" substituted “country of the Eastern Group of States Parties” for “Warsaw Pact country”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id90272766-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id90272767-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of President under this section delegated to Secretary of Defense by Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"1992-02-13"},"text":"Feb. 13, 1992","children":[],"tail":", 57 F.R. 6663, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2799b"},"text":"section 2799b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
