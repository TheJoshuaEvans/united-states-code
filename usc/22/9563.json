{"tag":"section","attrib":{"id":"id9132570a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9563"},"text":null,"children":[{"tag":"num","attrib":{"value":"9563"},"text":"§ 9563.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prioritization of efforts and assistance for energy infrastructure projects in Europe and Eurasia","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9132570b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9563/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In pursuing the policy described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9562"},"text":"section 9562 of this title","children":[],"tail":", the Secretary of State, in consultation with the Secretary of Energy and the heads of other relevant United States agencies, shall, as appropriate, prioritize and expedite the efforts of the Department of State and those agencies in supporting the efforts of the European Commission and the governments of European and Eurasian countries to increase their energy security, including through—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id9132570c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9563/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" providing diplomatic and political support to the European Commission and those governments, as necessary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9132570d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9563/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate international negotiations concerning cross-border infrastructure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9132570e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9563/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enhance Europe’s regulatory environment with respect to energy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9132570f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9563/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop accessible, transparent, and competitive energy markets supplied by diverse sources, types, and routes of energy; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91325710-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9563/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" providing support to improve European and Eurasian energy markets, including early-stage project support and late-stage project support for the construction or improvement of energy and related infrastructure, as necessary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91325711-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9563/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to diversify the energy sources and supply routes of European and Eurasian countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91325712-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9563/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enhance energy market integration across the region; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91325713-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9563/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase competition within energy markets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91325714-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9563/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project selection","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91325715-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9563/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The agencies described in subsection (a) shall identify energy infrastructure projects that would be appropriate for United States assistance under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91325716-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9563/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A project is eligible for United States assistance under this section if the project—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91325717-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9563/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id91325718-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9563/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improves electricity transmission infrastructure, power generation through the use of a broad power mix (including fossil fuel and renewable energy), or energy efficiency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91325719-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9563/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advances electricity storage projects, smart grid projects, distributed generation models, or other technological innovations, as appropriate; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9132571a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9563/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is located in a European or Eurasian country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9132571b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9563/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting among projects that are eligible under paragraph (2), the agencies described in subsection (a) shall give preference to projects that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9132571c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9563/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" link the energy systems of 2 or more European or Eurasian countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9132571d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9563/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have already been identified by the European Commission as being integral for the energy security of European countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9132571e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9563/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are expected to enhance energy market integration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9132571f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9563/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" can attract funding from the private sector, an international financial institution, the government of the country in which the project will be carried out, or the European Commission; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91325720-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9563/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have the potential to use United States goods and services during project implementation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91325721-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9563/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Types of assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91325722-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9563/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Diplomatic and political support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall provide diplomatic and political support to the European Commission and the governments of European and Eurasian countries, as necessary, including by using the diplomatic and political influence and expertise of the Department of State to build the capacity of those countries to resolve any impediments to the development of projects selected under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91325723-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9563/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Early-stage project support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Trade and Development Agency shall provide early-stage project support with respect to projects selected under subsection (b), as necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91325724-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9563/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Late-stage project support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Agencies described in subsection (a) that provide late-stage project support shall do so with respect to projects selected under subsection (b), as necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91325725-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9563/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91325726-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9563/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception from certain limitation under BUILD Act","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91325727-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9563/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of providing support for projects under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91325728-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9563/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States International Development Finance Corporation may provide support for projects in countries with upper-middle-income economies or high-income economies (as those terms are defined by the World Bank);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91325729-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9563/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the restriction under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9612/c/2"},"text":"section 9612(c)(2) of this title","children":[],"tail":" shall not apply; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9132572a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9563/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Corporation shall restrict the provision of such support in a country described in subparagraph (A) unless—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9132572b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9563/e/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President certifies to the appropriate congressional committees that such support furthers the national economic or foreign policy interests of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9132572c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9563/e/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such support is—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id9132572d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9563/e/1/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designed to produce significant developmental outcomes or provide developmental benefits to the poorest population of that country; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id9132572e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9563/e/1/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" necessary to preempt or counter efforts by a strategic competitor of the United States to secure significant political or economic leverage or acquire national security-sensitive technologies or infrastructure in a country that is an ally or partner of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9132572f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9563/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the terms “appropriate congressional committees” and “less developed country” have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9601"},"text":"section 9601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9134a020-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dP/tXX/s2004"},"text":"Pub. L. 116–94, div. P, title XX, § 2004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3223"},"text":"133 Stat. 3223","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9134a021-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9134a022-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9134a023-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The BUILD Act, referred to in subsec. (e), probably means the BUILD Act of 2018, also known as the Better Utilization of Investments Leading to Development Act of 2018, which is classified principally to chapter 103 (§ 9601 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9601"},"text":"section 9601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id9134a024-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the European Energy Security and Diversification Act of 2019, and also as part of the Further Consolidated Appropriations Act, 2020, and not as part of the Countering Russian Influence in Europe and Eurasia Act of 2017 which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s2004"},"text":"section 2004 of Pub. L. 116–94","children":[],"tail":". Subsec. (d) of "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/s2004"},"text":"section 2004 of Pub. L. 116–94","children":[],"tail":" amended sections 2421 and 9543 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id9134a025-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9134a026-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Authority Under the European Energy Security and Diversification Act of 2019","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2022-06-08"},"text":"June 8, 2022","children":[],"tail":", 87 F.R. 35853, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum for the Secretary of State","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"By the authority vested in me as President by the Constitution and the laws of the United States of America, including ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of title 3","children":[],"tail":", United States Code, I hereby delegate to the Secretary of State the functions and authorities vested in the President by section 2004(e)(1)(C) of the European Energy Security and Diversification Act of 2019 ("},{"tag":"ref","attrib":{"href":"/us/usc/t22/s9563/e/1/C"},"text":"22 U.S.C. 9563(e)(1)(C)","children":[],"tail":") (the “Act”). The delegation in this memorandum shall apply to any provision of any future public law that is the same or substantially the same as the provision referenced in this memorandum. Any reference in this memorandum to the Act shall be deemed to be a reference to such Act as amended from time to time."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"You are authorized and directed to publish this memorandum in the Federal Register.","children":[],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"J.R. Biden, Jr.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
