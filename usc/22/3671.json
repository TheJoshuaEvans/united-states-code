{"tag":"section","attrib":{"id":"id90416720-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3671"},"text":null,"children":[{"tag":"num","attrib":{"value":"3671"},"text":"§ 3671.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transferred or reemployed employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90416721-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3671/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions of employment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90416722-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3671/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to any individual employed in the Panama Canal Company or the Canal Zone Government—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90416723-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3671/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who is transferred—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90416724-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3671/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a position in the Commission; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90416725-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3671/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a position in an Executive agency or in the Smithsonian Institution the permanent duty station of which is in the Republic of Panama (including the area known before ","children":[{"tag":"date","attrib":{"date":"1979-10-01"},"text":"October 1, 1979","children":[],"tail":", as the Canal Zone); or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90416726-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3671/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is separated by reason of a reduction in force on ","children":[{"tag":"date","attrib":{"date":"1979-09-30"},"text":"September 30, 1979","children":[],"tail":", and is appointed to a position in the Commission before "},{"tag":"date","attrib":{"date":"1980-04-01"},"text":"April 1, 1980","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the terms and conditions of employment set forth in paragraph (2) of this subsection shall be generally no less favorable, on or after the date of the transfer referred to in subparagraph (A) of this paragraph or the date of the appointment referred to in subparagraph (B) of this paragraph, as the case may be, than the terms and conditions of employment with the Panama Canal Company and Canal Zone Government on ","children":[{"tag":"date","attrib":{"date":"1979-09-30"},"text":"September 30, 1979","children":[],"tail":", or, in the case of a transfer described in subparagraph (A)(ii) of this paragraph which takes place before that date, on the date of the transfer."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90416727-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3671/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The terms and conditions of employment referred to in paragraph (1) of this subsection are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90416728-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3671/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":", (B) Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/dC/tXXXV/s3507/a"},"text":"Pub. L. 105–261, div. C, title XXXV, § 3507(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2269"},"text":"112 Stat. 2269","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90416729-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3671/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" premium pay and night differential;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9041672a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3671/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reinstatement and restoration rights;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9041672b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3671/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" injury and death compensation benefits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9041672c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3671/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to (H) Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/dC/tXXXV/s3507/a"},"text":"Pub. L. 105–261, div. C, title XXXV, § 3507(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2269"},"text":"112 Stat. 2269","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9041672d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3671/a/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduction-in-force rights;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9041672e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3671/a/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee grievance system, and the right to appeal adverse and disciplinary actions and position classification actions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9041672f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3671/a/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" veterans’ preference eligibility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90416730-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3671/a/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" holidays;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90416731-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3671/a/2/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" saved pay provisions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90416732-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3671/a/2/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" severance pay benefits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90416733-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3671/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Break in service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any individual described in subsection (a)(1)(B) of this section who would have met the service requirement for early retirement benefits under section 8336(i) or 8339(d)(2) of title 5 (as amended by sections 1241(a) and 1242 of this Act, respectively), but for a break in service of more than 3 days immediately after ","children":[{"tag":"date","attrib":{"date":"1979-09-30"},"text":"September 30, 1979","children":[],"tail":", shall be considered to meet that requirement. Any break in service by any such individual for purposes of section 8332 of such title 5 during the period beginning "},{"tag":"date","attrib":{"date":"1979-09-30"},"text":"September 30, 1979","children":[],"tail":", and ending on the date of the appointment referred to in such subsection (a)(1)(B) shall be considered a period of creditable service under such section 8332 for such individual, except that such period shall not be taken into account for purposes of determining average pay (as defined in section 8331(4) of such title 5) and no deduction, contribution, or deposit shall be required for that period under section 8334 of such title 5."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90416734-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3671/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of sections 903(c) and 904(a)(2) of title 20; sabbaticals","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90416735-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3671/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s903/c"},"text":"Section 903(c) of title 20","children":[],"tail":" shall not apply with respect to any teacher who was employed by the Canal Zone Government school system on "},{"tag":"date","attrib":{"date":"1979-09-30"},"text":"September 30, 1979","children":[],"tail":", and who was transferred from such position to a teaching position which is under the Department of Defense Overseas Dependent School System and the permanent duty station of which is in the Republic of Panama, until the rates of basic compensation established under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s903/c"},"text":"section 903(c) of title 20","children":[],"tail":" equal or exceed the rates of basic compensation then in effect for teachers who were so transferred."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90416736-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3671/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s904/a/2"},"text":"Section 904(a)(2) of title 20","children":[],"tail":" shall not apply with respect to any teacher who was employed by the Canal Zone Government school system on "},{"tag":"date","attrib":{"date":"1979-09-30"},"text":"September 30, 1979","children":[],"tail":", and who was transferred from such position to a teaching position which is under the Department of Defense Overseas Dependent School System and the permanent duty station of which is in the Republic of Panama."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90416737-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3671/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90416738-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3671/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of a department or agency of the United States may grant a sabbatical to any teacher to whom paragraph (1) of this subsection applies for not to exceed 11 months in order to permit the teacher to engage in study or uncompensated work experience which is in the United States and which will contribute to the teacher’s development and effectiveness. Basic compensation shall be paid to teachers on sabbatical under this section in the same manner and to the same extent as basic compensation would have been paid to teachers on sabbatical while employed in the Canal Zone Government school system on ","children":[{"tag":"date","attrib":{"date":"1979-09-30"},"text":"September 30, 1979","children":[],"tail":". A sabbatical shall not result in a loss of, or reduction in, leave to which the teacher is otherwise entitled, credit for time or service, or performance or efficiency rating. The head of the department or agency may authorize in accordance with chapter 57 of title 5 such travel expenses (including per diem allowance) as the head of the department or agency may determine to be essential for the study or experience."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90416739-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3671/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A sabbatical under this paragraph may not be granted to any teacher—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9041673a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3671/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more than once in any 10-year period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9041673b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3671/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unless the teacher has completed 7 years of service as a teacher; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9041673c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3671/c/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the teacher is eligible for voluntary retirement with a right to an immediate annuity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9041673d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3671/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9041673e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3671/c/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any teacher in a department or agency of the United States may be granted a sabbatical under this paragraph only if the teacher agrees, as a condition of accepting the sabbatical, to serve in the civil service upon the completion of the sabbatical for a period of two consecutive years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9041673f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3671/c/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each agreement required under clause (i) of this subparagraph shall provide that in the event the teacher fails to carry out the agreement (except for good and sufficient reason as determined by the head of the department or agency that granted the sabbatical) the teacher shall be liable to the United States for payment of all expenses (including salary) of the sabbatical. The amount shall be treated as a debt due the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90416740-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70/tI/s1231/a"},"text":"Pub. L. 96–70, title I, § 1231(a)","children":[],"tail":"–(c), "},{"tag":"date","attrib":{"date":"1979-09-27"},"text":"Sept. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/468"},"text":"93 Stat. 468","children":[],"tail":", 469; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dC/tXXXV/s3537"},"text":"Pub. L. 104–201, div. C, title XXXV, § 3537","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2864"},"text":"110 Stat. 2864","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dC/tXXXV/s3550/d/2/C"},"text":"Pub. L. 105–85, div. C, title XXXV, § 3550(d)(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2074"},"text":"111 Stat. 2074","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/dC/tXXXV/s3507/a"},"text":"Pub. L. 105–261, div. C, title XXXV, § 3507(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2269"},"text":"112 Stat. 2269","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90416741-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90416742-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90416743-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70"},"text":"Pub. L. 96–70","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-27"},"text":"Sept. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/452"},"text":"93 Stat. 452","children":[],"tail":", known as the Panama Canal Act of 1979, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3601"},"text":"section 3601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id90416744-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70/s1231/d"},"text":"Section 1231(d) of Pub. L. 96–70","children":[],"tail":" amended sections 5595, 5724a, and 8102 of Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90416745-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(2)(A), (B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261"},"text":"Pub. L. 105–261","children":[],"tail":" struck out subpars. (A) and (B) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) rates of basic pay;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) tropical differential;”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(F) to (H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261"},"text":"Pub. L. 105–261","children":[],"tail":" struck out subpars. (F) to (H) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(F) leave and travel;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(G) transportation and repatriation benefits;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(H) group health and life insurance;”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (c)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1979-09-30"},"text":"September 30, 1979","children":[],"tail":"” for “the day before "},{"tag":"date","attrib":{"date":"1979-10-01"},"text":"October 1, 1979","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" struck out par. (3) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3)(A) The provisions of this subsection shall take effect on ","children":[{"tag":"date","attrib":{"date":"1979-09-27"},"text":"September 27, 1979","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) No spending authority (as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s651/c/2/C"},"text":"section 651(c)(2)(C) of title 2","children":[],"tail":") provided for under this subsection shall take effect before "},{"tag":"date","attrib":{"date":"1979-10-01"},"text":"October 1, 1979","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) Effective ","children":[{"tag":"date","attrib":{"date":"1979-10-01"},"text":"October 1, 1979","children":[],"tail":", any individual who, but for subparagraph (B) of this paragraph, would have been entitled to one or more payments pursuant to this subsection for periods before "},{"tag":"date","attrib":{"date":"1979-10-01"},"text":"October 1, 1979","children":[],"tail":", shall be entitled, to the extent or in such amounts as are provided in advance in appropriation Acts, to a lump sum payment equal to the total amount of all such payments.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90416746-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id90416747-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/dC/tXXXV/s3507/a"},"text":"Pub. L. 105–261, div. C, title XXXV, § 3507(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2269"},"text":"112 Stat. 2269","children":[],"tail":", provided that the amendment made by section 3507(a) striking out subsec. (a)(2)(A), (B), and (F) to (H) of this section is effective 11:59 p.m. (Eastern Standard Time), "},{"tag":"date","attrib":{"date":"1999-12-30"},"text":"Dec. 30, 1999","children":[],"tail":", and any right or condition of employment provided for in, or arising from, subsec. (a)(2)(A), (B), and (F) to (H) of this section is terminated."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
