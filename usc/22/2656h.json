{"tag":"section","attrib":{"id":"id8fedef80-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2656h"},"text":null,"children":[{"tag":"num","attrib":{"value":"2656h"},"text":"§ 2656h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International credit reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fedef81-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2656h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on loan criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"1991-10-28"},"text":"October 28, 1991","children":[],"tail":", the Assistant Secretary of State for Economic and Business Affairs, in consultation with the Secretary of the Treasury, shall submit to the Chairman of the Foreign Relations Committee of the Senate and the Speaker of the House of Representatives a report setting forth clear criteria for bilateral loans by which the United States can determine the likelihood of repayment by a country seeking to receive United States loans. The report should include the criteria used for—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fedef82-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2656h/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing country risk;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fedef83-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2656h/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projecting loan repayments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fedef84-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2656h/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" estimating subsidy levels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fedef85-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2656h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports on loans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning 180 days after the submission of the report in subsection (a) and annually thereafter, the Secretary of State, in consultation with the Secretary of the Treasury, shall submit a report to the Chairman of the Foreign Relations Committee of the Senate and the Speaker of the House of Representatives showing actual repayments by country and by program to the United States Government for the previous 5 years and the scheduled repayments to the United States Government for the next 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fedef86-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/138/tI/s197"},"text":"Pub. L. 102–138, title I, § 197","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/684"},"text":"105 Stat. 684","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fedef87-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8fedef88-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8fedef89-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Authority of Secretary of State","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Except as otherwise provided, Secretary of State to have and exercise any authority vested by law in any official or office of Department of State and references to such officials or offices deemed to refer to Secretary of State or Department of State, as appropriate, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651a"},"text":"section 2651a of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/s161/d"},"text":"section 161(d) of Pub. L. 103–236","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651a"},"text":"section 2651a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
