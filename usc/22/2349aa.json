{"tag":"section","attrib":{"id":"id8f95bca1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"2349aa"},"text":"§ 2349aa.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law that restricts assistance to foreign countries (other than sections 2304 and 2371 of this title), the President is authorized to furnish, on such terms and conditions as the President may determine, assistance to foreign countries in order to enhance the ability of their law enforcement personnel to deter terrorists and terrorist groups from engaging in international terrorist acts such as bombing, kidnapping, assassination, hostage taking, and hijacking. Such assistance may include training services and the provision of equipment and other commodities related to bomb detection and disposal, management of hostage situations, physical security, and other matters relating to the detection, deterrence, and prevention of acts of terrorism, the resolution of terrorist incidents, and the apprehension of those involved in such acts.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f95bca2-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. II, § 571, as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/151/s101/b/2"},"text":"Pub. L. 98–151, § 101(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-11-14"},"text":"Nov. 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/972"},"text":"97 Stat. 972","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/164/tI/s121/a"},"text":"Pub. L. 104–164, title I, § 121(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-07-21"},"text":"July 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1428"},"text":"110 Stat. 1428","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f95bca3-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f95bca4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8f95bca5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195/s571"},"text":"Section 571 of Pub. L. 87–195","children":[],"tail":" is based on section 201 of title II of H.R. 2992, Ninety-eighth Congress, as reported "},{"tag":"date","attrib":{"date":"1983-05-17"},"text":"May 17, 1983","children":[],"tail":", and enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/98/151"},"text":"Pub. L. 98–151","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f95bca6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/164"},"text":"Pub. L. 104–164","children":[],"tail":" substituted “Notwithstanding any other provision of law that restricts assistance to foreign countries (other than sections 2304 and 2371 of this title)” for “Subject to the provisions of this part”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f95bca7-2930-11f1-8918-be39dde81dc6"},"text":null,"child