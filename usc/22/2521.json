{"tag":"section","attrib":{"id":"id8fd3b097-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2521"},"text":null,"children":[{"tag":"num","attrib":{"value":"2521"},"text":"§ 2521.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign language proficiency","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No person shall be assigned to duty as a volunteer under this chapter in any foreign country or area unless at the time of such assignment he possesses such reasonable proficiency as his assignment requires in speaking the language of the country or area to which he is assigned.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8fd3b098-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/293/tI/s24"},"text":"Pub. L. 87–293, title I, § 24","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-22"},"text":"Sept. 22, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/624"},"text":"75 Stat. 624","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fd3b099-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8fd3b09a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8fd3b09b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/293"},"text":"Pub. L. 87–293","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-22"},"text":"Sept. 22, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/612"},"text":"75 Stat. 612","children":[],"tail":", known as the Peace Corps Act. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2501"},"text":"section 2501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
