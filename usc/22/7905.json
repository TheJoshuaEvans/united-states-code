{"tag":"section","attrib":{"id":"id90f1f228-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7905"},"text":null,"children":[{"tag":"num","attrib":{"value":"7905"},"text":"§ 7905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Greenhouse Gas Intensity Reducing Technology Export Initiative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90f1f229-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7905/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established an interagency working group to carry out a Greenhouse Gas Intensity Reducing Technology Export Initiative to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90f1f22a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7905/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the export of greenhouse gas intensity reducing technologies and practices from the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f1f22b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7905/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify developing countries that should be designated as priority countries for the purpose of exporting greenhouse gas intensity reducing technologies and practices, based on the report submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7902/a/2/A"},"text":"section 7902(a)(2)(A) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f1f22c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7905/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify potential barriers to adoption of exported greenhouse gas intensity reducing technologies and practices based on the reports submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7904"},"text":"section 7904 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f1f22d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7905/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify previous efforts to export energy technologies to learn best practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90f1f22e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7905/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The working group shall be composed of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90f1f22f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7905/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of State, who shall act as the head of the working group;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f1f230-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7905/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the United States Agency for International Development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f1f231-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7905/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Trade Representative;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f1f232-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7905/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a designee of the Secretary of Energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f1f233-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7905/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a designee of the Secretary of Commerce; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f1f234-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7905/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a designee of the Administrator of the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90f1f235-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7905/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance reviews and reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", and each year thereafter, the interagency working group shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90f1f236-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7905/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct a performance review of actions taken and results achieved by the Federal Government (including each of the agencies represented on the interagency working group) to promote the export of greenhouse gas intensity reducing technologies and practices from the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f1f237-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7905/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the appropriate authorizing and appropriating committees of Congress a report that describes the results of the performance reviews and evaluates progress in promoting the export of greenhouse gas intensity reducing technologies and practices from the United States, including any recommendations for increasing the export of the technologies and practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90f1f238-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/240/tVII/s735"},"text":"Pub. L. 101–240, title VII, § 735","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXVI/s1611"},"text":"Pub. L. 109–58, title XVI, § 1611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1115"},"text":"119 Stat. 1115","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90f1f239-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90f1f23a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id90f1f23b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2005-10-01"},"text":"Oct. 1, 2005","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/240/s739"},"text":"section 739 of Pub. L. 101–240","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7901"},"text":"section 7901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
