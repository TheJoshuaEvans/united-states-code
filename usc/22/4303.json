{"tag":"section","attrib":{"id":"id9075e38a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4303"},"text":null,"children":[{"tag":"num","attrib":{"value":"4303"},"text":"§ 4303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorities of Secretary of State","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall carry out the following functions:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9075e38b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4303/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assist agencies of Federal, State, and municipal government with regard to ascertaining and according benefits, privileges, and immunities to which a foreign mission may be entitled.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9075e38c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4303/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provide or assist in the provision of benefits for or on behalf of a foreign mission in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4304"},"text":"section 4304 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9075e38d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4303/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As determined by the Secretary, dispose of property acquired in carrying out the purposes of this chapter.","children":[{"tag":"ref","attrib":{"idref":"fn002299"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002299"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9075e38e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4303/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As determined by the Secretary, designate an office within the Department of State to carry out the purposes of this chapter.","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" If such an office is established, the President may appoint, by and with the advice and consent of the Senate, a Director, with the rank of ambassador. Of the Director and the next most senior person in the office, one should be an individual who has served in the Foreign Service and the other should be an individual who has served in the United States intelligence community."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9075e38f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4303/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Perform such other functions as the Secretary may determine necessary in furtherance of the policy of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9075e390-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch841"},"text":"Aug. 1, 1956, ch. 841","children":[],"tail":", title II, § 203, as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/241/tII/s202/b"},"text":"Pub. L. 97–241, title II, § 202(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-08-24"},"text":"Aug. 24, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/284"},"text":"96 Stat. 284","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/164/tVI/s604/a"},"text":"Pub. L. 98–164, title VI, § 604(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1983-11-22"},"text":"Nov. 22, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1043"},"text":"97 Stat. 1043","children":[],"tail":", 1044; "},{"tag":"ref","attrib":{"href":"/us/pl/98/618/tVI/s601/d"},"text":"Pub. L. 98–618, title VI, § 601(d)","children":[],"tail":", formerly § 601(c), "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3303"},"text":"98 Stat. 3303","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dF/tLXVII/s6712/2"},"text":"Pub. L. 119–60, div. F, title LXVII, § 6712(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1649"},"text":"139 Stat. 1649","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/204/tI/s173/a/2"},"text":"Pub. L. 100–204, title I, § 173(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1360"},"text":"101 Stat. 1360","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/246/tI/s116/a"},"text":"Pub. L. 101–246, title I, § 116(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-02-16"},"text":"Feb. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/24"},"text":"104 Stat. 24","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s162"},"text":"Pub. L. 103–236, title I, § 162","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(2), "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/409"},"text":"108 Stat. 409","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9075e391-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9075e392-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9075e393-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in pars. (3) and (4), was in the original “this Act” and was translated as reading “this title” meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch841"},"text":"act Aug. 1, 1956, ch. 841","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1982-08-24"},"text":"Aug. 24, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/97/241/tII/s202/b"},"text":"Pub. L. 97–241, title II, § 202(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/283"},"text":"96 Stat. 283","children":[],"tail":", known as the Foreign Missions Act, which is classified principally to this chapter. For complete classification of title II to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4301"},"text":"section 4301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9075e394-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":" amended section generally. Prior to amendment, section required Secretary of State to establish Office of Foreign Missions in Department of State, provided for Director and Deputy Director of Office, and specified their powers and duties."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (c)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/246"},"text":"Pub. L. 101–246","children":[],"tail":" added par. (3) and redesignated former par. (3) as (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/204"},"text":"Pub. L. 100–204","children":[],"tail":" inserted sentence at end relating to compensation of Director."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/618/s601/d/1"},"text":"Pub. L. 98–618, § 601(d)(1)","children":[],"tail":", formerly § 601(c)(1), as renumbered by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":", struck out requirements that Director be an individual with: minimum of ten years service in the Foreign Service, significant administrative experience, and service in countries wherein the United States has had significant problems in assuring secure and efficient operations of its missions as result of the actions of other countries."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/618/s601/d/2"},"text":"Pub. L. 98–618, § 601(d)(2)","children":[],"tail":", formerly § 601(c)(1), as renumbered by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":", substituted requirement of prior complementary service of the Director and Deputy Director in the Foreign Service and the Intelligence Community for requirement that Deputy Director must have served in the Intelligence Community."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/164/s604/a"},"text":"Pub. L. 98–164, § 604(a)","children":[],"tail":", inserted provisions respecting rank, and experience required of the Director, and substituted provision requiring appointment by the President by and with the advice and consent of the Senate, for provision requiring appointment by the Secretary."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/164/s604/b"},"text":"Pub. L. 98–164, § 604(b)","children":[],"tail":", added subsec. (b) and redesignated former subsec. (b) as (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9075e395-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9075e396-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":" applicable with respect to officials, offices, and bureaus of Department of State when executive orders, regulations, or departmental directives implementing the amendments by sections 161 and 162 of "},{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":" become effective, or 90 days after "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", whichever comes earlier, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/s161/b"},"text":"section 161(b) of Pub. L. 103–236","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651a"},"text":"section 2651a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9075e397-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1987 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/204"},"text":"Pub. L. 100–204","children":[],"tail":" effective 30 days after "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/204/s173/b"},"text":"section 173(b) of Pub. L. 100–204","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2707"},"text":"section 2707 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9075e398-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/618/tVI/s601/e"},"text":"Pub. L. 98–618, title VI, § 601(e)","children":[],"tail":", formerly § 601(d), "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3303"},"text":"98 Stat. 3303","children":[],"tail":", as renumbered and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dF/tLXVII/s6712/2"},"text":"Pub. L. 119–60, div. F, title LXVII, § 6712(2)","children":[],"tail":", (4), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1649"},"text":"139 Stat. 1649","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dF/tLXVII/s6712/2"},"text":"“The amendments made by subsection (d) [amending this section] shall apply only with respect to any appointment of a Director or Deputy Director of the Office of Foreign Missions, as the case may be, after the date of the enactment of this section [","children":[{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9075e399-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1983 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/164/tVI/s604/c"},"text":"Pub. L. 98–164, title VI, § 604(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-11-22"},"text":"Nov. 22, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1044"},"text":"97 Stat. 1044","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/164/tVI/s604/c"},"text":"“The amendments made by this section [amending this section] shall apply with respect to any Director of the Office of Foreign Missions, and to any Deputy Director of the Office of Foreign Missions, appointed after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1983-11-22"},"text":"Nov. 22, 1983","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id9075e39a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1982-10-01"},"text":"Oct. 1, 1982","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/241/s204"},"text":"section 204 of Pub. L. 97–241","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4301"},"text":"section 4301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9075e39b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"New Spending Authority","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Any new spending authority provided by amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/204/s173/a/2"},"text":"section 173(a)(2) of Pub. L. 100–204","children":[],"tail":" effective for any fiscal year only to such extent or in such amounts as are provided in advance in appropriation Acts, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/204/s173/c"},"text":"section 173(c) of Pub. L. 100–204","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2707"},"text":"section 2707 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
