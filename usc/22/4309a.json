{"tag":"section","attrib":{"id":"id9075e458-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4309a"},"text":null,"children":[{"tag":"num","attrib":{"value":"4309a"},"text":"§ 4309a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States responsibilities for employees of the United Nations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9075e459-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4309a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9075e45a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4309a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" pursuant to the Agreement Between the United States and the United Nations Regarding the Headquarters of the United Nations (authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/80/357"},"text":"Public Law 80–357","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t22/s287"},"text":"22 U.S.C. 287","children":[],"tail":" note)), the United States has accepted—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9075e45b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4309a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the obligation to permit and to facilitate the right of individuals, who are employed by or are authorized by the United Nations to conduct official business in connection with that organization or its agencies, to enter into and exit from the United States for purposes of conducting official activities within the United Nations Headquarters District, subject to regulation as to points of entry and departure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9075e45c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4309a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the implied obligation to permit and to facilitate the acquisition of facilities in order to conduct such activities within or in proximity to the United Nations Headquarters District, subject to reasonable regulation including regulation of the location and size of such facilities; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9075e45d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4309a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" taking into account paragraph (1) and consistent with the obligation of the United States to facilitate the functioning of the United Nations, the United States has no additional obligation to permit the conduct of any other activities, including nonofficial activities, by such individuals outside of the United Nations Headquarters District.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9075e45e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4309a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities of United Nations employees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9075e45f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4309a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The conduct of any activities, or the acquisition of any benefits (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4301/a/1"},"text":"section 4301(a)(1) of this title","children":[],"tail":"), outside the United Nations Headquarters District by any individual employed by, or authorized by the United Nations to conduct official business in connection with, that organization or its agencies, or by any person or agency acting on behalf thereof, may be permitted or denied or subject to reasonable regulation, as determined to be in the best interests of the United States and pursuant to this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9075e460-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4309a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s139/26"},"text":"Pub. L. 103–236, title I, § 139(26)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/399"},"text":"108 Stat. 399","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9075e461-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4309a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall report to the Congress—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9075e462-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4309a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 30 days after ","children":[{"tag":"date","attrib":{"date":"1985-08-16"},"text":"August 16, 1985","children":[],"tail":", on the plans of the Secretary for implementing this section; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9075e463-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4309a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 6 months thereafter, on the actions taken pursuant to those plans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9075e464-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4309a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States nationals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply with respect to any United States national.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9075e465-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4309a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “United Nations Headquarters District” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “United Nations Headquarters District” means the area within the United States which is agreed to by the United Nations and the United States to constitute such a district, together with such other areas as the Secretary of State may approve from time to time in order to permit effective functioning of the United Nations or missions to the United Nations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9075e466-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch841"},"text":"Aug. 1, 1956, ch. 841","children":[],"tail":", title II, § 209A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/93/tI/s141"},"text":"Pub. L. 99–93, title I, § 141","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-16"},"text":"Aug. 16, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/423"},"text":"99 Stat. 423","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s139/26"},"text":"Pub. L. 103–236, title I, § 139(26)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/399"},"text":"108 Stat. 399","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9075e467-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9075e468-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9075e469-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/80/357"},"text":"Public Law 80–357","children":[],"tail":", referred to in subsec. (a)(1), is "},{"tag":"ref","attrib":{"href":"/us/act/1947-08-04/ch482"},"text":"act Aug. 4, 1947, ch. 482","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/756"},"text":"61 Stat. 756","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s287"},"text":"section 287 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9075e46a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":" struck out par. (2) which read as follows: “The Secretary shall apply to those employees of the United Nations Secretariat who are nationals of a foreign country or members of a foreign mission all terms, limitations, restrictions, and conditions which are applicable pursuant to this chapter to the members of that country’s mission or of any other mission to the United Nations unless the Secretary determines and reports to the Congress that national security and foreign policy circumstances require that this paragraph be waived in specific circumstances.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
