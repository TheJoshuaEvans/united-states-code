{"tag":"section","attrib":{"id":"id90843bb0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4859"},"text":null,"children":[{"tag":"num","attrib":{"value":"4859"},"text":"§ 4859.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of public entrances of United States diplomatic missions abroad","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall install and maintain a walk-through metal detector or other advanced screening system at public entrances of each United States diplomatic mission abroad.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id90843bb1-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/399/tIV/s409"},"text":"Pub. L. 99–399, title IV, § 409","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/866"},"text":"100 Stat. 866","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
