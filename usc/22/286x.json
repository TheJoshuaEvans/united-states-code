{"tag":"section","attrib":{"id":"id8ec8a88c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286x"},"text":null,"children":[{"tag":"num","attrib":{"value":"286x"},"text":"§ 286x.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to private sector of El Salvador, Nicaragua, and other nations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It is the sense of the Congress that in providing assistance through loans or other means to any nation, in particular El Salvador and Nicaragua, the Fund and the Bank should encourage programs which assist the private sector to create an environment which will stabilize the economy of the nation; and that the United States representatives to the Fund and the Bank shall promote the use of assistance by the Fund and the Bank to encourage such programs.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ec8a88d-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-07-31/ch339/s38"},"text":"July 31, 1945, ch. 339, § 38","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/389/s8"},"text":"Pub. L. 96–389, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-07"},"text":"Oct. 7, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1554"},"text":"94 Stat. 1554","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ec8a88e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ec8a88f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id8ec8a890-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1980-10-07"},"text":"Oct. 7, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/389/s12"},"text":"section 12 of Pub. L. 96–389","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s286s"},"text":"section 286s of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
