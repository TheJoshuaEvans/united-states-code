{"tag":"section","attrib":{"id":"id908b67d1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5353"},"text":null,"children":[{"tag":"num","attrib":{"value":"5353"},"text":"§ 5353.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fair trade in financial services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id908b67d2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5353/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discussions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"When advantageous the President or his designee shall conduct discussions with the governments of countries that are major financial centers, aimed at:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id908b67d3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5353/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring that United States banking organizations and securities companies have access to foreign markets and receive national treatment in those markets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908b67d4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5353/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing or eliminating barriers to, and other distortions of, international trade in financial services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908b67d5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5353/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" achieving reasonable comparability in the types of financial services permissible for financial service companies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908b67d6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5353/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing uniform supervisory standards for banking organizations and securities companies, including uniform capital standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id908b67d7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5353/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation before discussions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before entering into those discussions, the President or his designee shall consult with the committees of jurisdiction in the Senate and the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id908b67d8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5353/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After completing those discussions and after consultation with the committees of jurisdiction, the President shall transmit to the Congress any recommendations that have emerged from those discussions. Any recommendations for changes in United States financial laws or practices shall be accompanied by a description of the changes in foreign financial laws or practices that would accompany action by the Congress, and by an explanation of the benefits that would accrue to the United States from adoption of the recommendations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id908b67d9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5353/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction of section","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section may be construed as prior approval of any legislation which may be necessary to implement any recommendations resulting from discussions under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id908b67da-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tIII/s3603"},"text":"Pub. L. 100–418, title III, § 3603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1387"},"text":"102 Stat. 1387","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id908b67db-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id908b67dc-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id908b67dd-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of President under this section delegated to Secretary of the Treasury by section 1 of Ex. Ord. No. 12781, ","children":[{"tag":"date","attrib":{"date":"1991-11-20"},"text":"Nov. 20, 1991","children":[],"tail":", 56 F.R. 59203, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of Title 3","children":[],"tail":", The President."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
