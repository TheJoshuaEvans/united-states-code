{"tag":"section","attrib":{"id":"id914c6d0f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9741"},"text":null,"children":[{"tag":"num","attrib":{"value":"9741"},"text":"§ 9741.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovering assets stolen from the Venezuelan people","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id914c6d10-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9741/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovering assets","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President, acting through the Secretary of State and in consultation with the Secretary of the Treasury, shall advance a coordinated international effort—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id914c6d11-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9741/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to work with foreign governments—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id914c6d12-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9741/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to share financial investigations intelligence, as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914c6d13-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9741/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to block the assets identified pursuant to paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914c6d14-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9741/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide technical assistance to help governments establish the necessary legal framework to carry out asset forfeitures; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914c6d15-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9741/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out special financial investigations to identify and track assets taken from the people and institutions of Venezuela through theft, corruption, money laundering, or other illicit means.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id914c6d16-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9741/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategy requirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id914c6d17-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9741/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"December 20, 2019","children":[],"tail":", the President, acting through the Secretary of State and in consultation with the Secretary of the Treasury, shall submit a strategy for carrying out the activities described in subsection (a) to Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914c6d18-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9741/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The strategy required under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id914c6d19-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9741/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess whether the United States or another member of the international community should establish a managed fund to hold the assets identified pursuant to subsection (a)(2) that could be returned to a future democratic government in Venezuela; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914c6d1a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9741/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include such recommendations as the President and the Secretary of State consider appropriate for legislative or administrative action in the United States that would be needed to establish and manage the fund described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id914c6d1b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dJ/tI/s151"},"text":"Pub. L. 116–94, div. J, title I, § 151","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3039"},"text":"133 Stat. 3039","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
