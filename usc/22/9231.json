{"tag":"section","attrib":{"id":"id91218e47-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9231"},"text":null,"children":[{"tag":"num","attrib":{"value":"9231"},"text":"§ 9231.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress on trilateral cooperation between the United States, South Korea, and Japan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id91218e48-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9231/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that the President—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91218e49-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9231/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" should seek to strengthen high-level trilateral mechanisms for discussion and coordination of policy toward North Korea between the Government of the United States, the Government of South Korea, and the Government of Japan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91218e4a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9231/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" should ensure that the mechanisms specifically address North Korea’s nuclear, ballistic, and conventional weapons programs, its human rights record, and cybersecurity threats posed by North Korea;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91218e4b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9231/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" should ensure that representatives of the United States, South Korea, and Japan meet on a regular basis and include representatives of the United States Department of State, the United States Department of Defense, the United States intelligence community, and representatives of counterpart agencies in South Korea and Japan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91218e4c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9231/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" should continue to brief the relevant congressional committees regularly on the status of such discussions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91218e4d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9231/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relevant committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The relevant committees referred to in subsection (a)(4) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91218e4e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9231/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations, the Committee on Armed Services, and the Select Committee on Intelligence of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91218e4f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9231/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs, the Committee on Armed Services, and the Permanent Select Committee on Intelligence of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id91218e50-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/122/tII/s211"},"text":"Pub. L. 114–122, title II, § 211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-18"},"text":"Feb. 18, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/111"},"text":"130 Stat. 111","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
