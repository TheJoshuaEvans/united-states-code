{"tag":"section","attrib":{"id":"id8fedefd9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2656k"},"text":null,"children":[{"tag":"num","attrib":{"value":"2656k"},"text":"§ 2656k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Human rights awareness for American athletic delegations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fedefda-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2656k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of Congress that individuals representing the United States at international athletic competitions in foreign countries should have the opportunity to be informed about human rights and security concerns in such countries and how best to safeguard their personal security and privacy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fedefdb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2656k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fedefdc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2656k/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2021-12-27"},"text":"December 27, 2021","children":[],"tail":", the Secretary of State shall devise and implement a strategy for disseminating briefing materials, including information described in subsection (c), to individuals representing the United States at international athletic competitions in a covered country."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fedefdd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2656k/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing and form of materials","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fedefde-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2656k/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The briefing materials referred to in paragraph (1) shall be offered not later than 180 days prior to the commencement of an international athletic competition in a covered country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fedefdf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2656k/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of delivery","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Briefing materials related to the human rights record of covered countries may be delivered electronically or disseminated in person, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fedefe0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2656k/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Information briefing materials related to personal security risks may be offered electronically, in written format, by video teleconference, or prerecorded video.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fedefe1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2656k/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In devising and implementing the strategy required under paragraph (1), the Secretary of State shall consult with the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fedefe2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2656k/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee on Foreign Affairs of the House of Representatives and the Committee on Foreign Relations in the Senate, not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2021-12-27"},"text":"December 27, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fedefe3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2656k/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Leading human rights nongovernmental organizations and relevant subject-matter experts in determining the content of the briefings required under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fedefe4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2656k/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Olympic and Paralympic Committee and the national governing bodies of amateur sports that play a role in determining which individuals represent the United States in international athletic competitions, regarding the most appropriate and effective method to disseminate briefing materials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fedefe5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2656k/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content of briefings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The briefing materials required under subsection (b) shall include, with respect to a covered country hosting an international athletic competition in which individuals may represent the United States, the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fedefe6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2656k/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information on the human rights concerns present in such covered country, as described in the Department of State’s Annual Country Reports on Human Rights Practices.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fedefe7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2656k/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information, as applicable, on risks such individuals may face to their personal and digital privacy and security, and recommended measures to safeguard against certain forms of foreign intelligence targeting, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fedefe8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2656k/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered country defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “covered country” means, with respect to a country hosting an international athletic competition in which individuals representing the United States may participate, any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fedefe9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2656k/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any Communist country specified in subsection (f) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2370"},"text":"section 2370 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fedefea-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2656k/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any country ranked as a Tier 3 country in the most recent Department of State’s annual Trafficking in Persons Report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fedefeb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2656k/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other country the Secretary of State determines presents serious human rights concerns for the purpose of informing such individuals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fedefec-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2656k/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any country the Secretary of State, in consultation with other cabinet officials as appropriate, determines presents a serious counterintelligence risk.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fedefed-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dF/tLXV/s6504"},"text":"Pub. L. 117–81, div. F, title LXV, § 6504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2426"},"text":"135 Stat. 2426","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
