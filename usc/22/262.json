{"tag":"section","attrib":{"id":"id8e8ab5a6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262"},"text":null,"children":[{"tag":"num","attrib":{"value":"262"},"text":"§ 262.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" President’s participation in international congresses restricted","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Executive shall not extend or accept any invitation to participate in any international congress, conference, or like event, without first having specific authority of law to do so.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8e8ab5a7-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-03-04/ch149"},"text":"Mar. 4, 1913, ch. 149","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/913"},"text":"37 Stat. 913","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
