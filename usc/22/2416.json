{"tag":"section","attrib":{"id":"id8fb998f5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2416"},"text":null,"children":[{"tag":"num","attrib":{"value":"2416"},"text":"§ 2416.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual foreign military training report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fb998f6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2416/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fb998f7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2416/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than January 31 of each year, the Secretary of Defense and the Secretary of State shall jointly prepare and submit to the appropriate congressional committees a report on all military training provided to foreign military personnel by the Department of Defense and the Department of State during the previous fiscal year and all such training proposed for the current fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fb998f8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2416/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for certain countries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) does not apply to any NATO member, Australia, Japan, or New Zealand, unless one of the appropriate congressional committees has specifically requested, in writing, inclusion of such country in the report. Such request shall be made not later than 90 calendar days prior to the date on which the report is required to be transmitted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fb998f9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2416/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report described in subsection (a) shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fb998fa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2416/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For each military training activity, the foreign policy justification and purpose for the activity, the number of foreign military personnel provided training and their units of operation, and the location of the training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fb998fb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2416/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For each country, the aggregate number of students trained and the aggregate cost of the military training activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fb998fc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2416/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to United States personnel, the operational benefits to United States forces derived from each military training activity and the United States military units involved in each activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fb998fd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2416/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report described in subsection (a) shall be in unclassified form but may include a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fb998fe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2416/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability on Internet","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All unclassified portions of the report described in subsection (a) shall be made available to the public on the Internet through the Department of State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fb998ff-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2416/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fb99900-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2416/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations and the Committee on International Relations of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fb99901-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2416/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations and the Committee on Foreign Relations of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fb99902-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. III, § 656, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/7/dB/tXIII/s1307"},"text":"Pub. L. 106–113, div. B, § 1000(a)(7) [div. B, title XIII, § 1307]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–512; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/228/dB/tXII/s1262/a"},"text":"Pub. L. 107–228, div. B, title XII, § 1262(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"Sept. 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1434"},"text":"116 Stat. 1434","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fb99903-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8fb99904-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id8fb99905-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2416, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. III, § 656, as added "},{"tag":"ref","attrib":{"href":"/us/pl/92/226"},"text":"Pub. L. 92–226","children":[],"tail":", pt. III, § 304(b), "},{"tag":"date","attrib":{"date":"1972-02-07"},"text":"Feb. 7, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/30"},"text":"86 Stat. 30","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/93/559/s39/b"},"text":"Pub. L. 93–559, § 39(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-12-30"},"text":"Dec. 30, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1810"},"text":"88 Stat. 1810","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/329/tIV/s413/a"},"text":"Pub. L. 94–329, title IV, § 413(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-06-30"},"text":"June 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/761"},"text":"90 Stat. 761","children":[],"tail":", related to limitation on number of United States personnel in Cambodia, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/95/424/tVI"},"text":"Pub. L. 95–424, title VI","children":[],"tail":", §§ 604, 605, "},{"tag":"date","attrib":{"date":"1978-10-06"},"text":"Oct. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/961"},"text":"92 Stat. 961","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1978-10-01"},"text":"Oct. 1, 1978","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8fb99906-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/228"},"text":"Pub. L. 107–228","children":[],"tail":" designated existing provisions as par. (1), inserted par. (1) heading, and added par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8fb99907-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id8fb99908-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on International Relations of House of Representatives changed to Committee on Foreign Affairs of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
