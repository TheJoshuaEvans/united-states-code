{"tag":"section","attrib":{"id":"id91029404-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8519"},"text":null,"children":[{"tag":"num","attrib":{"value":"8519"},"text":"§ 8519.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports on certain activities of foreign export credit agencies and of the Export-Import Bank of the United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id91029405-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8519/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on certain activities of export credit agencies of foreign countries","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91029406-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8519/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2010-07-01"},"text":"July 1, 2010","children":[],"tail":", the President shall submit to the appropriate congressional committees a report on any activity of an export credit agency of a foreign country that is an activity comparable to an activity described in subsection (a) or (b) of section 5 of the Iran Sanctions Act of 1996, as amended by section 102 of this Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91029407-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8519/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall update the report required by paragraph (1) as new information becomes available with respect to the activities of export credit agencies of foreign countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91029408-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8519/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on certain financing by the Export-Import Bank of the United States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days (or, in extraordinary circumstances, not later than 15 days) before the Export-Import Bank of the United States approves cofinancing (including loans, guarantees, other credits, insurance, and reinsurance) in which an export credit agency of a foreign country identified in the report required by subsection (a) will participate, the President shall submit to the appropriate congressional committees a report identifying—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91029409-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8519/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the export credit agency of the foreign country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9102940a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8519/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the beneficiaries of the financing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9102940b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/195/tI/s111"},"text":"Pub. L. 111–195, title I, § 111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-01"},"text":"July 1, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1339"},"text":"124 Stat. 1339","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9102940c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id9102940d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8551/a"},"text":"section 8551(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9102940e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9102940f-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 5 of the Iran Sanctions Act of 1996, as amended by section 102 of this Act, referred to in subsec. (a)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/172/s5"},"text":"section 5 of Pub. L. 104–172","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/195/s102"},"text":"section 102 of Pub. L. 111–195","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"section 1701 of Title 50","children":[],"tail":", War and National Defense."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id91029410-2930-11f1-8918-be39dde81dc6"},"