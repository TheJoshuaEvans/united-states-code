{"tag":"section","attrib":{"id":"id9071294f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4155"},"text":null,"children":[{"tag":"num","attrib":{"value":"4155"},"text":"§ 4155.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conversion of certain positions in Department of Agriculture","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90712950-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4155/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation and classification of positions to be occupied; notice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 15 days after ","children":[{"tag":"date","attrib":{"date":"1981-02-15"},"text":"February 15, 1981","children":[],"tail":", the Secretary of Agriculture shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90712951-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4155/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate and classify under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3981"},"text":"section 3981 of this title","children":[],"tail":" those positions in the Foreign Agricultural Service under the General Schedule described in "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":" which the Secretary of Agriculture determines are to be occupied by career members of the Foreign Service, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90712952-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4155/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide written notice to individuals holding those positions of such designation and classification of the personnel category under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3903"},"text":"section 3903 of this title","children":[],"tail":" which will apply to such individual."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90712953-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4155/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election to convert","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each employee serving in a position at the time it is designated under subsection (a) shall, not later than 120 days after notice of such designation, elect—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90712954-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4155/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to accept conversion to the Foreign Service, in which case such employee shall be converted in accordance with the provisions of subsection (c); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90712955-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4155/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to decline conversion to the Foreign Service and have the provisions of subsection (d) apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90712956-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4155/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations for appointment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90712957-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4155/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Agriculture shall recommend to the President for appointment to the appropriate class (as determined under paragraph (2)), by and with the advice and consent of the Senate, those employees who elect conversion under subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90712958-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4155/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Agriculture shall appoint as Foreign Service personnel those employees who elect to accept conversion and who are not eligible for appointment under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90712959-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4155/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Results of declining to convert","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any employee who declines conversion under subsection (b)(2) shall for so long as that employee continues to hold the designated position be deemed to be a member of the Foreign Service for purposes of allowances, differentials, and similar benefits (as determined by the Secretary of Agriculture).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9071295a-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tII/s2105"},"text":"Pub. L. 96–465, title II, § 2105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2150"},"text":"94 Stat. 2150","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9071295b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9071295c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id9071295d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (a), “","children":[{"tag":"date","attrib":{"date":"1981-02-15"},"text":"February 15, 1981","children":[],"tail":"” substituted for “the effective date of this Act” pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/96/465/s2403"},"text":"section 2403 of Pub. L. 96–465","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3901"},"text":"section 3901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
