{"tag":"section","attrib":{"id":"id8e884468-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s254e"},"text":null,"children":[{"tag":"num","attrib":{"value":"254e"},"text":"§ 254e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability insurance for members of mission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8e884469-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s254e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each mission, members of the mission and their families, and individuals described in section 19 of the Convention on Privileges and Immunities of the United Nations of ","children":[{"tag":"date","attrib":{"date":"1946-02-13"},"text":"February 13, 1946","children":[],"tail":", shall comply with any requirement imposed by the regulations promulgated by the Director of the Office of Foreign Missions in the Department of State pursuant to subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8e88446a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s254e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment by regulation of liability insurance requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Office of Foreign Missions shall, by regulation, establish liability insurance requirements which can reasonably be expected to afford adequate compensation to victims and which are to be met by each mission, members of the mission and their families, and individuals described in section 19 of the Convention on Privileges and Immunities of the United Nations of ","children":[{"tag":"date","attrib":{"date":"1946-02-13"},"text":"February 13, 1946","children":[],"tail":", relating to risks arising from the operation in the United States of any motor vehicle, vessel, or aircraft."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8e88446b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s254e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement of liability insurance requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Office of Foreign Missions shall take such steps as he may deem necessary to insure that each mission, members of the mission and their families, and individuals described in section 19 of the Convention on Privileges and Immunities of the United Nations of ","children":[{"tag":"date","attrib":{"date":"1946-02-13"},"text":"February 13, 1946","children":[],"tail":", who operate motor vehicles, vessels, or aircraft in the United States comply with the requirements established pursuant to subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8e88446c-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/393/s6"},"text":"Pub. L. 95–393, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-09-30"},"text":"Sept. 30, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/809"},"text":"92 Stat. 809","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/164/tVI/s602"},"text":"Pub. L. 98–164, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-11-22"},"text":"Nov. 22, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1042"},"text":"97 Stat. 1042","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8e88446d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8e88446e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8e88446f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1983—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/164/s602/1"},"text":"Pub. L. 98–164, § 602(1)","children":[],"tail":", substituted “Director of the Office of Foreign Missions in the Department of State” for “President”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/164/s602/2"},"text":"Pub. L. 98–164, § 602(2)","children":[],"tail":", inserted provision respecting adequate compensation to victims, and substituted reference to Director for reference to President."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/164/s602/3"},"text":"Pub. L. 98–164, § 602(3)","children":[],"tail":", substituted reference to Director for reference to President."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8e884470-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id8e884471-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective at end of ninety-day period beginning on ","children":[{"tag":"date","attrib":{"date":"1978-09-30"},"text":"Sept. 30, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/393/s9"},"text":"section 9 of Pub. L. 95–393","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s254a"},"text":"section 254a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8e884472-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Authority of Secretary of State","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Except as otherwise provided, Secretary of State to have and exercise any authority vested by law in any official or office of Department of State and references to such officials or offices deemed to refer to Secretary of State or Department of State, as appropriate, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651a"},"text":"section 2651a of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/s161/d"},"text":"section 161(d) of Pub. L. 103–236","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651a"},"text":"section 2651a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
