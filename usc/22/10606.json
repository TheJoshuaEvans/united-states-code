{"tag":"section","attrib":{"id":"id915ac597-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606"},"text":null,"children":[{"tag":"num","attrib":{"value":"10606"},"text":"§ 10606.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects and grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id915ac598-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project funding requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id915ac599-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Foundation shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id915ac59a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide grants to support eligible projects described in paragraph (3) that advance its mission to enable effective management of primarily protected and conserved areas and their contiguous buffer zones in eligible countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915ac59b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advance effective landscape or seascape approaches to conservation that include buffer zones, wildlife dispersal and corridor areas, and other effective area-based conservation measures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915ac59c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not purchase, own, or lease land, including conservation easements, in eligible countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id915ac59d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Eligible entities shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id915ac59e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not-for-profit organizations with demonstrated expertise in protected and conserved area management and economic development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915ac59f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" governments of eligible partner countries, as determined by subsection (b), with the exception of governments and government entities that are prohibited from receiving grants from the Foundation pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s10607"},"text":"section 10607 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915ac5a0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indigenous and local communities in such eligible countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id915ac5a1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Eligible projects shall include projects that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id915ac5a2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" focus on supporting—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id915ac5a3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transparent and effective long-term management of primarily protected or conserved areas and their contiguous buffer zones in countries described in subsection (b), including terrestrial, coastal, and marine protected or conserved areas, parks, community conservancies, Indigenous reserves, conservation easements, and biological reserves; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id915ac5a4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other effective area-based conservation measures;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915ac5a5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are cost-matched at a ratio of not less than $2 from sources other than the United States for every $1 made available under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915ac5a6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" are subject to long-term binding memoranda of understanding with the governments of eligible countries and local communities—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id915ac5a7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/a/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that local populations have access, resource management responsibilities, and the ability to pursue permissible, sustainable economic activity on affected lands; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id915ac5a8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/a/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that may be signed by governments in such eligible countries to ensure free, prior, and informed consent of affected communities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915ac5a9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporate a set of key performance and impact indicators;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915ac5aa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" demonstrate robust local community engagement, with the completion of appropriate environmental and social due diligence, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id915ac5ab-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/a/3/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" free, prior, and informed consent of Indigenous Peoples and relevant local communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id915ac5ac-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/a/3/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inclusive governance structures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id915ac5ad-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/a/3/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effective grievance mechanisms;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915ac5ae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" create economic opportunities for local communities, including through—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id915ac5af-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/a/3/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equity and profit-sharing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id915ac5b0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/a/3/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperative management of natural resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id915ac5b1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/a/3/F/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employment activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id915ac5b2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/a/3/F/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other related economic growth activities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915ac5b3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/a/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leverage stable baseline funding for the effective management of the primarily protected or conserved area project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915ac5b4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/a/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to the extent possible—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id915ac5b5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/a/3/H/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are viable and prepared for implementation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id915ac5b6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/a/3/H/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate a plan to strengthen the capacity of, and transfer skills to, local institutions to manage the primarily protected or conserved area before or after grant funding is exhausted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id915ac5b7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible countries","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id915ac5b8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Pursuant to the Plan of Action required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s10602/c"},"text":"section 10602(c) of this title","children":[],"tail":", and before awarding any grants or entering into any project agreements for any fiscal year, the Board shall conduct a review to identify eligible countries in which the Foundation may fund projects. Such review shall consider countries that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id915ac5b9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are low-income, lower middle-income, or upper-middle-income economies (as defined by the International Bank for Reconstruction and Development and the International Development Association);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915ac5ba-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" have—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id915ac5bb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a high degree of threatened or at-risk biological diversity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id915ac5bc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" species or ecosystems of significant importance, including threatened or endangered species or ecosystems at risk of degradation or destruction;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915ac5bd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have demonstrated a commitment to conservation through verifiable actions, such as protecting lands and waters through the gazettement of national parks, community conservancies, marine reserves and protected areas, forest reserves, or other legally recognized forms of place-based conservation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915ac5be-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are not ineligible to receive United States foreign assistance pursuant to any other provision of law, including laws identified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s10607"},"text":"section 10607 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id915ac5bf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of eligible countries","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 5 days after the date on which the Board determines which countries are eligible to receive assistance under this chapter for a fiscal year, the Executive Director shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id915ac5c0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit a report to the appropriate congressional committees that includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id915ac5c1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of all such eligible countries, as determined through the review process described in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id915ac5c2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a detailed justification for each such eligibility determination, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id915ac5c3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/b/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of why the eligible country would be suitable for partnership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id915ac5c4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/b/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the eligible partner country’s interest in and ability to participate meaningfully in proposed Foundation activities, including an evaluation of such eligible country’s prospects to substantially benefit from Foundation assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id915ac5c5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/b/2/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimation of each such eligible partner country’s commitment to conservation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id915ac5c6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/b/2/A/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the capacity and willingness of the eligible country to enact or implement reforms that might be necessary to maximize the impact and effectiveness of Foundation support; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915ac5c7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish the information contained in the report described in subparagraph (A) in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id915ac5c8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grantmaking","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id915ac5c9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to maximize program effectiveness, the Foundation shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id915ac5ca-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with other international public and private donors to the greatest extent practicable and appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915ac5cb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek additional financial and nonfinancial contributions and commitments for its projects from governments in eligible countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915ac5cc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strive to generate a partnership mentality among all participants, including public and private funders, host governments, local protected areas authorities, and private and nongovernmental organization partners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915ac5cd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prioritize investments in communities with low levels of economic development to the greatest extent practicable and appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915ac5ce-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider the eligible partner country’s planned and dedicated resources to the proposed project and the eligible entity’s ability to successfully implement the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id915ac5cf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Foundation grants—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id915ac5d0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall fund eligible projects that enhance the management of well-defined primarily protected or conserved areas and the systems of such conservation areas in eligible countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915ac5d1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" should support adequate baseline funding for eligible projects in eligible countries to be sustained for not less than 10 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915ac5d2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" should, during the grant period, demonstrate progress in achieving clearly defined key performance indicators (as defined in the grant agreement), which may include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id915ac5d3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the protection of biological diversity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id915ac5d4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the protection of native flora and habitats, such as trees, forests, wetlands, grasslands, mangroves, coral reefs, and sea grass;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id915ac5d5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/c/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community-based economic growth indicators, such as improved land tenure, increases in beneficiaries participating in related economic growth activities, and sufficient income from conservation activities being directed to communities in project areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id915ac5d6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/c/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improved management of the primarily protected or conserved area covered by the project, as documented through the submission of strategic plans or annual reports to the Foundation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id915ac5d7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/c/2/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification of additional revenue sources or sustainable financing mechanisms to meet the recurring costs of management of the primarily protected or conserved areas; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915ac5d8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall be terminated if the Board determines that the project is not—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id915ac5d9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/c/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meeting applicable requirements under this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id915ac5da-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10606/c/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making progress in achieving the key performance indicators defined in the grant agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id915ac5db-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dE/tLI/s5106"},"text":"Pub. L. 118–159, div. E, title LI, § 5106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2417"},"text":"138 Stat. 2417","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id915ac5dc-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id915ac5dd-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id915ac5de-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (b)(2) and (c)(2)(D)(i), was in the original “this title” and was translated as reading “this subtitle”, meaning subtitle A (§§ 5101–5109) of title LI of div. E of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2410"},"text":"138 Stat. 2410","children":[],"tail":", known as the United States Foundation for International Conservation Act of 2024, which is classified generally to this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
