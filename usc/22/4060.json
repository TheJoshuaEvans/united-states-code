{"tag":"section","attrib":{"id":"id9062d134-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4060"},"text":null,"children":[{"tag":"num","attrib":{"value":"4060"},"text":"§ 4060.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assignment and attachment of moneys","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9062d135-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4060/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annuities and severance pay benefits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9062d136-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4060/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual entitled to an annuity from the Fund may make allotments or assignments of amounts from such annuity for such purposes as the Secretary of State in his or her sole discretion considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9062d137-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4060/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3727"},"text":"section 3727 of title 31","children":[],"tail":" or any other law, a member of the Service who is entitled to receive benefits under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4009/b/1"},"text":"section 4009(b)(1) of this title","children":[],"tail":" may assign to any person the whole or any part of those benefits. Any such assignment shall be on a form approved by the Secretary of the Treasury and a copy of such assignment form shall be deposited with the Secretary of the Treasury by the member executing the assignment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9062d138-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4060/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participants or annuitants having former spouses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9062d139-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4060/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9062d13a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4060/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of any participant or annuitant who has a former spouse who is covered by a court order or who is a party to a spousal agreement—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9062d13b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4060/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any right of the former spouse to any annuity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4054/a"},"text":"section 4054(a) of this title","children":[],"tail":" in connection with any retirement or disability annuity of the participant, and the amount of any such annuity;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9062d13c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4060/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any right of the former spouse to a survivor annuity under section 4054(b) or (c) of this title, and the amount of any such annuity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9062d13d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4060/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any right of the former spouse to any payment of a lump-sum credit under section 4055(a) or (b) of this title;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be determined in accordance with that spousal agreement or court order, if and to the extent expressly provided for in the terms of that spousal agreement or court order.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9062d13e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4060/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This paragraph shall not apply in the case of any spousal agreement or court order which, as determined by the Secretary of State—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9062d13f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4060/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would provide for a survivor annuity for a spouse or any former spouse of a participant with respect to which there has not been an annuity reduction (or a salary reduction or payment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4054/c/3"},"text":"section 4054(c)(3) of this title","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9062d140-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4060/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is otherwise inconsistent with the requirements of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9062d141-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4060/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except with respect to obligations between participants and former spouses, payments under this part which would otherwise be made to a participant or annuitant based upon his or her service shall be paid (in whole or in part) by the Secretary of State to another individual to the extent expressly provided for in the terms of any order or any court decree of legal separation, or the terms of any court order or court-approved property settlement agreement incident to any court decree of legal separation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9062d142-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4060/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraphs (1) and (2) shall apply only to payments made under this part for periods beginning after the date of receipt by the Secretary of State of written notice of such decree, order, or agreement, and such additional information and such documentation as the Secretary of State may require.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9062d143-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4060/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any payment under this subsection to an individual bars recovery by any other individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9062d144-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4060/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The 10-year requirement of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4044/b/6"},"text":"section 4044(b)(6) of this title","children":[],"tail":", or any other provision of this part, shall not be construed to affect the rights any spouse or individual formerly married to a participant or annuitant may have, under any law or rule of law of any State or the District of Columbia, with respect to an annuity of a participant or annuitant under this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9062d145-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4060/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of other provisions of law or remedies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"None of the moneys mentioned in this part shall be assignable either in law or equity, except under subsection (a) or (b) of this section, or subject to execution, levy, attachment, garnishment, or other legal process, except as otherwise may be provided by Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9062d146-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s820"},"text":"Pub. L. 96–465, title I, § 820","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2120"},"text":"94 Stat. 2120","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/335/tIV/s402/a/2"},"text":"Pub. L. 99–335, title IV, § 402(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-06"},"text":"June 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/609"},"text":"100 Stat. 609","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9062d147-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9062d148-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id9062d149-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (a)(2), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3727"},"text":"section 3727 of title 31","children":[],"tail":"” substituted for “section 3477 of the Revised Statutes of the United States ("},{"tag":"ref","attrib":{"href":"/us/usc/t31/s203"},"text":"31 U.S.C. 203","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s4/b"},"text":"Pub. L. 97–258, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1067"},"text":"96 Stat. 1067","children":[],"tail":", the first section of which enacted Title 31, Money and Finance."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9062d14a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsecs. (b)(1)(B)(ii), (2), (3), (5), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/335"},"text":"Pub. L. 99–335","children":[],"tail":" substituted “this part” for “this subchapter” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9062d14b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9062d14c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/335"},"text":"Pub. L. 99–335","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1987-01-01"},"text":"Jan. 1, 1987","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/335/s702/a"},"text":"section 702(a) of Pub. L. 99–335","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8401"},"text":"section 8401 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
