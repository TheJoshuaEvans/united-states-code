{"tag":"section","attrib":{"id":"id8f80395b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2292a–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"2292a–1"},"text":"§ 2292a–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriated funds; Presidential reports to Committees on Appropriations of the Senate and the House","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President shall submit quarterly reports to the Committee on Appropriations of the United States Senate and to the Committee on Appropriations of the House of Representatives on the programing and obligation of funds appropriated for International Disaster Assistance.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f80395c-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/330/tI/s100"},"text":"Pub. L. 94–330, title I, § 100","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-06-30"},"text":"June 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/773"},"text":"90 Stat. 773","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f80395d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f80395e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8f80395f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Foreign Assistance Act of 1961 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
