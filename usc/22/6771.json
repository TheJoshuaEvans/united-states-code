{"tag":"section","attrib":{"id":"id90c4a0c1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6771"},"text":null,"children":[{"tag":"num","attrib":{"value":"6771"},"text":"§ 6771.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90c4a0c2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6771/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Neither the Secretary of Defense nor any other officer or employee of the United States may, directly or by contract—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90c4a0c3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6771/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct any test or experiment involving the use of any chemical or biological agent on a civilian population; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90c4a0c4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6771/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use human subjects for the testing of chemical or biological agents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90c4a0c5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6771/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in subsection (a) may be construed to prohibit actions carried out for purposes not prohibited by this chapter (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6701/8"},"text":"section 6701(8) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90c4a0c6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6771/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Biological agent” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “biological agent” means any micro-organism (including bacteria, viruses, fungi, rickettsiae or protozoa), pathogen, or infectious substance, or any naturally occurring, bio-engineered or synthesized component of any such micro-organism, pathogen, or infectious substance, whatever its origin or method of production, capable of causing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90c4a0c7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6771/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" death, disease, or other biological malfunction in a human, an animal, a plant, or another living organism;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90c4a0c8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6771/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deterioration of food, water, equipment, supplies, or materials of any kind; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90c4a0c9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6771/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deleterious alteration of the environment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90c4a0ca-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dI/tVI/s602"},"text":"Pub. L. 105–277, div. I, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-886"},"text":"112 Stat. 2681–886","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90c4a0cb-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90c4a0cc-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90c4a0cd-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b), was in the original “this Act” and was translated as reading “this division”, meaning div. I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-856"},"text":"112 Stat. 2681–856","children":[],"tail":", known as the Chemical Weapons Convention Implementation Act of 1998, to reflect the probable intent of Congress. For complete classification of division I to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6701"},"text":"section 6701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
