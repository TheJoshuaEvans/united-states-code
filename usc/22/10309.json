{"tag":"section","attrib":{"id":"id91560a79-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10309"},"text":null,"children":[{"tag":"num","attrib":{"value":"10309"},"text":"§ 10309.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Post Data Pilot Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id91560a7a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10309/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Post Data and AI Pilot Program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91560a7b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10309/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to establish a program, which shall be known as the “Post Data Program” (referred to in this section as the “Program”), that shall be overseen by the Department’s Chief Data and Artificial Intelligence Officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91560a7c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10309/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The goals of the Program shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91560a7d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10309/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cultivating a data and artificial intelligence culture at diplomatic posts globally, including data fluency and data collaboration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91560a7e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10309/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Promoting data integration with Department of State Headquarters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91560a7f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10309/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Creating operational efficiencies, supporting innovation, and enhancing mission impact.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91560a80-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10309/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91560a81-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10309/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2025-12-18"},"text":"December 18, 2025","children":[],"tail":", the Secretary shall submit to the appropriate congressional committees an implementation plan that outlines strategies for—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91560a82-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10309/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advancing the goals described in subsection (a)(2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91560a83-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10309/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hiring data and artificial intelligence officers at United States diplomatic posts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91560a84-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10309/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allocation of necessary resources to sustain the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91560a85-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10309/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reporting requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2025-12-18"},"text":"December 18, 2025","children":[],"tail":", and annually thereafter for the following three years, the Secretary shall submit a report to the appropriate congressional committees regarding the status of the implementation plan required under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91560a86-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10309/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91560a87-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10309/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs and the Committee on Appropriations of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91560a88-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10309/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations and the Committee on Appropriations of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id91560a89-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dE/tIII/s5301"},"text":"Pub. L. 119–60, div. E, title III, § 5301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1592"},"text":"139 Stat. 1592","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id91560a8a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id91560a8b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id91560a8c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “Department” and “Secretary” as used in this section, see section 5002 of Pub. L. 119—60, set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
