{"tag":"section","attrib":{"id":"id8ebcc23a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"284bb"},"text":"§ 284bb.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eighteenth replenishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ebcc23b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284bb/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Governor of the International Development Association is authorized to contribute on behalf of the United States $3,291,030,000 to the eighteenth replenishment of the resources of the Association, subject to obtaining the necessary appropriations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ebcc23c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284bb/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to pay for the United States contribution provided for in subsection (a), there are authorized to be appropriated, without fiscal year limitation, $3,291,030,000 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ebcc23d-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/565/s30"},"text":"Pub. L. 86–565, § 30","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dK/tVII/s7083/b"},"text":"Pub. L. 115–141, div. K, title VII, § 7083(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/966"},"text":"132 Stat. 966","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
