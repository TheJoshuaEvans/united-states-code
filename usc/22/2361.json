{"tag":"section","attrib":{"id":"id8f9a7850-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2361"},"text":null,"children":[{"tag":"num","attrib":{"value":"2361"},"text":"§ 2361.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Completion of plans and cost estimates","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f9a7851-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2361/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction on agreements or grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No agreement or grant which constitutes an obligation of the United States Government in excess of $500,000 under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1501"},"text":"section 1501 of title 31","children":[],"tail":" shall be made for any assistance authorized under part I of subchapter I of this chapter, subpart II of part II of subchapter I of this chapter, or part IV of subchapter II of this chapter—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f9a7852-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2361/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such agreement or grant requires substantive technical or financial planning, until engineering, financial, and other plans necessary to carry out such assistance, and a reasonably firm estimate of the cost to the United States Government of providing such assistance, have been completed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f9a7853-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2361/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such agreement or grant requires legislative action within the recipient country, unless such legislative action may reasonably be anticipated to be completed in time to permit the orderly accomplishment of the purposes of such agreement or grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f9a7854-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2361/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plans for water or related land resource construction projects; computation of benefits and costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Plans required under subsection (a) of this section for any water or related land resource construction project or program shall include a computation of benefits and costs made insofar as practicable in accordance with the principles, standards, and procedures established pursuant to the Water Resources Planning Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1962"},"text":"42 U.S.C. 1962","children":[],"tail":", et seq.) or acts amendatory or supplementary thereto."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f9a7855-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2361/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts for construction outside United States; competitive basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the maximum extent practicable, all contracts for construction outside the United States made in connection with any agreement or grant subject to subsection (a) of this section shall be made on a competitive basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f9a7856-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2361/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Engineering, financial, and other plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) of this section shall not apply to any assistance furnished for the sole purpose of preparation of engineering, financial, and other plans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f9a7857-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2361/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification of country capability to maintain and utilize projects as prerequisite to assistance for capital projects exceeding cost limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to any other requirements of this section, no assistance authorized under part I of subchapter I of this chapter, subpart II of part II of subchapter I of this chapter, or part IV of subchapter II of this chapter shall be furnished with respect to any capital assistance project estimated to cost in excess of $1,000,000 until the head of the agency primarily responsible for administering subchapter I of this chapter has received and taken into consideration a certification from the principal officer of such agency in the country in which the project is located as to the capability of the country (both financial and human resources) to effectively maintain and utilize the project taking into account among other things the maintenance and utilization of projects in such country previously financed or assisted by the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f9a7858-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. III, § 611, "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/442"},"text":"75 Stat. 442","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/565"},"text":"Pub. L. 87–565","children":[],"tail":", pt. III, § 301(b), "},{"tag":"date","attrib":{"date":"1962-08-01"},"text":"Aug. 1, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/260"},"text":"76 Stat. 260","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/205"},"text":"Pub. L. 88–205","children":[],"tail":", pt. III, § 301(c), "},{"tag":"date","attrib":{"date":"1963-12-16"},"text":"Dec. 16, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/385"},"text":"77 Stat. 385","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/137"},"text":"Pub. L. 90–137","children":[],"tail":", pt. II, § 301(d), "},{"tag":"date","attrib":{"date":"1967-11-14"},"text":"Nov. 14, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/458"},"text":"81 Stat. 458","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/424/tI/s102/g/2/D"},"text":"Pub. L. 95–424, title I, § 102(g)(2)(D)","children":[],"tail":", (E), "},{"tag":"date","attrib":{"date":"1978-10-06"},"text":"Oct. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/943"},"text":"92 Stat. 943","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/53/tI/s117"},"text":"Pub. L. 96–53, title I, § 117","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-08-14"},"text":"Aug. 14, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/365"},"text":"93 Stat. 365","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/83/tXII"},"text":"Pub. L. 99–83, title XII","children":[],"tail":", §§ 1208, 1211(b)(2), "},{"tag":"date","attrib":{"date":"1985-08-08"},"text":"Aug. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/278"},"text":"99 Stat. 278","children":[],"tail":", 279.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f9a7859-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f9a785a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8f9a785b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Water Resources Planning Act, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/80"},"text":"Pub. L. 89–80","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-07-22"},"text":"July 22, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/244"},"text":"79 Stat. 244","children":[],"tail":", which is classified generally to chapter 19B (§ 1962 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1962"},"text":"section 1962 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f9a785c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1985—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/83/s1208/1"},"text":"Pub. L. 99–83, § 1208(1)","children":[],"tail":", substituted “$500,000” for “$100,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/83/s1211/b/2"},"text":"Pub. L. 99–83, § 1211(b)(2)","children":[],"tail":", substituted reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1501"},"text":"section 1501 of title 31","children":[],"tail":", for reference to section 1311 of the Supplemental Appropriation Act, 1955."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/83/s1208/2"},"text":"Pub. L. 99–83, § 1208(2)","children":[],"tail":", substituted “the principles, standards, and procedures established pursuant to the Water Resources Planning Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1962"},"text":"42 U.S.C. 1962","children":[],"tail":", et seq.) or acts amendatory or supplementary thereto” for “the procedures set forth in the Principles and Standards for Planning Water and Related Land Resources, dated "},{"tag":"date","attrib":{"date":"1973-10-25"},"text":"October 25, 1973","children":[],"tail":", with respect to such computations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/53"},"text":"Pub. L. 96–53","children":[],"tail":" substituted “Principles and Standards for Planning Water and Related Land Resources, dated "},{"tag":"date","attrib":{"date":"1973-10-25"},"text":"October 25, 1973","children":[],"tail":"” for “Memorandum of the President dated "},{"tag":"date","attrib":{"date":"1962-05-15"},"text":"May 15, 1962","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/424/s102/g/2/D"},"text":"Pub. L. 95–424, § 102(g)(2)(D)","children":[],"tail":", substituted “part I of subchapter I of this chapter, subpart II of part II of subchapter I of this chapter, or part IV of subchapter II of this chapter” for “subparts I, II, and VI of part II and part IV of subchapter I of this chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/424/s102/g/2/E"},"text":"Pub. L. 95–424, § 102(g)(2)(E)","children":[],"tail":", substituted “part I of subchapter I of this chapter, subpart II of part II of subchapter I of this chapter, or part IV of subchapter II of this chapter” for “subparts I, II, or VI of part II or part IV of subchapter I of this chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/137"},"text":"Pub. L. 90–137","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1963—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/205"},"text":"Pub. L. 88–205","children":[],"tail":" substituted “the Memorandum of the President dated "},{"tag":"date","attrib":{"date":"1962-05-15"},"text":"May 15, 1962","children":[],"tail":",” for “circular A–47 of the Bureau of the Budget.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/565"},"text":"Pub. L. 87–565","children":[],"tail":" included subpart VI of part II of subchapter I of this chapter within the restriction."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f9a785d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8f9a785e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References to Subchapter I Deemed To Include Certain Parts of Subchapter II","children":[],"tail":null},{"tag":"p","attrib":{},"text":"References to subchapter I of this chapter are deemed to include parts IV (§ 2346 et seq.), VI (§ 2348 et seq.), and VIII (§ 2349aa et seq.) of subchapter II of this chapter, and references to subchapter II are deemed to exclude such parts. See ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/226/s202/b"},"text":"section 202(b) of Pub. L. 92–226","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2346"},"text":"section 2346 of this title","children":[],"tail":", and sections 2348c and 2349aa–5 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8f9a785f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References to Part I Deemed To Include Section 2293","children":[],"tail":null},{"tag":"p","attrib":{},"text":"References to part I of subchapter I of this chapter are deemed to include a reference to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2293"},"text":"section 2293 of this title","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2293/d/1"},"text":"section 2293(d)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8f9a7860-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/83"},"text":"Pub. L. 99–83","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1985-10-01"},"text":"Oct. 1, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/83/s1301"},"text":"section 1301 of Pub. L. 99–83","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151–1"},"text":"section 2151–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8f9a7861-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1979 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/53"},"text":"Pub. L. 96–53","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1979-10-01"},"text":"Oct. 1, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/53/s512/a"},"text":"section 512(a) of Pub. L. 96–53","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8f9a7862-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/424"},"text":"Pub. L. 95–424","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1978-10-01"},"text":"Oct. 1, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/424/s605"},"text":"section 605 of Pub. L. 95–424","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
