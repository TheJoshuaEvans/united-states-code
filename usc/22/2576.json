{"tag":"section","attrib":{"id":"id8fd62132-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2576"},"text":null,"children":[{"tag":"num","attrib":{"value":"2576"},"text":"§ 2576.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Arms control information","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In order to assist the Secretary of State in the performance of his duties with respect to arms control, nonproliferation, and disarmament policy and negotiations, any Government agency preparing any legislative or budgetary proposal for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fd62133-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2576/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any program of research, development, testing, engineering, construction, deployment, or modernization with respect to nuclear armaments, nuclear implements of war, military facilities or military vehicles designed or intended primarily for the delivery of nuclear weapons,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fd62134-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2576/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any program of research, development, testing, engineering, construction, deployment, or modernization with respect to armaments, ammunition, implements of war, or military facilities, having—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fd62135-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2576/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimated total program cost in excess of $250,000,000, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fd62136-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2576/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimated annual program cost in excess of $50,000,000, or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fd62137-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2576/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other program involving technology with potential military application or weapons systems which such Government agency or the Secretary of State believes may have a significant impact on arms control, nonproliferation, and disarmament policy or negotiations,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall, on a continuing basis, provide the Secretary of State with full and timely access to detailed information with respect to the nature, scope, and purpose of such proposal.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fd62138-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/297/tIII/s305"},"text":"Pub. L. 87–297, title III, § 305","children":[],"tail":", formerly § 36, as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/141/tI/s146"},"text":"Pub. L. 94–141, title I, § 146","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-11-29"},"text":"Nov. 29, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/758"},"text":"89 Stat. 758","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/338/s1"},"text":"Pub. L. 95–338, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-08-08"},"text":"Aug. 8, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/458"},"text":"92 Stat. 458","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tVII"},"text":"Pub. L. 103–236, title VII","children":[],"tail":", §§ 704(1), 719(e), "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/492"},"text":"108 Stat. 492","children":[],"tail":", 501; renumbered § 305 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. A, title XII, § 1223(10), (21), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-770"},"text":"112 Stat. 2681–770","children":[],"tail":", 2681–772.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fd62139-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8fd6213a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8fd6213b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1223/10"},"text":"Pub. L. 105–277, § 1223(10)","children":[],"tail":", substituted “Secretary of State” for “Director” wherever appearing and, in concluding provisions, struck out “, in accordance with the procedures established pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2575"},"text":"section 2575 of this title","children":[],"tail":",” after “detailed information”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/s719/e"},"text":"Pub. L. 103–236, § 719(e)","children":[],"tail":", substituted “information” for “impact information and analysis” in section catchline, redesignated subsec. (a) as entire section, and inserted “, nonproliferation,” after “arms control” in introductory provisions and par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/s704/1"},"text":"Pub. L. 103–236, § 704(1)","children":[],"tail":", struck out subsec. (b) which required the Director to assess and analyze certain legislative and budgetary proposals with respect to their impact on arms control and disarmament policy and negotiations and subsec. (c) which prohibited courts from compelling performance of any requirement under this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/338/s1/1"},"text":"Pub. L. 95–338, § 1(1)","children":[],"tail":", substituted “technology with potential military application or weapons systems” for “weapons systems or technology”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/338/s1/2"},"text":"Pub. L. 95–338, § 1(2)","children":[],"tail":", inserted provisions requiring requests to be transmitted either as an individual program or as an aggregation of related programs, and classification requirements for transmitted statements."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8fd6213c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8fd6213d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effect