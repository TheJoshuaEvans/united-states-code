{"tag":"section","attrib":{"id":"id911a61cc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9003"},"text":null,"children":[{"tag":"num","attrib":{"value":"9003"},"text":"§ 9003.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial remedies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id911a61cd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9003/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction of courts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The courts of the States and the United States district courts shall have concurrent original jurisdiction of actions arising under the Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id911a61ce-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9003/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person seeking to initiate judicial proceedings under the Convention for the return of a child or for arrangements for organizing or securing the effective exercise of rights of access to a child may do so by commencing a civil action by filing a petition for the relief sought in any court which has jurisdiction of such action and which is authorized to exercise its jurisdiction in the place where the child is located at the time the petition is filed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id911a61cf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9003/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notice of an action brought under subsection (b) shall be given in accordance with the applicable law governing notice in interstate child custody proceedings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id911a61d0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9003/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of case","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The court in which an action is brought under subsection (b) shall decide the case in accordance with the Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id911a61d1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9003/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Burdens of proof","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id911a61d2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9003/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A petitioner in an action brought under subsection (b) shall establish by a preponderance of the evidence—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911a61d3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9003/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an action for the return of a child, that the child has been wrongfully removed or retained within the meaning of the Convention; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911a61d4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9003/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an action for arrangements for organizing or securing the effective exercise of rights of access, that the petitioner has such rights.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a61d5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9003/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of an action for the return of a child, a respondent who opposes the return of the child has the burden of establishing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911a61d6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9003/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by clear and convincing evidence that one of the exceptions set forth in article 13b or 20 of the Convention applies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911a61d7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9003/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by a preponderance of the evidence that any other exception set forth in article 12 or 13 of the Convention applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id911a61d8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9003/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of Convention","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of any action brought under this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id911a61d9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9003/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “authorities”, as used in article 15 of the Convention to refer to the authorities of the state of the habitual residence of a child, includes courts and appropriate government agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a61da-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9003/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “wrongful removal or retention” and “wrongfully removed or retained”, as used in the Convention, include a removal or retention of a child before the entry of a custody order regarding that child; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a61db-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9003/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “commencement of proceedings”, as used in article 12 of the Convention, means, with respect to the return of a child located in the United States, the filing of a petition in accordance with subsection (b) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id911a61dc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9003/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full faith and credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Full faith and credit shall be accorded by the courts of the States and the courts of the United States to the judgment of any other such court ordering or denying the return of a child, pursuant to the Convention, in an action brought under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id911a61dd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9003/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remedies under Convention not exclusive","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The remedies established by the Convention and this chapter shall be in addition to remedies available under other laws or international agreements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id911a61de-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/300/s4"},"text":"Pub. L. 100–300, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-29"},"text":"Apr. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/438"},"text":"102 Stat. 438","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id911a61df-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id911a61e0-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id911a61e1-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (f) to (h), was in the original “this Act” meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/300"},"text":"Pub. L. 100–300","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-29"},"text":"Apr. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/437"},"text":"102 Stat. 437","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s9001"},"text":"section 9001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id911a61e2-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11603"},"text":"section 11603 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
