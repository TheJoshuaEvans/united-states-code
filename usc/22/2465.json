{"tag":"section","attrib":{"id":"id8fc7c911-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2465"},"text":null,"children":[{"tag":"num","attrib":{"value":"2465"},"text":"§ 2465.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" John Lewis Civil Rights Fellowship Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fc7c912-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2465/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established the John Lewis Civil Rights Fellowship Program (referred to in this section as the “Fellowship Program”) within the J. William Fulbright Educational Exchange Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fc7c913-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2465/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the Fellowship Program are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fc7c914-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2465/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to honor the legacy of Representative John Lewis by promoting a greater understanding of the history and tenets of nonviolent civil rights movements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fc7c915-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2465/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to advance foreign policy priorities of the United States by promoting studies, research, and international exchange in the subject of nonviolent movements that established and protected civil rights around the world.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fc7c916-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2465/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Bureau of Educational and Cultural Affairs (referred to in this section as the “Bureau”) shall administer the Fellowship Program in accordance with policy guidelines established by the Board, in consultation with the binational Fulbright Commissions and United States Embassies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fc7c917-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2465/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of fellows","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fc7c918-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2465/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall annually select qualified individuals to participate in the Fellowship Program. The Bureau may determine the number of fellows selected each year, which, whenever feasible, shall be not fewer than 25.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fc7c919-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2465/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outreach","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fc7c91a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2465/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent practicable, the Bureau shall conduct outreach at institutions, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id8fc7c91b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2465/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minority serving institutions, including historically Black colleges and universities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8fc7c91c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2465/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other appropriate institutions that are likely to produce a range of qualified applicants, as determined by the Bureau.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fc7c91d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2465/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this paragraph:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id8fc7c91e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2465/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Historically Black college and university","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “historically Black college and university” has the meaning given the term “part B institution” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1061"},"text":"section 1061 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8fc7c91f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2465/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minority serving institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “minority-serving institution” means an eligible institution under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1067q/a"},"text":"section 1067q(a) of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fc7c920-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2465/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fellowship orientation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Annually, the Bureau shall organize and administer a fellowship orientation, which shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fc7c921-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2465/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be held in Washington, D.C., or at another location selected by the Bureau; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fc7c922-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2465/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include programming to honor the legacy of Representative John Lewis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fc7c923-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2465/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Structure","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fc7c924-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2465/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Work plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To carry out the purposes described in subsection (b)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fc7c925-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2465/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" each fellow selected pursuant to subsection (d) shall arrange an internship or research placement—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id8fc7c926-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2465/f/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with a nongovernmental organization, academic institution, or other organization approved by the Bureau; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8fc7c927-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2465/f/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a country with an operational Fulbright U.S. Student Program; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fc7c928-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2465/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Bureau shall, for each fellow, approve a work plan that identifies the target objectives for the fellow, including specific duties and responsibilities relating to those objectives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fc7c929-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2465/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conferences; presentations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each fellow shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fc7c92a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2465/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attend a fellowship orientation organized and administered by the Bureau under subsection (e);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fc7c92b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2465/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not later than the date that is 1 year after the end of the fellowship period, attend a fellowship summit organized and administered by the Bureau, which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id8fc7c92c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2465/f/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whenever feasible, shall be held in a location of importance to the civil rights movement in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8fc7c92d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2465/f/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may coincide with other events facilitated by the Bureau; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fc7c92e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2465/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at such summit, give a presentation on lessons learned during the period of the fellowship.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fc7c92f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2465/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fellowship period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each fellowship under this section shall continue for a period determined by the Bureau, which, whenever feasible, shall be not fewer than 10 months.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fc7c930-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2465/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fellowship award","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Bureau shall provide each fellow under this section with an allowance that is equal to the amount needed for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fc7c931-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2465/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reasonable costs of the fellow during the fellowship period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fc7c932-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2465/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" travel and lodging expenses related to attending the orientation and summit required under subsection (e)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fc7c933-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2465/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date of the completion of the Fellowship Program by the initial cohort of fellows selected under subsection (d), and annually thereafter, the Secretary of State shall submit to the Committee on Foreign Relations of the Senate and the Committee on Foreign Affairs of the House of Representatives a report on the implementation of the Fellowship Program, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fc7c934-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2465/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the demographics of the cohort of fellows who completed a fellowship during the preceding 1-year period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fc7c935-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2465/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of internship and research placements, and research projects selected by such cohort, under the Fellowship Program, including feedback from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fc7c936-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2465/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such cohort on implementation of the Fellowship Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fc7c937-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2465/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary on lessons learned;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fc7c938-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2465/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan for factoring such lessons learned into future programming, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fc7c939-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2465/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of trends relating to the diversity of each cohort of fellows and the topics of projects completed since the establishment of the Fellowship Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fc7c93a-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/256/s115"},"text":"Pub. L. 87–256, § 115","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dF/tLXVI/s6604/a"},"text":"Pub. L. 118–31, div. F, title LXVI, § 6604(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/1011"},"text":"137 Stat. 1011","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fc7c93b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id8fc7c93c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s6604/c"},"text":"section 6604(c) of Pub. L. 118–31","children":[],"tail":", see Termination Date note set out below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8fc7c93d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"terminationDate","id":"id8fc7c93e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dF/tLXVI/s6604/c"},"text":"Pub. L. 118–31, div. F, title LXVI, § 6604(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/1013"},"text":"137 Stat. 1013","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/31/dF/tLXVI/s6604/c"},"text":"“The authority to carry out the John Lewis Civil Rights Fellowship Program established under section 115 of the Mutual Educational and Cultural Exchange Act of 1961 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2451"},"text":"22 U.S.C. 2451","children":[],"tail":" et seq.) ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2465"},"text":"22 U.S.C. 2465","children":[],"tail":"], as added by subsection (a), shall expire on the date that is 10 years after the date of the enactment of this division ["},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
