{"tag":"section","attrib":{"id":"id8eba518c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283ee"},"text":null,"children":[{"tag":"num","attrib":{"value":"283ee"},"text":"§ 283ee.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Reserve banks as depositories","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any Federal Reserve bank which is requested to do so by the Corporation shall act as its depository or as its fiscal agent, and the Board of Governors of the Federal Reserve System shall supervise and direct the carrying out of these functions by the Federal Reserve banks.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8eba518d-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tI/s101/1/tI"},"text":"Pub. L. 98–473, title I, § 101(1) [title I]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1884"},"text":"98 Stat. 1884","children":[],"tail":", 1885.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8eba518e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8eba518f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8eba5190-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on section 206 of title II of S. 2416, Ninety-eighth Congress, as introduced ","children":[{"tag":"date","attrib":{"date":"1984-03-13"},"text":"Mar. 13, 1984","children":[],"tail":", and enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
