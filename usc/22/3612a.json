{"tag":"section","attrib":{"id":"id903f1caa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3612a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3612a"},"text":"§ 3612a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General powers of Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id903f1cab-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3612a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corporate seal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may adopt, alter, and use a corporate seal, which shall be judicially noticed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id903f1cac-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3612a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bylaws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may by action of the Board of Directors adopt, amend, and repeal bylaws governing the conduct of its general business and the performance of the powers and duties granted to or imposed upon it by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id903f1cad-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3612a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suits by and against Commission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission may sue and be sued in its corporate name, except that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id903f1cae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3612a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amenability of the Commission to suit is limited by Article VIII of the Panama Canal Treaty of 1977, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3761"},"text":"section 3761 of this title","children":[],"tail":", and otherwise by law;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903f1caf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3612a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an attachment, garnishment, or similar process may not be issued against salaries or other moneys owed by the Commission to its employees except as provided by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5520a"},"text":"section 5520a of title 5","children":[],"tail":" and sections 659, 661, and 662 "},{"tag":"ref","attrib":{"idref":"fn002264"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002264"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 42, or as otherwise specifically authorized by the laws of the United States; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903f1cb0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3612a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commission is exempt from the payment of interest on claims and judgments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id903f1cb1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3612a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts, leases, agreements, or other transactions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may enter into contracts, leases, agreements, or other transactions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id903f1cb2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3612a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obligations and expenditures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id903f1cb3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3612a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may determine the character of, and necessity for, its obligations and expenditures and the manner in which they shall be incurred, allowed, and paid; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903f1cb4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3612a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may incur, allow, and pay its obligations and expenditures, subject to pertinent provisions of law generally applicable to Government corporations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id903f1cb5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3612a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority in payment of debts out of bankrupt estates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall have the priority of the Government of the United States in the payment of debts out of bankrupt estates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id903f1cb6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3612a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment of notaries public","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id903f1cb7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3612a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission may appoint any United States citizen to have the general powers of a notary public to perform, on behalf of Commission employees and their dependents outside the United States, any notarial act that a notary public is required or authorized to perform within the United States. Unless an earlier expiration is provided by the terms of the appointment, any such appointment shall expire three months after the Canal Transfer Date.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903f1cb8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3612a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Every notarial act performed by a person acting as a notary under paragraph (1) shall be as valid, and of like force and effect within the United States, as if executed by or before a duly authorized and competent notary public in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903f1cb9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3612a/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The signature of any person acting as a notary under paragraph (1), when it appears with the title of that person’s office, is prima facie evidence that the signature is genuine, that the person holds the designated title, and that the person is authorized to perform a notarial act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id903f1cba-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3612a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority of the Commission under this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3612b"},"text":"section 3612b of this title","children":[],"tail":" is subject to the Panama Canal Treaty of 1977 and related agreements, and to chapter 91 of title 31."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id903f1cbb-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70/tI/s1102a"},"text":"Pub. L. 96–70, title I, § 1102a","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dC/tXXXV/s3524/a"},"text":"Pub. L. 104–106, div. C, title XXXV, § 3524(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/639"},"text":"110 Stat. 639","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dC/tXXXV"},"text":"Pub. L. 105–85, div. C, title XXXV","children":[],"tail":", §§ 3546, 3550(d)(3), "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2073"},"text":"111 Stat. 2073","children":[],"tail":", 2074.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id903f1cbc-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id903f1cbd-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id903f1cbe-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 661 and 662 of title 42, referred to in subsec. (c)(2), were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/tIII/s362/b/1"},"text":"Pub. L. 104–193, title III, § 362(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-22"},"text":"Aug. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2246"},"text":"110 Stat. 2246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id903f1cbf-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s3546/2"},"text":"Pub. L. 105–85, § 3546(2)","children":[],"tail":", added subsec. (g). Former subsec. (g) redesignated (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s3550/d/3"},"text":"Pub. L. 105–85, § 3550(d)(3)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3612b"},"text":"section 3612b of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s3546/1"},"text":"Pub. L. 105–85, § 3546(1)","children":[],"tail":", redesignated subsec. (g) as (h)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
