{"tag":"section","attrib":{"id":"id911a6189-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8929"},"text":null,"children":[{"tag":"num","attrib":{"value":"8929"},"text":"§ 8929.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on non-compliance by the Russian Federation of its obligations under the INF Treaty","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id911a618a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8929/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress makes the following findings:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id911a618b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8929/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Russian Federation is in violation of its obligations under the Treaty between the United States of America and the Union of Soviet Socialist Republics on the Elimination of Their Intermediate-Range and Shorter-Range Missiles, signed at Washington ","children":[{"tag":"date","attrib":{"date":"1987-12-08"},"text":"December 8, 1987","children":[],"tail":", and entered into force "},{"tag":"date","attrib":{"date":"1988-06-01"},"text":"June 1, 1988","children":[],"tail":" (commonly referred to as the “Intermediate-Range Nuclear Forces Treaty” or “INF Treaty”)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a618c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8929/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This behavior poses a threat to the United States, its deployed forces, and its allies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id911a618d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8929/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id911a618e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8929/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President should hold the Russian Federation accountable for being in violation of its obligations under the INF Treaty; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a618f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8929/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President should demand the Russian Federation completely and verifiably eliminate the military systems that constitute the violation of its obligations under the INF Treaty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id911a6190-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8929/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id911a6191-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8929/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2014-12-18"},"text":"December 18, 2014","children":[],"tail":", and every 90 days thereafter, the President shall submit to the committees specified in subsection (d) a report that includes the following elements:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911a6192-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8929/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the status of the President’s efforts, in cooperation with United States allies, to hold the Russian Federation accountable for being in violation of its obligations under the INF Treaty and obtain the complete and verifiable elimination of its military systems that constitute the violation of its obligations under the INF Treaty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911a6193-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8929/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President’s assessment as to whether it remains in the national security interests of the United States to remain a party to the INF Treaty, and other related treaties and agreements, while the Russian Federation is in violation of its obligations under the INF Treaty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911a6194-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8929/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notification of any deployment by the Russian Federation of a ground launched ballistic or cruise missile system with a range of between 500 and 5,500 kilometers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911a6195-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8929/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A plan developed by the Secretary of State, in consultation with the Director of National Intelligence and the Defense Threat Reduction Agency (DTRA), to verify that the Russian Federation has fully and completely dismantled any ground launched cruise missiles or ballistic missiles with a range of between 500 and 5,500 kilometers, including details on facilities that inspectors need access to, people inspectors need to talk with, how often inspectors need the accesses for, and how much the verification regime would cost.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a6196-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8929/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report required under paragraph (1) shall be submitted in unclassified form but may contain a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a6197-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8929/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sunset","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The reporting requirement under paragraph (1) shall be in effect so long as the INF Treaty remains in force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id911a6198-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8929/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Committees specified","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The committees specified in this subsection are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id911a6199-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8929/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations, the Committee on Armed Services, and the Select Committee on Intelligence of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a619a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8929/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs, the Committee on Armed Services, and the Permanent Select Committee on Intelligence of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id911a619b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/272/s10"},"text":"Pub. L. 113–272, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2965"},"text":"128 Stat. 2965","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tXII/s1235/d"},"text":"Pub. L. 116–92, div. A, title XII, § 1235(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1650"},"text":"133 Stat. 1650","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id911a619c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id911a619d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id911a619e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" added par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id911a619f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id911a61a0-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of President under subsec. (c) of this section delegated to Secretary of State by Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2015-02-19"},"text":"Feb. 19, 2015","children":[],"tail":", 80 F.R. 12071, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s8925"},"text":"section 8925 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
