{"tag":"section","attrib":{"id":"id8ff51aa4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"2680–4"},"text":"§ 2680–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic briefings from Bureau of Intelligence and Research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ff51aa5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall offer to the appropriate congressional committees regular, quarterly briefings by the Bureau of Intelligence and Research, in coordination with other bureaus as appropriate, on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ff51aa6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680–4/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any topic requested by one or more of the appropriate congressional committees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff51aa7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680–4/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any topic of current importance to the national security of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff51aa8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680–4/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other topic the Secretary considers necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff51aa9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Location","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The briefings required under subsection (a) shall be held at a secure facility that is suitable for review of information that is classified at the level of “Top Secret/SCI”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff51aaa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680–4/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No limitation on other briefings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any briefings pursuant to subsection (a) shall be in addition to any briefings provided to the appropriate congressional committees, the Select Committee on Intelligence of the Senate, and the Permanent Select Committee on Intelligence of the House of Representatives. Nothing in this section shall be construed to limit the provision of any other briefings to the committees described in this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ff51aab-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dE/tI/s5171"},"text":"Pub. L. 119–60, div. E, title I, § 5171","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1586"},"text":"139 Stat. 1586","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ff51aac-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ff51aad-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id8ff51aae-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “Secretary” and “Appropriate Congressional Committees” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s5002"},"text":"section 5002 of Pub. L. 119–60","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
