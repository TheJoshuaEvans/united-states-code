{"tag":"section","attrib":{"id":"id8eb80784-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283a"},"text":null,"children":[{"tag":"num","attrib":{"value":"283a"},"text":"§ 283a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment of officers; term of office; salary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8eb80785-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Governor and alternate governor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President, by and with the advice and consent of the Senate, shall appoint a governor of the Bank and an alternate for the governor. The term of office for the governor and the alternate governor shall be five years, but each shall remain in office until a successor has been appointed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8eb80786-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive director and alternate executive director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President, by and with the advice and consent of the Senate, shall appoint an executive director of the Bank and an alternate Executive Director. Except as provided for in article XV, section 3, of the agreement, the term of office for the executive director shall be three years, but he shall remain in office until a successor has been appointed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8eb80787-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No person shall be entitled to receive any salary or other compensation from the United States for services as a governor, alternate governor, or executive director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8eb80788-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/147/s3"},"text":"Pub. L. 86–147, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-08-07"},"text":"Aug. 7, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/299"},"text":"73 Stat. 299","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/599"},"text":"Pub. L. 91–599","children":[],"tail":", ch. 2, § 21(b), "},{"tag":"date","attrib":{"date":"1970-12-30"},"text":"Dec. 30, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1658"},"text":"84 Stat. 1658","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8eb80789-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8eb8078a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8eb8078b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1970—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/599"},"text":"Pub. L. 91–599","children":[],"tail":" authorized appointment of an alternate Executive Director."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
