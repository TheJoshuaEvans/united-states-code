{"tag":"section","attrib":{"id":"id8f5a13c3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2151z"},"text":null,"children":[{"tag":"num","attrib":{"value":"2151z"},"text":"§ 2151z.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Targeted assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f5a13c4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2151z/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of target populations and strengthening United States assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall use poverty measurement standards, such as those developed by the International Bank for Reconstruction and Development, and other appropriate measurements in determining target populations for United States development assistance, and shall strengthen United States efforts to assure that a substantial percentage of development assistance under this part directly improves the lives of the poor majority, with special emphasis on those individuals living in absolute poverty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f5a13c5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2151z/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ultimate beneficiaries of activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the maximum extent possible, activities under this part that attempt to increase the institutional capabilities of private organizations or governments, or that attempt to stimulate scientific and technological research, shall be designed and monitored to ensure that the ultimate beneficiaries of these activities are the poor majority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f5a13c6-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. I, § 128, as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/377/tI/s101/b/2"},"text":"Pub. L. 97–377, title I, § 101(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-12-21"},"text":"Dec. 21, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1832"},"text":"96 Stat. 1832","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/83/tIII/s312/a"},"text":"Pub. L. 99–83, title III, § 312(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-08"},"text":"Aug. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/216"},"text":"99 Stat. 216","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f5a13c7-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f5a13c8-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f5a13c9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1985—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/83"},"text":"Pub. L. 99–83","children":[],"tail":", in amending section generally, designated existing provisions as subsec. (a), substituted provisions setting overall guidelines and principles for determination of target populations and strengthening United States assistance, for provisions relating to Presidential responsibility in carrying out this part in fiscal year 1983 for targeting assistance for those living in absolute poverty, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f5a13ca-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8f5a13cb-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/83"},"text":"Pub. L. 99–83","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1985-10-01"},"text":"Oct. 1, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/83/s1301"},"text":"section 1301 of Pub. L. 99–83","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151–1"},"text":"section 2151–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8f5a13cc-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report of Administrator of Agency for International Development to Congress by ","children":[{"tag":"date","attrib":{"date":"1983-06-21"},"text":"June 21, 1983","children":[],"tail":", on Implementation of Section"}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/377/tI/s101/b/2"},"text":"Pub. L. 97–377, title I, § 101(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-12-21"},"text":"Dec. 21, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1832"},"text":"96 Stat. 1832","children":[],"tail":", provided in part that within six months after "},{"tag":"date","attrib":{"date":"1982-12-21"},"text":"Dec. 21, 1982","children":[],"tail":", the Administrator of the Agency for International Development would report to Congress on the implementation of this section, the types of projects determined to meet these requirements, and the effect on the overall United States foreign assistance program."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id8f5a13cd-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id8f5a13ce-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions of President under this section, see Ex. Ord. No. 12163, ","children":[{"tag":"date","attrib":{"date":"1979-09-29"},"text":"Sept. 29, 1979","children":[],"tail":", 44 F.R. 56673, as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2381"},"text":"section 2381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
