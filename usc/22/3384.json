{"tag":"section","attrib":{"id":"id9037f0ce-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384"},"text":null,"children":[{"tag":"num","attrib":{"value":"3384"},"text":"§ 3384.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taiwan Fellowship Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9037f0cf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall establish the Taiwan Fellowship Program (referred to in this section as the “Program”) to provide a fellowship opportunity in Taiwan of up to 2 years for eligible United States citizens. The Department of State, in consultation with the American Institute in Taiwan and the implementing partner, may modify the name of the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9037f0d0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9037f0d1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The American Institute in Taiwan should use amounts appropriated pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3387/a"},"text":"section 3387(a) of this title","children":[],"tail":" to enter into an annual or multi-year cooperative agreement with an appropriate implementing partner."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9037f0d2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fellowships","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Department of State or the American Institute in Taiwan, in consultation with, as appropriate, the implementing partner, should award to eligible United States citizens, subject to available funding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id903a39c3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approximately 5 fellowships during the first 2 years of the Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id903a39c4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approximately 10 fellowships during each of the remaining years of the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id903a39c5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" American Institution ","children":[{"tag":"ref","attrib":{"idref":"fn002259"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002259"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Institute”."}],"tail":" in Taiwan agreement; implementing partner"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", the American Institute in Taiwan, in consultation with the Department of State, should—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id903a39c6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" begin negotiations with the Taipei Economic and Cultural Representative Office, or with another appropriate entity, for the purpose of entering into an agreement to facilitate the placement of fellows in an agency of Taiwan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903a39c7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" begin the process of selecting an implementing partner, which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id903a39c8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall agree to meet all of the legal requirements required to operate in Taiwan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id903a39c9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be composed of staff who demonstrate significant experience managing exchange programs in the Indo-Pacific region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id903a39ca-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Curriculum","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id903a39cb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First year","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During the first year of each fellowship under this section, each fellow should study—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id903a39cc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Mandarin Chinese language;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id903a39cd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the people, history, and political climate on Taiwan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id903a39ce-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the issues affecting the relationship between the United States and the Indo-Pacific region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903a39cf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Second year","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During the second year of each fellowship under this section, each fellow, subject to the approval of the Department of State, the American Institute in Taiwan, and the implementing partner, and in accordance with the purposes of this chapter, should work in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id903a39d0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a parliamentary office, ministry, or other agency of Taiwan; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id903a39d1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an organization outside the public sector in Taiwan, whose interests are associated with the interests of the fellow and the agency of the United States Government from which the fellow is or had been employed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id903a39d2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id903a39d3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A United States citizen is eligible for a fellowship under this section if the citizen—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id903a39d4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an employee of the United States Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id903a39d5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has received at least one exemplary performance review in his or her current United States Government role within at least the last three years prior to beginning the fellowship;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id903a39d6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has at least 2 years of experience in any branch of the United States Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id903a39d7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a demonstrated professional or educational background in the relationship between the United States and countries in the Indo-Pacific region; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id903a39d8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/e/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has demonstrated his or her commitment to further service in the United States Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903a39d9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of fellows","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each recipient of a fellowship under this section shall agree, as a condition of such fellowship—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id903a39da-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain satisfactory progress in language training and appropriate behavior in Taiwan, consistent with United States Government policy toward Taiwan, as determined by the Department of State, the American Institute in Taiwan and, as appropriate, its implementing partner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id903a39db-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to refrain from engaging in any intelligence or intelligence-related activity on behalf of the United States Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id903a39dc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to continue Federal Government employment for a period of not less than 4 years after the conclusion of the fellowship or for not less than 2 years for a fellowship that is 1 year or shorter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903a39dd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of implementing partner","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id903a39de-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of fellows","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The implementing partner, with the concurrence of the Department of State and the American Institute in Taiwan, shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id903a39df-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/e/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make efforts to recruit fellowship candidates who reflect the diversity of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id903a39e0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/e/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" select fellows for the Taiwan Fellowship Program based solely on merit, with appropriate supervision from the Department of State and the American Institute in Taiwan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id903a39e1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/e/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prioritize the selection of candidates willing to serve in a fellowship lasting 1 year or longer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id903a39e2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First year","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The implementing partner should provide each fellow in the first year (or shorter duration, as jointly determined by the Department of State and the American Institute in Taiwan for those who are not serving a 2-year fellowship) with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id903a39e3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/e/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intensive Mandarin Chinese language training; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id903a39e4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/e/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" courses in the politics, culture, and history of Taiwan, China, and the broader Indo-Pacific.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id903a39e5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of first-year training","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Department of State, in coordination with the American Institute in Taiwan and, as appropriate, the implementing partner, may waive any of the training required under paragraph (2) to the extent that a fellow has Mandarin language skills, knowledge of the topic described in subparagraph (B)(ii), or for other related reasons approved by the Department of State and the American Institute in Taiwan. If any of the training requirements are waived for a fellow serving a 2-year fellowship, the training portion of his or her fellowship may be shortened to the extent appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id903a39e6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/e/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office; staffing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The implementing partner, in consultation with the Department of State and the American Institute in Taiwan, may maintain an office and at least 1 full-time staff member in Taiwan—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id903a39e7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/e/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to liaise with the American Institute in Taiwan and institutions of Taiwan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id903a39e8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/e/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to serve as the primary in-country point of contact for the recipients of fellowships under this subchapter and their dependents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id903a39e9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/e/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The implementing partner may perform other functions in association with support of the Taiwan Fellowship Program, including logistical and administrative functions, as prescribed by the Department of State and the American Institute in Taiwan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903a39ea-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noncompliance","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id903a39eb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any fellow who fails to comply with the requirements under this section shall reimburse the American Institute in Taiwan, or the appropriate United States Government agency for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id903a39ec-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/e/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal funds expended for the fellow’s participation in the fellowship, as set forth in subparagraphs (B) and (C); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id903a39ed-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/e/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interest accrued on such funds (calculated at the prevailing rate).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id903a39ee-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full reimbursement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any fellow who violates subparagraph (A) or (B) of paragraph (2) shall reimburse the American Institute in Taiwan, or the appropriate United States Government agency, in an amount equal to the sum of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id903a39ef-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/e/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all of the Federal funds expended for the fellow’s participation in the fellowship; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id903a39f0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/e/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interest on the amount specified in subparagraph (A), which shall be calculated at the prevailing rate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id903a39f1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/e/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pro rata reimbursement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any fellow who violates subparagraph (C) of paragraph (2) shall reimburse the American Institute in Taiwan, or the appropriate United States Government agency, in an amount equal to the difference between—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id903a39f2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/e/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount specified in subparagraph (B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id903a39f3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/e/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the product of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id903a39f4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/e/4/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount the fellow received in compensation during the final year of the fellowship, including the value of any allowances and benefits received by the fellow; multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id903a39f5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/e/4/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage of the period specified in paragraph (2)(C) during which the fellow did not remain employed by the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id903a39f6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Flexible fellowship duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any requirement under this section, the Secretary of State, in consultation with the American Institute in Taiwan and, as appropriate, the implementing partner, may award fellowships that have a duration of less than 2 years, and may alter the curriculum requirements under subsection (d) for such purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id903a39f7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3384/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sunset","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The fellowship program under this subchapter shall terminate 7 years after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id903a39f8-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLV/s5530"},"text":"Pub. L. 117–263, div. E, title LV, § 5530","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3326"},"text":"136 Stat. 3326","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id903a39f9-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id903a39fa-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id903a39fb-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (d)(2), was in the original “this subtitle”, meaning subtitle A (§§ 5501–5540) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLV"},"text":"Pub. L. 117–263, div. E, title LV","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3292"},"text":"136 Stat. 3292","children":[],"tail":", known as the Taiwan Enhanced Resilience Act, which is classified principally to this chapter. For complete classification of subtitle A to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3351"},"text":"section 3351 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
