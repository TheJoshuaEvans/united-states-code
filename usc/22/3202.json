{"tag":"section","attrib":{"id":"id902e53a0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3202"},"text":null,"children":[{"tag":"num","attrib":{"value":"3202"},"text":"§ 3202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional statement of purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is the purpose of this chapter to promote the policies set forth above by—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id902e53a1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3202/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing a more effective framework for international cooperation to meet the energy needs of all nations and to ensure that the worldwide development of peaceful nuclear activities and the export by any nation of nuclear materials and equipment and nuclear technology intended for use in peaceful nuclear activities do not contribute to proliferation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id902e53a2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3202/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorizing the United States to take such actions as are required to ensure that it will act reliably in meeting its commitment to supply nuclear reactors and fuel to nations which adhere to effective non-proliferation policies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id902e53a3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3202/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing incentives to the other nations of the world to join in such international cooperative efforts and to ratify the Treaty; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id902e53a4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3202/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring effective controls by the United States over its exports of nuclear materials and equipment and of nuclear technology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id902e53a5-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/242/s3"},"text":"Pub. L. 95–242, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-03-10"},"text":"Mar. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/120"},"text":"92 Stat. 120","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id902e53a6-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id902e53a7-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id902e53a8-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/242"},"text":"Pub. L. 95–242","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-03-10"},"text":"Mar. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/120"},"text":"92 Stat. 120","children":[],"tail":", known as the Nuclear Non-Proliferation Act of 1978. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3201"},"text":"section 3201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id902e53a9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id902e53aa-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1978-03-10"},"text":"Mar. 10, 1978","children":[],"tail":", except as otherwise provided and regardless of any requirements for the promulgation of implementing regulations, see "},{"tag":"ref","attrib":{"href":"/us/pl/95/242/s603/c"},"text":"section 603(c) of Pub. L. 95–242","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3201"},"text":"section 3201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
