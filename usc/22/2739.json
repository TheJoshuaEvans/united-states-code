{"tag":"section","attrib":{"id":"id9005e3eb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2739"},"text":null,"children":[{"tag":"num","attrib":{"value":"2739"},"text":"§ 2739.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil service rotational program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9005e3ec-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2739/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of pilot rotational program for civil service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2023-12-22"},"text":"December 22, 2023","children":[],"tail":", the Secretary shall establish a program to provide qualified civil servants serving at the Department an opportunity to serve at a United States embassy, including identifying criteria and an application process for such program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9005e3ed-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2739/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program established under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9005e3ee-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2739/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide at least 20 career civil servants the opportunity to serve for 2 to 3 years at a United States embassy to gain additional skills and experience;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9005e3ef-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2739/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offer such civil servants the opportunity to serve in a political or economic section at a United States embassy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9005e3f0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2739/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include clear and transparent criteria for eligibility and selection, which shall include a minimum of 5 years of service at the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9005e3f1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2739/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent position and promotion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Following a rotation at a United States embassy pursuant to the program established by this section, participants in the program must be afforded, at minimum, a position equivalent in seniority, compensation, and responsibility to the position occupied prior serving in the program. Successful completion of a rotation at a United States embassy shall be considered favorably with regard to applications for promotion in civil service jobs at the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9005e3f2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2739/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2023-12-22"},"text":"December 22, 2023","children":[],"tail":", the Secretary shall identify not less than 20 positions in United States embassies for the program established under this section and offer at least 20 civil servants the opportunity to serve in a rotation at a United States embassy pursuant to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9005e3f3-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dF/tLXII/s6208"},"text":"Pub. L. 118–31, div. F, title LXII, § 6208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/975"},"text":"137 Stat. 975","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9005e3f4-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9005e3f5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id9005e3f6-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “Secretary” and “Department” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s6002"},"text":"section 6002 of Pub. L. 118–31","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
