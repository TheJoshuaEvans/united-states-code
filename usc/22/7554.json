{"tag":"section","attrib":{"id":"id90e128b6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7554"},"text":null,"children":[{"tag":"num","attrib":{"value":"7554"},"text":"§ 7554.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90e128b7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7554/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall submit reports to the Committees on Foreign Relations and Appropriations of the Senate, and the Committees on International Relations and Appropriations of the House of Representatives on progress made in accomplishing the “Purposes of Assistance” set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7512"},"text":"section 7512 of this title","children":[],"tail":" utilizing assistance provided by the United States for Afghanistan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90e128b8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7554/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline for submission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The first report shall be submitted no later than ","children":[{"tag":"date","attrib":{"date":"2003-12-31"},"text":"December 31, 2003","children":[],"tail":", and subsequent reports shall be submitted in conjunction with reports required under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7553"},"text":"section 7553 of this title","children":[],"tail":" and thereafter through "},{"tag":"date","attrib":{"date":"2004-12-31"},"text":"December 31, 2004","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90e128b9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7554/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any report or other matter that is required to be submitted to Congress (including a committee of Congress) by this chapter may contain a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90e128ba-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/327/tIII/s304"},"text":"Pub. L. 107–327, title III, § 304","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/106/tII/s2215/c"},"text":"Pub. L. 108–106, title II, § 2215(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-06"},"text":"Nov. 6, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1233"},"text":"117 Stat. 1233","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tVII/s7104/e/3"},"text":"Pub. L. 108–458, title VII, § 7104(e)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3782"},"text":"118 Stat. 3782","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90e128bb-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90e128bc-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90e128bd-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":" designated existing provisions as subsecs. (a) and (b), inserted subsec. headings, and added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90e128be-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id90e128bf-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on International Relations of House of Representatives changed to Committee on Foreign Affairs of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
