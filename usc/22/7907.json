{"tag":"section","attrib":{"id":"id90f1f257-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7907"},"text":null,"children":[{"tag":"num","attrib":{"value":"7907"},"text":"§ 7907.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fellowship and exchange programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of State, in coordination with the Secretary of Energy, the Secretary of Commerce, and the Administrator of the Environmental Protection Agency, shall carry out fellowship and exchange programs under which officials from developing countries visit the United States to acquire expertise and knowledge of best practices to reduce greenhouse gas intensity in their countries.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id90f1f258-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/240/tVII/s737"},"text":"Pub. L. 101–240, title VII, § 737","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXVI/s1611"},"text":"Pub. L. 109–58, title XVI, § 1611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1117"},"text":"119 Stat. 1117","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90f1f259-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90f1f25a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id90f1f25b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2005-10-01"},"text":"Oct. 1, 2005","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/240/s739"},"text":"section 739 of Pub. L. 101–240","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7901"},"text":"section 7901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
