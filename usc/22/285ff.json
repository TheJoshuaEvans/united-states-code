{"tag":"section","attrib":{"id":"id8ebf3309-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285ff"},"text":null,"children":[{"tag":"num","attrib":{"value":"285ff"},"text":"§ 285ff.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tenth replenishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ebf330a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285ff/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Governor of the Bank is authorized to contribute, on behalf of the United States, $359,600,000 to the tenth replenishment of the resources of the Fund, subject to obtaining the necessary appropriations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ebf330b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285ff/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to pay for the United States contribution provided for in subsection (a), there are authorized to be appropriated, without fiscal year limitation, $359,600,000 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ebf330c-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/369/s35"},"text":"Pub. L. 89–369, § 35","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dJ/tVII/s7083/a"},"text":"Pub. L. 113–235, div. J, title VII, § 7083(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2684"},"text":"128 Stat. 2684","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
