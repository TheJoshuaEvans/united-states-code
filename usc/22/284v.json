{"tag":"section","attrib":{"id":"id8ebcc21f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284v"},"text":null,"children":[{"tag":"num","attrib":{"value":"284v"},"text":"§ 284v.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fifteenth replenishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ebcc220-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284v/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Governor of the International Development Association is authorized to contribute on behalf of the United States $3,705,000,000 to the fifteenth replenishment of the resources of the Association, subject to obtaining the necessary appropriations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ebcc221-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284v/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to pay for the United States contribution provided for in subsection (a), there are authorized to be appropriated, without fiscal year limitation, $3,705,000,000 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ebcc222-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/565/s24"},"text":"Pub. L. 86–565, § 24","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/32/tXI/s1109/a"},"text":"Pub. L. 111–32, title XI, § 1109(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-06-24"},"text":"June 24, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1901"},"text":"123 Stat. 1901","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
