{"tag":"section","attrib":{"id":"id9056ea71-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4012a"},"text":null,"children":[{"tag":"num","attrib":{"value":"4012a"},"text":"§ 4012a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign national employees separation pay","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9056ea72-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4012a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury of the United States a fund to provide separation pay for foreign national employees of agencies of the United States Government, other than the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9056ea73-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4012a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There shall be deposited in such account—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9056ea74-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4012a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all amounts previously obligated for accrued separation pay of foreign national employees of such agencies of the United States Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9056ea75-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4012a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts obligated for fiscal years after 1991 by such agencies for the current and future costs of separation pay of foreign national employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9056ea76-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4012a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts shall be deposited in the fund annually and are authorized to be available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9056ea77-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4012a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures from fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts deposited in the fund shall be available for expenditure to make separation payments to foreign national employees in countries in which such pay is legally authorized.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9056ea78-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/138/tI/s151"},"text":"Pub. L. 102–138, title I, § 151","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/672"},"text":"105 Stat. 672","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9056ea79-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9056ea7a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id9056ea7b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Foreign Relations Authorization Act, Fiscal Years 1992 and 1993, and not as part of the Foreign Service Act of 1980 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
