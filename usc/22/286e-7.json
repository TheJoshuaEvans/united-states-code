{"tag":"section","attrib":{"id":"id8ec3edd0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286e–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"286e–7"},"text":"§ 286e–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplementary Financing Facility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ec3edd1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286e–7/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of resources","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of participation of the United States in the Supplementary Financing Facility (hereinafter referred to as the “facility”) established by the decision numbered 5508–(77/127) of the Executive Directors of the Fund, the Secretary of the Treasury is authorized to make resources available as provided in the decision numbered 5509–(77/127) of the Fund, in an amount not to exceed the equivalent of 1,450 million Special Drawing Rights.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ec3edd2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286e–7/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustments in the value of monetary assets","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall account, through the fund established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s5302"},"text":"section 5302 of title 31","children":[],"tail":", for any adjustment in the value of monetary assets held by the United States in respect of United States participation in the facility."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ec3edd3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286e–7/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this section, the authority of the Secretary to enter into agreements making resources available under this section shall be limited to such amounts as are appropriated in advance in appropriation Acts. Effective ","children":[{"tag":"date","attrib":{"date":"1978-10-01"},"text":"October 1, 1978","children":[],"tail":", there are hereby authorized to be appropriated to the Secretary of the Treasury, without fiscal year limitation, such sums as are necessary to carry out subsection (a) of this section, but not to exceed an amount of dollars equivalent to 1,450 million Special Drawing Rights."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ec3edd4-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-07-31/ch339/s28"},"text":"July 31, 1945, ch. 339, § 28","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/435/s1"},"text":"Pub. L. 95–435, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-10"},"text":"Oct. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1051"},"text":"92 Stat. 1051","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ec3edd5-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ec3edd6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8ec3edd7-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (b), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s5302"},"text":"section 5302 of title 31","children":[],"tail":"” substituted for “section 10 of the Gold Reserve Act of 1934, as amended ("},{"tag":"ref","attrib":{"href":"/us/usc/t31/s822a"},"text":"31 U.S.C. 822a","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s4/b"},"text":"Pub. L. 97–258, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1067"},"text":"96 Stat. 1067","children":[],"tail":", the first section of which enacted Title 31, Money and Finance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
