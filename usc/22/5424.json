{"tag":"section","attrib":{"id":"id908db1b7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5424"},"text":null,"children":[{"tag":"num","attrib":{"value":"5424"},"text":"§ 5424.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peace Corps programs in Poland and Hungary","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out programs in Poland and Hungary under the Peace Corps Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2501"},"text":"22 U.S.C. 2501","children":[],"tail":" et seq.], $6,000,000 for the 3-year period beginning "},{"tag":"date","attrib":{"date":"1989-10-01"},"text":"October 1, 1989","children":[],"tail":", in addition to amounts otherwise available for such purposes. Such programs shall include the use of Peace Corps volunteers—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id908db1b8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5424/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide English language training, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908db1b9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5424/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to extend the technical skills described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s5423/a"},"text":"section 5423(a) of this title","children":[],"tail":" to the people of Poland and Hungary, using the Associate Volunteer Program to the extent practicable."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id908db1ba-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/179/tII/s204"},"text":"Pub. L. 101–179, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-28"},"text":"Nov. 28, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1310"},"text":"103 Stat. 1310","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id908db1bb-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id908db1bc-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id908db1bd-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Peace Corps Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/293"},"text":"Pub. L. 87–293","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-22"},"text":"Sept. 22, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/612"},"text":"75 Stat. 612","children":[],"tail":", which is classified principally to chapter 34 (§ 2501 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2501"},"text":"section 2501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
