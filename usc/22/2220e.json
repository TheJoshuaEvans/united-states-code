{"tag":"section","attrib":{"id":"id8f6d268b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2220e"},"text":null,"children":[{"tag":"num","attrib":{"value":"2220e"},"text":"§ 2220e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presidential report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President shall transmit to the Congress, not later than September 1 of each year, a report detailing the activities carried out pursuant to this subpart during the preceding fiscal year and containing a projection of programs and activities to be conducted during the subsequent five fiscal years. Each report shall contain a summary of the activities of the Board established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2220c"},"text":"section 2220c of this title","children":[],"tail":" and may include the separate views of the Board with respect to any aspect of the programs conducted or proposed to be conducted under this subpart."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f6d268c-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. I, § 300, as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/161/tIII/s312"},"text":"Pub. L. 94–161, title III, § 312","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-20"},"text":"Dec. 20, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/866"},"text":"89 Stat. 866","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/373/s5"},"text":"Pub. L. 106–373, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-27"},"text":"Oct. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1433"},"text":"114 Stat. 1433","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f6d268d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f6d268e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f6d268f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/373"},"text":"Pub. L. 106–373","children":[],"tail":" substituted “September 1” for “April 1”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f6d2690-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8f6d2691-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of provisions of law requiring submittal to Congress of any annual, semiannual, or other regular periodic report listed in House Document No. 103–7 (in which a report required under this section is listed on page 25), see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id8f6d2692-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id8f6d2693-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions of President under this section, see Ex. Ord. No. 12163, ","children":[{"tag":"date","attrib":{"date":"1979-09-29"},"text":"Sept. 29, 1979","children":[],"tail":", 44 F.R. 56673, as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2381"},"text":"section 2381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
