{"tag":"section","attrib":{"id":"id8fa8cf5a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2378c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2378c"},"text":"§ 2378c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on assistance for the West Bank and Gaza","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fa8cf5b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2378c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Assistance may be provided under this chapter to nongovernmental organizations for the West Bank and Gaza only during a period for which a certification described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2378b/b"},"text":"section 2378b(b) of this title","children":[],"tail":" is in effect with respect to the Palestinian Authority."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fa8cf5c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2378c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply with respect to the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fa8cf5d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2378c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to meet basic human needs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Assistance to meet food, water, medicine, health, or sanitation needs, or other assistance to meet basic human needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fa8cf5e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2378c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to promote democracy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Assistance to promote democracy, human rights, freedom of the press, non-violence, reconciliation, and peaceful coexistence, provided that such assistance does not directly benefit Hamas or any other foreign terrorist organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fa8cf5f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2378c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance for individual members of the Palestinian Legislative Council","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Assistance, other than funding of salaries or salary supplements, to individual members of the Palestinian Legislative Council who the President determines are not members of Hamas or any other foreign terrorist organization, for the purposes of facilitating the attendance of such members in programs for the development of institutions of democratic governance, including enhancing the transparent and accountable operations of such institutions, and providing support for the Middle East peace process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fa8cf60-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2378c/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other types of assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any other type of assistance if the President—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fa8cf61-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2378c/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determines that the provision of such assistance is in the national security interest of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fa8cf62-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2378c/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not less than 30 days prior to the obligation of amounts for the provision of such assistance—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id8fa8cf63-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2378c/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consults with the appropriate congressional committees regarding the specific programs, projects, and activities to be carried out using such assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8fa8cf64-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2378c/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submits to the appropriate congressional committees a written memorandum that contains the determination of the President under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fa8cf65-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2378c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marking requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Assistance provided under this chapter to nongovernmental organizations for the West Bank and Gaza shall be marked as assistance from the American people or the United States Government unless the Secretary of State or, as appropriate, the Administrator of the United States Agency for International Development, determines that such marking will endanger the lives or safety of persons delivering such assistance or would have an adverse effect on the implementation of that assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fa8cf66-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2378c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Assistance made available under this chapter to nongovernmental organizations for the West Bank and Gaza may not be provided until 15 days after the date on which the President has provided notice thereof to the Committee on International Relations and the Committee on Appropriations of the House of Representatives and to the Committee on Foreign Relations and the Committee on Appropriations of the Senate in accordance with the procedures applicable to reprogramming notifications under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2394–1/a"},"text":"section 2394–1(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fa8cf67-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2378c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fa8cf68-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2378c/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"the ","children":[{"tag":"ref","attrib":{"idref":"fn002147"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002147"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":" term “appropriate congressional committees” means—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fa8cf69-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2378c/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on International Relations and the Committee on Appropriations of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fa8cf6a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2378c/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations and the Committee on Appropriations of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fa8cf6b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2378c/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign terrorist organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “foreign terrorist organization” means an organization designated as a foreign terrorist organization by the Secretary of State in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1189/a"},"text":"section 1189(a) of title 8","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fa8cf6c-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. III, § 620L, as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/446/s3/a"},"text":"Pub. L. 109–446, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-21"},"text":"Dec. 21, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3320"},"text":"120 Stat. 3320","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fa8cf6d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8fa8cf6e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8fa8cf6f-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a), (c), and (d), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/424"},"text":"75 Stat. 424","children":[],"tail":", known as the Foreign Assistance Act of 1961. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8fa8cf70-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id8fa8cf71-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on International Relations of House of Representatives changed to Committee on Foreign Affairs of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id8fa8cf72-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id8fa8cf73-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of President under subsec. (b)(4)(B) of this section delegated to Secretary of State by Determination of President of the United States, No. 2007–20, ","children":[{"tag":"date","attrib":{"date":"2007-06-01"},"text":"June 1, 2007","children":[],"tail":", 72 F.R. 34973, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2378b"},"text":"section 2378b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
