{"tag":"section","attrib":{"id":"id907d0fde-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4703"},"text":null,"children":[{"tag":"num","attrib":{"value":"4703"},"text":"§ 4703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scholarship program authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id907d0fdf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4703/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President, acting through the United States Information Agency, shall provide scholarships (including partial assistance) for undergraduate study at United States institutions of higher education by citizens and nationals of developing countries who have completed their secondary education and who would not otherwise have an opportunity to study in the United States due to financial limitations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id907d0fe0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4703/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of scholarship; forgiveness of loan repayment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To encourage students to use their training in their countries of origin, each scholarship pursuant to this section shall be in the form of a loan with all repayment to be forgiven upon the student’s prompt return to his or her country of origin for a period which is at least one year longer than the period spent studying in the United States. If the student is granted asylum in the United States pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1158"},"text":"section 1158 of title 8","children":[],"tail":" or is admitted to the United States as a refugee pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1157"},"text":"section 1157 of title 8","children":[],"tail":", half of the repayment shall be forgiven."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id907d0fe1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4703/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before allocating any of the funds made available to carry out this chapter, the President shall consult with United States institutions of higher education, educational exchange organizations, United States missions in developing countries, and the governments of participating countries on how to implement the guidelines specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4704"},"text":"section 4704 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id907d0fe2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4703/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Institution of higher education” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this chapter, the term “institution of higher education” has the same meaning as given to such term by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id907d0fe3-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/93/tVI/s603"},"text":"Pub. L. 99–93, title VI, § 603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-16"},"text":"Aug. 16, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/440"},"text":"99 Stat. 440","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tI/s102/a/7/D"},"text":"Pub. L. 105–244, title I, § 102(a)(7)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1619"},"text":"112 Stat. 1619","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id907d0fe4-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id907d0fe5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id907d0fe6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" substituted “section 1001” for “section 1141(a)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id907d0fe7-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id907d0fe8-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id907d0fe9-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"United States Information Agency (other than Broadcasting Board of Governors and International Broadcasting Bureau) abolished and functions transferred to Secretary of State, see sections 6531 and 6532 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
