rolled by a financial institution described in subparagraph (A), (B), or (C), regardless of location.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911f42bc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9202/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" North Korean person","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “North Korean person” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911f42bd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9202/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a North Korean citizen or national; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911f42be-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9202/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity owned or controlled by the Government of North Korea or by a North Korean citizen or national.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911f42bf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9202/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Significant activities undermining cybersecurity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “significant activities undermining cybersecurity” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911f42c0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9202/14/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" significant efforts to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id911f42c1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9202/14/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deny access to or degrade, disrupt, or destroy an information and communications technology system or network; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id911f42c2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9202/14/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exfiltrate information from such a system or network without authorization;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911f42c3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9202/14/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significant destructive malware attacks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911f42c4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9202/14/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significant denial of service activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911f42c5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9202/14/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other significant activities described in regulations promulgated to implement ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9214"},"text":"section 9214 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911f42c6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9202/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" South Korea","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “South Korea” means the Republic of Korea.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911f42c7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9202/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States person","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “United States person” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911f42c8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9202/16/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a United States citizen or an alien lawfully admitted for permanent residence to the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911f42c9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9202/16/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity organized under the laws of the United States or of any jurisdiction within the United States, including a foreign branch of such an entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id911f42ca-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/122/s3"},"text":"Pub. L. 114–122, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-18"},"text":"Feb. 18, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/95"},"text":"130 Stat. 95","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/44/tIII/s302/a"},"text":"Pub. L. 115–44, title III, § 302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-02"},"text":"Aug. 2, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/940"},"text":"131 Stat. 940","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dF/tLXXI/s7122/b/1"},"text":"Pub. L. 116–92, div. F, title LXXI, § 7122(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2248"},"text":"133 Stat. 2248","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id911f42cb-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id911f42cc-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id911f42cd-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/122"},"text":"Pub. L. 114–122","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-18"},"text":"Feb. 18, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/93"},"text":"130 Stat. 93","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s9201"},"text":"section 9201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subchapter I or II, referred to in par. (4), was in the original “title I or II”, meaning titles I and II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/122"},"text":"Pub. L. 114–122","children":[],"tail":". Title I is classified principally to subchapter I of this chapter. Title II is classified generally to subchapter II of this chapter. For complete classification of titles I and II of "},{"tag":"ref","attrib":{"href":"/us/pl/114/122"},"text":"Pub. L. 114–122","children":[],"tail":" to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id911f42ce-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" substituted “(a), (b), or (g)” for “(a) or (b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Par. (1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/44/s302/a/1"},"text":"Pub. L. 115–44, § 302(a)(1)","children":[],"tail":", substituted “Executive Order No. 13694” for “or Executive Order 13694” and inserted “or Executive Order No. 13722 ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":" note; relating to blocking the property of the Government of North Korea and the Workers’ Party of Korea, and Prohibiting Certain Transactions With Respect to North Korea),” before “to the extent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/44/s302/a/2"},"text":"Pub. L. 115–44, § 302(a)(2)","children":[],"tail":", substituted “2094 (2013), 2270 (2016), or 2321 (2016)” for “or 2094 (2013)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (5) to (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/44/s302/a/3/A"},"text":"Pub. L. 115–44, § 302(a)(3)(A)","children":[],"tail":", added par. (5) and redesignated former pars. (5) to (8) as (6) to (9), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (9)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/44/s302/a/4"},"text":"Pub. L. 115–44, § 302(a)(4)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (10) to (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/44/s302/a/3/A"},"text":"Pub. L. 115–44, § 302(a)(3)(A)","children":[],"tail":", redesignated pars. (9) to (11) as (10) to (12), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/44/s302/a/5/B"},"text":"Pub. L. 115–44, § 302(a)(5)(B)","children":[],"tail":", added par. (13). Former par. (13) redesignated (14)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/44/s302/a/3/A"},"text":"Pub. L. 115–44, § 302(a)(3)(A)","children":[],"tail":", redesignated par. (12) as (13). Former par. (13) redesignated (14)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/44/s302/a/5/A"},"text":"Pub. L. 115–44, § 302(a)(5)(A)","children":[],"tail":", redesignated par. (13) as (14). Former par. (14) redesignated (15)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/44/s302/a/3/A"},"text":"Pub. L. 115–44, § 302(a)(3)(A)","children":[],"tail":", redesignated par. (13) as (14). Former par. (14) redesignated (15)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (15). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/44/s302/a/5/A"},"text":"Pub. L. 115–44, § 302(a)(5)(A)","children":[],"tail":", redesignated par. (14) as (15). Former par. (15) redesignated (16)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/44/s302/a/3/A"},"text":"Pub. L. 115–44, § 302(a)(3)(A)","children":[],"tail":", redesignated par. (14) as (15)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (16). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/44/s302/a/5/A"},"text":"Pub. L. 115–44, § 302(a)(5)(A)","children":[],"tail":", redesignated par. (15) as (16)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id911f42cf-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id911f42d0-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulatory Authority","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/44/tIII/s333"},"text":"Pub. L. 115–44, title III, § 333","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-02"},"text":"Aug. 2, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/955"},"text":"131 Stat. 955","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/44/tIII/s333"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President shall, not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2017-08-02"},"text":"Aug. 2, 2017","children":[],"tail":"], promulgate regulations as necessary for the implementation of this title [see Short Title of 2017 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s9201"},"text":"section 9201 of this title","children":[],"tail":"] and the amendments made by this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not fewer than 10 days before the promulgation of a regulation under subsection (a), the President shall notify and provide to the appropriate congressional committees [see Definitions note below] the proposed regulation, specifying the provisions of this title or the amendments made by this title that the regulation is implementing.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id911f42d1-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/44/tIII/s332"},"text":"Pub. L. 115–44, title III, § 332","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-02"},"text":"Aug. 2, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/954"},"text":"131 Stat. 954","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/44/tIII/s332"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Nothing in this title [see Short Title of 2017 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9201"},"text":"section 9201 of this title","children":[],"tail":"] shall be construed to limit—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authority or obligation of the President to apply the sanctions described in section 104 of the North Korea Sanctions and Policy Enhancement Act of 2016 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9214"},"text":"22 U.S.C. 9214","children":[],"tail":"), as amended by section 311 of this Act, with regard to persons who meet the criteria for designation under such section, or in any other provision of law; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authorities of the President pursuant to the International Emergency Economic Powers Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":" et seq.).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id911f42d2-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authority To Consolidate Reports","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/44/tIII/s331"},"text":"Pub. L. 115–44, title III, § 331","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-02"},"text":"Aug. 2, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/954"},"text":"131 Stat. 954","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/44/tIII/s331"},"text":"“Any reports required to be submitted to the appropriate congressional committees [see Definitions note below] under this title [see Short Title of 2017 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9201"},"text":"section 9201 of this title","children":[],"tail":"] or any amendment made by this title that are subject to deadlines for submission consisting of similar units of time may be consolidated into a single report that is submitted to appropriate congressional committees pursuant to the earlier of such deadlines. The consolidated reports must contain all information required under this title or any amendment made by this title, in addition to all other elements mandated by previous law.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id911f42d3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/44/tIII/s302/b"},"text":"Pub. L. 115–44, title III, § 302(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-02"},"text":"Aug. 2, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/941"},"text":"131 Stat. 941","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/44/tIII/s302/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In this title [see Short Title of 2017 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9201"},"text":"section 9201 of this title","children":[],"tail":"]:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicable united nations security council resolution; luxury goods","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The terms ‘applicable United Nations Security Council resolution’ and ‘luxury goods’ have the meanings given those terms, respectively, in section 3 of the North Korea Sanctions and Policy Enhancement Act of 2016 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9202"},"text":"22 U.S.C. 9202","children":[],"tail":"), as amended by subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriate congressional committees; government of north korea; united states person","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The terms ‘appropriate congressional committees’, ‘Government of North Korea’, and ‘United States person’ have the meanings given those terms, respectively, in section 3 of the North Korea Sanctions and Policy Enhancement Act of 2016 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9202"},"text":"22 U.S.C. 9202","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Foreign person; north korean person","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The terms ‘foreign person’ and ‘North Korean person’ have the meanings given those terms, respectively, in paragraph (5) and paragraph (13) of section 3 of the North Korea Sanctions and Policy Enhancement Act of 2016 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9202/5"},"text":"22 U.S.C. 9202(5)","children":[],"tail":" and 9202(13)), as added by subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibited weapons program","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘prohibited weapons program’ means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any program related to the development of nuclear, chemical, or biological weapons, and their means of delivery, including ballistic missiles; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any program to develop related materials with respect to a program described in subparagraph (A).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
