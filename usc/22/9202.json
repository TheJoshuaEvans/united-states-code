ragraph","attrib":{"id":"id911f42af-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9202/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Humanitarian assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “humanitarian assistance” means assistance to meet humanitarian needs, including needs for food, medicine, medical supplies, clothing, and shelter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911f42b0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9202/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intelligence community","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “intelligence community” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003/4"},"text":"section 3003(4) of title 50","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911f42b1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9202/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Luxury goods","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “luxury goods”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911f42b2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9202/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the meaning given such term in section 746.4(b)(1) of title 15, Code of Federal Regulations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911f42b3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9202/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes the items listed in Supplement No. 1 to part 746 of such title, and any similar items; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911f42b4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9202/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" also includes any items so designated under an applicable United Nations Security Council resolution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911f42b5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9202/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monetary instruments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “monetary instruments” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s5312/a"},"text":"section 5312(a) of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911f42b6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9202/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" North Korea","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “North Korea” means the Democratic People’s Republic of Korea.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911f42b7-2930-11f1-8918-be39dde81dc6","id