{"tag":"section","attrib":{"id":"id902998fa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2804"},"text":null,"children":[{"tag":"num","attrib":{"value":"2804"},"text":"§ 2804.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of standards and criteria; publication in the Federal Register","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id902998fb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2804/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Commerce is hereby authorized and directed to establish and maintain standards, definitions, and criteria which are adequate to carry out the purposes of section 2802(a)(1) and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2803/a"},"text":"section 2803(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id902998fc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2804/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Standards, definitions, and criteria established by the Secretary and such revisions in them as he may make from time to time shall be published in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id902998fd-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/269/s4"},"text":"Pub. L. 91–269, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-05-27"},"text":"May 27, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/272"},"text":"84 Stat. 272","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
