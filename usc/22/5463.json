{"tag":"section","attrib":{"id":"id908db241-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5463"},"text":null,"children":[{"tag":"num","attrib":{"value":"5463"},"text":"§ 5463.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Encouraging voluntary assistance for Poland and Hungary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id908db242-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5463/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Encouraging private contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of the Congress that the President should take all possible steps to encourage across the Nation a massive outpouring of private contributions of money and nonperishable foods, to be collected by civic, religious, school, and youth organizations, for assistance to Poland and to refugees from Romania who are in Hungary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id908db243-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5463/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation to Poland of private contributions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In further ","children":[{"tag":"ref","attrib":{"idref":"fn002315"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002315"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “furtherance”."}],"tail":" of subsection (a), the President—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id908db244-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5463/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using all available authorities, including ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s402"},"text":"section 402 of title 10","children":[],"tail":" (relating to transportation of humanitarian relief supplies), should use resources of the Department of Defense (including the National Guard) to transport nonfinancial private contributions to Poland,"},{"tag":"ref","attrib":{"idref":"fn002316"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002316"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. The comma probably should be a semicolon."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908db245-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5463/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" should request additional authorities as needed for the use of those resources for that purpose; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908db246-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5463/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" should encourage maximum participation by such recognized private and voluntary organizations as the Polish-American Congress in the transportation of nonfinancial private contributions to Poland.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id908db247-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/179/tVI/s603"},"text":"Pub. L. 101–179, title VI, § 603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-28"},"text":"Nov. 28, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1319"},"text":"103 Stat. 1319","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
