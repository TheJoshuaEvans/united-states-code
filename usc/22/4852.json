{"tag":"section","attrib":{"id":"id90843b73-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4852"},"text":null,"children":[{"tag":"num","attrib":{"value":"4852"},"text":"§ 4852.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Diplomatic construction program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90843b74-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4852/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference for United States contractors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s302"},"text":"section 302 of this title","children":[],"tail":", and where adequate competition exists, only United States persons and qualified United States joint venture persons may be awarded—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90843b75-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4852/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a diplomatic construction or design project which has an estimated total project value exceeding $25,000,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90843b76-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4852/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a diplomatic construction or design project which involves technical security, unless the project involves low-level technology, as determined by the Secretary of State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90843b77-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4852/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not apply with respect to any diplomatic construction or design project in a foreign country whose statutes prohibit the use of United States contractors on such projects. The exception contained in this subsection shall only become effective with respect to a foreign country 30 days after the Secretary of State certifies to the Committee on Foreign Affairs and the Committee on Appropriations of the House of Representatives and the Committee on Foreign Relations and the Committee on Appropriations of the Senate what specific actions he has taken to urge such foreign country to permit the use of United States contractors on such projects, and what actions he shall take with respect to that country as authorized by title II of the State Department Basic Authorities Act of 1956 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4301"},"text":"22 U.S.C. 4301","children":[],"tail":" et seq.; commonly referred to as the “Foreign Missions Act”)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90843b78-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4852/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90843b79-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4852/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “adequate competition” means with respect to a construction or design project, the presence of three or more qualified bidders submitting responsive bids for that project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90843b7a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4852/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “United States person” means a person which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90843b7b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4852/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is incorporated or legally organized under the laws of the United States, including State, the District of Columbia, and local laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90843b7c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4852/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has its principal place of business in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90843b7d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4852/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has been incorporated or legally organized in the United States—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90843b7e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4852/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for more than 5 years before the issuance date of the invitation for bids or request for proposals with respect to a construction project under subsection (a)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90843b7f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4852/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for more than 2 years before the issuance date of the invitation for bids or request for proposals with respect to a construction or design project which involves physical or technical security under subsection (a)(2);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90843b80-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4852/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has performed within the United States or on a Federal contract abroad administrative and technical, professional, or construction services similar in complexity, type of construction, and value to the project being bid;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90843b81-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4852/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90843b82-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4852/c/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employs United States citizens in at least 65 percent of its principal management positions in the United States,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90843b83-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4852/c/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employs United States citizens in more than half of its permanent, full-time positions in the United States, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90843b84-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4852/c/2/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will employ United States citizens in at least 65 percent of the supervisory positions on the foreign buildings office project site; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90843b85-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4852/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “qualified United States joint venture person” means a joint venture in which a United States person or persons owns at least 51 percent of the assets of the joint venture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90843b86-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4852/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" American minority contractors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 10 percent of the amount appropriated pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4851/a"},"text":"section 4851(a) of this title","children":[],"tail":" for diplomatic construction or design projects each fiscal year shall be allocated to the extent practicable for contracts with American minority contractors."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90843b87-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4852/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" American small business contractors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 10 percent of the amount appropriated pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4851/a"},"text":"section 4851(a) of this title","children":[],"tail":" for diplomatic construction or design projects each fiscal year shall be allocated to the extent practicable for contracts with American small business contractors."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90843b88-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4852/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on subcontracting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to a diplomatic construction project, a prime contractor may not subcontract more than 50 percent of the total value of its contract for that project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90843b89-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/399/tIV/s402"},"text":"Pub. L. 99–399, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/864"},"text":"100 Stat. 864","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/246/tI/s132"},"text":"Pub. L. 101–246, title I, § 132","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-02-16"},"text":"Feb. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/32"},"text":"104 Stat. 32","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/138/tI/s131"},"text":"Pub. L. 102–138, title I, § 131","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/662"},"text":"105 Stat. 662","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s162/g/10"},"text":"Pub. L. 103–236, title I, § 162(g)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/407"},"text":"108 Stat. 407","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/228/dA/tII/s206/b"},"text":"Pub. L. 107–228, div. A, title II, § 206(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"Sept. 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1364"},"text":"116 Stat. 1364","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dE/tLII/s5208"},"text":"Pub. L. 117–81, div. E, title LII, § 5208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2357"},"text":"135 Stat. 2357","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dG/tLXXII/s7214"},"text":"Pub. L. 118–159, div. G, title LXXII, § 7214","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2536"},"text":"138 Stat. 2536","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90843b8a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90843b8b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90843b8c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Title II of the State Department Basic Authorities Act of 1956, referred to in subsec. (b), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch841"},"text":"act Aug. 1, 1956, ch. 841","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1982-08-24"},"text":"Aug. 24, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/97/241/tII/s202/b"},"text":"Pub. L. 97–241, title II, § 202(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/283"},"text":"96 Stat. 283","children":[],"tail":", known as the Foreign Missions Act, which is classified principally to chapter 53 (§ 4301 et seq.) of this title. For complete classification of title II to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4301"},"text":"section 4301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90843b8d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s7214/1"},"text":"Pub. L. 118–159, § 7214(1)","children":[],"tail":", inserted “be awarded” after “joint venture persons may” in introductory provisions, struck out “bid on” at beginning of pars. (1) and (2), and substituted “$25,000,000” for “$10,000,000” in par. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s7214/2/A"},"text":"Pub. L. 118–159, § 7214(2)(A)","children":[],"tail":", substituted “three” for “two”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s7214/2/B/i"},"text":"Pub. L. 118–159, § 7214(2)(B)(i)","children":[],"tail":", substituted “on a Federal contract abroad” for “at a United States diplomatic or consular establishment abroad”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(E), (F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s7214/2/B/ii"},"text":"Pub. L. 118–159, § 7214(2)(B)(ii)","children":[],"tail":"–(iv), redesignated subpar. (F) as (E), substituted “65” for “80” in cls. (i) and (iii), and struck out former subpar. (E) which read as follows: “with respect to a construction project under subsection (a)(1), has achieved total business volume equal to or greater than the value of the project being bid cumulatively over 3 years of the 5-year period before the date specified in subparagraph (C)(i);”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s7214/2/B/ii"},"text":"Pub. L. 118–159, § 7214(2)(B)(ii)","children":[],"tail":", struck out subpar. (G) which read as follows: “has the existing technical and financial resources in the United States to perform the contract; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (c)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" substituted “cumulatively over 3 years” for “in 3 years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (c)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/228"},"text":"Pub. L. 107–228","children":[],"tail":" inserted “or at a United States diplomatic or consular establishment abroad” after “United States”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":" substituted “Secretary of State” for “Assistant Secretary for Diplomatic Security”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/138/s131/1"},"text":"Pub. L. 102–138, § 131(1)","children":[],"tail":", substituted “$10,000,000” for “$5,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/138/s131/2"},"text":"Pub. L. 102–138, § 131(2)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “bid on a diplomatic construction or design project which involves physical or technical security, unless the project—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) involves nonsophisticated, low-level technology, as determined by the Assistant Secretary for Diplomatic Security;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) is for the design or construction of a facility that does not process or store classified material; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) does not exceed a total value of $500,000.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/246"},"text":"Pub. L. 101–246","children":[],"tail":" amended par. (2) generally. Prior to amendment, par. (2) read as follows: “bid on a diplomatic construction or design project which involves physical or technical security.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90843b8e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id90843b8f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":" applicable with respect to officials, offices, and bureaus of Department of State when executive orders, regulations, or departmental directives implementing the amendments by sections 161 and 162 of "},{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":" become effective, or 90 days after "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", whichever comes earlier, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/s161/b"},"text":"section 161(b) of Pub. L. 103–236","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651a"},"text":"section 2651a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id90843b90-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of United States Embassy in Ottawa","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/246/tI/s125"},"text":"Pub. L. 101–246, title I, § 125","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-02-16"},"text":"Feb. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/27"},"text":"104 Stat. 27","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/246/tI/s125"},"text":"“Section 402(a) of the Diplomatic Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4852/a"},"text":"22 U.S.C. 4852(a)","children":[],"tail":") shall not apply to the construction or renovation of the United States Embassy in Ottawa, Canada.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
