{"tag":"section","attrib":{"id":"id8ebcc231-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284z"},"text":null,"children":[{"tag":"num","attrib":{"value":"284z"},"text":"§ 284z.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Seventeenth replenishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ebcc232-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284z/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Governor of the International Development Association is authorized to contribute on behalf of the United States $3,871,800,000 to the seventeenth replenishment of the resources of the Association, subject to obtaining the necessary appropriations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ebcc233-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284z/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to pay for the United States contribution provided for in subsection (a), there are authorized to be appropriated, without fiscal year limitation, $3,871,800,000 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ebcc234-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/565/s28"},"text":"Pub. L. 86–565, § 28","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dJ/tVII/s7083/b"},"text":"Pub. L. 113–235, div. J, title VII, § 7083(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2684"},"text":"128 Stat. 2684","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
