{"tag":"section","attrib":{"id":"id90bfbe7d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6593"},"text":null,"children":[{"tag":"num","attrib":{"value":"6593"},"text":"§ 6593.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance programs coordination and oversight","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90bfbe7e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6593/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary of State","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90bfbe7f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6593/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under the direction of the President, the Secretary of State shall coordinate all United States assistance in accordance with this section, except as provided in paragraphs (2) and (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bfbe80-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6593/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Export promotion activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Coordination of activities relating to promotion of exports of United States goods and services shall continue to be primarily the responsibility of the Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bfbe81-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6593/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International economic activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Coordination of activities relating to United States participation in international financial institutions and relating to organization of multilateral efforts aimed at currency stabilization, currency convertibility, debt reduction, and comprehensive economic reform programs shall continue to be primarily the responsibility of the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bfbe82-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6593/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorities and powers of the Secretary of State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The powers and authorities of the Secretary provided in this part are in addition to the powers and authorities provided to the Secretary under any other Act, including section 101(b) and section 622(c) of the Foreign Assistance Act of 1961 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151/b"},"text":"22 U.S.C. 2151(b)","children":[],"tail":", 2382(c))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90bfbe83-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6593/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Coordination activities of the Secretary of State under subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90bfbe84-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6593/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approving an overall assistance and economic cooperation strategy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bfbe85-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6593/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring program and policy coordination among agencies of the United States Government in carrying out the policies set forth in the Foreign Assistance Act of 1961 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"22 U.S.C. 2151","children":[],"tail":" et seq.], the Arms Export Control Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2751"},"text":"22 U.S.C. 2751","children":[],"tail":" et seq.], and other relevant assistance Acts;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bfbe86-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6593/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursuing coordination with other countries and international organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bfbe87-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6593/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resolving policy, program, and funding disputes among United States Government agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90bfbe88-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6593/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statutory construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section may be construed to lessen the accountability of any Federal agency administering any program, project, or activity of United States assistance for any funds made available to the Federal agency for that purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90bfbe89-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6593/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to provide personnel of Agency for International Development","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the Agency for International Development is authorized to detail to the Department of State on a nonreimbursable basis such personnel employed by the Agency as the Secretary of State may require to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90bfbe8a-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. A, title XV, § 1523, "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-794"},"text":"112 Stat. 2681–794","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90bfbe8b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90bfbe8c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90bfbe8d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Foreign Assistance Act of 1961, referred to in subsec. (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/424"},"text":"75 Stat. 424","children":[],"tail":", which is classified principally to chapter 32 (§ 2151 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Arms Export Control Act, referred to in subsec. (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/629"},"text":"Pub. L. 90–629","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1320"},"text":"82 Stat. 1320","children":[],"tail":", which is classified principally to chapter 39 (§ 2751 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2751"},"text":"section 2751 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
