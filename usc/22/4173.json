{"tag":"section","attrib":{"id":"id90712998-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4173"},"text":null,"children":[{"tag":"num","attrib":{"value":"4173"},"text":"§ 4173.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional oversight of implementation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90712999-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4173/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":", (b) Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/204/tI/s185/c/2"},"text":"Pub. L. 100–204, title I, § 185(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1366"},"text":"101 Stat. 1366","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9071299a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4173/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with agency representatives","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall consult, in accordance with the procedures set out in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4113/g"},"text":"section 4113(g) of this title","children":[],"tail":", with the exclusive representative (if any) of members of the Foreign Service in each agency specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4103/a"},"text":"section 4103(a) of this title","children":[],"tail":" with respect to steps to be taken in implementing this chapter and reported under section 4001(c)(4) "},{"tag":"ref","attrib":{"idref":"fn002297"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002297"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title. To that end, each such exclusive representative will have timely access to all relevant information at each stage. Each such report shall include the views of each such exclusive representative on any and all aspects of the report and the information contained in such report."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9071299b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tII/s2402"},"text":"Pub. L. 96–465, title II, § 2402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2168"},"text":"94 Stat. 2168","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/204/tI/s185/c/2"},"text":"Pub. L. 100–204, title I, § 185(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1366"},"text":"101 Stat. 1366","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9071299c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9071299d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9071299e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4001/c/4"},"text":"Section 4001(c)(4) of this title","children":[],"tail":", referred to in subsec. (c), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/114/323/tVII/s715/b/5"},"text":"Pub. L. 114–323, title VII, § 715(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1946"},"text":"130 Stat. 1946","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9071299f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1987—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/204"},"text":"Pub. L. 100–204","children":[],"tail":" struck out subsec. (a) which related to report by Secretary of State and its contents and subsec. (b) which related to annual supplemental report and its contents."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/204"},"text":"Pub. L. 100–204","children":[],"tail":" substituted “under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4001/c/4"},"text":"section 4001(c)(4) of this title","children":[],"tail":"” for “under this section”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
