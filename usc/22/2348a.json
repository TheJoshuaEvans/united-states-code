{"tag":"section","attrib":{"id":"id8f95bc68-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2348a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2348a"},"text":"§ 2348a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f95bc69-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2348a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal years 1986 and 1987","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the President to carry out the purposes of this part, in addition to amounts otherwise available for such purposes, $37,000,000 for fiscal year 1986 and $37,000,000 for fiscal year 1987.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f95bc6a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2348a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts appropriated under this section are authorized to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f95bc6b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2348a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency transfer of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the President determines that, as the result of an unforeseen emergency, the provision of assistance under this part in amounts in excess of funds otherwise available for such assistance is important to the national interests of the United States, the President may (1) exercise the authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2360/a"},"text":"section 2360(a) of this title","children":[],"tail":" to transfer funds available to carry out part IV of this subchapter for use under this part without regard to the 20-percent increase limitation contained in such section, except that the total amount so transferred in any fiscal year may not exceed $15,000,000; and (2) in the event the President also determines that such unforeseen emergency requires the immediate provision of assistance under this part, direct the drawdown of commodities and services from the inventory and resources of any agency of the United States Government of an aggregate value not to exceed $25,000,000 in any fiscal year. In addition to the aggregate value of $25,000,000 authorized in paragraph (2) of the preceding sentence, the President may direct the drawdown of commodities and services from the inventory and resources of any agency of the United States Government for the purposes of providing necessary and immediate assistance to Taiwan of a value not to exceed $25,000,000 in any fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f95bc6c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2348a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement of applicable appropriation, fund, or account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the President such sums as may be necessary to reimburse the applicable appropriation, fund, or account for commodities and services provided under subsection (c)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f95bc6d-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. II, § 552, as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/384/s12/a"},"text":"Pub. L. 95–384, § 12(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-09-26"},"text":"Sept. 26, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/736"},"text":"92 Stat. 736","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/92/s10/a"},"text":"Pub. L. 96–92, § 10(a)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1979-10-29"},"text":"Oct. 29, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/705"},"text":"93 Stat. 705","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/533/tI/s116/a"},"text":"Pub. L. 96–533, title I, § 116(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-16"},"text":"Dec. 16, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3140"},"text":"94 Stat. 3140","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/113/tI/s114"},"text":"Pub. L. 97–113, title I, § 114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1528"},"text":"95 Stat. 1528","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/83/tI/s105/a"},"text":"Pub. L. 99–83, title I, § 105(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"1985-08-08"},"text":"Aug. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/195"},"text":"99 Stat. 195","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLV/s5505/b"},"text":"Pub. L. 117–263, div. E, title LV, § 5505(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3299"},"text":"136 Stat. 3299","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f95bc6e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f95bc6f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f95bc70-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" inserted at end “In addition to the aggregate value of $25,000,000 authorized in paragraph (2) of the preceding sentence, the President may direct the drawdown of commodities and services from the inventory and resources of any agency of the United States Government for the purposes of providing necessary and immediate assistance to Taiwan of a value not to exceed $25,000,000 in any fiscal year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/83/s105/a"},"text":"Pub. L. 99–83, § 105(a)","children":[],"tail":", amended subsec. (a) generally, substituting provisions authorizing appropriations of $37,000,000 for fiscal years 1986 and 1987, for provisions authorizing appropriations of $19,000,000 for fiscal years 1982 and 1983."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/83/s105/b/1/A"},"text":"Pub. L. 99–83, § 105(b)(1)(A)","children":[],"tail":", (B), designated existing provisions as cl. (1) and added cl. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/83/s105/b/1/C"},"text":"Pub. L. 99–83, § 105(b)(1)(C)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/113/s114/a"},"text":"Pub. L. 97–113, § 114(a)","children":[],"tail":", substituted “$19,000,000 for the fiscal year 1982 and $19,000,000 for the fiscal year 1983” for “$25,000,000 for the fiscal year 1981”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/113/s114/b"},"text":"Pub. L. 97–113, § 114(b)","children":[],"tail":", increased to $15,000,000 from $10,000,000 amount of funds authorized to be transferred in any fiscal year and deleted restriction on transfer of earmarked funds."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/533"},"text":"Pub. L. 96–533","children":[],"tail":" substituted “$25,000,000 for the fiscal year 1981” for “$21,100,000 for the fiscal year 1980”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/92/s10/a"},"text":"Pub. L. 96–92, § 10(a)","children":[],"tail":", substituted “$21,100,000 for the fiscal year 1980” for “$30,900,000 for the fiscal year 1979”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/92/s10/c"},"text":"Pub. L. 96–92, § 10(c)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f95bc71-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8f95bc72-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/83"},"text":"Pub. L. 99–83","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1985-10-01"},"text":"Oct. 1, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/83/s1301"},"text":"section 1301 of Pub. L. 99–83","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151–1"},"text":"section 2151–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id8f95bc73-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id8f95bc74-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions of President under this section, see Ex. Ord. No. 12163, ","children":[{"tag":"date","attrib":{"date":"1979-09-29"},"text":"Sept. 29, 1979","children":[],"tail":", 44 F.R. 56673, as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2381"},"text":"section 2381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
