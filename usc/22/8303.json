{"tag":"section","attrib":{"id":"id90f91e10-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8303"},"text":null,"children":[{"tag":"num","attrib":{"value":"8303"},"text":"§ 8303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Volunteers for Prosperity","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90f91e11-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The VfP Office shall pursue the objectives of the VfP Program described in subsection (b) by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90f91e12-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8303/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementing the VfPServe Program to provide eligible skilled professionals with matching grants to offset the travel and living expenses of volunteering abroad with nonprofit organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f91e13-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8303/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise promoting short- and long-term international volunteer service by skilled American professionals, including connecting such professionals with nonprofit organizations, to achieve such objectives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f91e14-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8303/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" helping nonprofit organizations in the United States recruit and effectively manage additional skilled American professionals for volunteer assignments throughout the developing world;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f91e15-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8303/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing recognition for skilled American volunteers and the organizations deploying them;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f91e16-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8303/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" helping nonprofit organizations and corporations in the United States to identify resources and opportunities in international volunteer service utilizing skilled Americans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f91e17-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8303/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging the establishment of international volunteer programs for employees of United States corporations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f91e18-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8303/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging international voluntary service by highly skilled Americans to promote health and prosperity throughout the world.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90f91e19-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" VfP Program objectives","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The objectives of the VfP Program should include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90f91e1a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8303/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eliminating extreme poverty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f91e1b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8303/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing world hunger and malnutrition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f91e1c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8303/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing access to safe potable water;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f91e1d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8303/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enacting universal education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f91e1e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8303/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing child mortality and childhood diseases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f91e1f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8303/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" combating the spread of preventable diseases, including HIV, malaria, and tuberculosis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f91e20-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8303/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing educational and work skill support for girls and empowering women to achieve independence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f91e21-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8303/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creating sustainable business and entrepreneurial opportunities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f91e22-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8303/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing access to information technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90f91e23-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Volunteers for Prosperity Service Incentive Program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90f91e24-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8303/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The VfP Office may provide matching grants to offset the travel and living costs of volunteering abroad to any eligible organization that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90f91e25-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8303/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has members who possess skills relevant to addressing any objective described in subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90f91e26-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8303/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provides a dollar-for-dollar match for such grant—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90f91e27-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8303/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through the organization with which the individual is serving; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90f91e28-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8303/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by raising private funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f91e29-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8303/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondiscrimination requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The VfP Office may not provide a stipend to an individual under paragraph (1) unless the nonprofit organization to which the individual is assigned has certified to the VfP Office that it does not discriminate with respect to any project or activity receiving Federal financial assistance, including a stipend under this chapter, because of race, religion, color, national origin, sex, political affiliation, or beliefs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f91e2a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8303/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with ineligible service categories","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Service carried out by a volunteer receiving funds under this section may not provide a direct benefit to any—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90f91e2b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8303/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" business organized for profit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90f91e2c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8303/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" labor union;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90f91e2d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8303/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" partisan political organization; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90f91e2e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8303/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" religious or faith-based organization for the purpose of proselytization, worship or any other explicitly religious activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90f91e2f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8303/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90f91e30-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8303/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the United States Agency for International Development shall make available the amounts appropriated pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8304"},"text":"section 8304 of this title","children":[],"tail":" to the VfP Office to pursue the objectives described in subsection (b) by carrying out the functions described in subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f91e31-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8303/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts made available under paragraph (1) may be used by the VfP Office to provide personnel and other resources to develop, manage, and expand the VfP Program, under the supervision of the United States Agency for International Development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90f91e32-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8303/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The VfP Office shall coordinate its efforts with other public and private efforts that aim to send skilled professionals to serve in developing nations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90f91e33-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8303/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The VfP Office shall submit an annual report to Congress on the activities of the VfP Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90f91e34-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/tV/s5103"},"text":"Pub. L. 111–13, title V, § 5103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1598"},"text":"123 Stat. 1598","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90f91e35-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90f91e36-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id90f91e37-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/s6101/a"},"text":"section 6101(a) of Pub. L. 111–13","children":[],"tail":", set out as an Effective Date of 2009 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
