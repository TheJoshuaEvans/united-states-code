{"tag":"section","attrib":{"id":"id9102938c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514a"},"text":null,"children":[{"tag":"num","attrib":{"value":"8514a"},"text":"§ 8514a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of sanctions with respect to the transfer of goods or technologies to Iran that are likely to be used to commit human rights abuses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9102938d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall impose sanctions in accordance with subsection (c) with respect to each person on the list required by subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9102938e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" List","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9102938f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2012-08-10"},"text":"August 10, 2012","children":[],"tail":", the President shall submit to the appropriate congressional committees a list of persons that the President determines have knowingly engaged in an activity described in paragraph (2) on or after "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"August 10, 2012","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91029390-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activity described","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91029391-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person engages in an activity described in this paragraph if the person—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id91029392-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514a/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfers, or facilitates the transfer of, goods or technologies described in subparagraph (C) to Iran, any entity organized under the laws of Iran or otherwise subject to the jurisdiction of the Government of Iran, or any national of Iran, for use in or with respect to Iran; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91029393-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514a/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides services (including services relating to hardware, software, and specialized information, and professional consulting, engineering, and support services) with respect to goods or technologies described in subparagraph (C) after such goods or technologies are transferred to Iran.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91029394-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability to contracts and other agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person engages in an activity described in subparagraph (A) without regard to whether the activity is carried out pursuant to a contract or other agreement entered into before, on, or after ","children":[{"tag":"date","attrib":{"date":"2012-08-10"},"text":"August 10, 2012","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91029395-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514a/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goods or technologies described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Goods or technologies described in this subparagraph are goods or technologies that the President determines are likely to be used by the Government of Iran or any of its agencies or instrumentalities (or by any other person on behalf of the Government of Iran or any of such agencies or instrumentalities) to commit serious human rights abuses against the people of Iran, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id91029396-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514a/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" firearms or ammunition (as those terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s921"},"text":"section 921 of title 18","children":[],"tail":"), rubber bullets, police batons, pepper or chemical sprays, stun grenades, electroshock weapons, tear gas, water cannons, or surveillance technology; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91029397-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514a/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sensitive technology (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8515/c"},"text":"section 8515(c) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91029398-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule to allow for termination of sanctionable activity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall not be required to include a person on the list required by paragraph (1) if the President certifies in writing to the appropriate congressional committees that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91029399-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514a/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person is no longer engaging in, or has taken significant verifiable steps toward stopping, the activity described in paragraph (2) for which the President would otherwise have included the person on the list; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9102939a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514a/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President has received reliable assurances that the person will not knowingly engage in any activity described in paragraph (2) in the future.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9102939b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates of list","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall submit to the appropriate congressional committees an updated list under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9102939c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514a/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each time the President is required to submit an updated list to those committees under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8514/b/2/A"},"text":"section 8514(b)(2)(A) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9102939d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514a/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as new information becomes available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9102939e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of report; public availability","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9102939f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514a/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The list required by paragraph (1) shall be submitted in unclassified form but may contain a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910293a0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514a/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The unclassified portion of the list required by paragraph (1) shall be made available to the public and posted on the websites of the Department of the Treasury and the Department of State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id910293a1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of sanctions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id910293a2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), the President shall impose sanctions described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8514/c"},"text":"section 8514(c) of this title","children":[],"tail":" with respect to a person on the list required by subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910293a3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers to Iran’s Revolutionary Guard Corps","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a person on the list required by subsection (b) for transferring, or facilitating the transfer of, goods or technologies described in subsection (b)(2)(C) to Iran’s Revolutionary Guard Corps, or providing services with respect to such goods or technologies after such goods or technologies are transferred to Iran’s Revolutionary Guard Corps, the President shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id910293a4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impose sanctions described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8514/c"},"text":"section 8514(c) of this title","children":[],"tail":" with respect to the person; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910293a5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impose such other sanctions from among the sanctions described in section 6(a) of the Iran Sanctions Act of 1996 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/172"},"text":"Public Law 104–172","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":" note) as the President determines appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id910293a6-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/195/tI/s105A"},"text":"Pub. L. 111–195, title I, § 105A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/158/tIV/s402/a"},"text":"Pub. L. 112–158, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1252"},"text":"126 Stat. 1252","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
