{"tag":"section","attrib":{"id":"id8ffeb872-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2721"},"text":null,"children":[{"tag":"num","attrib":{"value":"2721"},"text":"§ 2721.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Impermissible basis for denial of passports","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A passport may not be denied issuance, revoked, restricted, or otherwise limited because of any speech, activity, belief, affiliation, or membership, within or outside the United States, which, if held or conducted within the United States, would be protected by the first amendment to the Constitution of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ffeb873-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch841"},"text":"Aug. 1, 1956, ch. 841","children":[],"tail":", title I, § 49, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/138/tI/s113"},"text":"Pub. L. 102–138, title I, § 113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/655"},"text":"105 Stat. 655","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
