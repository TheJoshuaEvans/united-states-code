{"tag":"section","attrib":{"id":"id90272740-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2799"},"text":null,"children":[{"tag":"num","attrib":{"value":"2799"},"text":"§ 2799.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purpose of this subchapter is to authorize the President to support, consistent with the CFE Treaty, a NATO equipment transfer program that will—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90272741-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2799/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance NATO’s forces,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90272742-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2799/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase NATO standardization and interoperability, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90272743-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2799/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" better distribute defense burdens within the NATO alliance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90272744-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/629"},"text":"Pub. L. 90–629","children":[],"tail":", ch. 9, § 91, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/228/s2"},"text":"Pub. L. 102–228, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-12"},"text":"Dec. 12, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1691"},"text":"1