{"tag":"section","attrib":{"id":"id90dedeb1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7431"},"text":null,"children":[{"tag":"num","attrib":{"value":"7431"},"text":"§ 7431.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondelegation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The authorities vested in the President by sections 7422 and 7430(a) of this title may not be delegated by the President pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of title 3","children":[],"tail":" or any other provision of law. The authority vested in the President by "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7424/c/3"},"text":"section 7424(c)(3) of this title","children":[],"tail":" may not be delegated by the President pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of title 3","children":[],"tail":" or any other provision of law to any official other than the Secretary of Defense, and if so delegated may not be subdelegated."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id90dedeb2-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/206/tII/s2012"},"text":"Pub. L. 107–206, title II, § 2012","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-02"},"text":"Aug. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/907"},"text":"116 Stat. 907","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
