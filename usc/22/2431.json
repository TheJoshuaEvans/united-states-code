{"tag":"section","attrib":{"id":"id8fbe53b8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431"},"text":null,"children":[{"tag":"num","attrib":{"value":"2431"},"text":"§ 2431.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fbe53b9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fbe53ba-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It is the established policy of the United States to support and seek protection of tropical forests and coral reef ecosystems around the world.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe53bb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Tropical forests provide a wide range of benefits to humankind by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fbe53bc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" harboring a major share of the Earth’s biological and terrestrial resources, which are the basis for developing pharmaceutical products and revitalizing agricultural crops;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fbe53bd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" playing a critical role as carbon sinks in reducing greenhouse gases in the atmosphere, thus moderating potential global climate change; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fbe53be-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulating hydrological cycles on which agricultural and coastal resources depend.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe53bf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" International negotiations and assistance programs to conserve forest resources have proliferated over the past decade, but the rapid rate of tropical deforestation continues unabated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe53c0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Developing countries with urgent needs for investment and capital for development have allocated a significant amount of their forests to logging concessions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe53c1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Poverty and economic pressures on the populations of developing countries have, over time, resulted in clearing of vast areas of forest for conversion to agriculture, which is often unsustainable in the poor soils underlying tropical forests.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe53c2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Debt reduction can reduce economic pressures on developing countries and result in increased protection for tropical forests and coral reef ecosystems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe53c3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Finding economic benefits to local communities from sustainable uses of tropical forests and coral reef ecosystems is critical to the protection of such areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fbe53c4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this subchapter are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fbe53c5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to recognize the values received by United States citizens from protection of tropical forests and coral reef ecosystems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe53c6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate greater protection of tropical forests and coral ecosystems (and to give priority to protecting areas with the highest levels of biodiversity and under the most severe threat) by providing for the alleviation of debt in countries where tropical forests and coral reef ecosystems are located, thus allowing the use of additional resources to protect these critical resources and reduce economic pressures that have led to deforestation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe53c7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that resources freed from debt in such countries are targeted to protection of tropical forests and coral reef ecosystems and their associated values; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe53c8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to rechannel existing resources to facilitate the protection of tropical forests and coral reef ecosystems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fbe53c9-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. V, § 802, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/214/s1"},"text":"Pub. L. 105–214, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-29"},"text":"July 29, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/885"},"text":"112 Stat. 885","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/440/s3/a"},"text":"Pub. L. 115–440, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-14"},"text":"Jan. 14, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5580"},"text":"132 Stat. 5580","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fbe53ca-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8fbe53cb-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id8fbe53cc-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2431, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. V, § 801, as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/189/s24"},"text":"Pub. L. 93–189, § 24","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-17"},"text":"Dec. 17, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/728"},"text":"87 Stat. 728","children":[],"tail":", authorized the President to furnish assistance for relief and reconstruction of South Vietnam, Cambodia, and Laos, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/94/329/tIV/s413/a"},"text":"Pub. L. 94–329, title IV, § 413(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-06-30"},"text":"June 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/761"},"text":"90 Stat. 761","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195/s802"},"text":"section 802 of Pub. L. 87–195","children":[],"tail":", pt. V, was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2432"},"text":"section 2432 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/94/329"},"text":"Pub. L. 94–329","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8fbe53cd-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/440/s3/a/1"},"text":"Pub. L. 115–440, § 3(a)(1)","children":[],"tail":", substituted “tropical forests and coral reef ecosystems” for “tropical forests”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/440/s3/a/2"},"text":"Pub. L. 115–440, § 3(a)(2)","children":[],"tail":", struck out “far-flung” before “agricultural”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/440/s3/a/1"},"text":"Pub. L. 115–440, § 3(a)(1)","children":[],"tail":", substituted “tropical forests and coral reef ecosystems” for “tropical forests”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/440/s3/a/3"},"text":"Pub. L. 115–440, § 3(a)(3)","children":[],"tail":", substituted “tropical forests and coral reef ecosystems is critical to the protection of such areas” for “tropical forests is critical to the protection of tropical forests”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/440/s3/a/1"},"text":"Pub. L. 115–440, § 3(a)(1)","children":[],"tail":", substituted “tropical forests and coral reef ecosystems” for “tropical forests”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/440/s3/a/4"},"text":"Pub. L. 115–440, § 3(a)(4)","children":[],"tail":", substituted “protection of tropical forests and coral ecosystems” for “protection of tropical forests”, “protecting areas” for “protecting tropical forests”, and “where tropical forests and coral reef ecosystems” for “‘where tropical forests”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/440/s3/a/1"},"text":"Pub. L. 115–440, § 3(a)(1)","children":[],"tail":", substituted “tropical forests and coral reef ecosystems” for “tropical forests”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8fbe53ce-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id8fbe53cf-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For short title of this subchapter as the “Tropical Forest and Coral Reef Conservation Act of 1998”, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195/s801"},"text":"section 801 of Pub. L. 87–195","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
