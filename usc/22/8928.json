{"tag":"section","attrib":{"id":"id911a617a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8928"},"text":null,"children":[{"tag":"num","attrib":{"value":"8928"},"text":"§ 8928.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support for Russian democracy and civil society organizations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id911a617b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8928/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State shall, directly or through nongovernmental or international organizations, such as the Organization for Security and Co-operation in Europe, the National Endowment for Democracy, and related organizations—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id911a617c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8928/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve democratic governance, transparency, accountability, rule of law, and anti-corruption efforts in the Russian Federation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a617d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8928/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthen democratic institutions and political and civil society organizations in the Russian Federation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a617e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8928/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expand uncensored Internet access in the Russian Federation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a617f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8928/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expand free and unfettered access to independent media of all kinds in the Russian Federation, including through increasing United States Government-supported broadcasting activities, and assist with the protection of journalists and civil society activists who have been targeted for free speech activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id911a6180-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8928/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary of State $20,000,000 for each of fiscal years 2016 through 2018 to carry out the activities set forth in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id911a6181-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8928/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategy requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"2014-12-18"},"text":"December 18, 2014","children":[],"tail":", the President shall submit a strategy to carry out the activities set forth in subsection (a) to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id911a6182-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8928/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations and the Committee on Appropriations of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a6183-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8928/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs and the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id911a6184-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8928/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transparency requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any assistance provided pursuant to this section shall be conducted in as transparent of a manner as possible, consistent with the nature and goals of this section. The President shall provide a briefing on the activities funded by this section at the request of the committees specified in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id911a6185-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/272/s9"},"text":"Pub. L. 113–272, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2964"},"text":"128 Stat. 2964","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id911a6186-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id911a6187-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id911a6188-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of President under subsec. (c) of this section delegated to Secretary of State by Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2015-02-19"},"text":"Feb. 19, 2015","children":[],"tail":", 80 F.R. 12071, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s8925"},"text":"section 8925 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
