{"tag":"section","attrib":{"id":"id90e128a2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7551"},"text":null,"children":[{"tag":"num","attrib":{"value":"7551"},"text":"§ 7551.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement to comply with procedures relating to the prohibition on assistance to drug traffickers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Assistance provided under this chapter shall be subject to the same provisions as are applicable to assistance under the Foreign Assistance Act of 1961 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"22 U.S.C. 2151","children":[],"tail":" et seq.] and the Arms Export Control Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2751"},"text":"22 U.S.C. 2751","children":[],"tail":" et seq.] under section 487 of the Foreign Assistance Act of 1961 (relating to the prohibition on assistance to drug traffickers; "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2291f"},"text":"22 U.S.C. 2291f","children":[],"tail":"), and the applicable regulations issued under that section."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id90e128a3-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/327/tIII/s301"},"text":"Pub. L. 107–327, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-04"},"text":"Dec. 4, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2812"},"text":"116 Stat. 2812","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90e128a4-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90e128a5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children"