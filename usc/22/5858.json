{"tag":"section","attrib":{"id":"id90a0c40a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5858"},"text":null,"children":[{"tag":"num","attrib":{"value":"5858"},"text":"§ 5858.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice and reports to Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90a0c40b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5858/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of proposed obligations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not less than 15 days before obligating any funds under section 5853 or 5854 of this title or the amendments made by section 506(a),","children":[{"tag":"ref","attrib":{"idref":"fn002325"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002325"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" the President shall transmit to the Speaker of the House of Representatives, the President Pro Tempore of the Senate, and the appropriate congressional committees a report on the proposed obligation. Each such report shall specify—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90a0c40c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5858/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the account, budget activity, and particular program or programs from which the funds proposed to be obligated are to be derived and the amount of the proposed obligations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a0c40d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5858/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the activities and forms of assistance for which the President plans to obligate such funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90a0c40e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5858/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Semiannual report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1993-04-30"},"text":"April 30, 1993","children":[],"tail":", and not later than "},{"tag":"date","attrib":{"date":"1993-10-30"},"text":"October 30, 1993","children":[],"tail":", the President shall transmit to the Speaker of the House of Representatives, the President Pro Tempore of the Senate, and the appropriate congressional committees a report on the activities carried out under sections 5853 and 5854 of this title and the amendments made by section 506(a)."},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" Each such report shall set forth, for the preceding 6-month period and cumulatively, the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90a0c40f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5858/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amounts expended for such activities and the purposes for which they were expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a0c410-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5858/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The source of the funds obligated for such activities, specified by program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a0c411-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5858/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the participation of all United States Government departments and agencies in such activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a0c412-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5858/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the activities carried out and the forms of assistance provided.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a0c413-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5858/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other information as the President considers appropriate to fully inform the Congress concerning the operation of the programs and activities carried out under sections 5853 and 5854 of this title and the amendments made by section 506(a).","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90a0c414-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5858/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90a0c415-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5858/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90a0c416-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5858/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations of the Senate, the Committee on Foreign Affairs of the House of Representatives, and the Committees on Appropriations of the House and the Senate, wherever the account, budget activity, or program is funded from appropriations made under the international affairs budget function (150);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90a0c417-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5858/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committees on Armed Services and the Committees on Appropriations of the Senate and the House of Representatives, wherever the account, budget activity, or program is funded from appropriations made under the national defense budget function (050); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a0c418-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5858/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the committee to which the specified activities of section 5853(a) or 5854(a) of this title or subtitle B ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of the Soviet Nuclear Threat Reduction Act of 1991 (as the case may be), if the subject of separate legislation, would be referred, under the rules of the respective House of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id