{"tag":"section","attrib":{"id":"id8efd262e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1432"},"text":null,"children":[{"tag":"num","attrib":{"value":"1432"},"text":"§ 1432.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information on United States participation in United Nations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In carrying out the objectives of this chapter, information concerning the participation of the United States in the United Nations, its organizations and functions, shall be emphasized.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8efd262f-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-01-27/ch36"},"text":"Jan. 27, 1948, ch. 36","children":[],"tail":", title I, § 3, "},{"tag":"ref","attrib":{"href":"/us/stat/62/6"},"text":"62 Stat. 6","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
