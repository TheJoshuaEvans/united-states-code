{"tag":"section","attrib":{"id":"id8fd3b0f3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2568"},"text":null,"children":[{"tag":"num","attrib":{"value":"2568"},"text":"§ 2568.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program for visiting scholars","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A program for visiting scholars in the fields of arms control, nonproliferation, and disarmament shall be established by the Secretary of State in order to obtain the services of scholars from the faculties of recognized institutions of higher learning. The purpose of the program will be to give specialists in the physical sciences and other disciplines relevant to the Department of State’s activities an opportunity for active participation in the arms control, nonproliferation, and disarmament activities of the Department of State and to gain for the Department of State the perspective and expertise such persons can offer. Each fellow in the program shall be appointed for a term of one year, except that such term may be extended for a 1-year period.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8fd3b0f4-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/297/tII/s202"},"text":"Pub. L. 87–297, title II, § 202","children":[],"tail":", formerly § 28, as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/202/s3"},"text":"Pub. L. 98–202, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-12-02"},"text":"Dec. 2, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1381"},"text":"97 Stat. 1381","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tVII/s719/b"},"text":"Pub. L. 103–236, title VII, § 719(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/501"},"text":"108 Stat. 501","children":[],"tail":"; renumbered § 202 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. A, title XII, § 1223(5), (21), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-769"},"text":"112 Stat. 2681–769","children":[],"tail":", 2681–772.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fd3b0f5-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8fd3b0f6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8fd3b0f7-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1223/5"},"text":"Pub. L. 105–277, § 1223(5)","children":[],"tail":", substituted “Secretary of State” for “Director” and “Department of State’s” for “Agency’s”, substituted “Department of State” for “Agency” in two places, and struck out at end “Fellows shall be chosen by a board consisting of the Director, who shall be the chairperson, and all former Directors of the Agency.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":" substituted “fields of arms control, nonproliferation, and disarmament” for “field of arms control and disarmament” in first sentence and inserted “, nonproliferation,” after “participation in the arms control” in second sentence."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8fd3b0f8-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8fd3b0f9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1999-04-01"},"text":"Apr. 1, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1201"},"text":"section 1201 of Pub. L. 105–277","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6511"},"text":"section 6511 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
