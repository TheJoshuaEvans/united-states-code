{"tag":"section","attrib":{"id":"id90a5a646-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6002"},"text":null,"children":[{"tag":"num","attrib":{"value":"6002"},"text":"§ 6002.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of policy","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It should be the policy of the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90a5a647-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6002/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to seek a peaceful transition to democracy and a resumption of economic growth in Cuba through the careful application of sanctions directed at the Castro government and support for the Cuban people;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a5a648-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6002/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to seek the cooperation of other democratic countries in this policy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a5a649-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6002/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make clear to other countries that, in determining its relations with them, the United States will take into account their willingness to cooperate in such a policy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a5a64a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6002/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to seek the speedy termination of any remaining military or technical assistance, subsidies, or other forms of assistance to the Government of Cuba from any of the independent states of the former Soviet Union;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a5a64b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6002/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to continue vigorously to oppose the human rights violations of the Castro regime;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a5a64c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6002/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain sanctions on the Castro regime so long as it continues to refuse to move toward democratization and greater respect for human rights;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a5a64d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6002/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be prepared to reduce the sanctions in carefully calibrated ways in response to positive developments in Cuba;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a5a64e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6002/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage free and fair elections to determine Cuba’s political future;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a5a64f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6002/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to request the speedy termination of any military or technical assistance, subsidies, or other forms of assistance to the Government of Cuba from the government of any other country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a5a650-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6002/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to initiate immediately the development of a comprehensive United States policy toward Cuba in a post-Castro era.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90a5a651-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tXVII/s1703"},"text":"Pub. L. 102–484, div. A, title XVII, § 1703","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2576"},"text":"106 Stat. 2576","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
