{"tag":"section","attrib":{"id":"id8ff51b1c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2684a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2684a"},"text":"§ 2684a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capital Investment Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ff51b1d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2684a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Department of State a Capital Investment Fund to provide for the procurement and enhancement of information technology and other related capital investments for the Department of State and to ensure the efficient management, coordination, operation, and utilization of such resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff51b1e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2684a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds otherwise available for the purposes of subsection (a) may be deposited in such Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff51b1f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2684a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts deposited into the Fund shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff51b20-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2684a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures from Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts deposited in the Fund shall be available for purposes of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff51b21-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2684a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reprogramming procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds credited to the Capital Investment Fund shall not be available for obligation or expenditure except in compliance with the procedures applicable to reprogramming notifications under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2706"},"text":"section 2706 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ff51b22-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s135"},"text":"Pub. L. 103–236, title I, § 135","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/396"},"text":"108 Stat. 396","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. B, title XXII, § 2209, "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-811"},"text":"112 Stat. 2681–811","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ff51b23-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ff51b24-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8ff51b25-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s2209/1"},"text":"Pub. L. 105–277, § 2209(1)","children":[],"tail":", inserted “and enhancement” after “procurement”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s2209/2"},"text":"Pub. L. 105–277, § 2209(2)","children":[],"tail":", substituted “shall” for “are authorized to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s2209/3"},"text":"Pub. L. 105–277, § 2209(3)","children":[],"tail":", substituted “for purposes of subsection (a)” for “for expenditure to procure capital equipment and information technology”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s2209/4"},"text":"Pub. L. 105–277, § 2209(4)","children":[],"tail":", reenacted heading without change and amended text generally. Prior to amendment, text read as follows: “Funds credited to the Capital Investment Fund shall be treated as a reprogramming of funds under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2706"},"text":"section 2706 of this title","children":[],"tail":" and shall not be available for obligation or expenditure except in compliance with the procedures applicable to such reprogrammings.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
