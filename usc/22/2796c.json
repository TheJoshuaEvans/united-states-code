{"tag":"section","attrib":{"id":"id9024dd7c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2796c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2796c"},"text":"§ 2796c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of other statutory provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any reference to sales of defense articles under this chapter in any provision of law restricting the countries or organizations to which such sales may be made shall be deemed to include a reference to leases of defense articles under this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id9024dd7d-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/629"},"text":"Pub. L. 90–629","children":[],"tail":", ch. 6, § 64, as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/113/tI/s109/a"},"text":"Pub. L. 97–113, title I, § 109(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1526"},"text":"95 Stat. 1526","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9024dd7e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9024dd7f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9024dd80-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":