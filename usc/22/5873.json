{"tag":"section","attrib":{"id":"id90a0c479-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5873"},"text":null,"children":[{"tag":"num","attrib":{"value":"5873"},"text":"§ 5873.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Within one year after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", the President shall submit to the designated congressional committees a report describing—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90a0c47a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5873/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the opportunities for increased space-related trade with the independent states of the former Soviet Union;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a0c47b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5873/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a technology procurement plan for identifying and evaluating all unique space hardware, space technology, and space services available to the United States from the independent states;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a0c47c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5873/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specific space hardware, space technology, and space services that have been, or could be, the subject of discussions described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s5871/c"},"text":"section 5871(c) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a0c47d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5873/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the trade missions carried out pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s5872/a"},"text":"section 5872(a) of this title","children":[],"tail":", including the private participation in and the results of such missions;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a0c47e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5873/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any barriers, regulatory or practical, that inhibit space-related trade between the United States and independent states, including any such barriers in either the United States or the independent states; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a0c47f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5873/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any anticompetitive issues raised during the course of negotiations, as observed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s5872/b"},"text":"section 5872(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90a0c480-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/511/tVI/s603"},"text":"Pub. L. 102–511, title VI, § 603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3347"},"text":"106 Stat. 3347","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
