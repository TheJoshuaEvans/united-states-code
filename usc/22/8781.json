bsec. (a)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/158/s312"},"text":"section 312 of Pub. L. 112–158","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1249"},"text":"126 Stat. 1249","children":[],"tail":". Subsec. (a) of section 312 is not classified to the Code. Subsecs. (b) and (c) of section 312 amended "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s8513"},"text":"section 8513 of this title","children":[],"tail":". Subsec. (d) of section 312 enacted provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s8513"},"text":"section 8513 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8513b"},"text":"Section 8513b of this title","children":[],"tail":", as added by section 312, referred to in subsec. (a)(2), was in the original “section 104A of the Comprehensive Iran Sanctions, Accountability, and Divestment Act of 2010, as added by section 312” and was translated as meaning section 104A of the Comprehensive Iran Sanctions, Accountability, and Divestment Act of 2010, as added by "},{"tag":"ref","attrib":{"href":"/us/pl/112/158/s216/a"},"text":"section 216(a) of Pub. L. 112–158","children":[],"tail":", to reflect the probable intent of Congress. For classification of "},{"tag":"ref","attrib":{"href":"/us/pl/112/158/s312"},"text":"section 312 of Pub. L. 112–158","children":[],"tail":", see above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Sections 8514a and 8514b of this title, as added by subtitle A of title IV, referred to in subsecs. (a)(3) and (b)(2)(B), are sections 8514a and 8514b of this title, as added by subtitle A (§§ 401–403) of title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/158"},"text":"Pub. L. 112–158","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail