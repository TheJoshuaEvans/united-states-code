{"tag":"section","attrib":{"id":"id91325633-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9530"},"text":null,"children":[{"tag":"num","attrib":{"value":"9530"},"text":"§ 9530.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions, waiver, and termination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id91325634-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9530/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The provisions of this part and amendments made by this part shall not apply with respect to the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91325635-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9530/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Activities subject to the reporting requirements under title V of the National Security Act of 1947 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3091"},"text":"50 U.S.C. 3091","children":[],"tail":" et seq.), or any authorized intelligence activities of the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91325636-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9530/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The admission of an alien to the United States if such admission is necessary to comply with United States obligations under the Agreement between the United Nations and the United States of America regarding the Headquarters of the United Nations, signed at Lake Success ","children":[{"tag":"date","attrib":{"date":"1947-06-26"},"text":"June 26, 1947","children":[],"tail":", and entered into force "},{"tag":"date","attrib":{"date":"1947-11-21"},"text":"November 21, 1947","children":[],"tail":", under the Convention on Consular Relations, done at Vienna "},{"tag":"date","attrib":{"date":"1963-04-24"},"text":"April 24, 1963","children":[],"tail":", and entered into force "},{"tag":"date","attrib":{"date":"1967-03-19"},"text":"March 19, 1967","children":[],"tail":", or under other international agreements."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91325637-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9530/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of sanctions that are imposed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9511"},"text":"section 9511 of this title","children":[],"tail":", if the President imposes sanctions with respect to a person under this part or the amendments made by this part, the President may waive the application of those sanctions if the President determines that such a waiver is in the national security interest of the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91325638-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9530/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9511"},"text":"section 9511 of this title","children":[],"tail":", the President may terminate the application of sanctions under section 9524, 9525, 9526, 9527, or 9528 of this title with respect to a person if the President submits to the appropriate congressional committees—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id91325639-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9530/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a notice of and justification for the termination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9132563a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9530/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a notice that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9132563b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9530/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person is not engaging in the activity that was the basis for the sanctions or has taken significant verifiable steps toward stopping the activity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9132563c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9530/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President has received reliable assurances that the person will not knowingly engage in activity subject to sanctions under this part in the future.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9132563d-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/44/tII/s236"},"text":"Pub. L. 115–44, title II, § 236","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-02"},"text":"Aug. 2, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/921"},"text":"131 Stat. 921","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9132563e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9132563f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id91325640-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This part, referred to in text, is part 2 (§§ 221–238) of subtitle A of title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/44"},"text":"Pub. L. 115–44","children":[],"tail":", which enacted this part and sections 8909 and 8910 of this title and amended sections 8901, 8907, 8908, 8923, 8924 of this title. For complete classification of part 2 to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The National Security Act of 1947, referred to in subsec. (a)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"act July 26, 1947, ch. 343","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/495"},"text":"61 Stat. 495","children":[],"tail":". Title V of the Act is classified generally to subchapter III (§ 3091 et seq.) of chapter 44 of Title 50, War and National Defense. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
