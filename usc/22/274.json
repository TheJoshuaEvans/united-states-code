:"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"appropriations","id":"id8ea9af5d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Annual Appropriations Between 1948 and 1970","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-03/ch400/tI/s101"},"text":"Act June 3, 1948, ch. 400, title I, § 101","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/305"},"text":"62 Stat. 305","children":[],"tail":", and subsequent Department of State Appropriation Acts through act "},{"tag":"date","attrib":{"date":"1969-12-24"},"text":"Dec. 24, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/91/153/tI/s101"},"text":"Pub. L. 91–153, title I, § 101","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/404"},"text":"83 Stat. 404","children":[],"tail":", failed to authorize appropriations for this section. See Annual Appropriations note set out above."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
