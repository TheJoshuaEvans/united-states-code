{"tag":"section","attrib":{"id":"id8ea9af56-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s274"},"text":null,"children":[{"tag":"num","attrib":{"value":"274"},"text":"§ 274.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International Council of Scientific Unions and Associated Unions; authorization of annual appropriations for membership","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is hereby authorized to be appropriated, to be expended under the direction of the Secretary of State, in paying the annual share of the United States as an adhering member of the International Council of Scientific Unions and Associated Unions, including the International Astronomical Union, International Union of Chemistry, International Union of Geodesy and Geophysics, International Union of Mathematics, International Scientific Radio Union, International Union of Physics, and International Geographical Union, and such other international scientific unions as the Secretary of State may designate, such sum as may be necessary for the payment of such annual share, not to exceed $100,000 in any one year.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ea9af57-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-07/ch454"},"text":"Aug. 7, 1935, ch. 454","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/540"},"text":"49 Stat. 540","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/627"},"text":"Pub. L. 85–627","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-14"},"text":"Aug. 14, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/574"},"text":"72 Stat. 574","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/104"},"text":"Pub. L. 89–104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-08-03"},"text":