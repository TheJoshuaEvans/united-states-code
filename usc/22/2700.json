{"tag":"section","attrib":{"id":"id8ff78bdd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2700"},"text":null,"children":[{"tag":"num","attrib":{"value":"2700"},"text":"§ 2700.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of vehicles","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of State may authorize the principal officer of a Foreign Service post to provide for the use of Government owned or leased vehicles located at that post for transportation of United States Government employees and their families when public transportation is unsafe or not available or when such use is advantageous to the Government.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ff78bde-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch841"},"text":"Aug. 1, 1956, ch. 841","children":[],"tail":", title I, § 28, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/465/tII/s2201/a"},"text":"Pub. L. 96–465, title II, § 2201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2154"},"text":"94 Stat. 2154","children":[],"tail":"; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/97/241/tII/s202/a"},"text":"Pub. L. 97–241, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-08-24"},"text":"Aug. 24, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/282"},"text":"96 Stat. 282","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ff78bdf-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ff78be0-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"childre