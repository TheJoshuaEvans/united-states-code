{"tag":"section","attrib":{"id":"id8f14f45d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1643"},"text":null,"children":[{"tag":"num","attrib":{"value":"1643"},"text":"§ 1643.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional declaration of purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It is the purpose of this subchapter to provide for the determination of the amount and validity of claims against the Government of Cuba, or the Chinese Communist regime, which have arisen since ","children":[{"tag":"date","attrib":{"date":"1959-01-01"},"text":"January 1, 1959","children":[],"tail":", in the case of claims against the Government of Cuba, or since "},{"tag":"date","attrib":{"date":"1949-10-01"},"text":"October 1, 1949","children":[],"tail":", in the case of claims against the Chinese Communist regime, out of nationalization, expropriation, intervention, or other takings of, or special measures directed against, property of nationals of the United States, and claims for disability or death of nationals of the United States arising out of violations of international law by the Government of Cuba, or the Chinese Communist regime, in order to obtain information concerning the total amount of such claims against the Government of Cuba, or the Chinese Communist regime, on behalf of nationals of the United States. This subchapter shall not be construed as authorizing an appropriation or as any intention to authorize an appropriation for the purpose of paying such claims."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f14f45e-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-03-10/ch54"},"text":"Mar. 10, 1950, ch. 54","children":[],"tail":", title V, § 501, as added "},{"tag":"ref","attrib":{"href":"/us/pl/88/666"},"text":"Pub. L. 88–666","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-10-16"},"text":"Oct. 16, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/1110"},"text":"78 Stat. 1110","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/89/262/s1"},"text":"Pub. L. 89–262, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-10-19"},"text":"Oct. 19, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/988"},"text":"79 Stat. 988","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/780/s1"},"text":"Pub. L. 89–780, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-06"},"text":"Nov. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1365"},"text":"80 Stat. 1365","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f14f45f-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f14f460-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f14f461-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1966—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/780"},"text":"Pub. L. 89–780","children":[],"tail":" provided for applicability of section to the Chinese Communist regime in the case of claims which have arisen since "},{"tag":"date","attrib":{"date":"1949-10-01"},"text":"October 1, 1949","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/262"},"text":"Pub. L. 89–262","children":[],"tail":" struck out “which have arisen out of debts for merchandise furnished or services rendered by nationals of the United States without regard to the date on which such merchandise was furnished or services were rendered or” after “Government of Cuba” in first sentence."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f14f462-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"separability","id":"id8f14f463-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Separability","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1950-03-10/ch54/tV/s513"},"text":"Act Mar. 10, 1950, ch. 54, title V, § 513","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/88/666"},"text":"Pub. L. 88–666","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-10-16"},"text":"Oct. 16, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/1113"},"text":"78 Stat. 1113","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/88/666"},"text":"“If any provision of this Act [enacting this subchapter], or the application thereof to any person or circumstances, shall be held invalid, the remainder of the Act, or the application of such provision to other persons or circumstances, shall not be affected.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
