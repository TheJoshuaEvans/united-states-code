{"tag":"section","attrib":{"id":"id91218e0c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9226"},"text":null,"children":[{"tag":"num","attrib":{"value":"9226"},"text":"§ 9226.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel sanctions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of State may deny a visa to, and the Secretary of Homeland Security may deny entry into the United States of, any alien who is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91218e0d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9226/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a designated person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91218e0e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9226/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a corporate officer of a designated person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91218e0f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9226/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a principal shareholder with a controlling interest in a designated person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id91218e10-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/122/tII/s206"},"text":"Pub. L. 114–122, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-18"},"text":"Feb. 18, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/108"},"text":"130 Stat. 108","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
