{"tag":"section","attrib":{"id":"id908db248-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5464"},"text":null,"children":[{"tag":"num","attrib":{"value":"5464"},"text":"§ 5464.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Economic and commercial officers at United States embassies and missions in Poland and Hungary","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is the sense of the Congress that, to the extent practicable—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id908db249-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5464/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Embassy in Budapest, Hungary, should be assigned one additional economic and commercial officer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908db24a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5464/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Embassy in Warsaw, Poland, should be assigned one additional economic officer and one additional commercial officer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908db24b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5464/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Trade Center in Warsaw, Poland, should be assigned one additional economic and commercial officer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908db24c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5464/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States mission in Krakow, Poland, should be assigned one additional economic and commercial officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id908db24d-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/179/tVI/s604"},"text":"Pub. L. 101–179, title VI, § 604","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-28"},"text":"Nov. 28, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1320"},"text":"103 Stat. 1320","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
