{"tag":"section","attrib":{"id":"id907372cc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4200"},"text":null,"children":[{"tag":"num","attrib":{"value":"4200"},"text":"§ 4200.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification of invoices generally","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No consular officer shall certify any invoice unless he is satisfied that the person making oath thereto is the person he represents himself to be, that he is a credible person, and that the statements made under such oath are true; and he shall, thereupon, by his certificate, state that he was so satisfied.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id907372cd-2930-11f1-8918-be39dde81dc6"},"text":"(R.S. § 1715.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id907372ce-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id907372cf-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id907372d0-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 1715 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1856-08-18/ch127/s27"},"text":"act Aug. 18, 1856, ch. 127, § 27","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/11/62"},"text":"11 Stat. 62","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Foreign Service Act of 1980 which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s1180"},"text":"section 1180 of this title","children":[],"tail":", and prior thereto to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s83"},"text":"section 83 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
