{"tag":"section","attrib":{"id":"id8ff78b69-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2690"},"text":null,"children":[{"tag":"num","attrib":{"value":"2690"},"text":"§ 2690.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign gifts; audit; reports to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any expenditure for any gift for any person of any foreign country which involves any funds made available to meet unforeseen emergencies arising in the Diplomatic and Consular Service shall be audited by the Comptroller General and reports thereon made to the Congress to such extent and at such times as he may determine necessary. The representatives of the Government Accountability Office shall have access to all books, accounts, records, reports, files, and all other papers, things, or property pertaining to such expenditure and necessary to facilitate the audit.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ff78b6a-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch841"},"text":"Aug. 1, 1956, ch. 841","children":[],"tail":", title I, § 20, as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/350/tI/s116/a"},"text":"Pub. L. 94–350, title I, § 116(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-07-12"},"text":"July 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/827"},"text":"90 Stat. 827","children":[],"tail":"; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/97/241/tII/s202/a"},"text":"Pub. L. 97–241, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-08-24"},"text":"Aug. 24, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/282"},"text":"96 Stat. 282","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ff78b6b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ff78b6c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8ff78b6d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
