{"tag":"section","attrib":{"id":"id911f4358-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221"},"text":null,"children":[{"tag":"num","attrib":{"value":"9221"},"text":"§ 9221.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinations with respect to North Korea as a jurisdiction of primary money laundering concern","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id911f4359-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress makes the following findings:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id911f435a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Under Secretary of the Treasury for Terrorism and Financial Intelligence, who is responsible for safeguarding the financial system against illicit use, money laundering, terrorist financing, and the proliferation of weapons of mass destruction, and has repeatedly expressed concern about North Korea’s misuse of the international financial system—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911f435b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in 2006—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id911f435c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stated, “Given [North Korea’s] counterfeiting of U.S. currency, narcotics trafficking and use of accounts world-wide to conduct proliferation-related transactions, the line between illicit and licit North Korean money is nearly invisible.”; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id911f435d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" urged financial institutions worldwide to “think carefully about the risks of doing any North Korea-related business”;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911f435e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in 2011, stated that North Korea—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id911f435f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “remains intent on engaging in proliferation, selling arms as well as bringing in material”; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id911f4360-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was “aggressively pursuing the effort to establish front companies.”; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911f4361-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in 2013, stated—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id911f4362-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in reference to North Korea’s distribution of high-quality counterfeit United States currency, that “North Korea is continuing to try to pass a supernote into the international financial system”; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id911f4363-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of the Treasury would soon introduce new currency with improved security features to protect against counterfeiting by the Government of North Korea.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911f4364-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Financial Action Task Force, an intergovernmental body whose purpose is to develop and promote national and international policies to combat money laundering and terrorist financing, has repeatedly—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911f4365-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expressed concern at deficiencies in North Korea’s regimes to combat money laundering and terrorist financing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911f4366-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" urged North Korea to adopt a plan of action to address significant deficiencies in those regimes and the serious threat those deficiencies pose to the integrity of the international financial system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911f4367-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" urged all jurisdictions to apply countermeasures to protect the international financial system from ongoing and substantial money laundering and terrorist financing risks emanating from North Korea;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911f4368-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" urged all jurisdictions to advise their financial institutions to give special attention to business relationships and transactions with North Korea, including North Korean companies and financial institutions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911f4369-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" called on all jurisdictions—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id911f436a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221/a/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to protect against correspondent relationships being used to bypass or evade countermeasures and risk mitigation practices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id911f436b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221/a/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to take into account money laundering and terrorist financing risks when considering requests by North Korean financial institutions to open branches and subsidiaries in their respective jurisdictions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91218d5c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" On ","children":[{"tag":"date","attrib":{"date":"2013-03-07"},"text":"March 7, 2013","children":[],"tail":", the United Nations Security Council unanimously adopted Resolution 2094, which—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91218d5d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" welcomed the Financial Action Task Force’s—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id91218d5e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendation on financial sanctions related to proliferation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91218d5f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guidance on the implementation of such sanctions;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91218d60-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" decided that United Nations member states should apply enhanced monitoring and other legal measures to prevent the provision of financial services or the transfer of property that could contribute to activities prohibited by applicable United Nations Security Council resolutions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91218d61-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" called upon United Nations member states to prohibit North Korean financial institutions from establishing or maintaining correspondent relationships with financial institutions in their respective jurisdictions to prevent the provision of financial services if such member states have information that provides reasonable grounds to believe that such activities could contribute to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id91218d62-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221/a/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities prohibited by an applicable United Nations Security Council resolution; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91218d63-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221/a/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the evasion of such prohibitions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91218d64-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress regarding the designation of North Korea as a jurisdiction of primary money laundering concern","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91218d65-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acknowledges the efforts of the United Nations Security Council to impose limitations on, and to require the enhanced monitoring of, transactions involving North Korean financial institutions that could contribute to sanctioned activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91218d66-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" urges the President, in the strongest terms—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91218d67-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to immediately designate North Korea as a jurisdiction of primary money laundering concern; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91218d68-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to adopt stringent special measures to safeguard the financial system against the risks posed by North Korea’s willful evasion of sanctions and its illicit activities; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91218d69-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" urges the President to seek the prompt implementation by other countries of enhanced monitoring and due diligence to prevent North Korea’s misuse of the international financial system, including by sharing information about activities, transactions, and property that could contribute to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91218d6a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities sanctioned by applicable United Nations Security Council resolutions; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91218d6b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the evasion of such sanctions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91218d6c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinations regarding North Korea","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91218d6d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2016-02-18"},"text":"February 18, 2016","children":[],"tail":", the Secretary of the Treasury, in consultation with the Secretary of State and the Attorney General, and in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s5318A"},"text":"section 5318A of title 31","children":[],"tail":", shall determine whether reasonable grounds exist for concluding that North Korea is a jurisdiction of primary money laundering concern."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91218d6e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhanced due diligence and reporting requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary of the Treasury determines under paragraph (1) that reasonable grounds exist for concluding that North Korea is a jurisdiction of primary money laundering concern, the Secretary, in consultation with the Federal functional regulators (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6809"},"text":"section 6809 of title 15","children":[],"tail":"), shall impose 1 or more of the special measures described in "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s5318A/b"},"text":"section 5318A(b) of title 31","children":[],"tail":" with respect to the jurisdiction of North Korea."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91218d6f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report required","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91218d70-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after the date on which the Secretary of the Treasury makes a determination under paragraph (1), the Secretary shall submit to the appropriate congressional committees a report that contains the reasons for such determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91218d71-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report submitted under subparagraph (A) shall be submitted in unclassified form, but may include a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id91218d72-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/122/tII/s201"},"text":"Pub. L. 114–122, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-18"},"text":"Feb. 18, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/101"},"text":"130 Stat. 101","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
