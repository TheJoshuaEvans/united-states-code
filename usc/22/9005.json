{"tag":"section","attrib":{"id":"id911a61ea-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9005"},"text":null,"children":[{"tag":"num","attrib":{"value":"9005"},"text":"§ 9005.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Admissibility of documents","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"With respect to any application to the United States Central Authority, or any petition to a court under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9003"},"text":"section 9003 of this title","children":[],"tail":", which seeks relief under the Convention, or any other documents or information included with such application or petition or provided after such submission which relates to the application or petition, as the case may be, no authentication of such application, petition, document, or information shall be required in order for the application, petition, document, or information to be admissible in court."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id911a61eb-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/300/s6"},"text":"Pub. L. 100–300, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-29"},"text":"Apr. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/439"},"text":"102 Stat. 439","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id911a61ec-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id911a61ed-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id911a61ee-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11605"},"text":"section 11605 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
