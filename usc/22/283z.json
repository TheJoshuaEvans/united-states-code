{"tag":"section","attrib":{"id":"id8eba50f1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z"},"text":null,"children":[{"tag":"num","attrib":{"value":"283z"},"text":"§ 283z.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposal of light-capital or intermediate technologies as part of Bank’s development strategy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8eba50f2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of proposed resolution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States Executive Director of the Bank shall propose to the Board of Executive Directors of the Bank the adoption of a resolution providing (1) that the development and utilization of light-capital or intermediate technologies should be accepted as major facets of the Bank’s development strategy, and (2) that such light-capital or intermediate technologies should be developed and utilized as soon as possible in all Bank activities. Such resolution shall further provide that, by the close of the calendar year 1977, some projects that employ primarily such light-capital or intermediate technologies shall be designed and approved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8eba50f3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Progress report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States Governor of the Bank shall report to the Congress no later than six months after ","children":[{"tag":"date","attrib":{"date":"1976-05-31"},"text":"May 31, 1976","children":[],"tail":", on the proposal made under subsection (a), and no later than twelve months after such date on the progress that has been made with respect to such proposal."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8eba50f4-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/147/s28"},"text":"Pub. L. 86–147, § 28","children":[],"tail":", formerly § 29, as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/302/tI/s104"},"text":"Pub. L. 94–302, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-05-31"},"text":"May 31, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/593"},"text":"90 Stat. 593","children":[],"tail":"; renumbered § 28, "},{"tag":"ref","attrib":{"href":"/us/pl/96/259/tI/s101/1"},"text":"Pub. L. 96–259, title I, § 101(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-03"},"text":"June 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/429"},"text":"94 Stat. 429","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8eba50f5-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8eba50f6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id8eba50f7-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/147/s28"},"text":"section 28 of Pub. L. 86–147","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/94/302/s103/a/1"},"text":"section 103(a)(1) of Pub. L. 94–302","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s283y"},"text":"section 283y of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/95/118/tVII/s702"},"text":"Pub. L. 95–118, title VII, § 702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-10-03"},"text":"Oct. 3, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1070"},"text":"91 Stat. 1070","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
