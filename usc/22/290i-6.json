{"tag":"section","attrib":{"id":"id8ee09e8a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290i–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"290i–6"},"text":"§ 290i–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subscription to stock","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ee09e8b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290i–6/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of United States subscription to stock","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President is authorized to agree to subscribe on behalf of the United States to twenty-nine thousand eight hundred and twenty shares of the capital stock of the Bank: ","children":[{"tag":"i","attrib":{},"text":"Provided, however","children":[],"tail":", That the subscription shall be effective only to such extent or in such amounts as are provided in advance in appropriations Acts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ee09e8c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290i–6/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated, without fiscal year limitation, for payment by the Secretary of the Treasury of the initial United States subscription to twenty-nine thousand eight hundred and twenty shares of the capital stock of the Bank, $359,733,570: ","children":[{"tag":"i","attrib":{},"text":"Provided, however","children":[],"tail":", That not more than $17,986,679 of such sum may be made available for paid in subscriptions to the Bank for each of the fiscal years 1982, 1983, and 1984."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ee09e8d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290i–6/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distributions by Bank","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any payment or distributions of moneys from the Bank to the United States shall be covered into the Treasury as a miscellaneous receipt.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ee09e8e-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXIII/s1338"},"text":"Pub. L. 97–35, title XIII, § 1338","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/742"},"text":"95 Stat. 742","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ee09e8f-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id8ee09e90-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id8ee09e91-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of President under subsec. (a) delegated to Secretary of the Treasury, see Ex. Ord. No. 12403, ","children":[{"tag":"date","attrib":{"date":"1983-02-08"},"text":"Feb. 8, 1983","children":[],"tail":", 48 F.R. 6087."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
