{"tag":"section","attrib":{"id":"id903a3a40-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3391"},"text":null,"children":[{"tag":"num","attrib":{"value":"3391"},"text":"§ 3391.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Nothing in this chapter may be construed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id903a3a41-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3391/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to restore diplomatic relations with the Republic of China; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903a3a42-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3391/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to alter the United States Government’s position with respect to the international status of the Republic of China.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id903a3a43-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLV/s5539"},"text":"Pub. L. 117–263, div. E, title LV, § 5539","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3334"},"text":"136 Stat. 3334","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id903a3a44-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id903a3a45-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":nu