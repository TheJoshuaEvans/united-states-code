children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1672"},"text":"106 Stat. 1672","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/87/tV/s524"},"text":"Pub. L. 103–87, title V, § 524","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-30"},"text":"Sept. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/952"},"text":"107 Stat. 952","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tVII/s731/e"},"text":"Pub. L. 103–236, title VII, § 731(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/503"},"text":"108 Stat. 503","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/306/tV/s524"},"text":"Pub. L. 103–306, title V, § 524","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-23"},"text":"Aug. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1632"},"text":"108 Stat. 1632","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/107/tV/s524"},"text":"Pub. L. 104–107, title V, § 524","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-12"},"text":"Feb. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/729"},"text":"110 Stat. 729","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/164/tI"},"text":"Pub. L. 104–164, title I","children":[],"tail":", §§ 146, 153(a), "},{"tag":"date","attrib":{"date":"1996-07-21"},"text":"July 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1434"},"text":"110 Stat. 1434","children":[],"tail":", 1440; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/c/tV/s524"},"text":"Pub. L. 104–208, div. A, title I, § 101(c) [title V, § 524]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-121"},"text":"110 Stat. 3009–121","children":[],"tail":", 3009–149; "},{"tag":"ref","attrib":{"href":"/us/pl/105/118/tV/s524"},"text":"Pub. L. 105–118, title V, § 524","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-26"},"text":"Nov. 26, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2412"},"text":"111 Stat. 2412","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/d/tV/s524"},"text":"Pub. L. 105–277, div. A, § 101(d) [title V, § 524]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-150"},"text":"112 Stat. 2681–150","children":[],"tail":", 2681–177; "},{"tag":"ref","attrib":{"href":"/us/pl/107/228/dB/tXII/s1233"},"text":"Pub. L. 107–228, div. B, title XII, § 1233","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"Sept. 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1433"},"text":"116 Stat. 1433","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90226d51-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90226d52-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90226d53-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a)(1), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/629"},"text":"Pub. L. 90–629","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1321"},"text":"82 Stat. 1321","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2751"},"text":"section 2751 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Foreign Assistance Act of 1961, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/424"},"text":"75 Stat. 424","children":[],"tail":". Chapter 2 of part II of that Act is classified generally to part II (§ 2311 et seq.) of subchapter II of this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id90226d54-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/145"},"text":"Pub. L. 102–145","children":[],"tail":" is based on section 545 of H.R. 2621, One Hundred Second Congress, 1st Session, as passed by the House of Representatives on "},{"tag":"date","attrib":{"date":"1991-06-19"},"text":"June 19, 1991","children":[],"tail":", which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/102/145/s118"},"text":"Pub. L. 102–145, § 118","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/102/266/s102"},"text":"Pub. L. 102–266, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-04-01"},"text":"Apr. 1, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/93"},"text":"106 Stat. 93","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/pl/102/145/s118"},"text":"Section 118 of Pub. L. 102–145","children":[],"tail":" provided that the authority and conditions provided in such section 545 shall be applicable to funds appropriated by "},{"tag":"ref","attrib":{"href":"/us/pl/102/145"},"text":"Pub. L. 102–145","children":[],"tail":" (and are hereby enacted) in lieu of the authority and conditions provided in "},{"tag":"ref","attrib":{"href":"/us/pl/101/513/s546"},"text":"section 546 of Pub. L. 101–513","children":[],"tail":". See 1990, 1991, and 1992 Amendment notes below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/591"},"text":"Pub. L. 99–591","children":[],"tail":" is a corrected version of "},{"tag":"ref","attrib":{"href":"/us/pl/99/500"},"text":"Pub. L. 99–500","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90226d55-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/228"},"text":"Pub. L. 107–228","children":[],"tail":" designated existing provisions as par. (1), substituted “which may not exceed (A) five years, and (B) a specified period of time required to complete major refurbishment work of the leased articles to be performed prior to the delivery of the leased articles,” for “of not to exceed five years”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" substituted “the current fiscal year” for “1998” in par. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/118"},"text":"Pub. L. 105–118","children":[],"tail":" substituted “1998” for “1997” in par. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/164/s153/a"},"text":"Pub. L. 104–164, § 153(a)","children":[],"tail":", struck out “, or to any defense article which has passed three-quarters of its normal service life.” after “electronics interface projects” in second sentence and inserted after second sentence “The President may waive the requirement of paragraph (4) for reimbursement of depreciation for any defense article which has passed three-quarters of its normal service life if the President determines that to do so is important to the national security interest of the United States.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" substituted “1997” for “1996” in par. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/107"},"text":"Pub. L. 104–107","children":[],"tail":" substituted “1996” for “1995” in par. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/164/s146"},"text":"Pub. L. 104–164, § 146","children":[],"tail":", substituted “and, if the articles are lost or destroyed while leased—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) in the event the United States intends to replace the articles lost or destroyed, the replacement cost (less any depreciation in the value) of the articles; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) in the event the United States does not intend to replace the articles lost or destroyed, an amount not less than the actual value (less any depreciation in the value) specified in the lease agreement” for “and the replacement cost (less any depreciation in the value) of the articles if the articles are lost or destroyed while leased”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/306"},"text":"Pub. L. 103–306","children":[],"tail":" substituted “1995” for “1994” in par. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":" struck out “and” at end of par. (2), added par. (3), redesignated former par. (3) as (4), and substituted “paragraph (4)” for “paragraph (3)” in two places in provisions following par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/87"},"text":"Pub. L. 103–87","children":[],"tail":" substituted “1994” for “1993” in par. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/391"},"text":"Pub. L. 102–391","children":[],"tail":" substituted “1993” for “1992” in par. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/266"},"text":"Pub. L. 102–266","children":[],"tail":" added "},{"tag":"ref","attrib":{"href":"/us/pl/102/145/s118"},"text":"Pub. L. 102–145, § 118","children":[],"tail":". See 1991 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/145/s118"},"text":"Pub. L. 102–145, § 118","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/102/266"},"text":"Pub. L. 102–266","children":[],"tail":", substituted “1992” for “1991” in par. (B). See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","child