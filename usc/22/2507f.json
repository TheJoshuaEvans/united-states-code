{"tag":"section","attrib":{"id":"id8fcef5af-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507f"},"text":null,"children":[{"tag":"num","attrib":{"value":"2507f"},"text":"§ 2507f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of a policy on stalking","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fcef5b0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall develop and implement a comprehensive policy on stalking that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fcef5b1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires an immediate, effective, and thorough response from the Peace Corps upon receipt of a report of stalking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fcef5b2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides, during training, all Peace Corps volunteers with a point of contact for the reporting of stalking; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fcef5b3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507f/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protects the confidentiality of volunteers who report stalking to the maximum extent practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fcef5b4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development and consultation with experts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing the stalking policy under subsection (a), the President shall consult with and incorporate, as appropriate, the recommendations and views of those with expertise regarding the crime of stalking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fcef5b5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training of in-country staff","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall provide for the training of all in-country staff regarding the stalking policy developed under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fcef5b6-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/293/tI/s8F"},"text":"Pub. L. 87–293, title I, § 8F","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/57/s2"},"text":"Pub. L. 112–57, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-11-21"},"text":"Nov. 21, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/742"},"text":"125 Stat. 742","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
