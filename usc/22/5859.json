{"tag":"section","attrib":{"id":"id90a0c41f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5859"},"text":null,"children":[{"tag":"num","attrib":{"value":"5859"},"text":"§ 5859.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International nonproliferation initiative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90a0c420-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5859/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" to (e) Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90a0c421-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5859/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Avoidance of duplicative authorizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply if the National Defense Authorization Act for Fiscal Year 1993 enacts the same authorities and requirements as are contained in this section and authorizes the appropriation of the same (or a greater) amount to carry out such authorities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90a0c422-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/511/tV/s509"},"text":"Pub. L. 102–511, title V, § 509","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3343"},"text":"106 Stat. 3343","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90a0c423-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90a0c424-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90a0c425-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Defense Authorization Act for Fiscal Year 1993, referred to in subsec. (f), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484"},"text":"Pub. L. 102–484","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2315"},"text":"106 Stat. 2315","children":[],"tail":". For complete classification of this Act to the Code, see Tables. See Codification note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id90a0c426-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/511/s509"},"text":"section 509 of Pub. L. 102–511","children":[],"tail":". Subsecs. (a) to (e) were omitted pursuant to subsec. (f) because section 1505 of the National Defense Authorization Act for Fiscal Year 1993, "},{"tag":"ref","attrib":{"href":"/us/pl/102/484"},"text":"Pub. L. 102–484","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s5859a"},"text":"section 5859a of this title","children":[],"tail":", enacted the same authorities and requirements as contained in subsecs. (a) to (e) and authorized the appropriation of the same or a greater amount to carry out such authorities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
