{"tag":"section","attrib":{"id":"id8ff78c1c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2704"},"text":null,"children":[{"tag":"num","attrib":{"value":"2704"},"text":"§ 2704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsistence expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of State may pay, without regard to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5702"},"text":"section 5702 of title 5","children":[],"tail":", subsistence expenses of (1) special agents of the Department of State who are on authorized protective missions, whether at or away from their duty stations, and (2) members of the Foreign Service and employees of the Department who are required to spend extraordinary amounts of time in travel status. The authorities available to the Secretary of State under this section with respect to the Department of State shall be available to the Broadcasting Board of Governors and the Administrator of the Agency for International Development with respect to their respective agencies, except that the authority of clause (2) shall be available with respect to those agencies only in the case of members of the Foreign Service and employees of the agency who are performing security-related functions abroad."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ff78c1d-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch841"},"text":"Aug. 1, 1956, ch. 841","children":[],"tail":", title I, § 32, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/465/tII/s2201/a"},"text":"Pub. L. 96–465, title II, § 2201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2157"},"text":"94 Stat. 2157","children":[],"tail":"; renumbered title I, "},{"tag":"ref","attrib":