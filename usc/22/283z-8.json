{"tag":"section","attrib":{"id":"id8eba5148-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"283z–8"},"text":"§ 283z–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increase in lending to Caribbean","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Treasury shall instruct the United States Executive Director of the Bank to enter into discussions with the management of the Bank and with other member country governments to seek to increase Bank lending to the Caribbean region, directly or through appropriate financial intermediaries, for viable projects which will—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8eba5149-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–8/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" result in expanded regional economic integration, diversification, and industrial and agricultural production, and improved infrastructure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8eba514a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–8/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek to ensure equitable and environmentally sustainable economic growth.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8eba514b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/147/s36"},"text":"Pub. L. 86–147, § 36","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/240/tII/s204"},"text":"Pub. L. 101–240, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2499"},"text":"103 Stat. 2499","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
