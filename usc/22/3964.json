{"tag":"section","attrib":{"id":"id90522ee5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3964"},"text":null,"children":[{"tag":"num","attrib":{"value":"3964"},"text":"§ 3964.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assignments to salary class","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90522ee6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3964/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall assign all Foreign Service officers and Foreign Service personnel (other than Foreign Service personnel who are paid in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3967"},"text":"section 3967 of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3968"},"text":"section 3968 of this title","children":[],"tail":") to appropriate salary classes in the Foreign Service Schedule."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90522ee7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3964/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90522ee8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3964/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The salary class to which a member of the Service is assigned under this section shall not be affected by the assignment of the member to a position classified under subchapter V.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90522ee9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3964/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as authorized by subchapter I of chapter 35 of title 5, changes in the salary class of a member of the Senior Foreign Service or a member of the Service assigned to a salary class in the Foreign Service Schedule shall be made only in accordance with subchapter VI. The Secretary shall prescribe regulations (which shall be consistent with the relevant provisions of subchapter VI of chapter 53 of title 5 and with the regulations prescribed to carry out such provisions) providing for retention of pay by members of the Service in cases in which reduction-in-force procedures are applied.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90522eea-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s404"},"text":"Pub. L. 96–465, title I, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2088"},"text":"94 Stat. 2088","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s180/a/3"},"text":"Pub. L. 103–236, title I, § 180(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/415"},"text":"108 Stat. 415","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90522eeb-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90522eec-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90522eed-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":" struck out “who are family members of Government employees paid in accordance with a local compensation plan established under” after “"},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3967"},"text":"section 3967 of this title","children":[],"tail":" or”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
