{"tag":"section","attrib":{"id":"id8f1764be-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1644c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1644c"},"text":"§ 1644c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ownership of claims by nationals","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A claim shall not be favorably considered under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s1644b"},"text":"section 1644b of this title","children":[],"tail":" unless the property right on which it is based was owned, wholly or partially, directly or indirectly, by a national of the United States on the date of loss and if favorably considered, the claim shall be considered only if it has been held by one or more nationals of the United States continuously from the date that the loss occurred until the date of filing with the Commission."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f1764bf-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-03-10/ch54"},"text":"Mar. 10, 1950, ch. 54","children":[],"tail":", title VI, § 603, as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/542"},"text":"Pub. L. 94–542","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-18"},"text":"Oct. 18, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2510"},"text":"90 Stat. 2510","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
