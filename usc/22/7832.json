{"tag":"section","attrib":{"id":"id90ef808c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7832"},"text":null,"children":[{"tag":"num","attrib":{"value":"7832"},"text":"§ 7832.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance provided inside North Korea","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90ef808d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7832/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Humanitarian assistance through nongovernmental and international organizations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of the Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90ef808e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7832/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the same time that Congress supports the provision of humanitarian assistance to the people of North Korea on humanitarian grounds, such assistance also should be provided and monitored so as to minimize the possibility that such assistance could be diverted to political or military use, and to maximize the likelihood that it will reach the most vulnerable North Koreans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ef808f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7832/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significant increases above current levels of United States support for humanitarian assistance provided inside North Korea should be conditioned upon substantial improvements in transparency, monitoring, and access to vulnerable populations throughout North Korea; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ef8090-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7832/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States should encourage other countries that provide food and other humanitarian assistance to North Korea to do so through monitored, transparent channels, rather than through direct, bilateral transfers to the Government of North Korea.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90ef8091-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7832/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States assistance to the government of North Korea","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90ef8092-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7832/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" United States humanitarian assistance to any department, agency, or entity of the Government of North Korea shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90ef8093-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7832/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be delivered, distributed, and monitored according to internationally recognized humanitarian standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ef8094-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7832/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be provided on a needs basis, and not used as a political reward or tool of coercion;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ef8095-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7832/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reach the intended beneficiaries, who should be informed of the source of the assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ef8096-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7832/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be made available to all vulnerable groups in North Korea, no matter where in the country they may be located; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ef8097-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7832/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" United States nonhumanitarian assistance to North Korea shall be contingent on North Korea’s substantial progress toward—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90ef8098-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7832/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" respect for the basic human rights of the people of North Korea, including freedom of religion;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ef8099-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7832/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing for family reunification between North Koreans and their descendants and relatives in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ef809a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7832/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fully disclosing all information regarding citizens of Japan and the Republic of Korea abducted by the Government of North Korea;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ef809b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7832/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allowing such abductees, along with their families, complete and genuine freedom to leave North Korea and return to the abductees’ original home countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ef809c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7832/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reforming the North Korean prison and labor camp system, and subjecting such reforms to independent international monitoring; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ef809d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7832/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" decriminalizing political expression and activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90ef809e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7832/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2004-10-18"},"text":"October 18, 2004","children":[],"tail":", the Administrator of the Agency for International Development shall submit to the appropriate congressional committees a report describing compliance with this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90ef809f-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/333/tII/s202"},"text":"Pub. L. 108–333, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-18"},"text":"Oct. 18, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1293"},"text":"118 Stat. 1293","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
