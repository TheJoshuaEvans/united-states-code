{"tag":"section","attrib":{"id":"id90dc6d87-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7203"},"text":null,"children":[{"tag":"num","attrib":{"value":"7203"},"text":"§ 7203.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7202"},"text":"Section 7202 of this title","children":[],"tail":" shall not affect any authority or requirement to impose (or continue to impose) a sanction referred to in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7202"},"text":"section 7202 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90dc6d88-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7203/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" against a foreign country or foreign entity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90dc6d89-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7203/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursuant to a declaration of war against the country or entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90dc6d8a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7203/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursuant to specific statutory authorization for the use of the Armed Forces of the United States against the country or entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90dc6d8b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7203/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" against which the Armed Forces of the United States are involved in hostilities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90dc6d8c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7203/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where imminent involvement by the Armed Forces of the United States in hostilities against the country or entity is clearly indicated by the circumstances; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90dc6d8d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7203/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to the extent that the sanction would prohibit, restrict, or condition the provision or use of any agricultural commodity, medicine, or medical device that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90dc6d8e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7203/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" controlled on the United States Munitions List established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2778"},"text":"section 2778 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90dc6d8f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7203/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" controlled on any control list established under the Export Administration Act of 1979 or any successor statute (50 U.S.C. App. 2401 et seq.); ","children":[{"tag":"ref","attrib":{"idref":"fn002379"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002379"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90dc6d90-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7203/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used to facilitate the design, development, or production of chemical or biological weapons, missiles, or weapons of mass destruction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90dc6d91-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/387/s1/a/tIX/s904"},"text":"Pub. L. 106–387, § 1(a) [title IX, § 904]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1549"},"text":"114 Stat. 1549","children":[],"tail":", 1549A–68; "},{"tag":"ref","attrib":{"href":"/us/pl/107/56/tII/s221/a/1"},"text":"Pub. L. 107–56, title II, § 221(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/292"},"text":"115 Stat. 292","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90dc6d92-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90dc6d93-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90dc6d94-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Export Administration Act of 1979, referred to in par. (2)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/72"},"text":"Pub. L. 96–72","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-29"},"text":"Sept. 29, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/503"},"text":"93 Stat. 503","children":[],"tail":", which was classified principally to section 2401 et seq. of the former Appendix to Title 50, War and National Defense, prior to editorial reclassification and renumbering as chapter 56 (§ 4601 et seq.) of Title 50, and was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXVII/s1766/a"},"text":"Pub. L. 115–232, div. A, title XVII, § 1766(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2232"},"text":"132 Stat. 2232","children":[],"tail":", except for sections 11A, 11B, and 11C thereof ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4611"},"text":"50 U.S.C. 4611","children":[],"tail":", 4612, 4613). See the Export Control Reform Act of 2018 ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4801"},"text":"50 U.S.C. 4801","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90dc6d95-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—Par. (2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56"},"text":"Pub. L. 107–56","children":[],"tail":" amended subpar. (C) generally. Prior to amendment, subpar. (C) read as follows: “used to facilitate the development or production of a chemical or biological weapon or weapon of mass destruction.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
