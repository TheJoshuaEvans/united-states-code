{"tag":"section","attrib":{"id":"id90037308-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736"},"text":null,"children":[{"tag":"num","attrib":{"value":"2736"},"text":"§ 2736.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exit interviews for workforce","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90037309-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retained members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director General of the Foreign Service and the Director of the Bureau of Human Resources or its equivalent shall conduct periodic interviews with a representative and diverse cross-section of the workforce of the Department—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9003730a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to understand the reasons of individuals in such workforce for remaining in a position in the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9003730b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to receive feedback on workplace policies, professional development opportunities, and other issues affecting the decision of individuals in the workforce to remain in the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9003730c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Departing members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director General of the Foreign Service and the Director of the Bureau of Human Resources or its equivalent shall provide an opportunity for an exit interview to each individual in the workforce of the Department who separates from service with the Department to better understand the reasons of such individual for leaving such service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9003730d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of analysis from interviews","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director General of the Foreign Service and the Director of the Bureau of Human Resources or its equivalent shall analyze demographic data and other information obtained through interviews under subsections (a) and (b) to determine to what extent, if any, the diversity of those participating in such interviews impacts the results.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9003730e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tracking data","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Department shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9003730f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" track demographic data relating to participants in professional development programs and the rate of placement into senior positions for participants in such programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90037310-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" annually evaluate such data—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90037311-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify ways to improve outreach and recruitment for such programs, consistent with merit system principles; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90037312-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to understand the extent to which participation in any professional development program offered or sponsored by the Department differs among the demographic categories of the workforce; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90037313-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actively encourage participation from a range of demographic categories, especially from categories with consistently low participation, in such professional development programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90037314-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dE/tLIV/s5402"},"text":"Pub. L. 117–81, div. E, title LIV, § 5402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2371"},"text":"135 Stat. 2371","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90037315-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90037316-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id90037317-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “Department” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s5002"},"text":"section 5002 of Pub. L. 117–81","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s263c"},"text":"section 263c of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dE/tLIV/s5401"},"text":"Pub. L. 117–81, div. E, title LIV, § 5401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2371"},"text":"135 Stat. 2371","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/81/dE/tLIV/s5401"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In this title [enacting this section and sections 2736a to 2736e of this title and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3941"},"text":"section 3941 of this title","children":[],"tail":"]:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicant flow data","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘applicant flow data’ means data that tracks the rate of applications for job positions among demographic categories.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Demographic data","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘demographic data’ means facts or statistics relating to the demographic categories specified in the Office of Management and Budget statistical policy directive entitled ‘Standards for Maintaining, Collecting, and Presenting Federal Data on Race and Ethnicity’ (81 Fed. Reg. 67398).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Diversity","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘diversity’ means those classes of persons protected under the Civil Rights Act of 1964 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000a"},"text":"42 U.S.C. 2000a","children":[],"tail":" et seq.) and the Americans with Disabilities Act of 1990 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12101"},"text":"42 U.S.C. 12101","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Workforce","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘workforce’ means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals serving in a position in the civil service (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2101"},"text":"section 2101 of title 5","children":[],"tail":", United States Code);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals who are members of the Foreign Service (as defined in section 103 of the Foreign Service Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3902"},"text":"22 U.S.C. 3902","children":[],"tail":") [sic, "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3903"},"text":"22 U.S.C. 3903","children":[],"tail":"]);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all individuals serving under a personal services contract;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all individuals serving under a Foreign Service Limited appointment under section 309 of the Foreign Service Act of 1980 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3949"},"text":"22 U.S.C. 3949","children":[],"tail":"]; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals other than Locally Employed Staff working in the Department of State under any other authority.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
