{"tag":"section","attrib":{"id":"id91029413-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8531"},"text":null,"children":[{"tag":"num","attrib":{"value":"8531"},"text":"§ 8531.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91029414-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8531/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy sector of Iran","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “energy sector of Iran” refers to activities to develop petroleum or natural gas resources or nuclear power in Iran.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91029415-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8531/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “financial institution” has the meaning given that term in section 14 of the Iran Sanctions Act of 1996 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/172"},"text":"Public Law 104–172","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91029416-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8531/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Iran","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Iran” includes the Government of Iran and any agency or instrumentality of Iran.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91029417-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8531/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “person” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91029418-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8531/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a natural person, corporation, company, business association, partnership, society, trust, or any other nongovernmental entity, organization, or group;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91029419-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8531/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any governmental entity or instrumentality of a government, including a multilateral development institution (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s262r/c/3"},"text":"section 262r(c)(3) of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9102941a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8531/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any successor, subunit, parent entity, or subsidiary of, or any entity under common ownership or control with, any entity described in subparagraph (A) or (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9102941b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8531/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each of the several States, the District of Columbia, the Commonwealth of Puerto Rico, the Commonwealth of the Northern Mariana Islands, American Samoa, Guam, the United States Virgin Islands, and any other territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9102941c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8531/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State or local government","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “State or local government” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9102941d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8531/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any State and any agency or instrumentality thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9102941e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8531/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any local government within a State, and any agency or instrumentality thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9102941f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8531/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other governmental instrumentality of a State or locality; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91029420-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8531/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any public institution of higher education within the meaning of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"20 U.S.C. 1001","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id91029421-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/195/tII/s201"},"text":"Pub. L. 111–195, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-01"},"text":"July 1, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1341"},"text":"124 Stat. 1341","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id91029422-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id91029423-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8551/a"},"text":"section 8551(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id91029424-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editori