{"tag":"section","attrib":{"id":"id8f5ef58e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152j–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"2152j–4"},"text":"§ 2152j–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In sections 2152j to 2152j–4 of this title:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f5ef58f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152j–4/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8f5ef590-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152j–4/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations, the Committee on Armed Services, and the Committee on Appropriations of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f5ef591-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152j–4/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs, the Committee on Armed Services, and the Committee on Appropriations of the of the ","children":[{"tag":"ref","attrib":{"idref":"fn002104"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002104"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" House of Representatives."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","a