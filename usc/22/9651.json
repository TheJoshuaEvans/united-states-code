{"tag":"section","attrib":{"id":"id9147b24b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9651"},"text":null,"children":[{"tag":"num","attrib":{"value":"9651"},"text":"§ 9651.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of risk and audit committees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9147b24c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9651/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To assist the Board to fulfill its duties and responsibilities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9621/a"},"text":"section 9621(a) of this title","children":[],"tail":", the Corporation shall establish a risk committee and an audit committee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9147b24d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9651/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties and responsibilities of risk committee","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the direction of the Board, the risk committee established under subsection (a) shall have oversight responsibility of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9147b24e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9651/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" formulating risk management policies of the operations of the Corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b24f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9651/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reviewing and providing guidance on operation of the Corporation’s global risk management framework;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b250-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9651/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing policies for enterprise risk management, monitoring, and management of strategic, reputational, regulatory, operational, developmental, environmental, social, and financial risks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b251-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9651/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing the risk profile of the Corporation, including a risk management and compliance framework and governance structure to support such framework; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b252-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9651/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" developing policies and procedures for assessing, prior to providing, and for any period during which the Corporation provides, support to any foreign entities, whether such entities have in place sufficient enhanced due diligence policies and practices to prevent money laundering and corruption to ensure the Corporation does not provide support to persons that are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9147b253-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9651/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly engaging in acts of corruption;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9147b254-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9651/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly providing material or financial support for terrorism, drug trafficking, or human trafficking; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9147b255-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9651/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" responsible for ordering or otherwise directing serious or gross violations of human rights.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9147b256-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9651/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties and responsibilities of audit committee","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the direction of the Board, the audit committee established under subsection (a) shall have the oversight responsibility of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9147b257-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9651/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the integrity of the Corporation’s financial reporting and systems of internal controls regarding finance and accounting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b258-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9651/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the integrity of the Corporation’s financial statements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b259-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9651/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the performance of the Corporation’s internal audit function; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b25a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9651/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compliance with legal and regulatory requirements related to the finances of the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9147b25b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dF/tIV/s1441"},"text":"Pub. L. 115–254, div. F, title IV, § 1441","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3503"},"text":"132 Stat. 3503","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
