{"tag":"section","attrib":{"id":"id8e8f7005-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262g–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"262g–2"},"text":"§ 262g–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of guidelines for international financial institutions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8e8f7006-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262g–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with representatives of member countries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall consult with representatives of other member countries of the International Bank for Reconstruction and Development, the International Development Association, the Asian Development Bank, the African Development Fund, and the African Development Bank (if the United States becomes a member of that Bank), for the purpose of establishing guidelines within each of those institutions which specify that, in a manner consistent with the purposes and charters of those institutions, a specified proportion of the annual lending by each institution shall be designed to benefit needy people, primarily by financing sound, efficient, productive, self-sustaining projects designed to benefit needy people in developing countries, thus helping poor people improve their conditions of life.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8e8f7007-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262g–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional findings regarding implementation of objectives","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Congress finds that projects to construct basic infrastructure, to expand productive capacity (including private enterprise), and to address social problems can all meet the objectives of this section if they are designed and implemented properly. For the purposes of this title, “needy people” means those people living in “absolute” or “relative” poverty as determined under the standards employed by the International Bank for Reconstruction and Development and the International Development Association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8e8f7008-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/118/tXI/s1102"},"text":"Pub. L. 95–118, title XI, § 1102","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXIII/s1361/b"},"text":"Pub. L. 97–35, title XIII, § 1361(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/745"},"text":"95 Stat. 745","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8e8f7009-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8e8f700a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8e8f700b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This title, referred to in subsec. (b), is title XI (§§ 1101–1103) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/118"},"text":"Pub. L. 95–118","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXIII/s1361/b"},"text":"Pub. L. 97–35, title XIII, § 1361(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/745"},"text":"95 Stat. 745","children":[],"tail":", which enacted sections 262g–1 and 262g–2 of this title and enacted a provision set out as a note below. For complete classification of title XI to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8e8f700c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id8e8f700d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/s1372"},"text":"section 1372 of Pub. L. 97–35","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s290i"},"text":"section 290i of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8e8f700e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reports to Congress","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/118/tXI/s1103"},"text":"Pub. L. 95–118, title XI, § 1103","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXIII/s1361/b"},"text":"Pub. L. 97–35, title XIII, § 1361(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/746"},"text":"95 Stat. 746","children":[],"tail":", required reports on the progress being made toward achieving the goals of this section, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/101/240/tV/s541/d/4"},"text":"Pub. L. 101–240, title V, § 541(d)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2518"},"text":"103 Stat. 2518","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
