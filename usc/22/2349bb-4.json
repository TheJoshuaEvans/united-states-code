{"tag":"section","attrib":{"id":"id8f982e4b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349bb–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"2349bb–4"},"text":"§ 2349bb–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f982e4c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349bb–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the President to carry out this part $162,000,000 for fiscal year 2003.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f982e4d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349bb–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available under subsection (a) may be used notwithstanding any other provision of law (other than section 2304 or 2371 of this title) and shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f982e4e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349bb–4/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts made available by the Foreign Operations, Export Financing, and Related Programs Appropriations Act, 2002, under “Nonproliferation, Antiterrorism, Demining, and Related Programs” and “Assistance for the Independent States of the Former Soviet Union” accounts for the activities described in subsection (d) shall be considered to be made available pursuant to this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f982e4f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349bb–4/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The activities referred to in subsection (c) are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f982e50-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349bb–4/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance under the Nonproliferation and Disarmament Fund;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f982e51-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349bb–4/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance for science and technology centers in the independent states of the former Soviet Union;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f982e52-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349bb–4/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" export control assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f982e53-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349bb–4/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" export control and border assistance under part XI of subchapter I of this chapter or the FREEDOM Support Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s5801"},"text":"22 U.S.C. 5801","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f982e54-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. II, § 586, formerly § 585, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/280/tIII/s301"},"text":"Pub. L. 106–280, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-06"},"text":"Oct. 6, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/852"},"text":"114 Stat. 852","children":[],"tail":"; renumbered § 586 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/228/dB/tXIII"},"text":"Pub. L. 107–228, div. B, title XIII","children":[],"tail":", §§ 1301(a), 1303(1), "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"Sept. 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1435"},"text":"116 Stat. 1435","children":[],"tail":", 1436.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f982e55-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f982e56-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8f982e57-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Foreig