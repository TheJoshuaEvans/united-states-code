{"tag":"section","attrib":{"id":"id90902295-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5493"},"text":null,"children":[{"tag":"num","attrib":{"value":"5493"},"text":"§ 5493.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses of Agency for International Development","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purpose of paying administrative expenses incurred in connection with carrying out its functions under this chapter, the Agency for International Development may use up to $500,000 each fiscal year of the funds made available to the Agency under this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id90902296-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/179/tVIII/s803"},"text":"Pub. L. 101–179, title VIII, § 803","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-28"},"text":"Nov. 28, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1323"},"text":"103 Stat. 1323","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90902297-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90902298-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90902299-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/179"},"text":"Pub. L. 101–179","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-28"},"text":"Nov. 28, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1298"},"text":"103 Stat. 1298","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s5401"},"text":"section 5401 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9090229a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9090229b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Administrative Expenses of Agency for International Development for Fiscal Year 1991; Supersedure of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/513/tII"},"text":"Pub. L. 101–513, title II","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1994"},"text":"104 Stat. 1994","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/513/tII"},"text":"“Up to $1,000,000 of the funds appropriated under this heading [“Assistance for Eastern Europe”] may be used for the administrative expenses incurred by the Agency for International Development in connection with administering programs for Eastern Europe: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the authority of this subsection shall supersede for fiscal year 1991 the provisions of section 803 of the Support for East European Democracy (SEED) Act of 1989 ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s5493"},"text":"22 U.S.C. 5493","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
