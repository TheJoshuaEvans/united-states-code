{"tag":"section","attrib":{"id":"id906c6ebe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4112"},"text":null,"children":[{"tag":"num","attrib":{"value":"4112"},"text":"§ 4112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employees represented","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The employees of the Department shall constitute a single and separate worldwide bargaining unit, from which there shall be excluded—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id906c6ebf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4112/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employees engaged in personnel work in other than a purely clerical capacity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6ec0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4112/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employees engaged in criminal or national security investigations or who audit the work of individuals to insure that their functions are discharged honestly and with integrity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id906c6ec1-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s1012"},"text":"Pub. L. 96–465, title I, § 1012","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2135"},"text":"94 Stat. 2135","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
