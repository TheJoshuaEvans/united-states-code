{"tag":"section","attrib":{"id":"id91133515-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8804"},"text":null,"children":[{"tag":"num","attrib":{"value":"8804"},"text":"§ 8804.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of sanctions with respect to the sale, supply, or transfer of certain materials to or from Iran","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id91133516-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8804/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale, supply, or transfer of certain materials","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91133517-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8804/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall impose 5 or more of the sanctions described in section 6(a) of the Iran Sanctions Act of 1996 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/172"},"text":"Public Law 104–172","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":" note) with respect to a person if the President determines that the person knowingly, on or after the date that is 180 days after "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"January 2, 2013","children":[],"tail":", sells, supplies, or transfers, directly or indirectly, to or from Iran—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91133518-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8804/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a precious metal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91133519-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8804/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a material described in subsection (d) determined pursuant to subsection (e)(1) to be used by Iran as described in that subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9113351a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8804/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any other material described in subsection (d) if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9113351b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8804/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the material is—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id9113351c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8804/a/1/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be used in connection with the energy, shipping, or shipbuilding sectors of Iran or any sector of the economy of Iran determined pursuant to subsection (e)(2) to be controlled directly or indirectly by Iran’s Revolutionary Guard Corps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id9113351d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8804/a/1/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sold, supplied, or transferred to or from an Iranian person included on the list of specially designated nationals and blocked persons maintained by the Office of Foreign Assets Control of the Department of the Treasury (other than an Iranian financial institution described in subsection (b)); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id9113351e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8804/a/1/C/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determined pursuant to subsection (e)(3) to be used in connection with the nuclear, military, or ballistic missile programs of Iran; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9113351f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8804/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the material is resold, retransferred, or otherwise supplied—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id91133520-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8804/a/1/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to an end-user in a sector described in subclause (I) of clause (i);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id91133521-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8804/a/1/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a person described in subclause (II) of that clause; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id91133522-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8804/a/1/C/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a program described in subclause (III) of that clause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91133523-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8804/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirement to impose sanctions under paragraph (1) shall not include the authority to impose sanctions relating to the importation of goods under paragraph (8)(A) or (12) of section 6(a) of the Iran Sanctions Act of 1996, and any sanction relating to the importation of goods shall not count for purposes of the requirement to impose sanctions under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91133524-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8804/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Iranian financial institutions described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An Iranian financial institution described in this subsection is an Iranian financial institution that has not been designated for the imposition of sanctions in connection with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91133525-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8804/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Iran’s proliferation of weapons of mass destruction or delivery systems for weapons of mass destruction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91133526-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8804/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Iran’s support for international terrorism; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91133527-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8804/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Iran’s abuses of human rights.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91133528-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8804/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facilitation of certain transactions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall prohibit the opening, and prohibit or impose strict conditions on the maintaining, in the United States of a correspondent account or a payable-through account by a foreign financial institution that the President determines knowingly, on or after the date that is 180 days after ","children":[{"tag":"date","attrib":{"date":"2013-01-02"},"text":"January 2, 2013","children":[],"tail":", conducts or facilitates a significant financial transaction for the sale, supply, or transfer to or from Iran of materials the sale, supply, or transfer of which would subject a person to sanctions under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91133529-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8804/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Materials described","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Materials described in this subsection are graphite, raw or semi-finished metals such as aluminum and steel, coal, and software for integrating industrial processes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9113352a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8804/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination with respect to use of materials","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2013-01-02"},"text":"January 2, 2013","children":[],"tail":", and every 180 days thereafter, the President shall submit to the appropriate congressional committees and publish in the Federal Register a report that contains the determination of the President with respect to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id9113352b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8804/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" whether Iran is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9113352c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8804/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using any of the materials described in subsection (d) as a medium for barter, swap, or any other exchange or transaction; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9113352d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8804/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" listing any of such materials as assets of the Government of Iran for purposes of the national balance sheet of Iran;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9113352e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8804/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which sectors of the economy of Iran are controlled directly or indirectly by Iran’s Revolutionary Guard Corps; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9113352f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8804/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which of the materials described in subsection (d) are used in connection with the nuclear, military, or ballistic missile programs of Iran.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91133530-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8804/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for persons exercising due diligence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may not impose sanctions under subsection (a) or (c) with respect to a person if the President determines that the person has exercised due diligence in establishing and enforcing official policies, procedures, and controls to ensure that the person does not sell, supply, or transfer to or from Iran materials the sale, supply, or transfer of which would subject a person to sanctions under subsection (a) or conduct or facilitate a financial transaction for such a sale, supply, or transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91133531-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8804/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91133532-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8804/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President may waive the imposition of sanctions under this section for a period of not more than 180 days, and may renew that waiver for additional periods of not more than 180 days, if the President—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91133533-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8804/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determines that such a waiver is vital to the national security of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91133534-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8804/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submits to the appropriate congressional committees a report providing a justification for the waiver.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91133535-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8804/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each report submitted under paragraph (1)(B) shall be submitted in unclassified form, but may include a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91133536-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8804/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National balance sheet of Iran defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “national balance sheet of Iran” refers to the ratio of the assets of the Government of Iran to the liabilities of that Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id91133537-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tXII/s1245"},"text":"Pub. L. 112–239, div. A, title XII, § 1245","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2009"},"text":"126 Stat. 2009","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id91133538-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id91133539-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id9113353a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of certain functions and authorities vested in the President by this section, see Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2013-06-03"},"text":"June 3, 2013","children":[],"tail":", 78 F.R. 35545, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s8801"},"text":"section 8801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
