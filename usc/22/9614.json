{"tag":"section","attrib":{"id":"id9145684d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9614"},"text":null,"children":[{"tag":"num","attrib":{"value":"9614"},"text":"§ 9614.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independent accountability mechanism","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9145684e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9614/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall establish a transparent and independent accountability mechanism.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9145684f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9614/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The independent accountability mechanism established pursuant to subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91456850-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9614/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" annually evaluate and report to the Board and Congress regarding compliance with environmental, social, labor, human rights, and transparency standards, consistent with Corporation statutory mandates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91456851-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9614/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a forum for resolving concerns regarding the impacts of specific Corporation-supported projects with respect to such standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91456852-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9614/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide advice regarding Corporation projects, policies, and practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91456853-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9614/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consolidation of functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2025-12-18"},"text":"December 18, 2025","children":[],"tail":", the Board shall submit a report to the appropriate congressional committees describing any efficiencies that may be gained through the consolidation of functions of the independent accountability mechanism under the authorities of the Office of the Inspector General of the Corporation under section 1414. "},{"tag":"ref","attrib":{"idref":"fn002455"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002455"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" The report shall include an outline as to how the Inspector General of the Corporation would develop an internal environmental, social, and governance expertise to adequately replace the independent accountability mechanism’s environmental, social, and governance expertise."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id91456854-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dF/tI/s1415"},"text":"Pub. L. 115–254, div. F, title I, § 1415","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3492"},"text":"132 Stat. 3492","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dH/tLXXXVII/s8733"},"text":"Pub. L. 119–60, div. H, title LXXXVII, § 8733","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1960"},"text":"139 Stat. 1960","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id91456855-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id91456856-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id91456857-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id91456858-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Section 1414, referred to in subsec. (c), means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1414"},"text":"section 1414 of Pub. L. 115–254","children":[],"tail":", div. F, title I, "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3492"},"text":"132 Stat. 3492","children":[],"tail":", which amended section 8G of the Inspector General Act of 1978, "},{"tag":"ref","attrib":{"href":"/us/pl/95/452"},"text":"Pub. L. 95–452","children":[],"tail":", formerly § 8E, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/504"},"text":"Pub. L. 100–504","children":[],"tail":", which was set out in the Appendix to Title 5, Government Organization and Employees, prior to repeal and restatement as "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s415"},"text":"section 415 of Title 5","children":[],"tail":"."}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id91456859-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
