{"tag":"section","attrib":{"id":"id8f982e73-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"2349cc"},"text":"§ 2349cc.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Congress makes the following findings:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f982e74-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Increasingly digitized and interconnected social, political, and economic systems have introduced new vulnerabilities for malicious actors to exploit, which threatens economic and national security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f982e75-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The rapid development, deployment, and integration of information and communication technologies into all aspects of modern life bring mounting risks of accidents and malicious activity involving such technologies, and their potential consequences.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f982e76-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Because information and communication technologies are globally manufactured, traded, and networked, the economic and national security of the United State ","children":[{"tag":"ref","attrib":{"idref":"fn002139"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002139"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “States”."}],"tail":" depends greatly on cybersecurity practices of other actors, including other countries."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f982e77-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" United States assistance to countries and international organizations to bolster civilian capacity to address national cybersecurity and deterrence in cyberspace can help—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8f982e78-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce vulnerability in the information and communication technologies ecosystem; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f982e79-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349cc/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advance national and economic security objectives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f982e7a-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. II, § 591, as added "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dF/tLXIII/s6307"},"text":"Pub. L. 118–31, div. F, title LXIII, § 6307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/990"},"text":"137 Stat. 990","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
