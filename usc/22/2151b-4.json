{"tag":"section","attrib":{"id":"id8f509dae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2151b–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"2151b–4"},"text":"§ 2151b–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to combat malaria","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f509daf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2151b–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Congress finds that malaria kills more people annually than any other communicable disease except tuberculosis, that more than 90 percent of all malaria cases are in sub-Saharan Africa, and that children and women are particularly at risk. Congress recognizes that there are cost-effective tools to decrease the spread of malaria and that malaria is a curable disease if promptly diagnosed and adequately treated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f509db0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2151b–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is a major objective of the foreign assistance program of the United States to provide assistance for the prevention, control, treatment, and cure of malaria.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f509db1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2151b–4/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out this section and consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151b/c"},"text":"section 2151b(c) of this title","children":[],"tail":", the President is authorized to furnish assistance, on such terms and conditions as the President may determine, for the prevention, treatment, control, and elimination of malaria."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f509db2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2151b–4/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the President shall coordinate with the World Health Organization, the Global Fund to Fight AIDS, Tuberculosis, and Malaria, the Department of Health and Human Services (the Centers for Disease Control and Prevention and the National Institutes of Health), and other organizations with respect to the development and implementation of a comprehensive malaria control program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f509db3-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. I, § 104C, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/25/tIII/s303/a"},"text":"Pub. L. 108–25, title III, § 303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-05-27"},"text":"May 27, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/736"},"text":"117 Stat. 736","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/293/tIII/s303/a"},"text":"Pub. L. 110–293, title III, § 303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2960"},"text":"122 Stat. 2960","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f509db4-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f509db5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f509db6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/293"},"text":"Pub. L. 110–293","children":[],"tail":" inserted “treatment,” after “control,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id8f509db7-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id8f509db8-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions of President under this section, see Ex. Ord. No. 12163, ","children":[{"tag":"date","attrib":{"date":"1979-09-29"},"text":"Sept. 29, 1979","children":[],"tail":", 44 F.R. 56673, as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2381"},"text":"section 2381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
