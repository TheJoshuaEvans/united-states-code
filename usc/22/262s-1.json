{"tag":"section","attrib":{"id":"id8ea4f478-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262s–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"262s–1"},"text":"§ 262s–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procurement opportunities for United States firms","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall instruct the United States Executive Directors of the multilateral development institutions to take all possible steps to ensure that information relating to potential procurement opportunities for United States firms is expeditiously communicated to the Secretary of the Treasury, the Secretary of State, and the Secretary of Commerce, and is disseminated as widely as possible to large and small businesses.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ea4f479-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/118/tXVIII/s1802"},"text":"Pub. L. 95–118, title XVIII, § 1802","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/240/tV/s541/a"},"text":"Pub. L. 101–240, title V, § 541(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2516"},"text":"103 Stat. 2516","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ea4f47a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ea4f47b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id8ea4f47c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The definitions in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s262r"},"text":"section 262r of this title","children":[],"tail":" apply to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
