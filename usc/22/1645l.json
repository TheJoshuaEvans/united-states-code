{"tag":"section","attrib":{"id":"id8f176517-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1645l"},"text":null,"children":[{"tag":"num","attrib":{"value":"1645l"},"text":"§ 1645l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated for any fiscal year beginning on or after ","children":[{"tag":"date","attrib":{"date":"1980-10-01"},"text":"October 1, 1980","children":[],"tail":", such sums as may be necessary to enable the Commission and the Treasury Department to pay their respective administrative expenses incurred in carrying out their functions under this subchapter. Amounts appropriated under this section may remain available until expended."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f176518-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-03-10/ch54"},"text":"Mar. 10, 1950, ch. 54","children":[],"tail":", title VII, § 713, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/606"},"text":"Pub. L. 96–606","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-28"},"text":"Dec. 28, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3537"},"text":"94 Stat. 3537","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
