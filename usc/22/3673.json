{"tag":"section","attrib":{"id":"id9043d754-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3673"},"text":null,"children":[{"tag":"num","attrib":{"value":"3673"},"text":"§ 3673.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transition separation incentive payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9043d755-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3673/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In applying to the Commission and employees of the Commission the provisions of section 663 of the Treasury, Postal Service, and General Government Appropriations Act, 1997 (as contained in section 101(f) of division A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Public Law 104–208","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-383"},"text":"110 Stat. 3009–383","children":[],"tail":"), relating to voluntary separation incentives for employees of certain Federal agencies (in this section referred to as “section 663”)—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id9043d756-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3673/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “employee” shall mean an employee of the Commission who has served in the Republic of Panama in a position with the Commission for a continuous period of at least three years immediately before the employee’s separation under an appointment without time limitation and who is covered under the Civil Service Retirement System or the Federal Employees’ Retirement System under subchapter III of chapter 83 or chapter 84, respectively, of title 5, other than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9043d757-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3673/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee described in any of subparagraphs (A) through (F) of subsection (a)(2) of section 663; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9043d758-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3673/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee of the Commission who, during the 24-month period preceding the date of separation, has received a recruitment or relocation bonus under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3657/c"},"text":"section 3657(c) of this title","children":[],"tail":" or who, within the 12-month period preceding the date of separation, received a retention bonus under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3657/d"},"text":"section 3657(d) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9043d759-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3673/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the strategic plan under subsection (b) of section 663 shall include (in lieu of the matter specified in subsection (b)(2) of that section)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9043d75a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3673/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the positions to be affected, identified by occupational category and grade level;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9043d75b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3673/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and amounts of separation incentive payments to be offered; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9043d75c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3673/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how such incentive payments will facilitate the successful transfer of the Panama Canal to the Republic of Panama;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9043d75d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3673/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a separation incentive payment under section 663 may be paid to a Commission employee only to the extent necessary to facilitate the successful transfer of the Panama Canal by the United States of America to the Republic of Panama as required by the Panama Canal Treaty of 1977;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9043d75e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3673/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such a payment—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9043d75f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3673/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be in an amount determined by the Commission not to exceed $25,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9043d760-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3673/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be made (notwithstanding the limitation specified in subsection (c)(2)(D) of section 663) in the case of an eligible employee who voluntarily separates (whether by retirement or resignation) during the 90-day period beginning on ","children":[{"tag":"date","attrib":{"date":"1997-11-18"},"text":"November 18, 1997","children":[],"tail":", or during the period beginning on "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"October 1, 1998","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"1998-12-31"},"text":"December 31, 1998","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9043d761-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3673/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of not more than 15 employees who (as determined by the Commission) are unwilling to work for the Panama Canal Authority after the Canal Transfer Date and who occupy critical positions for which (as determined by the Commission) at least two years of experience is necessary to ensure that seasoned managers are in place on and after the Canal Transfer Date, such a payment (notwithstanding paragraph (4))—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9043d762-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3673/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be in an amount determined by the Commission not to exceed 50 percent of the basic pay of the employee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9043d763-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3673/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be made (notwithstanding the limitation specified in subsection (c)(2)(D) of section 663) in the case of such an employee who voluntarily separates (whether by retirement or resignation) during the 90-day period beginning on ","children":[{"tag":"date","attrib":{"date":"1997-11-18"},"text":"November 18, 1997","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9043d764-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3673/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provisions of subsection (f) of section 663 shall not apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9043d765-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3673/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A decision by the Commission to exercise or to not exercise the authority to pay a transition separation incentive under this section shall not be subject to review under any statutory procedure or any agency or negotiated grievance procedure except under any of the laws referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2302/d"},"text":"section 2302(d) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9043d766-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70/tI/s1233"},"text":"Pub. L. 96–70, title I, § 1233","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dC/tXXXV/s3526"},"text":"Pub. L. 105–85, div. C, title XXXV, § 3526","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2067"},"text":"111 Stat. 2067","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/73/tI/s107/a/2/E"},"text":"Pub. L. 115–73, title I, § 107(a)(2)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-10-26"},"text":"Oct. 26, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1239"},"text":"131 Stat. 1239","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1097/b/3/E"},"text":"Pub. L. 115–91, div. A, title X, § 1097(b)(3)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1618"},"text":"131 Stat. 1618","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9043d767-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9043d768-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9043d769-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 663 of the Treasury, Postal Service, and General Government Appropriations Act, 1997 (as contained in section 101(f) of division A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Public Law 104–208","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-383"},"text":"110 Stat. 3009–383","children":[],"tail":"), referred to in subsec. (a), is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5597"},"text":"section 5597 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9043d76a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" substituted “section 2302(d)” for “section 2302(c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/73"},"text":"Pub. L. 115–73","children":[],"tail":" substituted “section 2302(c)” for “section 2302(d)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
