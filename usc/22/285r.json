{"tag":"section","attrib":{"id":"id8ebf32a0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285r"},"text":null,"children":[{"tag":"num","attrib":{"value":"285r"},"text":"§ 285r.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contribution to special funds; authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ebf32a1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285r/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Governor of the Bank is hereby authorized to agree to contribute on behalf of the United States $50,000,000 to the special funds of the Bank. This contribution shall be made available to the Bank pursuant to the provisions of article 19 of the articles of agreement of the Bank.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ebf32a2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285r/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to pay for the United States contribution to the special funds, there is hereby authorized to be appropriated without fiscal year limitation $50,000,000 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ebf32a3-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/369/s21"},"text":"Pub. L. 89–369, § 21","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/537"},"text":"Pub. L. 93–537","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-12-22"},"text":"Dec. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1735"},"text":"88 Stat. 1735","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
