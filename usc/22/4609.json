{"tag":"section","attrib":{"id":"id907d0fb2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4609"},"text":null,"children":[{"tag":"num","attrib":{"value":"4609"},"text":"§ 4609.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id907d0fb3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4609/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id907d0fb4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4609/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out this chapter, there are authorized to be appropriated such sums as may be necessary for fiscal years 2009 through 2014.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id907d0fb5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4609/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds appropriated pursuant to the authority of paragraph (1) shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id907d0fb6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4609/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of unobligated funds; reports of use of funds to Congress and President","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board of Directors may transfer to the legal entity authorized to be established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4603/c"},"text":"section 4603(c) of this title","children":[],"tail":" any funds not obligated or expended from appropriations to the Institute for a fiscal year, and such funds shall remain available for obligation or expenditure for the purposes of such legal entity without regard to fiscal year limitations. Any use by such legal entity of appropriated funds shall be reported to each House of the Congress and to the President of the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id907d0fb7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4609/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contractual authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any authority provided by this chapter to enter into contracts shall be effective for a fiscal year only to such extent or in such amounts as are provided in appropriation Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id907d0fb8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4609/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any authorization of appropriations made for the purposes of carrying out this chapter shall be extended in the same manner as applicable programs are extended under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1226a"},"text":"section 1226a of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id907d0fb9-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/tXVII/s1710"},"text":"Pub. L. 98–525, title XVII, § 1710","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2659"},"text":"98 Stat. 2659","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tXVI/s1601/a/1"},"text":"Pub. L. 99–498, title XVI, § 1601(a)(1)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1612"},"text":"100 Stat. 1612","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/569/tIII/s301"},"text":"Pub. L. 100–569, title III, § 301[(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-31"},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2863"},"text":"102 Stat. 2863","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/325/tXV/s1554/a"},"text":"Pub. L. 102–325, title XV, § 1554(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-23"},"text":"July 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/839"},"text":"106 Stat. 839","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/208/s2/k/14"},"text":"Pub. L. 103–208, § 2(k)(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2486"},"text":"107 Stat. 2486","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tIX/s931/2"},"text":"Pub. L. 105–244, title IX, § 931(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1834"},"text":"112 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIX/s921/c"},"text":"Pub. L. 110–315, title IX, § 921(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3456"},"text":"122 Stat. 3456","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id907d0fba-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id907d0fbb-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id907d0fbc-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s921/c/1"},"text":"Pub. L. 110–315, § 921(c)(1)","children":[],"tail":", substituted “to be appropriated such sums as may be necessary for fiscal years 2009 through 2014” for “to be appropriated $15,000,000 for fiscal year 1999 and such sums as may be necessary for each of the 4 succeeding fiscal years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s921/c/2"},"text":"Pub. L. 110–315, § 921(c)(2)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" substituted “1999” for “1993” and “4” for “6”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/208"},"text":"Pub. L. 103–208","children":[],"tail":" substituted “6” for “4” before “succeeding fiscal years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/325"},"text":"Pub. L. 102–325","children":[],"tail":" amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) For the purpose of carrying out this chapter (except for paragraph (9) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4604/b"},"text":"section 4604(b) of this title","children":[],"tail":"), there are authorized to be appropriated $10,000,000 for fiscal year 1989; $10,000,000 for fiscal year 1990; $10,000,000 for fiscal year 1991; $15,000,000 for fiscal year 1992; and $15,000,000 for fiscal year 1993."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) Funds appropriated pursuant to paragraph (1) are authorized to remain available until expended.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/569"},"text":"Pub. L. 100–569","children":[],"tail":" amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows: “For the purpose of carrying out this chapter (except for paragraph (9) of "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4604/b"},"text":"section 4604(b) of this title","children":[],"tail":"), there are authorized to be appropriated $6,000,000 for the fiscal year 1987 and $10,000,000 for the fiscal year 1988. Amounts appropriated under this section are authorized to remain available to the Institute until expended.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/498"},"text":"Pub. L. 99–498","children":[],"tail":" substituted “fiscal year 1987” for “fiscal year 1985”, “fiscal year 1988” for “fiscal year 1986”, and “Amounts appropriated under this section are authorized to remain available to the Institute until expended” for “Moneys appropriated for the fiscal year 1985 shall remain available to the Institute through the fiscal year 1986”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id907d0fbd-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id907d0fbe-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id907d0fbf-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/208"},"text":"Pub. L. 103–208","children":[],"tail":" effective as if included in the Hi