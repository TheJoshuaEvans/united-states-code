ding this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1986-10-01"},"text":"October 1, 1986","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
