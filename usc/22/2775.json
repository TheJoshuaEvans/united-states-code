{"tag":"section","attrib":{"id":"id901414e3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2775"},"text":null,"children":[{"tag":"num","attrib":{"value":"2775"},"text":"§ 2775.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign military sales to less developed countries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id901414e4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2775/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When the President finds that any economically less developed country is diverting development assistance furnished pursuant to the Foreign Assistance Act of 1961, as amended [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"22 U.S.C. 2151","children":[],"tail":" et seq.], or sales under the Food for Peace Act, as amended ["},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1691"},"text":"7 U.S.C. 1691","children":[],"tail":" et seq.], to military expenditures, or is diverting its own resources to unnecessary military expenditures, to a degree which materially interferes with its development, such country shall be immediately ineligible for further sales and guarantees under sections 2761, 2762, 2763, and 2764 of this title, until the President is assured that such diversion will no longer take place."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id901414e5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2775/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/559/s45/a/5"},"text":"Pub. L. 93–559, § 45(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-12-30"},"text":"Dec. 30, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1814"},"text":"88 Stat. 1814","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id901414e6-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/629"},"text":"Pub. L. 90–629","children":[],"tail":", ch. 3, § 35, "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1325"},"text":"82 Stat. 1325","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/559/s45/a/5"},"text":"Pub. L. 93–559, § 45(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-12-30"},"text":"Dec. 30, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1814"},"text":"88 Stat. 1814","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/tIII/s3001/b/1/A"},"text":"Pub. L. 110–246, title III, § 3001(b)(1)(A)","children":[],"tail":", (2)(T), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1820"},"text":"122 Stat. 1820","children":[],"tail":", 1821.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id901414e7-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id901414e8-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id901414e9-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Foreign Assistance Act of 1961, as amended, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", "},{"tag":"date",