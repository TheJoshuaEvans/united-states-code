{"tag":"section","attrib":{"id":"id90d9fd51-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7115"},"text":null,"children":[{"tag":"num","attrib":{"value":"7115"},"text":"§ 7115.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ensuring protection and confidentiality for survivors of human trafficking","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90d9fd52-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7115/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90d9fd53-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7115/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “covered grant” means a grant from the Attorney General or the Secretary of Health and Human Services under section 7104(b), 7105(b), or 7105(f) of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90d9fd54-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7115/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “covered recipient” means a grantee or subgrantee receiving funds under a covered grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90d9fd55-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7115/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Covered grants and covered recipients shall be subject, at the election of the Attorney General or the Secretary of Health and Human Services, as applicable, to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90d9fd56-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7115/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conditions under section 40002(b)(2) of the Violence Against Women Act of 1994 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12291/b/2"},"text":"34 U.S.C. 12291(b)(2)","children":[],"tail":") that apply with respect to grants under such Act and grantees and subgrantees for such grants; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90d9fd57-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7115/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conditions under section 306(c)(5) of the Family Violence Prevention and Services Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10406/c/5"},"text":"42 U.S.C. 10406(c)(5)","children":[],"tail":") that apply with respect to grants under such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10401"},"text":"42 U.S.C. 10401","children":[],"tail":" et seq.] and grantees and subgrantees for such grants."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90d9fd58-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7115/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Justice-sponsored research","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section shall be construed to prohibit a covered recipient from sharing personally identifying information with researchers seeking the information for the purposes of conducting research—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90d9fd59-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7115/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is funded by the Department of Justice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90d9fd5a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7115/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which protections are in place in accordance with the requirements under part 22 of title 28, Code of Federal Regulations, or any successor thereto, and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10231/a"},"text":"section 10231(a) of title 34","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90d9fd5b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7115/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which a current privacy certificate is on file documenting how the researchers intend to fulfill the obligations under such part 22.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90d9fd5c-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/386/dA/s114"},"text":"Pub. L. 106–386, div. A, § 114","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/347/tI/s103"},"text":"Pub. L. 117–347, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6200"},"text":"136 Stat. 6200","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90d9fd5d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90d9fd5e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90d9fd5f-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Violence Against Women Act of 1994, referred to in subsec. (b)(1), is title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1902"},"text":"108 Stat. 1902","children":[],"tail":". For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/s40001"},"text":"section 40001 of Pub. L. 103–322","children":[],"tail":", set out as a Short Title of 1994 Act note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of Title 34","children":[],"tail":", Crime Control and Law Enforcement, and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Family Violence Prevention and Services Act, referred to in subsec. (b)(2), is title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/457"},"text":"Pub. L. 98–457","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-09"},"text":"Oct. 9, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1757"},"text":"98 Stat. 1757","children":[],"tail":", which is classified generally to chapter 110 (§ 10401 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10401"},"text":"section 10401 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
