{"tag":"section","attrib":{"id":"id90e85539-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7631a"},"text":null,"children":[{"tag":"num","attrib":{"value":"7631a"},"text":"§ 7631a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States Agency for International Development","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90e8553a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7631a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator of the United States Agency for International Development, in coordination with the Coordinator of United States Government Activities to Combat HIV/AIDS Globally, may facilitate availability and accessibility of microbicides, provided that such pharmaceuticals are approved, tentatively approved, or otherwise authorized for use by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90e8553b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7631a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Food and Drug Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e8553c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7631a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a stringent regulatory agency acceptable to the Secretary of Health and Human Services; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e8553d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7631a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a quality assurance mechanism acceptable to the Secretary of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90e8553e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7631a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts authorized to be appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7671"},"text":"section 7671 of this title","children":[],"tail":" for HIV/AIDS assistance, there are authorized to be appropriated to the President such sums as may be necessary for each of the fiscal years 2009 through 2013 to carry out this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90e8553f-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/293/tII/s203/e"},"text":"Pub. L. 110–293, title II, § 203(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2941"},"text":"122 Stat. 2941","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90e85540-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90e85541-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id90e85542-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Tom Lantos and Henry J. Hyde United States Global Leadership Against HIV/AIDS, Tuberculosis, and Malaria Reauthorization Act of 2008, and not as part of the United States Leadership Against HIV/AIDS, Tuberculosis, and Malaria Act of 2003 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
