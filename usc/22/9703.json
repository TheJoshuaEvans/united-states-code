{"tag":"section","attrib":{"id":"id914a239c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9703"},"text":null,"children":[{"tag":"num","attrib":{"value":"9703"},"text":"§ 9703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advancing a negotiated solution to Venezuela’s crisis","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id914a239d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9703/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id914a239e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9703/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" direct, credible negotiations led by the Interim President of Venezuela and members of Venezuela’s democratically elected National Assembly—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id914a239f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9703/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are supported by stakeholders in the international community that have recognized the Interim President of Venezuela;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914a23a0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9703/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include the input and interests of Venezuelan civil society; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914a23a1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9703/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" represent the best opportunity to reach a solution to the Venezuelan crisis that includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id914a23a2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9703/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" holding a new presidential election that complies with international standards for a free, fair, and transparent electoral process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id914a23a3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9703/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ending Nicolás Maduro’s usurpation of presidential authorities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id914a23a4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9703/a/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restoring democracy and the rule of law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id914a23a5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9703/a/1/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" freeing political prisoners; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id914a23a6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9703/a/1/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitating the delivery of humanitarian aid;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914a23a7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9703/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dialogue between the Maduro regime and representatives of the political opposition that commenced in October 2017, and were supported by the Governments of Mexico, of Chile, of Bolivia, and of Nicaragua, did not result in an agreement because the Maduro regime failed to credibly participate in the process; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914a23a8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9703/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" negotiations between the Maduro regime and representatives of the political opposition that commenced in October 2016, and were supported by the Vatican, did not result in an agreement because the Maduro regime failed to credibly participate in the process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id914a23a9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9703/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the policy of the United States to support diplomatic engagement in order to advance a negotiated and peaceful solution to Venezuela’s political, economic, and humanitarian crisis that is described in subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id914a23aa-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dJ/tI/s113"},"text":"Pub. L. 116–94, div. J, title I, § 113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3031"},"text":"133 Stat. 3031","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
