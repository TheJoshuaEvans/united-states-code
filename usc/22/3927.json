{"tag":"section","attrib":{"id":"id904d4d95-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3927"},"text":null,"children":[{"tag":"num","attrib":{"value":"3927"},"text":"§ 3927.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief of mission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id904d4d96-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3927/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under the direction of the President, the chief of mission to a foreign country—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id904d4d97-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3927/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall have full responsibility for the direction, coordination, and supervision of all Government executive branch employees in that country (except for Voice of America correspondents on official assignment and employees under the command of a United States area military commander); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904d4d98-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3927/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall keep fully and currently informed with respect to all activities and operations of the Government within that country, and shall insure that all Government executive branch employees in that country (except for Voice of America correspondents on official assignment and employees under the command of a United States area military commander) comply fully with all applicable directives of the chief of mission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id904d4d99-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3927/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of agencies with employees in foreign countries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any executive branch agency having employees in a foreign country shall keep the chief of mission to that country fully and currently informed with respect to all activities and operations of its employees in that country, and shall insure that all of its employees in that country (except for Voice of America correspondents on official assignment and employees under the command of a United States area military commander) comply fully with all applicable directives of the chief of mission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id904d4d9a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3927/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotion of United States goods and services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each chief of mission to a foreign country shall have as a principal duty the promotion of United States goods and services for export to such country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id904d4d9b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3927/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotion of United States economic interests","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each chief of mission to a foreign country shall have as a principal duty the promotion of United States economic and commercial interests in such country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id904d4d9c-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s207"},"text":"Pub. L. 96–465, title I, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2079"},"text":"94 Stat. 2079","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/241/tI/s123"},"text":"Pub. L. 97–241, title I, § 123","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-08-24"},"text":"Aug. 24, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/281"},"text":"96 Stat. 281","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/204/tI/s136"},"text":"Pub. L. 100–204, title I, § 136","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1345"},"text":"101 Stat. 1345","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/228/dA/tV/s505/b"},"text":"Pub. L. 107–228, div. A, title V, § 505(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"Sept. 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1393"},"text":"116 Stat. 1393","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/dJ/tVII/s704"},"text":"Pub. L. 116–94, div. J, title VII, § 704","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3070"},"text":"133 Stat. 3070","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id904d4d9d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id904d4d9e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id904d4d9f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94"},"text":"Pub. L. 116–94","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsecs. (a)(1), (2), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/228"},"text":"Pub. L. 107–228","children":[],"tail":" inserted “Voice of America correspondents on official assignment and” after “except for”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/204/s136/1"},"text":"Pub. L. 100–204, § 136(1)","children":[],"tail":", (2), inserted “executive branch” after “Government” in par. (1) and after second reference to “Government” in par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/204/s136/3"},"text":"Pub. L. 100–204, § 136(3)","children":[],"tail":", inserted “executive branch” after “Any”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/241"},"text":"Pub. L. 97–241","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
