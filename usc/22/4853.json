{"tag":"section","attrib":{"id":"id90843b91-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4853"},"text":null,"children":[{"tag":"num","attrib":{"value":"4853"},"text":"§ 4853.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security requirements for contractors","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"1986-08-27"},"text":"August 27, 1986","children":[],"tail":", the Secretary of State shall issue regulations to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90843b92-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4853/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthen the security procedures applicable to contractors and subcontractors involved in any way with any diplomatic construction or design project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90843b93-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4853/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permit a contractor or subcontractor to have access to any design or blueprint relating to such a project only in accordance with those procedures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90843b94-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/399/tIV/s403"},"text":"Pub. L. 99–399, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/865"},"text":"100 Stat. 865","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
