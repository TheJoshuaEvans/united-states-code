{"tag":"section","attrib":{"id":"id8e942bd3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262m"},"text":null,"children":[{"tag":"num","attrib":{"value":"262m"},"text":"§ 262m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional findings and policies for multilateral development banks respecting environment, public health, natural resources, and indigenous peoples","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8e942bd4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262m/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States assistance to the multilateral development banks should promote sustainable use of natural resources and the protection of the environment, public health, and the status of indigenous peoples in developing countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e942bd5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262m/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" multilateral development bank projects, policies, and loans have failed in some cases to provide adequate safeguards for the environment, public health, natural resources, and indigenous peoples;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e942bd6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262m/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" many development efforts of the multilateral development banks are more enduring and less costly if based on consultations with directly affected population groups and communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e942bd7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262m/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing country governments sometimes do not ensure that appropriate policies and procedures are in place to use natural resources sustainably or consult with affected population groups and communities, where costs could be reduced or benefits made more enduring; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e942bd8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262m/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in general, the multilateral development banks do not yet provide systematic and adequate assistance to their borrowers to encourage sustainable resource use and consultation with affected communities, where costs could be reduced or benefits made more enduring.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8e942bd9-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/118/tXIII/s1301"},"text":"Pub. L. 95–118, title XIII, § 1301","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/e/tI"},"text":"Pub. L. 100–202, § 101(e) [title I]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-131"},"text":"101 Stat. 1329–131","children":[],"tail":", 1329–134.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8e942bda-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8e942bdb-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8e942bdc-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/118/s1301"},"text":"Section 1301 of Pub. L. 95–118","children":[],"tail":" is based on section 701 of title VII of H.R. 3750, One Hundredth Congress, as introduced "},{"tag":"date","attrib":{"date":"1987-12-11"},"text":"Dec. 11, 1987","children":[],"tail":", and enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
