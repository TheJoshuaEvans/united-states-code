{"tag":"section","attrib":{"id":"id9062d14d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4061"},"text":null,"children":[{"tag":"num","attrib":{"value":"4061"},"text":"§ 4061.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments for future benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9062d14e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4061/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statutes deemed to authorize appropriations to Fund to finance unfunded liability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any statute which authorizes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9062d14f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4061/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" new or liberalized benefits payable from the Fund under this part, including annuity increases other than under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4065"},"text":"section 4065 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9062d150-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4061/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" extension of the benefits of the System to new groups of employees; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9062d151-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4061/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increases in salary on which benefits are computed;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is deemed to authorize appropriations to the Fund to finance the unfunded liability created by that statute, in 30 equal annual installments with interest computed at the rate used in the then most recent valuation of the System and with the first payment thereof due as of the end of the fiscal year in which each new or liberalized benefit, extension of benefits, or increase in salary is effective.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9062d152-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4061/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations to Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Fund for each fiscal year an amount equal to the amount of the Foreign Service normal cost for that year which is not met by contributions to the Fund under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4045/a"},"text":"section 4045(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9062d153-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s821"},"text":"Pub. L. 96–465, title I, § 821","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2121"},"text":"94 Stat. 2121","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/335/tIV/s402/a/3"},"text":"Pub. L. 99–335, title IV, § 402(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-06"},"text":"June 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/609"},"text":"100 Stat. 609","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9062d154-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9062d155-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9062d156-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/335"},"text":"Pub. L. 99–335","children":[],"tail":" inserted “under this part” after “payable from the Fund”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9062d157-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9062d158-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/335"},"text":"Pub. L. 99–335","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1987-01-01"},"text":"Jan. 1, 1987","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/335/s702/a"},"text":"section 702(a) of Pub. L. 99–335","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8401"},"text":"section 8401 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
