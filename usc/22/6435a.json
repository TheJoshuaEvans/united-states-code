{"tag":"section","attrib":{"id":"id90b8b93c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6435a"},"text":null,"children":[{"tag":"num","attrib":{"value":"6435a"},"text":"§ 6435a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards of conduct and disclosure","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90b8b93d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6435a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation with nongovernmental organizations, the Department of State, and Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall seek to effectively and freely cooperate with all entities engaged in the promotion of religious freedom abroad, governmental and nongovernmental, in the performance of the Commission’s duties under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90b8b93e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6435a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflict of interest and antinepotism","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90b8b93f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6435a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Member affiliations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (3), in order to ensure the independence and integrity of the Commission, the Commission may not compensate any nongovernmental agency, project, or person related to or affiliated with any member of the Commission, whether in that member’s direct employ or not. Staff employed by the Commission may not serve in the employ of any nongovernmental agency, project, or person related to or affiliated with any member of the Commission while employed by the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b8b940-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6435a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Staff of the Commission may not receive compensation from any other source for work performed in carrying out the duties of the Commission while employed by the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b8b941-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6435a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90b8b942-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6435a/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), paragraph (1) shall not apply to payments made for items such as conference fees or the purchase of periodicals or other similar expenses, if such payments would not cause the aggregate value paid to any agency, project, or person for a fiscal year to exceed $250.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b8b943-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6435a/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subparagraph (A), the Commission shall not give special preference to any agency, project, or person related to or affiliated with any member of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b8b944-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6435a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “affiliated” means the relationship between a member of the Commission and—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90b8b945-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6435a/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual who holds the position of officer, trustee, partner, director, or employee of an agency, project, or person of which that member, or relative of that member of,","children":[{"tag":"ref","attrib":{"idref":"fn002345"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002345"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should follow “member”."}],"tail":" the Commission is an officer, trustee, partner, director, or employee; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b8b946-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6435a/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nongovernmental agency or project of which that member, or a relative of that member, of the Commission is an officer, trustee, partner, director, or employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90b8b947-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6435a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90b8b948-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6435a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations, the Commission may contract with and compensate Government agencies or persons for the conduct of activities necessary to the discharge of its functions under this subchapter. Any such person shall be hired without interruption or loss of civil service or Foreign Service status or privilege. The Commission may procure temporary and intermittent services under the authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109/b"},"text":"section 3109(b) of title 5","children":[],"tail":", except that the Commission may not expend more than $250,000 in any fiscal year to procure such services."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b8b949-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6435a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expert study","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a study requested under section 6474 ","children":[{"tag":"ref","attrib":{"idref":"fn002346"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002346"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" of this title, the Commission may, subject to the availability of appropriations, contract with experts and shall provide the funds for such a study. The Commission shall not be required to provide the funds for that part of the study conducted by the Comptroller General of the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90b8b94a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6435a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gifts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90b8b94b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6435a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to preserve its independence, the Commission may not accept, use, or dispose of gifts or donations of services or property. An individual Commissioner or employee of the Commission may not, in his or her capacity as a Commissioner or employee, knowingly accept, use or dispose of gifts or donations of services or property, unless he or she in good faith believes such gifts or donations to have a value of less than $50 and a cumulative value during a calendar year of less than $100.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b8b94c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6435a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This subsection shall not apply to the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90b8b94d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6435a/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Gifts provided on the basis of a personal friendship with a Commissioner or employee, unless the Commissioner or employee has reason to believe that the gift was provided because of the Commissioner’s position and not because of the personal friendship.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b8b94e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6435a/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Gifts provided on the basis of a family relationship.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b8b94f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6435a/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The acceptance of training, invitations to attend or participate in conferences or such other events as are related to the conduct of the duties of the Commission, or food or refreshment associated with such activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b8b950-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6435a/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Items of nominal value or gifts of estimated value of $10 or less.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b8b951-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6435a/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" De minimis gifts provided by a foreign leader or state, not exceeding a value of $260. Gifts believed by Commissioners to be in excess of $260, but which would create offense or embarrassment to the United States Government if refused, shall be accepted and turned over to the United States Government in accordance with the Foreign Gifts and Decorations Act of 1966 and the rules and regulations governing such gifts provided to Members of Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b8b952-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6435a/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Informational materials such as documents, books, videotapes, periodicals, or other forms of communications.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b8b953-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6435a/d/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Goods or services provided by any agency or component of the Government of the United States, including any commission established under the authority of such Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90b8b954-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6435a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual financial report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to providing the reports required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6432"},"text":"section 6432 of this title","children":[],"tail":", the Commission shall provide, each year no later than January 1, to the Committees on Foreign Affairs and Appropriations of the House of Representatives, and to the Committees on Foreign Relations and Appropriations of the Senate, a financial report detailing and identifying its expenditures for the preceding fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90b8b955-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6435a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall comply with all of the records management requirements set forth in chapter 31 of title 44 (commonly referred to as the “Federal Records Act of 1950”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90b8b956-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6435a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Official email for commission business","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When conducting any Commission business on electronic accounts, Commission Members and staff shall use official Commission electronic accounts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90b8b957-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/292/tII/s208"},"text":"Pub. L. 105–292, title II, § 208","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/55/s1/b/5"},"text":"Pub. L. 106–55, § 1(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-08-17"},"text":"Aug. 17, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/403"},"text":"113 Stat. 403","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/228/dA/tVI/s681/f"},"text":"Pub. L. 107–228, div. A, title VI, § 681(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"Sept. 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1409"},"text":"116 Stat. 1409","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/75/s5"},"text":"Pub. L. 112–75, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-23"},"text":"Dec. 23, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1273"},"text":"125 Stat. 1273","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/dJ/tVIII/s809"},"text":"Pub. L. 116–94, div. J, title VIII, § 809","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3079"},"text":"133 Stat. 3079","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90b8b958-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90b8b959-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90b8b95a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6474"},"text":"Section 6474 of this title","children":[],"tail":", referred to in subsec. (c)(2), was in the original a reference to "},{"tag":"ref","attrib":{"href":"/us/pl/105/292/s605"},"text":"section 605 of Pub. L. 105–292","children":[],"tail":", which was renumbered section 606 by "},{"tag":"ref","attrib":{"href":"/us/pl/114/281/tV/s501/1"},"text":"Pub. L. 114–281, title V, § 501(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1437"},"text":"130 Stat. 1437","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Foreign Gifts and Decorations Act of 1966, referred to in subsec. (d)(2)(E), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/673"},"text":"Pub. L. 89–673","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-15"},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/952"},"text":"80 Stat. 952","children":[],"tail":", which was classified principally to chapter 37 (§ 2621 et seq.) of this title. The Act was substantially repealed, except for provisions which are classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2625"},"text":"section 2625 of this title","children":[],"tail":", and with limited applicability, to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2621"},"text":"section 2621 of this title","children":[],"tail":", and was restated in "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s7342"},"text":"section 7342 of Title 5","children":[],"tail":", Government Organization and Employees, by "},{"tag":"ref","attrib":{"href":"/us/pl/90/83/s10/b"},"text":"Pub. L. 90–83, § 10(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-09-11"},"text":"Sept. 11, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/224"},"text":"91 Stat. 224","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90b8b95b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94"},"text":"Pub. L. 116–94","children":[],"tail":" added subsecs. (f) and (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/75/s5/1"},"text":"Pub. L. 112–75, § 5(1)","children":[],"tail":", substituted “$250,000” for “$100,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/75/s5/2"},"text":"Pub. L. 112–75, § 5(2)","children":[],"tail":", substituted “Foreign Affairs” for “International Relations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/228"},"text":"Pub. L. 107–228","children":[],"tail":" substituted “The Commission may procure temporary and intermittent services under the authority of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109/b"},"text":"section 3109(b) of title 5","children":[],"tail":", except that the Commission may not expend more than $100,000 in any fiscal year to procure such services.” for “The Commission may not procure temporary and intermittent services under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109/b"},"text":"section 3109(b) of title 5","children":[],"tail":" or under other contracting authority other than that allowed under this subchapter.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
