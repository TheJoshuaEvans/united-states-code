{"tag":"section","attrib":{"id":"id8ebcc242-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284dd"},"text":null,"children":[{"tag":"num","attrib":{"value":"284dd"},"text":"§ 284dd.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Twentieth replenishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ebcc243-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284dd/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States Governor of the International Development Association is authorized to contribute on behalf of the United States $3,500,000,000 to the twentieth replenishment of the resources of the Association, subject to obtaining the necessary appropriations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ebcc244-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284dd/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to pay for the United States contribution provided for in subsection (a), there are authorized to be appropriated, without fiscal year limitation, $3,500,000,000 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ebcc245-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/565/s32"},"text":"Pub. L. 86–565, § 32","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dK/tVII/s7072/a"},"text":"Pub. L. 117–328, div. K, title VII, § 7072(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5091"},"text":"136 Stat. 5091","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
