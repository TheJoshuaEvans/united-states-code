{"tag":"section","attrib":{"id":"id8ff78b73-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2692"},"text":null,"children":[{"tag":"num","attrib":{"value":"2692"},"text":"§ 2692.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation for persons participating in State Department proceedings; availability of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ff78b74-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2692/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of State may compensate, pursuant to regulations which he shall prescribe, for the cost of participating in any proceeding or on any advisory committee or delegation of the Department of State, any organization or person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ff78b75-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2692/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is representing an interest which would not otherwise be adequately represented and whose participation is necessary for a fair determination of the issues taken as a whole; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff78b76-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2692/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who would otherwise be unable to participate in such proceeding or on such committee or delegation because such organization or person cannot afford to pay the costs of such participation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff78b77-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2692/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Of the funds appropriated for salaries and expenses for the Department of State, not to exceed $250,000 shall be available in any fiscal year for compensation under this section to such organizations and persons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ff78b78-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch841"},"text":"Aug. 1, 1956, ch. 841","children":[],"tail":", title I, § 22, as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/105/tI/s113/a"},"text":"Pub. L. 95–105, title I, § 113(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-17"},"text":"Aug. 17, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/848"},"text":"91 Stat. 848","children":[],"tail":"; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/97/241/tII/s202/a"},"text":"Pub. L. 97–241, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-08-24"},"text":"Aug. 24, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/282"},"text":"96 Stat. 282","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ff78b79-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ff78b7a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id8ff78b7b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/105/tI/s113/b"},"text":"Pub. L. 95–105, title I, § 113(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-17"},"text":"Aug. 17, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/849"},"text":"91 Stat. 849","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/105/tI/s113/b"},"text":"“Subsection (a) [enacting this section] shall become effective on ","children":[{"tag":"date","attrib":{"date":"1977-10-01"},"text":"October 1, 1977","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
