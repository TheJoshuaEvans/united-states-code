{"tag":"section","attrib":{"id":"id8ff9d631-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2706a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2706a"},"text":"§ 2706a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rewards payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may transfer to and merge with “Emergencies in the Diplomatic and Consular Service” for rewards payments and for expenses of rewards programs unobligated balances of funds appropriated under “Diplomatic and Consular Programs” for this fiscal year and for each fiscal year on and after ","children":[{"tag":"date","attrib":{"date":"2007-12-26"},"text":"December 26, 2007","children":[],"tail":", at no later than the end of the fifth fiscal year after the fiscal year for which any such funds were appropriated or otherwise made available."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ff9d632-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/dJ/tI"},"text":"Pub. L. 110–161, div. J, title I","children":[],"tail":" (part), "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2278"},"text":"121 Stat. 2278","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dK/tI"},"text":"Pub. L. 117–328, div. K, title I","children":[],"tail":", par. (6)(F), "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4975"},"text":"136 Stat. 4975","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ff9d633-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ff9d634-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8ff9d635-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Secretary, referred to in text, means the Secretary of State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8ff9d636-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" inserted “and for expenses of rewards programs” after “for rewards payments”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ff9d637-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8ff9d638-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References to Diplomatic and Consular Programs Account","children":[],"tail":null},{"tag":"p","attrib":{},"text":"References to the Diplomatic and Consular Programs account to be construed to include the Diplomatic Programs account in fiscal year 2020 and each fiscal year thereafter, see par. (7) of title I of div. G of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94"},"text":"Pub. L. 116–94","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":"."}],"tail":"