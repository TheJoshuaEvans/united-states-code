{"tag":"section","attrib":{"id":"id9062d159-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4062"},"text":null,"children":[{"tag":"num","attrib":{"value":"4062"},"text":"§ 4062.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unfunded liability obligations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9062d15a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4062/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of interest and military service credit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"At the end of each fiscal year, the Secretary of State shall notify the Secretary of the Treasury of the amount equivalent to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9062d15b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4062/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interest on the unfunded liability computed for that year at the interest rate used in the then most recent valuation of the System, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9062d15c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4062/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that portion of disbursement for annuities for that year which the Secretary of State estimates is attributable to credit allowed for military and naval service, less an amount determined by the Secretary of State to be appropriate to reflect the value of the deposits made to the credit of the Fund under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4045/e"},"text":"section 4045(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9062d15d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4062/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit to Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before closing the accounts for each fiscal year, the Secretary of the Treasury shall credit such amounts to the Fund, as a Government contribution, out of any money in the Treasury of the United States not otherwise appropriated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9062d15e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4062/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Requests for appropriations to the Fund under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4061/b"},"text":"section 4061(b) of this title","children":[],"tail":" shall include reports to the Congress on the sums credited to the Fund under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9062d15f-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s822"},"text":"Pub. L. 96–465, title I, § 822","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2121"},"text":"94 Stat. 2121","children":[],"tail":"; Ex. Ord. No. 12446, § 4(d), "},{"tag":"date","attrib":{"date":"1983-10-17"},"text":"Oct. 17, 1983","children":[],"tail":", 48 F.R. 48445.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9062d160-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9062d161-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9062d162-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1983—Subsec. (a)(2). Ex. Ord. No. 12446 inserted “, less an amount determined by the Secretary of State to be appropriate to reflect the value of the deposits made to the credit of the Fund under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4045/e"},"text":"section 4045(e) of this title","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9062d163-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9062d164-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1983 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by Ex. Ord. No. 12446 effective ","children":[{"tag":"date","attrib":{"date":"1983-10-17"},"text":"Oct. 17, 1983","children":[],"tail":", see section 4(e) of Ex. Ord. No. 12446, set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4067"},"text":"section 4067 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9062d165-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of provisions of law requiring submittal to Congress of any annual, semiannual, or other regular periodic report listed in House Document No. 103–7 (in which a report required under subsec. (c) of this section is listed on page 127), see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
