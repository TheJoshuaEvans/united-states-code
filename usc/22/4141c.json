{"tag":"section","attrib":{"id":"id90712917-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4141c"},"text":null,"children":[{"tag":"num","attrib":{"value":"4141c"},"text":"§ 4141c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Of the amounts authorized to be appropriated by section 101(a)(1) of the Foreign Relations Authorization Act, Fiscal Years 1990 and 1991, $100,000 for the fiscal year 1990 and $150,000 for the fiscal year 1991 shall be available only to carry out this subchapter. Sums appropriated for the purposes of this subchapter are authorized to remain available until expended.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id90712918-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s1204"},"text":"Pub. L. 96–465, title I, § 1204","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/246/tI/s149/b"},"text":"Pub. L. 101–246, title I, § 149(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-02-16"},"text":"Feb. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/41"},"text":"104 Stat. 41","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90712919-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9071291a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9071291b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"