{"tag":"section","attrib":{"id":"id90ef7ffc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7802"},"text":null,"children":[{"tag":"num","attrib":{"value":"7802"},"text":"§ 7802.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this chapter are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90ef7ffd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7802/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote respect for and protection of fundamental human rights in North Korea;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ef7ffe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7802/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote a more durable humanitarian solution to the plight of North Korean refugees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ef7fff-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7802/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote increased monitoring, access, and transparency in the provision of humanitarian assistance inside North Korea;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ef8000-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7802/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote the free flow of information into and out of North Korea; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ef8001-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7802/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote progress toward the peaceful reunification of the Korean peninsula under a democratic system of government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90ef8002-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/333/s4"},"text":"Pub. L. 108–333, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-18"},"text":"Oct. 18, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1290"},"text":"118 Stat. 1290","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
