{"tag":"section","attrib":{"id":"id8fbe5469-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431g"},"text":null,"children":[{"tag":"num","attrib":{"value":"2431g"},"text":"§ 2431g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservation Agreement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fbe546a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State is authorized, in consultation with other appropriate officials of the Federal Government, to enter into a Conservation Agreement with any eligible country concerning the operation and use of the Fund for that country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fbe546b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of Agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2430g/b"},"text":"section 2430g(b) of this title","children":[],"tail":" (relating to contents of an agreement) shall apply to an Agreement in the same manner as such requirements apply to an Americas Framework Agreement."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fbe546c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administering body","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fbe546d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431g/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts disbursed from the Fund in each beneficiary country shall be administered by a body constituted under the laws of that country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe546e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431g/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fbe546f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431g/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The administering body shall consist of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id8fbe5470-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431g/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more individuals appointed by the United States Government to serve in an official capacity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8fbe5471-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431g/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more individuals appointed by the government of the beneficiary country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8fbe5472-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431g/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" individuals who represent a broad range of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id8fbe5473-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431g/c/2/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environmental nongovernmental organizations of, or active in, the beneficiary country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id8fbe5474-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431g/c/2/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local community development nongovernmental organizations of the beneficiary country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id8fbe5475-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431g/c/2/A/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" scientific, academic, or forestry organizations of the beneficiary country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fbe5476-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431g/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A majority of the members of the administering body shall be individuals described in subparagraph (A)(iii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe5477-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431g/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2430g/c/3"},"text":"section 2430g(c)(3) of this title","children":[],"tail":" (relating to responsibilities of the administering body) shall apply to an administering body described in paragraph (1) in the same manner as such requirements apply to an administering body described in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2430g/c/1"},"text":"section 2430g(c)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fbe5478-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431g/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts deposited in a Fund shall be used only to provide grants to conserve, maintain, and restore the tropical forests and coral reef ecosystems in the beneficiary country, through one or more of the following activities:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fbe5479-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431g/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Establishment, restoration, protection, and maintenance of parks, protected areas, and reserves.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe547a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431g/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Development and implementation of scientifically sound systems of natural resource management, including land and ecosystem management practices.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe547b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431g/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Training programs to increase the scientific, technical, and managerial capacities of individuals and organizations involved in conservation efforts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe547c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431g/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Restoration, protection, or sustainable use of diverse animal and plant species.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe547d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431g/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Research and identification of medicinal uses of plant life to treat human diseases, illnesses, and health related concerns.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe547e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431g/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Development and support of the livelihoods of individuals dependent on a tropical forest or coral reef ecosystem and related resources in a manner consistent with conserving such resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fbe547f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431g/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant recipients","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fbe5480-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431g/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants made from a Fund shall be made to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fbe5481-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431g/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nongovernmental environmental, forestry, conservation, and indigenous peoples organizations of, or active in, the beneficiary country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fbe5482-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431g/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other appropriate local or regional entities of, or active in, the beneficiary country; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fbe5483-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431g/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in limited circumstances, the government of the beneficiary country when needed to improve governance and enhance management of tropical forests or coral reef ecosystems, without replacing existing levels of financial efforts by the government of the beneficiary country and with priority given to projects that complement grants made under subparagraphs (A) and (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe5484-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431g/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In providing grants under paragraph (1), priority shall be given to projects that are run by nongovernmental organizations and other private entities and that involve local communities in their planning and execution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fbe5485-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431g/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of larger grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any grant of more than $250,000 from a Fund must be approved by the Government of the United States and the government of the beneficiary country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fbe5486-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431g/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the event that a country ceases to meet the eligibility requirements set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2431c/a"},"text":"section 2431c(a) of this title","children":[],"tail":", as determined by the President pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2431c/b"},"text":"section 2431c(b) of this title","children":[],"tail":", then grants from the Fund for that country may only be made to nongovernmental organizations until such time as the President determines that such country meets the eligibility requirements set forth in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2431c/a"},"text":"section 2431c(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fbe5487-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. V, § 809, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/214/s1"},"text":"Pub. L. 105–214, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-29"},"text":"July 29, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/890"},"text":"112 Stat. 890","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/440/s8/a"},"text":"Pub. L. 115–440, § 8(a)","children":[],"tail":"–(d), "},{"tag":"date","attrib":{"date":"2019-01-14"},"text":"Jan. 14, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5583"},"text":"132 Stat. 5583","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fbe5488-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8fbe5489-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8fbe548a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/440/s8/a/1"},"text":"Pub. L. 115–440, § 8(a)(1)","children":[],"tail":", substituted “Conservation Agreement” for “Tropical Forest Agreement” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/440/s8/a/2"},"text":"Pub. L. 115–440, § 8(a)(2)","children":[],"tail":", (b), struck out par. (1) designation and heading, substituted “Conservation Agreement” for “Tropical Forest Agreement”, and struck out par. (2). Prior to amendment, text of par. (2) read as follows: “In the negotiation of such an Agreement, the Secretary shall consult with the Board in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2431i"},"text":"section 2431i of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/440/s8/d/1"},"text":"Pub. L. 115–440, § 8(d)(1)","children":[],"tail":", inserted “to serve in an official capacity” after “Government”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/440/s8/d/2/A"},"text":"Pub. L. 115–440, § 8(d)(2)(A)","children":[],"tail":", substituted “tropical forests and coral reef ecosystems” for “tropical forests” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/440/s8/d/2/B"},"text":"Pub. L. 115–440, § 8(d)(2)(B)","children":[],"tail":", struck out “tropical forest” before “plant”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/440/s8/d/2/C"},"text":"Pub. L. 115–440, § 8(d)(2)(C)","children":[],"tail":", substituted “dependent on a tropical forest or coral reef ecosystem and related resources in a manner consistent with conserving such resources” for “living in or near a tropical forest in a manner consistent with protecting such tropical forest”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/440/s8/c/1"},"text":"Pub. L. 115–440, § 8(c)(1)","children":[],"tail":", substituted “in limited circumstances, the government of the beneficiary country when needed to improve governance and enhance management of tropical forests or coral reef ecosystems, without replacing existing levels of financial efforts by the government of the beneficiary country and with priority given to projects that complement grants made under subparagraphs (A) and (B)” for “in exceptional circumstances, the government of the beneficiary country”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/440/s8/c/2"},"text":"Pub. L. 115–440, § 8(c)(2)","children":[],"tail":", amended subsec. (f) generally. Prior to amendment, text read as follows: “Any grant of more than $100,000 from a Fund shall be subject to veto by the Government of the United States or the government of the beneficiary country.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
