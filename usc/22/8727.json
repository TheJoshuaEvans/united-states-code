{"tag":"section","attrib":{"id":"id910e79f4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8727"},"text":null,"children":[{"tag":"num","attrib":{"value":"8727"},"text":"§ 8727.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of, and immigration restrictions on, senior officials of the Government of Iran and their family members","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id910e79f5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8727/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2012-08-10"},"text":"August 10, 2012","children":[],"tail":", and annually thereafter, the President shall publish a list of each individual the President determines is—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id910e79f6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8727/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a senior official of the Government of Iran described in subsection (b) that is involved in Iran’s—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id910e79f7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8727/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" illicit nuclear activities or proliferation of weapons of mass destruction or delivery systems for weapons of mass destruction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910e79f8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8727/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support for international terrorism; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910e79f9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8727/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commission of serious human rights abuses against citizens of Iran or their family members; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e79fa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8727/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a family member of such an official.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id910e79fb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8727/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Senior officials of the Government of Iran described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A senior official of the Government of Iran described in this subsection is any senior official of that Government, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id910e79fc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8727/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Supreme Leader of Iran;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e79fd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8727/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President of Iran;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e79fe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8727/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the Cabinet of the Government of Iran;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e79ff-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8727/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the Assembly of Experts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e7a00-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8727/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a senior member of the Intelligence Ministry of Iran; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e7a01-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8727/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a senior member of Iran’s Revolutionary Guard Corps, including a senior member of a paramilitary organization such as Ansar-e-Hezbollah or Basij-e Motaz’afin.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id910e7a02-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8727/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion from United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (d), the Secretary of State shall deny a visa to, and the Secretary of Homeland Security shall exclude from the United States, any alien who is on the list required by subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id910e7a03-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8727/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception to comply with United Nations Headquarters agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (c) shall not apply to an individual if admitting the individual to the United States is necessary to permit the United States to comply with the Agreement between the United Nations and the United States of America regarding the Headquarters of the United Nations, signed ","children":[{"tag":"date","attrib":{"date":"1947-06-26"},"text":"June 26, 1947","children":[],"tail":", and entered into force "},{"tag":"date","attrib":{"date":"1947-11-21"},"text":"November 21, 1947","children":[],"tail":", and other applicable international obligations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id910e7a04-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8727/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President may waive the application of subsection (a) or (c) with respect to an individual if the President—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id910e7a05-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8727/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determines that such a waiver is essential to the national interests of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e7a06-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8727/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 7 days before the waiver takes effect, notifies Congress of the waiver and the reason for the waiver.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id910e7a07-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/158/tII/s221"},"text":"Pub. L. 112–158, title II, § 221","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1238"},"text":"126 Stat. 1238","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id910e7a08-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id910e7a09-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8785/a"},"text":"section 8785(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
