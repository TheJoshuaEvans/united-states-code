{"tag":"section","attrib":{"id":"id90eac676-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7682"},"text":null,"children":[{"tag":"num","attrib":{"value":"7682"},"text":"§ 7682.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90eac677-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7682/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the President such sums as may be necessary for the fiscal year 2004 and each fiscal year thereafter to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s262p–8"},"text":"section 262p–8 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90eac678-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7682/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts appropriated pursuant to subsection (a) are authorized to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90eac679-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/25/tV/s503"},"text":"Pub. L. 108–25, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-05-27"},"text":"May 27, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/749"},"text":"117 Stat. 749","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
