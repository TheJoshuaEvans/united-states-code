{"tag":"section","attrib":{"id":"id8ede2ca1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–11"},"text":null,"children":[{"tag":"num","attrib":{"value":"290g–11"},"text":"§ 290g–11.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional authorization for payment of United States contribution","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ede2ca2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–11/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States Governor of the Fund is authorized to contribute on behalf of the United States $125,000,000 to the Fund as the United States contribution to the second replenishment of the resources of the Fund, except that any commitment to make such contribution shall be made subject to obtaining the necessary appropriations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ede2ca3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–11/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to pay for the United States contribution provided for in this section, there is authorized to be appropriated, without fiscal year limitation, $125,000,000 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ede2ca4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–11/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of keeping to a minimum the cost to the United States, the Secretary of the Treasury—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ede2ca5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–11/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall pay the United States contribution to the African Development Fund authorized by this section by letter of credit in three annual installments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ede2ca6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–11/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall take the steps necessary to obtain a certification from the Fund that any undisbursed balances resulting from draw-downs on such letter of credit will not exceed at any time the United States share of expected disbursement requirements for the following three-month period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ede2ca7-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/302/tII/s212"},"text":"Pub. L. 94–302, title II, § 212","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/259/tIII/s301/2"},"text":"Pub. L. 96–259, title III, § 301(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-03"},"text":"June 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/430"},"text":"94 Stat. 430","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
