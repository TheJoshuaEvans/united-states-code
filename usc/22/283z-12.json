{"tag":"section","attrib":{"id":"id8eba5159-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–12"},"text":null,"children":[{"tag":"num","attrib":{"value":"283z–12"},"text":"§ 283z–12.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to vote for and contribute to an increase in resources of the Fund for Special Operations; providing debt relief to Haiti","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8eba515a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–12/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vote authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s283c"},"text":"section 283c of this title","children":[],"tail":", the United States Governor of the Bank is authorized to vote in favor of a resolution to increase the resources of the Fund for Special Operations up to $479,000,000, in furtherance of providing debt relief for Haiti in view of the Cancun Declaration of "},{"tag":"date","attrib":{"date":"2010-03-21"},"text":"March 21, 2010","children":[],"tail":", which provides that:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8eba515b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–12/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Haiti’s debts to the Fund for Special Operations are to be cancelled;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8eba515c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–12/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Haiti’s remaining local currency conversion obligations to the Fund for Special Operations are to be cancelled;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8eba515d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–12/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" undisbursed balances of existing loans of the Fund for Special Operations to Haiti are to be converted to grants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8eba515e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–12/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Fund for Special Operations is to make available significant and immediate grant financing to Haiti as well as appropriate resources to other countries remaining as borrowers within the Fund for Special Operations, consistent with paragraph 6 of the Cancun Declaration of ","children":[{"tag":"date","attrib":{"date":"2010-03-21"},"text":"March 21, 2010","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8eba515f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–12/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contribution authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent and in the amount provided in advance in appropriations Acts the United States Governor of the Bank may, on behalf of the United States and in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s283c"},"text":"section 283c of this title","children":[],"tail":", contribute up to $252,000,000 to the Fund for Special Operations, which will provide for debt relief of:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8eba5160-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–12/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" up to $240,000,000 to the Fund for Special Operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8eba5161-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–12/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" up to $8,000,000 to the International Fund For Agricultural Development (IFAD); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8eba5162-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–12/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" up to $4,000,000 for the International Development Association (IDA).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8eba5163-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–12/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To pay for the contribution authorized under subsection (b), there are authorized to be appropriated, without fiscal year limitation, for payment by the Secretary of the Treasury $212,000,000, for the United States contribution to the Fund for Special Operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8eba5164-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/147/s40"},"text":"Pub. L. 86–147, § 40","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/212/tI/s1009"},"text":"Pub. L. 111–212, title I, § 1009","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2330"},"text":"124 Stat. 2330","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
