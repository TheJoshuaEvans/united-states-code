{"tag":"section","attrib":{"id":"id90037318-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2736a"},"text":"§ 2736a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recruitment and retention","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90037319-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9003731a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continue to seek a diverse and talented pool of applicants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9003731b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" instruct the Director General of the Foreign Service and the Director of the Bureau of Human Resources of the Department to have a recruitment plan of action for the recruitment of people belonging to traditionally under-represented groups, which should include outreach at appropriate colleges, universities, affinity groups, and professional associations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9003731c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The diversity recruitment initiatives described in subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9003731d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recruiting at women’s colleges, historically Black colleges and universities, minority-serving institutions, and other institutions serving a significant percentage of minority students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9003731e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" placing job advertisements in newspapers, magazines, and job sites oriented toward diverse groups;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9003731f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sponsoring and recruiting at job fairs in urban and rural communities and land-grant colleges or universities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90037320-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing opportunities through highly respected, international leadership programs, that focus on diversity recruitment and retention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90037321-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expanding the use of paid internships; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90037322-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cultivating partnerships with organizations dedicated to the advancement of the profession of international affairs and national security to advance shared diversity goals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90037323-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expand training on anti-harassment and anti-discrimination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90037324-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall, through the Foreign Service Institute and other educational and training opportunities—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90037325-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure the provision to all individuals in the workforce of training on anti-harassment and anti-discrimination information and policies, including in existing Foreign Service Institute courses or modules prioritized in the Department’s Diversity and Inclusion Strategic Plan for 2016–2020 to promote diversity in Bureau awards or mitigate unconscious bias;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90037326-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expand the provision of training on workplace rights and responsibilities to focus on anti-harassment and anti-discrimination information and policies, including policies relating to sexual assault prevention and response; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90037327-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736a/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" make such expanded training mandatory for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90037328-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736a/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals in senior and supervisory positions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90037329-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736a/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals having responsibilities related to recruitment, retention, or promotion of employees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9003732a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736a/c/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other individual determined by the Department who needs such training based on analysis by the Department or OPM analysis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9003732b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Best practices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Department shall give special attention to ensuring the continuous incorporation of research-based best practices in training provided under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9003732c-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dE/tLIV/s5403"},"text":"Pub. L. 117–81, div. E, title LIV, § 5403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2372"},"text":"135 Stat. 2372","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9003732d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9003732e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9003732f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Expansion of Diplomats in Residence Programs","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dF/tLXII/s6213"},"text":"Pub. L. 118–31, div. F, title LXII, § 6213","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/978"},"text":"137 Stat. 978","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/31/dF/tLXII/s6213"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than two years after the date of the enactment of this division [","children":[{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":"]—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary [of State] is authorized to increase the number of diplomats in the Diplomats in Residence Program from 17 to at least 20; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the United States Agency for International Development is authorized to increase the number of development diplomats in the Diplomats in Residence Program from 1 to at least 3.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than one year after the date of the enactment of this division, and every year for three years thereafter, the Secretary shall report to the appropriate congressional committees [Committee on Foreign Relations of the Senate and Committee on Foreign Affairs of the House of Representatives] whether additional Diplomats in Residence have been established, and, if so, what regions or colleges or universities such diplomats are assigned to, with an explanation as to why those regions or schools were chosen as most in need of additional Department [of State] recruiting personnel.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id90037330-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “Secretary” and “Department” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s5002"},"text":"section 5002 of Pub. L. 117–81","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s263c"},"text":"section 263c of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “diversity” and “workforce” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s5401"},"text":"section 5401 of Pub. L. 117–81","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2736"},"text":"section 2736 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
