{"tag":"section","attrib":{"id":"id8f28078c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1974"},"text":null,"children":[{"tag":"num","attrib":{"value":"1974"},"text":"§ 1974.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inapplicability of chapter to certain seizures","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The provisions of this chapter shall not apply with respect to a seizure made by a country at war with the United States or a seizure made in accordance with the provisions of any applicable convention or treaty, if that treaty or convention was made with advice and consent to ","children":[{"tag":"ref","attrib":{"idref":"fn002081"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002081"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “of”."}],"tail":" the Senate and was in force and effect for the United States and the seizing country at the time of the seizure."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f28078d-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-27/ch1018/s4"},"text":"Aug. 27, 1954, ch. 1018, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/883"},"text":"68 Stat. 883","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/364/tIII/s303/b"},"text":"Pub. L. 98–364, title III, § 303(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-17"},"text":"July 17, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/444"},"text":"98 Stat. 444","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f28078e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f28078f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f280790-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/364"},"text":"Pub. L. 98–364","children":[],"tail":" substituted “any applicable convention or treaty, if that treaty or convention was made with advice and consent to the Senate and was in force and effect for the United States and the seizing country at the time of the seizure” for “any fishery convention or treaty to which the United States is a party”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f280791-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8f280792-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/364"},"text":"Pub. L. 98–364","children":[],"tail":" applicable with respect to seizures made after "},{"tag":"date","attrib":{"date":"1983-04-01"},"text":"Apr. 1, 1983","children":[],"tail":", by foreign countries of vessels of the United States, see "},{"tag":"ref","attrib":{"href":"/us/pl/98/364/s303/c"},"text":"section 303(c) of Pub. L. 98–364","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s1972"},"text":"section 1972 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
